<div class="swse-shell-surface swse-shell-surface--messenger" data-shell-region="surface-messenger" data-surface-id="{{vm.id}}">
  <div class="swse-shell-surface__header swse-messenger-header">
    <button class="swse-shell-surface__back-btn" data-shell-action="return-to-home" type="button" title="Return to Home">
      <i class="fas fa-arrow-left"></i>
      <span>Home</span>
    </button>

    <div class="swse-shell-surface__title swse-messenger-titlemark">
      <span class="swse-home-header__icon">✉</span>
      <span>HOLOCOM MESSENGER</span>
      {{#if vm.unreadCount}}<span class="swse-messenger-titlemark__badge">{{vm.unreadCount}}</span>{{/if}}
    </div>

    <div class="swse-home-header__actions">
      <button class="swse-home-header__notice-btn" data-shell-action="open-notifications" type="button" title="Holonet alerts">
        <span class="swse-home-header__notice-icon">◌</span>
        <span>Alerts</span>
        {{#if vm.notificationCenter.totalUnread}}<span class="swse-home-header__notice-badge">{{vm.notificationCenter.totalUnread}}</span>{{/if}}
      </button>
      <div class="swse-home-header__actor">{{vm.actorName}}</div>
    </div>
  </div>

  {{#if vm.error}}
  <div class="swse-shell-surface__body swse-messenger-body swse-messenger-body--error">
    <section class="swse-messenger-main swse-panel">
      <div class="swse-panel__title">Messenger Offline</div>
      <div class="swse-messenger-empty swse-messenger-empty--error">{{vm.error}}</div>
    </section>
  </div>
  {{else}}
  <div class="swse-shell-surface__body swse-messenger-body">
    <aside class="swse-messenger-threads swse-panel">
      <div class="swse-messenger-panel-head">
        <div>
          <div class="swse-panel__title">Inbox</div>
          <div class="swse-messenger-panel-subtitle">Private Holonet threads</div>
        </div>
        <button class="swse-messenger-new-btn" data-shell-action="messenger-compose" type="button" title="Start a new transmission">
          <span>＋</span>
          <b>New</b>
        </button>
      </div>

      <div class="swse-messenger-privacy-note">
        <span class="swse-messenger-privacy-note__icon">◇</span>
        <span>{{vm.privacyNote}}</span>
      </div>

      <div class="swse-messenger-thread-list">
        {{#if vm.threads.length}}
          {{#each vm.threads}}
          <button class="swse-messenger-thread {{#if (eq ../vm.selectedThreadId this.id)}}active{{/if}}" data-thread-id="{{this.id}}" type="button">
            <span class="swse-messenger-thread__avatar">
              {{#if this.contactAvatar}}
              <img src="{{this.contactAvatar}}" alt="">
              {{else}}
              <span>{{#if this.hasNpcContact}}◇{{else}}✦{{/if}}</span>
              {{/if}}
            </span>
            <span class="swse-messenger-thread__content">
              <span class="swse-messenger-thread__topline">
                <span class="swse-messenger-thread__title">{{this.title}}</span>
                {{#if this.unreadCount}}
                <span class="swse-messenger-thread__badge">{{this.unreadCount}}</span>
                {{/if}}
              </span>
              <span class="swse-messenger-thread__chips">
                {{#if this.hasNpcContact}}<span class="swse-messenger-chip swse-messenger-chip--npc">NPC</span>{{/if}}
                {{#if this.isPlayerPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private">Private</span>{{/if}}
                {{#if this.isGmVisible}}<span class="swse-messenger-chip swse-messenger-chip--gm">GM visible</span>{{/if}}
              </span>
              <span class="swse-messenger-thread__preview">{{this.preview}}</span>
              <span class="swse-messenger-thread__time">{{this.updatedLabel}}</span>
            </span>
          </button>
          {{/each}}
        {{else}}
          <div class="swse-messenger-empty">No transmissions yet. Start with a player, GM, or established contact.</div>
        {{/if}}
      </div>
    </aside>

    <section class="swse-messenger-main swse-panel">
      {{#if vm.isComposingNew}}
      <div class="swse-messenger-compose-shell">
        <div class="swse-messenger-conversation-head">
          <div>
            <div class="swse-panel__title">New Transmission</div>
            <div class="swse-messenger-panel-subtitle">Choose recipients, then send a private thread.</div>
          </div>
          {{#if vm.threads.length}}
          <button class="swse-messenger-ghost-btn" data-shell-action="messenger-cancel-compose" type="button">Cancel</button>
          {{/if}}
        </div>

        <form class="swse-messenger-compose-new" data-holonet-action="send-message">
          <div class="swse-messenger-recipient-picker">
            <div class="swse-messenger-recipient-picker__bar">
              <div>
                <div class="swse-messenger-recipient-picker__title">Recipients</div>
                <div class="swse-messenger-recipient-picker__hint">NPC contacts appear only after they have opened a thread with you.</div>
              </div>
              <input class="swse-messenger-contact-search" data-contact-search type="search" placeholder="Search contacts..." autocomplete="off">
            </div>
            <div class="swse-messenger-contact-tabs" data-contact-tabs>
              <button type="button" class="active" data-contact-filter="all">All</button>
              <button type="button" data-contact-filter="player">Players</button>
              <button type="button" data-contact-filter="gm">GM</button>
              <button type="button" data-contact-filter="npc">NPC Contacts</button>
            </div>

            <div class="swse-messenger-recipient-groups">
              {{#if vm.recipientGroups.length}}
                {{#each vm.recipientGroups}}
                <section class="swse-messenger-recipient-group" data-contact-group="{{this.key}}">
                  <div class="swse-messenger-recipient-group__title">{{this.label}}</div>
                  <div class="swse-messenger-recipient-grid">
                    {{#each this.options}}
                    <label class="swse-messenger-recipient-option" data-contact-option data-contact-category="{{this.category}}" data-contact-label="{{this.label}} {{this.subtitle}} {{this.typeLabel}}">
                      <input type="checkbox" name="recipientIds" value="{{this.id}}">
                      <span class="swse-messenger-recipient-option__avatar">
                        {{#if this.avatar}}<img src="{{this.avatar}}" alt="">{{else}}<span>{{#if (eq this.category "npc")}}◇{{else}}✦{{/if}}</span>{{/if}}
                      </span>
                      <span class="swse-messenger-recipient-option__body">
                        <span class="swse-messenger-recipient-option__label">{{this.label}}</span>
                        <span class="swse-messenger-recipient-option__subtitle">{{this.subtitle}}</span>
                      </span>
                      <span class="swse-messenger-recipient-option__type swse-messenger-recipient-option__type--{{this.category}}">{{this.typeLabel}}</span>
                    </label>
                    {{/each}}
                  </div>
                </section>
                {{/each}}
              {{else}}
                <div class="swse-messenger-empty">No eligible recipients are available.</div>
              {{/if}}
            </div>
          </div>

          <textarea name="body" rows="5" placeholder="Compose transmission..." data-holonet-editor="message"></textarea>
          <div class="swse-messenger-composer__meta">
            <div class="swse-messenger-help">
              {{#each vm.composerHelp}}<span>{{this}}</span>{{/each}}
            </div>
            <button type="submit" class="swse-btn swse-btn--primary">Transmit</button>
          </div>
        </form>
      </div>
      {{else}}
        {{#if vm.selectedThread}}
        <div class="swse-messenger-conversation-head">
          <div class="swse-messenger-conversation-head__identity">
            <div class="swse-panel__title">{{vm.selectedThread.title}}</div>
            <div class="swse-messenger-panel-subtitle">{{vm.selectedContactSummary}}</div>
          </div>
          <div class="swse-messenger-conversation-head__chips">
            {{#if vm.selectedThread.hasNpcContact}}<span class="swse-messenger-chip swse-messenger-chip--npc">NPC contact</span>{{/if}}
            {{#if vm.selectedThread.isPlayerPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private">Private thread</span>{{/if}}
            <span class="swse-messenger-chip swse-messenger-chip--gm">GM visible</span>
          </div>
        </div>

        <div class="swse-messenger-conversation" data-thread-id="{{vm.selectedThread.id}}">
          {{#if vm.messages.length}}
            {{#each vm.messages}}
            <article class="swse-msg {{#if this.isOwn}}swse-msg--own{{/if}} {{#if this.isUnread}}swse-msg--unread{{/if}}">
              <div class="swse-msg__avatar">
                {{#if this.senderAvatar}}<img src="{{this.senderAvatar}}" alt="">{{else}}<span>✦</span>{{/if}}
              </div>
              <div class="swse-msg__packet">
                <div class="swse-msg__meta">
                  <span class="swse-msg__sender">{{this.senderLabel}}</span>
                  <span class="swse-msg__kind">{{this.senderKind}}</span>
                  <span class="swse-msg__time">{{this.createdAt}}</span>
                </div>
                <div class="swse-msg__body">{{{this.bodyHtml}}}</div>
              </div>
            </article>
            {{/each}}
          {{else}}
            <div class="swse-messenger-empty">Thread is empty.</div>
          {{/if}}
        </div>

        <form class="swse-messenger-composer" data-holonet-action="send-message" data-thread-id="{{vm.selectedThread.id}}">
          <textarea name="body" rows="3" placeholder="Reply to thread..." data-holonet-editor="message"></textarea>
          <div class="swse-messenger-composer__meta">
            <div class="swse-messenger-help">
              {{#each vm.composerHelp}}<span>{{this}}</span>{{/each}}
            </div>
            <button type="submit" class="swse-btn swse-btn--primary">Send</button>
          </div>
        </form>
        {{else}}
        <div class="swse-messenger-empty swse-messenger-empty--center">
          <div class="swse-messenger-empty__glyph">✉</div>
          <div>No thread selected.</div>
          <button class="swse-messenger-new-btn swse-messenger-new-btn--large" data-shell-action="messenger-compose" type="button">New Transmission</button>
        </div>
        {{/if}}
      {{/if}}
    </section>
  </div>
  {{/if}}
</div>
