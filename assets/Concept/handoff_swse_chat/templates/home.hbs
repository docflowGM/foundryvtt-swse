{{!-- GM Datapad home surface — redesigned as command center dashboard.
     Uses appClusters (already built by _buildAppClusters) and urgentApps.
     All data-app-card and data-nav-to hooks preserved unchanged.
     Add `urgentApps` to _prepareContext in gm-datapad.js (see PATCH_NOTES.md).
--}}
<div class="gm-datapad-page gm-datapad-home" data-shell-region="surface-home">

  {{!-- ── CRITICAL ACTIONS RAIL ──────────────────────────────────────────── --}}
  {{!-- Hidden when no urgent items. Show any app with statusTone=crit & badge --}}
  <div class="gm-home-urgent-rail {{#unless urgentApps.length}}gm-home-urgent-rail--hidden{{/unless}}"
       aria-label="Critical actions requiring GM attention">
    <div class="gm-home-urgent-eyebrow">
      <i class="fa-solid fa-circle-exclamation"></i>
      Critical — Requires Immediate GM Action
    </div>
    {{#each urgentApps}}
    <button class="gm-urgent-action" data-nav-to="{{this.id}}" type="button">
      <i class="{{this.icon}}"></i>
      <span>{{this.badgeCount}} {{this.label}}</span>
    </button>
    {{/each}}
  </div>

  {{!-- ── APP CLUSTERS ─────────────────────────────────────────────────────── --}}
  {{!-- Two columns: Operations (left), Economy+Holonet+Config (right) --}}
  <div class="gm-app-clusters">

    {{!-- LEFT COLUMN: Operations cluster --}}
    {{#with (lookup appClusters 0)}}
    <div class="gm-app-cluster">
      <div class="gm-cluster-header">
        <h4>{{this.label}}</h4>
        <span class="gm-cluster-count {{this.tone}}">{{this.countLabel}}</span>
      </div>
      <div class="gm-cluster-apps">
        {{#each this.apps}}
        <button class="gm-app-row {{this.statusTone}}"
                data-app-card="{{this.id}}"
                data-route-id="{{this.id}}"
                title="{{this.description}}"
                type="button">
          <div class="gm-app-row-code">{{this.code}}</div>
          <div class="gm-app-row-icon"><i class="{{this.icon}}"></i></div>
          <div class="gm-app-row-body">
            <div class="gm-app-row-label">{{this.label}}</div>
            <div class="gm-app-row-desc">{{this.description}}</div>
          </div>
          {{#if this.badgeCount}}
          <div class="gm-app-row-badge {{this.badgeType}}">{{this.badgeCount}}</div>
          {{/if}}
        </button>
        {{/each}}
      </div>
    </div>
    {{/with}}

    {{!-- RIGHT COLUMN: Economy / Holonet / Configuration clusters --}}
    <div class="gm-app-cluster-col">
      {{#each appClusters}}
      {{#unless (eq @index 0)}}
      <div class="gm-app-cluster">
        <div class="gm-cluster-header">
          <h4>{{this.label}}</h4>
          <span class="gm-cluster-count {{this.tone}}">{{this.countLabel}}</span>
        </div>
        <div class="gm-cluster-apps">
          {{#each this.apps}}
          <button class="gm-app-row {{this.statusTone}}"
                  data-app-card="{{this.id}}"
                  data-route-id="{{this.id}}"
                  title="{{this.description}}"
                  type="button">
            <div class="gm-app-row-code">{{this.code}}</div>
            <div class="gm-app-row-icon"><i class="{{this.icon}}"></i></div>
            <div class="gm-app-row-body">
              <div class="gm-app-row-label">{{this.label}}</div>
              <div class="gm-app-row-desc">{{this.description}}</div>
            </div>
            {{#if this.badgeCount}}
            <div class="gm-app-row-badge {{this.badgeType}}">{{this.badgeCount}}</div>
            {{/if}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/unless}}
      {{/each}}
    </div>

  </div>
</div>
