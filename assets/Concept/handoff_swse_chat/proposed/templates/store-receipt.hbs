{{!--
  New: templates/chat/store-receipt.hbs

  Rendered by StoreReceiptChat.fromHook() and posted via SWSEChat.postHTML
  with `whisper: [...actorOwnerUserIds]`.

  Required context:
    transactionId        ← UUID
    sourceType           ← 'purchase' | 'approval' | 'denial' | 'credit-transfer' | 'credit-grant' | 'refund' | 'party-fund'
    deltaDirection       ← 'positive' | 'negative' | 'neutral'
    kindLabel            ← short header label ('Purchase', 'Approved', 'Denied', 'Transfer', 'Grant', 'Refund')
    vlabel               ← long vertical mast label
    meta                 ← array of chips (vendor, dashboard name, timestamp)
    title                ← receipt title (one line)
    itemsHtml            ← already-escaped HTML or plain text describing items
    chipSvg              ← optional inline SVG path string (engine picks a glyph per source-type)

  Balance fields — all numbers, formatted by helper {{formatCredits n}}.
    previousLabel        ← 'Previous' | 'Your Previous'
    previousCredits
    deltaArrowLabel      ← 'spent' | 'received' | 'sent' | 'cost' | 'no change'
    deltaCredits         ← signed integer (negative for purchases, positive for grants)
    finalLabel           ← 'New Balance' | 'Your New Balance'
    finalCredits

  Footer:
    fromLabel / toLabel  ← present on credit-transfer
    actorName            ← buyer for purchases, grantor for grants
    issuerLabel          ← 'Approved by: GM', 'Denied by: GM', 'Issued by: GM'
    actions              ← optional array of buttons: {label, dataset:{...}}
--}}

<div class="swse-receipt-card"
     data-swse-chat-type="store-receipt"
     data-store-transaction-id="{{transactionId}}"
     data-store-source-type="{{sourceType}}"
     data-store-delta-direction="{{deltaDirection}}">

  <div class="rc-mast">
    <span class="rc-chip" aria-hidden="true">
      {{{chipSvg}}}
    </span>
    <span class="rc-vlbl">{{vlabel}}</span>
  </div>

  <div class="rc-body">
    <div class="rc-head">
      <span class="kind">{{kindLabel}}</span>
      {{#each meta}}
        <span class="sep"></span><span>{{this}}</span>
      {{/each}}
    </div>

    <div class="rc-title">{{title}}</div>
    {{#if itemsHtml}}<div class="rc-items">{{{itemsHtml}}}</div>{{/if}}

    <div class="rc-ledger">
      <div class="rc-cell">
        <span class="k">{{previousLabel}}</span>
        <span class="v">{{formatCredits previousCredits}}<span class="cr">cr</span></span>
      </div>
      <div class="rc-delta">
        <span class="arrow">{{deltaArrowLabel}}</span>
        <span class="amt">{{formatDelta deltaCredits}}</span>
      </div>
      <div class="rc-cell right new">
        <span class="k">{{finalLabel}}</span>
        <span class="v">{{formatCredits finalCredits}}<span class="cr">cr</span></span>
      </div>
    </div>

    <div class="rc-foot">
      {{#if fromLabel}}<span class="who">From: <b>{{fromLabel}}</b> &nbsp;→&nbsp; To: <b>{{toLabel}}</b></span>{{/if}}
      {{#if actorName}}<span class="who">{{#if (eq sourceType "purchase")}}Buyer{{else}}Actor{{/if}}: <b>{{actorName}}</b></span>{{/if}}
      {{#if issuerLabel}}<span class="who">{{issuerLabel}}</span>{{/if}}
      <span class="tx">{{transactionId}}</span>
    </div>

    {{#if actions}}
    <div class="rc-actions">
      {{#each actions}}
        <button type="button"
                class="rc-btn"
                {{#each dataset}}data-{{@key}}="{{this}}" {{/each}}>{{label}}</button>
      {{/each}}
    </div>
    {{/if}}
  </div>
</div>
