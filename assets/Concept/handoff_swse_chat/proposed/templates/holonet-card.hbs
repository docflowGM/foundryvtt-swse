{{!--
  New: templates/chat/holonet-card.hbs

  Rendered by HolonetChatCard.fromRecord() and posted via SWSEChat.postHTML
  with `whisper: record.recipients` (so non-recipients never see it).

  Required context:
    rail            ← optional CSS color override (else CSS picks from priority/source)
    priority        ← 'urgent' | 'alert' | 'secure' (optional)
    source          ← 'gm' | 'npc'
    direction       ← 'outgoing' for the sender's own copy
    recordId        ← HolonetRecord.id
    threadId        ← HolonetThread.id
    unread          ← boolean
    priorityLabel   ← e.g. 'Urgent', 'DM', 'Alert', 'Sent'
    meta            ← array of small chips (channel, encryption, timestamp)
    fromLabel       ← who the message is from (formatted)
    relayLabel      ← optional relay/channel suffix
    subject         ← message subject / first line
    preview         ← short preview (sanitized)
    attachmentCount ← integer (optional)
    actionLabel     ← button text, e.g. 'Open Holochat' (default)
--}}

<div class="swse-holonet-card"
     role="button" tabindex="0"
     {{#if priority}}data-priority="{{priority}}"{{/if}}
     {{#if source}}data-source="{{source}}"{{/if}}
     {{#if direction}}data-direction="{{direction}}"{{/if}}
     data-holonet-record-id="{{recordId}}"
     data-holonet-thread-id="{{threadId}}"
     data-holonet-action="open-thread"
     {{#if rail}}style="--rail: {{rail}};"{{/if}}>
  {{#if unread}}<span class="unread" aria-label="Unread"></span>{{/if}}

  <div class="mast">
    <span class="antenna" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        {{#if (eq direction "outgoing")}}
          <path d="M12 20 V12"/>
          <path d="M6 16 Q12 10 18 16"/>
          <path d="M3 19 Q12 7 21 19" opacity="0.45"/>
          <circle cx="12" cy="10.5" r="1.4" fill="currentColor"/>
        {{else}}
          <path d="M12 4 V12"/>
          <path d="M6 8 Q12 14 18 8"/>
          <path d="M3 5 Q12 17 21 5" opacity="0.55"/>
          <circle cx="12" cy="13.5" r="1.4" fill="currentColor"/>
        {{/if}}
      </svg>
    </span>
    <span class="vlbl">{{vlabel}}</span>
  </div>

  <div class="htbody">
    <div class="htmeta">
      <span class="pri">{{priorityLabel}}</span>
      {{#each meta}}
        <span class="sep"></span>
        <span>{{this}}</span>
      {{/each}}
    </div>
    <div class="htfrom">
      {{fromLabel}}
      {{#if relayLabel}}<span class="relay">// {{relayLabel}}</span>{{/if}}
    </div>
    <div class="htsubject">{{subject}}</div>
    {{#if preview}}<div class="htprev">{{preview}}</div>{{/if}}
  </div>

  <div class="htgo">
    <span class="arrow">▸</span>
    <span>{{#if actionLabel}}{{actionLabel}}{{else}}Open<br/>Holochat{{/if}}</span>
  </div>
</div>
