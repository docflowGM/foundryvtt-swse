{
  "schemaVersion": 3,
  "purpose": "Canonical option registry for feat and talent choices that must be resolved immediately at selection time or backfilled later.",
  "notes": [
    "Phase 2 establishes backend choice-source models for future dialogs/backfill.",
    "fixed choices are explicit option lists printed by the feat.",
    "prerequisiteDerived choices are resolved from actor state created by provider feats.",
    "grantPool choices are deferred to their dedicated progression registries.",
    "Weapon Proficiency is one grouped feat. Exotic proficiency is a nested branch, not a separate primary choice surface.",
    "Phase 6 maps supported selected-choice feats to executable modifier/unlock metadata while leaving attack-option feats as rule hooks until roll context consumes them."
  ],
  "choiceKinds": {
    "weapon_proficiency": {
      "label": "Weapon Proficiency",
      "mode": "nested",
      "repeatable": true,
      "steps": [
        "weapon_group",
        "exotic_category_when_needed",
        "specific_exotic_weapon_when_needed"
      ],
      "choiceSource": "fixed",
      "provides": "weapon_proficiency",
      "storagePath": "flags.swse.choices.weaponProficiency",
      "resultShape": {
        "group": "<weapon group id>",
        "category": "<exotic category when group is exotic>",
        "weapon": "<specific exotic weapon when group is exotic>"
      }
    },
    "weapon_focus": {
      "label": "Weapon Focus",
      "mode": "weapon_group_or_exotic_weapon",
      "repeatable": true,
      "requiresExistingProficiency": true,
      "choiceSource": "prerequisiteDerived",
      "derivesFrom": [
        "weapon_proficiency"
      ],
      "consumes": "weapon_proficiency",
      "provides": "weapon_focus",
      "storagePath": "flags.swse.choices.weapon_focus",
      "allowedFromActor": "weaponProficiencies",
      "effectTarget": "attack.bonus",
      "effectValue": 1
    },
    "weapon_specialization": {
      "label": "Weapon Specialization",
      "mode": "weapon_group_or_exotic_weapon",
      "repeatable": true,
      "requiresExistingWeaponFocus": true,
      "choiceSource": "prerequisiteDerived",
      "derivesFrom": [
        "weapon_focus"
      ],
      "consumes": "weapon_focus",
      "provides": "weapon_specialization",
      "storagePath": "flags.swse.choices.weapon_specialization",
      "effectTarget": "damage.weapon",
      "effectValue": 2
    },
    "skill_focus": {
      "label": "Skill Focus",
