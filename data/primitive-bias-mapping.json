  "implementation_notes": {
    "note_1": "All mappings are additive. Never subtract or override.",
    "note_2": "CONDITIONAL primitives apply weight factor (0.5–1.0). Apply weight multiplier to mechanicalBias values.",
    "note_3": "STRUCTURAL_ACCESS primitives require secondary lookup. Do NOT apply mapping here; extract primitive instead.",
    "note_4": "attributeBias values use ability score deltas (e.g., 1 = +1 to ability).",
    "note_5": "All mechanical bias values should be 0.1–0.5 range for proportional contribution.",
    "note_6": "Role bias contributions should be 0.1–0.25 for subsidiary roles.",
    "note_7": "If primitive has multiple bonuses (e.g., +2 to melee, +1 morale), apply all applicable mappings.",
    "note_8": "Never use feat name or tag to infer bias. Use only primitive type and target fields."
  }
