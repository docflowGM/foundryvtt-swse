  "featGrant": {
    "description": "Grants a feat (STRUCTURAL ACCESS)",
    "note": "Do NOT apply bias here. Recursively extract primitives from granted feat.",
    "rule": "if primitive.type === 'featGrant': lookup feat by name; process its rules instead"
  },

  "featPattern": {
    "description": "Pattern-based feat grant (STRUCTURAL ACCESS)",
    "note": "Resolve all matching feats, extract their primitives",
    "rule": "Resolve feat pattern, process all matching feats' primitives"
  },

  "talentFromTree": {
