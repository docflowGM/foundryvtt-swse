  "schemaVersion": 1,
  "phase": "7C.5",
  "status": "skeleton_only",
  "intent": {
    "description": "Defines the expanded feat bucket and subbucket taxonomy for future feat metadata migration without modifying existing feat records.",
    "noCatalogMutation": true,
    "primaryBucketRequiredInFuture": true,
    "primarySubbucketRequiredInFuture": true,
    "secondaryBucketsAllowed": true,
    "tagsRemainCrossCuttingSearchHints": true,
    "taxonomyReviewRule": "Do not classify feats from title keywords alone. Use prerequisites, benefit text, runtime mechanics, and source context. If classification is 50/50, mark the feat for source review instead of guessing."
  },
  "futureFeatFields": {
    "bucket": "Primary top-level feat bucket used by the feat browser.",
    "subbucket": "Primary subbucket within the selected bucket.",
    "secondaryBuckets": "Optional additional discoverability buckets; never replaces the primary bucket.",
    "taxonomyConfidence": "high | medium | source_review_required",
    "taxonomyReviewed": "Boolean indicating whether a human/source-aware pass reviewed the assignment.",
    "sourceReviewReason": "Required when taxonomyConfidence is source_review_required."
  },
