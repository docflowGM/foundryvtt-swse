{
  "schemaVersion": 2,
  "phase": "1-core-web-feats",
  "scope": "Star Wars Saga Edition core rulebook feat families plus Saga Edition Web Enhancement 1: Tech Specialist",
  "purpose": "Conservative source-parity manifest used by scripts/dev/audit-core-web-feat-parity.mjs. This file tracks feat presence, choice scoping, prerequisite shape, and implementation classification. It intentionally avoids copying full protected rules text.",
  "sourceNotes": [
    "Core rulebook feat families are represented as families where the Foundry catalog may use one document with a required choice or multiple scoped feat documents.",
    "Tech Specialist comes from Saga Edition Web Enhancement 1 and is treated as a manual workflow until a dedicated modification UI exists.",
    "Do not treat this manifest as rules text. It is implementation metadata for parity auditing. Add page references or internal notes locally as needed.",
    "Updated against foundryvtt-swse-main (3).zip on 2026-06-30: removed Devastating Attack and Improved Initiative from Phase 1 expectations because the current SWSE catalog/source pass does not support them as core feats. Devastating Attack appears in stat blocks as a talent/special action, not as a feat entry. Improved Initiative is not a SWSE core feat entry in the uploaded source scan."
  ],
  "implementationClasses": {
    "passiveActorMath": "Should alter actor-derived stats or roll math without a modal after acquisition.",
    "passiveRollMath": "Should alter an attack/skill/ability roll when context matches.",
    "activeCombatOption": "Should appear as an optional combat toggle/action and affect a specific roll/action.",
    "scopedChoice": "Requires a selected skill, weapon group, weapon, attack category, or similar scope at acquisition.",
    "manualWorkflow": "Requires a dedicated workflow/app or GM handling; acquisition can be legal but effect should be advisory until workflow exists.",
    "advisory": "Rules impact is mostly descriptive, tactical, or too contextual for safe automation."
  },
