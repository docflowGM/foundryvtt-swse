":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":40,"max":40,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":5,"size":"medium","speed":8,"defenses":{"reflex":{"total":18,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":19,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":18,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":16}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":0,"bab":4,"race":"","class":"","className":"","biography":"","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Nighthunter Guardian","cl":5,"tags":["beast"],"size":"medium","initiative":4,"senses":"Scent,\u00a0Perception\u00a0+11","perception":11,"reflexDefense":18,"flatFootedDefense":16,"fortitudeDefense":19,"willDefense":18,"hitPoints":40,"damageThreshold":null,"speed":"8 Squares","melee":"Bite +5* (1d6+6); Claws (2) +5* (1d4+6)","fightingSpace":"1 Square","reach":"1 Square","baseAttackBonus":4,"grapple":6,"speciesTraits":[],"abilities":{"strength":15,"dexterity":14,"constitution":18,"intelligence":2,"wisdom":17,"charisma":10},"feats":[],"skills":[],"abilityText":"","beastLevel":6}}},"items":[]}
{"_id":"fc0234e7fe1fa1ef","name":"Krayt Dragon","type":"npc","img":"icons/svg/mystery-man.svg","system":{"isDroid":false,"droidDegree":"","attributes":{"str":{"base":54,"racial":0,"enhancement":0,"temp":0},"dex":{"base":6,"racial":0,"enhancement":0,"temp":0},"con":{"base":48,"racial":0,"enhancement":0,"temp":0},"int":{"base":1,"racial":0,"enhancement":0,"temp":0},"wis":{"base":13,"racial":0,"enhancement":0,"temp":0},"cha":{"base":10,"racial":0,"enhancement":0,"temp":0}},"skills":{"acrobatics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"climb":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"deception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"endurance":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"con","favorite":false},"gatherInformation":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"initiative":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"jump":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"knowledgeBureaucracy":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeGalacticLore":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeLifeSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgePhysicalSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeSocialSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTactics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTechnology":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"mechanics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":399,"max":399,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":16,"size":"medium","speed":10,"defenses":{"reflex":{"total":16,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":30,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":12,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":16}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":0,"bab":12,"race":"","class":"","className":"","biography":"Camouflage:\u00a0A Krayt Dragon's natural coloration changes to mimic its surroundings. Krayt Dragons ignore their size modifier when they make\u00a0Stealth\u00a0checks.\nDevour:\u00a0If a\u00a0Krayt Dragon hits with its Bite attack against a Huge or smaller opponent, it can automatically make a\u00a0Grapple\u00a0check at its full bonus as a\u00a0Free Action. If the\u00a0Grapple\u00a0check is successful, the Krayt Dragon can begin Devouring its target. The creature being Devoured takes 1d8+22 points of damage each round at the start of its turn, before it takes any actions. When the creature reaches 0 Hit Points, it is swallowed by the Krayt Dragon and continues to take 1d6 points of\u00a0Acid\u00a0damage each round at the start of its turn.\nThe Krayt Dragon cannot make Bite attacks until it releases the creature (a\u00a0Free Action) or swallows it.\nTremorsense:\u00a0A Krayt Dragon automatically senses the location of anything that is in contact with the ground within 100 squares (no\u00a0Perception\u00a0check required).","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Krayt Dragon","cl":16,"tags":["beast"],"size":null,"initiative":6,"senses":"Low-Light Vision, Tremorsense,\u00a0Perception\u00a0+14","perception":14,"reflexDefense":16,"flatFootedDefense":16,"fortitudeDefense":30,"willDefense":12,"hitPoints":399,"damageThreshold":null,"speed":"10 Squares;\u00a0Powerful Charge","melee":"Bite +24* (4d6+40); Bite +28* (4d6+48) with\u00a0Powerful Charge; Tail Slap +24* (3d6+40)","fightingSpace":"8x8 Squares","reach":"6 Squares","baseAttackBonus":12,"grapple":54,"speciesTraits":[],"abilities":{"strength":54,"dexterity":6,"constitution":48,"intelligence":1,"wisdom":13,"charisma":10},"feats":["f8e2a30390d870e7","3f76464c43c73f84","e73873cdc77a6451","1592aaedf4b6e40a","a9f6de36f24ef202","3d4a4e93ced26712"],"skills":["Perception\u00a0+14,\u00a0Stealth\u00a0+16"],"abilityText":"Camouflage:\u00a0A Krayt Dragon's natural coloration changes to mimic its surroundings. Krayt Dragons ignore their size modifier when they make\u00a0Stealth\u00a0checks.\nDevour:\u00a0If a\u00a0Krayt Dragon hits with its Bite attack against a Huge or smaller opponent, it can automatically make a\u00a0Grapple\u00a0check at its full bonus as a\u00a0Free Action. If the\u00a0Grapple\u00a0check is successful, the Krayt Dragon can begin Devouring its target. The creature being Devoured takes 1d8+22 points of damage each round at the start of its turn, before it takes any actions. When the creature reaches 0 Hit Points, it is swallowed by the Krayt Dragon and continues to take 1d6 points of\u00a0Acid\u00a0damage each round at the start of its turn.\nThe Krayt Dragon cannot make Bite attacks until it releases the creature (a\u00a0Free Action) or swallows it.\nTremorsense:\u00a0A Krayt Dragon automatically senses the location of anything that is in contact with the ground within 100 squares (no\u00a0Perception\u00a0check required)."}}},"items":[]}
{"_id":"fc787e85ccc4ed7d","name":"Derriphan","type":"npc","img":"icons/svg/mystery-man.svg","system":{"isDroid":false,"droidDegree":"","attributes":{"str":{"base":6,"racial":0,"enhancement":0,"temp":0},"dex":{"base":18,"racial":0,"enhancement":0,"temp":0},"con":{"base":10,"racial":0,"enhancement":0,"temp":0},"int":{"base":2,"racial":0,"enhancement":0,"temp":0},"wis":{"base":16,"racial":0,"enhancement":0,"temp":0},"cha":{"base":8,"racial":0,"enhancement":0,"temp":0}},"skills":{"acrobatics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"climb":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"deception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"endurance":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"con","favorite":false},"gatherInformation":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"initiative":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"jump":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"knowledgeBureaucracy":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeGalacticLore":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeLifeSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgePhysicalSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeSocialSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTactics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTechnology":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"mechanics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":36,"max":36,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":7,"size":"medium","speed":8,"defenses":{"reflex":{"total":17,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":11,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":14,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":13}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":0,"bab":6,"race":"","class":"","className":"","biography":"Consume Force:\u00a0Whenever a Derriphan is targeted by a\u00a0Force Power\u00a0without the [Light Side] descriptor, the Derriphan immediately regains one spent\u00a0Force Power\u00a0as a\u00a0Reaction.\nDark Backlash:\u00a0Whenever a Derriphan is targeted by a\u00a0Force Power\u00a0with the [Mind-Affecting] descriptor, the creature activating that\u00a0Force Power\u00a0immediately takes 3d8 points of\u00a0Force\u00a0damage.\nPossession:\u00a0As a\u00a0Standard Action, a Derriphan can attempt to possess the body of an adjacent creature. The Derriphan makes an attack (1d20+9) against the\u00a0Reflex Defense: of the target; if the attack succeeds, the Derriphan enters the target's body.\nOnce inside, the Derriphan cannot be targeted by attacks or skill checks. Each round on its turn, the Derriphan makes a single attack (1d20+9) against the possessed creature's\u00a0Will Defense; a successful attack deals 3d8 points of\u00a0Force\u00a0damage to the target, and a failed attack deals half damage. If the target is reduced to 0 Hit Points by this attack, the Derriphan seizes mental control of the creature, restoring it to full Hit Points.\nWhile the Derriphan possesses a creature, the Derriphan controls all of its actions. The Derriphan-possessed creature has access to the Derriphan's\u00a0Force Power Suite\u00a0in addition to its own. The Derriphan uses whichever\u00a0Use the Force\u00a0skill bonus is higher, either its bonus or its host's bonus, and the Derriphan-possessed creature's\u00a0Dark Side Score\u00a0equals its\u00a0Wisdom\u00a0score for as long as it is possessed.\nIf a Derriphan-possessed creature is reduced to 0 Hit Points, the Derriphan exits that body as a\u00a0Reaction, appearing in an adjacent square of its choosing.","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Derriphan","cl":7,"tags":["beast"],"size":null,"initiative":8,"senses":"Darkvision,\u00a0Perception\u00a0+7","perception":7,"reflexDefense":17,"flatFootedDefense":13,"fortitudeDefense":11,"willDefense":14,"hitPoints":36,"damageThreshold":null,"speed":"8 Squares (Hovering)","melee":null,"fightingSpace":"1 Square","reach":"1 Square","baseAttackBonus":6,"grapple":0,"speciesTraits":[],"abilities":{"strength":6,"dexterity":18,"constitution":10,"intelligence":2,"wisdom":16,"charisma":8},"feats":["ddbeb23013d9e917","9b7b869a86f39190","f8e2a30390d870e7"],"skills":["Initiative\u00a0+8 (may reroll, must take second result),\u00a0Stealth\u00a0+8,\u00a0Use the Force\u00a0+8"],"abilityText":"Consume Force:\u00a0Whenever a Derriphan is targeted by a\u00a0Force Power\u00a0without the [Light Side] descriptor, the Derriphan immediately regains one spent\u00a0Force Power\u00a0as a\u00a0Reaction.\nDark Backlash:\u00a0Whenever a Derriphan is targeted by a\u00a0Force Power\u00a0with the [Mind-Affecting] descriptor, the creature activating that\u00a0Force Power\u00a0immediately takes 3d8 points of\u00a0Force\u00a0damage.\nPossession:\u00a0As a\u00a0Standard Action, a Derriphan can attempt to possess the body of an adjacent creature. The Derriphan makes an attack (1d20+9) against the\u00a0Reflex Defense: of the target; if the attack succeeds, the Derriphan enters the target's body.\nOnce inside, the Derriphan cannot be targeted by attacks or skill checks. Each round on its turn, the Derriphan makes a single attack (1d20+9) against the possessed creature's\u00a0Will Defense; a successful attack deals 3d8 points of\u00a0Force\u00a0damage to the target, and a failed attack deals half damage. If the target is reduced to 0 Hit Points by this attack, the Derriphan seizes mental control of the creature, restoring it to full Hit Points.\nWhile the Derriphan possesses a creature, the Derriphan controls all of its actions. The Derriphan-possessed creature has access to the Derriphan's\u00a0Force Power Suite\u00a0in addition to its own. The Derriphan uses whichever\u00a0Use the Force\u00a0skill bonus is higher, either its bonus or its host's bonus, and the Derriphan-possessed creature's\u00a0Dark Side Score\u00a0equals its\u00a0Wisdom\u00a0score for as long as it is possessed.\nIf a Derriphan-possessed creature is reduced to 0 Hit Points, the Derriphan exits that body as a\u00a0Reaction, appearing in an adjacent square of its choosing."}}},"items":[]}
