iscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":76,"max":76,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":7,"size":"medium","speed":6,"defenses":{"reflex":{"total":14,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":14,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":12,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":13}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":14,"bab":6,"race":"","class":"","className":"","biography":"Sonic Blast:\u00a0As a\u00a0Standard Action, a Storm Beast can emit a 6-Square\u00a0Cone\u00a0of destructive sonic energy originating at a point adjacent to it. It makes an attack roll against the\u00a0Fortitude Defense\u00a0of every creature in the\u00a0Cone, dealing full damage on a hit and half damage on a miss. This is an\u00a0Area Effect.","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Storm Beast","cl":7,"tags":["beast"],"size":"medium","initiative":5,"senses":"Perception\u00a0+6","perception":6,"reflexDefense":14,"flatFootedDefense":13,"fortitudeDefense":14,"willDefense":12,"hitPoints":76,"damageThreshold":14,"speed":"6 Squares","melee":"Claws (2) +10* (1d4+14); Claws (2) +10* (2d4+14) with\u00a0Mighty Swing","fightingSpace":"1 Square","reach":"1 Square","baseAttackBonus":6,"grapple":13,"speciesTraits":[],"abilities":{"strength":24,"dexterity":12,"constitution":19,"intelligence":2,"wisdom":14,"charisma":13},"feats":["ddbeb23013d9e917","dd2c0e394cdf08ba","3f76464c43c73f84"],"skills":["Endurance\u00a0+13"],"abilityText":"Sonic Blast:\u00a0As a\u00a0Standard Action, a Storm Beast can emit a 6-Square\u00a0Cone\u00a0of destructive sonic energy originating at a point adjacent to it. It makes an attack roll against the\u00a0Fortitude Defense\u00a0of every creature in the\u00a0Cone, dealing full damage on a hit and half damage on a miss. This is an\u00a0Area Effect.","beastLevel":8}}},"items":[]}
{"_id":"faa06321f785d61c","name":"Tibanna Mynock","type":"npc","img":"icons/svg/mystery-man.svg","system":{"isDroid":false,"droidDegree":"","attributes":{"str":{"base":2,"racial":0,"enhancement":0,"temp":0},"dex":{"base":18,"racial":0,"enhancement":0,"temp":0},"con":{"base":10,"racial":0,"enhancement":0,"temp":0},"int":{"base":1,"racial":0,"enhancement":0,"temp":0},"wis":{"base":12,"racial":0,"enhancement":0,"temp":0},"cha":{"base":8,"racial":0,"enhancement":0,"temp":0}},"skills":{"acrobatics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"climb":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"deception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"endurance":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"con","favorite":false},"gatherInformation":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"initiative":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"jump":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"knowledgeBureaucracy":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeGalacticLore":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeLifeSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgePhysicalSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeSocialSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTactics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTechnology":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"mechanics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":14,"max":14,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":1,"size":"medium","speed":6,"defenses":{"reflex":{"total":24,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":10,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":11,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":20}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":10,"bab":1,"race":"","class":"","className":"","biography":"Tibanna Pouch:\u00a0Tibanna Mynocks have dozens of small, leathery pouches all over their bodies that capture and hold pockets of Tibanna gas. When a Tibanna Mynock is killed, its Tibanna pouches rupture, filling a 2x2 square area with Tibanna gas. Whenever a creature enters this area, the gas makes an attack roll (1d20+10) against the creature's\u00a0Fortitude Defense.\nIf the attack succeeds, the target takes 2d6 points of damage (Other Tibanna Mynocks are immune to this effect). Additionally, a Tibanna gas cloud can be dissipated by firing a blaster bolt into it (Reflex Defense: 10 for one of the squares occupied by the gas). Doing so causes the cloud to burn up rapidly, dealing 4d6 points of energy damage to any creature in or adjacent to the gas.\n00:00\n41:20\nDinko\u00a0Statistics (CL 2)\nFine\u00a0Beast\u00a03\nDefenses\nOffense\nAttack Options:\u00a0Poison,\u00a0Weapon Finesse\nSpecial Actions:\u00a0Stench\nSpecies Traits:\u00a0Motion Vision, Poison, Scent, Stench,\u00a0Pack Traits\nBase Stats\nMotion Vision:\u00a0The eyes of a Dinko have evolved such that they see only movement. The creature takes a -5 penalty to attack rolls against opponents that have not moved in the previous round. Although a Dinko cannot see its opponent, its keen sense of smell alerts it to the presence of potential prey (See Scent).\nPoison:\u00a0If the Bite attack of a Dinko deals damage to a living target, the target is also poisoned. If the poison succeeds on an attack roll (1d20+8) against the target's\u00a0Fortitude Defense, the target moves -1 step along the\u00a0Condition Track.\nA target moved to the end of the\u00a0Condition Track\u00a0by the poison is\u00a0Immobilized, but not unconscious. The Poison attacks each round until cured with a successful DC 15\u00a0Treat Injury\u00a0check.\nScent:\u00a0Dinkos ignore\u00a0Concealment\u00a0and\u00a0Cover\u00a0when making\u00a0Perception\u00a0checks to\u00a0Notice\u00a0opponents within 10 squares, and they take no penalty from poor visibility when\u00a0Tracking.\nStench:\u00a0Dinkos exude a foul stench that nauseates most other creatures. If the Stench succeeds on an attack roll (1d20+5) against the target's\u00a0Fortitude Defense, the target becomes nauseated for 1 round. A nauseated target can make only a single\u00a0Move Action\u00a0that round. The Stench attacks each round that the target remains within 2 squares of the Dinko.","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Tibanna Mynock","cl":1,"tags":["beast"],"size":null,"initiative":10,"senses":"Motion Vision, Scent,\u00a0Perception\u00a0+7","perception":7,"reflexDefense":24,"flatFootedDefense":20,"fortitudeDefense":10,"willDefense":11,"hitPoints":14,"damageThreshold":10,"speed":"6 Squares","melee":"Bite +0 (1d4); Bite -3 (1) plus Poison","fightingSpace":"1 Square","reach":"1 Square","baseAttackBonus":1,"grapple":-15,"speciesTraits":[],"abilities":{"strength":2,"dexterity":18,"constitution":10,"intelligence":1,"wisdom":12,"charisma":8},"feats":["a9f6de36f24ef202","252b67d6e31c377e"],"skills":["Initiative\u00a0+10,\u00a0Perception\u00a0+7"],"abilityText":"Tibanna Pouch:\u00a0Tibanna Mynocks have dozens of small, leathery pouches all over their bodies that capture and hold pockets of Tibanna gas. When a Tibanna Mynock is killed, its Tibanna pouches rupture, filling a 2x2 square area with Tibanna gas. Whenever a creature enters this area, the gas makes an attack roll (1d20+10) against the creature's\u00a0Fortitude Defense.\nIf the attack succeeds, the target takes 2d6 points of damage (Other Tibanna Mynocks are immune to this effect). Additionally, a Tibanna gas cloud can be dissipated by firing a blaster bolt into it (Reflex Defense: 10 for one of the squares occupied by the gas). Doing so causes the cloud to burn up rapidly, dealing 4d6 points of energy damage to any creature in or adjacent to the gas.\n00:00\n41:20\nDinko\u00a0Statistics (CL 2)\nFine\u00a0Beast\u00a03\nDefenses\nOffense\nAttack Options:\u00a0Poison,\u00a0Weapon Finesse\nSpecial Actions:\u00a0Stench\nSpecies Traits:\u00a0Motion Vision, Poison, Scent, Stench,\u00a0Pack Traits\nBase Stats\nMotion Vision:\u00a0The eyes of a Dinko have evolved such that they see only movement. The creature takes a -5 penalty to attack rolls against opponents that have not moved in the previous round. Although a Dinko cannot see its opponent, its keen sense of smell alerts it to the presence of potential prey (See Scent).\nPoison:\u00a0If the Bite attack of a Dinko deals damage to a living target, the target is also poisoned. If the poison succeeds on an attack roll (1d20+8) against the target's\u00a0Fortitude Defense, the target moves -1 step along the\u00a0Condition Track.\nA target moved to the end of the\u00a0Condition Track\u00a0by the poison is\u00a0Immobilized, but not unconscious. The Poison attacks each round until cured with a successful DC 15\u00a0Treat Injury\u00a0check.\nScent:\u00a0Dinkos ignore\u00a0Concealment\u00a0and\u00a0Cover\u00a0when making\u00a0Perception\u00a0checks to\u00a0Notice\u00a0opponents within 10 squares, and they take no penalty from poor visibility when\u00a0Tracking.\nStench:\u00a0Dinkos exude a foul stench that nauseates most other creatures. If the Stench succeeds on an attack roll (1d20+5) against the target's\u00a0Fortitude Defense, the target becomes nauseated for 1 round. A nauseated target can make only a single\u00a0Move Action\u00a0that round. The Stench attacks each round that the target remains within 2 squares of the Dinko."}}},"items":[]}
