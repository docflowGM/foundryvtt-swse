{"_id":"67e364ba12d5677f","name":"Brintak","type":"npc","img":"icons/svg/mystery-man.svg","system":{"isDroid":false,"droidDegree":"","attributes":{"str":{"base":26,"racial":0,"enhancement":0,"temp":0},"dex":{"base":13,"racial":0,"enhancement":0,"temp":0},"con":{"base":26,"racial":0,"enhancement":0,"temp":0},"int":{"base":2,"racial":0,"enhancement":0,"temp":0},"wis":{"base":10,"racial":0,"enhancement":0,"temp":0},"cha":{"base":13,"racial":0,"enhancement":0,"temp":0}},"skills":{"acrobatics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"climb":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"deception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"endurance":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"con","favorite":false},"gatherInformation":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"initiative":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"jump":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"knowledgeBureaucracy":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeGalacticLore":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeLifeSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgePhysicalSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeSocialSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTactics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTechnology":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"mechanics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":188,"max":188,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":14,"size":"huge","speed":6,"defenses":{"reflex":{"total":25,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":18,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":10,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":23}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":28,"bab":11,"race":"","class":"","className":"","biography":"Poison:\u00a0If the Tentacle of a Brintak deals damage to a living target, the target is also poisoned. If the poison succeeds on an attack roll (1d20+10) against the target's\u00a0Fortitude Defense, the target takes 1d12 points of damage (in addition to the Tentacle damage). If the attack is unsuccessful, the target takes half damage.\nPounce:\u00a0When\u00a0Long Jumping, a Brintak does not require a running start for jumps of 4 squares or fewer and does not double the\u00a0Jump\u00a0DC when doing so. If the Brintak successfully jumps into or adjacent to a target enemy's square, the Brintak can make an immediate attack against the target. If the attack is successful, the Brintak can attempt to\u00a0Trip\u00a0the target as a\u00a0Free Action\u00a0that does not provoke\u00a0Attacks of Opportunity.\nRoar:\u00a0As a\u00a0Move Action, a Brintak can produce a terrifying, rumbling roar and make a\u00a0Persuasion\u00a0check to\u00a0Intimidate\u00a0any enemy target within 6 squares. If the check succeeds, the target must move away from the Brintak at its normal speed on the target's next turn, and the target moves -1 step on the\u00a0Condition Track. This is a\u00a0Mind-Affecting\u00a0effect.","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Brintak","cl":14,"tags":["beast"],"size":"huge","initiative":8,"senses":"Low-Light Vision,\u00a0Perception\u00a0+12","perception":12,"reflexDefense":25,"flatFootedDefense":23,"fortitudeDefense":18,"willDefense":10,"hitPoints":188,"damageThreshold":28,"speed":"6 Squares;\u00a0Improved Charge, Pounce","melee":"Bite +19 (2d6+7); Claws (2) +19 (1d8+7); Tentacle +19 (1d8+7) plus Poison","fightingSpace":"3x3 Squares","reach":"2 Squares","baseAttackBonus":11,"grapple":29,"speciesTraits":[],"abilities":{"strength":26,"dexterity":13,"constitution":26,"intelligence":2,"wisdom":10,"charisma":13},"feats":["7bc21d4a74b95be5","45366d4f3a5e443d","0166fcdddc548545","ff8eaa4e2f6d1cf1","c238f3f722689a3a"],"skills":["Perception\u00a0+12"],"abilityText":"Poison:\u00a0If the Tentacle of a Brintak deals damage to a living target, the target is also poisoned. If the poison succeeds on an attack roll (1d20+10) against the target's\u00a0Fortitude Defense, the target takes 1d12 points of damage (in addition to the Tentacle damage). If the attack is unsuccessful, the target takes half damage.\nPounce:\u00a0When\u00a0Long Jumping, a Brintak does not require a running start for jumps of 4 squares or fewer and does not double the\u00a0Jump\u00a0DC when doing so. If the Brintak successfully jumps into or adjacent to a target enemy's square, the Brintak can make an immediate attack against the target. If the attack is successful, the Brintak can attempt to\u00a0Trip\u00a0the target as a\u00a0Free Action\u00a0that does not provoke\u00a0Attacks of Opportunity.\nRoar:\u00a0As a\u00a0Move Action, a Brintak can produce a terrifying, rumbling roar and make a\u00a0Persuasion\u00a0check to\u00a0Intimidate\u00a0any enemy target within 6 squares. If the check succeeds, the target must move away from the Brintak at its normal speed on the target's next turn, and the target moves -1 step on the\u00a0Condition Track. This is a\u00a0Mind-Affecting\u00a0effect.","beastLevel":15}}},"items":[]}
