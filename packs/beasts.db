{"_id":"01a186d7e190346d","name":"Bergruutfa","type":"npc","img":"icons/svg/mystery-man.svg","system":{"isDroid":false,"droidDegree":"","attributes":{"str":{"base":26,"racial":0,"enhancement":0,"temp":0},"dex":{"base":6,"racial":0,"enhancement":0,"temp":0},"con":{"base":27,"racial":0,"enhancement":0,"temp":0},"int":{"base":2,"racial":0,"enhancement":0,"temp":0},"wis":{"base":12,"racial":0,"enhancement":0,"temp":0},"cha":{"base":5,"racial":0,"enhancement":0,"temp":0}},"skills":{"acrobatics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"climb":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"deception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"endurance":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"con","favorite":false},"gatherInformation":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"initiative":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"jump":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"knowledgeBureaucracy":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeGalacticLore":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeLifeSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgePhysicalSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeSocialSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTactics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTechnology":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"mechanics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":81,"max":81,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":5,"size":"huge","speed":10,"defenses":{"reflex":{"total":4,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":18,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":11,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":4}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":0,"bab":4,"race":"","class":"","className":"","biography":"Head Butt:\u00a0When a Bergruutfa makes a successful melee attack against an adjacent target, it makes an immediate opposed\u00a0Grapple\u00a0check. If the check is successful, the target is moved back 1 square for every 5 points by which it failed the check. This movement does not provoke an\u00a0Attack of Opportunity. A Bergruutfa receives a +5 circumstance bonus to its\u00a0Grapple\u00a0check if it\u00a0Charges\u00a0prior to making the attack.","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Bergruutfa","cl":5,"tags":["mount","beast"],"size":"huge","initiative":1,"senses":"Perception\u00a0+9","perception":9,"reflexDefense":4,"flatFootedDefense":4,"fortitudeDefense":18,"willDefense":11,"hitPoints":81,"damageThreshold":null,"speed":"10 Squares","melee":"Slam +9* (1d8+14)","fightingSpace":"3x3 Squares","reach":"1 Square","baseAttackBonus":4,"grapple":22,"speciesTraits":[],"abilities":{"strength":26,"dexterity":6,"constitution":27,"intelligence":2,"wisdom":12,"charisma":5},"feats":["96666de28ba99b64","3f76464c43c73f84","11db29efd899c438"],"skills":["Perception\u00a0+9"],"abilityText":"Head Butt:\u00a0When a Bergruutfa makes a successful melee attack against an adjacent target, it makes an immediate opposed\u00a0Grapple\u00a0check. If the check is successful, the target is moved back 1 square for every 5 points by which it failed the check. This movement does not provoke an\u00a0Attack of Opportunity. A Bergruutfa receives a +5 circumstance bonus to its\u00a0Grapple\u00a0check if it\u00a0Charges\u00a0prior to making the attack."}}},"items":[]}
