s can kill just as easily as physical damage. This creature's attacks are considered\u00a0Mind-Affecting\u00a0effects.\nSemi-Corporeal:\u00a0This creature is a manifestation of Force energy and is only partially vulnerable to normal attacks. It takes half damage from weapons other than energy weapons. If a weapon deals energy damage or another type of damage, the creature takes full damage from that weapon. If a weapon deals energy damage\u00a0and\u00a0another type of damage, the creature takes only half damage from that weapon.","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Living Nightmare","cl":6,"tags":["beast"],"size":"medium","initiative":7,"senses":"Darkvision,\u00a0Perception\u00a0+17","perception":17,"reflexDefense":14,"flatFootedDefense":10,"fortitudeDefense":13,"willDefense":11,"hitPoints":53,"damageThreshold":13,"speed":"6 Squares (Flying);\u00a0Running Attack","melee":"Slam +9 (2d6+2) with Attack the Mind","fightingSpace":"1 Square","reach":"1 Square","baseAttackBonus":5,"grapple":9,"speciesTraits":[],"abilities":{"strength":8,"dexterity":18,"constitution":16,"intelligence":2,"wisdom":12,"charisma":16},"feats":["4d6a68d553fb0449","1592aaedf4b6e40a","252b67d6e31c377e"],"skills":["Perception\u00a0+17"],"abilityText":"Attack the Mind:\u00a0This creature's melee attacks target the opponent's\u00a0Will Defense\u00a0instead of its\u00a0Reflex Defense, and the creature's damage (treated as energy damage) ignores SR and DR. The creature's attacks target the mind of the opponent, though the damage it causes can kill just as easily as physical damage. This creature's attacks are considered\u00a0Mind-Affecting\u00a0effects.\nSemi-Corporeal:\u00a0This creature is a manifestation of Force energy and is only partially vulnerable to normal attacks. It takes half damage from weapons other than energy weapons. If a weapon deals energy damage or another type of damage, the creature takes full damage from that weapon. If a weapon deals energy damage\u00a0and\u00a0another type of damage, the creature takes only half damage from that weapon.","beastLevel":7}}},"items":[]}
{"_id":"49d2087a996618a2","name":"Saber Cat","type":"npc","img":"icons/svg/mystery-man.svg","system":{"isDroid":false,"droidDegree":"","attributes":{"str":{"base":14,"racial":0,"enhancement":0,"temp":0},"dex":{"base":18,"racial":0,"enhancement":0,"temp":0},"con":{"base":13,"racial":0,"enhancement":0,"temp":0},"int":{"base":2,"racial":0,"enhancement":0,"temp":0},"wis":{"base":12,"racial":0,"enhancement":0,"temp":0},"cha":{"base":7,"racial":0,"enhancement":0,"temp":0}},"skills":{"acrobatics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"climb":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"deception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"endurance":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"con","favorite":false},"gatherInformation":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"initiative":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"jump":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"knowledgeBureaucracy":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeGalacticLore":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeLifeSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgePhysicalSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeSocialSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTactics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTechnology":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"mechanics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":33,"max":33,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":5,"size":"medium","speed":8,"defenses":{"reflex":{"total":14,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":11,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":11,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":10}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":11,"bab":4,"race":"","class":"","className":"","biography":"Pounce:\u00a0When\u00a0Long Jumping, a Saber Cat does not require a running start for jumps of 4 squares or fewer and does not double the\u00a0Jump\u00a0DC when doing so. If the Saber Cat successfully jumps into or adjacent to a target enemy's square, the Saber Cat can make an immediate attack against the target. If the attack is successful, the Saber Cat can attempt to\u00a0Trip\u00a0the target as a\u00a0Free Action\u00a0that does not provoke\u00a0Attacks of Opportunity.\nin:\u00a0Nonheroic Units,\u00a0Beasts\nVindinax\nEdit\nReference Book:\u00a0Star Wars Saga Edition Unknown Regions\nAffiliations:\u00a0Beasts\nOriginating from a mysterious planet in\u00a0The Unknown Regions, the Vindinax is a dangerous predator that reached the top of its food chain long ago. Scientists who have studied the creature believe its native habitat to be either the jungle or the forest, since it favors hiding in high places and pouncing on prey from above.\nThe Vindinax has a dark green, chitinous carapace, leading many to believe that it is insectoid in nature. However, the creature also has forward-facing eyes and sharp teeth and claws that appear to be mammalian in origin.\nThe creature aboard Iol Station was brought in by a merchant hoping to sell it to a zoo on another world in\u00a0The Unknown Regions. However, the customs officers aboard the station determined that the merchant did not have the proper paperwork to ship the Vindinax. Despite the merchant's protests, the officers retained the creature and forced the merchant to pay a hefty fine to\u00a0Tangan Industries\u00a0for the potential threat he had brought to the station. The customs officers left the Vindinax in Cargo Bay 2, not suspecting that it could break out of its shipping container.\nContents","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Saber Cat","cl":5,"tags":["beast"],"size":"medium","initiative":7,"senses":"Perception\u00a0+9","perception":9,"reflexDefense":14,"flatFootedDefense":10,"fortitudeDefense":11,"willDefense":11,"hitPoints":33,"damageThreshold":11,"speed":"8 Squares; Pounce","melee":"Bite +8 (1d6+5); Gore +8 (1d6+5); Claws (2) +8 (1d4+5)","fightingSpace":"1 Square","reach":"1 Square","baseAttackBonus":4,"grapple":8,"speciesTraits":[],"abilities":{"strength":14,"dexterity":18,"constitution":13,"intelligence":2,"wisdom":12,"charisma":7},"feats":["a9f6de36f24ef202","a9f6de36f24ef202","252b67d6e31c377e"],"skills":["Jump\u00a0+10,\u00a0Perception\u00a0+9,\u00a0Stealth\u00a0+12"],"abilityText":"Pounce:\u00a0When\u00a0Long Jumping, a Saber Cat does not require a running start for jumps of 4 squares or fewer and does not double the\u00a0Jump\u00a0DC when doing so. If the Saber Cat successfully jumps into or adjacent to a target enemy's square, the Saber Cat can make an immediate attack against the target. If the attack is successful, the Saber Cat can attempt to\u00a0Trip\u00a0the target as a\u00a0Free Action\u00a0that does not provoke\u00a0Attacks of Opportunity.\nin:\u00a0Nonheroic Units,\u00a0Beasts\nVindinax\nEdit\nReference Book:\u00a0Star Wars Saga Edition Unknown Regions\nAffiliations:\u00a0Beasts\nOriginating from a mysterious planet in\u00a0The Unknown Regions, the Vindinax is a dangerous predator that reached the top of its food chain long ago. Scientists who have studied the creature believe its native habitat to be either the jungle or the forest, since it favors hiding in high places and pouncing on prey from above.\nThe Vindinax has a dark green, chitinous carapace, leading many to believe that it is insectoid in nature. However, the creature also has forward-facing eyes and sharp teeth and claws that appear to be mammalian in origin.\nThe creature aboard Iol Station was brought in by a merchant hoping to sell it to a zoo on another world in\u00a0The Unknown Regions. However, the customs officers aboard the station determined that the merchant did not have the proper paperwork to ship the Vindinax. Despite the merchant's protests, the officers retained the creature and forced the merchant to pay a hefty fine to\u00a0Tangan Industries\u00a0for the potential threat he had brought to the station. The customs officers left the Vindinax in Cargo Bay 2, not suspecting that it could break out of its shipping container.\nContents","beastLevel":6}}},"items":[]}
{"_id":"501927c7b700052a","name":"Beck-tori","type":"npc","img":"icons/svg/mystery-man.svg","system":{"isDroid":false,"droidDegree":"","attributes":{"str":{"base":22,"racial":0,"enhancement":0,"temp":0},"dex":{"base":10,"racial":0,"enhancement":0,"temp":0},"con":{"base":20,"racial":0,"enhancement":0,"temp":0},"int":{"base":2,"racial":0,"enhancement":0,"temp":0},"wis":{"base":12,"racial":0,"enhancement":0,"temp":0},"cha":{"base":12,"racial":0,"enhancement":0,"temp":0}},"skills":{"acrobatics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"climb":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"deception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"endurance":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"con","favorite":false},"gatherInformation":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"initiative":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"jump":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"knowledgeBureaucracy":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeGalacticLore":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeLifeSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgePhysicalSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeSocialSciences":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTactics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"knowledgeTechnology":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"mechanics":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"perception":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"persuasion":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false},"pilot":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"ride":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"stealth":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"dex","favorite":false},"survival":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"swim":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"str","favorite":false},"treatInjury":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"wis","favorite":false},"useComputer":{"trained":false,"focused":false,"miscMod":0,"selectedAbility":"int","favorite":false},"useTheForce":{"trained":true,"focused":false,"miscMod":0,"selectedAbility":"cha","favorite":false}},"hp":{"value":123,"max":123,"temp":0,"bonus":0},"conditionTrack":{"current":0,"persistent":false,"penalty":0},"level":12,"size":"medium","speed":6,"defenses":{"reflex":{"total":30,"armor":0,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"dex","source":"level","level":0},"fort":{"total":28,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"con","level":0},"will":{"total":22,"classBonus":0,"misc":{"auto":{},"user":{}},"ability":"wis","level":0},"flatFooted":{"total":30}},"languages":[],"destinyPoints":{"value":0,"max":0},"forcePoints":{"value":0,"max":0,"die":"1d6"},"darkSideScore":0,"damageThreshold":38,"bab":9,"race":"","class":"","className":"","biography":"Devour:\u00a0If a\u00a0Beck-tori hits with it's Bite attack against a Large or smaller opponent, it can automatically make a\u00a0Grapple\u00a0check at its full bonus as a\u00a0Free Action. If the\u00a0Grapple\u00a0check is successful, the Beck-tori can begin Devouring it's target.\nThe creature being Devoured takes 1d8+12 points of damage each round at the start of its turn, before it takes any actions. When the creature reaches 0 Hit Points, it is swallowed by the Beck-tori and continues to take 1d6 points of\u00a0Acid\u00a0damage each round at the start of its turn.\nThe Beck-tori cannot make Bite attacks until it releases the creature (A\u00a0Free Action) or swallows it.\nFast Healing 5:\u00a0A Beck-tori regains 5 Hit Points every round at the end of its turn, up to its normal maximum, until it is killed.","derived":{}},"effects":[],"flags":{"swse":{"beastData":{"name":"Beck-tori","cl":12,"tags":["beast"],"size":null,"initiative":11,"senses":"Low-Light Vision,\u00a0Perception\u00a0+5","perception":5,"reflexDefense":30,"flatFootedDefense":30,"fortitudeDefense":28,"willDefense":22,"hitPoints":123,"damageThreshold":38,"speed":"6 Squares (Walking), 8 Squares (Swimming)","melee":"Bite +15 (2d6+12)","fightingSpace":"3x3 Squares","reach":"2 Squares","baseAttackBonus":9,"grapple":25,"speciesTraits":[],"abilities":{"strength":22,"dexterity":10,"constitution":20,"intelligence":2,"wisdom":12,"charisma":12},"feats":["7bc21d4a74b95be5","ddbeb23013d9e917","9b7b869a86f39190","c238f3f722689a3a","a9f6de36f24ef202","a9f6de36f24ef202"],"skills":["Initiative\u00a0+12,\u00a0Survival\u00a0+12,\u00a0Use the Force\u00a0+12"],"abilityText":"Devour:\u00a0If a\u00a0Beck-tori hits with it's Bite attack against a Large or smaller opponent, it can automatically make a\u00a0Grapple\u00a0check at its full bonus as a\u00a0Free Action. If the\u00a0Grapple\u00a0check is successful, the Beck-tori can begin Devouring it's target.\nThe creature being Devoured takes 1d8+12 points of damage each round at the start of its turn, before it takes any actions. When the creature reaches 0 Hit Points, it is swallowed by the Beck-tori and continues to take 1d6 points of\u00a0Acid\u00a0damage each round at the start of its turn.\nThe Beck-tori cannot make Bite attacks until it releases the creature (A\u00a0Free Action) or swallows it.\nFast Healing 5:\u00a0A Beck-tori regains 5 Hit Points every round at the end of its turn, up to its normal maximum, until it is killed."}}},"items":[]}
