{"_id":"medsecret000004","name":"Improved Perform Surgery","type":"feat","img":"assets/class/Medic.webp","system":{"featType":"class_feature","benefit":"You can attempt a Treat Injury check to perform Surgery in half the usual time.","prerequisite":"Medic 2","special":"A Medic can select a given Medical Secret only once.","normalText":"","sourcebook":"Force Unleashed Campaign Guide","page":0,"tags":["medical_secret","treat_injury","surgery","time_reduction"],"bonus_feat_for":["Medic"],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can attempt a Treat Injury check to perform Surgery in half the usual time.</p>","medicalSecret":true,"treatInjuryHook":"performSurgery"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"medicalSecret":true,"treatInjuryHook":"performSurgery"}}}
{"_id":"medsecret000005","name":"Improved Revivify","type":"feat","img":"assets/class/Medic.webp","system":{"featType":"class_feature","benefit":"You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.","prerequisite":"Medic 2","special":"A Medic can select a given Medical Secret only once.","normalText":"","sourcebook":"Force Unleashed Campaign Guide","page":0,"tags":["medical_secret","treat_injury","revivify","action_economy"],"bonus_feat_for":["Medic"],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.</p>","medicalSecret":true,"treatInjuryHook":"revivify"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"medicalSecret":true,"treatInjuryHook":"revivify"}}}
{"_id":"medsecret000006","name":"Improved Treatment","type":"feat","img":"assets/class/Medic.webp","system":{"featType":"class_feature","benefit":"You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.","prerequisite":"Medic 2","special":"A Medic can select a given Medical Secret only once.","normalText":"","sourcebook":"Force Unleashed Campaign Guide","page":0,"tags":["medical_secret","treat_injury","treat_disease","treat_radiation","patients"],"bonus_feat_for":["Medic"],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.</p>","medicalSecret":true,"treatInjuryHook":"treatment"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"medicalSecret":true,"treatInjuryHook":"treatment"}}}
{"_id":"medsecret000007","name":"Personal Physician","type":"feat","img":"assets/class/Medic.webp","system":{"featType":"class_feature","benefit":"You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.","prerequisite":"Medic 2","special":"A Medic can select a given Medical Secret only once.","normalText":"","sourcebook":"Force Unleashed Campaign Guide","page":0,"tags":["medical_secret","treat_injury","self_treatment","penalty_reduction"],"bonus_feat_for":["Medic"],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.</p>","medicalSecret":true,"treatInjuryHook":"selfTreatment"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"medicalSecret":true,"treatInjuryHook":"selfTreatment"}}}
