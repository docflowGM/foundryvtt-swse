{"_id":"a57e92330ca9df40","name":"Improved First Aid","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC (in addition to any extra Hit Point gained normally for exceeding the DC).","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC (in addition to any extra Hit Point gained normally for exceeding the DC).</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"ffeb375a10c1a15f","name":"Improved Heal Damage","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"a8aef9c5acbb60ae","name":"Improved Long-Term Care","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"On a successful application of Long-Term Care, the target recovers an additional number of Hit Points equal to your Class Level.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>On a successful application of Long-Term Care, the target recovers an additional number of Hit Points equal to your Class Level.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"025504b14a5efb3f","name":"Improved Perform Surgery","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can attempt a Treat Injury check to perform Surgery in half the usual time.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can attempt a Treat Injury check to perform Surgery in half the usual time.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"8657d1ecc5dc871f","name":"Improved Revivify","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"509ab4fbcce37c44","name":"Improved Treatment","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"4dc31d29cabc28d0","name":"Personal Physician","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"dc989f034a5e5ae4","name":"Arkanian Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You are capable of using the Gene Splicing Talent to create new near-Species or new creatures without adding +10 to the DC of the check for each additional Species you splice (though you still pay for added traits, forms of movement, and natural attacks).","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You are capable of using the Gene Splicing Talent to create new near-Species or new creatures without adding +10 to the DC of the check for each additional Species you splice (though you still pay for added traits, forms of movement, and natural attacks).</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"ddb1db3a82efcd3f","name":"Columi/Khommite Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"Clones you create gain a +5 bonus to their Will Defense when they roll to check for Clone Madness.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>Clones you create gain a +5 bonus to their Will Defense when they roll to check for Clone Madness.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"de51bc110ffb3fd9","name":"Kaminoan Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you roll a Knowledge (Life Sciences) check to create a clone, you may Take 10 or Take 20 on the check.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you roll a Knowledge (Life Sciences) check to create a clone, you may Take 10 or Take 20 on the check.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"6ac8cecf9fed82dd","name":"Lurrian Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you use a Gene Sequencer, you gain an additional +5 bonus to your Knowledge (Life Sciences) check when you create a clone.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you use a Gene Sequencer, you gain an additional +5 bonus to your Knowledge (Life Sciences) check when you create a clone.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"c07bf53aa3991a0f","name":"Medical Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You are able to use cloning to create replacement organs with no chance of rejection, as well as gene-therapy to help revitalize your patients. You can create a retrovirus that reduces the physical age of your patient by 1 step (from Middle Age to Adult, etc). Note you cannot use this to move younger than Young Adult. A de-aging retrovirus adds +10 to the DC.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You are able to use cloning to create replacement organs with no chance of rejection, as well as gene-therapy to help revitalize your patients. You can create a retrovirus that reduces the physical age of your patient by 1 step (from Middle Age to Adult, etc). Note you cannot use this to move younger than Young Adult. A de-aging retrovirus adds +10 to the DC.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"8102bfb7ec6d9f1f","name":"Polis Massan Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you make a Knowledge (Life Sciences) check to create a clone with a Fossilized or Dead DNA tissue sample, the DC is reduced by 5.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you make a Knowledge (Life Sciences) check to create a clone with a Fossilized or Dead DNA tissue sample, the DC is reduced by 5.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"c260078e3dfb0fdd","name":"Verpine Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you make a Knowledge (Life Sciences) check to create multiple clones with the Mass Cloning Talent, reduce your DC by 5.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you make a Knowledge (Life Sciences) check to create multiple clones with the Mass Cloning Talent, reduce your DC by 5.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
