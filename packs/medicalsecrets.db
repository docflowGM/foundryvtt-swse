{"_id":"20a578ad27896a3e","name":"Improved First Aid","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC (in addition to any extra Hit Point gained normally for exceeding the DC).","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC (in addition to any extra Hit Point gained normally for exceeding the DC).</p>"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"4e1d5c04282db66e","name":"Improved Heal Damage","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.</p>"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"3cf9691279b7dcd6","name":"Improved Long-Term Care","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"On a successful application of Long-Term Care, the target recovers an additional number of Hit Points equal to your Class Level.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>On a successful application of Long-Term Care, the target recovers an additional number of Hit Points equal to your Class Level.</p>"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"2d59f1906629ef1d","name":"Improved Perform Surgery","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can attempt a Treat Injury check to perform Surgery in half the usual time.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can attempt a Treat Injury check to perform Surgery in half the usual time.</p>"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"23b6895e390b5382","name":"Improved Revivify","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.</p>"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"d43a3d38b80ced9d","name":"Improved Treatment","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.</p>"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"e78b6758175ad45b","name":"Personal Physician","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.</p>"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
