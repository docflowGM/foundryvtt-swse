{"_id":"medsecret000001","name":"Improved First Aid","type":"feat","img":"assets/class/Medic.webp","system":{"featType":"class_feature","benefit":"When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC, in addition to any extra Hit Point gained normally for exceeding the DC.","prerequisite":"Medic 2","special":"A Medic can select a given Medical Secret only once.","normalText":"","sourcebook":"Force Unleashed Campaign Guide","page":0,"tags":["medical_secret","treat_injury","first_aid","medpac","healing"],"bonus_feat_for":["Medic"],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC, in addition to any extra Hit Point gained normally for exceeding the DC.</p>","medicalSecret":true,"treatInjuryHook":"firstAid"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"medicalSecret":true,"treatInjuryHook":"firstAid"}}}
{"_id":"medsecret000002","name":"Improved Heal Damage","type":"feat","img":"assets/class/Medic.webp","system":{"featType":"class_feature","benefit":"On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.","prerequisite":"Medic 2","special":"A Medic can select a given Medical Secret only once.","normalText":"","sourcebook":"Force Unleashed Campaign Guide","page":0,"tags":["medical_secret","treat_injury","surgery","heal_damage","healing"],"bonus_feat_for":["Medic"],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.</p>","medicalSecret":true,"treatInjuryHook":"healDamage"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"medicalSecret":true,"treatInjuryHook":"healDamage"}}}
