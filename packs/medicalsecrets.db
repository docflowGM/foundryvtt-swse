{"_id":"ef3bd878ddfd5197","name":"Improved First Aid","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC (in addition to any extra Hit Point gained normally for exceeding the DC).","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains one additional point for every point by which your check exceeds the DC (in addition to any extra Hit Point gained normally for exceeding the DC).</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"ec8f8dc64ccee93c","name":"Improved Heal Damage","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>On a successful Surgery attempt to Heal Damage, the target recovers an additional number of Hit Points equal to your Class Level.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"e68840fa772734d2","name":"Improved Long-Term Care","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"On a successful application of Long-Term Care, the target recovers an additional number of Hit Points equal to your Class Level.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>On a successful application of Long-Term Care, the target recovers an additional number of Hit Points equal to your Class Level.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"240c2f22fceb2d52","name":"Improved Perform Surgery","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can attempt a Treat Injury check to perform Surgery in half the usual time.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can attempt a Treat Injury check to perform Surgery in half the usual time.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"9563f20fcae88c46","name":"Improved Revivify","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to Revivify someone as a Standard Action instead of a Full-Round Action.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"48882cefee4952fa","name":"Improved Treatment","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You can make a Treat Injury check to treat Disease or Radiation in 1 hour, instead of 8 hours. Also, you can treat up to twice as many patients as normal.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"2c67742ca4ffaa22","name":"Personal Physician","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.","prerequisite":"","special":"","normalText":"","sourcebook":"Core","page":0,"tags":["medical-secret"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You take no penalties on your Skill Checks when using the Treat Injury skill on yourself.</p>","homebrew":false},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"1bd7411709e78288","name":"Arkanian Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You are capable of using the Gene Splicing Talent to create new near-Species or new creatures without adding +10 to the DC of the check for each additional Species you splice (though you still pay for added traits, forms of movement, and natural attacks).","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You are capable of using the Gene Splicing Talent to create new near-Species or new creatures without adding +10 to the DC of the check for each additional Species you splice (though you still pay for added traits, forms of movement, and natural attacks).</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"fcc50960db143b33","name":"Columi/Khommite Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"Clones you create gain a +5 bonus to their Will Defense when they roll to check for Clone Madness.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>Clones you create gain a +5 bonus to their Will Defense when they roll to check for Clone Madness.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"ce6b9d3ec2674767","name":"Kaminoan Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you roll a Knowledge (Life Sciences) check to create a clone, you may Take 10 or Take 20 on the check.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you roll a Knowledge (Life Sciences) check to create a clone, you may Take 10 or Take 20 on the check.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"d234a98f9a82d99e","name":"Lurrian Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you use a Gene Sequencer, you gain an additional +5 bonus to your Knowledge (Life Sciences) check when you create a clone.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you use a Gene Sequencer, you gain an additional +5 bonus to your Knowledge (Life Sciences) check when you create a clone.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"74c096f59853571f","name":"Medical Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You are able to use cloning to create replacement organs with no chance of rejection, as well as gene-therapy to help revitalize your patients. You can create a retrovirus that reduces the physical age of your patient by 1 step (from Middle Age to Adult, etc). Note you cannot use this to move younger than Young Adult. A de-aging retrovirus adds +10 to the DC.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You are able to use cloning to create replacement organs with no chance of rejection, as well as gene-therapy to help revitalize your patients. You can create a retrovirus that reduces the physical age of your patient by 1 step (from Middle Age to Adult, etc). Note you cannot use this to move younger than Young Adult. A de-aging retrovirus adds +10 to the DC.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"095c726dc01c60bf","name":"Polis Massan Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you make a Knowledge (Life Sciences) check to create a clone with a Fossilized or Dead DNA tissue sample, the DC is reduced by 5.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you make a Knowledge (Life Sciences) check to create a clone with a Fossilized or Dead DNA tissue sample, the DC is reduced by 5.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"69a1b61dc997d80d","name":"Verpine Cloning Secrets","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you make a Knowledge (Life Sciences) check to create multiple clones with the Mass Cloning Talent, reduce your DC by 5.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you make a Knowledge (Life Sciences) check to create multiple clones with the Mass Cloning Talent, reduce your DC by 5.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"c3be939db2ab8587","name":"Rapid Stabilization","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"Once per encounter, when you successfully stabilize a dying creature with Treat Injury, that creature immediately regains hit points equal to your Intelligence modifier plus your Medic level.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>Once per encounter, when you successfully stabilize a dying creature with Treat Injury, that creature immediately regains hit points equal to your Intelligence modifier plus your Medic level.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"f71cdbb48f89825a","name":"Field Triage Expert","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you successfully use Treat Injury as a standard action, you may also remove one step on the condition track from the target (once per target per encounter).","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you successfully use Treat Injury as a standard action, you may also remove one step on the condition track from the target (once per target per encounter).</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"d814e3056044b09b","name":"Emergency Combat Medic","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You do not provoke attacks of opportunity when using Treat Injury, and you gain a +5 bonus on Treat Injury checks made on allies adjacent to enemies.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You do not provoke attacks of opportunity when using Treat Injury, and you gain a +5 bonus on Treat Injury checks made on allies adjacent to enemies.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"224c5be0f5b026d0","name":"Surgical Precision","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"If you exceed a Treat Injury DC by 10 or more, the target gains temporary hit points equal to your Intelligence modifier until the end of the encounter.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>If you exceed a Treat Injury DC by 10 or more, the target gains temporary hit points equal to your Intelligence modifier until the end of the encounter.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"e9c3cbc43da2cbed","name":"Trauma Override","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"Once per day, when an ally would be reduced to unconsciousness, they instead remain conscious at 0 hit points until the end of their next turn.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>Once per day, when an ally would be reduced to unconsciousness, they instead remain conscious at 0 hit points until the end of their next turn.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"da50f957a5e2e30c","name":"Pain Management Specialist","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"After you successfully treat an ally, that ally gains a +2 morale bonus to attack rolls and Will Defense until the end of their next turn.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>After you successfully treat an ally, that ally gains a +2 morale bonus to attack rolls and Will Defense until the end of their next turn.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"ddb2209e916b4e29","name":"Efficient Use of Supplies","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"When you use a medpac or other consumable medical item, there is a 50% chance it is not expended on use.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>When you use a medpac or other consumable medical item, there is a 50% chance it is not expended on use.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"6191e754e76811ac","name":"Battlefield Surgeon","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"Once per encounter as a full-round action, you may treat two adjacent allies with a single Treat Injury check, applying the results separately.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>Once per encounter as a full-round action, you may treat two adjacent allies with a single Treat Injury check, applying the results separately.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"86e481c96d51f921","name":"Adrenal Surge Injection","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"Once per encounter, when you successfully use Treat Injury on an ally, that ally may immediately move up one step on the condition track or gain a +2 bonus to Reflex Defense until the start of your next turn.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>Once per encounter, when you successfully use Treat Injury on an ally, that ally may immediately move up one step on the condition track or gain a +2 bonus to Reflex Defense until the start of your next turn.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"6982b85313c8c9fb","name":"Stabilize Under Fire","type":"feat","img":"systems/foundryvtt-swse/assets/icons/medical-secret.png","system":{"featType":"medical","benefit":"You may use Treat Injury as a reaction to an ally taking damage that would reduce them to 0 hit points or lower, immediately stabilizing them if the check succeeds.","prerequisite":"","special":"","normalText":"","sourcebook":"Homebrew","page":0,"tags":["medical-secret","homebrew"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"description":"<p>You may use Treat Injury as a reaction to an ally taking damage that would reduce them to 0 hit points or lower, immediately stabilizing them if the check succeeds.</p>","homebrew":true},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
