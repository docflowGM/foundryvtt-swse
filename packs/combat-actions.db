{"_id":"a801c9e246df48dd","name":"Anticipate Enemy Strategy","type":"combat-action","img":"icons/svg/sword.svg","system":{"key":"anticipate-enemy-strategy","domain":"character","category":"combat","crewPosition":null,"actionType":"move","actionTypeRaw":"move","cost":1,"summary":"","notes":"Trained in Knowledge (Tactics) only. Make Knowledge (Tactics) check vs target's Will Defense (or 10 + target's CL if no Will Defense). Success reveals target's likely next action, who they'll attack, where they'll move, or other strategies.","notesAdvanced":null,"restriction":null,"requirements":[],"examples":[],"relatedSkills":[{"skill":"Knowledge (Tactics)","dc":{"type":"opposed","target":"Target's Will Defense or 10 + CL"},"outcome":"Gain insight into target's next action and strategy"}],"ammoConsumption":null,"tags":[],"sourcebook":null,"page":null,"executable":false,"trigger":null,"toggleable":false},"effects":[],"folder":null,"sort":37,"ownership":{"default":0},"flags":{},"_stats":{"created":"2026-04-14T16:38:49.090379Z","modified":"2026-04-14T16:38:49.090379Z","lastModifiedBy":null}}
{"_id":"aa67e688789a482f","name":"Maiming Foes","type":"combat-action","img":"icons/svg/sword.svg","system":{"key":"maiming-foes","domain":"character","category":"combat","crewPosition":null,"actionType":"standard","actionTypeRaw":"standard","cost":1,"summary":"","notes":"Declare intent to maim instead of kill. Make attack at -5 penalty. On hit, deal half damage. If attack reduces target to 0 HP, target is maimed but alive instead of dead.","notesAdvanced":null,"restriction":null,"requirements":[],"examples":[],"relatedSkills":[{"skill":"Attack Roll","dc":{"type":"expression","value":"d20 + BAB + modifiers - 5"},"outcome":"Half damage; target maimed at 0 HP instead of dying"}],"ammoConsumption":null,"tags":[],"sourcebook":null,"page":null,"executable":false,"trigger":null,"toggleable":false},"effects":[],"folder":null,"sort":36,"ownership":{"default":0},"flags":{},"_stats":{"created":"2026-04-14T16:38:49.090301Z","modified":"2026-04-14T16:38:49.090301Z","lastModifiedBy":null}}
