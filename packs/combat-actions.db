{"_id":"af1becba0e7242e9","name":"Coup de Grace","type":"combat-action","img":"icons/svg/sword.svg","system":{"key":"coup-de-grace","domain":"character","category":"combat","crewPosition":null,"actionType":"full-round","actionTypeRaw":"full-round","cost":1,"summary":"","notes":"Full-Round Action against a Helpless target. Can use melee weapon or ranged weapon if adjacent. Automatically scores a Critical Hit dealing double damage. Target reduced to 0 HP dies instantly. Unconscious or disabled defenders hit by Coup de Grace die instantly. Cannot use against vehicles or objects.","notesAdvanced":null,"restriction":null,"requirements":[],"examples":[],"relatedSkills":[{"skill":"Attack Roll (Melee or Ranged)","outcome":"Auto-critical hit; double damage; instant death if reduced to 0 HP"}],"ammoConsumption":null,"tags":[],"sourcebook":null,"page":null,"executable":false,"trigger":null,"toggleable":false},"effects":[],"folder":null,"sort":9,"ownership":{"default":0},"flags":{},"_stats":{"created":"2026-04-14T16:38:49.088784Z","modified":"2026-04-14T16:38:49.088784Z","lastModifiedBy":null}}
