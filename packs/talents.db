{"_id": "32029a2f0dbb7104", "name": "Prepared Explosive", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you use a Mine or other fixed (non-Grenade) Explosive, you can choose to have the Burst radius of the Explosive become Difficult Terrain after the Explosive has detonated. Alternatively, if you plant a Mine or fixed Explosive in an area of Difficult Terrain, you can have the Explosive deal no damage and instead turn the Difficult Terrain into normal terrain.", "description": {"value": "When you use a Mine or other fixed (non-Grenade) Explosive, you can choose to have the Burst radius of the Explosive become Difficult Terrain after the Explosive has detonated. Alternatively, if you plant a Mine or fixed Explosive in an area of Difficult Terrain, you can have the Explosive deal no damage and instead turn the Difficult Terrain into normal terrain."}, "class": "b85240cf77cf95eb", "costNumeric": null, "category": "Military Engineer", "treeId": "e32009b1b0aee8c9", "tags": ["heavy-weapons"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Prepared Explosive"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.prepared_explosive", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": []}}}
