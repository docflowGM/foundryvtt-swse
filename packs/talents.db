{"_id": "d9f47bfdde76475f", "name": "Brutal Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Focus (Chosen Weapon)", "benefit": "Choose a single weapon with which you posses the Weapon Focus feat. Attacks with such weapons that deal damage (including doubling damage from a Critical Hit) exceeding an opponent's Damage Threshold deals +1 die of damage on that attack.", "description": {"value": "Choose a single weapon with which you posses the Weapon Focus feat. Attacks with such weapons that deal damage (including doubling damage from a Critical Hit) exceeding an opponent's Damage Threshold deals +1 die of damage on that attack.\n\nYou can select this Talent multiple times. Each time you select this Talent, it applies to a different weapon."}, "class": "533f1066362655c7", "costNumeric": null, "category": "Gladiator", "treeId": "12a2a02b0901605d", "tags": ["controller", "defender", "feat-chain", "leader", "melee", "mobility", "positioning", "ranged", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "defense.will", "attack.when-hit", "attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Brutal Attack"}]}}, "effects": [{"_id": "931a54c4-04db-4448-ac4f-8b57094c235a", "name": "Brutal Attack", "icon": "icons/svg/sword.svg", "changes": [{"key": "system.damage.melee", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Brutal Attack"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.brutal_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["defense.reflex", "defense.will", "attack.when-hit", "attack.with-melee", "attack.with-ranged"]}}}
{"_id": "d9fe8a0c76d845d4", "name": "Assault Tactics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Move Action, you may designate a single creature or object as the target of an assault. If you succeed on a DC 15 Knowledge (Tactics) check, you and all allies able to hear and understand you deal an additional 1d6 points of damage to the target with each successful melee or ranged attack, until the start of your next turn. This is a Mind-Affecting effect.", "description": {"value": "As a Move Action, you may designate a single creature or object as the target of an assault. If you succeed on a DC 15 Knowledge (Tactics) check, you and all allies able to hear and understand you deal an additional 1d6 points of damage to the target with each successful melee or ranged attack, until the start of your next turn. This is a Mind-Affecting effect."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "treeId": "9253ace716c3e966", "tags": ["action-economy", "ambush", "controller", "damage-reduction", "defender", "feat-chain", "force", "force-control", "force-defense", "force-offense", "leader", "leadership", "mobility", "positioning", "scaling", "scout", "skills", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "attack.when-hit", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Assault Tactics"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.assault_tactics", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["defense.reflex", "attack.when-hit", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "d9ffff2586cd259b", "name": "Stalwart Subordinates", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When any ally within 12 squares of you and in your line of sight is targeted by a Skill Check against its Will Defense, the source of that Skill Check (whether a Hazard, a creature, a Droid, or whatever) must roll the Skill Check twice, and take the lowest result.", "description": {"value": "When any ally within 12 squares of you and in your line of sight is targeted by a Skill Check against its Will Defense, the source of that Skill Check (whether a Hazard, a creature, a Droid, or whatever) must roll the Skill Check twice, and take the lowest result."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "treeId": "61b74c82cb56876c", "tags": ["action-economy", "controller", "leader", "mobility", "positioning", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Stalwart Subordinates"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stalwart_subordinates", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "da12fc505efc5eea", "name": "Visions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Prerequisites: The long-lived Draethos are particularly adept at searching and understanding the past. When using Farseeing to look into the past, reduce your DC numbers by half. Also, you are able to see everything within 6 squares of your target clearly without spending a Force Point.", "description": "Prerequisites: The long-lived Draethos are particularly adept at searching and understanding the past. When using Farseeing to look into the past, reduce your DC numbers by half. Also, you are able to see everything within 6 squares of your target clearly without spending a Force Point.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.force_perception"}], "_source": "canonical-csv"}, "treeId": "dad3c0da191748c1", "tags": ["damage_reduction", "force", "force_point_spend", "positioning", "precognition", "resource_spend", "tree_dad3c0da191748c1", "uncategorized_talent", "visions"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Visions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.visions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": []}}}
{"_id": "da5096b45d174f36", "name": "Shield Gauntlet Deflect", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You can use to deflect some of the barrage of shots fired from a ranged weapon set on Autofire. If your Use the Force check succeeds, you take half damage if the attack hits an no damage if the attack misses. This Talent allows you to redirect a deflected blaster bolt along a specific trajectory so that it damages another creature or object in its path. When you successfully perform a , you can make an immediate ranged attack against another target within 6 squares of you which you have line of sight. If the attack succeeds, it deals normal weapon damage to the target. Only single blaster bolts can be redirected in this manner. You cannot use this Talent to redirect barrages from Autofire weapons and other types of projectiles. To use this Talent, you must be wearing an active Shield Gauntlet, you must be aware of the attack, and you must not be Flat-Footed. You treat a Siang Lance as a Rifle instead of as an Exotic Weapon (Ranged). Additionally, you gain a +1 bonus to attack rolls with a Siang Lance. This Talent counts as the Weapon Focus (Siang Lance) feat for the purpose of satisfying prerequisites. If you also have the Weapon Focus (Rifles) feat, the attack bonus provided by this Talent does not stack with the attack bonus provided by Weapon Focus (Rifles).", "benefit": "You can use to deflect some of the barrage of shots fired from a ranged weapon set on Autofire. If your Use the Force check succeeds, you take half damage if the attack hits an no damage if the attack misses. This Talent allows you to redirect a deflected blaster bolt along a specific trajectory so that it damages another creature or object in its path. When you successfully perform a , you can make an immediate ranged attack against another target within 6 squares of you which you have line of sight. If the attack succeeds, it deals normal weapon damage to the target. Only single blaster bolts can be redirected in this manner. You cannot use this Talent to redirect barrages from Autofire weapons and other types of projectiles. To use this Talent, you must be wearing an active Shield Gauntlet, you must be aware of the attack, and you must not be Flat-Footed. You treat a Siang Lance as a Rifle instead of as an Exotic Weapon (Ranged). Additionally, you gain a +1 bonus to attack rolls with a Siang Lance. This Talent counts as the Weapon Focus (Siang Lance) feat for the purpose of satisfying prerequisites. If you also have the Weapon Focus (Rifles) feat, the attack bonus provided by this Talent does not stack with the attack bonus provided by Weapon Focus (Rifles).", "class": "", "category": "", "costNumeric": null, "treeId": "2a1838832f6146e2", "tags": ["block", "burst_damage", "controller", "defender", "defense", "deflect", "duelist", "force", "force_execution", "force_offense", "lightsaber_polearm", "melee_defense", "offense_ranged", "positioning", "ranged", "ranged_defense", "scaling", "shield", "shields", "striker", "support", "tree_2a1838832f6146e2", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 1, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-ranged", "proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Shield Gauntlet Deflect"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["attack.when-hit", "attack.with-ranged", "proximity.ally-nearby"]}}}
