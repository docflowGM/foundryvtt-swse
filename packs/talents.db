{"_id": "bd34fd5bbc4a14fb", "name": "Commanding Officer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You gain a single Follower. Choose either the Aggressive, Defensive, or Utility Follower Template for your Follower, generating the follower's statistics using the rules found in the Followers page. This Follower gains one Armor Proficiency Feat of your choice and Weapon Proficiency (Rifles), in addition to those provided by the Follower Templates. The Follower must meet the prerequisites for the Armor Proficiency Feat you select.", "description": {"value": "You gain a single Follower. Choose either the Aggressive, Defensive, or Utility Follower Template for your Follower, generating the follower's statistics using the rules found in the Followers page. This Follower gains one Armor Proficiency Feat of your choice and Weapon Proficiency (Rifles), in addition to those provided by the Follower Templates. The Follower must meet the prerequisites for the Armor Proficiency Feat you select.\n\nYou can select this Talent multiple times. Each time you do, you gain one additional Follower (maximum of three Followers)."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "781feba15dc9e42f", "tags": ["action-economy", "battlefield-control", "burst-damage", "positioning", "ranged", "soldier", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 5, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-ranged", "turn.on-current-turn"], "enabled": true, "priority": 500, "description": "Commanding Officer"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.commanding_officer", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.426Z", "detectedPredicates": ["attack.when-hit", "attack.with-ranged", "turn.on-current-turn"]}}}
{"_id": "bd6cbb85cf7fc8a2", "name": "Triangulate", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Enhanced Vision", "benefit": "If you and at least one other ally have line of sight to and are aware of a target, you and all allies that can hear and understand you can reroll one ranged attack roll against that target, accepting the second result even if it is worse. You and your allies can only gain the benefits of this Talent once per encounter.", "description": {"value": "If you and at least one other ally have line of sight to and are aware of a target, you and all allies that can hear and understand you can reroll one ranged attack roll against that target, accepting the second result even if it is worse. You and your allies can only gain the benefits of this Talent once per encounter."}, "class": "acd10710f000ae70", "costNumeric": null, "category": "Vanguard", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.enhanced_vision"}], "_source": "canonical-csv"}, "treeId": "ca304c9496f38747", "tags": ["category_vanguard", "cover", "feat_chain", "offense_ranged", "positioning", "ranged", "ranged_support", "recon", "support", "talent_chain", "targeting", "teamwork"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Triangulate"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.triangulate", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.426Z", "detectedPredicates": ["attack.with-ranged", "turn.once-per-round"]}}}
