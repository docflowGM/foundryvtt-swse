{"_id": "ff3b4c48d0a05a16", "name": "Keep Them at Bay", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you use the Aid Another Action to Suppress an Enemy, that enemy takes a -5 penalty on its next attack instead of the normal -2 penalty. Only 1 character may gain the benefits of this Talent against a given target at a time.", "description": {"value": "When you use the Aid Another Action to Suppress an Enemy, that enemy takes a -5 penalty on its next attack instead of the normal -2 penalty. Only 1 character may gain the benefits of this Talent against a given target at a time."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "798ed0945cbdac1c", "tags": ["soldier"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Keep Them at Bay"}]}}, "effects": [{"_id": "c7a67d08-5969-44c9-9eb3-b8cd84c5b93e", "name": "Keep Them at Bay", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.suppress.penalty", "mode": 5, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Keep Them at Bay"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.keep_them_at_bay", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": []}}}
{"_id": "ff3c38adbb101622", "name": "Reconnaissance Team Leader", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You gain a single Follower. Choose either the Aggressive, Defensive, or Utility Follower Template for your Follower, generating the follower's statistics using the Followers rules. This Follower gains the Skill Training (Perception) and Skill Training (Stealth) Feats. Additionally, whenever you use the Stealth skill, all your Followers can also make Stealth checks as a part of the same Action if they are able to.", "description": {"value": "You gain a single Follower. Choose either the Aggressive, Defensive, or Utility Follower Template for your Follower, generating the follower's statistics using the Followers rules. This Follower gains the Skill Training (Perception) and Skill Training (Stealth) Feats. Additionally, whenever you use the Stealth skill, all your Followers can also make Stealth checks as a part of the same Action if they are able to.\n\nYou can select this Talent up to three times. Each time you do, you gain one additional Follower."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "860fa1a66c837574", "tags": ["action-economy", "battlefield-control", "controller", "leader", "melee", "mobility", "perception", "positioning", "ranged", "scout", "skills", "stealth", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 5, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged", "turn.on-current-turn"], "enabled": true, "priority": 500, "description": "Reconnaissance Team Leader"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.reconnaissance_team_leader", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged", "turn.on-current-turn"]}}}
{"_id": "ffdca1739d401042", "name": "Opportunistic Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Uncanny Instincts", "benefit": "Once per encounter, whenever you would use Uncanny Instincts, you can forgo this extra movement and instead increase your Reflex Defense by 5 until the end of your next turn.", "description": {"value": "Once per encounter, whenever you would use Uncanny Instincts, you can forgo this extra movement and instead increase your Reflex Defense by 5 until the end of your next turn."}, "class": "19ee85a788380256", "costNumeric": null, "category": "Outlaw", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.uncanny_instincts"}], "_source": "canonical-csv"}, "treeId": "3caa80f6bef04200", "tags": ["category_outlaw", "controller", "defender", "duelist", "feat_chain", "mobility", "opportunist", "striker", "survivability", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 5, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Opportunistic Defense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.opportunistic_defense", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "ffe31e578e9abeee", "name": "Pick a Fight", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Cantina Brawler", "benefit": "During the Surprise Round, you and all allies within 6 squares of you gain a +1 morale bonus on attack rolls. Additionally, until the end of the encounter, you retain this bonus to attack rolls against any target you or your allies damage during the Surprise Round.", "description": {"value": "During the Surprise Round, you and all allies within 6 squares of you gain a +1 morale bonus on attack rolls. Additionally, until the end of the encounter, you retain this bonus to attack rolls against any target you or your allies damage during the Surprise Round."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.cantina_brawler"}], "_source": "canonical-csv"}, "treeId": "67fdd8dce9abd6c1", "tags": ["ambush", "feat-chain", "positioning", "soldier", "striker", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "ae516621-dc99-4102-aa42-02d1fa20a8cd", "name": "Pick a Fight", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Pick a Fight", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.pick_a_fight"}}}
