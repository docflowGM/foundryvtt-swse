{"_id": "9e2092257b53cd21", "name": "Flurry Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Proficiency (Chosen Weapon)", "benefit": "Choose a single Weapon Group or Exotic Weapon you are proficient with. When you score a Critical Hit with a weapon from that group, you can make one immediate extra attack (in addition to the other effects of a Critical Hit) against a single target within Range.", "description": {"value": "Choose a single Weapon Group or Exotic Weapon you are proficient with. When you score a Critical Hit with a weapon from that group, you can make one immediate extra attack (in addition to the other effects of a Critical Hit) against a single target within Range.\n\nYou may only use this Talent once per turn. You can select this Talent multiple times. its effects do not stack. Each time you take the Talent, it applies to a new Weapon Group or Exotic Weapon."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "71e99c646b18d85c", "tags": ["positioning", "precision", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Flurry Attack"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.flurry_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "9e4345faaaa94dd8", "name": "Dastardly Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "Whenever you make a successful attack against an opponent that is denied its Dexterity bonus to Reflex Defense, the target moves -1 step along the Condition Track. This Talent can be used only against characters, not objects or Vehicles."}, "benefit": "Whenever you make a successful attack against an opponent that is denied its Dexterity bonus to Reflex Defense, the target moves -1 step along the Condition Track. This Talent can be used only against characters, not objects or Vehicles.", "class": "", "category": "", "costNumeric": null, "treeId": "67b59e020c1660eb", "tags": ["condition_removal", "controller", "defender", "feat_chain", "force", "force_control", "force_defense", "force_offense", "lightsaber", "melee", "mobility", "offense_melee", "pilot", "precision_damage", "striker", "talent_chain", "tree_67b59e020c1660eb", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.against-melee", "defense.reflex", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Dastardly Strike"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["defense.against-melee", "defense.reflex", "attack.with-melee"]}}}
{"_id": "9ee88ce289527ed3", "name": "Flee", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Long Stride", "benefit": "As a Standard Action, you can designate a single opponent and move up to your Speed away from that opponent; this movement does not provoke Attacks of Opportunity from that opponent, though it might provoke as normal for all other opponents.", "description": {"value": "As a Standard Action, you can designate a single opponent and move up to your Speed away from that opponent; this movement does not provoke Attacks of Opportunity from that opponent, though it might provoke as normal for all other opponents."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.long_stride"}], "_source": "canonical-csv"}, "treeId": "7c47d36dc1f77d9c", "tags": ["controller", "feat-chain", "mobility", "scout", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "speed.base", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.speed"}]}}, "effects": [{"_id": "85dc0793-06c5-4c6a-a4e6-7c009083aef2", "name": "Flee", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.speed", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Flee", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.flee"}}}
