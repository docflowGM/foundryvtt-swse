{"_id": "40508f87f3a8f33f", "name": "Inspire Zeal", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Bolster Ally, Inspire Confidence, Ignite Fervor", "benefit": "Whenever an ally within line of sight of you makes an attack that moves an opponent down the Condition Track (such as dealing damage that equals of exceeds the target's Damage Threshold), that ally moves the target an additional -1 step down the Condition Track.", "description": {"value": "Whenever an ally within line of sight of you makes an attack that moves an opponent down the Condition Track (such as dealing damage that equals of exceeds the target's Damage Threshold), that ally moves the target an additional -1 step down the Condition Track."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.ignite_fervor"}], "_source": "canonical-csv"}, "treeId": "72d32ebcbb607314", "tags": ["condition-removal", "controller", "feat-chain", "mobility", "noble", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Inspire Zeal"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.inspire_zeal", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "41426ecd7fade0b0", "name": "Weapon Specialization", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Focus with chosen Exotic Weapon or Weapon Group", "benefit": "Choose a single Exotic Weapon or weapon group with which you are proficient. You gain a +2 bonus on damage rolls with such weapons. If you select Heavy Weapons as the weapon group this Talent applies to, you may also use the Talent with Vehicle Weapon attacks.", "description": {"value": "Choose a single Exotic Weapon or weapon group with which you are proficient. You gain a +2 bonus on damage rolls with such weapons. If you select Heavy Weapons as the weapon group this Talent applies to, you may also use the Talent with Vehicle Weapon attacks.\n\nYou may select this Talent multiple times. Each time you select this Talent, it applies to a different Exotic Weapon or weapon group."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "2359c05ff13f3feb", "tags": ["feat-chain", "jedi", "lightsaber", "melee", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Weapon Specialization"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.weapon_specialization", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "42f9f503f5e26de7", "name": "Focused Warrior", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Your training makes you confident and disciplined in combat. When you successfully deal damage to an opponent in combat, you gain a +5 morale bonus to Will Defense until the start of your next turn. You lose this bonus to Will Defense if you are Surprised or Flat-Footed for any reason.", "description": {"value": "Your training makes you confident and disciplined in combat. When you successfully deal damage to an opponent in combat, you gain a +5 morale bonus to Will Defense until the start of your next turn. You lose this bonus to Will Defense if you are Surprised or Flat-Footed for any reason."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "4007fa87192b5884", "tags": ["ambush", "controller", "defender", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.will", "type": "untyped", "value": 5, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.will"}]}}, "effects": [{"_id": "265f34e6-649f-4887-9e12-d76a8b999112", "name": "Focused Warrior", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.will", "mode": 2, "value": "5"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Focused Warrior", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.focused_warrior"}}}
