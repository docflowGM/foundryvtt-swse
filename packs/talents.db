{"_id": "35350a8b3d2a4810", "name": "Empowered", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You must have an Weapon drawn to use this Talent, and you must be aware of the attack and not Flat-Footed. You may spend a Force Point to use this Talent to negate an attack against an adjacent character.", "benefit": "You must have an Weapon drawn to use this Talent, and you must be aware of the attack and not Flat-Footed. You may spend a Force Point to use this Talent to negate an attack against an adjacent character.", "class": "", "category": "", "costNumeric": null, "treeId": "01e443d93e47f9c4", "tags": ["alchemy", "controller", "crafting", "empowerment", "force", "force_offense", "force_point_spend", "positioning", "resource_spend", "tree_01e443d93e47f9c4", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Empowered"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.408Z", "detectedPredicates": []}}}
