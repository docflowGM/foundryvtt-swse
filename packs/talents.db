{"_id": "991dbfc3a436b5a1", "name": "Squadron Maneuvers", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charisma 13, Any Talent from either the Expert Pilot Talent Tree or the Gunner Talent Tree", "benefit": "Choose one Talent that you already possess. The Talent you select must be from either the Expert Pilot Talent Tree or the Gunner Talent Tree. Once per encounter as a Standard Action, you can impart the benefits of the chosen Talent to all members of your squadron. Once gained, its benefits last until the end of the encounter.", "description": {"value": "Choose one Talent that you already possess. The Talent you select must be from either the Expert Pilot Talent Tree or the Gunner Talent Tree. Once per encounter as a Standard Action, you can impart the benefits of the chosen Talent to all members of your squadron. Once gained, its benefits last until the end of the encounter."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "cha", "min": 13}], "_source": "canonical-csv"}, "treeId": "dc1b8c5ce2a70394", "tags": ["action-economy", "defender", "feat-chain", "force", "force-defense", "force-offense", "leader", "light-side", "mobility", "scout", "striker", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Squadron Maneuvers"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.squadron_maneuvers", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["defense.reflex", "turn.once-per-round"]}}}
{"_id": "994e8232ccd3847c", "name": "Savage Reputation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Bloodthirsty", "benefit": "You have cultivated a Savage Reputation, and when you are recognized, you instill fear in your enemies. All opponents within 6 squares of you take a -1 penalty to all their attack rolls. This is a Mind-Affecting Fear effect.", "description": {"value": "You have cultivated a Savage Reputation, and when you are recognized, you instill fear in your enemies. All opponents within 6 squares of you take a -1 penalty to all their attack rolls. This is a Mind-Affecting Fear effect."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "61db5e2c0c44ef67", "tags": ["damage-reduction", "positioning", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Savage Reputation"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.savage_reputation", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "9992fb4ee6ab40df", "name": "Tripwire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Jury-Rigger, Trained in Mechanics", "description": {"value": "As a Standard Action, you can set up a simple snare or trap across an opening up to 3 squares wide. You must have the required items to set the trap. Make a successful DC 20 Mechanics check to set the trap. Make a Deception check to conceal the wire. Compare the result of the Deception check to the Perception check of the next creature that passes through that square (-10 if it observes you setting the trap).\n\nIf the creature fails the Perception check, it takes the indicated use of the trap. If the creature succeeds, it can make a DC 10 Acrobatics check to avoid the wire. Select one of the following options:\n\nClothesline: Requires thin wire, set at neck height. Success results in the target falling Prone in the trapped square, ending its Actions for the turn and taking 1d6 points of damage.\nElectronic Tripwire: Success results in Mine damage (Treat as Frag Grenade, 2-square blast radius centered on one end of the wire). Target is automatically hit; roll 1d20+10 against the Reflex Defense of adjacent targets.\nTripwire: Requires thin wire, set at ankle height. Add 2 to the Deception check result. Success results in the target immediately falling Prone in the trapped square and ending its Actions for the turn."}, "benefit": "As a Standard Action, you can set up a simple snare or trap across an opening up to 3 squares wide. You must have the required items to set the trap. Make a successful DC 20 Mechanics check to set the trap. Make a Deception check to conceal the wire. Compare the result of the Deception check to the Perception check of the next creature that passes through that square (-10 if it observes you setting the trap).", "class": "", "category": "", "costNumeric": null, "treeId": "dca33c0215264a02", "tags": ["action_economy", "battlefield", "control", "controller", "deception", "mobility", "new_action", "social_control", "standard_action", "trap", "tree_dca33c0215264a02", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Tripwire"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "99c685b0631a5601", "name": "Swerve", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Fade Away", "benefit": "Once per encounter when an enemy makes an Attack of Opportunity against you, as a Reaction you can automatically negate the attack and immediately move up to half your speed. This movement does not provoke Attacks of Opportunity.", "description": {"value": "Once per encounter when an enemy makes an Attack of Opportunity against you, as a Reaction you can automatically negate the attack and immediately move up to half your speed. This movement does not provoke Attacks of Opportunity.\n\nIf you have the Combat Reflexes feat, you may use this Talent a number of times per encounter equal to your Dexterity bonus (minimum 1). You may still only use this Talent once per round.\n\noncentrate All Fire\nWhen you use the Aid Another Action to aid an ally's attack roll with a Vehicle Weapon, if the attack hits, it deals +1 die of damage. Any ally can only benefit from this Talent once per attack roll, regardless of how many allies with this Talent aid on the attack."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.fade_away"}], "_source": "canonical-csv"}, "treeId": "5a30489609182e8c", "tags": ["controller", "feat-chain", "mobility", "scout", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Swerve"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.swerve", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "9aa564522f427214", "name": "Launch Point", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Safe Zone", "benefit": "Any ally who starts his or her turn within your Safe Zone and then exits the Safe Zone gains a +2 bonus to attack rolls before the end of that ally's turn, provided that the ally is not within your Safe Zone when the attack is made.", "description": {"value": "Any ally who starts his or her turn within your Safe Zone and then exits the Safe Zone gains a +2 bonus to attack rolls before the end of that ally's turn, provided that the ally is not within your Safe Zone when the attack is made."}, "class": "4ee81a6708a516cd", "costNumeric": null, "category": "Pathfinder", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.safe_zone"}], "_source": "canonical-csv"}, "treeId": "383ff8d392488cf8", "tags": ["category_pathfinder", "cover", "feat_chain", "mobility", "positioning", "recon", "striker", "support", "survival", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Launch Point"}]}}, "effects": [{"_id": "635fb882-fe55-45a8-a2da-e5fbedf7a644", "name": "Launch Point", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.movement.exit_bonus", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Launch Point"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.launch_point", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "9ae263137f27e220", "name": "Capture Droid", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, you can use this Talent on an adjacent enemy Droid that has been reduced to 0 Hit Points or moved to the bottom of the Condition Track, but not destroyed.", "description": {"value": "Once per encounter, you can use this Talent on an adjacent enemy Droid that has been reduced to 0 Hit Points or moved to the bottom of the Condition Track, but not destroyed.\n\nAs a Standard Action, make a Mechanics check against the Droid's Will Defense. If your result equals or exceeds the Droid's Will Defense, the Droid moves +2 steps on the Condition Track, regains 1d8 Hit Points, becomes your ally, and it's Attitude toward you immediately shifts to Friendly.\n\nThe Droid fights on your side until the end of the encounter, at which point it is destroyed."}, "class": "db019dfbb271cdf6", "costNumeric": null, "category": "Improviser", "treeId": "7f37422819d7be6f", "tags": ["category_improviser", "control", "controller", "damage_reduction", "defender", "droid", "gear", "jury_rig", "mechanics", "mobility", "new_action", "positioning", "skills", "standard_action", "striker", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Capture Droid"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.capture_droid", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["defense.will", "turn.once-per-round"]}}}
{"_id": "9af262765ace3af1", "name": "Close Cover", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Watch This", "benefit": "If you occupy the same space as a Vehicle that is larger than the Vehicle you are Piloting, your Vehicle gains a +5 Cover bonus from the larger Vehicle.", "description": {"value": "If you occupy the same space as a Vehicle that is larger than the Vehicle you are Piloting, your Vehicle gains a +5 Cover bonus from the larger Vehicle."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.watch_this"}], "_source": "canonical-csv"}, "treeId": "296772ab8e69c9ef", "tags": ["feat-chain", "positioning", "scout", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Close Cover"}]}}, "effects": [{"_id": "8194a5ec-64aa-4755-b417-71b31ae2ae8e", "name": "Close Cover", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.cover", "mode": 2, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Close Cover"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.close_cover", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "9b337a844329fa17", "name": "Blowback", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you make an attack with a Rifle that deals damage in excess of your target's Damage Threshold, you can choose to push the target 1 square away from you.", "description": {"value": "When you make an attack with a Rifle that deals damage in excess of your target's Damage Threshold, you can choose to push the target 1 square away from you."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "1933731cc59f8463", "tags": ["controller", "positioning", "ranged"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Blowback"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.blowback", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "9bee4563b328def7", "name": "Sith Alchemy Specialist", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Sith Alchemy", "benefit": "You can modify an object with Sith Alchemy so that it gains a specific trait. Specific traits are listed in the Sith Alchemy Table, below. You can only perform one modification at a time. Unless otherwise noted, you cannot grant more than one benefit to a single object, and you cannot apply the same benefit more than once. You must spend a Force Point and devote 1 hour of uninterrupted work to apply a trait to the relevant object, and when you do so, you increase your Dark Side Score by 1.", "description": {"value": "You can modify an object with Sith Alchemy so that it gains a specific trait. Specific traits are listed in the Sith Alchemy Table, below. You can only perform one modification at a time. Unless otherwise noted, you cannot grant more than one benefit to a single object, and you cannot apply the same benefit more than once. You must spend a Force Point and devote 1 hour of uninterrupted work to apply a trait to the relevant object, and when you do so, you increase your Dark Side Score by 1."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.sith_alchemy"}], "_source": "canonical-csv"}, "treeId": "a67faf2ae089ab5d", "tags": ["category_sith_apprentice", "controller", "crafting", "dark_side", "feat_chain", "force", "force_execution", "force_point_spend", "jedi", "resource_spend", "sith_alchemy", "striker", "talent_chain", "tree_a67faf2ae089ab5d"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Sith Alchemy Specialist"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sith_alchemy_specialist", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "9befb5e9bce19fa0", "name": "The Will to Resist", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Once per turn, if your Will Defense is targeted, you may replace Will with a Use the Force check; you take -5 to Use the Force until the end of your next turn.", "description": "Replace Will Defense with a Use the Force check when targeted.", "costNumeric": null, "treeId": "d3661aa9906bdc79", "tags": ["defender", "force", "force_defense", "force_execution", "recovery", "resilience", "resource_recovery", "tree_d3661aa9906bdc79", "uncategorized_talent", "use_the_force", "will_defense"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "The Will to Resist"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.the_will_to_resist", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "9c0c0966b7c7c30e", "name": "Unstoppable", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can sometimes shrug off the effect of debilitating attacks. Once per encounter, if you are hit by an attack that would normally knock you down the Condition Track, you can reduce the number of steps you move down the Condition Track by 1 step (to a minimum of 0).", "description": {"value": "You can sometimes shrug off the effect of debilitating attacks. Once per encounter, if you are hit by an attack that would normally knock you down the Condition Track, you can reduce the number of steps you move down the Condition Track by 1 step (to a minimum of 0)."}, "class": "533f1066362655c7", "costNumeric": null, "category": "Gladiator", "treeId": "12a2a02b0901605d", "tags": ["condition-removal", "controller", "damage-reduction", "mobility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Unstoppable"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unstoppable", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "9c1e0b0566cb45c2", "name": "Weakening Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dastardly Strike", "benefit": "Whenever you deal damage to an opponent denied its Dexterity bonus to its Reflex Defense, you can choose not to move the target down the Condition Track and instead impose a -5 penalty on all your opponent's attack and melee damage rolls until the end of your next turn.", "description": {"value": "Whenever you deal damage to an opponent denied its Dexterity bonus to its Reflex Defense, you can choose not to move the target down the Condition Track and instead impose a -5 penalty on all your opponent's attack and melee damage rolls until the end of your next turn."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dastardly_attack"}], "_source": "canonical-csv"}, "treeId": "67b59e020c1660eb", "tags": ["condition-removal", "controller", "defender", "feat-chain", "melee", "scoundrel", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "damage", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.damage"}]}}, "effects": [{"_id": "48ea021d-a599-486b-af9e-e6d937fc1e82", "name": "Weakening Strike", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Weakening Strike", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.weakening_strike"}}}
{"_id": "9c2a4cbe82e922ec", "name": "Bodyguard III", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Attract Minion, Bodyguard I, Bodyguard II", "benefit": "When you redirect an attack to a minion using the Bodyguard I Talent, that minion can make an immediate melee or ranged attack against your attacker, if the attacker is within Range. Additionally, the bonus provided by the Bodyguard II Talent increases to your full Class Level.", "description": {"value": "When you redirect an attack to a minion using the Bodyguard I Talent, that minion can make an immediate melee or ranged attack against your attacker, if the attacker is within Range. Additionally, the bonus provided by the Bodyguard II Talent increases to your full Class Level."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.bodyguard_ii"}], "_source": "canonical-csv"}, "treeId": "560cc7994b357a0d", "tags": ["defender", "feat-chain", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Bodyguard III"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.bodyguard_iii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "9c88f3f82e6e2082", "name": "Bonded Mount", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charm Beast", "benefit": "Whenever you encounter a domesticated Beast with a Friendly or Helpful Attitude toward you, you can spend a Force Point as a Full-Round Action to bond the Beast to you as a mount. A Bonded Mount shares an emphatic link with you, allowing you to sense its emotions as a Free Action.", "description": {"value": "Whenever you encounter a domesticated Beast with a Friendly or Helpful Attitude toward you, you can spend a Force Point as a Full-Round Action to bond the Beast to you as a mount. A Bonded Mount shares an emphatic link with you, allowing you to sense its emotions as a Free Action.\n\nWhen you Ride a Bonded Mount, your mount uses your Reflex Defense and Will Defense instead of its own. Additionally, if your mount has any special senses (such as Scent, Darkvision, or Low-Light Vision) that you do not possess, you gain the benefits of its special senses as long as you are riding that mount."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.charm_beast"}], "_source": "canonical-csv"}, "treeId": "ed899f9f41fc1391", "tags": ["action_economy", "beast_companion", "category_force_adept", "controller", "dark_side", "defender", "force", "force_capacity", "force_defense", "force_execution", "force_point_spend", "force_training", "mystic", "nature", "resource_spend", "scout", "support", "survival", "sustained_damage", "tree_ed899f9f41fc1391"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "defense.will"], "enabled": true, "priority": 500, "description": "Bonded Mount"}]}}, "effects": [{"_id": "c54c1cda-216f-4847-a0d9-b1942931aa54", "name": "Bonded Mount", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.mount.shared_defenses", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Bonded Mount"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.bonded_mount", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["defense.reflex", "defense.will"]}}}
