{"_id": "16dd1c81c5145dd8", "name": "Repairs on the Fly", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can use the Repair application of the Mechanics skill to Repair Droid or Repair Object as a Standard Action. You can gain the benefits of this Talent only once per day per Droid, object, or Vehicle Repaired.", "description": {"value": "You can use the Repair application of the Mechanics skill to Repair Droid or Repair Object as a Standard Action. You can gain the benefits of this Talent only once per day per Droid, object, or Vehicle Repaired."}, "class": "b85240cf77cf95eb", "costNumeric": null, "category": "Military Engineer", "treeId": "e32009b1b0aee8c9", "tags": ["action-economy", "battlefield-control", "burst-damage", "controller", "evasion", "feat-chain", "force", "force-offense", "heavy-weapons", "leader", "mechanics", "mobility", "piloting", "positioning", "scaling", "scout", "skills", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 5, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Repairs on the Fly"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.repairs_on_the_fly", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
