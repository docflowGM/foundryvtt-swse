{"_id": "e0f66d77a2b065a7", "name": "Shoto Focus", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you wield both a one-handed Lightsaber and a Short Lightsaber (or Guard Shoto), you gain a +2 competence bonus on attack rolls made with the Short Lightsaber (or Guard Shoto).", "description": {"value": "Whenever you wield both a one-handed Lightsaber and a Short Lightsaber (or Guard Shoto), you gain a +2 competence bonus on attack rolls made with the Short Lightsaber (or Guard Shoto)."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "2359c05ff13f3feb", "tags": ["jedi", "lightsaber", "melee", "ranged", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Shoto Focus"}]}}, "effects": [{"_id": "0e1fb92b-b025-4128-8f91-dc92364c8487", "name": "Shoto Focus", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.shoto", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Shoto Focus"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.shoto_focus", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e15a3408b9474354", "name": "Jury-Rigger", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You may reroll any Mechanics check made to Jury-Rig. You must, however, accept the result of the reroll, even if it is worse.", "description": {"value": "You may reroll any Mechanics check made to Jury-Rig. You must, however, accept the result of the reroll, even if it is worse."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "dca33c0215264a02", "tags": ["action-economy", "controller", "defender", "evasion", "heavy-weapons", "mechanics", "perception", "positioning", "scout", "skills", "social", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 10, "type": "untyped", "predicates": ["defense.reflex", "attack.when-hit", "target.is-prone"], "enabled": true, "priority": 500, "description": "Jury-Rigger"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.jury_rigger", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.reflex", "attack.when-hit", "target.is-prone"]}}}
{"_id": "e15adb60be0dda02", "name": "Known Dissident", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Know Your Enemy", "benefit": "You are a well-know opponent of a large and influential government or organization (such as the Empire or the Corporate Sector Authority). Officials of any level are loath to take action against you, lest they inadvertently promote your cause. As a Standard Action, you can make a Persuasion check against the Will Defense of a single opponent within line of sight that can hear and understand you.", "description": {"value": "You are a well-know opponent of a large and influential government or organization (such as the Empire or the Corporate Sector Authority). Officials of any level are loath to take action against you, lest they inadvertently promote your cause. As a Standard Action, you can make a Persuasion check against the Will Defense of a single opponent within line of sight that can hear and understand you.\n\nIf the Persuasion check succeeds, that opponent may not attack you or any Vehicle you occupy until the start of your next turn. If the target is of higher level than you, it gains a +5 bonus to its Will Defense, and the target must be able to hear and understand you. If the target is attacked, the effect of this Talent ends.\n\nThis is a Mind-Affecting effect."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.know_your_enemy"}], "_source": "canonical-csv"}, "treeId": "d65a4816379802ee", "tags": ["defender", "feat-chain", "noble", "skills", "social", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 5, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Known Dissident"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.known_dissident", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.will"]}}}
