{"_id": "b0ecc747a76deb72", "name": "Unsavory Reputation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Inspire Fear I, Inspire Fear II, Inspire Fear III, Notorious", "benefit": "Any opponent that is reduced to half Hit Points or fewer while within 6 squares of you takes a -2 penalty on all attack rolls and Skill Checks for the duration of the encounter. This is a Mind-Affecting Fear effect.", "description": {"value": "Any opponent that is reduced to half Hit Points or fewer while within 6 squares of you takes a -2 penalty on all attack rolls and Skill Checks for the duration of the encounter. This is a Mind-Affecting Fear effect."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.inspire_fear_iii"}, {"type": "talent", "id": "swse.talent.notorious"}], "_source": "canonical-csv"}, "treeId": "c1be604242cb328f", "tags": ["damage-reduction", "feat-chain", "positioning", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Unsavory Reputation"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unsavory_reputation", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "b11a87e70f957ed2", "name": "Impel Ally II", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Impel Ally I", "benefit": "You can spend two Swift Actions to grant one ally the ability to take a Standard Action or Move Action. The ally must move immediately on your turn, before you do anything else, or else the opportunity is wasted.", "description": {"value": "You can spend two Swift Actions to grant one ally the ability to take a Standard Action or Move Action. The ally must move immediately on your turn, before you do anything else, or else the opportunity is wasted."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.impel_ally_i"}], "_source": "canonical-csv"}, "treeId": "560cc7994b357a0d", "tags": ["action-economy", "controller", "feat-chain", "mobility", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Impel Ally II"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.impel_ally_ii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b15fa2f45baf55ea", "name": "Entreat Beast", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charm Beast", "benefit": "You can use The Force to convince a small Beast to carry objects, deliver messages, or perform other minor tasks for you. If you are near a Beast that is at least Indifferent to you (whether this be a pet you bring with you or a Beast encountered in the wild), you can make a Use the Force check against the Beast's Will Defense as a Swift Action.", "description": {"value": "You can use The Force to convince a small Beast to carry objects, deliver messages, or perform other minor tasks for you. If you are near a Beast that is at least Indifferent to you (whether this be a pet you bring with you or a Beast encountered in the wild), you can make a Use the Force check against the Beast's Will Defense as a Swift Action.\n\nIf your Skill Check equals or exceeds the Beast's Will Defense, the Beast performs one task for you from the following list:\n\nDeliver an Object: The Beast attempts, to the best of its ability, to deliver one object from your person to another target within 30 squares of you.\nRetrieve an Object: The Beast attempts, to the best of its ability, to retrieve one unattended object within 30 squares of it and its line of sight and bring it to you.\nManipulate a Small Object: The Beast attempts, to the best of its ability, to press a button, pull a lever, or otherwise perform some minor activation of an unattended item within 30 squares."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.charm_beast"}], "_source": "canonical-csv"}, "treeId": "ed899f9f41fc1391", "tags": ["action_economy", "beast_companion", "category_force_adept", "controller", "defender", "feat_chain", "force", "force_capacity", "force_defense", "force_execution", "force_training", "mystic", "nature", "positioning", "support", "survival", "swift_action", "talent_chain", "tree_ed899f9f41fc1391", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Entreat Beast"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.entreat_beast", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "b1669310f65d42b7", "name": "Engineering Savant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Prerequisites: Skill Focus (Mechanics), Gearhead, , Patient Builder When you use the Tech Specialist feat on a weapon or suit of armor that you are proficient with, or a device, Droid, or Vehicle that you are familiar with (GM's call), you may pay twice as much for the parts to add the trait, but the trait does not count towards the one-per-item limit of traits. You cannot apply the same trait to the same item twice, and you may only use this Talent once per item that you upgrade.", "benefit": "Prerequisites: Skill Focus (Mechanics), Gearhead, , Patient Builder When you use the Tech Specialist feat on a weapon or suit of armor that you are proficient with, or a device, Droid, or Vehicle that you are familiar with (GM's call), you may pay twice as much for the parts to add the trait, but the trait does not count towards the one-per-item limit of traits. You cannot apply the same trait to the same item twice, and you may only use this Talent once per item that you upgrade.", "class": "", "category": "", "costNumeric": null, "treeId": "38d7c18ce4664c66", "tags": ["armor", "crafting", "defender", "droid", "engineering", "mechanics", "pilot", "skills", "striker", "tech", "tree_38d7c18ce4664c66", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Engineering Savant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b1960cbc28776a53", "name": "Silent Takedown", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Stealth", "benefit": "You are skilled at quietly knocking out or eliminating guards and others when they are caught unaware. If you damage an opponent that is unaware of you, that opponent cannot speak or make other noises until the end of your next turn. This is a Stun effect.", "description": {"value": "You are skilled at quietly knocking out or eliminating guards and others when they are caught unaware. If you damage an opponent that is unaware of you, that opponent cannot speak or make other noises until the end of your next turn. This is a Stun effect."}, "class": "e647ee8f065e1d19", "costNumeric": null, "category": "Infiltrator", "treeId": "7c7a8730e1b4381a", "tags": ["skills", "stealth", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Silent Takedown"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.silent_takedown", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b19ce52b1c965015", "name": "Nowhere to Hide", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You may choose to reroll any Gather Information checks made to Locate Individual, but you must accept the result of the reroll, even if it is worse.", "description": {"value": "You may choose to reroll any Gather Information checks made to Locate Individual, but you must accept the result of the reroll, even if it is worse."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "a47ed82a822e3962", "tags": ["scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Nowhere to Hide"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.nowhere_to_hide", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b1afecfea833a2a5", "name": "Deceptive Shot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Select one target in line of sight within 6 squares. You can spend two Swift Actions on the same turn to make a Deception check; if the check result equals or exceeds the target's Will Defense, the target is denied its Dexterity bonus to Reflex Defense against your attacks until the beginning of your next turn.", "description": {"value": "Select one target in line of sight within 6 squares. You can spend two Swift Actions on the same turn to make a Deception check; if the check result equals or exceeds the target's Will Defense, the target is denied its Dexterity bonus to Reflex Defense against your attacks until the beginning of your next turn."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "cb6f775cd227a3e3", "tags": ["defender", "positioning", "ranged", "skills", "social"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Deceptive Shot"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.deceptive_shot", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b1bfca51996bb303", "name": "Lose Pursuit", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When a Vehicle that you are Piloting is adjacent to a Vehicle of Colossal size or smaller that is Piloted by an ally, both you and your ally gain a +5 circumstance bonus to Pilot checks to avoid being pulled into a Dogfight as an Attack of Opportunity.", "description": {"value": "When a Vehicle that you are Piloting is adjacent to a Vehicle of Colossal size or smaller that is Piloted by an ally, both you and your ally gain a +5 circumstance bonus to Pilot checks to avoid being pulled into a Dogfight as an Attack of Opportunity."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "5f355ad4093d2bf8", "tags": ["evasion", "feat-chain", "positioning", "scout", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Lose Pursuit"}]}}, "effects": [{"_id": "fbe83864-95da-4809-8409-ed5651c78d22", "name": "Lose Pursuit", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.avoidance.dogfight", "mode": 2, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Lose Pursuit"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lose_pursuit", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b265aa9dd35c4c5b", "name": "Akk Dog Master", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Exotic Weapon Proficiency (Vibroshield)", "description": "You and your Akk Dog have bonded through The Force and can fight in concert. You can use any of the followers Actions on your turn: Attack in Concert: As a Standard Action, you can make a melee or ranged attack against a target in Range. If your Akk Dog Follower is adjacent to the target and your attack hits, the target also takes Piercing damage equal to 1d6 + the Akk Dog's Strength modifier. This additional damage is considered part of your attack for the purposes of resolving damage, Damage Reduction, Shield Rating, and overcoming Damage Threshold. Fall Upon Prey: As a Standard Action, you can make a melee or ranged attack against a target in Range, and your Akk Dog can take the Charge Action against a target within its Range. However, both you and your Akk Dog take a -5 penalty on your attack rolls (this replaces the bonus to attack rolls granted by the Charge Action). Paired Maul: As a Standard Action, you can make a melee or ranged attack against a target in Range. If the attack hits, your Akk Dog Follower gains a +2 competence bonus on it's next attack roll against that target. Prerequisite: Your Akk Dog Follower gains the Powerful Charge feat. Prerequisite: Whenever you are targeted by an attack made by an enemy adjacent to your Akk Dog Follower, that attacker provokes an Attack of Opportunity from your Akk Dog Follower. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Force Users Prerequisite: , Vibroshield Mastery While on Haruun Kal, you may spend a Force Point to gain a +2 Force bonus to all Use the Force checks to activate Force Powers or Force Talents, increase your speed by 1 square, and all native wildlife native is treated as one step more Friendly (see Attitude). These effects last until the end of the encounter. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Force Users You may treat Talents from the Lightsaber Combat Talent Tree as Force Talents. Additionally, the Vibroshield satisfies the requirement for an activated Lightsaber for any Force Talent or Force Power. If you create your own Vibroshield (see Build Object), you are considered to be behind Improved Cover instead of Cover when using the Fight Defensively Action.", "benefit": "You and your Akk Dog have bonded through The Force and can fight in concert. You can use any of the followers Actions on your turn: Attack in Concert: As a Standard Action, you can make a melee or ranged attack against a target in Range. If your Akk Dog Follower is adjacent to the target and your attack hits, the target also takes Piercing damage equal to 1d6 + the Akk Dog's Strength modifier. This additional damage is considered part of your attack for the purposes of resolving damage, Damage Reduction, Shield Rating, and overcoming Damage Threshold. Fall Upon Prey: As a Standard Action, you can make a melee or ranged attack against a target in Range, and your Akk Dog can take the Charge Action against a target within its Range. However, both you and your Akk Dog take a -5 penalty on your attack rolls (this replaces the bonus to attack rolls granted by the Charge Action). Paired Maul: As a Standard Action, you can make a melee or ranged attack against a target in Range. If the attack hits, your Akk Dog Follower gains a +2 competence bonus on it's next attack roll against that target. Prerequisite: Your Akk Dog Follower gains the Powerful Charge feat. Prerequisite: Whenever you are targeted by an attack made by an enemy adjacent to your Akk Dog Follower, that attacker provokes an Attack of Opportunity from your Akk Dog Follower. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Force Users Prerequisite: , Vibroshield Mastery While on Haruun Kal, you may spend a Force Point to gain a +2 Force bonus to all Use the Force checks to activate Force Powers or Force Talents, increase your speed by 1 square, and all native wildlife native is treated as one step more Friendly (see Attitude). These effects last until the end of the encounter. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Force Users You may treat Talents from the Lightsaber Combat Talent Tree as Force Talents. Additionally, the Vibroshield satisfies the requirement for an activated Lightsaber for any Force Talent or Force Power. If you create your own Vibroshield (see Build Object), you are considered to be behind Improved Cover instead of Cover when using the Fight Defensively Action.", "class": "", "category": "", "costNumeric": null, "treeId": "46d03bab0cf74a14", "tags": ["action_economy", "beast_companion", "cover", "damage_reduction", "defender", "defense", "feat_chain", "force", "force_capacity", "force_defense", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "leader", "lightsaber", "melee", "mobility", "mount", "new_action", "offense_melee", "offense_ranged", "positioning", "ranged", "resource_spend", "scaling", "shield", "shields", "standard_action", "striker", "support", "survival", "talent_chain", "tree_46d03bab0cf74a14", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.on-current-turn"], "enabled": true, "priority": 500, "description": "Akk Dog Master"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.on-current-turn"]}}}
