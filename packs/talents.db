{"_id": "4c23c64e3ab8dcc6", "name": "Jet Pack Withdraw", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Jet Pack Training", "benefit": "Once per encounter, as a Reaction when an opponent moves adjacent to you, you can expend one charge of your Jet Pack to fly and Move your Speed, or Withdraw.", "description": {"value": "Once per encounter, as a Reaction when an opponent moves adjacent to you, you can expend one charge of your Jet Pack to fly and Move your Speed, or Withdraw."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.jet_pack_training"}], "_source": "canonical-csv"}, "treeId": "1f50c63b6f08de10", "tags": ["controller", "feat-chain", "heavy-weapons", "mobility", "positioning", "soldier", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Jet Pack Withdraw"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.jet_pack_withdraw", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "4c689ac688e80c9e", "name": "Trick Step", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, make an Initiative check, opposed by the Initiative check of an enemy within your line of sight.", "description": {"value": "As a Swift Action, make an Initiative check, opposed by the Initiative check of an enemy within your line of sight.\n\nIf your check result equals or exceeds the target's check, the target is considered Flat-Footed against the next attack you make before the end of your turn. If the target's check result is higher, you are considered Flat-Footed against the next attack made by the target before the start of your next turn."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "4af97ad058b1b30f", "tags": ["action-economy", "controller", "defender", "evasion", "mobility", "positioning", "scoundrel", "skills", "social"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Trick Step"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.trick_step", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "4c7eb9c679ee43a8", "name": "Demoralizing Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Noble Fencing Style", "benefit": "As a Reaction, you can designate an enemy you have just hit with a melee attack. The enemy takes only half damage from the attack, but takes a -5 penalty on attacks made against you until the end of your next turn. A single target may only be affected by this Talent once per round. This is a Mind-Affecting effect.", "description": {"value": "As a Reaction, you can designate an enemy you have just hit with a melee attack. The enemy takes only half damage from the attack, but takes a -5 penalty on attacks made against you until the end of your next turn. A single target may only be affected by this Talent once per round. This is a Mind-Affecting effect."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.noble_fencing_style"}], "_source": "canonical-csv"}, "treeId": "9df067790c87e6bc", "tags": ["defender", "feat-chain", "melee", "noble", "striker", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Demoralizing Defense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.demoralizing_defense", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["attack.with-melee", "turn.once-per-round"]}}}
