{"_id": "642c6c8643db7470", "name": "Greater Weapon Focus", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Focus (Chosen Weapon)", "benefit": "Choose one Exotic Weapon or weapon group with which you're proficient. You gain a +1 bonus on attack rolls with the chosen Exotic Weapon or weapon from the chosen group. This bonus stacks with the bonus granted by the Weapon Focus feat.", "description": {"value": "Choose one Exotic Weapon or weapon group with which you're proficient. You gain a +1 bonus on attack rolls with the chosen Exotic Weapon or weapon from the chosen group. This bonus stacks with the bonus granted by the Weapon Focus feat.\n\nYou may select this Talent multiple times. Each time you select this Talent, it applies to a different Exotic Weapon or weapon group."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "2f720d8b061f9bd0", "tags": ["damage-reduction", "defender", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Greater Weapon Focus"}]}}, "effects": [{"_id": "7a2683eb-2396-4638-aa86-e28807081035", "name": "Greater Weapon Focus", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Greater Weapon Focus"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.greater_weapon_focus", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.414Z", "detectedPredicates": []}}}
{"_id": "648d9634a3795988", "name": "Spynet Agent", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Bothan, or two Talents from the Infiltration Talent Tree", "benefit": "You can use your Gather Information check modifier instead of your Knowledge (Galactic Lore) check modifier when making Knowledge (Galactic Lore) checks. You are considered Trained in the Knowledge (Galactic Lore) skill for the purpose of using this Talent. If you are entitled to a Knowledge (Galactic Lore) reroll, you can reroll your Gather Information check instead (subject to the same circumstances and limitations).", "description": {"value": "You can use your Gather Information check modifier instead of your Knowledge (Galactic Lore) check modifier when making Knowledge (Galactic Lore) checks. You are considered Trained in the Knowledge (Galactic Lore) skill for the purpose of using this Talent. If you are entitled to a Knowledge (Galactic Lore) reroll, you can reroll your Gather Information check instead (subject to the same circumstances and limitations)."}, "costNumeric": null, "treeId": "d20682671d035cef", "tags": ["action_economy", "defender", "force", "force_defense", "force_offense", "intel", "investigation", "knowledge", "leader", "mobility", "network", "precision", "resources", "social", "social_network", "striker", "tree_d20682671d035cef", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Spynet Agent"}]}}, "effects": [{"_id": "83955a11-6392-40c8-af86-13d443630373", "name": "Spynet Agent", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.gatherInfo", "mode": 5, "value": "enhanced"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Spynet Agent"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, 