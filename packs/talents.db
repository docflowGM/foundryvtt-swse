{"_id": "8063a6b94b1de530", "name": "Close-Quarters Fighter", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you occupy the same square as your target or are adjacent to your target, you gain a +1 circumstance bonus to your melee attack rolls against that target.", "description": {"value": "Whenever you occupy the same square as your target or are adjacent to your target, you gain a +1 circumstance bonus to your melee attack rolls against that target."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "fad8118981c532f0", "tags": ["melee", "positioning", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Close-Quarters Fighter"}]}}, "effects": [{"_id": "52ac954c-2e04-4391-bf29-a25057f27a80", "name": "Close-Quarters Fighter", "icon": "icons/svg/fist.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Close-Quarters Fighter"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.close_quarters_fighter", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "8070dbbea2886bbd", "name": "Improved Surveillance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Surveillance, Trained in Perception", "benefit": "When you successfully use the Surveillance Talent, you grant yourself and your allies a +1 insight bonus to all Defenses against the target.", "description": {"value": "When you successfully use the Surveillance Talent, you grant yourself and your allies a +1 insight bonus to all Defenses against the target."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.surveillance"}], "_source": "canonical-csv"}, "treeId": "7c42882a1347ef18", "tags": ["defender", "feat-chain", "scout", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.will", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}]}}, "effects": [{"_id": "a9c922ec-ac94-42c6-8705-b39c8c2e5f2a", "name": "Improved Surveillance", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.all", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Improved Surveillance", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_surveillance"}}}
{"_id": "80a24150fd2f3163", "name": "Droid Jammer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can construct a short-range Jammer that affects Droids. As a Full-Round Action, you make a Mechanics check to build the Jammer. When a Droid comes within 6 squares of you, compare the result of your Mechanics check to the Droid's Will Defense. If your check result equals or exceeds the Droid's Will Defense, the Droid can only take Swift Actions as long as it remains within the radius of the Jammer.", "description": {"value": "You can construct a short-range Jammer that affects Droids. As a Full-Round Action, you make a Mechanics check to build the Jammer. When a Droid comes within 6 squares of you, compare the result of your Mechanics check to the Droid's Will Defense. If your check result equals or exceeds the Droid's Will Defense, the Droid can only take Swift Actions as long as it remains within the radius of the Jammer.\n\nDroids that are immune to the effect of a Restraining Bolt are immune to the effects of this Talent. The Jammer functions for the remainder of the encounter. You may only have one Jammer (Device or Droid) active at a time."}, "class": "de3f367749b82fcf", "costNumeric": null, "category": "Saboteur", "treeId": "8897a36d59662ee9", "tags": ["action-economy", "defender", "mechanics", "mobility", "positioning", "skills"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Droid Jammer"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.droid_jammer", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "80e14ef4d1f52a4a", "name": "Precision", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can make a melee attack with a Lightsaber against an adjacent opponent. If the attack hits, it deals normal damage and also reduces the target's speed to 2 squares until the end of your next turn.", "description": {"value": "As a Standard Action, you can make a melee attack with a Lightsaber against an adjacent opponent. If the attack hits, it deals normal damage and also reduces the target's speed to 2 squares until the end of your next turn."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "2359c05ff13f3feb", "tags": ["damage-reduction", "jedi", "lightsaber", "melee", "mobility", "positioning"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Precision"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.precision", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
{"_id": "81154e9fc33e43b3", "name": "Direct", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can return one spent Force Power to the Force Power Suite of any ally within 6 squares of you and in your line of sight. The Force Power must have been spent by the ally you designate.", "description": {"value": "As a Standard Action, you can return one spent Force Power to the Force Power Suite of any ally within 6 squares of you and in your line of sight. The Force Power must have been spent by the ally you designate."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "152047d6ab7896ad", "tags": ["force", "jedi", "light-side", "positioning", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Direct"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.direct", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": ["proximity.ally-nearby"]}}}
{"_id": "816ac9cc1e6c413b", "name": "Force Meld", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "However, the characters using the Aid Another Reaction takes a -5 penalty on all Use the Force checks until the end of their next turn. Additionally, when any character participating in the takes damage that exceeds their Will Defense; all other participants take damage equal to the original damage minus their own Will Defense. Homebrew Reference Book: Legacy of the Force Sourcebook", "benefit": "However, the characters using the Aid Another Reaction takes a -5 penalty on all Use the Force checks until the end of their next turn. Additionally, when any character participating in the takes damage that exceeds their Will Defense; all other participants take damage equal to the original damage minus their own Will Defense. Homebrew Reference Book: Legacy of the Force Sourcebook", "class": "", "category": "", "costNumeric": null, "treeId": "d6b4331c0e31f7e3", "tags": ["action_economy", "defender", "force", "force_defense", "force_execution", "force_meld", "force_offense", "initiative", "pilot", "precognition", "reaction", "senses", "striker", "support", "teamwork", "tree_d6b4331c0e31f7e3", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Force Meld"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "81cd2a2473e248a0", "name": "In Balance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "As a Full-Round Action, you may make a DC 20 Use the Force check. If successful, you may spend a Force Point to negate Dark Side Points gained by activating Force Powers with the [Dark Side] descriptor in your Force Power Suite; you may negate a number of Dark Side Points in this way equal to your Wisdom modifier (minimum 1). After successfully activating this Talent, you may not attempt it again for 24 hours.", "benefit": "As a Full-Round Action, you may make a DC 20 Use the Force check. If successful, you may spend a Force Point to negate Dark Side Points gained by activating Force Powers with the [Dark Side] descriptor in your Force Power Suite; you may negate a number of Dark Side Points in this way equal to your Wisdom modifier (minimum 1). After successfully activating this Talent, you may not attempt it again for 24 hours.", "class": "", "category": "", "costNumeric": null, "treeId": "dcac793cc9fe42a7", "tags": ["action_economy", "balance", "dark_side", "force", "force_capacity", "force_execution", "force_point_spend", "force_power_synergy", "resource_spend", "survivability", "sustained_damage", "tree_dcac793cc9fe42a7", "uncategorized_talent", "use_the_force", "will_defense"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] In Balance"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
