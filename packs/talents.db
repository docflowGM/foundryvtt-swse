{"_id": "e07f87b5dbcf035f", "name": "Labyrinthine Mind", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, as a Reaction, you become immune to all Mind-Affecting effects until the end of your next turn (you can choose to ignore this for beneficial effects).", "description": {"value": "Once per encounter, as a Reaction, you become immune to all Mind-Affecting effects until the end of your next turn (you can choose to ignore this for beneficial effects).\n\nAny Mind-Affecting effects currently afflicting you are also removed, though you can choose to retain any beneficial effects you currently have."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "cee9b9398682b7d0", "tags": ["scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Labyrinthine Mind"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.labyrinthine_mind", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "e09d40421ade49e8", "name": "Binding Sickle", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "When you miss with an attack made with a Chain Sickle, or fail a Grapple attempt made with one, the target of that attack or attempt takes damage equal to your Dexterity modifier (minimum +1). Homebrew Reference Book: Dathomir Field Guide", "benefit": "When you miss with an attack made with a Chain Sickle, or fail a Grapple attempt made with one, the target of that attack or attempt takes damage equal to your Dexterity modifier (minimum +1). Homebrew Reference Book: Dathomir Field Guide", "class": "", "category": "", "costNumeric": null, "treeId": "ad16f3e5f4f7441b", "tags": ["exotic_weapon", "ranged_control", "spellcasting", "striker", "tree_ad16f3e5f4f7441b", "uncategorized_talent", "witchcraft"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Binding Sickle"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
