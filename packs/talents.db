{"_id": "98a88ebf26ac318a", "name": "Whirling Death", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Melee Smash, Unrelenting Assault", "benefit": "You twirl your Weapon around you in a blur, creating a circle of death around you. Any enemy target that begins its turn adjacent to you takes damage equal to your Strength bonus. You must be wielding a Melee Weapon to be using this Talent.", "description": {"value": "You twirl your Weapon around you in a blur, creating a circle of death around you. Any enemy target that begins its turn adjacent to you takes damage equal to your Strength bonus. You must be wielding a Melee Weapon to be using this Talent."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.unrelenting_assault"}], "_source": "canonical-csv"}, "treeId": "fad8118981c532f0", "tags": ["feat-chain", "melee", "positioning", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Whirling Death"}]}}, "effects": [{"_id": "425ab35b-2c6b-47fc-a03b-35f2830b161e", "name": "Whirling Death", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.adjacent", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Whirling Death"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.whirling_death", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": []}}}
{"_id": "98c720992c5b428e", "name": "Focus Terror", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Swift Action, you can harness the fear felt by your allies and transform it into a powerful motivational tool. All allies within 12 squares of you and in your line of sight move +2 steps along the Condition Track, but suffer a -2 penalty on attack rolls and Skill Checks for a number of rounds equal to your Character Level.", "description": {"value": "Once per encounter as a Swift Action, you can harness the fear felt by your allies and transform it into a powerful motivational tool. All allies within 12 squares of you and in your line of sight move +2 steps along the Condition Track, but suffer a -2 penalty on attack rolls and Skill Checks for a number of rounds equal to your Character Level."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "4d5ac20318ef56b6", "tags": ["action_economy", "category_sith_apprentice", "condition_removal", "controller", "dark_side", "defender", "force", "force_control", "force_defense", "force_execution", "force_offense", "jedi", "mobility", "positioning", "striker", "sustained_damage", "swift_action"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Focus Terror"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.focus_terror", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["defense.reflex", "turn.once-per-round"]}}}
