{"_id": "2b808a4a90614f92", "name": "Strength of the Empire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Ward", "benefit": "When an ally within 12 squares of you and in your line of sight hits with a Lightsaber attack, you deal +1 die of damage with the next Lightsaber attack you make before the end of your next turn.", "description": {"value": "When an ally within 12 squares of you and in your line of sight hits with a Lightsaber attack, you deal +1 die of damage with the next Lightsaber attack you make before the end of your next turn.\n\nrmored Guard\n\nWhen you use the Ward Talent, your ally's Cover bonus to their Reflex Defense is increased by one-half the Armor bonus of any Natural Armor you possess as well as any Armor you are wearing."}, "class": "ec505163e5647cc6", "costNumeric": null, "category": "Imperial Knight", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.knights_morale"}], "_source": "canonical-csv"}, "treeId": "8048efd85ae61101", "tags": ["category_imperial_knight", "cover", "defense", "force", "imperial", "leader", "lightsaber", "melee", "offense_melee", "positioning", "striker", "support"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.fortitude"}]}}, "effects": [{"_id": "dbefdea5-6fc9-4630-9345-56506e86d915", "name": "Strength of the Empire", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.fortitude", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Strength of the Empire", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.strength_of_the_empire"}}}
