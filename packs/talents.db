{"_id": "d6faa4b87d5c35ce", "name": "Pulling the Strings", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can make a Persuasion check against the Will Defense of a target within 12 squares. If you succeed, you move the target up to half its speed toward you through the safest route, and you make an immediate ranged or melee attack against the the target if it is within Range. You cannot move an opponent into a Hazard (such as into lava or off a cliff).", "description": {"value": "As a Standard Action, you can make a Persuasion check against the Will Defense of a target within 12 squares. If you succeed, you move the target up to half its speed toward you through the safest route, and you make an immediate ranged or melee attack against the the target if it is within Range. You cannot move an opponent into a Hazard (such as into lava or off a cliff)."}, "costNumeric": null, "treeId": "db1b30c2163d0650", "tags": ["controller", "deception", "defender", "manipulation", "mobility", "new_action", "offense_melee", "persuasion", "positioning", "skills", "social", "standard_action", "tree_db1b30c2163d0650", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Pulling the Strings"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.pulling_the_strings", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "d7870d0940a3ce0b", "name": "Ranged Disarm", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can Disarm an opponent using a ranged attack. If your ranged Disarm attack fails, your opponent doesn't get to make a free attack against you.", "description": {"value": "You can Disarm an opponent using a ranged attack. If your ranged Disarm attack fails, your opponent doesn't get to make a free attack against you."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "13776eed744d410c", "tags": ["action-economy", "condition-removal", "controller", "defender", "lightsaber", "melee", "mobility", "positioning", "ranged", "striker", "unarmed"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "movement.while-moving"], "enabled": true, "priority": 500, "description": "Ranged Disarm"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ranged_disarm", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "movement.while-moving"]}}}
{"_id": "d7e9b15e21ea1c4e", "name": "Devastating Melee Smash", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Melee Smash", "benefit": "Once per encounter, you can attempt a Devastating Melee Smash. You must declare this special melee attack before making the attack roll. If the attack rolls succeeds, add half your level to the damage, instead of the normal +1 bonus for the Melee Smash Talent.", "description": {"value": "Once per encounter, you can attempt a Devastating Melee Smash. You must declare this special melee attack before making the attack roll. If the attack rolls succeeds, add half your level to the damage, instead of the normal +1 bonus for the Melee Smash Talent.\n\nThe damage from this Talent does not stack with any damage bonus provided by the Powerful Charge feat."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.melee_smash"}], "_source": "canonical-csv"}, "treeId": "67fdd8dce9abd6c1", "tags": ["melee", "mobility", "scaling", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["attack.with-melee", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Devastating Melee Smash"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.devastating_melee_smash", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["attack.with-melee", "turn.once-per-round"]}}}
{"_id": "d838141fe404a9fb", "name": "Defensive Circle", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Battle Meditation, Block or Deflect, Jedi Battle Commander", "benefit": "As a Swift Action, you and any allies affected by your Battle Meditation gain a +2 insight bonus to their Reflex Defense, lasting as long as they are affected by your Battle Meditation. Additionally, you gain a +1 bonus to your Use the Force checks to Block and Deflect (as per the Talents) for each adjacent ally wielding a Lightsaber.", "description": {"value": "As a Swift Action, you and any allies affected by your Battle Meditation gain a +2 insight bonus to their Reflex Defense, lasting as long as they are affected by your Battle Meditation. Additionally, you gain a +1 bonus to your Use the Force checks to Block and Deflect (as per the Talents) for each adjacent ally wielding a Lightsaber."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "dfc4142435b4356d", "tags": ["defender", "feat-chain", "force", "force-defense", "jedi", "light-side", "positioning", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}]}}, "effects": [{"_id": "6a224ecd-b448-4e2d-a126-4c6a26131c0c", "name": "Defensive Circle", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.reflex", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Defensive Circle", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.defensive_circle"}}}
{"_id": "d8d7218123a28f39", "name": "Fleet Tactics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charisma 13, Fleet Deployment", "benefit": "As a Standard Action, you may designate a single Vehicle as the target of a large-scale assault. If you succeed on a DC 15 Knowledge (Tactics) check, all allied Gunners within line of sight deal 1 additional die of damage to the target with each successful ranged attack until the start of your next turn.", "description": {"value": "As a Standard Action, you may designate a single Vehicle as the target of a large-scale assault. If you succeed on a DC 15 Knowledge (Tactics) check, all allied Gunners within line of sight deal 1 additional die of damage to the target with each successful ranged attack until the start of your next turn.\n\nThis is a Mind-Affecting effect."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "cha", "min": 13}, {"type": "talent", "id": "swse.talent.fleet_deployment"}], "_source": "canonical-csv"}, "treeId": "057a978a7dc1d5a7", "tags": ["feat-chain", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Fleet Tactics"}]}}, "effects": [{"_id": "5418f918-6d09-4764-a21e-a3d95edc8f0e", "name": "Fleet Tactics", "icon": "icons/svg/rocket.svg", "changes": [{"key": "system.damage.vehicle", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Fleet Tactics"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fleet_tactics", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": []}}}
{"_id": "d9241073d3b975e6", "name": "Ward", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, designate one adjacent ally. Until the end of your next turn, as long as that ally remains adjacent to you, you are considered to be providing that ally with Soft Cover against all attacks.", "description": {"value": "As a Swift Action, designate one adjacent ally. Until the end of your next turn, as long as that ally remains adjacent to you, you are considered to be providing that ally with Soft Cover against all attacks.\n\nYou cannot be designated as the target of this Talent (such as, when it is used by an ally) if you have used this Talent since the start of your last turn, and you cannot use this Talent if you are currently designated as another ally's Ward."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "c92c2cbc79b8a515", "tags": ["action-economy", "armor", "defender", "positioning", "scaling", "soldier", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "attack.when-hit", "proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Ward"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ward", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["defense.reflex", "attack.when-hit", "proximity.ally-nearby"]}}}
