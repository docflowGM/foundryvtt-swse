{"_id": "69420a9a5ff5d8b9", "name": "Rapid Alchemy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can perform minor alchemical alterations to a Melee Weapon you wield. For the remainder of the encounter, you gain a +2 Equipment bonus on attack rolls with that Weapon. Additionally, once before the end of the encounter, you can sacrifice this bonus as a Free Action to gain a +5 Equipment bonus on a single damage roll you make with that Weapon.", "description": {"value": "As a Standard Action, you can perform minor alchemical alterations to a Melee Weapon you wield. For the remainder of the encounter, you gain a +2 Equipment bonus on attack rolls with that Weapon. Additionally, once before the end of the encounter, you can sacrifice this bonus as a Free Action to gain a +5 Equipment bonus on a single damage roll you make with that Weapon."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "a67faf2ae089ab5d", "tags": ["category_sith_apprentice", "controller", "crafting", "dark_side", "force", "force_execution", "force_offense", "jedi", "melee", "new_action", "sith_alchemy", "standard_action", "striker", "tree_a67faf2ae089ab5d"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Rapid Alchemy"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.rapid_alchemy", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["turn.once-per-round"]}}}
