{"_id": "456a0aa44da5105c", "name": "Disarming Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Intelligence 13, Improved Disarm, Weapon Specialization", "benefit": "Choose a single Exotic Weapon or weapon group with which you are proficient. You ignore a target's armor bonus to Reflex Defense when Disarming with such a weapon. Additionally, as a Free Action, once per encounter, you can grant yourself a +10 bonus on your attack roll when attempting to Disarm an opponent while using such a weapon.", "description": {"value": "Choose a single Exotic Weapon or weapon group with which you are proficient. You ignore a target's armor bonus to Reflex Defense when Disarming with such a weapon. Additionally, as a Free Action, once per encounter, you can grant yourself a +10 bonus on your attack roll when attempting to Disarm an opponent while using such a weapon."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "int", "min": 13}, {"type": "talent", "id": "swse.talent.weapon_specialization"}], "_source": "canonical-csv"}, "treeId": "2e9265a596cc43f7", "tags": ["armor", "defender", "feat-chain", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 10, "type": "untyped", "predicates": ["defense.reflex", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Disarming Attack"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.disarming_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.411Z", "detectedPredicates": ["defense.reflex", "turn.once-per-round"]}}}
