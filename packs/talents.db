{"_id": "d350b28e72652d29", "name": "Wicked Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Focus (Lightsabers), Weapon Specialization (Lightsabers)", "benefit": "When you score a critical hit with a Lightsaber, you may spend a Force Point to move the target -2 steps along the Condition Track.", "description": {"value": "When you score a critical hit with a Lightsaber, you may spend a Force Point to move the target -2 steps along the Condition Track."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.weapon_specialization"}], "_source": "canonical-csv"}, "treeId": "d1037bc7a08ea80b", "tags": ["category_sith_apprentice", "condition_removal", "controller", "critical_hit", "dark_side", "feat_chain", "force", "force_control", "force_execution", "force_point_spend", "jedi", "lightsaber", "melee", "mobility", "offense_melee", "precision", "resource_spend", "striker", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Wicked Strike"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.wicked_strike", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["attack.when-hit"]}}}
