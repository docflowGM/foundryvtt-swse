{"_id": "c7f46a5c92d7dd5e", "name": "Uncanny Dodge II", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Acute Senses, Improved Initiative, Uncanny Dodge I", "benefit": "You cannot be Flanked. You can react to opponents on opposite sides of you as easily as you can react to a single attacker.", "description": {"value": "You cannot be Flanked. You can react to opponents on opposite sides of you as easily as you can react to a single attacker.\n\nIf you are the Pilot, this Talent applies to your Vehicle."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.uncanny_dodge_i"}], "_source": "canonical-csv"}, "treeId": "1c48d1cd9ab1f5c8", "tags": ["evasion", "feat-chain", "scout", "talent-chain"], "executionModel": "PASSIVE", "subType": "RULE", "abilityMeta": {"rules": [{"type": "CANNOT_BE_FLANKED", "description": "You cannot be flanked"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.uncanny_dodge_ii"}}}
