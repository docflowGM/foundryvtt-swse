{"_id": "cdb01f90827fad8c", "name": "Stinging Assault", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Specialization", "benefit": "You can deliver nasty injuries that leave your opponents reeling. Whenever you successfully damage an opponent using a Slashing weapon that you have the Weapon Specialization Talent for, your opponent takes a -2 penalty on melee attacks against you until the start of your next turn. The effects of multiple Stinging Assaults do not stack.", "description": {"value": "You can deliver nasty injuries that leave your opponents reeling. Whenever you successfully damage an opponent using a Slashing weapon that you have the Weapon Specialization Talent for, your opponent takes a -2 penalty on melee attacks against you until the start of your next turn. The effects of multiple Stinging Assaults do not stack."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.weapon_specialization"}], "_source": "canonical-csv"}, "treeId": "2e9265a596cc43f7", "tags": ["feat-chain", "melee", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Stinging Assault"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stinging_assault", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "cdcdb85912d9eb67", "name": "Force Blank", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You are especially hard to detect using The Force. Attempts to detect you using the Sense Surroundings aspect of the Use the Force skill suffer a -10 penalty.", "description": {"value": "You are especially hard to detect using The Force. Attempts to detect you using the Sense Surroundings aspect of the Use the Force skill suffer a -10 penalty."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "29b16e48a3dbf165", "tags": ["damage-reduction", "force", "scoundrel", "scout", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Force Blank"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_blank", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cddfb9833c7d3344", "name": "Channel Vitality", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can fuel your mastery of The Force with your own vitality. As a Swift Action, you can move -1 step down the Condition Track to gain a temporary Force Point. This temporary Force Point lasts until the end of your turn, at which point it is lost if it has not been used.", "description": {"value": "You can fuel your mastery of The Force with your own vitality. As a Swift Action, you can move -1 step down the Condition Track to gain a temporary Force Point. This temporary Force Point lasts until the end of your turn, at which point it is lost if it has not been used."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "a3d0b7c9a6d041f2", "tags": ["action_economy", "category_force_adept", "condition_removal", "controller", "force", "force_capacity", "force_control", "force_execution", "force_point_spend", "force_training", "mobility", "mystic", "resource_spend", "swift_action"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Channel Vitality"}]}}, "effects": [{"_id": "cd17d39c-c610-4b0b-8acc-83305f8cec2b", "name": "Channel Vitality", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.forcePoints", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Channel Vitality"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.channel_vitality", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cdf3e44536031f53", "name": "Distracting Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Brutal Attack (Chosen Weapon)", "benefit": "When you deal damage to a target with a melee or ranged attack, compare the attack roll to the targets' Will Defense. If the attack roll also meets or exceeds the target's Will Defense, the target takes a -2 penalty to their Reflex Defense until the end of your next turn.", "description": {"value": "When you deal damage to a target with a melee or ranged attack, compare the attack roll to the targets' Will Defense. If the attack roll also meets or exceeds the target's Will Defense, the target takes a -2 penalty to their Reflex Defense until the end of your next turn."}, "class": "533f1066362655c7", "costNumeric": null, "category": "Gladiator", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.brutal_attack"}], "_source": "canonical-csv"}, "treeId": "12a2a02b0901605d", "tags": ["defender", "feat-chain", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "defense.will"], "enabled": true, "priority": 500, "description": "Distracting Attack"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.distracting_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["defense.reflex", "defense.will"]}}}
{"_id": "cdf46b8cdde49733", "name": "Knowledge is Power", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "SpyNet Agent", "benefit": "As a Swift Action, you can designate a single target within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL. If the check is successful, for the remainder of the encounter you score a Critical Hit against that target on a natural roll of 19 or 20.", "description": {"value": "As a Swift Action, you can designate a single target within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL. If the check is successful, for the remainder of the encounter you score a Critical Hit against that target on a natural roll of 19 or 20.\n\nIf you have another ability that increases your weapon's critical range against that target (such as the Elite Trooper's Extended Critical Range Talent, or the Jedi Knight's Vaapad Talent), you increase this range by 1 (for example, from 19-20 to 18-20). However, anything other than a Natural 20 is not considered an automatic hit; if you roll anything other than a Natural 20 and still miss the target, you do not score a Critical Hit."}, "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.spynet_agent"}], "_source": "canonical-csv"}, "treeId": "d20682671d035cef", "tags": ["action_economy", "critical_hit", "feat_chain", "investigation", "knowledge", "positioning", "precision", "resources", "social", "social_network", "striker", "swift_action", "talent_chain", "tree_d20682671d035cef", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Knowledge is Power"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.knowledge_is_power", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "ce1f5d3316b052f6", "name": "True Betrayal", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Cast Suspicion, Friend or Foe", "benefit": "As a Standard Action, make a Persuasion check against the Will Defense of one enemy within your line of sight that can hear and understand you. If your check result equals or exceeds the target's Will Defense, that target immediately makes an attack (as a Free Action) against another target of your choice.", "description": {"value": "As a Standard Action, make a Persuasion check against the Will Defense of one enemy within your line of sight that can hear and understand you. If your check result equals or exceeds the target's Will Defense, that target immediately makes an attack (as a Free Action) against another target of your choice.\n\nThis can be a melee attack against an adjacent target or a ranged attack against a target within the attacker's Point-Blank Range. The target gains a +5 bonus to its Will Defense if it is of a higher level than you. This is a Mind-Affecting effect."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.friend_or_foe"}], "_source": "canonical-csv"}, "treeId": "da34105c875650ae", "tags": ["defender", "feat-chain", "noble", "skills", "social", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 5, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "True Betrayal"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.true_betrayal", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "ce987679b604f25b", "name": "Grand Leader", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, once per encounter, you can grant bonus Hit Points equal to 5 + one-half your Character Level to allies within 20 squares of you and in your line of sight. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from multiple sources do not stack.", "description": {"value": "As a Swift Action, once per encounter, you can grant bonus Hit Points equal to 5 + one-half your Character Level to allies within 20 squares of you and in your line of sight. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from multiple sources do not stack."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "treeId": "9253ace716c3e966", "tags": ["leader", "positioning", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Grand Leader"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.grand_leader", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "ced81064716debaa", "name": "Influence Savant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Mind Trick You can convince others that they have been cut off from The Force, even if that is not the case, preventing them from making Use the Force checks. Whenever a target with an Intelligence of 3 or higher within 12 squares of you and in your line of sight attempts to make a Use the Force check for any reason, you can spend one use of the Mind Trick Force Power as a Reaction. You make a Use the Force check, and if your Use the Force check equals or exceeds the target's Use the Force check result, that target's Skill Check is negated, and the Action it was attempting fails. Reference Book: Star Wars Saga Edition Force Unleashed Campaign Guide", "description": "Mind Trick You can convince others that they have been cut off from The Force, even if that is not the case, preventing them from making Use the Force checks. Whenever a target with an Intelligence of 3 or higher within 12 squares of you and in your line of sight attempts to make a Use the Force check for any reason, you can spend one use of the Mind Trick Force Power as a Reaction. You make a Use the Force check, and if your Use the Force check equals or exceeds the target's Use the Force check result, that target's Skill Check is negated, and the Action it was attempting fails. Reference Book: Star Wars Saga Edition Force Unleashed Campaign Guide", "costNumeric": null, "treeId": "6ac3416fb6aada56", "tags": ["action_economy", "controller", "force", "force_capacity", "force_execution", "force_power_synergy", "positioning", "reaction", "skill_substitution", "striker", "telekinesis", "telepathy", "tree_6ac3416fb6aada56", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Influence Savant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.influence_savant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cef9b7ca6a26f4a6", "name": "Two-Faced", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dirty Tactics, Misplaced Loyalty", "benefit": "You have mastered the art of saying one thing and doing another, allowing you to deceive your enemies to keep your machinations hidden. You can use each of the following actions once per encounter as a Standard Action:", "description": {"value": "You have mastered the art of saying one thing and doing another, allowing you to deceive your enemies to keep your machinations hidden. You can use each of the following actions once per encounter as a Standard Action:\n\nFalse Security: Make a single melee or ranged attack against a target within your Range. At any time before the beginning of your next turn, you can make a single attack against that target as a Reaction if that target attacks you.\nNonthreatening: Make a single melee or ranged attack against a target within your Range. Until the beginning of your next turn, that opponent cannot make any attacks against you except for Attacks of Opportunity. This is a Mind-Affecting effect.\nTricky Target: Make a single melee or ranged attack against a target within your range that has not attacked you since the end of your last turn. You gain a +2 bonus on your attack roll and damage roll for this attack."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.misplaced_loyalty"}], "_source": "canonical-csv"}, "treeId": "e91cc675fbf9ba6e", "tags": ["action-economy", "feat-chain", "noble", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Two-Faced"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.two_faced", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "cf16d7c9bb7a70ad", "name": "Reconnaissance Actions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Reconnaissance Team Leader", "benefit": "You and your reconnaissance team have learned to work together as a cohesive unit and have an established set of tactics, which you have practiced to perfection. You can use any of the following actions on your turn:", "description": {"value": "You and your reconnaissance team have learned to work together as a cohesive unit and have an established set of tactics, which you have practiced to perfection. You can use any of the following actions on your turn:\n\nForward Scouting: As a Standard Action, you can make a melee or ranged attack against a target in Range. For each of your Followers armed with a ranged weapon who has line of sight to your target, you can grant one ally a +2 insight bonus on attack rolls against the target until the end of your next turn. Thus, if you have multiple armed Followers with line of sight to the target, you can grant the +2 bonus to multiple allies.\nGroup Sniping: As a Standard Action, you can make a melee or ranged attack against a target in Range. For each of your Followers armed with a ranged weapon who has line of sight to your target, you and each of your followers gains a +1 circumstance bonus to Stealth checks until the end of your next turn.\nSweep the Area: As a Standard Action, you can make a melee or ranged attack against a target in Range. For each of your Followers armed with a ranged weapon who has line of sight to your target, you and each of your Followers gains a +1 circumstance bonus on Perception checks until the end of your next turn."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "860fa1a66c837574", "tags": ["feat-chain", "leader", "perception", "positioning", "ranged", "scout", "skills", "stealth", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged"], "enabled": true, "priority": 500, "description": "Reconnaissance Actions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.reconnaissance_actions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["attack.with-ranged"]}}}
{"_id": "cf2d518039afd828", "name": "Sentinel Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Any time you attack a Flat-Footed opponent (or one who is denied its Dexterity bonus to its Reflex Defense against you) with a damage-dealing Force Power, or attack with a Lightsaber, you deal an extra +1d6 points of damage with that attack. This Talent does not affect Force Powers with the [Dark Side] descriptor.", "description": {"value": "Any time you attack a Flat-Footed opponent (or one who is denied its Dexterity bonus to its Reflex Defense against you) with a damage-dealing Force Power, or attack with a Lightsaber, you deal an extra +1d6 points of damage with that attack. This Talent does not affect Force Powers with the [Dark Side] descriptor.\n\nYou can select this Talent multiple times. Each time you select it, your Sentinel Strike damage increases by +1d6 points (maximum +5d6 points of damage)."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "eab0d8bbee7e0f4f", "tags": ["force", "force-offense", "jedi", "light-side", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Sentinel Strike"}]}}, "effects": [{"_id": "d09476da-02f8-413d-91fd-1d8873844060", "name": "Sentinel Strike", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.flatfooted", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Sentinel Strike"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sentinel_strike", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cf4b1e5b126a2a7e", "name": "Inspire Fear I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Your infamy and reputation are such that any opponent whose level is equal to or less than your Character Level takes a -1 penalty on attack rolls and opposed Skill Checks made against you, as well as Use the Force checks made to activate Force Powers against you. This is a Mind-Affecting Fear effect.", "description": {"value": "Your infamy and reputation are such that any opponent whose level is equal to or less than your Character Level takes a -1 penalty on attack rolls and opposed Skill Checks made against you, as well as Use the Force checks made to activate Force Powers against you. This is a Mind-Affecting Fear effect."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "treeId": "c1be604242cb328f", "tags": ["damage-reduction", "positioning", "skills", "social", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Inspire Fear I"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.inspire_fear_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "cf59931d6a0c0719", "name": "Take Them Alive", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you or any of your allies within 6 squares of you reduces a target to 0 Hit Points, you can choose to treat that opponent as though they had been reduced to 0 Hit Points by Stun damage (and thus, remain stable).", "description": {"value": "Whenever you or any of your allies within 6 squares of you reduces a target to 0 Hit Points, you can choose to treat that opponent as though they had been reduced to 0 Hit Points by Stun damage (and thus, remain stable)."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "61db5e2c0c44ef67", "tags": ["damage-reduction", "positioning", "scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["target.is-stunned"], "enabled": true, "priority": 500, "description": "Take Them Alive"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"skillSubstitution": true, "substitutionType": "persuasion_vs_combat", "description": "Use Persuasion checks instead of combat attacks for capture/knockout", "id": "swse.talent.take_them_alive", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["target.is-stunned"]}}}
{"_id": "cfd5d3f677b2bf1a", "name": "Feared Warrior", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Commanding Presence", "benefit": "Your abilities on the battlefield are well known and feared. When you reduce an opponent to 0 Hit Points with an attack, you can make a Persuasion check as a Free Action against all targets within 6 squares. If your Persuasion check exceeds the target's Will Defense, that target takes a -2 penalty on attack rolls for the remainder of the encounter.", "description": {"value": "Your abilities on the battlefield are well known and feared. When you reduce an opponent to 0 Hit Points with an attack, you can make a Persuasion check as a Free Action against all targets within 6 squares. If your Persuasion check exceeds the target's Will Defense, that target takes a -2 penalty on attack rolls for the remainder of the encounter.\n\nThis Talent affects any given target only once per encounter. This is a Mind-Affecting Fear effect."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.commanding_presence"}], "_source": "canonical-csv"}, "treeId": "4007fa87192b5884", "tags": ["damage-reduction", "feat-chain", "positioning", "skills", "social", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Feared Warrior"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.feared_warrior", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "cfdd73f3d939799d", "name": "Dark Side Adept", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Force Powers that are strongly tied to The Dark Side flow through you more easily. You can reroll any Use the Force check made when activating Force Powers with the [Dark Side] descriptor, but you must keep the result of the reroll, even if it is worse.", "description": {"value": "Force Powers that are strongly tied to The Dark Side flow through you more easily. You can reroll any Use the Force check made when activating Force Powers with the [Dark Side] descriptor, but you must keep the result of the reroll, even if it is worse."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "d1037bc7a08ea80b", "tags": ["action_economy", "category_sith_apprentice", "condition_removal", "controller", "dark_side", "feat_chain", "force", "force_control", "force_execution", "force_offense", "jedi", "leader", "light_side", "lightsaber", "mechanics", "melee", "mobility", "positioning", "scaling", "skills", "social", "striker", "support", "sustained_damage", "talent_chain", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Dark Side Adept"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_side_adept", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "d001094556c97a92", "name": "Juke", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Vehicular Evasion", "benefit": "When you Fly Defensively as the Pilot of a Vehicle, you may negate a weapon hit on your Vehicle using the Vehicular Combat feat one additional time per round.", "description": {"value": "When you Fly Defensively as the Pilot of a Vehicle, you may negate a weapon hit on your Vehicle using the Vehicular Combat feat one additional time per round."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.vehicular_evasion"}], "_source": "canonical-csv"}, "treeId": "b17c1515c06361d6", "tags": ["feat-chain", "scout", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Juke"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.juke", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "d043a3c0494345ac", "name": "Primitive Block", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Empower Weapon", "benefit": "As a Reaction, you may negate a melee attack by making a successful Use the Force check. The DC of the Use the Force check is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty on your Use the Force checks to use this Talent for every time you have used Primitive Block since the beginning of your last turn.", "description": {"value": "As a Reaction, you may negate a melee attack by making a successful Use the Force check. The DC of the Use the Force check is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty on your Use the Force checks to use this Talent for every time you have used Primitive Block since the beginning of your last turn.\n\nYou must have an Empowered Weapon drawn to use this Talent, and you must be aware of the attack and not Flat-Footed. You may spend a Force Point to use this Talent to negate an attack against an adjacent character.\n\nYou may use the Primitive Block Talent to negate melee Area Attacks, such as those made by the Whirlwind Attack feat. If you succeed on the Use the Force check, you take half damage if the attack hit, and no damage if the attack missed."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.empower_weapon"}], "_source": "canonical-csv"}, "treeId": "01e443d93e47f9c4", "tags": ["action_economy", "alchemy", "battlefield_control", "block", "category_force_adept", "controller", "crafting", "dark_side", "empowerment", "feat_chain", "force", "force_capacity", "force_execution", "force_offense", "force_point_spend", "force_training", "lightsaber", "melee", "melee_defense", "mobility", "mystic", "offense_melee", "reaction", "resource_spend", "scaling", "striker", "sustained_damage", "talent_chain", "tree_01e443d93e47f9c4", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Primitive Block"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.primitive_block", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee"]}}}
{"_id": "d054d594fe0ceba2", "name": "At Peace", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Gain +2 to all Defense scores until end of encounter or until you make an attack.", "description": "Gain +2 to all defenses until the end of the encounter or until you attack.", "costNumeric": null, "treeId": "001a438135e03588", "tags": ["defender", "force", "healing", "light_side", "resource_recovery", "striker", "survivability", "tree_001a438135e03588", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.fortitude"}, {"target": "defense.reflex", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}, {"target": "defense.will", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.will"}]}}, "effects": [{"_id": "1b5ec32b-6917-4e1f-8f15-c9433c07d7ab", "name": "At Peace", "icon": "icons/svg/shield.svg", "changes": [{"key": "system.defenses.fortitude", "mode": 2, "value": "2"}, {"key": "system.defenses.reflex", "mode": 2, "value": "2"}, {"key": "system.defenses.will", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "At Peace", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.at_peace"}}}
{"_id": "d091b5f6b34b4967", "name": "Rising Panic", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You start a in an enemy who observes your attacks and actions, inhibiting the enemy's ability to respond. Once per round as a Reaction to an enemy damaging one of your allies or moving one of your allies down the Condition Track, you can make a Use the Force check against the target's Will Defense. If the check equals or exceeds the target's Will Defense, you move the target -1 step on the Condition Track. An enemy moved to the bottom of the Condition Track by this Talent does not fall unconscious, but instead must spend its actions fleeing combat for one minute or until it moves up the Condition Track. This is a Mind-Affecting Fear effect.", "benefit": "You start a in an enemy who observes your attacks and actions, inhibiting the enemy's ability to respond. Once per round as a Reaction to an enemy damaging one of your allies or moving one of your allies down the Condition Track, you can make a Use the Force check against the target's Will Defense. If the check equals or exceeds the target's Will Defense, you move the target -1 step on the Condition Track. An enemy moved to the bottom of the Condition Track by this Talent does not fall unconscious, but instead must spend its actions fleeing combat for one minute or until it moves up the Condition Track. This is a Mind-Affecting Fear effect.", "class": "", "category": "", "costNumeric": null, "treeId": "427213bd55e04e27", "tags": ["action_economy", "condition_removal", "control", "controller", "defender", "fear", "force", "force_control", "force_defense", "force_execution", "force_offense", "mobility", "panic", "reaction", "sustained_damage", "tree_427213bd55e04e27", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "movement.while-moving", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Rising Panic"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["defense.will", "movement.while-moving", "turn.once-per-round"]}}}
{"_id": "d0b25a52cdc093bf", "name": "Know Weakness", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Adversary Lore", "benefit": "Whenever you use Adversary Lore on a target successfully, that target also takes an additional 1d6 points of damage from any successful attack made against it by you or an ally who can hear and understand you until the end of your next turn.", "description": {"value": "Whenever you use Adversary Lore on a target successfully, that target also takes an additional 1d6 points of damage from any successful attack made against it by you or an ally who can hear and understand you until the end of your next turn."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["feat-chain", "force", "force-offense", "jedi", "light-side", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Know Weakness"}]}}, "effects": [{"_id": "759aacd1-50eb-44fc-b92e-c9d92db36769", "name": "Know Weakness", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Know Weakness"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.know_weakness", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": []}}}
