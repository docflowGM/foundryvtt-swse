{"_id": "f92583cf04620d84", "name": "Stellar Warrior", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Spacehound", "benefit": "Whenever you roll a Natural 20 on an attack roll made aboard a Starship, you gain one temporary Force Point. If the Force Point is not used before the end of the encounter, it is lost. This Talent works with both Weapon Systems and personal weapons used aboard a Starship.", "description": {"value": "Whenever you roll a Natural 20 on an attack roll made aboard a Starship, you gain one temporary Force Point. If the Force Point is not used before the end of the encounter, it is lost. This Talent works with both Weapon Systems and personal weapons used aboard a Starship."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.spacehound"}], "_source": "canonical-csv"}, "treeId": "5ea8c79492d40713", "tags": ["feat-chain", "force", "force-offense", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Stellar Warrior"}]}}, "effects": [{"_id": "8655a9b1-41f3-4be7-a85c-98972f9c7cc8", "name": "Stellar Warrior", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.forcePoints", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Stellar Warrior"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stellar_warrior", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": []}}}
{"_id": "f9352f317ad2f695", "name": "Stolen Form", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Any One Force Technique, Weapon Focus (Lightsabers)", "benefit": "You have learned how to use a Jedi fighting technique to defeat Jedi in combat. Choose one Talent from the Lightsaber Forms Talent Tree; you gain the benefits of this Talent and are considered to have this Talent for the purpose of satisfying prerequisites. You must meet all the prerequisites as normal for the chosen Talent, in addition to the prerequisites of this Talent.", "description": {"value": "You have learned how to use a Jedi fighting technique to defeat Jedi in combat. Choose one Talent from the Lightsaber Forms Talent Tree; you gain the benefits of this Talent and are considered to have this Talent for the purpose of satisfying prerequisites. You must meet all the prerequisites as normal for the chosen Talent, in addition to the prerequisites of this Talent.\n\nYou can select this Talent multiple times. Each time you select it, choose a different Talent from the Lightsaber Forms Talent Tree."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "prerequisitesMeta": ["Requires at least one Force Technique", "Requires at least one Force Technique"], "treeId": "d1037bc7a08ea80b", "tags": ["category_sith_apprentice", "controller", "dark_side", "feat_chain", "force", "force_execution", "jedi", "lightsaber", "melee", "offense_melee", "striker", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Stolen Form"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stolen_form", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": []}}}
