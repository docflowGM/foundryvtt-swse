{"_id": "d11f6beaa5f93e66", "name": "Desperate Measures", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Focus Terror", "benefit": "Desperation stems from fear. Once per encounter as a Swift Action, you can instill desperation in all allies within 12 squares of you and in your line of sight, allowing each of them to make an immediate attack at a -5 penalty.", "description": {"value": "Desperation stems from fear. Once per encounter as a Swift Action, you can instill desperation in all allies within 12 squares of you and in your line of sight, allowing each of them to make an immediate attack at a -5 penalty."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.focus_terror"}], "_source": "canonical-csv"}, "treeId": "4d5ac20318ef56b6", "tags": ["action_economy", "category_sith_apprentice", "controller", "dark_side", "feat_chain", "force", "force_execution", "force_offense", "jedi", "positioning", "striker", "swift_action", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Desperate Measures"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.desperate_measures", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "d137ae2e8be700b3", "name": "Stolen Advantage", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Cast Suspicion", "benefit": "Whenever an enemy within your line of sight uses the Aid Another Action to grant one of its allies a bonus, you can (as a Reaction) designate one ally within your line of sight. The enemy automatically fails to aid its ally, and the ally you designate gains a +2 bonus on its next attack roll made before the end of your next turn.", "description": {"value": "Whenever an enemy within your line of sight uses the Aid Another Action to grant one of its allies a bonus, you can (as a Reaction) designate one ally within your line of sight. The enemy automatically fails to aid its ally, and the ally you designate gains a +2 bonus on its next attack roll made before the end of your next turn."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.cast_suspicion"}], "_source": "canonical-csv"}, "treeId": "da34105c875650ae", "tags": ["feat-chain", "leader", "noble", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Stolen Advantage"}]}}, "effects": [{"_id": "58982ff8-2693-47c7-8202-43608bc9a592", "name": "Stolen Advantage", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.allies", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Stolen Advantage"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stolen_advantage", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": []}}}
{"_id": "d1418afeaa3f40ec", "name": "Reflexive Tilting", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "- Your effortless adjustments in flight just by shifting weight make you a little more elusive than when you're on the ground. While airborne and with your jet pack Active, you gain a dodge bonus of +1 to your Reflex Defense. This bonus stacks with other applicable dodge bonuses, and you lose all dodge bonuses when you would lose a Dexterity bonus to your Reflex Defense.", "benefit": "- Your effortless adjustments in flight just by shifting weight make you a little more elusive than when you're on the ground. While airborne and with your jet pack Active, you gain a dodge bonus of +1 to your Reflex Defense. This bonus stacks with other applicable dodge bonuses, and you lose all dodge bonuses when you would lose a Dexterity bonus to your Reflex Defense.", "class": "", "category": "", "costNumeric": null, "treeId": "25d99948c9cb41ad", "tags": ["defender", "evasion", "mobility", "pilot", "scaling", "striker", "survivability", "sustained_damage", "tree_25d99948c9cb41ad", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Reflexive Tilting"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "d1561acfdeac3d78", "name": "Dark Deception", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can cloak your intentions with a veil of anger and hate. When another character attempts to sense you through The Force in any way, you can choose to act as though your Dark Side Score equals your Wisdom score.", "description": {"value": "You can cloak your intentions with a veil of anger and hate. When another character attempts to sense you through The Force in any way, you can choose to act as though your Dark Side Score equals your Wisdom score."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "eab0d8bbee7e0f4f", "tags": ["dark-side", "force", "jedi", "light-side", "skills"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Dark Deception"}]}}, "effects": [{"name": "Dark Deception (Class Skill)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.deception.classSkill", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Dark Deception", "effectType": "class-skill"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_deception", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "d1683318140f3906", "name": "Legendary Commander", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charisma 13, Intelligence 13, Born Leader", "benefit": "When you are the Commander of a Capital Ship, calculate its Reflex Defense using your Heroic Level plus one-half the ship's armor bonus (rounded down), the Pilot's Heroic Level, or the ship's Armor bonus, whichever is highest.", "description": {"value": "When you are the Commander of a Capital Ship, calculate its Reflex Defense using your Heroic Level plus one-half the ship's armor bonus (rounded down), the Pilot's Heroic Level, or the ship's Armor bonus, whichever is highest.\n\nIn addition, all Gunners on your ship add one-half your Heroic Level, or one-half their Heroic Level, whichever is more, to damage rolls with Vehicle Weapons. Finally, you treat any generic crew as being one quality level higher (maximum of Ace, see Crew Quality)."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "cha", "min": 13}, {"type": "attribute", "ability": "int", "min": 13}, {"type": "talent", "id": "swse.talent.born_leader"}], "_source": "canonical-csv"}, "treeId": "057a978a7dc1d5a7", "tags": ["armor", "defender", "feat-chain", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Legendary Commander"}]}}, "effects": [{"_id": "082aee90-5658-405e-abb8-c9d7198b2d9b", "name": "Legendary Commander", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.gunners", "mode": 5, "value": "half_level"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Legendary Commander"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.legendary_commander", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "d18f6de464dc42cf", "name": "Commander's Prerogative", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Initiative", "description": {"value": "During the first round of combat in an encounter (after the Surprise Round, if any), you can take your turn before any of your allies, but you must use either the Share Talent Prestige Class ability or a Talent from one of the following Talent Trees as part of your turn: Commando Talent Tree, Leadership Talent Tree, or Military Tactics Talent Tree. On the subsequent round, you return to your normal place in the Initiative Order."}, "benefit": "During the first round of combat in an encounter (after the Surprise Round, if any), you can take your turn before any of your allies, but you must use either the Share Talent Prestige Class ability or a Talent from one of the following Talent Trees as part of your turn: Commando Talent Tree, Leadership Talent Tree, or Military Tactics Talent Tree. On the subsequent round, you return to your normal place in the Initiative Order.", "class": "", "category": "", "costNumeric": null, "treeId": "9253ace716c3e966", "tags": ["action_economy", "ally_support", "commander", "defender", "leader", "morale", "positioning", "scout", "skills", "striker", "support", "sustained_damage", "tree_9253ace716c3e966", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Commander's Prerogative"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["defense.will", "turn.once-per-round"]}}}
{"_id": "d1c2e9bdbb58b715", "name": "Fleet Deployment", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charisma 13", "benefit": "As a Full-Round Action, you can designate a number of Vehicles equal to your Officer Class Level and within your line of sight. Those Vehicles may immediately move a number of squares equal to their speed.", "description": {"value": "As a Full-Round Action, you can designate a number of Vehicles equal to your Officer Class Level and within your line of sight. Those Vehicles may immediately move a number of squares equal to their speed."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "treeId": "057a978a7dc1d5a7", "tags": ["action-economy", "controller", "leader", "mobility", "positioning", "ranged", "scaling", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Fleet Deployment"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fleet_deployment", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "d1fd547124c1901c", "name": "Force Persuasion", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Adept Negotiator", "benefit": "You can use your Use the Force modifier instead of your Persuasion check modifier when making a Persuasion check. You are considered Trained in the Persuasion skill. If you are entitled to a Persuasion check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations).", "description": {"value": "You can use your Use the Force modifier instead of your Persuasion check modifier when making a Persuasion check. You are considered Trained in the Persuasion skill. If you are entitled to a Persuasion check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations)."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.adept_negotiator"}], "_source": "canonical-csv"}, "treeId": "e99cfa9db8493573", "tags": ["feat-chain", "force", "jedi", "light-side", "skills", "social", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Force Persuasion"}]}}, "effects": [{"_id": "f8c30152-0d87-4368-a330-0f73d55cd21d", "name": "Force Persuasion", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.persuasion.substitute", "mode": 5, "value": "useTheForce"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Persuasion"}}}, {"name": "Force Persuasion (Trained)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.persuasion.trained", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Persuasion", "effectType": "skill-trained"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_persuasion", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": []}}}
{"_id": "d21d7d3d4d7be0d2", "name": "Seducer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You excel at seduction through deception. If you fail a Persuasion check to change a target's Attitude, you can immediately reroll the check using your Deception skill in lieu of your Persuasion skill. You must accept the result of the reroll, even if it is worse.", "description": {"value": "You excel at seduction through deception. If you fail a Persuasion check to change a target's Attitude, you can immediately reroll the check using your Deception skill in lieu of your Persuasion skill. You must accept the result of the reroll, even if it is worse."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "8375b9b26b679901", "tags": ["force", "scoundrel", "skills", "social"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Seducer"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.seducer", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": []}}}
