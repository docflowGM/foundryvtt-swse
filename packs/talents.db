{"_id": "4d7d5a38d0394e4c", "name": "Force Bond", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Strong in the Force", "description": "Alternatively, by spending a Destiny Point, a bonded individual may make an attack roll against their partner, ignoring the effects of line of sight and line of effect (including Cover and Concealment). If the bonded individual dies, or you spend a Destiny Point to sever the bond, the may be given to any other willing being possessing the Force Sensitivity feat. Homebrew Reference Book: Legacy of the Force Sourcebook", "benefit": "Alternatively, by spending a Destiny Point, a bonded individual may make an attack roll against their partner, ignoring the effects of line of sight and line of effect (including Cover and Concealment). If the bonded individual dies, or you spend a Destiny Point to sever the bond, the may be given to any other willing being possessing the Force Sensitivity feat. Homebrew Reference Book: Legacy of the Force Sourcebook", "class": "", "category": "", "costNumeric": null, "treeId": "6ac3416fb6aada56", "tags": ["controller", "cover", "defense", "dual_wield", "feat_chain", "force", "force_offense", "skill_substitution", "talent_chain", "telekinesis", "telepathy", "tree_6ac3416fb6aada56", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Force Bond"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": []}}}
{"_id": "4d8882a28da30454", "name": "Inspire Confidence", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can inspire confidence in all allies in your line of sight, granting them a +1 morale bonus on attack rolls, and a +1 morale bonus on Skill Checks for the rest of the encounter, or until you're unconscious or dead. Once Inspired, your allies don't need to remain within line of sight of you.", "description": {"value": "As a Standard Action, you can inspire confidence in all allies in your line of sight, granting them a +1 morale bonus on attack rolls, and a +1 morale bonus on Skill Checks for the rest of the encounter, or until you're unconscious or dead. Once Inspired, your allies don't need to remain within line of sight of you.\n\nYou can't Inspire Confidence in yourself."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "72d32ebcbb607314", "tags": ["action-economy", "controller", "defender", "leader", "mobility", "noble", "striker", "support"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "1faa089c-9609-46d8-8543-9a68ace3553b", "name": "Inspire Confidence", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Inspire Confidence", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.inspire_confidence"}}}
