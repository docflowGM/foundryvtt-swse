{"_id": "ef3ec55015c60bda", "name": "Channel Aggression", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you succeed on an attack against a Flanked opponent, or any target that is denied its Dexterity bonus to Reflex Defense, you may spend a Force Point as a Free Action to deal additional damage to the target equal to 1d6 per Class Level (maximum 10d6).", "description": {"value": "If you succeed on an attack against a Flanked opponent, or any target that is denied its Dexterity bonus to Reflex Defense, you may spend a Force Point as a Free Action to deal additional damage to the target equal to 1d6 per Class Level (maximum 10d6)."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "96ef43a3054dcb58", "tags": ["action_economy", "category_force_adept", "condition_removal", "controller", "damage_reduction", "dark_side", "force", "force_capacity", "force_control", "force_execution", "force_offense", "force_point_spend", "force_support", "force_training", "light_side", "mechanics", "medicine", "melee", "mobility", "mystic", "precision", "resource_spend", "skills", "stealth", "striker", "support", "sustained_damage", "tree_96ef43a3054dcb58"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "movement.while-moving"], "enabled": true, "priority": 500, "description": "Channel Aggression"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.channel_aggression", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "movement.while-moving"]}}}
{"_id": "ef8a59509a45df46", "name": "Adapt and Survive", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When an enemy within 24 squares of you and in your line of sight receives a morale or insight bonus of any kind, you also gain the benefits of that bonus until the end of your next turn.", "description": {"value": "When an enemy within 24 squares of you and in your line of sight receives a morale or insight bonus of any kind, you also gain the benefits of that bonus until the end of your next turn."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "ab2c265c4b2f54f6", "tags": ["scout"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.will", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}]}}, "effects": [{"_id": "b356b87a-a4e2-4cd8-a0dc-0cd4c48b42c9", "name": "Adapt and Survive", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.all", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Adapt and Survive", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.adapt_and_survive"}}}
{"_id": "efd3308a8ccc22c6", "name": "Severing Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you deal damage with a Lightsaber that is equal to or greater than both the target's current Hit Points and the target's Damage Threshold (that is, when you would deal enough damage to kill your target), you may choose to use this Talent.", "description": {"value": "When you deal damage with a Lightsaber that is equal to or greater than both the target's current Hit Points and the target's Damage Threshold (that is, when you would deal enough damage to kill your target), you may choose to use this Talent.\n\nInstead of dealing full damage, you instead deal half damage to your target and move it -1 step on the Condition Track. In addition, you sever one of your target's arms at the wrist or elbow joint, or one of the target's legs at the knee or ankle joint (your choice).\n\nSevering part of an arm prevents the target from wielding weapons or using tools in that hand, and imposes a -5 penalty on Skill Checks and Ability Checks keyed to Strength and Dexterity.\n\nSevering part of a leg knocks the target Prone, reduces the target's Speed by half, reduces its Carrying Capacity by half, and imposes a -5 penalty on Skill Checks and Ability Checks keyed to Strength and Dexterity.\n\nBecause of the severity of such an injury, losing part of a limb causes a Persistent Condition that can only be removed by having Surgery successfully performed on you. A Cybernetic Prosthesis negates these reductions and penalties."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "b3c5d90b5036f39b", "tags": ["jedi", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["movement.while-moving"], "enabled": true, "priority": 500, "description": "Severing Strike"}]}}, "effects": [{"_id": "8a7d9568-c68f-4b0e-a64a-0064e0dd2330", "name": "Severing Strike", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.limb_loss", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Severing Strike"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.severing_strike", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["movement.while-moving"]}}}
{"_id": "f0166d26d9f6252a", "name": "Acute Senses", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You may reroll any Perception check, but the result of the reroll must be accepted, even if it is worse. This Talent applies to Use Computer checks made to perceive enemy ships (see Use Sensors).", "description": {"value": "You may reroll any Perception check, but the result of the reroll must be accepted, even if it is worse. This Talent applies to Use Computer checks made to perceive enemy ships (see Use Sensors)."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "dca33c0215264a02", "tags": ["action-economy", "armor", "controller", "damage-reduction", "defender", "force", "force-control", "force-defense", "force-offense", "melee", "mobility", "positioning", "ranged", "scout", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Acute Senses"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.acute_senses", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "f0851e0e5a1ac771", "name": "Multiattack Proficiency (advanced melee)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Reduce multiattack penalty by 2 for advanced melee weapons.", "description": "Reduce the attack penalty for multiple attacks with advanced melee weapons by 2.", "class": "d87c05d2a34f5627", "costNumeric": null, "category": "Melee Duelist", "treeId": "1381bb8c9a838279", "tags": ["damage-reduction", "melee"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Multiattack Proficiency (advanced melee)"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.multiattack_proficiency_advanced_melee", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": []}}}
{"_id": "f098749cb8767a5f", "name": "Force Haze", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Clear Mind", "benefit": "You can spend a Force Point as a Standard Action to create a \"Haze\" that hides you and your allies from the perception of others. You can hide a number of creatures in line of sight equal to your Class Level. Make a Use the Force check and compare the result to the Will Defense of any opponent that moves into line of sight of any creature hidden by your Force Haze. If your check result equals or exceeds the opponent's Will Defense, all hidden creatures are treated as if they had Total Concealment against the opponent.", "description": {"value": "You can spend a Force Point as a Standard Action to create a \"Haze\" that hides you and your allies from the perception of others. You can hide a number of creatures in line of sight equal to your Class Level. Make a Use the Force check and compare the result to the Will Defense of any opponent that moves into line of sight of any creature hidden by your Force Haze. If your check result equals or exceeds the opponent's Will Defense, all hidden creatures are treated as if they had Total Concealment against the opponent.\n\nThe Force Haze lasts for up to 1 minute but is dismissed instantly if anyone hidden by the Force Haze makes an attack.\n\nYou may use this Talent to hide a single Vehicle while you are on board. The Vehicle can't have a size penalty to Reflex Defense, Initiative, or Pilot checks greater than your Heroic Level. Thus, a Gargantuan Starship (size penalty of -5) can be hidden only by a character of 5th level or higher."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.clear_mind"}], "_source": "canonical-csv"}, "treeId": "36f18f3e974feb33", "tags": ["action-economy", "ambush", "battlefield-control", "condition-removal", "controller", "dark-side", "defender", "evasion", "feat-chain", "force", "force-control", "force-defense", "force-offense", "jedi", "light-side", "lightsaber", "melee", "mobility", "perception", "piloting", "positioning", "scout", "skills", "stealth", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.reflex", "defense.will", "attack.when-hit", "proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Force Haze"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_haze", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["defense.reflex", "defense.will", "attack.when-hit", "proximity.ally-nearby"]}}}
{"_id": "f09f37cda0fc10e1", "name": "Right Gear for the Job", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per day when an ally makes an Untrained skill check, as a Reaction you can grant that ally a +5 Equipment bonus to the check, and the ally is considered Trained in that Skill for the purpose of using Trained-only applications of the Skill.", "description": {"value": "Once per day when an ally makes an Untrained skill check, as a Reaction you can grant that ally a +5 Equipment bonus to the check, and the ally is considered Trained in that Skill for the purpose of using Trained-only applications of the Skill.\n\nYou cannot use this Talent to allow an ally to make an Untrained Use the Force check."}, "class": "db019dfbb271cdf6", "costNumeric": null, "category": "Improviser", "treeId": "a0d6323d6c1bf911", "tags": ["action_economy", "category_improviser", "control", "force", "force_execution", "gear", "jury_rig", "reaction", "striker", "support", "tech", "use_the_force", "utility"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "skill.untrained", "type": "untyped", "value": 5, "enabled": true, "priority": 500, "description": "Migrated from AE system.skills.untrained"}]}}, "effects": [{"_id": "3cc7c79a-6293-4219-9303-9d075dd4fe39", "name": "Right Gear for the Job", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.untrained", "mode": 2, "value": "5"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Right Gear for the Job", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.right_gear_for_the_job"}}}
{"_id": "f0bfcfc354862328", "name": "No Escape", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Opportunistic Strike", "benefit": "Whenever an opponent uses the Withdraw Action to leave your Threatened Area, that opponent is considered Flat-Footed against you until the end of your next turn.", "description": {"value": "Whenever an opponent uses the Withdraw Action to leave your Threatened Area, that opponent is considered Flat-Footed against you until the end of your next turn."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.opportunistic_strike"}], "_source": "canonical-csv"}, "treeId": "6367600ed3c0cfae", "tags": ["controller", "feat-chain", "mobility", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] No Escape"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.no_escape", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": []}}}
