{"_id": "bef731c3743c2c7f", "name": "Precision Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "The Jedi are skilled at blocking and deflecting ranged attacks with their Lightsabers, and you are able to compensate for this to some degree by taking careful shots. Whenever you Aim before making a ranged attack, you increase the difficulty of Deflect attempts to negate your attack by +5.", "description": {"value": "The Jedi are skilled at blocking and deflecting ranged attacks with their Lightsabers, and you are able to compensate for this to some degree by taking careful shots. Whenever you Aim before making a ranged attack, you increase the difficulty of Deflect attempts to negate your attack by +5."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "29b16e48a3dbf165", "tags": ["force", "force-offense", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Precision Fire"}]}}, "effects": [{"_id": "7f7f2136-9779-498c-a2e3-9e8dafbfcd92", "name": "Precision Fire", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.ranged", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Precision Fire"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.precision_fire", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.426Z", "detectedPredicates": []}}}
