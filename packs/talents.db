{"_id": "39b5423e255e14b1", "name": "Transposing Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Noble Fencing Style, Base Attack Bonus +5", "benefit": "When you hit a character with a melee attack, you can choose to have the attack deal only half damage and switch places with that foe. Your foe must be no more than one size category larger than you, and you must end up occupying a space that was previously occupied by your target (And vice versa) to use this Talent. This movement does not provoke Attacks of Opportunity.", "description": {"value": "When you hit a character with a melee attack, you can choose to have the attack deal only half damage and switch places with that foe. Your foe must be no more than one size category larger than you, and you must end up occupying a space that was previously occupied by your target (And vice versa) to use this Talent. This movement does not provoke Attacks of Opportunity."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.noble_fencing_style"}, {"type": "bab", "min": 5}], "_source": "canonical-csv"}, "treeId": "9df067790c87e6bc", "tags": ["controller", "feat-chain", "melee", "noble", "positioning", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Transposing Strike"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.transposing_strike", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.408Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee"]}}}
{"_id": "3a34ce2ef55c41b1", "name": "Directed Action", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "As a Standard Action, you allow one Droid that can hear and understand you to make a Deception, Mechanics, Persuasion, Pilot, Ride, Treat Injury, or Use Computer check immediately as a Free Action. The Droid can replace its relevant Ability Score modifier for that check with your Intelligence modifier."}, "benefit": "As a Standard Action, you allow one Droid that can hear and understand you to make a Deception, Mechanics, Persuasion, Pilot, Ride, Treat Injury, or Use Computer check immediately as a Free Action. The Droid can replace its relevant Ability Score modifier for that check with your Intelligence modifier.", "class": "", "category": "", "costNumeric": null, "treeId": "01cb1ca2a10640b3", "tags": ["action_economy", "ally_support", "controller", "deception", "droid", "healing", "leader", "melee", "mobility", "new_action", "persuasion", "pilot", "positioning", "ranged", "social", "social_control", "standard_action", "support", "sustained_damage", "tactics", "teamwork", "tree_01cb1ca2a10640b3", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Directed Action"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.408Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged"]}}}
