{"_id": "4bdb0bda258c609e", "name": "Thrive on Chaos", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Advantageous Opening", "benefit": "When an enemy or ally within 20 squares of you is reduced to 0 Hit Points, you gain Bonus Hit Points equal to 5 + one-half your Character Level. Damage is subtracted from Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points do not stack.", "description": {"value": "When an enemy or ally within 20 squares of you is reduced to 0 Hit Points, you gain Bonus Hit Points equal to 5 + one-half your Character Level. Damage is subtracted from Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points do not stack."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.advantageous_opening"}], "_source": "canonical-csv"}, "treeId": "bf3b07c1687a3ca2", "tags": ["damage-reduction", "feat-chain", "positioning", "scoundrel", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "29309b4d-9fad-43d5-8a21-1f63f85b8952", "name": "Thrive on Chaos", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Thrive on Chaos", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.thrive_on_chaos"}}}
