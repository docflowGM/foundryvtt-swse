{"_id": "0fa7aace1d7606c6", "name": "Innocuous", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, you can make a Deception check against a single enemy within 6 squares of you and in line of sight. If the check equals or exceeds the target's Will Defense, the target takes a -5 penalty on all attacks made against you until the start of your next turn.", "description": {"value": "As a Swift Action, you can make a Deception check against a single enemy within 6 squares of you and in line of sight. If the check equals or exceeds the target's Will Defense, the target takes a -5 penalty on all attacks made against you until the start of your next turn."}, "class": "8da58194b3d58041", "costNumeric": null, "category": "Charlatan", "treeId": "ab9b75bc19f8e983", "tags": ["action_economy", "category_charlatan", "control", "deception", "defender", "mobility", "opportunist", "positioning", "skills", "social", "social_control", "stealth", "striker", "swift_action"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "defense.will"], "enabled": true, "priority": 500, "description": "Innocuous"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.innocuous", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.403Z", "detectedPredicates": ["defense.reflex", "defense.will"]}}}
