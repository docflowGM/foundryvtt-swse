{"_id": "9d1c806bdee12411", "name": "Mandalorian Ferocity", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dexterity 13", "benefit": "Mandalorians can be ferocious fighters. Select one weapon group or Exotic Weapon you are proficient with. Once per encounter, when making more than one attack in a round, you can add one damage die to each successful hit with the selected weapon group or Exotic Weapon.", "description": {"value": "Mandalorians can be ferocious fighters. Select one weapon group or Exotic Weapon you are proficient with. Once per encounter, when making more than one attack in a round, you can add one damage die to each successful hit with the selected weapon group or Exotic Weapon.\n\nYou can take this Talent more than once, selecting a different Exotic Weapon or weapon group each time."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "dex", "min": 13}], "_source": "canonical-csv"}, "treeId": "4b8857716e056f62", "tags": ["feat-chain", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Mandalorian Ferocity"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.mandalorian_ferocity", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "9d235eba6b3e5daf", "name": "Knockback", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you score a Critical Hit against a target no more than two size categories larger than you are, you can choose to move that opponent 1 square in any direction as a Free Action.", "description": {"value": "When you score a Critical Hit against a target no more than two size categories larger than you are, you can choose to move that opponent 1 square in any direction as a Free Action.\n\nYou cannot use this Talent on an opponent that is being Grabbed or Grappled, and you cannot move your target into a solid object or into another creature's Fighting Space."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "71e99c646b18d85c", "tags": ["controller", "mobility", "positioning", "precision", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Knockback"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.knockback", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "9dc39670f94a6ef2", "name": "Master Negotiator", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Adept Negotiator", "benefit": "If you successfully use the Adept Negotiator Talent, your target moves an additional -1 step along the Condition Track. This is a Mind-Affecting effect. You affect the Condition Track of the specific character (usually the Vehicle's Commander), not a Starship.", "description": {"value": "If you successfully use the Adept Negotiator Talent, your target moves an additional -1 step along the Condition Track. This is a Mind-Affecting effect. You affect the Condition Track of the specific character (usually the Vehicle's Commander), not a Starship."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.adept_negotiator"}], "_source": "canonical-csv"}, "treeId": "e99cfa9db8493573", "tags": ["condition-removal", "controller", "feat-chain", "force", "force-control", "jedi", "light-side", "mobility", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Master Negotiator"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.master_negotiator", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
