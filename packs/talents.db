{"_id": "b8a9dd4c950a96f5", "name": "Incite Rage", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Swift Action, you can channel your anger and hatred into your allies. All allies within 12 squares of you and in your line of sight gain a +1 rage bonus on attack rolls, but take a -2 penalty to their Reflex Defense. This effect lasts until the encounter ends, or until you are knocked unconscious or killed.", "description": {"value": "Once per encounter as a Swift Action, you can channel your anger and hatred into your allies. All allies within 12 squares of you and in your line of sight gain a +1 rage bonus on attack rolls, but take a -2 penalty to their Reflex Defense. This effect lasts until the encounter ends, or until you are knocked unconscious or killed."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "4d5ac20318ef56b6", "tags": ["action_economy", "category_sith_apprentice", "controller", "dark_side", "force", "force_execution", "force_offense", "jedi", "mobility", "scaling", "striker", "support", "swift_action"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Incite Rage"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.incite_rage", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.426Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "b8aaf500d3069938", "name": "Indomitable", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per day as a Swift Action, you can move +5 steps on the Condition Track. This does not remove any Persistent Conditions that may be affecting you. This Talent does not affect the Condition Track of a Vehicle.", "description": {"value": "Once per day as a Swift Action, you can move +5 steps on the Condition Track. This does not remove any Persistent Conditions that may be affecting you. This Talent does not affect the Condition Track of a Vehicle.\n\nYou can select this talent multiple times. Each time you select this Talent, you can use it one additional time per day."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "798ed0945cbdac1c", "tags": ["condition-removal", "controller", "mobility", "scaling", "soldier", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Indomitable"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.indomitable", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.426Z", "detectedPredicates": []}}}
