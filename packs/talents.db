{"_id": "c83f18465c3b9d91", "name": "Revenge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dark Presence, Power of the Dark Side", "benefit": "Gain +2 attack and +2 damage if an ally of equal or higher level dies or is reduced to 0 hp within line of sight.", "description": "If an ally of equal or higher level is reduced to 0 hit points, gain +2 attack and damage.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dark_presence"}], "_source": "canonical-csv"}, "treeId": "de95d37c72b1c4cd", "tags": ["damage_reduction", "dark_side", "dark_side_mastery", "feat_chain", "force", "force_multiplier", "forecast_value", "striker", "support", "talent_chain", "tree_de95d37c72b1c4cd", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}, {"target": "damage", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.damage"}]}}, "effects": [{"_id": "89c56330-11d2-4b3f-b2da-1a6551eb94ad", "name": "Revenge", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "2"}, {"key": "system.damage", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Revenge", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.revenge"}}}
{"_id": "c87b8389c8ca6ea9", "name": "Consular's Vitality", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per round as a Swift Action, you grant one ally within 12 squares of you (and within your line of sight) Bonus Hit Points equal to 5 + your Charisma modifier.", "description": {"value": "Once per round as a Swift Action, you grant one ally within 12 squares of you (and within your line of sight) Bonus Hit Points equal to 5 + your Charisma modifier.\n\nThese Bonus Hit Points last until the beginning of your next turn (at which point any remaining Bonus Hit Points are lost), and any damage dealt to that ally comes out of Bonus Hit Points first.\n\nYou take a -5 penalty on all Use the Force checks until the beginning of your next turn."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["action-economy", "force", "force-offense", "jedi", "light-side", "lightsaber", "melee", "mobility", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Consular's Vitality"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.consulars_vitality", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": []}}}
{"_id": "c8bf9ab9d1f8588a", "name": "Greater Dark Side Talisman", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dark Side Talisman", "benefit": "You can spend a Force Point to imbue a Weapon or some other portable object with the Dark Side of The Force, creating a Talisman that grants you protection from the Light Side. Creating the Greater Dark Side Talisman takes a Full-Round Action.", "description": {"value": "You can spend a Force Point to imbue a Weapon or some other portable object with the Dark Side of The Force, creating a Talisman that grants you protection from the Light Side. Creating the Greater Dark Side Talisman takes a Full-Round Action.\n\nWhile you wear or carry the Talisman, you gain a +2 Force bonus to all of your Defenses against Force Powers with the [Light Side] descriptor.\n\nYou can only have one Greater Dark Side Talisman, or Dark Side Talisman, active at a given time (though you can have both a Greater Dark Side Talisman and a Greater Force Talisman active at the same time), and if your Greater Dark Side Talisman is destroyed, you cannot create another one for 24 hours."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dark_side_talisman"}], "_source": "canonical-csv"}, "treeId": "96ef43a3054dcb58", "tags": ["action_economy", "category_force_adept", "controller", "dark_side", "defender", "force", "force_capacity", "force_defense", "force_execution", "force_point_spend", "force_training", "leader", "light_side", "mystic", "resource_spend", "striker", "sustained_damage", "tree_96ef43a3054dcb58"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.reflex", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.will", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}]}}, "effects": [{"_id": "e831a305-fff9-4fc9-85e0-b6c1134b34b0", "name": "Greater Dark Side Talisman", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.all", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Greater Dark Side Talisman", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.greater_dark_side_talisman"}}}
{"_id": "c913aa5322934cfd", "name": "Buried Presence", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Proficiency (Pistols) or Weapon Proficiency (Rifles)", "description": "When you use either the Talent or the Vanish Talent, you affect one other willing adjacent target, granting it the effect of that Talent as well. You can select this Talent multiple times. Each time you do so, it increases the number of adjacent willing targets you affect by one. You can spend a Force Point as a Swift Action to substitute your Use the Force modifier for your ranged attack bonus when making attacks with a ranged weapon until the beginning of your next turn. You can make a Use the Force check as a Swift Action to vanish from the sight of a single target within line of sight. If the result of your Use the Force check exceeds the target's Will Defense, you gain Total Concealment from that target until the beginning of your next turn, or until you make an attack roll or Skill Check against the target.", "benefit": "When you use either the Talent or the Vanish Talent, you affect one other willing adjacent target, granting it the effect of that Talent as well. You can select this Talent multiple times. Each time you do so, it increases the number of adjacent willing targets you affect by one. You can spend a Force Point as a Swift Action to substitute your Use the Force modifier for your ranged attack bonus when making attacks with a ranged weapon until the beginning of your next turn. You can make a Use the Force check as a Swift Action to vanish from the sight of a single target within line of sight. If the result of your Use the Force check exceeds the target's Will Defense, you gain Total Concealment from that target until the beginning of your next turn, or until you make an attack roll or Skill Check against the target.", "class": "", "category": "", "costNumeric": null, "treeId": "754907ded50d4f46", "tags": ["action_economy", "concealment", "defender", "feat_chain", "force", "force_defense", "force_execution", "force_offense", "force_point_spend", "leader", "mobility", "offense_ranged", "positioning", "ranged", "resource_spend", "scaling", "stealth", "striker", "swift_action", "talent_chain", "tree_754907ded50d4f46", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Buried Presence"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": ["defense.will", "attack.with-ranged"]}}}
{"_id": "c93a9e38c432551b", "name": "Cleanse Mind", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per turn as a Swift Action, you can remove one ongoing Mind-Affecting effect (such as the effects of Demand Surrender or Weaken Resolve Talents, or the effect of being moved to the end of the Condition Track by the Adept Negotiator Talent, or the ongoing effects of the Mind Trick Force Power) from a single allied target within line of sight.", "description": {"value": "Once per turn as a Swift Action, you can remove one ongoing Mind-Affecting effect (such as the effects of Demand Surrender or Weaken Resolve Talents, or the effect of being moved to the end of the Condition Track by the Adept Negotiator Talent, or the ongoing effects of the Mind Trick Force Power) from a single allied target within line of sight."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["controller", "force", "force-control", "jedi", "light-side", "mobility", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Cleanse Mind"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.cleanse_mind", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": []}}}
{"_id": "c95b1077ab31f9b0", "name": "Sokan", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Acrobatic Recovery", "benefit": "You may Take 10 on Acrobatics checks to Tumble, even when distracted or threatened. Additionally, each threatened or occupied square that you Tumble through only counts as 1 square of movement.", "description": {"value": "You may Take 10 on Acrobatics checks to Tumble, even when distracted or threatened. Additionally, each threatened or occupied square that you Tumble through only counts as 1 square of movement."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "2bc2572e852832e4", "tags": ["feat-chain", "jedi", "lightsaber", "melee", "positioning", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Sokan"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sokan", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": []}}}
{"_id": "c980750800b91061", "name": "Stay in the Fight", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Stalwart Subordinates", "benefit": "Remove one mind-affecting or fear effect from an ally within 12 squares and line of sight and grant them hit points equal to 10 + class level.", "description": "A recruited enemy may immediately use Second Wind as a reaction.", "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.recruit_enemy"}], "_source": "canonical-csv"}, "treeId": "61b74c82cb56876c", "tags": ["controller", "feat-chain", "leader", "mobility", "positioning", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Stay in the Fight"}]}}, "effects": [{"_id": "58cd0029-73c7-4706-bcbd-324ac2d8df6a", "name": "Stay in the Fight", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.will", "mode": 2, "value": "immunity_mind_affect"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Stay in the Fight"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stay_in_the_fight", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "ca79321246ae6986", "name": "Sprint", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you use the Run action, you can move up to five times your Speed (instead of up to four times).", "description": {"value": "When you use the Run action, you can move up to five times your Speed (instead of up to four times)."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "9b06340233eb3cdd", "tags": ["mobility", "scout"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Sprint"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sprint", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": []}}}
{"_id": "cad07bbaa57634c0", "name": "Castigate", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You deliver a scathing rebuke against a target to erode its will and fill it with doubt. Make a Persuasion check as a Standard Action against the target's Will Defense. If successful, you impose a -2 penalty to all the target's Defenses until the end of your next turn.", "description": {"value": "You deliver a scathing rebuke against a target to erode its will and fill it with doubt. Make a Persuasion check as a Standard Action against the target's Will Defense. If successful, you impose a -2 penalty to all the target's Defenses until the end of your next turn.\n\nYou can use this ability only against targets that can clearly hear and understand your language."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "e91cc675fbf9ba6e", "tags": ["defender", "noble", "skills", "social"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Castigate"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.castigate", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "cae4f000dcfddd99", "name": "Swift Strider", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Long Stride, Sidestep", "benefit": "You are skilled at maneuvering on the battlefield thanks to your experience surviving in dangerous places. You can use each of the following actions once per encounter:", "description": {"value": "You are skilled at maneuvering on the battlefield thanks to your experience surviving in dangerous places. You can use each of the following actions once per encounter:\n\nBlurring Burst: As a Move Action, move up to your Speed, and gain a +2 bonus to your Reflex Defense until the end of the encounter.\nSudden Assault: Make a Charge attack against an enemy within range as a Standard Action. You take no penalty to your Reflex Defense for this attack.\nWeaving Stride: Move up to your Speed as a Move Action. You gain a cumulative +2 dodge bonus to your Reflex Defense for each Attack of Opportunity made against you during this movement. This bonus lasts until the beginning of your next turn."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.sidestep"}], "_source": "canonical-csv"}, "treeId": "7c47d36dc1f77d9c", "tags": ["controller", "defender", "feat-chain", "mobility", "scout", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Swift Strider"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.swift_strider", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "cb018e0f620614fd", "name": "Hunt the Hunter", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you use a Standard Action to actively look for hidden enemies, you can make a single melee or ranged attack against any one enemy you notice with your Perception check.", "description": {"value": "When you use a Standard Action to actively look for hidden enemies, you can make a single melee or ranged attack against any one enemy you notice with your Perception check."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "127a55c242e031f2", "tags": ["scout"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Hunt the Hunter"}]}}, "effects": [{"_id": "15ab0c89-8122-4a22-a63b-7bf80e6d54e6", "name": "Hunt the Hunter", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.hidden_search", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Hunt the Hunter"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hunt_the_hunter", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cb0dcc59f7ced910", "name": "Strength Implant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Standard Action, you can give one adjacent living creature a Strength Implant. The target must be willing to receive this Implant, which allows the target to deal +1 die of damage whenever it hits with a melee attack until the end of the encounter.", "description": {"value": "Once per encounter as a Standard Action, you can give one adjacent living creature a Strength Implant. The target must be willing to receive this Implant, which allows the target to deal +1 die of damage whenever it hits with a melee attack until the end of the encounter."}, "class": "557e1a5ec72166fd", "costNumeric": null, "category": "Shaper", "treeId": "d8a71a6c5b2b7581", "tags": ["ability_enhancement", "action_economy", "biotech", "category_shaper", "crafting", "gear", "healing", "implant", "melee", "new_action", "offense_melee", "positioning", "standard_action", "striker", "support", "tree_d8a71a6c5b2b7581"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Strength Implant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.strength_implant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "turn.once-per-round"]}}}
{"_id": "cb261592f68849a5", "name": "Infused Weapon", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Blast", "description": "From that point forward, when you wield the weapon, its Damage Reduction is doubled, and Lightsabers do not ignore the weapon's Damage Reduction. When you spend a Force Point to modify the attack roll of an , you also add 2 x the Force Point's result to the damage roll if the attack succeeds. When you use the Force Blast Force Power, if your Use the Force check exceeds the target's Fortitude Defense, you can choose to move the target -1 step along the Condition Track. Doing so increases your Dark Side Score by 1. Skullblade Mastery Talent created by Wikia user LilLiteralist. You treat a Felucian Skullblade as a Simple Weapon (Melee) instead of as an Exotic Weapon (Melee). Additionally, you gain a +1 bonus to attack rolls with a Felucian Skullblade. This Talent counts as the Weapon Focus (Felucian Skullblade) feat for the purpose of satisfying prerequisites. If you also have the Weapon Focus (Simple Weapons) feat, the attack bonus provided by this Talent does not stack with the attack bonus provided by Weapon Focus (Simple Weapons).", "benefit": "From that point forward, when you wield the weapon, its Damage Reduction is doubled, and Lightsabers do not ignore the weapon's Damage Reduction. When you spend a Force Point to modify the attack roll of an , you also add 2 x the Force Point's result to the damage roll if the attack succeeds. When you use the Force Blast Force Power, if your Use the Force check exceeds the target's Fortitude Defense, you can choose to move the target -1 step along the Condition Track. Doing so increases your Dark Side Score by 1. Skullblade Mastery Talent created by Wikia user LilLiteralist. You treat a Felucian Skullblade as a Simple Weapon (Melee) instead of as an Exotic Weapon (Melee). Additionally, you gain a +1 bonus to attack rolls with a Felucian Skullblade. This Talent counts as the Weapon Focus (Felucian Skullblade) feat for the purpose of satisfying prerequisites. If you also have the Weapon Focus (Simple Weapons) feat, the attack bonus provided by this Talent does not stack with the attack bonus provided by Weapon Focus (Simple Weapons).", "class": "", "category": "", "costNumeric": null, "treeId": "8a61bf426391431b", "tags": ["condition_removal", "controller", "damage_reduction", "dark_side", "defender", "feat_chain", "force", "force_capacity", "force_control", "force_defense", "force_execution", "force_item", "force_offense", "force_point_spend", "force_power_synergy", "lightsaber", "melee", "mobility", "resource_spend", "scaling", "striker", "support", "talent_chain", "tree_8a61bf426391431b", "uncategorized_talent", "use_the_force", "weapon_empowerment"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 1, "type": "untyped", "predicates": ["defense.against-melee", "defense.fortitude", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Infused Weapon"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["defense.against-melee", "defense.fortitude", "attack.with-melee"]}}}
{"_id": "cb4984135c665c4b", "name": "Twin Weapon Mastery", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Twin Weapon Style", "benefit": "Whenever you use the Twin Weapon Style Talent, you can move 2 squares between each attack. This movement does not provoke Attacks of Opportunity.", "description": {"value": "Whenever you use the Twin Weapon Style Talent, you can move 2 squares between each attack. This movement does not provoke Attacks of Opportunity."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "7db97c2c7ebca579", "tags": ["controller", "feat-chain", "force", "force-control", "force-offense", "jedi", "light-side", "mobility", "positioning", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Twin Weapon Mastery"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.twin_weapon_mastery", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cb4b14a242fbee71", "name": "Fade Away", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per turn when you are damaged by an enemy's attack, as a Reaction you can move up to half your speed. This movement does not provoke Attacks of Opportunity.", "description": {"value": "Once per turn when you are damaged by an enemy's attack, as a Reaction you can move up to half your speed. This movement does not provoke Attacks of Opportunity."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "5a30489609182e8c", "tags": ["action-economy", "controller", "mobility", "scout", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Fade Away"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fade_away", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "cb981391d4d16c59", "name": "Shift Defense I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, you can take a -2 penalty to one Defense (Reflex, Fortitude, or Will) to gain a +1 competence bonus to another Defense until the start of your next turn.", "description": {"value": "As a Swift Action, you can take a -2 penalty to one Defense (Reflex, Fortitude, or Will) to gain a +1 competence bonus to another Defense until the start of your next turn."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "treeId": "9253ace716c3e966", "tags": ["action-economy", "defender", "mobility", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Shift Defense I"}]}}, "effects": [{"_id": "ba3b7c8c-b416-4808-b91c-722e90b8c6b8", "name": "Shift Defense I", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.flexible", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Shift Defense I"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.shift_defense_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cbdedc32ac362634", "name": "Face the Foe", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you do not have Cover from a target, you gain a +1 morale bonus to attack rolls against that target.", "description": {"value": "If you do not have Cover from a target, you gain a +1 morale bonus to attack rolls against that target."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "b7a1211d08826500", "tags": ["leader", "noble", "positioning", "ranged", "scaling", "skills", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Face the Foe"}]}}, "effects": [{"_id": "5169131c-cf9c-4b1a-8000-3268dca5ae55", "name": "Face the Foe", "icon": "icons/svg/sword.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Face the Foe"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.face_the_foe", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["attack.when-hit", "attack.with-ranged"]}}}
{"_id": "cc1cf3a694244618", "name": "Diplomatic Poise", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "The strength of your personality is incomparable. Once per encounter, as a Reaction, you may use your Will Defense as your Fortitude Defense. This will also affect Damage Threshold until your next turn.", "benefit": "The strength of your personality is incomparable. Once per encounter, as a Reaction, you may use your Will Defense as your Fortitude Defense. This will also affect Damage Threshold until your next turn.", "class": "", "category": "", "costNumeric": null, "treeId": "feb08c2834a447ab", "tags": ["action_economy", "defender", "diplomacy", "leader", "reaction", "social_defense", "striker", "tree_feb08c2834a447ab", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 2, "type": "untyped", "predicates": ["defense.fortitude", "defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Diplomatic Poise"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["defense.fortitude", "defense.will", "turn.once-per-round"]}}}
{"_id": "cc6f40522eca4cdd90dc5a04edad0a07", "name": "Modification Specialist", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"benefit": "You have become skilled at Reprogramming and modifying your own Droid Systems. You do not incur the normal -5 penalty on Mechanics and Use Computer checks to Reprogram yourself or perform self-modifications.", "description": "You have become skilled at Reprogramming and modifying your own Droid Systems. You do not incur the normal -5 penalty on Mechanics and Use Computer checks to Reprogram yourself or perform self-modifications.", "prerequisites": "", "class": "3b1ed5f1038d49fb", "category": "Independent Droid", "treeId": "9fe73a3703fa45fca628fd43cae6bf7f", "tags": ["category_independent_droid", "crafting", "droid", "durability", "feat_chain", "mechanics", "modification", "self_repair", "skills", "slicing", "striker", "talent_chain", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Modification Specialist"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cc78c981176d4fed", "name": "Avoid Collisions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "- You can always attempt to Avoid a Collision for half damage. If you were permitted to avoid a collision without this talent, you instead take half-damage on a failure and no damage on a success.", "benefit": "- You can always attempt to Avoid a Collision for half damage. If you were permitted to avoid a collision without this talent, you instead take half-damage on a failure and no damage on a success.", "class": "", "category": "", "costNumeric": null, "treeId": "25d99948c9cb41ad", "tags": ["evasion", "mobility", "pilot", "striker", "survivability", "tree_25d99948c9cb41ad", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Avoid Collisions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
{"_id": "cc90a9fc255f4dc4", "name": "Seyugi Cyclone", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Whenever you use the Whirlwind Attack feat, you can move up to your speed after the attack is resolved. Prerequisite: You gain a +2 circumstance bonus to your Reflex Defense against any target hit by your Whirlwind Attack until the start of your next turn. Prerequisite: Instead of a normal melee attack at the end of a Charge, you can spend a Force Point to make a Whirlwind Attack at the end of a Charge, provided you are not wielding any weapons (other than Combat Gloves, a Stunning Gauntlet, or Shockboxing Gloves). Prerequisite: When you damage a target with a Whirlwind Attack, you can choose to move that target 1 square in any direction as a Free Action. You can't move a target that's being Grabbed or Grappled, and you can't move the opponent into a solid object or another creature's Fighting Space. This forced movement does not provoke Attacks of Opportunity.", "benefit": "Whenever you use the Whirlwind Attack feat, you can move up to your speed after the attack is resolved. Prerequisite: You gain a +2 circumstance bonus to your Reflex Defense against any target hit by your Whirlwind Attack until the start of your next turn. Prerequisite: Instead of a normal melee attack at the end of a Charge, you can spend a Force Point to make a Whirlwind Attack at the end of a Charge, provided you are not wielding any weapons (other than Combat Gloves, a Stunning Gauntlet, or Shockboxing Gloves). Prerequisite: When you damage a target with a Whirlwind Attack, you can choose to move that target 1 square in any direction as a Free Action. You can't move a target that's being Grabbed or Grappled, and you can't move the opponent into a solid object or another creature's Fighting Space. This forced movement does not provoke Attacks of Opportunity.", "class": "", "category": "", "costNumeric": null, "treeId": "a7ad797b01114925", "tags": ["action_economy", "controller", "defender", "force", "force_control", "force_defense", "force_offense", "force_point_spend", "martial_arts", "melee", "mobility", "offense_melee", "positioning", "resource_spend", "striker", "tree_a7ad797b01114925", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Seyugi Cyclone"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": ["defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee"]}}}
{"_id": "cc938ba0542c97e4", "name": "Unclouded Judgment", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Sense Deception", "benefit": "Spend a Force Point to automatically negate a mind-affecting Force power or talent.", "description": "Spend a Force Point to automatically negate a mind-affecting Force power or talent.", "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "44554c28675292b6", "tags": ["feat-chain", "force", "jedi", "light-side", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Unclouded Judgment"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unclouded_judgment", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.428Z", "detectedPredicates": []}}}
