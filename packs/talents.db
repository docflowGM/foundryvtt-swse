{"_id": "6ecfeff647f8764e", "name": "Inspire Loyalty", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You gain a single Follower. Choose either the aggressive, defensive, or utility Follower Template for your follower, generating the follower's statistics based on the rules found in the Followers section. This Follower gains one Armor Proficiency Feat of your choice and becomes Trained in the Perception skill. The Follower must meet the prerequisites for the Armor Proficiency Feat you select.", "description": {"value": "You gain a single Follower. Choose either the aggressive, defensive, or utility Follower Template for your follower, generating the follower's statistics based on the rules found in the Followers section. This Follower gains one Armor Proficiency Feat of your choice and becomes Trained in the Perception skill. The Follower must meet the prerequisites for the Armor Proficiency Feat you select.\n\nYou can select this Talent multiple times. Each time you do, you gain one additional Follower (maximum of 3 Followers)."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "be2e649cbb7332fa", "tags": ["action-economy", "controller", "defender", "force", "force-control", "force-defense", "force-offense", "melee", "mobility", "noble", "positioning", "ranged", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 5, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Inspire Loyalty"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.inspire_loyalty", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "6ef0900cd62869e7", "name": "Surprising Weapons", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you successfully hit an enemy with an Amphistaff, Thud Bug, or Razor Bug, and your attack roll also exceeds the target’s Will Defense, that target is considered Flat-Footed against you until the end of your next turn.", "description": {"value": "Whenever you successfully hit an enemy with an Amphistaff, Thud Bug, or Razor Bug, and your attack roll also exceeds the target’s Will Defense, that target is considered Flat-Footed against you until the end of your next turn."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "33c3210fcac8c664", "tags": ["controller", "defender", "scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Surprising Weapons"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.surprising_weapons", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "6ef413a824474491", "name": "Target Acquisition", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Equipped with a Weapon Tool", "description": "You lock onto the target designated by the Talent. If the target leaves your line of sight, you automatically reacquire the Target Lock as a Reaction if the target comes back within your line of sight. You also gain a +5 bonus to your Perception skill when opposing the target's Stealth checks. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids Once per encounter, as a Free Action, you can increase the damage dealt by one of your weapons by 1 or 2 damage dice in exchange for moving -1 step down the Condition Track for each die increased. The weapon must be permanently mounted to your chassis (as a Tool), and it must use your internal power supply. Handheld weapons, such as Blaster Rifles, do not qualify for this Talent.", "benefit": "You lock onto the target designated by the Talent. If the target leaves your line of sight, you automatically reacquire the Target Lock as a Reaction if the target comes back within your line of sight. You also gain a +5 bonus to your Perception skill when opposing the target's Stealth checks. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids Once per encounter, as a Free Action, you can increase the damage dealt by one of your weapons by 1 or 2 damage dice in exchange for moving -1 step down the Condition Track for each die increased. The weapon must be permanently mounted to your chassis (as a Tool), and it must use your internal power supply. Handheld weapons, such as Blaster Rifles, do not qualify for this Talent.", "class": "", "category": "", "costNumeric": null, "treeId": "73814706c00849c6", "tags": ["action_economy", "condition_removal", "controller", "feat_chain", "perception", "ranged", "ranged_support", "reaction", "setup", "skill_stealth", "skills", "stealth", "striker", "support", "talent_chain", "targeting", "tree_73814706c00849c6", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 5, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Target Acquisition"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["turn.once-per-round"]}}}
