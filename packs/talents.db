{"_id": "f0cf0ad742a5e014", "name": "Vehicular Evasion", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If the Vehicle you are piloting is hit by an Area Attack, it takes half damage if the attack hits. If the Area Attack misses your Vehicle, it takes no damage. You cannot use this Talent when your Vehicle is stationary or disabled.", "description": {"value": "If the Vehicle you are piloting is hit by an Area Attack, it takes half damage if the attack hits. If the Area Attack misses your Vehicle, it takes no damage. You cannot use this Talent when your Vehicle is stationary or disabled."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "b17c1515c06361d6", "tags": ["battlefield-control", "condition-removal", "controller", "defender", "evasion", "mechanics", "piloting", "positioning", "scaling", "scout", "skills", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Vehicular Evasion"}]}}, "effects": [{"_id": "5929f21c-82c9-4c5d-b26a-a056bd79bd7c", "name": "Vehicular Evasion", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.vehicles.damage_reduction", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Vehicular Evasion"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.vehicular_evasion", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
