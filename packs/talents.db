{"_id": "ddacb8e4517da6b5", "name": "Telekinetic Savant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you take the Force Training Feat and select Move Object as one of your Force Powers, you can also select one extra Force Power to add to your Force Power Suite for free. This extra Force Power must contain the [Telekinetic] descriptor. You can only gain one extra Force Power each time you take the Force Training Feat, regardless of how many times you choose the Move Object Force Power. If you increase your Wisdom score at a later time and select the Move Object power, you only gain an additional power if you did not take the Move Object power when you first chose that Feat. Otherwise, you gain an additional Force Power as normal. Reference Book: Star Wars Saga Edition Knights of the Old Republic Campaign Guide", "description": "When you take the Force Training Feat and select Move Object as one of your Force Powers, you can also select one extra Force Power to add to your Force Power Suite for free. This extra Force Power must contain the [Telekinetic] descriptor. You can only gain one extra Force Power each time you take the Force Training Feat, regardless of how many times you choose the Move Object Force Power. If you increase your Wisdom score at a later time and select the Move Object power, you only gain an additional power if you did not take the Move Object power when you first chose that Feat. Otherwise, you gain an additional Force Power as normal. Reference Book: Star Wars Saga Edition Knights of the Old Republic Campaign Guide", "costNumeric": null, "treeId": "6ac3416fb6aada56", "tags": ["controller", "force", "force_capacity", "force_control", "force_power_synergy", "mobility", "skill_substitution", "telekinesis", "telepathy", "tree_6ac3416fb6aada56", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Telekinetic Savant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.telekinetic_savant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": []}}}
{"_id": "ddece484fcea9c84", "name": "Medical Miracle", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can make a DC 20 Treat Injury check on an adjacent target. If the check is successful, that target immediately uses its Second Wind, even if it is above half Hit Points. If the target has already expended all of its Second Winds for the day, this Talent has no effect.", "description": {"value": "As a Standard Action, you can make a DC 20 Treat Injury check on an adjacent target. If the check is successful, that target immediately uses its Second Wind, even if it is above half Hit Points. If the target has already expended all of its Second Winds for the day, this Talent has no effect."}, "class": "06f4d9029debf827", "costNumeric": null, "category": "Medic", "treeId": "61725c845d26ade0", "tags": ["category_medic", "healing", "new_action", "positioning", "skills", "standard_action", "striker", "support", "survivability", "teamwork", "treat_injury"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Medical Miracle"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.medical_miracle", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["attack.when-hit"]}}}
