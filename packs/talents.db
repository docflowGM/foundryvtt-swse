{"_id": "51a8e7a193955f11", "name": "Power of Hatred", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Incite Rage", "benefit": "Once per encounter as a Swift Action, you can inflame the passions of your allies. Each ally within your line of sight who has fewer than half its normal Hit Points gains bonus Hit Points equal to your Character Level. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from multiple sources do not stack.", "description": {"value": "Once per encounter as a Swift Action, you can inflame the passions of your allies. Each ally within your line of sight who has fewer than half its normal Hit Points gains bonus Hit Points equal to your Character Level. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from multiple sources do not stack."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.incite_rage"}], "_source": "canonical-csv"}, "treeId": "4d5ac20318ef56b6", "tags": ["action_economy", "category_sith_apprentice", "controller", "dark_side", "feat_chain", "force", "force_execution", "jedi", "striker", "swift_action", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Power of Hatred"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.power_of_hatred", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "51ee1b777709cc4e", "name": "Security Slicer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Mechanics", "benefit": "You are an expert in electronic security. When you make a Mechanics check to Disable Device, you can do so without the help of a Security Kit. Additionally, something goes wrong only when you fail the Mechanics check by 10 or more.", "description": {"value": "You are an expert in electronic security. When you make a Mechanics check to Disable Device, you can do so without the help of a Security Kit. Additionally, something goes wrong only when you fail the Mechanics check by 10 or more."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "745a5686d6f21e8c"}], "_source": "fix5F-canonical"}, "treeId": "64874e65579e4cf4", "tags": ["feat-chain", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Security Slicer"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.security_slicer", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": []}}}
{"_id": "5218d5971b78119b", "name": "Empower Weapon", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You may spend a Force Point to empower a melee weapon. Empowering the weapon takes a Full-Round Action. From that point forward, the Empowered Weapon deals an additional die of damage, but only when wielded by you.", "description": {"value": "You may spend a Force Point to empower a melee weapon. Empowering the weapon takes a Full-Round Action. From that point forward, the Empowered Weapon deals an additional die of damage, but only when wielded by you.\n\nFor example, an empowered Lightsaber deals 3d8 points of damage, instead of 2d8 points of damage. Others who wield the weapon do not gain the bonus damage die."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "01e443d93e47f9c4", "tags": ["action_economy", "alchemy", "category_force_adept", "controller", "crafting", "empowerment", "force", "force_capacity", "force_control", "force_execution", "force_offense", "force_point_spend", "force_training", "lightsaber", "melee", "mobility", "mystic", "offense_melee", "positioning", "ranged", "resource_spend", "striker", "support", "sustained_damage", "tree_01e443d93e47f9c4"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Empower Weapon"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.empower_weapon", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["attack.when-hit", "proximity.ally-nearby"]}}}
{"_id": "5242623648114830", "name": "Critical Skill Success", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "Whenever you roll a Natural 20 on a Skill Check, choose one other Skill. Once before the end of your next turn, you can choose to gain a +5 competence bonus to a check with that Skill as a Free Action."}, "benefit": "Whenever you roll a Natural 20 on a Skill Check, choose one other Skill. Once before the end of your next turn, you can choose to gain a +5 competence bonus to a check with that Skill as a Free Action.", "class": "", "category": "", "costNumeric": null, "treeId": "04a6f32128cc4b98", "tags": ["critical_hit", "critical_success", "force", "precision", "scaling", "skill_mastery", "skills", "striker", "support", "tree_04a6f32128cc4b98", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Critical Skill Success"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "52a4914cca90cc4d", "name": "Guaranteed Shot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dual Weapon Mastery I", "benefit": "If you are wielding two Pistols and make a single ranged attack with one of those Pistols as a Standard Action, even if you miss you deal damage equal to half your Heroic Level to the target. This consumes a single shot from the weapon not making the attack, and the weapon you attack with uses as many shots required by the attack.", "description": {"value": "If you are wielding two Pistols and make a single ranged attack with one of those Pistols as a Standard Action, even if you miss you deal damage equal to half your Heroic Level to the target. This consumes a single shot from the weapon not making the attack, and the weapon you attack with uses as many shots required by the attack."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "ed77ab2e234089ed", "tags": ["feat-chain", "ranged", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Guaranteed Shot"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.guaranteed_shot", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": []}}}
{"_id": "52f51a77fd60f56f", "name": "Debilitating Shot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you Aim before making a ranged attack, you move the target character -1 step along the Condition Track if the attack deals damage. This Talent can be used only against characters, not objects or Vehicles.", "description": {"value": "If you Aim before making a ranged attack, you move the target character -1 step along the Condition Track if the attack deals damage. This Talent can be used only against characters, not objects or Vehicles."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "cb6f775cd227a3e3", "tags": ["action-economy", "condition-removal", "controller", "damage-reduction", "defender", "feat-chain", "force", "force-control", "force-defense", "force-offense", "mobility", "positioning", "precision", "ranged", "striker", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.against-ranged", "defense.reflex", "attack.when-hit", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Debilitating Shot"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.debilitating_shot", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["defense.against-ranged", "defense.reflex", "attack.when-hit", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "5319a796f2c4ff64", "name": "Fool's Luck", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can spend a Force Point to gain one of the following benefits for the rest of the encounter:", "description": {"value": "As a Standard Action, you can spend a Force Point to gain one of the following benefits for the rest of the encounter:\n\n+1 competence bonus to attack rolls\n+5 competence bonus on Skill Checks\n+1 competence bonus to all your Defenses\nIf you use this Talent to grant yourself a luck bonus to your Defenses, this bonus also applies to the Defenses of any Vehicle you are on (even if you are not the Pilot)."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "cee9b9398682b7d0", "tags": ["action-economy", "defender", "precision", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 5, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Fool's Luck"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fools_luck", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "533867af3de50833", "name": "Damaging Deception", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Cunning Distraction", "benefit": "You know how to distract a target, exposing weak spots that your allies can exploit. As a Standard Action, you can make a Deception check against the Will Defense of any target within your line of sight that can see, hear, and understand you. If successful, the next attack made by one of your allies made before the start of your next turn against that target deals 2 additional dice of damage.", "description": {"value": "You know how to distract a target, exposing weak spots that your allies can exploit. As a Standard Action, you can make a Deception check against the Will Defense of any target within your line of sight that can see, hear, and understand you. If successful, the next attack made by one of your allies made before the start of your next turn against that target deals 2 additional dice of damage."}, "class": "8da58194b3d58041", "costNumeric": null, "category": "Charlatan", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.cunning_distraction"}], "_source": "canonical-csv"}, "treeId": "ab9b75bc19f8e983", "tags": ["category_charlatan", "control", "deception", "defender", "feat_chain", "new_action", "opportunist", "skills", "social", "social_control", "standard_action", "stealth", "striker", "support", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Damaging Deception"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.damaging_deception", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["defense.will"]}}}
