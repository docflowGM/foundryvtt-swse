{"_id": "b293a6a20b90bebe", "name": "Tactical Withdrawal", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "All allies in line of sight and within 6 squares may withdraw as a swift action until the start of your next turn.", "description": "All allies in line of sight and within 6 squares may withdraw as a swift action until the start of your next turn.", "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "treeId": "560cc7994b357a0d", "tags": ["action-economy", "mobility", "positioning"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Tactical Withdrawal"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.tactical_withdrawal", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b2a9f60d6647fcc4", "name": "Shoulder to Shoulder", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you begin your turn adjacent to an ally, you gain a number of bonus Hit Points equal to your Heroic Level. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from various sources do not stack.", "description": {"value": "Whenever you begin your turn adjacent to an ally, you gain a number of bonus Hit Points equal to your Heroic Level. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from various sources do not stack."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "cb3751283ea8fa3d", "tags": ["positioning", "soldier", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Shoulder to Shoulder"}]}}, "effects": [{"_id": "bb8ee1e1-ea3c-4ba4-8315-7761e7a70cfb", "name": "Shoulder to Shoulder", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.hp", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Shoulder to Shoulder"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.shoulder_to_shoulder", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["proximity.ally-nearby"]}}}
{"_id": "b2b2176b7d9360e0", "name": "Advantageous Positioning", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Shift", "benefit": "Any opponent that you are Flanking is considered Flat-Footed and is denied its Dexterity bonus to its Reflex Defense against you.", "description": {"value": "Any opponent that you are Flanking is considered Flat-Footed and is denied its Dexterity bonus to its Reflex Defense against you."}, "class": "74fa04f5afb5f6e1", "costNumeric": null, "category": "Assassin", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.shift"}], "_source": "canonical-csv"}, "treeId": "186daeee7bd65a69", "tags": ["action_economy", "category_assassin", "condition_removal", "controller", "melee", "mobility", "precision_damage", "sniping", "stealth", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["attack.with-melee", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Advantageous Positioning"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"skillSubstitution": true, "substitutionType": "flanking_flatfoot", "description": "Flanked opponents are treated as flat-footed", "id": "swse.talent.advantageous_positioning", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["attack.with-melee", "turn.once-per-round"]}}}
{"_id": "b3255436ba174a17", "name": "Seen It All", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Tested in Battle, Trained in Initiative", "description": {"value": "You have seen more action in more places than most people know exist, and little in the galaxy gets you rattled. Any character using a Fear effect on you must roll twice, keeping the lower result on any Skill Checks and attack rolls."}, "benefit": "You have seen more action in more places than most people know exist, and little in the galaxy gets you rattled. Any character using a Fear effect on you must roll twice, keeping the lower result on any Skill Checks and attack rolls.", "class": "", "category": "", "costNumeric": null, "treeId": "96c390430d7a4975", "tags": ["action_economy", "awareness", "battlefield_control", "defender", "evasion", "melee", "positioning", "ranged", "striker", "support", "survivability", "tree_96c390430d7a4975", "uncategorized_talent", "veteran"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Seen It All"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "b3538b62448c840e", "name": "Force of Will", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You gain a +2 insight bonus to your Will Defense. Also, as a Swift Action, you can spend a Force Point to give all allies within 6 squares of you a +2 insight bonus to their Will Defense that lasts for the remainder of the encounter. This bonus does not extend to allies outside the range of the effect, even if they move within 6 squares of you later on.", "description": {"value": "You gain a +2 insight bonus to your Will Defense. Also, as a Swift Action, you can spend a Force Point to give all allies within 6 squares of you a +2 insight bonus to their Will Defense that lasts for the remainder of the encounter. This bonus does not extend to allies outside the range of the effect, even if they move within 6 squares of you later on.\n\nAllies who benefit from this Talent must remain within 6 squares of you to retain the insight bonus, and they lose it if you are knocked unconscious or killed. This is a Mind-Affecting effect."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["defender", "force", "force-defense", "jedi", "light-side", "positioning", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.will", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.will"}]}}, "effects": [{"_id": "863f70e4-6e08-4fd1-aa07-35a0fb8230dc", "name": "Force of Will", "icon": "icons/svg/brain.svg", "changes": [{"key": "system.defenses.will", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force of Will", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_of_will"}}}
{"_id": "b3590045fcd7c28c", "name": "Punishing Protection", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Inspire Loyalty, Base Attack Bonus +5", "benefit": "As a Reaction to you being damaged by an attack or a Force Power, one of your followers can make an immediate melee or ranged attack against the target that attacked you. Until the beginning of your next turn, any time you are damaged by an attack or Force Power, another one of your followers can attack that attacking target. This ability can be used once per encounter.", "description": {"value": "As a Reaction to you being damaged by an attack or a Force Power, one of your followers can make an immediate melee or ranged attack against the target that attacked you. Until the beginning of your next turn, any time you are damaged by an attack or Force Power, another one of your followers can attack that attacking target. This ability can be used once per encounter."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.inspire_loyalty"}, {"type": "bab", "min": 5}], "_source": "canonical-csv"}, "treeId": "be2e649cbb7332fa", "tags": ["action-economy", "feat-chain", "force", "force-offense", "noble", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Punishing Protection"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.punishing_protection", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "b3634baba7004d27", "name": "Cheap Trick", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Deception", "description": {"value": "When you make a Deception check to Feint against an enemy within 6 squares of you, you can roll twice, keeping the better of the two results."}, "benefit": "When you make a Deception check to Feint against an enemy within 6 squares of you, you can roll twice, keeping the better of the two results.", "class": "", "category": "", "costNumeric": null, "treeId": "7c6d007b549c4a4a", "tags": ["action_economy", "battlefield_control", "cheap_shot", "condition_removal", "controller", "damage_reduction", "deception", "defender", "melee", "mobility", "opportunist", "positioning", "ranged", "social_control", "striker", "support", "sustained_damage", "tree_7c6d007b549c4a4a", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "proximity.count-allies-within-12", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Cheap Trick"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "proximity.count-allies-within-12", "turn.once-per-round"]}}}
{"_id": "b37ac074a7e8de58", "name": "Instruction", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, as a Standard Action, you can boost the competence of one of your allies within 6 squares. That individual gains the ability to make a single Skill Check using your Skill modifier (except Use the Force); this Skill Check must be made before the end of the encounter, or the benefit is lost.", "description": {"value": "Once per encounter, as a Standard Action, you can boost the competence of one of your allies within 6 squares. That individual gains the ability to make a single Skill Check using your Skill modifier (except Use the Force); this Skill Check must be made before the end of the encounter, or the benefit is lost.\n\nYou can select this Talent multiple times. Each time you do so, you gain one additional use of this Talent per encounter."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "d65a4816379802ee", "tags": ["force", "noble", "positioning", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Instruction"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.instruction", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "b3ce8b08a8cb95fa", "name": "Lightsaber Evasion", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever an enemy misses you with a melee attack with a Lightsaber, you may move up to 2 squares in any direction. This movement does not provoke Attacks of Opportunity.", "description": {"value": "Whenever an enemy misses you with a melee attack with a Lightsaber, you may move up to 2 squares in any direction. This movement does not provoke Attacks of Opportunity."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "29b16e48a3dbf165", "tags": ["controller", "evasion", "force", "force-control", "force-offense", "lightsaber", "melee", "mobility", "positioning", "scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Lightsaber Evasion"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lightsaber_evasion", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b431ca7ea00947b9", "name": "Delusion", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You may create a predefined illusion designed to delude a single target. The delusion persists in the target's senses for 1d4 rounds. You then move down two steps on the Condition Track after creating the . You may use your Use the Force check modifier instead of your Deception check for purposes of Deceptive Appearance. You are considered Trained in the Deception skill for the purposes of using this Talent. If you are entitled to a Deception check reroll for Deceptive Appearance, you may reroll your Use the Force check instead.", "benefit": "You may create a predefined illusion designed to delude a single target. The delusion persists in the target's senses for 1d4 rounds. You then move down two steps on the Condition Track after creating the . You may use your Use the Force check modifier instead of your Deception check for purposes of Deceptive Appearance. You are considered Trained in the Deception skill for the purposes of using this Talent. If you are entitled to a Deception check reroll for Deceptive Appearance, you may reroll your Use the Force check instead.", "class": "", "category": "", "costNumeric": null, "treeId": "cfd358ef61fb47bd", "tags": ["condition_removal", "controller", "deception", "force", "force_control", "force_execution", "illusion", "mobility", "perception", "scout", "skills", "social", "social_control", "spellcasting", "striker", "sustained_damage", "tree_cfd358ef61fb47bd", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Delusion"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
{"_id": "b47beb909e6fce63", "name": "Dark Side Savant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Prerequisites: At least one Talent from the Dark Side Talent Tree, Force Storm, Hatred", "benefit": "You can spend a Force Point to increase the result of a Use the Force check made to activate a Force Power with the [Dark Side] descriptor. (Normally Force Points cannot be used to increase results of [Dark Side] or [Light Side] Force Powers.) Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - The Dark Side", "description": "You can spend a Force Point to increase the result of a Use the Force check made to activate a Force Power with the [Dark Side] descriptor. (Normally Force Points cannot be used to increase results of [Dark Side] or [Light Side] Force Powers.) Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - The Dark Side", "costNumeric": null, "treeId": "de95d37c72b1c4cd", "tags": ["dark_side", "dark_side_mastery", "feat_chain", "force", "force_capacity", "force_execution", "force_multiplier", "force_point_spend", "force_power_synergy", "forecast_value", "light_side", "resource_spend", "support", "talent_chain", "tree_de95d37c72b1c4cd", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Dark Side Savant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_side_savant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": []}}}
