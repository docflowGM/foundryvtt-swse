{"_id": "3df46d093b31411d", "name": "Indomitable class feature", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Rather than becoming completely detached from your mental state, you are able to filter through influences to selectively allow beneficial effects. Instead of being immune to all Mind-Affecting effects, you become aware of any Mind-Affecting effects which target you, and may choose to allow or deny each effect. You have this ability even while unconscious.", "benefit": "Rather than becoming completely detached from your mental state, you are able to filter through influences to selectively allow beneficial effects. Instead of being immune to all Mind-Affecting effects, you become aware of any Mind-Affecting effects which target you, and may choose to allow or deny each effect. You have this ability even while unconscious.", "class": "", "category": "", "costNumeric": null, "treeId": "e35ee41362604227", "tags": ["balance", "force", "survivability", "tree_e35ee41362604227", "uncategorized_talent", "will_defense"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Indomitable class feature"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.408Z", "detectedPredicates": []}}}
{"_id": "3e18acc25d6c03db", "name": "Steel Resolve", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you use a Standard Action to make a melee attack, you can take a penalty between -1 to -5 on your attack roll and add twice that value (+2 to +10) as an insight bonus to your Will Defense. This bonus may not exceed your Base Attack Bonus. The changes to attack rolls and Will Defense last until the start of your next turn.", "description": {"value": "When you use a Standard Action to make a melee attack, you can take a penalty between -1 to -5 on your attack roll and add twice that value (+2 to +10) as an insight bonus to your Will Defense. This bonus may not exceed your Base Attack Bonus. The changes to attack rolls and Will Defense last until the start of your next turn."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "36f18f3e974feb33", "tags": ["defender", "force", "force-defense", "force-offense", "jedi", "light-side", "melee", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.fortitude"}]}}, "effects": [{"_id": "0144ea2e-0dd1-4476-b7d8-46767075cae0", "name": "Steel Resolve", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.fortitude", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Steel Resolve", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.steel_resolve"}}}
{"_id": "3e35df4fce7082a3", "name": "Controlled Burst", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Your penalty when making an Autofire attack or using the Burst Fire feat is reduced to -2. In addition, if you Brace an Autofire-only weapon, you have no penalty on your attack roll.", "description": {"value": "Your penalty when making an Autofire attack or using the Burst Fire feat is reduced to -2. In addition, if you Brace an Autofire-only weapon, you have no penalty on your attack roll."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "2f720d8b061f9bd0", "tags": ["action-economy", "burst-damage", "damage-reduction", "dual-wield", "feat-chain", "force", "force-offense", "heavy-weapons", "lightsaber", "melee", "positioning", "ranged", "scaling", "soldier", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 12, "type": "untyped", "predicates": ["attack.with-melee", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Controlled Burst"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.controlled_burst", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": ["attack.with-melee", "turn.once-per-round"]}}}
{"_id": "3e6f7edaeec04a06", "name": "Quick Fix", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Mechanics", "benefit": "Once per encounter, you may Jury-Rig an object or Vehicle that is not Disabled. All normal benefits and penalties for Jury-Rigging still apply.", "description": {"value": "Once per encounter, you may Jury-Rig an object or Vehicle that is not Disabled. All normal benefits and penalties for Jury-Rigging still apply."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "745a5686d6f21e8c"}], "_source": "fix5F-canonical"}, "treeId": "38d7c18ce4664c66", "tags": ["action-economy", "damage-reduction", "feat-chain", "mechanics", "scoundrel", "skills", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Quick Fix"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.quick_fix", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "3e98c9f5a4f450ff", "name": "Educated", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Sometimes you surprise others with your skill. Once per day, you may make an Untrained skill check as though you were Trained in the Skill. Exception: you cannot use this Talent to make an Untrained Use the Force check as though you were Trained in the skill, unless you have the Force Sensitivity feat. You can select this Talent multiple times; each time you do, you can use it one additional time per day. Each time you gain a level (including the level at which you select this Talent), you receive an amount of credits equal to 5,000 x your Class Level. You can spend these credits as you see fit. The credits appear in a civilized, accessible location of your choice or in your private bank account. Reference Book: Star Wars Saga Edition Starships of the Galaxy Prerequisites: , Trained in Knowledge (Technology) You are Trained in the Mechanics skill. Additionally, when installing new systems into a Vehicle, the efficiency of your designs reduces the time it takes to install the system by 25%. Reference Book: Star Wars Saga Edition Force Unleashed Campaign Guide Prerequisites: , Intelligence 13 Select a number of Skills equal to your Intelligence modifier that you are not Trained in. You may now use Trained-only applications of those Skills, and they are considered Class Skills. You are not considered Trained in those Skills for any other purposes, and must still satisfy any other requirements in order to use the skill. Homebrew Reference Book: Legacy of the Force Sourcebook Select one type of performance, such as acting, dancing, singing, or playing a musical instrument. You gain a +5 bonus on Persuasion checks to entertain for that type of performance. Homebrew Reference Book: Legacy of the Force Sourcebook Prerequisites: , Intelligence 13 You have the ability to acquire aid and information from a long list of people. You may reroll any Gather Information check, but the result of the reroll must be accepted, even if it is worse. Additionally, the DC for any Persuasion checks made to reduce the cost of Bribery is reduced by 5.", "description": {"value": ""}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "b5bb4154688c66ab", "tags": ["ambush", "damage-reduction", "force", "mechanics", "noble", "scaling", "skills", "social", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Educated"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.educated", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "3eddc00a79422747", "name": "Uncanny Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per day, you can add one-half your Officer Class Level to all your Defenses for one round. You must declare that you are using this Talent at the beginning of your turn. The benefits last until the beginning of your next turn.", "description": {"value": "Once per day, you can add one-half your Officer Class Level to all your Defenses for one round. You must declare that you are using this Talent at the beginning of your turn. The benefits last until the beginning of your next turn."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "treeId": "9253ace716c3e966", "tags": ["defender", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Uncanny Defense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.uncanny_defense", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "3f01107ed7779426", "name": "Impel Ally III", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Impel Ally I, Impel Ally II", "benefit": "Once per encounter, you can spend three Swift Actions on consecutive turns to grant one ally the ability to take a Standard Action and a Move Action. The ally must act immediately on your turn when the final Swift Action is spent, before you do anything else, or the opportunity is wasted.", "description": {"value": "Once per encounter, you can spend three Swift Actions on consecutive turns to grant one ally the ability to take a Standard Action and a Move Action. The ally must act immediately on your turn when the final Swift Action is spent, before you do anything else, or the opportunity is wasted."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.impel_ally_ii"}], "_source": "canonical-csv"}, "treeId": "560cc7994b357a0d", "tags": ["action-economy", "controller", "feat-chain", "mobility", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Impel Ally III"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.impel_ally_iii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "3f5b1b3566f16ff5", "name": "Taint of the Dark Side", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dark Deception", "benefit": "Add one Force Power with the [Dark Side] descriptor to your Force Power Suite. Once per encounter you can use that Force Power with the [Dark Side] descriptor without increasing your Dark Side Score. If you spend a Force Point or Destiny Point to modify this Force Power in any way, you increase your Dark Side Score as normal.", "description": {"value": "Add one Force Power with the [Dark Side] descriptor to your Force Power Suite. Once per encounter you can use that Force Power with the [Dark Side] descriptor without increasing your Dark Side Score. If you spend a Force Point or Destiny Point to modify this Force Power in any way, you increase your Dark Side Score as normal."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "eab0d8bbee7e0f4f", "tags": ["dark-side", "feat-chain", "force", "jedi", "light-side", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Taint of the Dark Side"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.taint_of_the_dark_side", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "3f8f5305eabc525e", "name": "Walk the Line", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Disruptive", "benefit": "As a Standard Action, you can do or say something that catches your enemies off guard. All opponents within 6 squares of you, and within your line of sight take a -2 penalty to their Defenses until the start of your next turn. The penalty is negated if line of sight is broken.", "description": {"value": "As a Standard Action, you can do or say something that catches your enemies off guard. All opponents within 6 squares of you, and within your line of sight take a -2 penalty to their Defenses until the start of your next turn. The penalty is negated if line of sight is broken.\n\nThis Talent has a range of 6 squares at Starship Scale."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.disruptive"}], "_source": "canonical-csv"}, "treeId": "67b59e020c1660eb", "tags": ["defender", "feat-chain", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Walk the Line"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.walk_the_line", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
