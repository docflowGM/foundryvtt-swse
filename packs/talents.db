{"_id": "be617461ca46a5ad", "name": "Burning Assault", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Jet Pack Training", "benefit": "As a Standard Action you can expend one of your Jet Pack's charges to make an attack with the Jet Pack, treating it as a Flamethrower. You cannot use this Talent when you are flying. You are considered proficient in the Flamethrower for purposes of making this attack.", "description": {"value": "As a Standard Action you can expend one of your Jet Pack's charges to make an attack with the Jet Pack, treating it as a Flamethrower. You cannot use this Talent when you are flying. You are considered proficient in the Flamethrower for purposes of making this attack."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.jet_pack_training"}], "_source": "canonical-csv"}, "treeId": "1f50c63b6f08de10", "tags": ["feat-chain", "heavy-weapons", "mobility", "ranged", "soldier", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Burning Assault"}]}}, "effects": [{"_id": "47df0bb1-0bd6-47eb-9040-0eed4f41eba3", "name": "Burning Assault", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.flamethrower", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Burning Assault"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.burning_assault", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.426Z", "detectedPredicates": []}}}
