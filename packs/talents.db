{"_id": "54e32a12afb28906", "name": "Guidance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Perception", "benefit": "You know how to guide others through treacherous terrain. You may use a Swift Action to point out the path of least resistance to an ally within line of sight who can see, hear, and understand you. The ally ignores the effect of Difficult Terrain on its next turn. You cannot use this Talent on yourself.", "description": {"value": "You know how to guide others through treacherous terrain. You may use a Swift Action to point out the path of least resistance to an ally within line of sight who can see, hear, and understand you. The ally ignores the effect of Difficult Terrain on its next turn. You cannot use this Talent on yourself."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "43c5941072ec78af"}], "_source": "fix5F-canonical"}, "treeId": "089933380b40ce20", "tags": ["controller", "feat-chain", "scout", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Guidance"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.guidance", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": []}}}
