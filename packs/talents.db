{"_id": "1c381292494e3139", "name": "Hesitate", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can fill your opponent with doubt by making a Persuasion check as a Standard Action against a single target that can hear and understand you within 12 squares of you. If your check result equals or exceeds the target's Will Defense, the target takes a -2 penalty to its base speed, and if the target takes a Standard Action, it must also spend its Swift Action.", "description": {"value": "You can fill your opponent with doubt by making a Persuasion check as a Standard Action against a single target that can hear and understand you within 12 squares of you. If your check result equals or exceeds the target's Will Defense, the target takes a -2 penalty to its base speed, and if the target takes a Standard Action, it must also spend its Swift Action.\n\nThis penalty lasts until the end of the target's next turn."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "67b59e020c1660eb", "tags": ["action-economy", "defender", "mobility", "positioning", "scoundrel", "skills", "social", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Hesitate"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hesitate", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.405Z", "detectedPredicates": ["defense.will", "turn.once-per-round"]}}}
{"_id": "1d50b01d5151c3eb", "name": "Enhance Cover", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, you can designate a single ally within your line of sight who has Cover from one or more enemies. That ally is considered instead to have Improved Cover against those enemies until the start of your next turn as long as the ally still has Cover.", "description": {"value": "As a Swift Action, you can designate a single ally within your line of sight who has Cover from one or more enemies. That ally is considered instead to have Improved Cover against those enemies until the start of your next turn as long as the ally still has Cover."}, "class": "4ee81a6708a516cd", "costNumeric": null, "category": "Pathfinder", "treeId": "383ff8d392488cf8", "tags": ["action_economy", "category_pathfinder", "cover", "defense", "mobility", "positioning", "recon", "scaling", "support", "survival", "swift_action"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Enhance Cover"}]}}, "effects": [{"_id": "252a6d67-5560-4250-9598-2b17a0cb6877", "name": "Enhance Cover", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.cover", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Enhance Cover"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.enhance_cover", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.405Z", "detectedPredicates": []}}}
