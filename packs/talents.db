{"_id": "6a52361527b64513", "name": "Entangler", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "When Grabbing a target, you take a -2 penalty to your attack roll (instead of the normal -5 penalty). Until the target breaks the Grab, it takes a -5 penalty to attack rolls, including those made with Natural and Light Weapons (instead of the normal -2 penalty)."}, "benefit": "When Grabbing a target, you take a -2 penalty to your attack roll (instead of the normal -5 penalty). Until the target breaks the Grab, it takes a -5 penalty to attack rolls, including those made with Natural and Light Weapons (instead of the normal -2 penalty).", "class": "", "category": "", "costNumeric": null, "treeId": "67fdd8dce9abd6c1", "tags": ["control", "entangle", "positioning", "restrain", "tree_67fdd8dce9abd6c1", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Entangler"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "6a66ba6e0834dd6f", "name": "Born Leader", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, as a Swift Action, you grant all allies within your line of sight a +1 insight bonus on attack rolls. This effect lasts for as long as they remain within line of sight of you. An ally loses this bonus immediately if line of sight is broken or you are unconscious or dead.", "description": {"value": "Once per encounter, as a Swift Action, you grant all allies within your line of sight a +1 insight bonus on attack rolls. This effect lasts for as long as they remain within line of sight of you. An ally loses this bonus immediately if line of sight is broken or you are unconscious or dead."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "057a978a7dc1d5a7", "tags": ["armor", "defender", "noble", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.will", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.will"}]}}, "effects": [{"_id": "f9275c38-3cb5-4ab3-aaa5-25e5722dcdd3", "name": "Born Leader", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.will", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Born Leader", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.born_leader"}}}
