{"_id": "df9c25340dcb7c95", "name": "Ion Mastery", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You know the typical weaknesses of Vehicles and Droids, and you know how to preserve such targets for capture rather than destroying them. When attacking with Ion weapons, you gain a +1 bonus on attack rolls and deal +1 die of Ion damage.", "description": {"value": "You know the typical weaknesses of Vehicles and Droids, and you know how to preserve such targets for capture rather than destroying them. When attacking with Ion weapons, you gain a +1 bonus on attack rolls and deal +1 die of Ion damage."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "df6678946610c554", "tags": ["scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Ion Mastery"}]}}, "effects": [{"_id": "94fbdf73-6d9e-41ee-8a44-47de0826d93e", "name": "Ion Mastery", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.ion", "mode": 2, "value": "1"}, {"key": "system.damage.ion", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Ion Mastery"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ion_mastery", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "df9c364e91826cbf", "name": "Uncanny Dodge I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Acute Senses, Improved Initiative", "benefit": "You retain your Dexterity bonus to your Reflex Defense regardless of being caught Flat-Footed or struck by a hidden attacker. You still lose your Dexterity bonus to your Reflex Defense if you are Immobilized.", "description": {"value": "You retain your Dexterity bonus to your Reflex Defense regardless of being caught Flat-Footed or struck by a hidden attacker. You still lose your Dexterity bonus to your Reflex Defense if you are Immobilized.\n\nIf you are the Pilot, this Talent applies to your Vehicle."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.improved_initiative"}], "_source": "canonical-csv"}, "treeId": "1c48d1cd9ab1f5c8", "tags": ["controller", "evasion", "feat-chain", "scout", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Uncanny Dodge I"}]}}, "effects": [{"_id": "4a141452-850f-43d6-ae0e-f908f5049780", "name": "Uncanny Dodge I", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.dex_bonus.flatfooted", "mode": 5, "value": "retained"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Uncanny Dodge I"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.uncanny_dodge_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "dfb9e58c7bcb095c", "name": "Jedi Quarry", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, you can designate a single target creature as the focus of your attentions. You gain a +2 bonus to your Speed any time you spend a Move Action to Move, provided that you end your movement adjacent to the target.", "description": {"value": "As a Swift Action, you can designate a single target creature as the focus of your attentions. You gain a +2 bonus to your Speed any time you spend a Move Action to Move, provided that you end your movement adjacent to the target.\n\nYou retain this bonus (and may not use this Talent again) until your target surrenders, is reduced to 0 Hit Points, moves to the bottom of the Condition Track, or until the encounter ends."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "44554c28675292b6", "tags": ["controller", "force", "force-control", "jedi", "light-side", "mobility", "positioning", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "speed.base", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.speed"}]}}, "effects": [{"_id": "860c1193-7d99-4897-963c-59f57550c3ab", "name": "Jedi Quarry", "icon": "icons/svg/running.svg", "changes": [{"key": "system.speed", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Jedi Quarry", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.jedi_quarry"}}}
