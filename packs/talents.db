{"_id": "661899f73e20f2ce", "name": "Modify Poison", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Malkite Techniques", "benefit": "You can modify the deliver method of a Poison (Contact, Ingested, Inhaled) to another delivery method by succeeding in a Knowledge (Life Science) check (DC equal to the Poison's Treat Injury DC). The Poison's capabilities and specific effects are unchanged.", "description": {"value": "You can modify the deliver method of a Poison (Contact, Ingested, Inhaled) to another delivery method by succeeding in a Knowledge (Life Science) check (DC equal to the Poison's Treat Injury DC). The Poison's capabilities and specific effects are unchanged."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.malkite_techniques"}], "_source": "canonical-csv"}, "treeId": "c55b003333ff082d", "tags": ["feat-chain", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Modify Poison"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.modify_poison", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "661c2c0665e911f6", "name": "Findsman Ceremonies", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Sensitivity", "benefit": "Once per day, you can spend 10 minutes performing rituals that enhance your connection with The Force, receiving visions and portents as a result. At that time, you can spend any number of Force Points in the performance of the ritual, up to the total number you have remaining.", "description": {"value": "Once per day, you can spend 10 minutes performing rituals that enhance your connection with The Force, receiving visions and portents as a result. At that time, you can spend any number of Force Points in the performance of the ritual, up to the total number you have remaining.\n\nFor the remainder of the day, whenever you make a Perception or Stealth check, make a Use the Force check to use the Farseeing Force Power, or make an attack roll, you can choose to reroll that check, but must accept to the results of the reroll, even if it is worse. You may do this a number of times per day equal to the number of Force Points you spent during the casting of the ritual."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "022b31d355c840a9", "tags": ["action-economy", "ambush", "controller", "evasion", "melee", "mobility", "perception", "positioning", "ranged", "scoundrel", "skills"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Findsman Ceremonies"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.findsman_ceremonies", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "66b23ee79bd33bf1", "name": "Force Talisman", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You may spend a Force Point to imbue a weapon or some other portable object with The Force, creating a Talisman that provides protection to you. Creating the Talisman takes a Full-Round Action.", "description": {"value": "You may spend a Force Point to imbue a weapon or some other portable object with The Force, creating a Talisman that provides protection to you. Creating the Talisman takes a Full-Round Action.\n\nWhile you wear or carry the Talisman on your person, you gain a +1 Force bonus to one of your Defenses (Reflex Defense, Fortitude Defense, or Will Defense).\n\nYou may only have one Force Talisman active at a given time, and if your Force Talisman is destroyed, you may not create another Force Talisman for 24 hours."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "01e443d93e47f9c4", "tags": ["action_economy", "alchemy", "category_force_adept", "controller", "crafting", "defender", "empowerment", "force", "force_capacity", "force_defense", "force_execution", "force_point_spend", "force_training", "mystic", "resource_spend", "striker", "sustained_damage", "tree_01e443d93e47f9c4"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}]}}, "effects": [{"_id": "c9c2fc17-c5be-432e-aa0f-440af2bd315c", "name": "Force Talisman", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.reflex", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Talisman", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_talisman"}}}
{"_id": "66ed448a3a2e82bc", "name": "Close Scrape", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you are Piloting a Vehicle of Colossal size or smaller, you may make a Pilot check as a Reaction to turn a Critical Hit into a normal hit. The DC for the Pilot check is equal to the attack roll total of the Critical Hit.", "description": {"value": "Whenever you are Piloting a Vehicle of Colossal size or smaller, you may make a Pilot check as a Reaction to turn a Critical Hit into a normal hit. The DC for the Pilot check is equal to the attack roll total of the Critical Hit.\n\nIf you are successful, the damage from the attack is not doubled (though it is still considered an automatic hit)."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "b17c1515c06361d6", "tags": ["precision", "scout", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Close Scrape"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.close_scrape", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
