{"_id": "bebc181408831371", "name": "Master Mender", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Expert Shaper", "benefit": "Whenever you temporarily mend a Biotech device using the Treat Injury Skill, the mended device moves +4 steps on the Condition Track. In addition, the mended device only moves -3 steps down the Condition Track at the end of the scene or encounter, and is only disabled if this reduction brings it to -5 steps on the Condition Track.", "description": {"value": "Whenever you temporarily mend a Biotech device using the Treat Injury Skill, the mended device moves +4 steps on the Condition Track. In addition, the mended device only moves -3 steps down the Condition Track at the end of the scene or encounter, and is only disabled if this reduction brings it to -5 steps on the Condition Track."}, "class": "557e1a5ec72166fd", "costNumeric": null, "category": "Shaper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.expert_shaper"}], "_source": "canonical-csv"}, "treeId": "cdbee578d65154fc", "tags": ["ability_enhancement", "biotech", "category_shaper", "condition_removal", "controller", "crafting", "feat_chain", "healing", "mobility", "striker", "support", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Master Mender"}]}}, "effects": [{"_id": "7117168e-4a20-4a4e-b88d-e812caeb84a0", "name": "Master Mender", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.healing.biotech", "mode": 2, "value": "4"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Master Mender"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.master_mender", "migratedToState": true, "migrationDate": "2026-03-08T1