{"_id": "9319584186ce4228", "name": "Dathomiri Hunter", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Move Object", "description": "When you take the Aim Action with an Energy Bow, you need only spend a single Swift Action (instead of the normal two Swift Actions) as long as you have used the Sense Surroundings aspect of the Use the Force skill since the beginning of your turn. Homebrew Reference Book: Dathomir Field Guide Once per turn as a Free Action, you can expend one use of the Move Object power from your Force Power Suite to reroll an attack roll made with an Energy Bow. The result of the reroll must be accepted, even if it is worse. Homebrew Reference Book: Dathomir Field Guide Prerequisites: , Intuitive Aim As a Standard Action, you may make a single attack with an Energy Bow against a target you sensed through the Sense Surroundings aspect of the Use the Force skill since the beginning of your turn. That attack ignores all Concealment and Cover from any source that is not resistant to Lightsaber attacks. Attacks made in this way that pass through Cover to reach the target deal one less die of damage.", "benefit": "When you take the Aim Action with an Energy Bow, you need only spend a single Swift Action (instead of the normal two Swift Actions) as long as you have used the Sense Surroundings aspect of the Use the Force skill since the beginning of your turn. Homebrew Reference Book: Dathomir Field Guide Once per turn as a Free Action, you can expend one use of the Move Object power from your Force Power Suite to reroll an attack roll made with an Energy Bow. The result of the reroll must be accepted, even if it is worse. Homebrew Reference Book: Dathomir Field Guide Prerequisites: , Intuitive Aim As a Standard Action, you may make a single attack with an Energy Bow against a target you sensed through the Sense Surroundings aspect of the Use the Force skill since the beginning of your turn. That attack ignores all Concealment and Cover from any source that is not resistant to Lightsaber attacks. Attacks made in this way that pass through Cover to reach the target deal one less die of damage.", "class": "", "category": "", "costNumeric": null, "treeId": "ad16f3e5f4f7441b", "tags": ["action_economy", "controller", "cover", "defense", "exotic_weapon", "feat_chain", "force", "force_capacity", "force_control", "force_execution", "force_offense", "force_power_synergy", "lightsaber", "melee", "mobility", "new_action", "offense_melee", "ranged_control", "scout", "spellcasting", "standard_action", "striker", "sustained_damage", "swift_action", "talent_chain", "tree_ad16f3e5f4f7441b", "uncategorized_talent", "use_the_force", "witchcraft"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Dathomiri Hunter"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.421Z", "detectedPredicates": []}}}
