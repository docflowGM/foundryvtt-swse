{"_id": "6b09fe0c6fe98367", "name": "Sow Confusion", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Hesitate", "benefit": "Once per encounter, as a Standard Action, you can make a Deception check and compare the result to the Will Defense of all enemies in your line of sight.", "description": {"value": "Once per encounter, as a Standard Action, you can make a Deception check and compare the result to the Will Defense of all enemies in your line of sight.\n\nIf the check result equals or exceeds an enemy's Will Defense, that enemy must spend a Swift Action in addition to a Standard Action to make an attack until the start of your next turn."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.hesitate"}], "_source": "canonical-csv"}, "treeId": "67b59e020c1660eb", "tags": ["action-economy", "defender", "feat-chain", "mobility", "scoundrel", "skills", "social", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Sow Confusion"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sow_confusion", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["defense.will", "turn.once-per-round"]}}}
