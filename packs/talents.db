{"_id": "141e1a07b365e0fd", "name": "Extended Critical Range (rifles)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Base Attack Bonus +10, Weapon Proficiency (Rifles)", "benefit": "When you are using a Rifle, you extend the weapon's critical range by 1 (for example, 19-20 instead of 20). However, anything other than a Natural 20 is not considered an automatic hit; if you roll anything other than a Natural 20 and still miss the target, you do not score a Critical Hit.", "description": {"value": "When you are using a Rifle, you extend the weapon's critical range by 1 (for example, 19-20 instead of 20). However, anything other than a Natural 20 is not considered an automatic hit; if you roll anything other than a Natural 20 and still miss the target, you do not score a Critical Hit."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "bab", "min": 10}], "_source": "canonical-csv"}, "treeId": "71e99c646b18d85c", "tags": ["feat-chain", "positioning", "precision", "ranged", "soldier", "talent-chain"], "executionModel": "PASSIVE", "subType": "RULE", "abilityMeta": {"rules": [{"type": "EXTEND_CRITICAL_RANGE", "params": {"proficiency": "rifles", "by": 1}, "conditions": []}]}}, "effects": [{"_id": "7902bc6f-c483-4422-bbb0-ce70abe16c5f", "name": "Extended Critical Range (rifles)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.weapons.rifles.critRange", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Extended Critical Range (rifles)", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.extended_critical_range_rifles"}}}
{"_id": "14306c13238ccb83", "name": "Immovable", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can activate this Talent as a Swift Action. Until the start of your next turn, anyone attempting to move you involuntarily (such as with a Bantha Rush or the Move Object Force Power) takes a -5 penalty to attack rolls or Skill Checks made to use that effect that would move you. An enemy can only take the penalty from this Talent once per attempt, regardless of how many targets have used this Talent.", "description": {"value": "You can activate this Talent as a Swift Action. Until the start of your next turn, anyone attempting to move you involuntarily (such as with a Bantha Rush or the Move Object Force Power) takes a -5 penalty to attack rolls or Skill Checks made to use that effect that would move you. An enemy can only take the penalty from this Talent once per attempt, regardless of how many targets have used this Talent."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "10c843cef8ce2798", "tags": ["controller", "force", "force-control", "force-offense", "jedi", "light-side", "mobility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Immovable"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.immovable", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": []}}}
{"_id": "147f70a2b815f34e", "name": "Aggressive Surge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter when you catch a Second Wind, you can make a Charge attack as a Free Action, provided that you can make a charge attack against a legal target at the time you catch a Second Wind.", "description": {"value": "Once per encounter when you catch a Second Wind, you can make a Charge attack as a Free Action, provided that you can make a charge attack against a legal target at the time you catch a Second Wind."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "5a30489609182e8c", "tags": ["mobility", "scout"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Aggressive Surge"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.aggressive_surge", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "148e7a10a55d6ed3", "name": "Soften the Target", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you damage a target with a ranged attack, you may designate one ally within your line of sight as a Swift Action. The ally you designate ignores the target's Damage Reduction and Shield Rating (if any) until the start of your next turn.", "description": {"value": "Whenever you damage a target with a ranged attack, you may designate one ally within your line of sight as a Swift Action. The ally you designate ignores the target's Damage Reduction and Shield Rating (if any) until the start of your next turn."}, "class": "acd10710f000ae70", "costNumeric": null, "category": "Vanguard", "treeId": "ca304c9496f38747", "tags": ["action_economy", "battlefield_control", "category_vanguard", "controller", "cover", "damage_reduction", "defender", "defense", "mobility", "offense_ranged", "positioning", "ranged", "ranged_support", "recon", "shield", "shields", "striker", "support", "swift_action", "targeting", "teamwork"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged"], "enabled": true, "priority": 500, "description": "Soften the Target"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.soften_the_target", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["attack.with-ranged"]}}}
