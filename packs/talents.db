{"_id": "f785208aa6774cd7", "name": "Dark Side Maelstrom", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You create a wound in The Force itself, tearing open space in a vortex of intense Dark Side energy. Use of this Talent expends the Force Storm and Hatred Force Powers from your Force Power Suite. As a Full-Round Action, you may make a DC 25 Use the Force check. If the check succeeds, you create a within your line of sight one square in size that deals 2d8 Force damage to all targets within its affected area. The maelstrom can only be controlled by the creator and is capable of movement up to 6 squares per round. The maelstrom requires a Use the Force check with a Standard Action to maintain from round to round. The DC to maintain the maelstrom increases by one, the damage increases by +1d8 and it expands in size by one square area each round (1-square becomes 2x2 squares, etc.). If at any time a Use the Force check fails, the maelstrom disperses immediately. If the check fails by 10 or more, the maelstrom turns on its creator, dealing damage equal to its current damage die that round. If you take damage while maintaining , you must succeed on a Use the Force check (DC = current round DC + damage taken) to continue maintaining the Talent and prevent it from turning on its creator. Homebrew Reference Book: Dathomir Field Guide", "benefit": "You create a wound in The Force itself, tearing open space in a vortex of intense Dark Side energy. Use of this Talent expends the Force Storm and Hatred Force Powers from your Force Power Suite. As a Full-Round Action, you may make a DC 25 Use the Force check. If the check succeeds, you create a within your line of sight one square in size that deals 2d8 Force damage to all targets within its affected area. The maelstrom can only be controlled by the creator and is capable of movement up to 6 squares per round. The maelstrom requires a Use the Force check with a Standard Action to maintain from round to round. The DC to maintain the maelstrom increases by one, the damage increases by +1d8 and it expands in size by one square area each round (1-square becomes 2x2 squares, etc.). If at any time a Use the Force check fails, the maelstrom disperses immediately. If the check fails by 10 or more, the maelstrom turns on its creator, dealing damage equal to its current damage die that round. If you take damage while maintaining , you must succeed on a Use the Force check (DC = current round DC + damage taken) to continue maintaining the Talent and prevent it from turning on its creator. Homebrew Reference Book: Dathomir Field Guide", "class": "", "category": "", "costNumeric": null, "treeId": "de95d37c72b1c4cd", "tags": ["action_economy", "battlefield_control", "controller", "dark_side", "dark_side_mastery", "force", "force_capacity", "force_control", "force_execution", "force_multiplier", "force_offense", "force_power_synergy", "forecast_value", "mobility", "new_action", "positioning", "standard_action", "striker", "sustained_damage", "tree_de95d37c72b1c4cd", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Dark Side Maelstrom"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": []}}}
