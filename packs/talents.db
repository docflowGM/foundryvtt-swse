{"_id": "bb28cf47a45aff36", "name": "Enemy Tactics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever an enemy within 12 squares of you and in your line of sight receives an insight or morale bonus from any source, you can also gain that bonus, subject to all the same limitations as the bonus provided to that enemy.", "description": {"value": "Whenever an enemy within 12 squares of you and in your line of sight receives an insight or morale bonus from any source, you can also gain that bonus, subject to all the same limitations as the bonus provided to that enemy."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "4dc70f924e7794ac", "tags": ["defender", "melee", "noble", "positioning", "ranged"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Enemy Tactics"}]}}, "effects": [{"_id": "595c1bcc-ae66-4ad5-8c00-c9c6d404eb96", "name": "Enemy Tactics", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Enemy Tactics"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.enemy_tactics", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.426Z", "detectedPredicates": ["defense.reflex", "attack.with-melee", "attack.with-ranged"]}}}
