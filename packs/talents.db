{"_id": "6c62f35fddd45d66", "name": "Distracting Shout", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Cunning Distraction", "benefit": "Once per encounter, as a Reaction to one of your allies being attacked, you can make a Deception check, replacing the Defense Scores of that ally with the result of your Deception check for the resolution of that attack. If any Defense Scores are higher than the Deception check result, your ally can use that Defense Score instead. If the attack still hits, this does not count as the one use per encounter aspect of this Talent.", "description": {"value": "Once per encounter, as a Reaction to one of your allies being attacked, you can make a Deception check, replacing the Defense Scores of that ally with the result of your Deception check for the resolution of that attack. If any Defense Scores are higher than the Deception check result, your ally can use that Defense Score instead. If the attack still hits, this does not count as the one use per encounter aspect of this Talent."}, "class": "8da58194b3d58041", "costNumeric": null, "category": "Charlatan", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.cunning_distraction"}], "_source": "canonical-csv"}, "treeId": "ab9b75bc19f8e983", "tags": ["action_economy", "category_charlatan", "control", "deception", "defender", "feat_chain", "opportunist", "reaction", "skills", "social", "social_control", "stealth", "support", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Distracting Shout"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.distracting_shout", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "6e3c1c77acfb0141", "name": "Improved Jury-Rig", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can use the Jury-Rig application of the Mechanics Skill as a Standard Action instead of as a Full-Round Action. Additionally, you are not required to make a Skill Check to successfully Jury-Rig a device or Vehicle, and the device or Vehicle moves +3 steps on the Condition Track instead of +2.", "description": {"value": "You can use the Jury-Rig application of the Mechanics Skill as a Standard Action instead of as a Full-Round Action. Additionally, you are not required to make a Skill Check to successfully Jury-Rig a device or Vehicle, and the device or Vehicle moves +3 steps on the Condition Track instead of +2."}, "class": "db019dfbb271cdf6", "costNumeric": null, "category": "Improviser", "treeId": "7f37422819d7be6f", "tags": ["action_economy", "category_improviser", "control", "controller", "gear", "jury_rig", "mobility", "new_action", "pilot", "standard_action", "striker", "tech", "utility", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Improved Jury-Rig"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_jury_rig", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
