{"_id": "603e7e5d628a435d", "name": "Make an Example", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Whenever you or an ally within 6 squares of you takes damage that exceeds that character’s Damage Threshold, you and all allies within 6 squares of you gain a +2 bonus to attack rolls and damage rolls until the end of your next turn. Whenever you hit with an attack and deal enough damage to exceed a target’s Damage Threshold, that target takes a -5 penalty to attack rolls against you until the end of your next turn. This is a Mind-Affecting effect. As a Standard Action, you can do or say something that causes an enemy to doubt its motives. Choose one enemy within 12 squares and in your line of sight, and make a Persuasion check against the target’s Will Defense. If you succeed, the target can take only Move Actions and Swift Actions until the end of your next turn. This effect ends if you attack the target. This is a Mind-Affecting effect.", "benefit": "Whenever you or an ally within 6 squares of you takes damage that exceeds that character’s Damage Threshold, you and all allies within 6 squares of you gain a +2 bonus to attack rolls and damage rolls until the end of your next turn. Whenever you hit with an attack and deal enough damage to exceed a target’s Damage Threshold, that target takes a -5 penalty to attack rolls against you until the end of your next turn. This is a Mind-Affecting effect. As a Standard Action, you can do or say something that causes an enemy to doubt its motives. Choose one enemy within 12 squares and in your line of sight, and make a Persuasion check against the target’s Will Defense. If you succeed, the target can take only Move Actions and Swift Actions until the end of your next turn. This effect ends if you attack the target. This is a Mind-Affecting effect.", "class": "", "category": "", "costNumeric": null, "treeId": "e6a9c40b900847bd", "tags": ["action_economy", "controller", "defender", "fear", "leader", "mobility", "new_action", "persuasion", "positioning", "skills", "social", "social_control", "standard_action", "striker", "support", "tree_e6a9c40b900847bd", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "attack.when-hit"], "enabled": true, "priority": 500, "description": "Make an Example"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.414Z", "detectedPredicates": ["defense.will", "attack.when-hit"]}}}
{"_id": "6044037b6eb3ede9", "name": "Sucker Punch", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When your melee attack damages an opponent that is denied its Dexterity bonus to its Reflex Defense, that opponent cannot take Attacks of Opportunity until the end of its next turn.", "description": {"value": "When your melee attack damages an opponent that is denied its Dexterity bonus to its Reflex Defense, that opponent cannot take Attacks of Opportunity until the end of its next turn."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "67fdd8dce9abd6c1", "tags": ["defender", "melee", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Sucker Punch"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sucker_punch", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.414Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "604fde784454445d", "name": "Precision Shot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Base Attack Bonus +10 Once per round, you can spend a single Swift Action to designate a single enemy who is not within Point-Blank Range. When you make a successful ranged attack roll that deals damage against the designated enemy, add your Dexterity bonus (minimum +1) to the damage roll. This effect lasts until the target is unconscious, dead, or leaves your line of sight. You can have only one enemy designated in this manner. Prerequisite: You can keep your target worrying about where the next shot is coming from instead of trying to flee. When you deal damage to an enemy that you have Aimed at, the target's speed is reduced to 2 squares, and the target cannot take either a Double Move Action or use the Run Action until the end of your next turn. This is a Stunning effect.", "benefit": "Base Attack Bonus +10 Once per round, you can spend a single Swift Action to designate a single enemy who is not within Point-Blank Range. When you make a successful ranged attack roll that deals damage against the designated enemy, add your Dexterity bonus (minimum +1) to the damage roll. This effect lasts until the target is unconscious, dead, or leaves your line of sight. You can have only one enemy designated in this manner. Prerequisite: You can keep your target worrying about where the next shot is coming from instead of trying to flee. When you deal damage to an enemy that you have Aimed at, the target's speed is reduced to 2 squares, and the target cannot take either a Double Move Action or use the Run Action until the end of your next turn. This is a Stunning effect.", "class": "", "category": "", "costNumeric": null, "treeId": "d203a51d6d0a4c65", "tags": ["action_economy", "controller", "damage_reduction", "mobility", "move_action", "offense_ranged", "positioning", "precision_damage", "ranged", "sniping", "striker", "sustained_damage", "swift_action", "targeting", "tree_d203a51d6d0a4c65", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 10, "type": "untyped", "predicates": ["attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Precision Shot"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.414Z", "detectedPredicates": ["attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "606e14c428f1d159", "name": "Dark Presence", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Power of the Dark Side Whenever an ally of equal or higher level than you is killed or reduced to 0 hit points within your line of sight, you gain a +2 Force bonus on attack rolls and damage rolls until the end of the encounter. (Since Force bonuses do not stack, you don't get a higher bonus if more than one ally falls in the same encounter.)", "description": "Power of the Dark Side Whenever an ally of equal or higher level than you is killed or reduced to 0 hit points within your line of sight, you gain a +2 Force bonus on attack rolls and damage rolls until the end of the encounter. (Since Force bonuses do not stack, you don't get a higher bonus if more than one ally falls in the same encounter.)", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "cha", "min": 13}, {"type": "talent", "id": "swse.talent.power_of_the_dark_side"}], "_source": "canonical-csv"}, "treeId": "de95d37c72b1c4cd", "tags": ["damage_reduction", "dark_side", "dark_side_mastery", "force", "force_multiplier", "force_offense", "forecast_value", "scaling", "striker", "support", "tree_de95d37c72b1c4cd", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.will", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}]}}, "effects": [{"_id": "b278be01-b200-4515-abdb-7137e70ffebf", "name": "Dark Presence", "icon": "icons/svg/moon.svg", "changes": [{"key": "syste