{"_id": "7aa3eec9b7f748ef", "name": "Escort Pilot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "When a Vehicle that you are Piloting is adjacent to a Vehicle of Colossal size or smaller that is Piloted by an ally, both Vehicles gain a +10 bonus to their Damage Thresholds."}, "benefit": "When a Vehicle that you are Piloting is adjacent to a Vehicle of Colossal size or smaller that is Piloted by an ally, both Vehicles gain a +10 bonus to their Damage Thresholds.", "class": "", "category": "", "costNumeric": null, "treeId": "5f355ad4093d2bf8", "tags": ["action_economy", "ally_support", "escort", "pilot", "positioning", "striker", "support", "sustained_damage", "tree_5f355ad4093d2bf8", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Escort Pilot"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": ["proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "7aa4ca13a96d8770", "name": "Ruthless", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Once per encounter, if you drop a foe to 0 hp or to the bottom of the track, you gain an extra standard action.", "description": "Once per encounter, when you reduce a foe to 0 hit points or the bottom of the track, gain a bonus standard action.", "class": "74fa04f5afb5f6e1", "costNumeric": null, "category": "Assassin", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dirty_fighting"}], "_source": "canonical-csv"}, "treeId": "186daeee7bd65a69", "tags": ["action_economy", "category_assassin", "mobility", "new_action", "precision_damage", "sniping", "standard_action", "stealth", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Ruthless"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ruthless", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "7ab4fcbe5a8b7714", "name": "Shaped Explosion", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Skilled Demolitionist", "benefit": "You know how to set charges to direct a blast in a specific direction or manner. You can shape an explosion caused by Explosives or Mines that you set into a line or a cone instead of a radius. The length of the line is equal to 2 x the radius of the explosive Burst; the length of the cone is equal to 3 x the radius of the Burst, and either the line or the cone originates from the square where the Explosives are placed.", "description": {"value": "You know how to set charges to direct a blast in a specific direction or manner. You can shape an explosion caused by Explosives or Mines that you set into a line or a cone instead of a radius. The length of the line is equal to 2 x the radius of the explosive Burst; the length of the cone is equal to 3 x the radius of the Burst, and either the line or the cone originates from the square where the Explosives are placed."}, "class": "de3f367749b82fcf", "costNumeric": null, "category": "Saboteur", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.skilled_demolitionist"}], "_source": "canonical-csv"}, "treeId": "8897a36d59662ee9", "tags": ["feat-chain", "positioning", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Shaped Explosion"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.shaped_explosion", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": []}}}
{"_id": "7acc479dee2d3b10", "name": "Adept Negotiator", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can weaken the resolve of one opponent with your words. The target must have an Intelligence of 3 or higher, and it must be able to see, hear, and understand you. Make a Persuasion check; if the result equals or exceeds the target's Will Defense, it moves -1 step along the Condition Track. The target gets a +5 bonus to its Will Defense if it is higher level than you.", "description": {"value": "As a Standard Action, you can weaken the resolve of one opponent with your words. The target must have an Intelligence of 3 or higher, and it must be able to see, hear, and understand you. Make a Persuasion check; if the result equals or exceeds the target's Will Defense, it moves -1 step along the Condition Track. The target gets a +5 bonus to its Will Defense if it is higher level than you.\n\nIf the target reaches the end of its Condition Track, it does not fall unconscious, instead, it cannot attack you or your allies for the remainder of the encounter unless you or one of your allies attacks it or one of its allies first. This is a Mind-Affecting effect.\n\nYou affect the Condition Track of the specific character (usually the Vehicle's Commander), not a Starship."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["action-economy", "condition-removal", "controller", "defender", "force", "force-control", "force-defense", "force-offense", "jedi", "leader", "light-side", "lightsaber", "melee", "mobility", "positioning", "scout", "skills", "social", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 5, "type": "untyped", "predicates": ["defense.against-melee", "defense.reflex", "defense.will", "attack.with-melee", "proximity.ally-nearby", "turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Adept Negotiator"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.adept_negotiator", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": ["defense.against-melee", "defense.reflex", "defense.will", "attack.with-melee", "proximity.ally-nearby", "turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "7af4caf439358120", "name": "Telekinetic Prodigy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Telekinetic Savant, Force Training (Move Object selected)", "benefit": "Gain an extra use of the selected power from disarm, slam, thrust, or Move Object.", "description": "Gain an additional telekinetic Force power when you take Move Object.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.telekinetic_savant"}], "_source": "canonical-csv"}, "treeId": "6ac3416fb6aada56", "tags": ["controller", "feat_chain", "force", "force_capacity", "force_control", "force_power_synergy", "mobility", "skill_substitution", "talent_chain", "telekinesis", "telepathy", "tree_6ac3416fb6aada56", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Telekinetic Prodigy"}]}}, "effects": [{"_id": "6c82aec1-65f9-46bf-be33-4d307349eafc", "name": "Telekinetic Prodigy", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.forcePoints.max", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Telekinetic Prodigy"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.telekinetic_prodigy", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
{"_id": "7b23e0812d6a8985", "name": "Skirmisher", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you move at least 2 squares before you attack and end your move in a different square from where you started, you gain a +1 bonus on attack rolls until the start of your next turn. You gain the benefit of this Talent with Weapon Systems only if you are the Vehicle's Pilot.", "description": {"value": "If you move at least 2 squares before you attack and end your move in a different square from where you started, you gain a +1 bonus on attack rolls until the start of your next turn. You gain the benefit of this Talent with Weapon Systems only if you are the Vehicle's Pilot."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "67b59e020c1660eb", "tags": ["controller", "defender", "mobility", "positioning", "precision", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "b27e05f0-9859-46a5-92ab-7f844073dc03", "name": "Skirmisher", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Skirmisher", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.skirmisher"}}}
{"_id": "7b56d0b92582ae88", "name": "Blaster Turret I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, as a Standard Action you can create a Blaster Turret (Size Tiny, Initiative +4, Perception +4, Reflex Defense 10, 10 Hit Points, Damage Threshold 8) that can be mounted to any flat surface. The Turret fires as a standard Blaster Pistol once per round, using your Base Attack Bonus plus your Intelligence bonus and dealing 3d6 points of Energy damage.", "description": {"value": "Once per encounter, as a Standard Action you can create a Blaster Turret (Size Tiny, Initiative +4, Perception +4, Reflex Defense 10, 10 Hit Points, Damage Threshold 8) that can be mounted to any flat surface. The Turret fires as a standard Blaster Pistol once per round, using your Base Attack Bonus plus your Intelligence bonus and dealing 3d6 points of Energy damage.\n\nThe Turret fires at any target you designate (a Free Action, once per round on your turn), though you must remain adjacent to the Turret to control it. The Turret is expended at the end of the encounter."}, "class": "de3f367749b82fcf", "costNumeric": null, "category": "Saboteur", "treeId": "92b30151b9b21109", "tags": ["action-economy", "damage-reduction", "defender", "force", "force-control", "force-defense", "force-offense", "mechanics", "perception", "positioning", "ranged", "scout", "skills", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 8, "type": "untyped", "predicates": ["defense.reflex", "attack.when-hit"], "enabled": true, "priority": 500, "description": "Blaster Turret I"}]}}, "effects": [{"_id": "2e81358f-7a73-4c28-8fe3-5497d8a92b59", "name": "Blaster Turret I", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.actions.turret", "mode": 5, "value": "basic"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Blaster Turret I"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.blaster_turret_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": ["defense.reflex", "attack.when-hit"]}}}
{"_id": "7bc10cb88a6a0c92", "name": "Relentless", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Hunter's Mark, Hunter's Target", "benefit": "This Talent applies only to an opponent you've designated as your Hunter's Target. Any attack or effect originating from the target that would normally move you along the Condition Track does not, in fact, move you along the Condition Track.", "description": {"value": "This Talent applies only to an opponent you've designated as your Hunter's Target. Any attack or effect originating from the target that would normally move you along the Condition Track does not, in fact, move you along the Condition Track."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.hunters_target"}], "_source": "canonical-csv"}, "treeId": "a47ed82a822e3962", "tags": ["condition-removal", "controller", "evasion", "feat-chain", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Relentless"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.relentless", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
{"_id": "7d02251f13fd5645", "name": "Share Force Technique", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "At least 1 Force Technique", "benefit": "When you take this Talent, choose one Force Technique that you know. Once per turn as a Swift Action, you can grant the use of this Force Technique to one ally within 12 squares of you who is Trained in the Use the Force Skill.", "description": {"value": "When you take this Talent, choose one Force Technique that you know. Once per turn as a Swift Action, you can grant the use of this Force Technique to one ally within 12 squares of you who is Trained in the Use the Force Skill.\n\nThe target gains the benefit of this Force Technique until the end of your next turn. You cannot choose the Force Point Recovery Technique for this Talent."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "303d91124d4548c0", "tags": ["feat-chain", "force", "jedi", "leader", "light-side", "positioning", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Share Force Technique"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.share_force_technique", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
{"_id": "7d0259a008e5d68f", "name": "Force Exertion", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Training", "benefit": "Designate one Force power; remove another power to refresh the designated power; you move -1 step down the condition track for 1 minute.", "description": "Designate a Force power to replace another; you move -1 down the condition track for 1 minute.", "costNumeric": null, "treeId": "d3661aa9906bdc79", "tags": ["condition_removal", "controller", "feat_chain", "force", "force_capacity", "force_control", "force_power_synergy", "mobility", "recovery", "resilience", "resource_recovery", "talent_chain", "tree_d3661aa9906bdc79", "uncategorized_talent", "will_defense"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["movement.while-moving"], "enabled": true, "priority": 500, "description": "Force Exertion"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_exertion", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": ["movement.while-moving"]}}}
{"_id": "7d30702a5a2640a4", "name": "Close Contact", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "The Point-Blank Range of any Rifle or Carbine you use is increased by 5 squares. Short Range for the Weapon begins 5 squares later, but still ends at the same distance. You can take this Talent up to two times; each time you take this Talent, you increase the Point-Blank Range of any Rifle or Carbine you use by an additional 5 squares, up to a maximum of 10 squares.", "description": {"value": "The Point-Blank Range of any Rifle or Carbine you use is increased by 5 squares. Short Range for the Weapon begins 5 squares later, but still ends at the same distance. You can take this Talent up to two times; each time you take this Talent, you increase the Point-Blank Range of any Rifle or Carbine you use by an additional 5 squares, up to a maximum of 10 squares."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "1933731cc59f8463", "tags": ["positioning", "ranged"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Close Contact"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.close_contact", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
{"_id": "7d547902b8d9109e", "name": "Penetrating Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Focus with chosen Exotic Weapon or Weapon Group", "benefit": "Choose a single Exotic Weapon or weapon group with which you are proficient. Whenever you make a successful attack against a target with such a weapon, you treat your target's Damage Reduction as if it were 5 points lower when determining the result of your attack. If you select Heavy Weapons as the weapon group this Talent applies to, you may also use the Talent with Vehicle Weapon attacks.", "description": {"value": "Choose a single Exotic Weapon or weapon group with which you are proficient. Whenever you make a successful attack against a target with such a weapon, you treat your target's Damage Reduction as if it were 5 points lower when determining the result of your attack. If you select Heavy Weapons as the weapon group this Talent applies to, you may also use the Talent with Vehicle Weapon attacks.\n\nYou may select this Talent multiple times. Each time you select this Talent, it applies to a different Exotic Weapon or weapon group."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "2f720d8b061f9bd0", "tags": ["feat-chain", "leader", "scaling", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Penetrating Attack"}]}}, "effects": [{"_id": "a0fba2f5-3da6-476e-9ac5-900be2d16e6b", "name": "Penetrating Attack", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.combat.weaponGroupDRReduction", "mode": 2, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Penetrating Attack", "effectType": "dr_reduction", "weaponGroupSpecific": true, "notes": "Weapon group specific - applies when using designated weapon group"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.penetrating_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
{"_id": "7df2e8e4f18dc909", "name": "Battle Analysis", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, you can make a DC 15 Knowledge (Tactics) check. If the check succeeds, you know which allies and opponents in your line of sight are reduced to at least half of their maximum total Hit Points.", "description": {"value": "As a Swift Action, you can make a DC 15 Knowledge (Tactics) check. If the check succeeds, you know which allies and opponents in your line of sight are reduced to at least half of their maximum total Hit Points.\n\nIf you succeed at both a DC 15 Knowledge (Tactics) check and a DC 15 Use Computer check, you may use this Talent to determine what Vehicles are reduced to at least half their maximum Hit Points."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "798ed0945cbdac1c", "tags": ["action-economy", "battlefield-control", "burst-damage", "condition-removal", "controller", "defender", "feat-chain", "force", "force-control", "force-defense", "force-offense", "mechanics", "mobility", "piloting", "positioning", "ranged", "scaling", "shields", "skills", "social", "soldier", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.reflex", "defense.will", "attack.with-ranged", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Battle Analysis"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.battle_analysis", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": ["defense.reflex", "defense.will", "attack.with-ranged", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "7e0b34a95b5f465d", "name": "Begin Attack Run", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charisma 13", "benefit": "As a Swift Action, you designate a single target. When using the Attack Run Action against that target, Vehicles in your squadron gain a +5 bonus on their attack rolls (instead of the normal +2). You may have only one target designated at a time.", "description": {"value": "As a Swift Action, you designate a single target. When using the Attack Run Action against that target, Vehicles in your squadron gain a +5 bonus on their attack rolls (instead of the normal +2). You may have only one target designated at a time."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "cha", "min": 13}], "_source": "canonical-csv"}, "treeId": "dc1b8c5ce2a70394", "tags": ["action-economy", "force", "force-offense", "light-side", "scout", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Begin Attack Run"}]}}, "effects": [{"_id": "92b950a5-f690-488b-83f4-bbcee856516b", "name": "Begin Attack Run", "icon": "icons/svg/sword.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Begin Attack Run"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.begin_attack_run", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.419Z", "detectedPredicates": []}}}
{"_id": "7f47394dfbc94269", "name": "Force Meld", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Prerequisites: Dual Weapon Mastery I, Weapon Proficiency (Lightsabers), Weapon Proficiency (Pistols), Base Attack Bonus +5", "description": "The can only be maintained by expending a Swift Action every round. If this Swift Action cannot be expended (or if you are knocked Unconscious or killed), the is broken and the insight bonus provided by your Battle Meditation is lost. This is a Mind-Affecting effect. Homebrew Reference Book: New Jedi Order Campaign Guide Whenever you make a single attack with a Lightsaber as a Standard Action, you can immediately make an attack with a Pistol as a Free Action, provided you have both weapons in hand when you make the Lightsaber attack. The normal penalties for using two weapons apply to both attacks.", "benefit": "The can only be maintained by expending a Swift Action every round. If this Swift Action cannot be expended (or if you are knocked Unconscious or killed), the is broken and the insight bonus provided by your Battle Meditation is lost. This is a Mind-Affecting effect. Homebrew Reference Book: New Jedi Order Campaign Guide Whenever you make a single attack with a Lightsaber as a Standard Action, you can immediately make an attack with a Pistol as a Free Action, provided you have both weapons in hand when you make the Lightsaber attack. The normal penalties for using two weapons apply to both attacks.", "class": "", "category": "", "costNumeric": null, "treeId": "10c843cef8ce2798", "tags": ["action_economy", "dual_wield", "feat_chain", "force", "force_meld", "force_offense", "light_side", "lightsaber", "melee", "mobility", "new_action", "offense_melee", "ranged", "scout", "skills", "standard_action", "striker", "support", "sustained_damage", "swift_action", "talent_chain", "teamwork", "tree_10c843cef8ce2798", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta"