{"_id": "1505abc8babeeb84", "name": "Sneak Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Any time your opponent is Flat-Footed or otherwise denied its Dexterity bonus to Reflex Defense, you deal an additional 1d6 points of damage with a successful melee or ranged attack. You must be within 6 squares of the target to make a Sneak Attack with a ranged weapon.", "description": {"value": "Any time your opponent is Flat-Footed or otherwise denied its Dexterity bonus to Reflex Defense, you deal an additional 1d6 points of damage with a successful melee or ranged attack. You must be within 6 squares of the target to make a Sneak Attack with a ranged weapon.\n\nYou may select this Talent multiple times. Each time you select it, your Sneak Attack damage increases by +1d6 (Maximum +10d6)."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "67b59e020c1660eb", "tags": ["action-economy", "battlefield-control", "controller", "defender", "melee", "mobility", "positioning", "precision", "ranged", "scaling", "scoundrel", "skills", "social", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "defense.will", "attack.with-melee", "attack.with-ranged", "movement.while-moving", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Sneak Attack"}]}}, "effects": [{"_id": "3195415b-2276-403c-9fb1-5d323d38d31a", "name": "Sneak Attack", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.flatfooted", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Sneak Attack"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sneak_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "defense.will", "attack.with-melee", "attack.with-ranged", "movement.while-moving", "turn.once-per-round"]}}}
{"_id": "153f4b3c6510023d", "name": "Visionary Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Farseeing, WatchCircle Initiate", "benefit": "As a Reaction, you can make a Use the Force check after you or an ally within 12 squares is the target of a melee or ranged attack (but before the results of the attack roll are known), removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had activated the Force Power).", "description": {"value": "As a Reaction, you can make a Use the Force check after you or an ally within 12 squares is the target of a melee or ranged attack (but before the results of the attack roll are known), removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had activated the Force Power).\n\nIf your check result equals or exceeds the Will Defense of the attacker, you grant the target of that attack a +5 Force bonus to their Reflex Defense against that attack.\n\nThis counts as using the Farseeing Force Power against the attacker, but this Talent replaces the normal rules and effects of Farseeing. Any attack can only be affected by this Talent once (thus, multiple characters cannot use this Talent on the same attack to allow multiple rerolls).\n\nYou take a cumulative -5 penalty on Use the Force checks until the beginning of your next turn when you use this Talent."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.watchcircle_initiate"}], "_source": "canonical-csv"}, "treeId": "e99cfa9db8493573", "tags": ["defender", "feat-chain", "force", "force-defense", "force-offense", "jedi", "light-side", "positioning", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 5, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}]}}, "effects": [{"_id": "c5383fb2-2150-4b89-a8a2-c6c4d560b400", "name": "Visionary Defense", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.reflex", "mode": 2, "value": "5"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Visionary Defense", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.visionary_defense"}}}
{"_id": "1584c86ad48d7b81", "name": "Impenetrable Cover", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Maximize Cover", "benefit": "Whenever you have Cover against a target, you gain Damage Reduction equal to your Class Level against that target until the start of your next turn, provided you still have Cover from the target at the time the attack is made.", "description": {"value": "Whenever you have Cover against a target, you gain Damage Reduction equal to your Class Level against that target until the start of your next turn, provided you still have Cover from the target at the time the attack is made."}, "class": "acd10710f000ae70", "costNumeric": null, "category": "Vanguard", "treeId": "ca304c9496f38747", "tags": ["category_vanguard", "cover", "damage_reduction", "defender", "defense", "ranged_support", "recon", "striker", "targeting", "teamwork"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Impenetrable Cover"}]}}, "effects": [{"_id": "ddd1370d-e3e2-4dce-9bc1-2421fa05e8fa", "name": "Impenetrable Cover", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damageReduction", "mode": 5, "value": "class_level"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Impenetrable Cover"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.impenetrable_cover", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": []}}}
{"_id": "1681031c6828d556", "name": "Improved Soft Cover", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Innocuous", "benefit": "While you occupy a square adjacent to another creature, you can use a Swift Action to gain a +2 Cover bonus to your Reflex Defense until the start of your next turn or until you are no longer adjacent to another creature, whichever comes first.", "description": {"value": "While you occupy a square adjacent to another creature, you can use a Swift Action to gain a +2 Cover bonus to your Reflex Defense until the start of your next turn or until you are no longer adjacent to another creature, whichever comes first."}, "class": "8da58194b3d58041", "costNumeric": null, "category": "Charlatan", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.innocuous"}], "_source": "canonical-csv"}, "treeId": "ab9b75bc19f8e983", "tags": ["action_economy", "category_charlatan", "control", "controller", "cover", "deception", "defense", "mobility", "opportunist", "positioning", "social", "social_control", "stealth", "swift_action"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}]}}, "effects": [{"_id": "afa2c945-31b2-43ff-8b78-b63ca8cbd6ef", "name": "Improved Soft Cover", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.reflex", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Improved Soft Cover", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_soft_cover"}}}
