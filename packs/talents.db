{"_id": "3aeee38a6c7b7f12", "name": "Double Up", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Find an Opening, Seize the Moment", "benefit": "Once per encounter, whenever you would use Seize the Moment, you can forgo the extra Swift Action to make an immediate melee or ranged attack against the damaged opponent. If your attack is a ranged attack that hits and deals damage, you treat the damage dealt by you and your ally as though it was one attack for purposes of overcoming Damage Reduction, Shield Rating, and determining whether the damage exceeded the target's Damage Threshold.", "description": {"value": "Once per encounter, whenever you would use Seize the Moment, you can forgo the extra Swift Action to make an immediate melee or ranged attack against the damaged opponent. If your attack is a ranged attack that hits and deals damage, you treat the damage dealt by you and your ally as though it was one attack for purposes of overcoming Damage Reduction, Shield Rating, and determining whether the damage exceeded the target's Damage Threshold."}, "class": "19ee85a788380256", "costNumeric": null, "category": "Outlaw", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.find_an_opening"}], "_source": "canonical-csv"}, "treeId": "3caa80f6bef04200", "tags": ["action_economy", "category_outlaw", "defense", "duelist", "feat_chain", "mobility", "offense_ranged", "opportunist", "positioning", "ranged", "shield", "striker", "support", "survivability", "swift_action", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Double Up"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.double_up", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.408Z", "detectedPredicates": ["attack.when-hit", "attack.with-ranged", "turn.once-per-round"]}}}
