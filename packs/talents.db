{"_id": "c2d2d55ee60f886f", "name": "Lure Closer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trick Step", "benefit": "Once per turn, as a Move Action, you can make a Deception check against the Will Defense of one enemy within 12 squares and within your line of sight. If you check results equals or exceeds the target's Will Defense, the target must move a number of squares equal to half its speed, and each square of movement must bring the target closer to you (though the target does avoid Hazards and obstacles).", "description": {"value": "Once per turn, as a Move Action, you can make a Deception check against the Will Defense of one enemy within 12 squares and within your line of sight. If you check results equals or exceeds the target's Will Defense, the target must move a number of squares equal to half its speed, and each square of movement must bring the target closer to you (though the target does avoid Hazards and obstacles).\n\nIf the target cannot avoid a Hazard (such as a pit), it stops moving in the nearest safe square. This movement is considered involuntary and does not provoke Attacks of Opportunity. This is a Mind-Affecting effect."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.trick_step"}], "_source": "canonical-csv"}, "treeId": "4af97ad058b1b30f", "tags": ["controller", "defender", "evasion", "feat-chain", "mobility", "positioning", "scoundrel", "skills", "social", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Lure Closer"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lure_closer", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": ["defense.will"]}}}
