{"_id": "55b2475e42ce79f2", "name": "Second Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Blast Back", "benefit": "Once per encounter when you miss a target with a single melee or ranged attack, as a Free Action you can move up to half your speed and make a second attack of the same type against a different target. This movement doesn't provoke Attacks of Opportunity.", "description": {"value": "Once per encounter when you miss a target with a single melee or ranged attack, as a Free Action you can move up to half your speed and make a second attack of the same type against a different target. This movement doesn't provoke Attacks of Opportunity.\n\nIf you have the Combat Reflexes feat, you may use this Talent a number of times per encounter equal to your Dexterity bonus (minimum 1). You may still only use this Talent once per round."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.blast_back"}], "_source": "canonical-csv"}, "treeId": "5a30489609182e8c", "tags": ["controller", "feat-chain", "mobility", "scout", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Second Strike"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.second_strike", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["turn.once-per-round"]}}}
