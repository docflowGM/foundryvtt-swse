{"_id": "d4dcafa34cda98c2", "name": "Comrades in Arms", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you damage a target with a melee or ranged attack, all allies within 3 squares gain a +2 bonus on damage rolls against that target until the beginning of your next turn. Prerequisite: You can spend a Move Action to activate this Talent. Until the beginning of your next turn, if an ally Moves you can immediately move up to your speed, provided you end your movement within 3 squares of that ally. If you are adjacent to at least one ally, enemies gain no benefit from Flanking you or any adjacent allies.", "description": {"value": ""}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "eff10782c1e56598", "tags": ["action-economy", "controller", "melee", "mobility", "positioning", "ranged", "soldier", "striker", "support"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "447eb878-1a6a-4172-9058-d7b681f7df83", "name": "Comrades in Arms", "icon": "icons/svg/users.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Comrades in Arms", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.comrades_in_arms"}}}
{"_id": "d4fe49ef1701891e", "name": "Dark Side Master", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dark Side Adept", "benefit": "Force Powers that are strongly tied to the Dark Side flow through you more easily. You can reroll any Use the Force check made when activating Force Powers with the [Dark Side] descriptor, and can spend a Force Point to keep the better of the two results.", "description": {"value": "Force Powers that are strongly tied to the Dark Side flow through you more easily. You can reroll any Use the Force check made when activating Force Powers with the [Dark Side] descriptor, and can spend a Force Point to keep the better of the two results."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dark_side_adept"}], "_source": "canonical-csv"}, "treeId": "d1037bc7a08ea80b", "tags": ["category_sith_apprentice", "controller", "dark_side", "feat_chain", "force", "force_execution", "force_point_spend", "jedi", "resource_spend", "striker", "talent_chain", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Dark Side Master"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_side_master", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": []}}}
{"_id": "d587fb91aedddd09", "name": "Slashing Charge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Block, Riposte, Weapon Focus (Lightsabers)", "benefit": "Once per encounter, while making a Charge, you take no cumulative penalty to Use the Force checks for each Block attempt you make during the Charge. When performing Slashing Charge, you can apply the attack bonus granted by the Charge to all Riposte attacks as well. You can declare the use of this ability after you begin the Charge, but must do so before you make your first Riposte attack.", "description": {"value": "Once per encounter, while making a Charge, you take no cumulative penalty to Use the Force checks for each Block attempt you make during the Charge. When performing Slashing Charge, you can apply the attack bonus granted by the Charge to all Riposte attacks as well. You can declare the use of this ability after you begin the Charge, but must do so before you make your first Riposte attack."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "dfc4142435b4356d", "tags": ["feat-chain", "force", "jedi", "light-side", "lightsaber", "melee", "mobility", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Slashing Charge"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.slashing_charge", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "d61e3a2afe8ab339", "name": "Target Visions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Findsman Ceremonies", "benefit": "You have visions that tell you what your enemies are likely to do even before they do it. Once per encounter, when an enemy creature moves within 6 squares of you, you may make a melee or ranged attack against that target as a Reaction to their movement.", "description": {"value": "You have visions that tell you what your enemies are likely to do even before they do it. Once per encounter, when an enemy creature moves within 6 squares of you, you may make a melee or ranged attack against that target as a Reaction to their movement."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.findsman_ceremonies"}], "_source": "canonical-csv"}, "treeId": "022b31d355c840a9", "tags": ["action-economy", "controller", "feat-chain", "mobility", "positioning", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Target Visions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.target_visions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "d68318a928d3d5c7", "name": "Leading Feint", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Noble Fencing Style", "benefit": "Whenever you successfully damage an opponent with a melee attack, you can make a Deception check to Feint against that target as a Swift Action. If successful, you designate an ally within 12 squares; your target is designated Flat-Footed against the first attack that ally makes against your target before the beginning of your next turn.", "description": {"value": "Whenever you successfully damage an opponent with a melee attack, you can make a Deception check to Feint against that target as a Swift Action. If successful, you designate an ally within 12 squares; your target is designated Flat-Footed against the first attack that ally makes against your target before the beginning of your next turn."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.noble_fencing_style"}], "_source": "canonical-csv"}, "treeId": "9df067790c87e6bc", "tags": ["controller", "feat-chain", "noble", "positioning", "skills", "social", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Leading Feint"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.leading_feint", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": []}}}
{"_id": "d6a04668587e2c03", "name": "Improved Battle Meditation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Battle Meditation", "benefit": "You may activate your Battle Meditation Talent as a Swift Action, instead of as a Full-Round Action. The range of the Battle Meditation extends out to 12 squares. Opponents within the radius of your Battle Meditation suffer a -1 penalty to all attack rolls.", "description": {"value": "You may activate your Battle Meditation Talent as a Swift Action, instead of as a Full-Round Action. The range of the Battle Meditation extends out to 12 squares. Opponents within the radius of your Battle Meditation suffer a -1 penalty to all attack rolls."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.battle_meditation"}], "_source": "canonical-csv"}, "treeId": "10c843cef8ce2798", "tags": ["action-economy", "feat-chain", "force", "force-offense", "jedi", "light-side", "mobility", "positioning", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Improved Battle Meditation"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_battle_meditation", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.429Z", "detectedPredicates": []}}}
{"_id": "d6d3b0a2ec01ca9a", "name": "Speed Implant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Standard Action, you can give one adjacent living creature a Speed Implant. The target must be willing to receive this Implant, which increases the target's base Speed by 2 until the end of the encounter.", "description": {"value": "Once per encounter as a Standard Action, you can give one adjacent living creature a Speed Implant. The target must be willing to receive this Implant, which increases the target's base Speed by 2 until the end of the encounter."}, "class": "557e1a5ec72166fd", "costNumeric": null, "category": "Shaper", "treeId": "d8a71a6c5b2b7581", "tags": ["ability_enhancement", "action_economy", "biotech", "category_shaper", "crafting", "gear", "healing", "implant", "mobility", "new_action", "positioning", "standard_action", "support", "tree_d8a71a6c5b2b7581"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Speed Implant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.speed_implant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "d6e7f7178e643717", "name": "Bolster Ally", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can bolster an ally within line of sight, moving them +1 step along the Condition Track, and giving them a number of Bonus Hit Points equal to their Character Level, if they're at one-half their maximum Hit Points or less. Damage is subtracted from the Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter go away.", "description": {"value": "As a Standard Action, you can bolster an ally within line of sight, moving them +1 step along the Condition Track, and giving them a number of Bonus Hit Points equal to their Character Level, if they're at one-half their maximum Hit Points or less. Damage is subtracted from the Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter go away.\n\nYou can't Bolster the same ally more than once in a single encounter, and you can't Bolster yourself."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "72d32ebcbb607314", "tags": ["action-economy", "condition-removal", "controller", "defender", "force", "force-control", "force-defense", "force-offense", "leader", "melee", "mobility", "noble", "positioning", "ranged", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Bolster Ally"}]}}, "effects": [{"_id": "c5626626-5e0d-4051-b4c2-928434aef891", "name": "Bolster Ally", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.hp.regen", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Bolster Ally"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.bolster_ally", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby", "turn.once-per-round"]}}}
