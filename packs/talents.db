{"_id": "e49c62d72e8b28d3", "name": "Tangle Up", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Uncanny Instincts", "benefit": "As a Standard Action, you can make a non-Area Attack melee or ranged attack against an opponent within Range. If the attack hits, you deal half your normal damage (minimum 1 point), but your opponent loses its next Move Action.", "description": {"value": "As a Standard Action, you can make a non-Area Attack melee or ranged attack against an opponent within Range. If the attack hits, you deal half your normal damage (minimum 1 point), but your opponent loses its next Move Action."}, "class": "19ee85a788380256", "costNumeric": null, "category": "Outlaw", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.uncanny_instincts"}], "_source": "canonical-csv"}, "treeId": "3caa80f6bef04200", "tags": ["ambush", "category_outlaw", "duelist", "mobility", "move_action", "new_action", "offense_ranged", "opportunist", "positioning", "scoundrel", "standard_action", "striker", "survivability"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Tangle Up"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.tangle_up", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e53cad01df3f27dd", "name": "Tech Savant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Knowledge (Technology)", "benefit": "As a Standard Action, you can increase the speed of one adjacent Droid or Vehicle that you occupy by 1 square (applied to any method of Locomotion) until the end of your next turn. Any Droid or Vehicle can only benefit from this Talent once per round.", "description": {"value": "As a Standard Action, you can increase the speed of one adjacent Droid or Vehicle that you occupy by 1 square (applied to any method of Locomotion) until the end of your next turn. Any Droid or Vehicle can only benefit from this Talent once per round."}, "class": "b85240cf77cf95eb", "costNumeric": null, "category": "Military Engineer", "treeId": "e32009b1b0aee8c9", "tags": ["mobility", "positioning", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Tech Savant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.tech_savant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "e54ecc0ff06e61f3", "name": "Lightsaber Throw", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can throw a Lightsaber as a Standard Action, treating it as a Thrown weapon (without this Talent, a thrown Lightsaber is considered an Improvised Thrown Weapon). You are considered proficient with the thrown Lightsaber, and you apply the normal Range penalties to the attack roll. The thrown Lightsaber deals normal weapon damage if it hits.", "description": {"value": "You can throw a Lightsaber as a Standard Action, treating it as a Thrown weapon (without this Talent, a thrown Lightsaber is considered an Improvised Thrown Weapon). You are considered proficient with the thrown Lightsaber, and you apply the normal Range penalties to the attack roll. The thrown Lightsaber deals normal weapon damage if it hits.\n\nIf your target is no more than 6 squares away, you can pull your Lightsaber back to your hand as a Swift Action by making a DC 20 Use the Force check."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "b3c5d90b5036f39b", "tags": ["action-economy", "battlefield-control", "controller", "defender", "force", "force-control", "force-defense", "force-offense", "jedi", "lightsaber", "melee", "mobility", "positioning", "ranged", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Lightsaber Throw"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lightsaber_throw", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.reflex", "attack.with-ranged"]}}}
{"_id": "e58a8ad63c1d8771", "name": "Connections", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You are able to obtain Licensed, Restricted, Military, or Illegal equipment without having to pay a licensing fee or endure a background check, provided the total cost of the desired Equipment is equal to or less than your Character Level x 1,000 credits.", "description": {"value": "You are able to obtain Licensed, Restricted, Military, or Illegal equipment without having to pay a licensing fee or endure a background check, provided the total cost of the desired Equipment is equal to or less than your Character Level x 1,000 credits."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "b5bb4154688c66ab", "tags": ["force", "noble", "skills", "social", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Connections"}]}}, "effects": [{"_id": "6708f25b-1035-4044-99fb-a15527d65e5c", "name": "Connections", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.economy.blackMarketMultiplier", "mode": 2, "value": "-1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Connections", "effectType": "economy_bonus", "economy": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.connections", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "e5ac014e044a4afa", "name": "Droid Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "As a Standard Action, you can transmit tactical information to all Droid allies that can hear and understand you, granting them a bonus equal to your Intelligence modifier to one of their Defenses (your choice) until the beginning of your next turn."}, "benefit": "As a Standard Action, you can transmit tactical information to all Droid allies that can hear and understand you, granting them a bonus equal to your Intelligence modifier to one of their Defenses (your choice) until the beginning of your next turn.", "class": "", "category": "", "costNumeric": null, "treeId": "9688ed3500084dca", "tags": ["action_economy", "controller", "defender", "defense", "droid", "durability", "leader", "mobility", "new_action", "scout", "sensors", "skills", "standard_action", "striker", "support", "tree_9688ed3500084dca", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Droid Defense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "e5bef6ccacb51788", "name": "Collective Visions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Farseeing", "benefit": "When you use Farseeing, or a Force Power or Talent that has Farseeing as a prerequisite, other Force-users with Farseeing in their Force Power Suite can Aid Another on your Use the Force check as a Reaction, if they are within 6 squares of you.", "description": {"value": "When you use Farseeing, or a Force Power or Talent that has Farseeing as a prerequisite, other Force-users with Farseeing in their Force Power Suite can Aid Another on your Use the Force check as a Reaction, if they are within 6 squares of you."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["action-economy", "force", "jedi", "light-side", "positioning"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Collective Visions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.collective_visions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e6055a514a784387", "name": "Akk Dog Master", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": ", Commanding Officer, Inspire Loyalty, or Reconnaissance Team Leader Your Followers gain an additional Feat, which they must meet the prerequisites for, and another Feat every 3rd level (as per a normal character). Additionally, your Followers now benefit from changes to their Ability Scores and bonus Feats from their Species; if your Follower's Species does not change their Ability Scores, you can raise a single one of their Abilities from a 10 to a 12. Prerequisite: , Commanding Officer, Inspire Loyalty, or Reconnaissance Team Leader When commanding your Followers, the type they gain is increased by one step (a Swift Action allows a Move Action, a Move Action allows a Standard Action, and a Standard Action allows a Full-Round Action). Additionally, your Followers gain Hit Points equal to their Constitution modifier times your Heroic Level. Prerequisite: , Commanding Officer, Inspire Loyalty, or Reconnaissance Team Leader A number of times per encounter equal to your Charisma modifier (minimum 1), your Followers gain a Swift Action that can be used as normal. Additionally, your Followers gain a number of Trained Skills equal to their Intelligence score, and may take regular Actions instead of Follower Actions (you still must spend the equivalent Action for your Followers).", "benefit": ", Commanding Officer, Inspire Loyalty, or Reconnaissance Team Leader Your Followers gain an additional Feat, which they must meet the prerequisites for, and another Feat every 3rd level (as per a normal character). Additionally, your Followers now benefit from changes to their Ability Scores and bonus Feats from their Species; if your Follower's Species does not change their Ability Scores, you can raise a single one of their Abilities from a 10 to a 12. Prerequisite: , Commanding Officer, Inspire Loyalty, or Reconnaissance Team Leader When commanding your Followers, the type they gain is increased by one step (a Swift Action allows a Move Action, a Move Action allows a Standard Action, and a Standard Action allows a Full-Round Action). Additionally, your Followers gain Hit Points equal to their Constitution modifier times your Heroic Level. Prerequisite: , Commanding Officer, Inspire Loyalty, or Reconnaissance Team Leader A number of times per encounter equal to your Charisma modifier (minimum 1), your Followers gain a Swift Action that can be used as normal. Additionally, your Followers gain a number of Trained Skills equal to their Intelligence score, and may take regular Actions instead of Follower Actions (you still must spend the equivalent Action for your Followers).", "class": "", "category": "", "costNumeric": null, "treeId": "37f3554a2f30425a", "tags": ["action_economy", "beast_companion", "controller", "leader", "mobility", "mount", "move_action", "new_action", "standard_action", "striker", "support", "survival", "sustained_damage", "swift_action", "tree_37f3554a2f30425a", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Akk Dog Master"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "e6c4f05db6ac6c06", "name": "Master Advisor", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Skilled Advisor", "benefit": "When you use the Skilled Advisor Talent, the ally you aid gains one temporary Force Point at the end of their next turn. If the Force Point is not spent before the end of the encounter, it is lost.", "description": {"value": "When you use the Skilled Advisor Talent, the ally you aid gains one temporary Force Point at the end of their next turn. If the Force Point is not spent before the end of the encounter, it is lost."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "152047d6ab7896ad", "tags": ["feat-chain", "force", "jedi", "light-side", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Master Advisor"}]}}, "effects": [{"_id": "3b1dc7d4-e0aa-4b90-9669-119be1aca6b0", "name": "Master Advisor", "icon": "icons/svg/item-bag.svg", "changes": [], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Master Advisor", "effectType": "skill_success_grant", "requiresSkillSuccessHook": true, "skillName": "Skilled Advisor"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.master_advisor", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e6d56fb82c669b9d", "name": "Fluster", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Presence, Trained in Persuasion", "benefit": "You get under an opponent's skin. Once per encounter, make a Persuasion check to Intimidate one creature within line of sight as a Standard Action. On a success, instead of the normal effect of an Intimidate application of the Persuasion skill, the affected creature can take only a single Swift Action on its next turn. If the target is a higher level than you, it gains a +5 bonus to its Will Defense against the Intimidate check. This is a Mind-Affecting effect.", "description": {"value": "You get under an opponent's skin. Once per encounter, make a Persuasion check to Intimidate one creature within line of sight as a Standard Action. On a success, instead of the normal effect of an Intimidate application of the Persuasion skill, the affected creature can take only a single Swift Action on its next turn. If the target is a higher level than you, it gains a +5 bonus to its Will Defense against the Intimidate check. This is a Mind-Affecting effect."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.presence"}], "_source": "canonical-csv"}, "treeId": "8375b9b26b679901", "tags": ["action-economy", "defender", "feat-chain", "mobility", "noble", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 5, "type": "untyped", "predicates": ["defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Fluster"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fluster", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.will", "turn.once-per-round"]}}}
{"_id": "e797ad357746be9f", "name": "Guiding Strikes", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you deal damage to a target by making a Lightsaber attack on your turn, you can use a Swift Action before the end of your turn to activate this Talent. If you do so, allies adjacent to the target at the time you make the attack gain a +2 circumstance bonus to melee attack rolls against the target until the start of your next turn.", "description": {"value": "When you deal damage to a target by making a Lightsaber attack on your turn, you can use a Swift Action before the end of your turn to activate this Talent. If you do so, allies adjacent to the target at the time you make the attack gain a +2 circumstance bonus to melee attack rolls against the target until the start of your next turn."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["force", "force-offense", "jedi", "light-side", "melee", "positioning", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Guiding Strikes"}]}}, "effects": [{"_id": "44b16081-86c2-4966-9081-fb4145aa1dfe", "name": "Guiding Strikes", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Guiding Strikes"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.guiding_strikes", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "e835b21a01ae2ee7", "name": "Ambush Specialist", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you are not Surprised on the first round of combat in an encounter, you can treat the first round of combat as if it were the Surprise Round for the purposes of Talents and Feats that trigger only during the Surprise Round.", "description": {"value": "If you are not Surprised on the first round of combat in an encounter, you can treat the first round of combat as if it were the Surprise Round for the purposes of Talents and Feats that trigger only during the Surprise Round.\n\nAdditionally, during the Surprise Round as a Free Action you can designate a target as your Prime Target. You gain a +2 morale bonus to attack rolls against your Prime Target until the end of the encounter."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "12027e0ad5e4d260", "tags": ["action-economy", "ambush", "controller", "damage-reduction", "mobility", "perception", "scout", "skills", "soldier", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "55971dae-5cdf-40b0-823d-79482f07dbde", "name": "Ambush Specialist", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Ambush Specialist", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ambush_specialist"}}}
{"_id": "e857b1e13073b0a9", "name": "Safe Passage", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Escort Fighter", "benefit": "Once per turn, you can spend a Move Action to allow one ally within line of sight to move up to its speed as a Reaction. If a target makes an Attack of Opportunity against the ally during its movement, you can make an Attack of Opportunity against that target.", "description": {"value": "Once per turn, you can spend a Move Action to allow one ally within line of sight to move up to its speed as a Reaction. If a target makes an Attack of Opportunity against the ally during its movement, you can make an Attack of Opportunity against that target."}, "class": "4ee81a6708a516cd", "costNumeric": null, "category": "Pathfinder", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.escort_fighter"}], "_source": "canonical-csv"}, "treeId": "383ff8d392488cf8", "tags": ["action_economy", "category_pathfinder", "controller", "cover", "mobility", "move_action", "positioning", "reaction", "recon", "support", "survival"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Safe Passage"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.safe_passage", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e885f64758f5e2bd", "name": "Dark Side Sense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Jedi following the path of the Sentinel become exceptionally talented at rooting out evil. You may reroll any Use the Force check made to sense the presence and relative location of characters with a Dark Side Score of 1 or higher. You must take the result of the reroll, even if it is worse.", "description": {"value": "Jedi following the path of the Sentinel become exceptionally talented at rooting out evil. You may reroll any Use the Force check made to sense the presence and relative location of characters with a Dark Side Score of 1 or higher. You must take the result of the reroll, even if it is worse."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "36f18f3e974feb33", "tags": ["action-economy", "damage-reduction", "dark-side", "defender", "force", "force-defense", "force-offense", "jedi", "light-side", "lightsaber", "melee", "mobility", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 1, "type": "untyped", "predicates": ["defense.will", "attack.when-hit", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Dark Side Sense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_side_sense", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.will", "attack.when-hit", "attack.with-melee"]}}}
{"_id": "e8922370838f2965", "name": "Idealist", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charisma 13", "benefit": "Your confidence empowers you, giving you the ability to withstand the harmful influence of others. You can add your Charisma modifier in place of your Wisdom modifier to your Will Defense.", "description": {"value": "Your confidence empowers you, giving you the ability to withstand the harmful influence of others. You can add your Charisma modifier in place of your Wisdom modifier to your Will Defense."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "cha", "min": 13}], "_source": "canonical-csv"}, "treeId": "d65a4816379802ee", "tags": ["defender", "feat-chain", "noble", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Idealist"}]}}, "effects": [{"_id": "1f570592-aa99-435a-8d6a-2ba34e9e6605", "name": "Idealist", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.abilities.charisma.application", "mode": 5, "value": "will_defense"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Idealist"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.idealist", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "e8bf1222fd6289e4", "name": "Lightsaber Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action you can use your Lightsaber to parry your opponents' attacks, gaining a +1 deflection bonus to your Reflex Defense until the start of your next turn. You must have a Lightsaber drawn and ignited to use this Talent, and you don't gain the deflection bonus if you are Flat-Footed or otherwise unaware of the incoming attack.", "description": {"value": "As a Swift Action you can use your Lightsaber to parry your opponents' attacks, gaining a +1 deflection bonus to your Reflex Defense until the start of your next turn. You must have a Lightsaber drawn and ignited to use this Talent, and you don't gain the deflection bonus if you are Flat-Footed or otherwise unaware of the incoming attack.\n\nYou can take this Talent multiple times; each time you take this Talent, the deflection bonus increases by +1 (maximum +3)."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "2bc2572e852832e4", "tags": ["defender", "jedi", "lightsaber", "melee", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex.misc"}]}}, "effects": [{"_id": "fcdbf882-923a-4095-b0df-a1079c214099", "name": "Lightsaber Defense", "icon": "icons/svg/shield.svg", "changes": [{"key": "system.defenses.reflex.misc", "mode": 2, "value": "1", "priority": 20}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Lightsaber Defense", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lightsaber_defense"}}}
{"_id": "e8fe6087eef386c7", "name": "Findsman's Foresight", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Findsman Ceremonies", "benefit": "The visions you receive sometimes provide clues about dangerous situations. Whenever you make a Perception check to avoid Surprise, you may roll twice, keeping the better of the two results.", "description": {"value": "The visions you receive sometimes provide clues about dangerous situations. Whenever you make a Perception check to avoid Surprise, you may roll twice, keeping the better of the two results."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.findsman_ceremonies"}], "_source": "canonical-csv"}, "treeId": "022b31d355c840a9", "tags": ["ambush", "evasion", "feat-chain", "perception", "scoundrel", "skills", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Findsman's Foresight"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.findsmans_foresight", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e9541e13afbb4a41", "name": "Steady Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You are always considered to be engaged in melee combat for the purposes of ranged attacks made against you, inflicting a -5 penalty to such attacks without the Precise Shot feat. As a Reaction to a failed melee attack made against you while Fighting Defensively, you can move a single square in any direction. This movement does not provoke Attacks of Opportunity. A number of times per encounter equal to your Dexterity modifier (minimum 1), you can make a single melee attack as a Free Action when Fighting Defensively. You cannot make an attack in this way more than once per round.", "benefit": "You are always considered to be engaged in melee combat for the purposes of ranged attacks made against you, inflicting a -5 penalty to such attacks without the Precise Shot feat. As a Reaction to a failed melee attack made against you while Fighting Defensively, you can move a single square in any direction. This movement does not provoke Attacks of Opportunity. A number of times per encounter equal to your Dexterity modifier (minimum 1), you can make a single melee attack as a Free Action when Fighting Defensively. You cannot make an attack in this way more than once per round.", "class": "", "category": "", "costNumeric": null, "treeId": "fc978e442f544dbe", "tags": ["action_economy", "controller", "defense", "melee", "mobility", "offense_melee", "positioning", "precision", "ranged", "reaction", "steady", "sustained_damage", "tree_fc978e442f544dbe", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Steady Strike"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "e96812723ff4eb04", "name": "Dark Side Talisman", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can spend a Force Point to imbue a Weapon or some other portable object with the Dark Side of The Force, creating a Talisman that grants you protection from the Light Side. Creating the Dark Side Talisman takes a Full-Round Action.", "description": {"value": "You can spend a Force Point to imbue a Weapon or some other portable object with the Dark Side of The Force, creating a Talisman that grants you protection from the Light Side. Creating the Dark Side Talisman takes a Full-Round Action.\n\nWhile you wear or carry the Talisman, you gain a +2 Force bonus to one of your Defenses (Reflex, Fortitude, or Will) against Force Powers with the [Light Side] descriptor.\n\nYou can only have one Dark Side Talisman active at a given time (though you can have both a Dark Side Talisman and a Force Talisman active at the same time), and if your Dark Side Talisman is destroyed, you cannot create another one for 24 hours."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "96ef43a3054dcb58", "tags": ["action_economy", "category_force_adept", "controller", "dark_side", "defender", "force", "force_capacity", "force_defense", "force_execution", "force_point_spend", "force_training", "leader", "light_side", "mystic", "resource_spend", "striker", "sustained_damage", "tree_96ef43a3054dcb58"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.fortitude"}]}}, "effects": [{"_id": "fc12743e-ed4d-44f9-8416-052a537168b5", "name": "Dark Side Talisman", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.fortitude", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Dark Side Talisman", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_side_talisman"}}}
{"_id": "e97177f243cb2b0a", "name": "Seize Object", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Move Action, you can attempt to seize a held, carried, or worn object from an adjacent target by making a Disarm attack, with a +10 bonus on your attack roll.", "description": {"value": "Once per encounter as a Move Action, you can attempt to seize a held, carried, or worn object from an adjacent target by making a Disarm attack, with a +10 bonus on your attack roll.\n\nIf the attack succeeds, you are now holding the object, and you cannot use this Talent in place of the Disarm Action. You cannot conceal the use of this Talent from the target."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "67b59e020c1660eb", "tags": ["positioning", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 10, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Seize Object"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.seize_object", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "e97df0daa156338c", "name": "Mandalorian Advance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Veteran Mandalorians know how to move on the battlefield. Once per encounter, on your turn, you can Move up to your Speed as a Free Action before any other Action.", "description": {"value": "Veteran Mandalorians know how to move on the battlefield. Once per encounter, on your turn, you can Move up to your Speed as a Free Action before any other Action."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "4b8857716e056f62", "tags": ["action-economy", "controller", "mobility", "soldier"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Mandalorian Advance"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.mandalorian_advance", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "e9820b341bf94de1", "name": "Greater Weapon Specialization", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Greater Weapon Focus (Chosen Weapon), Weapon Specialization (Chosen Weapon)", "benefit": "Choose one Exotic Weapon or one of the following weapon groups: Advanced Melee Weapons, Heavy Weapons, Pistols, Rifles, or Simple Weapons. You gain a +2 bonus on damage rolls with the chosen Exotic Weapon or a weapon from the chosen group. This bonus stacks with the bonus granted by the Weapon Specialization Talent.", "description": {"value": "Choose one Exotic Weapon or one of the following weapon groups: Advanced Melee Weapons, Heavy Weapons, Pistols, Rifles, or Simple Weapons. You gain a +2 bonus on damage rolls with the chosen Exotic Weapon or a weapon from the chosen group. This bonus stacks with the bonus granted by the Weapon Specialization Talent.\n\nYou may select this Talent multiple times. Each time you select this Talent, it applies to a different Exotic Weapon or weapon group."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.weapon_specialization"}], "_source": "canonical-csv"}, "treeId": "2f720d8b061f9bd0", "tags": ["feat-chain", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Greater Weapon Specialization"}]}}, "effects": [{"_id": "771be58e-c672-412d-af10-303bcd8b76b4", "name": "Greater Weapon Specialization", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.melee", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Greater Weapon Specialization"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.greater_weapon_specialization", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e9aec3a7b011e17a", "name": "Melee Assault", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you make a melee attack against a target that has one or more of your allies adjacent to it, compare the result to the target's Fortitude Defense as well as its Reflex Defense. If the attack hits both Defenses, the attack deals +1 die of damage and the target is knocked Prone.", "description": {"value": "When you make a melee attack against a target that has one or more of your allies adjacent to it, compare the result to the target's Fortitude Defense as well as its Reflex Defense. If the attack hits both Defenses, the attack deals +1 die of damage and the target is knocked Prone."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "7bcd1d892f2e9ae7", "tags": ["controller", "defender", "melee", "positioning", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 1, "type": "untyped", "predicates": ["defense.fortitude", "attack.with-melee", "target.is-prone"], "enabled": true, "priority": 500, "description": "Melee Assault"}]}}, "effects": [{"_id": "d0010736-132c-4f0d-a237-ec68d1de1d01", "name": "Melee Assault", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.melee", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Melee Assault"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.melee_assault", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.fortitude", "attack.with-melee", "target.is-prone"]}}}
{"_id": "ea6ee6fad799491e", "name": "Jedi Healer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Knowledge (Life Sciences)", "description": "You may reroll any Treat Injury check, but the result of the reroll must be accepted, even if it is worse. In addition, you can use the First Aid, Treat Disease, Treat Poison, and Treat Radiation applications without the requisite Medical Kit or Medpac. Homebrew Reference Book: Legacy of the Force Sourcebook You are Trained in the Treat Injury skill. Additionally, patients under your care move +1 step along the Condition Track as a result of a successful Treat Injury check or activation of the Vital Transfer Force Power.", "benefit": "You may reroll any Treat Injury check, but the result of the reroll must be accepted, even if it is worse. In addition, you can use the First Aid, Treat Disease, Treat Poison, and Treat Radiation applications without the requisite Medical Kit or Medpac. Homebrew Reference Book: Legacy of the Force Sourcebook You are Trained in the Treat Injury skill. Additionally, patients under your care move +1 step along the Condition Track as a result of a successful Treat Injury check or activation of the Vital Transfer Force Power.", "class": "", "category": "", "costNumeric": null, "treeId": "e99cfa9db8493573", "tags": ["condition_removal", "controller", "feat_chain", "force", "force_capacity", "force_control", "force_power_synergy", "force_support", "healing", "investigation", "jedi_healer", "knowledge", "light_side", "medicine", "mobility", "poison", "skills", "striker", "support", "talent_chain", "tree_e99cfa9db8493573", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Jedi Healer"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "ea9a4f110f5d2d8d", "name": "Assault Gambit", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per turn, as a Standard Action, you can designate one ally and one enemy that have line of effect to each other. The ally and the enemy make opposed Initiative checks, and the winner can make a single immediate melee or ranged attack against the loser. No character can benefit from this Talent more than once per round.", "description": {"value": "Once per turn, as a Standard Action, you can designate one ally and one enemy that have line of effect to each other. The ally and the enemy make opposed Initiative checks, and the winner can make a single immediate melee or ranged attack against the loser. No character can benefit from this Talent more than once per round."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "b7a1211d08826500", "tags": ["action-economy", "defender", "leader", "mobility", "noble", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.reflex", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Assault Gambit"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.assault_gambit", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.reflex", "turn.once-per-round"]}}}
{"_id": "eafb1ee6cacedd20", "name": "Second Skin", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Armored Defense", "benefit": "When wearing Armor with which you are proficient, your Armor bonus to your Reflex Defense and Equipment bonus to your Fortitude Defense each increases by +1.", "description": {"value": "When wearing Armor with which you are proficient, your Armor bonus to your Reflex Defense and Equipment bonus to your Fortitude Defense each increases by +1."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.armored_defense"}], "_source": "canonical-csv"}, "treeId": "17cec542331cb4e4", "tags": ["armor", "defender", "feat-chain", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.reflex", "defense.fortitude"], "enabled": true, "priority": 500, "description": "Second Skin"}]}}, "effects": [{"_id": "4337c4f7-1771-4d6f-8cbc-bcff16813e10", "name": "Second Skin", "icon": "icons/svg/armor.svg", "changes": [{"key": "system.armor.maxDex", "mode": 2, "value": "1", "priority": 20}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Second Skin"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.second_skin", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": ["defense.reflex", "defense.fortitude"]}}}
{"_id": "eb4f3e8660bc476589d0323d4cc00845", "name": "Sith Alchemy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can use your mastery of to create mutated abominations. You must have access to a willing (or unconscious) creature to which you will apply the Sith Abomination Template or the Chrysalis Beast Template. You also need a medical lab outfitted for the process, which requires a number of days equal to creature's modified CL. You must spend a Force Point at the completion of the process to complete the transformation. A creature you have mutated is considered to be a domesticated creature, but for you only (unless it was already a domesticated creature before its mutation). As a Standard Action, you can perform minor alchemical alterations to a Melee Weapon you wield. For the remainder of the encounter, you gain a +2 Equipment bonus on attack rolls with that Weapon. Additionally, once before the end of the encounter, you can sacrifice this bonus as a Free Action to gain a +5 Equipment bonus on a single damage roll you make with that Weapon. Your knowledge of allows you to imbue certain objects with the power of the Dark Side. You can perform any of the following Alchemical Transformations, though each time you do so, increase your Dark Side Score by 1. Prerequisite: You can modify an object with Sith Alchemy so that it gains a specific trait. Specific traits are listed in the Sith Alchemy Table, below. You can only perform one modification at a time. Unless otherwise noted, you cannot grant more than one benefit to a single object, and you cannot apply the same benefit more than once. You must spend a Force Point and devote 1 hour of uninterrupted work to apply a trait to the relevant object, and when you do so, you increase your Dark Side Score by 1.", "description": "You can use your mastery of to create mutated abominations. You must have access to a willing (or unconscious) creature to which you will apply the Sith Abomination Template or the Chrysalis Beast Template. You also need a medical lab outfitted for the process, which requires a number of days equal to creature's modified CL. You must spend a Force Point at the completion of the process to complete the transformation. A creature you have mutated is considered to be a domesticated creature, but for you only (unless it was already a domesticated creature before its mutation). As a Standard Action, you can perform minor alchemical alterations to a Melee Weapon you wield. For the remainder of the encounter, you gain a +2 Equipment bonus on attack rolls with that Weapon. Additionally, once before the end of the encounter, you can sacrifice this bonus as a Free Action to gain a +5 Equipment bonus on a single damage roll you make with that Weapon. Your knowledge of allows you to imbue certain objects with the power of the Dark Side. You can perform any of the following Alchemical Transformations, though each time you do so, increase your Dark Side Score by 1. Prerequisite: You can modify an object with Sith Alchemy so that it gains a specific trait. Specific traits are listed in the Sith Alchemy Table, below. You can only perform one modification at a time. Unless otherwise noted, you cannot grant more than one benefit to a single object, and you cannot apply the same benefit more than once. You must spend a Force Point and devote 1 hour of uninterrupted work to apply a trait to the relevant object, and when you do so, you increase your Dark Side Score by 1.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dark_side_master"}], "_source": "canonical-csv"}, "treeId": "a67faf2ae089ab5d", "tags": ["action_economy", "beast_companion", "crafting", "dark_side", "force", "force_offense", "force_point_spend", "force_support", "healing", "investigation", "knowledge", "leader", "melee", "new_action", "resource_spend", "sith_alchemy", "standard_action", "striker", "support", "tree_a67faf2ae089ab5d", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Sith Alchemy"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sith_alchemy", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "eb503c1c3fb945a6", "name": "Power Boost", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Power Surge", "description": {"value": "You channel your Power Surge into a boost for your Locomotion System. When you initiate a Power Surge, you can use one of the following bonuses with your installed Locomotion System:"}, "benefit": "You channel your Power Surge into a boost for your Locomotion System. When you initiate a Power Surge, you can use one of the following bonuses with your installed Locomotion System:", "class": "", "category": "", "costNumeric": null, "treeId": "cec49bc60d1646b1", "tags": ["condition_removal", "controller", "droid", "mechanics", "mobility", "power_systems", "skills", "sustained_damage", "tech", "tree_cec49bc60d1646b1", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["movement.while-moving"], "enabled": true, "priority": 500, "description": "Power Boost"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["movement.while-moving"]}}}
{"_id": "eb701499ba157c6a", "name": "Mobile Attack (lightsabers)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Multiattack Proficiency (Lightsabers), Dual Weapon Mastery I, Weapon Focus (Lightsabers)", "benefit": "Immediately after making a Full Attack where you attacked with two Lightsabers (or both ends of a Double-Bladed Lightsaber), you may Move up to your Speed as a Free Action.", "description": {"value": "Immediately after making a Full Attack where you attacked with two Lightsabers (or both ends of a Double-Bladed Lightsaber), you may Move up to your Speed as a Free Action."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "dfc4142435b4356d", "tags": ["action-economy", "controller", "feat-chain", "force", "force-control", "force-offense", "jedi", "light-side", "lightsaber", "melee", "mobility", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Mobile Attack (lightsabers)"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.mobile_attack_lightsabers", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": []}}}
{"_id": "ebc1d6e79fa543c9", "name": "Steady Hands", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Treat Injury", "description": "After successfully performing the Revivify application of the Treat Injury skill, the target of your Revivify gains a number of Bonus Hit Points equal to 5 + your Character Level. These Bonus Hit Points last until the end of the encounter (at which point any remaining Bonus Hit Points are lost), and any damage dealt to that target comes out of Bonus Hit Points first. When using the Aid Another Action to aid a character with their Treat Injury check, you grant an additional +2 bonus for every 5 points by which you exceed the DC to assist. You can attempt the First Aid application of the Treat Injury skill without the use of a Medpac. However, doing so imposes a -5 penalty to the check. Choose a single method of medical treatment (Treat Disease, Treat Poison, or Treat Radiation). You may choose to reroll any Treat Injury check to perform that application, keeping the better of the two results. You may select this Talent multiple times. Each time you select this Talent, it applies to a different method of medical treatment. Prerequisite: When performing the First Aid or Heal Damage applications of the Treat Injury skill, you may choose to reroll any Treat Injury check to perform that application, but the result of the reroll must be accepted, even if it is worse. Once per encounter as a Free Action, you reduce the Treat Injury DC for all applications of the skill by your Intelligence modifier (minimum 1) until the start of your next turn. Additionally, when performing the Critical Care application of the Treat Injury skill, you take a -3 penalty to subsequent attempts at Critical Care in the last 24 hours, instead of the normal -5 penalty.", "benefit": "After successfully performing the Revivify application of the Treat Injury skill, the target of your Revivify gains a number of Bonus Hit Points equal to 5 + your Character Level. These Bonus Hit Points last until the end of the encounter (at which point any remaining Bonus Hit Points are lost), and any damage dealt to that target comes out of Bonus Hit Points first. When using the Aid Another Action to aid a character with their Treat Injury check, you grant an additional +2 bonus for every 5 points by which you exceed the DC to assist. You can attempt the First Aid application of the Treat Injury skill without the use of a Medpac. However, doing so imposes a -5 penalty to the check. Choose a single method of medical treatment (Treat Disease, Treat Poison, or Treat Radiation). You may choose to reroll any Treat Injury check to perform that application, keeping the better of the two results. You may select this Talent multiple times. Each time you select this Talent, it applies to a different method of medical treatment. Prerequisite: When performing the First Aid or Heal Damage applications of the Treat Injury skill, you may choose to reroll any Treat Injury check to perform that application, but the result of the reroll must be accepted, even if it is worse. Once per encounter as a Free Action, you reduce the Treat Injury DC for all applications of the skill by your Intelligence modifier (minimum 1) until the start of your next turn. Additionally, when performing the Critical Care application of the Treat Injury skill, you take a -3 penalty to subsequent attempts at Critical Care in the last 24 hours, instead of the normal -5 penalty.", "class": "", "category": "", "costNumeric": null, "treeId": "c1cf52502cf74435", "tags": ["action_economy", "critical_hit", "damage_reduction", "feat_chain", "healing", "leader", "medicine", "poison", "precision", "repair", "scaling", "skills", "stability", "striker", "support", "talent_chain", "tree_c1cf52502cf74435", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Steady Hands"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "ec12bc7f161a0893", "name": "Squadron Tactics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Charisma 13, Wisdom 13, Starship Tactics, Squadron Maneuvers", "benefit": "Once per encounter, when you use a non-attack pattern Starship Maneuver, you grant all ships in your squadron the ability to use the same Starship Maneuver once on their next turn. The Pilot of each ship that chooses to use the Starship Maneuver must make any Pilot checks or attack rolls the Starship Maneuver requires- your success or failure with the Starship Maneuver has no bearing on the success of other units in your squadron.", "description": {"value": "Once per encounter, when you use a non-attack pattern Starship Maneuver, you grant all ships in your squadron the ability to use the same Starship Maneuver once on their next turn. The Pilot of each ship that chooses to use the Starship Maneuver must make any Pilot checks or attack rolls the Starship Maneuver requires- your success or failure with the Starship Maneuver has no bearing on the success of other units in your squadron."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "wis", "min": 13}, {"type": "talent", "id": "swse.talent.squadron_maneuvers"}], "_source": "canonical-csv"}, "treeId": "dc1b8c5ce2a70394", "tags": ["feat-chain", "leader", "scout", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Squadron Tactics"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.squadron_tactics", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.432Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "ec12ce36ff7048f2", "name": "Seize the Moment", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, whenever you would use , you can forgo the extra Swift Action to make an immediate melee or ranged attack against the damaged opponent. If your attack is a ranged attack that hits and deals damage, you treat the damage dealt by you and your ally as though it was one attack for purposes of overcoming Damage Reduction, Shield Rating, and determining whether the damage exceeded the target's Damage Threshold. Prerequisite: Whenever you would use , you can forgo the Swift Action to be able to Aim as a single Swift Action on your turn.", "description": "Once per encounter, whenever you would use , you can forgo the extra Swift Action to make an immediate melee or ranged attack against the damaged opponent. If your attack is a ranged attack that hits and deals damage, you treat the damage dealt by you and your ally as though it was one attack for purposes of overcoming Damage Reduction, Shield Rating, and determining whether the damage exceeded the target's Damage Threshold. Prerequisite: Whenever you would use , you can forgo the Swift Action to be able to Aim as a single Swift Action on your turn.", "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.distress_to_discord"}], "_source": "canonical-csv"}, "treeId": "3caa80f6bef04200", "tags": ["action-economy", "damage-reduction", "defender", "melee", "mobility", "noble", "positioning", "ranged", "shields", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "attack.with-ranged", "turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Seize the Mom