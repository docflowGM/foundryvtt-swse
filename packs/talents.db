{"_id": "433c2e9c0e71aceb", "name": "Flanking Foe", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dual Weapon Mastery I", "benefit": "If flanked and wielding two pistols, make flanking attacks as a standard action instead of a full; must attack two targets.", "description": "If flanked while wielding two pistols, attack both flankers as a standard action instead of a full action.", "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "ed77ab2e234089ed", "tags": ["action-economy", "feat-chain", "ranged", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["target.is-flanked"], "enabled": true, "priority": 500, "description": "Flanking Foe"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.flanking_foe", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": ["target.is-flanked"]}}}
{"_id": "4348c2bca983e4a9", "name": "Bolstered Numbers", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Recruit Enemy", "benefit": "Whenever you successfully use Recruit Enemy on a target, you and all allies within line of sight gain a +2 morale bonus to attack rolls until the end of the encounter.", "description": {"value": "Whenever you successfully use Recruit Enemy on a target, you and all allies within line of sight gain a +2 morale bonus to attack rolls until the end of the encounter."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.recruit_enemy"}], "_source": "canonical-csv"}, "treeId": "a2c6962521c29361", "tags": ["feat-chain", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Bolstered Numbers"}]}}, "effects": [{"_id": "c29590ef-d27f-4108-9baa-e120eceb3c48", "name": "Bolstered Numbers", "icon": "icons/svg/sword.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Bolstered Numbers"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.bolstered_numbers", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "4356ac9986934fbf", "name": "Hammerblow", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you are Unarmed and holding no items, you double your Strength bonus to Unarmed attack rolls.", "description": {"value": "If you are Unarmed and holding no items, you double your Strength bonus to Unarmed attack rolls.\n\nMake Do\n\nWhen fighting with an Improvised Weapon, you take no penalty on your attack rolls."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "67fdd8dce9abd6c1", "tags": ["soldier", "unarmed"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Hammerblow"}]}}, "effects": [{"_id": "47b08191-30fd-415f-87b4-2a2d2eb68a4b", "name": "Hammerblow", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.unarmed", "mode": 5, "value": "str_x2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Hammerblow"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hammerblow", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "437443efb52249aa", "name": "Aura of Freedom", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Training", "description": "You can spend a Force Point as a Swift Action to designate one ally within 12 squares of you and in your line of sight that is currently Grabbed, Grappled, or Immobilized; that target automatically escapes from the Grab or Grapple (or the Immobilization effect is removed), and the target can move up to half its Speed immediately as a Reaction. This movement does not provoke Attacks of Opportunity. Choose one Force Power with the [Dark Side] or [Light Side] descriptor in your Force Power Suite. That Force Power is no longer considered to have that descriptor for you. While you are aboard a Vehicle, you can spend a Force Point as a Reaction to the Vehicle taking damage; you make a Use the Force check and reduce the damage the Vehicle takes by the check result. This reduction occurs after both DR and SR are applied to the damage.", "benefit": "You can spend a Force Point as a Swift Action to designate one ally within 12 squares of you and in your line of sight that is currently Grabbed, Grappled, or Immobilized; that target automatically escapes from the Grab or Grapple (or the Immobilization effect is removed), and the target can move up to half its Speed immediately as a Reaction. This movement does not provoke Attacks of Opportunity. Choose one Force Power with the [Dark Side] or [Light Side] descriptor in your Force Power Suite. That Force Power is no longer considered to have that descriptor for you. While you are aboard a Vehicle, you can spend a Force Point as a Reaction to the Vehicle taking damage; you make a Use the Force check and reduce the damage the Vehicle takes by the check result. This reduction occurs after both DR and SR are applied to the damage.", "class": "", "category": "", "costNumeric": null, "treeId": "f8e7edab5f234e27", "tags": ["action_economy", "ally_support", "controller", "damage_reduction", "dark_side", "defense", "feat_chain", "force", "force_capacity", "force_control", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "freedom", "light_side", "mobility", "pilot", "positioning", "reaction", "resource_spend", "striker", "support", "swift_action", "talent_chain", "tree_f8e7edab5f234e27", "uncategorized_talent", "use_the_force", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Aura of Freedom"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": ["proximity.ally-nearby"]}}}
{"_id": "438e13c99c7b53a6", "name": "Commanding Presence", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Your abilities on the battlefield are well known and feared. When you reduce an opponent to 0 Hit Points with an attack, you can make a Persuasion check as a Free Action against all targets within 6 squares. If your Persuasion check exceeds the target's Will Defense, that target takes a -2 penalty on attack rolls for the remainder of the encounter. This Talent affects any given target only once per encounter. This is a Mind-Affecting Fear effect. Your training makes you confident and disciplined in combat. When you successfully deal damage to an opponent in combat, you gain a +5 morale bonus to Will Defense until the start of your next turn. You lose this bonus to Will Defense if you are Surprised or Flat-Footed for any reason.", "description": "Your abilities on the battlefield are well known and feared. When you reduce an opponent to 0 Hit Points with an attack, you can make a Persuasion check as a Free Action against all targets within 6 squares. If your Persuasion check exceeds the target's Will Defense, that target takes a -2 penalty on attack rolls for the remainder of the encounter. This Talent affects any given target only once per encounter. This is a Mind-Affecting Fear effect. Your training makes you confident and disciplined in combat. When you successfully deal damage to an opponent in combat, you gain a +5 morale bonus to Will Defense until the start of your next turn. You lose this bonus to Will Defense if you are Surprised or Flat-Footed for any reason.", "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "4007fa87192b5884", "tags": ["action-economy", "ambush", "battlefield-control", "controller", "damage-reduction", "defender", "leader", "positioning", "skills", "social", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 5, "type": "untyped", "predicates": ["defense.will", "attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Commanding Presence"}]}}, "effects": [{"_id": "ff1494c0-5d9c-4bd3-9b5c-bc93f28f4ea2", "name": "Commanding Presence", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.leadership", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Commanding Presence"}}}, {"name": "Commanding Presence (Class Skill)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.persuasion.classSkill", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Commanding Presence", "effectType": "class-skill"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.commanding_presence", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": ["defense.will", "attack.when-hit", "turn.once-per-round"]}}}
{"_id": "43ac0c4b1759507a", "name": "Recruit Enemy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter when you deal damage to a living creature that is equal to or greater than the target's current Hit Points and the target's Damage Threshold (that is, when you deal enough damage to kill the target), you can use this Talent. Make a Persuasion check against the target's Will Defense; if your result equals or exceeds the target's Will Defense, instead of dealing full damage, you deal half damage to the target and move it -1 step on the Condition Track.", "description": {"value": "Once per encounter when you deal damage to a living creature that is equal to or greater than the target's current Hit Points and the target's Damage Threshold (that is, when you deal enough damage to kill the target), you can use this Talent. Make a Persuasion check against the target's Will Defense; if your result equals or exceeds the target's Will Defense, instead of dealing full damage, you deal half damage to the target and move it -1 step on the Condition Track.\n\nIn addition, the target becomes your ally, and its Attitude toward you immediately shifts to Friendly. The target fights on your side until the end of the encounter, at which point it departs (or, if the GM wishes, the target might become your ally permanently and join your party). Anyone Hostile to you becomes Hostile to the target.\n\nThis is a Mind-Affecting effect. If the target is a higher level than you, it gains a +5 bonus to its Will Defense. Enemies that cannot be bribed, blackmailed, or seduced (such as Stormtroopers) are immune to this effect."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "treeId": "a2c6962521c29361", "tags": ["action-economy", "condition-removal", "controller", "damage-reduction", "leader", "mobility", "scaling", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Recruit Enemy"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.recruit_enemy", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "43ee5741f4b2375c", "name": "Cover Your Tracks", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You are adept at living beneath society's radar. Anyone who attempts to locate you using the Gather Information skill suffers a -5 penalty on their Gather Information checks.", "description": {"value": "You are adept at living beneath society's radar. Anyone who attempts to locate you using the Gather Information skill suffers a -5 penalty on their Gather Information checks."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "e303ddd025779062", "tags": ["force", "jedi", "light-side"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Cover Your Tracks"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.cover_your_tracks", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.409Z", "detectedPredicates": []}}}
{"_id": "443373859f1ecca3", "name": "Force Pilot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Prerequisites: Technometry", "benefit": "Starship Tactics When activating a Starship Maneuver, you may spend a Force Point to reroll your Pilot check, keeping the better of the two results. Reference Book: Star Wars Saga Edition Clone Wars Campaign Guide You can spend a Force Point to add your Charisma bonus to your Perception check. You can select this Talent multiple times. Each time you select this Talent, you add your Charisma bonus an additional time. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual Prerequisite: You can substitute your Use the Force skill for any Use Computer check made to Astrogate or Use Sensors while you are the Pilot of a Vehicle. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual Prerequisites: You can use your Use the Force check modifier instead of your Use Computer check modifier to Astrogate. You are considered Trained in the Use Computer skill. If you are entitled to a Use Computer check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations). Homebrew Reference Book: Legacy of the Force Sourcebook You can use your Use the Force check modifier instead of your Mechanics check modifier. You are considered Trained in the Mechanics skill. If you are entitled to a Mechanics check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations). Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Force Users As a Full-Round Action, you may attempt to merge your consciousness with am adjacent complex machine such as a computer, Droid or Vehicle by treating a Use the Force check as the Improve Access function of the Use Computer skill. Failure to beat the machine's Will Defense results in 1d4 Force damage dealt directly to your Hit Points. Success is treated as normal, though you may spend a Force Point as a Reaction upon success to move the system's Attitude an additional step. When a system is Helpful you are considered merged, and remain so until you chose to return to your natural body. While merged you are considered helpless and unaware of your body's surroundings. However, on your turn, you are in control of the merged machine. You are able to use the Access Information ability of the Use Computer Skill at a +10 bonus. In the case of a Vehicle or Droid, you are able to operate any single Vehicle or Droid system as if you were at the appropriate station, but at a +5 bonus to the associated check (attack roll or Skill Check). Further, when a merged Force-user uses the Reroute Power Action, their Vehicle moves an additional +1 step up the Condition Track. Upon returning to their natural body, a Force-user suffers a -5 penalty to all Use the Force checks made for 1d4 hours for every round they spent merged, and cannot spend Force Points unless accepting a Dark Side Point. If the player was merged for longer than an hour, they suffer a -10 penalty to all Use the Force checks for 1d4 days for every hour spent merged, and cannot spend Force Points or Destiny Points unless accepting a Dark Side Point. Homebrew Reference Book: Legacy of the Force Sourcebook", "description": "Starship Tactics When activating a Starship Maneuver, you may spend a Force Point to reroll your Pilot check, keeping the better of the two results. Reference Book: Star Wars Saga Edition Clone Wars Campaign Guide You can spend a Force Point to add your Charisma bonus to your Perception check. You can select this Talent multiple times. Each time you select this Talent, you add your Charisma bonus an additional time. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual Prerequisite: You can substitute your Use the Force skill for any Use Computer check made to Astrogate or Use Sensors while you are the Pilot of a Vehicle. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual Prerequisites: You can use your Use the Force check modifier instead of your Use Computer check modifier to Astrogate. You are considered Trained in the Use Computer skill. If you are entitled to a Use Computer check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations). Homebrew Reference Book: Legacy of the Force Sourcebook You can use your Use the Force check modifier instead of your Mechanics check modifier. You are considered Trained in the Mechanics skill. If you are entitled to a Mechanics check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations). Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Force Users As a Full-Round Action, you may attempt to merge your consciousness with am adjacent complex machine such as a computer, Droid or Vehicle by treating a Use the Force check as the Improve Access function of the Use Computer skill. Failure to beat the machine's Will Defense results in 1d4 Force damage dealt directly to your Hit Points. Success is treated as normal, though you may spend a Force Point as a Reaction upon success to move the system's Attitude an additional step. When a system is Helpful you are considered merged, and remain so until you chose to return to your natural body. While merged you are considered helpless and unaware of your body's surroundings. However, on your turn, you are in control of the merged machine. You are able to use the Access Information ability of the Use Computer Skill at a +10 bonus. In the case of a Vehicle or Droid, you are able to operate any single Vehicle or Droid system as if you were at the appropriate station, but at a +5 bonus to the associated check (attack roll or Skill Check). Further, when a merged Force-user uses the Reroute Power Action, their Vehicle moves an additional +1 step up the Condition Track. Upon returning to their natural body, a Force-user suffers a -5 penalty to all Use the Force checks made for 1d4 hours for every round they spent merged, and cannot spend Force Points unless accepting a Dark Side Point. If the player was merged for longer than an hour, they suffer a -10 penalty to all Use the Force checks for 1d4 days for every hour spent merged, and cannot spend Force Points or Destiny Points unless accepting a Dark Side Point. Homebrew Reference Book: Legacy of the Force Sourcebook", "costNumeric": null, "treeId": "d6b4331c0e31f7e3", "tags": ["action_economy", "condition_removal", "controller", "dark_side", "defender", "droid", "feat_chain", "force", "force_control", "force_defense", "force_execution", "force_offense", "force_point_spend", "initiative", "light_side", "mechanics", "mobility", "perception", "pilot", "piloting", "positioning", "precognition", "reaction", "resource_spend", "scaling", "senses", "skills", "slicing", "striker", "sustained_damage", "talent_chain", "tree_d6b4331c0e31f7e3", "uncategorized_talent", "use_the_force", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 10, "type": "untyped", "predicates": ["defense.will", "attack.when-hit", "turn.on-current-turn"], "enabled": true, "priority": 500, "description": "Force Pilot"}]}}, "effects": [{"_id": "1a0877e3-3ddb-43ec-8895-3fce38f8d0e6", "name": "Force Pilot", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.pilot.trained", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Pilot"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_pilot", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.411Z", "detectedPredicates": ["defense.will", "attack.when-hit", "turn.on-current-turn"]}}}
{"_id": "443bfe7fa33dd627", "name": "Telepathic Intruder", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you use a Force Power with the [Mind-Affecting] descriptor successfully against a target, until the end of your next turn you gain a +2 Force bonus on Skill Checks made to activate [Mind-Affecting] Force Powers and Force Talents against that same target.", "description": {"value": "Whenever you use a Force Power with the [Mind-Affecting] descriptor successfully against a target, until the end of your next turn you gain a +2 Force bonus on Skill Checks made to activate [Mind-Affecting] Force Powers and Force Talents against that same target."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "d25dc04b0e16f107", "tags": ["category_force_adept", "controller", "force", "force_capacity", "force_execution", "force_power_synergy", "force_training", "mystic", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Telepathic Intruder"}]}}, "effects": [{"_id": "ce3c9524-4a99-42cd-8183-6b5084367f70", "name": "Telepathic Intruder", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.force.mind_affect", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Telepathic Intruder"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.telepathic_intruder", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.411Z", "detectedPredicates": []}}}
{"_id": "444c032c563c18a1", "name": "Beloved", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Bolster Ally, Inspire Confidence", "benefit": "Your allies hold you in such esteem that when you are threatened or injured, you can impel them to action. You can use each of the following actions once per encounter:", "description": {"value": "Your allies hold you in such esteem that when you are threatened or injured, you can impel them to action. You can use each of the following actions once per encounter:\n\nGuardian: Choose one ally as a Swift Action. As long as you remain within 6 squares of the ally, you gain a +2 bonus to your Reflex Defense until the start of your next turn.\nReprisal: Make a single melee or ranged attack against any target within your Range as a Standard Action. If your attack roll succeeds and if that target attacks you before the end of your next turn, one ally within 6 squares can make an attack against that target as a Reaction.\nTo Me!: Spend a Swift Action. Whenever you take any damage before the beginning of your next turn, each ally within line of sight can move 2 squares as a Reaction. This movement does not provoke Attacks of Opportunity."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.bolster_ally"}, {"type": "talent", "id": "swse.talent.inspire_confidence"}], "_source": "canonical-csv"}, "treeId": "72d32ebcbb607314", "tags": ["action-economy", "controller", "feat-chain", "mobility", "noble", "positioning", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Beloved"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.beloved", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.411Z", "detectedPredicates": ["proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "450aa69ead3975f2", "name": "Take the Hit", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Bodyguard's Sacrifice", "benefit": "Whenever you take damage on behalf of an ally through the use of a Talent (including Harm's Way), your Damage Threshold is increased by 5 points.", "description": {"value": "Whenever you take damage on behalf of an ally through the use of a Talent (including Harm's Way), your Damage Threshold is increased by 5 points."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.bodyguards_sacrifice"}], "_source": "canonical-csv"}, "treeId": "c92c2cbc79b8a515", "tags": ["defender", "feat-chain", "soldier", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.damageThreshold", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.damageThreshold"}]}}, "effects": [{"_id": "f2678501-e543-44a0-adcb-d661f7b07eb2", "name": "Take the Hit", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damageThreshold", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Take the Hit", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.take_the_hit"}}}
