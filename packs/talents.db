{"_id": "de751f28fc269c85", "name": "Intimidating Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Presence, Trained in Persuasion", "benefit": "Once per encounter, as a Reaction, you can make a Persuasion check to Intimidate one creature that is making a melee or ranged attack against you, and is within your line of sight. If you succeed, you impose a -5 penalty to that attack roll. If the target is a higher level than you, it gains a +5 bonus to its Will Defense against the Intimidate check.This is a Mind-Affecting effect.", "description": {"value": "Once per encounter, as a Reaction, you can make a Persuasion check to Intimidate one creature that is making a melee or ranged attack against you, and is within your line of sight. If you succeed, you impose a -5 penalty to that attack roll. If the target is a higher level than you, it gains a +5 bonus to its Will Defense against the Intimidate check.This is a Mind-Affecting effect."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.presence"}], "_source": "canonical-csv"}, "treeId": "8375b9b26b679901", "tags": ["defender", "feat-chain", "noble", "skills", "social", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 5, "type": "untyped", "predicates": ["defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Intimidating Defense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.intimidating_defense", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": ["defense.will", "turn.once-per-round"]}}}
