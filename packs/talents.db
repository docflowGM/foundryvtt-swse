{"_id": "2acaa4620d396fe9", "name": "Force Interrogation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you deal damage to one or more creatures by using a Force Power, you can immediately make a Persuasion check as a Free Action to Intimidate a single target you damaged.", "description": {"value": "When you deal damage to one or more creatures by using a Force Power, you can immediately make a Persuasion check as a Free Action to Intimidate a single target you damaged."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "a6ee1a0c534cbc73", "tags": ["action_economy", "category_force_adept", "controller", "defender", "force", "force_capacity", "force_defense", "force_execution", "force_offense", "force_power_synergy", "force_training", "mystic", "persuasion", "positioning", "skills", "social", "striker", "sustained_damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 1, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Force Interrogation"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_interrogation", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["defense.will"]}}}
