{"_id": "2c18952e0c014127", "name": "Force Cloak", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "As the Talent, except you can expand the bubble to envelop a number of creatures (including yourself) equal to your Character Level. As a Swift Action, you can take a penalty of up to -5 on your attack roll and add the same number (up to +5) as a Force bonus to an ally's Reflex Defense, provided the ally is within your line of sight when you activate this talent. The bonus you confer cannot exceed your Base Attack Bonus. The changes to your attack rolls and your ally's Reflex Defense last until the start of your next turn.", "benefit": "As the Talent, except you can expand the bubble to envelop a number of creatures (including yourself) equal to your Character Level. As a Swift Action, you can take a penalty of up to -5 on your attack roll and add the same number (up to +5) as a Force bonus to an ally's Reflex Defense, provided the ally is within your line of sight when you activate this talent. The bonus you confer cannot exceed your Base Attack Bonus. The changes to your attack rolls and your ally's Reflex Defense last until the start of your next turn.", "class": "", "category": "", "costNumeric": null, "treeId": "f5c62e2e81f648aa", "tags": ["action_economy", "concealment", "defender", "force", "force_defense", "force_offense", "mobility", "new_action", "standard_action", "stealth", "striker", "support", "swift_action", "tree_f5c62e2e81f648aa", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 5, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Force Cloak"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "2c18d68d5e294dc8", "name": "Natural Healing", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Your extensive knowledge of Natural Healing allows you to make First Aid, Treat Disease, and Treat Poison checks without a Medical Kit, if you have access to appropriate natural substitutes (as determined by the Gamemaster).", "description": {"value": "Your extensive knowledge of Natural Healing allows you to make First Aid, Treat Disease, and Treat Poison checks without a Medical Kit, if you have access to appropriate natural substitutes (as determined by the Gamemaster)."}, "class": "06f4d9029debf827", "costNumeric": null, "category": "Medic", "treeId": "61725c845d26ade0", "tags": ["category_medic", "control", "healing", "investigation", "knowledge", "medicine", "poison", "skills", "support", "survivability", "teamwork", "trap", "treat_injury"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Natural Healing"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.natural_healing", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": []}}}
{"_id": "2c27842384e55cb2", "name": "Mercenary's Grit", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you are affected by any debilitating condition, you can convert the condition's modifier from a penalty to a bonus for 1 round as a Swift Action. At the end of your next turn, move -1 step along the Condition Track.", "description": {"value": "When you are affected by any debilitating condition, you can convert the condition's modifier from a penalty to a bonus for 1 round as a Swift Action. At the end of your next turn, move -1 step along the Condition Track."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "4007fa87192b5884", "tags": ["action-economy", "condition-removal", "controller", "force", "force-control", "mobility", "soldier", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.on-current-turn"], "enabled": true, "priority": 500, "description": "Mercenary's Grit"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.mercenarys_grit", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["turn.on-current-turn"]}}}
{"_id": "2cf48b8aa712d19d", "name": "Melee Brute", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you make a melee attack against a target that has one or more of your allies adjacent to it, compare the result to the target's Fortitude Defense as well as its Reflex Defense. If the attack hits both Defenses, the target's Speed is reduced by 2 squares and it takes a -2 penalty to its Reflex Defense until the end of your next turn.", "description": {"value": "When you make a melee attack against a target that has one or more of your allies adjacent to it, compare the result to the target's Fortitude Defense as well as its Reflex Defense. If the attack hits both Defenses, the target's Speed is reduced by 2 squares and it takes a -2 penalty to its Reflex Defense until the end of your next turn."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "7bcd1d892f2e9ae7", "tags": ["defender", "melee", "mobility", "positioning", "soldier"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "defense.fortitude", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Melee Brute"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.melee_brute", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["defense.reflex", "defense.fortitude", "attack.with-melee"]}}}
{"_id": "2d392f2b63b738ed", "name": "Instinctive Navigation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Pilot", "benefit": "Use the Force replaces Use Computer for astrogation checks.", "description": "Use the Force instead of Use Computer for astrogation.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.force_pilot"}], "_source": "canonical-csv"}, "treeId": "d6b4331c0e31f7e3", "tags": ["feat_chain", "force", "force_execution", "initiative", "pilot", "precognition", "senses", "talent_chain", "tree_d6b4331c0e31f7e3", "uncategorized_talent", "use_the_force", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Instinctive Navigation"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.instinctive_navigation", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": []}}}
{"_id": "2d486ece7350cedf", "name": "Blast Back", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per round when you are damaged by an enemy's Area Attack, as a Reaction you can make an immediate melee or ranged attack against the source of the Area Attack, provided that you have line of sight to the attacker and the target is within your melee or ranged reach.", "description": {"value": "Once per round when you are damaged by an enemy's Area Attack, as a Reaction you can make an immediate melee or ranged attack against the source of the Area Attack, provided that you have line of sight to the attacker and the target is within your melee or ranged reach."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "5a30489609182e8c", "tags": ["action-economy", "controller", "melee", "mobility", "positioning", "ranged", "scout", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Blast Back"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.blast_back", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "2da74bc3f4d45d2d", "name": "Perfect Telepathy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can communicate in full sentences and complete thoughts when you use the Telepathy aspect of the Use the Force skill, instead of just in basic phrases. However, the target of your Telepathy can still only communicate in basic emotions or single thoughts.", "description": {"value": "You can communicate in full sentences and complete thoughts when you use the Telepathy aspect of the Use the Force skill, instead of just in basic phrases. However, the target of your Telepathy can still only communicate in basic emotions or single thoughts."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "d25dc04b0e16f107", "tags": ["category_force_adept", "controller", "force", "force_capacity", "force_execution", "force_training", "mystic", "support", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Perfect Telepathy"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.perfect_telepathy", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": []}}}
