{"_id": "5ea6368fd61de9f1", "name": "Unwavering Ally", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per turn, as a Swift Action, you can designate one ally within your line of sight who can hear and understand you. Until the start of your next turn, that ally becomes immune to all effects that render the ally Flat-Footed or that deny the ally a Dexterity bonus to his or her Reflex Defense.", "description": {"value": "Once per turn, as a Swift Action, you can designate one ally within your line of sight who can hear and understand you. Until the start of your next turn, that ally becomes immune to all effects that render the ally Flat-Footed or that deny the ally a Dexterity bonus to his or her Reflex Defense."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "5964237d22681dc0", "tags": ["controller", "defender", "noble", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Unwavering Ally"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unwavering_ally", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.414Z", "detectedPredicates": ["defense.reflex"]}}}
