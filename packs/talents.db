{"_id": "1e7a0010a589b870", "name": "Dirty Tactics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, as a Standard Action, you can grant a tactical advantage to all allies within your line of sight. When an ally Flanks an opponent, that ally gains a +4 Flanking bonus on melee attack rolls instead of the normal +2 bonus.", "description": {"value": "Once per encounter, as a Standard Action, you can grant a tactical advantage to all allies within your line of sight. When an ally Flanks an opponent, that ally gains a +4 Flanking bonus on melee attack rolls instead of the normal +2 bonus.\n\nAllies lose this benefit immediately if line of sight is broken or if you are unconscious or dead, or at the end of the encounter."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "e91cc675fbf9ba6e", "tags": ["action-economy", "ambush", "controller", "defender", "leader", "melee", "mobility", "noble", "positioning", "ranged", "scout", "skills", "social", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 4, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "defense.will", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Dirty Tactics"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dirty_tactics", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.405Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "defense.will", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "1fc568c1bbdd94e0", "name": "Noble Sacrifice", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Recruit Enemy", "benefit": "Whenever you successfully use Recruit Enemy on a target, if that target is reduced to 0 Hit Points or moved to the bottom of the Condition Track, as a Reaction you can grant yourself and all allies within line of sight a number of Bonus Hit Points equal to 10 + your Class Level.", "description": {"value": "Whenever you successfully use Recruit Enemy on a target, if that target is reduced to 0 Hit Points or moved to the bottom of the Condition Track, as a Reaction you can grant yourself and all allies within line of sight a number of Bonus Hit Points equal to 10 + your Class Level.\n\nDamage is subtracted from Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter are lost. Bonus Hit Points do not stack. No Bonus Hit Points may be granted if you or an ally reduce the target to 0 Hit Points or move it to the bottom of the Condition Track."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.recruit_enemy"}], "_source": "canonical-csv"}, "treeId": "a2c6962521c29361", "tags": ["feat-chain", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Noble Sacrifice"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.noble_sacrifice", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.405Z", "detectedPredicates": []}}}
