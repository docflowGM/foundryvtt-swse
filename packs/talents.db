{"_id": "46946e7208f1cf05", "name": "Six Questions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "SpyNet Agent", "benefit": "You have mastered the basic Bothan philosophy of Six Questions to glean more information from contacts through fewer questions. As a Swift Action, you can designate a single target within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL.", "description": {"value": "You have mastered the basic Bothan philosophy of Six Questions to glean more information from contacts through fewer questions. As a Swift Action, you can designate a single target within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL.\n\nIf the check is successful, you learn a target's Character Level, Classes, Ability Scores, and the target's available Force Points and Destiny Points."}, "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.spynet_agent"}], "_source": "canonical-csv"}, "treeId": "d20682671d035cef", "tags": ["action_economy", "feat_chain", "force", "investigation", "knowledge", "resources", "social", "social_network", "striker", "swift_action", "talent_chain", "tree_d20682671d035cef", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Six Questions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.six_questions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.411Z", "detectedPredicates": []}}}
