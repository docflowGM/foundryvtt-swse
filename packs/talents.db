{"_id": "fbe4b1551ef49a84", "name": "Sabotage Device", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action, you can sabotage any object or weapon that is powered by an Energy Cell or Power Pack so that it becomes a Grenade. The object or Weapon is then considered to be a Frag Grenade in all ways, but it can be turned back into its original form with another Swift Action.", "description": {"value": "As a Swift Action, you can sabotage any object or weapon that is powered by an Energy Cell or Power Pack so that it becomes a Grenade. The object or Weapon is then considered to be a Frag Grenade in all ways, but it can be turned back into its original form with another Swift Action."}, "class": "b85240cf77cf95eb", "costNumeric": null, "category": "Military Engineer", "treeId": "e32009b1b0aee8c9", "tags": ["action-economy", "heavy-weapons", "mobility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Sabotage Device"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sabotage_device", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": []}}}
{"_id": "fc4dd5a981974626", "name": "Watchful Step", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "You can use your Perception check modifier instead of your Initiative modifier when making Initiative checks. If you are entitled to an Initiative check reroll, you can reroll your Perception check instead (subject to the same circumstances and limitations). You are considered to be Trained in Initiative."}, "benefit": "You can use your Perception check modifier instead of your Initiative modifier when making Initiative checks. If you are entitled to an Initiative check reroll, you can reroll your Perception check instead (subject to the same circumstances and limitations). You are considered to be Trained in Initiative.", "class": "", "category": "", "costNumeric": null, "treeId": "9d826906ad8945b0", "tags": ["ambush", "ambush_defense", "defender", "initiative", "mobility", "positioning", "recon", "support", "sustained_damage", "tree_9d826906ad8945b0", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Watchful Step"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "fc91564e800719be", "name": "Biotech Mastery", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Biotech Specialist", "benefit": "When using the Biotech Specialist Feat to modify Biotech, you are able to make the appropriate modification in half of the normal time for half the normal cost. In addition, you can Take 10 on the Mechanics check (even when distracted or threatened), but you cannot Take 20.", "description": {"value": "When using the Biotech Specialist Feat to modify Biotech, you are able to make the appropriate modification in half of the normal time for half the normal cost. In addition, you can Take 10 on the Mechanics check (even when distracted or threatened), but you cannot Take 20."}, "class": "557e1a5ec72166fd", "costNumeric": null, "category": "Shaper", "treeId": "cdbee578d65154fc", "tags": ["ability_enhancement", "biotech", "category_shaper", "crafting", "healing", "mechanics", "skills", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Biotech Mastery"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.biotech_mastery", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": []}}}
{"_id": "fc986d810732ff3a", "name": "Master of Elegance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dual Weapon Flourish I or Single Weapon Flourish I, Weapon Finesse", "benefit": "You may add your Dexterity bonus (instead of your Strength bonus) on damage rolls when wielding a light melee weapon. When you wield a light melee weapon two-handed, you may apply double your Dexterity bonus (instead of double your Strength bonus) to the damage.", "description": {"value": "You may add your Dexterity bonus (instead of your Strength bonus) on damage rolls when wielding a light melee weapon. When you wield a light melee weapon two-handed, you may apply double your Dexterity bonus (instead of double your Strength bonus) to the damage."}, "class": "d87c05d2a34f5627", "costNumeric": null, "category": "Melee Duelist", "treeId": "1381bb8c9a838279", "tags": ["action-economy", "lightsaber", "melee", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "turn.on-current-turn"], "enabled": true, "priority": 500, "description": "Master of Elegance"}]}}, "effects": [{"_id": "7e0e71c5-4333-442a-ae60-0b4a8d53f64b", "name": "Master of Elegance", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.light_melee", "mode": 2, "value": "dex_bonus"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Master of Elegance"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.master_of_elegance", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": ["attack.with-melee", "turn.on-current-turn"]}}}
{"_id": "fcc6357b5b33dbb7", "name": "Lightsaber Form Savant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Swift Action, you can return any one spent Force Power with the [Lightsaber Form] descriptor to your Force Power Suite without spending a Force Point.", "description": {"value": "Once per encounter as a Swift Action, you can return any one spent Force Power with the [Lightsaber Form] descriptor to your Force Power Suite without spending a Force Point.\n\nYou can select this Talent multiple times. Each time you select it, you can use it one additional time per encounter."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "b3c5d90b5036f39b", "tags": ["force", "jedi", "lightsaber", "melee"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Lightsaber Form Savant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lightsaber_form_savant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "fd35b51c26fa0d5c", "name": "Confounding Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Tangle Up, Uncanny Instincts", "benefit": "Once per encounter, whenever you would use Uncanny Instincts, you can forgo the movement to make an immediate melee or ranged attack against the opponent that hit you. If your attack is a melee attack that hits and deals damage, you and your opponent immediately switch places; assuming both you and your opponent can end in a legal space.", "description": {"value": "Once per encounter, whenever you would use Uncanny Instincts, you can forgo the movement to make an immediate melee or ranged attack against the opponent that hit you. If your attack is a melee attack that hits and deals damage, you and your opponent immediately switch places; assuming both you and your opponent can end in a legal space."}, "class": "19ee85a788380256", "costNumeric": null, "category": "Outlaw", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.tangle_up"}], "_source": "canonical-csv"}, "treeId": "3caa80f6bef04200", "tags": ["category_outlaw", "controller", "duelist", "feat_chain", "melee", "mobility", "offense_melee", "offense_ranged", "opportunist", "striker", "survivability", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Confounding Attack"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.confounding_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.435Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "turn.once-per-round"]}}}
{"_id": "fd87928650da45fd", "name": "Poisoncraft", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Trained in Knowledge (Life Sciences), You have created a simple formula allowing you to revitalize your allies. Once per encounter, as a Standard Action, you can allow an adjacent non-Droid creature to Catch a Second Wind. This Second Wind is not counted towards target's normal daily ability to Catch a Second Wind, but if both are used in the same encounter the target moves -1 Persistent step down the Condition Track at the end of the encounter. The penalties imposed by this Persistent Condition persist until the target takes at least 8 hours to recuperate, during which time the target can't engage in any strenuous activity.", "benefit": "Trained in Knowledge (Life Sciences), You have created a simple formula allowing you to revitalize your allies. Once per encounter, as a Standard Action, you can allow an adjacent non-Droid creature to Catch a Second Wind. This Second Wind is not counted towards target's normal daily ability to Catch a Second Wind, but if both are used in the same encounter the target moves -1 Persistent step down the Condition Track at the end of the encounter. The penalties imposed by this Persistent Condition persist until the target takes at least 8 hours to recuperate, during which time the target can't engage in any strenuous activity.", "class": "", "category": "", "costNumeric": null, "treeId": "00cb74839a524276", "tags": ["action_economy", "condition_removal", "controller", "droid", "investigation", "knowledge", "knowledge_creatures", "mobility", "new_action", "poison", "positioning", "standard_action", "survival", "sustained_damage", "tree_00cb74839a524276", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Poisoncraft"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "fdc4061afb97e87f", "name": "Gauge Force Potential", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Perception", "benefit": "Use the Force vs Will to detect Force sensitivity, number of powers known, and Force Points.", "description": "Use the Force to detect Force sensitivity, powers known, and Force Points.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.force_perception"}], "_source": "canonical-csv"}, "treeId": "d6b4331c0e31f7e3", "tags": ["feat_chain", "force", "force_execution", "initiative", "pilot", "precognition", "senses", "talent_chain", "tree_d6b4331c0e31f7e3", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Gauge Force Potential"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.gauge_force_potential", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": []}}}
{"_id": "fde8157b6d097e12", "name": "Harm's Way", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Initiative", "benefit": "Once per round, you may spend a Swift Action to shield a single adjacent ally from attacks, taking the damage and suffering the ill effects in your ally's stead.", "description": {"value": "Once per round, you may spend a Swift Action to shield a single adjacent ally from attacks, taking the damage and suffering the ill effects in your ally's stead.\n\nUntil the start of your next turn, any attack made against the protected ally targets you instead. You may elect not to shield your protected ally against a given attack, provided the decision is made before the attack roll is made.\n\nIf you are the Pilot of a Vehicle, you may use this Talent to protect allied Vehicles. You may use it to protect Vehicles no more than one size category larger than your own."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "cb5493f65f0bdb62"}], "_source": "fix5F-canonical"}, "treeId": "c92c2cbc79b8a515", "tags": ["action-economy", "damage-reduction", "defender", "mobility", "positioning", "soldier", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Harm's Way"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.harms_way", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": ["proximity.ally-nearby"]}}}
{"_id": "fe0c3a64ca460542", "name": "Spacehound", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You take no penalty on attack rolls in Low Gravity or Zero Gravity environments, and you ignore the debilitating effects of Space Sickness. In addition, you are considered proficient with any Starship Weapon.", "description": {"value": "You take no penalty on attack rolls in Low Gravity or Zero Gravity environments, and you ignore the debilitating effects of Space Sickness. In addition, you are considered proficient with any Starship Weapon."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "5ea8c79492d40713", "tags": ["action-economy", "controller", "damage-reduction", "defender", "force", "force-control", "force-defense", "force-offense", "mobility", "positioning", "ranged", "scaling", "scoundrel", "shields", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.against-ranged", "defense.reflex", "attack.when-hit", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Spacehound"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.spacehound", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": ["defense.against-ranged", "defense.reflex", "attack.when-hit", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "fead6e3522fd458a", "name": "Elusive Dogfighter", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When engaged in a Dogfight, any enemy pilot engaged in the same Dogfight takes a -10 penalty on attack rolls when you succeed on the opposed Pilot check.", "description": {"value": "When engaged in a Dogfight, any enemy pilot engaged in the same Dogfight takes a -10 penalty on attack rolls when you succeed on the opposed Pilot check."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "b17c1515c06361d6", "tags": ["action-economy", "defender", "feat-chain", "mobility", "piloting", "positioning", "scaling", "scout", "skills", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Elusive Dogfighter"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.elusive_dogfighter", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.436Z", "detectedPredicates": ["defense.reflex", "turn.once-per-round"]}}}
