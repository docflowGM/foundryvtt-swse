{"_id": "c3a67c14c713a7a3", "name": "Skilled Demolitionist", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can set a Detonator as a Swift Action, and your Explosives never go off as the Detonator is being placed, even if you fail the check by 10 or more. You must still roll to determine if the charge otherwise goes off as planned (see Handle Explosives).", "description": {"value": "You can set a Detonator as a Swift Action, and your Explosives never go off as the Detonator is being placed, even if you fail the check by 10 or more. You must still roll to determine if the charge otherwise goes off as planned (see Handle Explosives)."}, "class": "de3f367749b82fcf", "costNumeric": null, "category": "Saboteur", "treeId": "8897a36d59662ee9", "tags": ["action-economy", "burst-damage", "feat-chain", "mobility", "positioning", "striker", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Skilled Demolitionist"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.skilled_demolitionist", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": []}}}
{"_id": "c3b22fdc6ca5af8e", "name": "Armored Mandalorian", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dexterity 13, Mandalorian Glory, Proficient with Armor", "benefit": "Mandalorians wear armor constantly and learn to adjust to take an impact on the strongest section of their armor. You add your armor's Fortitude Defense bonus as an Equipment bonus to your Elite Trooper Damage Reduction (with a maximum bonus equal to your base Elite Trooper DR).", "description": {"value": "Mandalorians wear armor constantly and learn to adjust to take an impact on the strongest section of their armor. You add your armor's Fortitude Defense bonus as an Equipment bonus to your Elite Trooper Damage Reduction (with a maximum bonus equal to your base Elite Trooper DR).\n\nAdditionally, if a Lightsaber does not ignore the DR of the armor you are wearing (such as Cortosis Weave/Phrik Alloy General Template), a Lightsaber does not ignore your Elite Trooper Damage Reduction."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "dex", "min": 13}, {"type": "talent", "id": "swse.talent.mandalorian_glory"}], "_source": "canonical-csv"}, "treeId": "4b8857716e056f62", "tags": ["armor", "damage-reduction", "defender", "feat-chain", "lightsaber", "melee", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 2, "type": "untyped", "predicates": ["defense.fortitude"], "enabled": true, "priority": 500, "description": "Armored Mandalorian"}]}}, "effects": [{"_id": "0841e981-1512-4f79-9ce3-9ad24a587a68", "name": "Armored Mandalorian", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damageReduction", "mode": 5, "value": "armor_fortitude_bonus"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Armored Mandalorian"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.armored_mandalorian", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": ["defense.fortitude"]}}}
