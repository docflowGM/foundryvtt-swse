{"_id": "ab6efafd94ad044e", "name": "Extended Critical Range (heavy)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Base attack bonus +10, Weapon Proficiency (heavy)", "benefit": "Increase critical range of heavy weapons by 1.", "description": "With heavy weapons, increase the weapon's critical threat range by 1.", "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "bab", "min": 10}], "_source": "canonical-csv"}, "treeId": "71e99c646b18d85c", "tags": ["feat-chain", "heavy-weapons", "positioning", "precision", "soldier", "talent-chain"], "executionModel": "PASSIVE", "subType": "RULE", "abilityMeta": {"rules": [{"type": "EXTEND_CRITICAL_RANGE", "params": {"proficiency": "heavy-weapons", "by": 1}, "conditions": []}]}}, "effects": [{"_id": "3aa9ccf6-cbd5-49f9-809b-5605c5e040f6", "name": "Extended Critical Range (heavy)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.weapons.heavy.critRange", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Extended Critical Range (heavy)", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.extended_critical_range_heavy"}}}
{"_id": "ab9f1497d0b2d7c2", "name": "WatchCircle Initiate", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Farseeing", "benefit": "As a Reaction, you can make a DC 15 Use the Force check and remove one use of the Farseeing Force Power from your active Force Power Suite (as though you had just activated the Force Power).", "description": {"value": "As a Reaction, you can make a DC 15 Use the Force check and remove one use of the Farseeing Force Power from your active Force Power Suite (as though you had just activated the Force Power).\n\nIf successful, you subtract 1 from your Force Point total (this cannot be subtracted from temporary Force Points, and does not count as spending a Force Point), and add 1 to the Force Point total of an ally within line of sight.\n\nThis counts as using the Farseeing Force Power against the target, but this Talent replaces the normal rules and effects of Farseeing."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["action-economy", "controller", "defender", "feat-chain", "force", "force-control", "force-defense", "force-offense", "jedi", "leader", "light-side", "melee", "mobility", "positioning", "ranged", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 5, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "defense.will", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "WatchCircle Initiate"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.watchcircle_initiate", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "defense.will", "attack.with-melee", "attack.with-ranged", "proximity.ally-nearby"]}}}
{"_id": "abe485644b195f0b", "name": "Vigilance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Swift Action you may designate one adjacent ally as the target of this Talent. That target gains a +1 deflection bonus to their Reflex Defense as long as you remain adjacent to them. You may change the target of this Talent as a Swift Action.", "description": {"value": "As a Swift Action you may designate one adjacent ally as the target of this Talent. That target gains a +1 deflection bonus to their Reflex Defense as long as you remain adjacent to them. You may change the target of this Talent as a Swift Action."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "77e3817ba5cfa0d5", "tags": ["defender", "force", "force-defense", "jedi", "leader", "light-side", "positioning", "striker", "support"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}]}}, "effects": [{"_id": "90cfe69a-0fd0-44cd-9036-67f9b43c2d75", "name": "Vigilance", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.reflex", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Vigilance", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.vigilance"}}}
{"_id": "ac11f849b15c784c", "name": "Quick Modification", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Masterwork Lightsaber", "benefit": "You can spend 1 minute modifying a Lightsaber you have built, removing one Lightsaber Accessory or Lightsaber Modification and putting a different one its place.", "description": {"value": "You can spend 1 minute modifying a Lightsaber you have built, removing one Lightsaber Accessory or Lightsaber Modification and putting a different one its place.\n\nGamemasters may rule that some modifications cannot be added or removed in this way due to rarity of materials or the difficulty of the Lightsaber Modification (such as adding or removing the Electrum Detail)."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "76ecaa09bb7619cb", "tags": ["controller", "feat-chain", "force", "force-control", "jedi", "light-side", "lightsaber", "melee", "mobility", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Quick Modification"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.quick_modification", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
