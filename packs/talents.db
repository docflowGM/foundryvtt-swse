{"_id": "196b54d69bd54983", "name": "Telekinetic Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Base Attack Bonus +5", "description": "Whenever you roll the damage for an Unarmed attack, you reroll any dice that come up with a result of 1. You recover all spent Force Powers, adding them to your Force Power Suite again, whenever you roll a Natural 20 on an Unarmed attack. Whenever you reduce an opponent to 0 Hit Points with an Unarmed attack, you can make a Jump check as a Free Action, moving a distance as determined by the results of your Jump check. You can use the Surge Force Power as normal to enhance this Jump check, increasing the distance you move. As a Standard Action, you can make two Unarmed attacks, each against different targets. Whenever you make a successful Unarmed attack, you can add the result of a Force Point roll to the damage roll instead of the attack roll. Whenever you successfully use the Throw feat, your opponent falls Prone in any space you desire up to 3 squares beyond your reach.", "benefit": "Whenever you roll the damage for an Unarmed attack, you reroll any dice that come up with a result of 1. You recover all spent Force Powers, adding them to your Force Power Suite again, whenever you roll a Natural 20 on an Unarmed attack. Whenever you reduce an opponent to 0 Hit Points with an Unarmed attack, you can make a Jump check as a Free Action, moving a distance as determined by the results of your Jump check. You can use the Surge Force Power as normal to enhance this Jump check, increasing the distance you move. As a Standard Action, you can make two Unarmed attacks, each against different targets. Whenever you make a successful Unarmed attack, you can add the result of a Force Point roll to the damage roll instead of the attack roll. Whenever you successfully use the Throw feat, your opponent falls Prone in any space you desire up to 3 squares beyond your reach.", "class": "", "category": "", "costNumeric": null, "treeId": "899038f739294c81", "tags": ["action_economy", "control", "controller", "damage_reduction", "feat_chain", "force", "force_capacity", "force_control", "force_offense", "force_point_spend", "force_power_synergy", "martial_arts", "mobility", "new_action", "offense_melee", "offense_ranged", "positioning", "ranged", "resource_spend", "standard_action", "striker", "talent_chain", "telekinesis", "trap", "tree_899038f739294c81", "unarmed", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "movement.while-moving", "target.is-prone"], "enabled": true, "priority": 500, "description": "Telekinetic Strike"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.405Z", "detectedPredicates": ["attack.when-hit", "movement.while-moving", "target.is-prone"]}}}
