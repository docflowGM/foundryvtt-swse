{"_id": "60b02b78caed8e16", "name": "Wingman", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Wisdom 13", "benefit": "As a Swift Action, you can make a DC 15 Pilot check to assist any allied Starfighter or Airspeeder within 2 squares at Starship Scale. If you succeed, the Pilot of that Vehicle gains a +5 bonus on all opposed Pilot checks relating to the Dogfight Action until the start of your next turn.", "description": {"value": "As a Swift Action, you can make a DC 15 Pilot check to assist any allied Starfighter or Airspeeder within 2 squares at Starship Scale. If you succeed, the Pilot of that Vehicle gains a +5 bonus on all opposed Pilot checks relating to the Dogfight Action until the start of your next turn."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "wis", "min": 13}], "_source": "canonical-csv"}, "treeId": "b17c1515c06361d6", "tags": ["action-economy", "feat-chain", "leader", "mobility", "positioning", "scout", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Wingman"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.wingman", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.414Z", "detectedPredicates": []}}}
