{"_id": "c59de6f440c92832", "name": "Cause Mutation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Sith Alchemy", "benefit": "You can use your mastery of Sith Alchemy to create mutated abominations. You must have access to a willing (or unconscious) creature to which you will apply the Sith Abomination Template or the Chrysalis Beast Template. You also need a medical lab outfitted for the process, which requires a number of days equal to creature's modified CL. You must spend a Force Point at the completion of the process to complete the transformation. A creature you have mutated is considered to be a domesticated creature, but for you only (unless it was already a domesticated creature before its mutation).", "description": {"value": "You can use your mastery of Sith Alchemy to create mutated abominations. You must have access to a willing (or unconscious) creature to which you will apply the Sith Abomination Template or the Chrysalis Beast Template. You also need a medical lab outfitted for the process, which requires a number of days equal to creature's modified CL. You must spend a Force Point at the completion of the process to complete the transformation. A creature you have mutated is considered to be a domesticated creature, but for you only (unless it was already a domesticated creature before its mutation)."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.sith_alchemy"}], "_source": "canonical-csv"}, "treeId": "a67faf2ae089ab5d", "tags": ["beast_companion", "category_sith_apprentice", "controller", "crafting", "dark_side", "force", "force_control", "force_execution", "force_point_spend", "healing", "jedi", "resource_spend", "sith_alchemy", "striker", "support", "tree_a67faf2ae089ab5d"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value"