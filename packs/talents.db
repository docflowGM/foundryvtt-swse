{"_id": "9fd409d9ceaf6733", "name": "Run Interference", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Escort Pilot Talent", "benefit": "As a Reaction, you can use your Vehicular Combat Feat to negate an attack against an adjacent Vehicle of Colossal size or smaller that is Piloted by an ally. If you can use Vehicular Combat more than once per round, each use to negate an attack counts toward your limit of uses per round.", "description": {"value": "As a Reaction, you can use your Vehicular Combat Feat to negate an attack against an adjacent Vehicle of Colossal size or smaller that is Piloted by an ally. If you can use Vehicular Combat more than once per round, each use to negate an attack counts toward your limit of uses per round."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "5f355ad4093d2bf8", "tags": ["feat-chain", "positioning", "scout", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Run Interference"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.run_interference", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a0099db14b3fc3e7", "name": "Punch Through", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you are the Pilot of a Vehicle, smaller Vehicles that attempt to engage you in a Dogfight take a -10 penalty on their Pilot checks, instead of the normal -5.", "description": {"value": "If you are the Pilot of a Vehicle, smaller Vehicles that attempt to engage you in a Dogfight take a -10 penalty on their Pilot checks, instead of the normal -5."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "296772ab8e69c9ef", "tags": ["scout"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Punch Through"}]}}, "effects": [{"_id": "d11b26c1-10ea-47f2-8b9c-7f7d19af6640", "name": "Punch Through", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.vehicles.dogfight_resistance", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Punch Through"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.punch_through", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a0ace6dcc1c67d48", "name": "Elusive Target", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When fighting an opponent or multiple opponents in melee, other opponents attempting to target you with ranged attacks take a -5 penalty. This penalty is in addition to the normal -5 penalty for firing into melee, making the penalty to target you -10.", "description": {"value": "When fighting an opponent or multiple opponents in melee, other opponents attempting to target you with ranged attacks take a -5 penalty. This penalty is in addition to the normal -5 penalty for firing into melee, making the penalty to target you -10."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "10c843cef8ce2798", "tags": ["force", "force-offense", "jedi", "light-side", "melee", "positioning", "ranged"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Elusive Target"}]}}, "effects": [{"_id": "d82c4204-1b7d-41b9-b88a-062970ca8db9", "name": "Elusive Target", "icon": "icons/svg/wind.svg", "changes": [{"key": "system.defenses.reflex.misc", "mode": 2, "value": "2", "priority": 20}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Elusive Target"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.elusive_target", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged"]}}}
{"_id": "a0c4b4b252ee4c96", "name": "Cortosis Staff Block", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Nikto Survival (Kajain'sa'Nikto)", "description": "As a Reaction, you may negate a melee attack by making a successful opposed attack roll. The DC of the attack roll is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty to your attack rolls to use this Talent for every time you have used since the beginning of your last turn. You must have a Cortosis Staff drawn to use this Talent, and you must be aware of the attack and not Flat-Footed. You may spend a Force Point to use this Talent to negate an attack against an adjacent character. Morgukai warriors have trained their minds to resist the effects of Jedi mind tricks, and as such, gain a +5 bonus to their Will Defense versus any Force Powers with the [Mind-Affecting] descriptor. Whenever you make multiple attacks with a Cortosis Staff as a Full Attack Action, you reduce the penalty on your attack rolls by 2. You can take this Talent multiple times; each time you take this Talent, you reduced the penalty on your attack rolls by an additional 2.", "benefit": "As a Reaction, you may negate a melee attack by making a successful opposed attack roll. The DC of the attack roll is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty to your attack rolls to use this Talent for every time you have used since the beginning of your last turn. You must have a Cortosis Staff drawn to use this Talent, and you must be aware of the attack and not Flat-Footed. You may spend a Force Point to use this Talent to negate an attack against an adjacent character. Morgukai warriors have trained their minds to resist the effects of Jedi mind tricks, and as such, gain a +5 bonus to their Will Defense versus any Force Powers with the [Mind-Affecting] descriptor. Whenever you make multiple attacks with a Cortosis Staff as a Full Attack Action, you reduce the penalty on your attack rolls by 2. You can take this Talent multiple times; each time you take this Talent, you reduced the penalty on your attack rolls by an additional 2.", "class": "", "category": "", "costNumeric": null, "treeId": "0a61ab9ece844326", "tags": ["action_economy", "anti_lightsaber", "block", "burst_damage", "controller", "cortosis", "damage_reduction", "defender", "duelist", "feat_chain", "force", "force_defense", "force_offense", "force_point_spend", "light_side", "melee", "melee_defense", "offense_melee", "positioning", "reaction", "resource_spend", "scaling", "striker", "talent_chain", "tree_0a61ab9ece844326", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 5, "type": "untyped", "predicates": ["defense.will", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Cortosis Staff Block"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["defense.will", "attack.with-melee"]}}}
{"_id": "a0c97d4ca8a2d34d", "name": "Watch Your Back", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you are adjacent to at least one ally, enemies gain no benefit from Flanking you or any adjacent allies.", "description": {"value": "If you are adjacent to at least one ally, enemies gain no benefit from Flanking you or any adjacent allies."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "eff10782c1e56598", "tags": ["positioning", "scaling", "soldier", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Watch Your Back"}]}}, "effects": [{"_id": "67e7f8a4-75be-4e5c-b53f-790de9267c7a", "name": "Watch Your Back", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.flanking.immunity", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Watch Your Back"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.watch_your_back", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a18d67d9fd947f68", "name": "Blend In", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Spies are adept at concealing their identities, even if not using a physical disguise. You can reroll any Deception check for the purpose of creating a Deceptive Appearance, keeping the better of the two results.", "description": "Spies are adept at concealing their identities, even if not using a physical disguise. You can reroll any Deception check for the purpose of creating a Deceptive Appearance, keeping the better of the two results.", "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "7c42882a1347ef18", "tags": ["scout", "skills", "social"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Blend In"}]}}, "effects": [{"name": "Blend In (Trained)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.deception.trained", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Blend In", "effectType": "skill-trained"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.blend_in", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a1a905019e7f17c0", "name": "Slippery Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Strike and Run", "benefit": "Once per encounter, you can designate an opponent you have just damaged as a Reaction; that opponent cannot make Attacks of Opportunity against you until the end of your next turn.", "description": {"value": "Once per encounter, you can designate an opponent you have just damaged as a Reaction; that opponent cannot make Attacks of Opportunity against you until the end of your next turn.\n\nYou may use this in conjunction with the Strike and Run Talent, allowing you to benefit from both Talents as a single Reaction."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.strike_and_run"}], "_source": "canonical-csv"}, "treeId": "6367600ed3c0cfae", "tags": ["feat-chain", "scoundrel", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Slippery Strike"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.slippery_strike", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "a1e013f8cfc15a86", "name": "Improved Quick Draw", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you are carrying a Pistol (either in your hand or in a holster), you may draw the Pistol and make a single attack during a Surprise Round, even if you are Surprised.", "description": {"value": "If you are carrying a Pistol (either in your hand or in a holster), you may draw the Pistol and make a single attack during a Surprise Round, even if you are Surprised.\n\nIf you are not Surprised, you may take any single Action of your choice, as normal."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "cb6f775cd227a3e3", "tags": ["ambush", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Improved Quick Draw"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_quick_draw", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a1ef8440f49847f1", "name": "Linebreaker Charge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Bantha Rush Having to protect the passback, the centerbreaker has to leverage their strength to an even greater degree than the linebreakers to keep the defenders at bay. When using the Charge Action, you can move with your opponent while using the Bantha Rush feat. If you have the Improved Bantha Rush feat, you can move with them as many squares as you push them back.", "benefit": "Bantha Rush Having to protect the passback, the centerbreaker has to leverage their strength to an even greater degree than the linebreakers to keep the defenders at bay. When using the Charge Action, you can move with your opponent while using the Bantha Rush feat. If you have the Improved Bantha Rush feat, you can move with them as many squares as you push them back.", "class": "", "category": "", "costNumeric": null, "treeId": "bfc1356c66c74783", "tags": ["action_economy", "charge", "controller", "mobility", "positioning", "scaling", "smashball", "teamwork", "tree_bfc1356c66c74783", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Linebreaker Charge"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a1f7a6ee66410c3e", "name": "Indomitable Will", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Immune to all mind-affecting effects for 1 minute.", "description": "Gain immunity to all mind-affecting effects for 1 minute.", "costNumeric": null, "treeId": "d3661aa9906bdc79", "tags": ["force", "recovery", "resilience", "resource_recovery", "tree_d3661aa9906bdc79", "uncategorized_talent", "will_defense"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Indomitable Will"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.indomitable_will", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a358402a9fc26c02", "name": "Force Perception", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You may spend a Force Point to reroll an Initiative check, keeping the better of the two rolls. Additionally, if you roll a natural 20 on the Initiative check reroll, you immediately regain the Force Point spent to activate this talent. Prerequisite: By focusing on a specific creature in your line of sight, you can gauge how strong in The Force they are. This takes a Standard Action and requires a Use the Force check. If your check result meets or beats the target's Will Defense, you know whether or not they have the Force Sensitivity feat, you know how many Force Powers they know (but not which ones specifically), and you know how many Force Points they currently have. Prerequisites: , Farseeing See also: On the Force, Visions, and Discretion Whenever you use the Farseeing Force Power, you can spend a Force Point as a Swift Action to see into the target's past or future instead of the present. You declare how far into the target's past or future you wish to look, up to a maximum of 1 year per your Character Level. Any information gained about a target's future is subject to change, depending on whether steps are taken to alter that future. Reference Book: Star Wars Saga Edition Force Unleashed Campaign Guide As a Standard Action, you can spend a Force Point to ignore all Concealment for 1 minute. Prerequisites: , Farseeing As a Swift Action, you can peer into the future in search of signs of danger, removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had just activated the Force Power). Any time before the end of your next turn when you are the target of an attack or Force Power, you can force your attacker to reroll the attack roll (or Use the Force check) against you, keeping the second result. This counts as using the Farseeing Force Power against the attacker, but this Talent replaces the normal rules and effect of that Force Power. Reference Book: Star Wars Saga Edition Clone Wars Campaign Guide Prerequisites: , Farseeing When you use the Farseeing Force Power, you can choose to target an object you hold instead of a character or creature. You can look into the targeted item's past, up to a maximum of 5 years per your Character Level. Any information gained about the object's past is based on the thoughts and emotions of the person holding or carrying the object at the time you perceive, which can skew the results of the vision. Reference Book: Star Wars Saga Edition Clone Wars Campaign Guide You can spend a Force Point to gain Low-Light Vision (see Visibility) for 1 minute or until the end of the encounter, whichever is longer. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Jedi Padawans Prerequisites: Once per encounter, you may spend a Force Point to gain a +1 insight bonus to your Reflex Defense and Will Defense for the remainder of the encounter, or until you are knocked unconscious.", "description": "You may spend a Force Point to reroll an Initiative check, keeping the better of the two rolls. Additionally, if you roll a natural 20 on the Initiative check reroll, you immediately regain the Force Point spent to activate this talent. Prerequisite: By focusing on a specific creature in your line of sight, you can gauge how strong in The Force they are. This takes a Standard Action and requires a Use the Force check. If your check result meets or beats the target's Will Defense, you know whether or not they have the Force Sensitivity feat, you know how many Force Powers they know (but not which ones specifically), and you know how many Force Points they currently have. Prerequisites: , Farseeing See also: On the Force, Visions, and Discretion Whenever you use the Farseeing Force Power, you can spend a Force Point as a Swift Action to see into the target's past or future instead of the present. You declare how far into the target's past or future you wish to look, up to a maximum of 1 year per your Character Level. Any information gained about a target's future is subject to change, depending on whether steps are taken to alter that future. Reference Book: Star Wars Saga Edition Force Unleashed Campaign Guide As a Standard Action, you can spend a Force Point to ignore all Concealment for 1 minute. Prerequisites: , Farseeing As a Swift Action, you can peer into the future in search of signs of danger, removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had just activated the Force Power). Any time before the end of your next turn when you are the target of an attack or Force Power, you can force your attacker to reroll the attack roll (or Use the Force check) against you, keeping the second result. This counts as using the Farseeing Force Power against the attacker, but this Talent replaces the normal rules and effect of that Force Power. Reference Book: Star Wars Saga Edition Clone Wars Campaign Guide Prerequisites: , Farseeing When you use the Farseeing Force Power, you can choose to target an object you hold instead of a character or creature. You can look into the targeted item's past, up to a maximum of 5 years per your Character Level. Any information gained about the object's past is based on the thoughts and emotions of the person holding or carrying the object at the time you perceive, which can skew the results of the vision. Reference Book: Star Wars Saga Edition Clone Wars Campaign Guide You can spend a Force Point to gain Low-Light Vision (see Visibility) for 1 minute or until the end of the encounter, whichever is longer. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Jedi Padawans Prerequisites: Once per encounter, you may spend a Force Point to gain a +1 insight bonus to your Reflex Defense and Will Defense for the remainder of the encounter, or until you are knocked unconscious.", "costNumeric": null, "treeId": "d6b4331c0e31f7e3", "tags": ["action_economy", "defender", "force", "force_capacity", "force_defense", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "initiative", "light_side", "mobility", "new_action", "pilot", "precognition", "resource_spend", "scout", "senses", "skills", "standard_action", "stealth", "striker", "support", "swift_action", "tree_d6b4331c0e31f7e3", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 1, "type": "untyped", "predicates": ["defense.reflex", "defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Force Perception"}]}}, "effects": [{"name": "Force Perception (Trained)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.perception.trained", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Perception", "effectType": "skill-trained"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_perception", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["defense.reflex", "defense.will", "turn.once-per-round"]}}}
{"_id": "a36c49bcd3fa4395", "name": "Warrior's Awareness", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "You learn your enemy's preferred tactics quickly. When an enemy character makes a melee attack against you for at least the second time in an encounter, make a Perception check as a Reaction. If the check is successful, you gain a +1 bonus to your Reflex Defense and Fortitude Defense against that character until the end of the encounter.\n\nYou can use this against only one character at a time, until that character is incapacitated or killed, or until you voluntarily switch targets by dropping the use of this Talent for one full round (you can take other Actions normally)."}, "benefit": "You learn your enemy's preferred tactics quickly. When an enemy character makes a melee attack against you for at least the second time in an encounter, make a Perception check as a Reaction. If the check is successful, you gain a +1 bonus to your Reflex Defense and Fortitude Defense against that character until the end of the encounter.", "class": "", "category": "", "costNumeric": null, "treeId": "13776eed744d410c", "tags": ["action_economy", "awareness", "force", "force_defense", "force_offense", "offense_melee", "reaction", "tree_13776eed744d410c", "uncategorized_talent", "warrior", "weapon_training"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Warrior's Awareness"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "a36f9a2eb2424f86", "name": "Amphistaff Block", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Prerequisites: Weapon Focus (Amphistaff), Base Attack Bonus +5", "description": "As a Reaction, you may negate a melee attack by making a successful Initiative check. The DC of the Initiative check is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty on your Initiative check for every time you have used since the beginning of your last turn. You may use this to negate melee Area Attacks. If you succeed on the Initiative check, you take half damage if the attack hits, and no damage if the attack misses. You must have an Amphistaff drawn and in the Quarterstaff or Spear Forms to use this Talent. You must be aware of the attack and not be Flat-Footed. Prerequisites: , Weapon Focus (Amphistaff), Base Attack Bonus +10 Once per encounter, as a Reaction, you may make an Amphistaff attack against a being whose attack you negated using the Talent. You cannot change the Form of the Amphistaff prior to making this attack (meaning, the attack can only be made with the Quarterstaff or Spear Forms of the weapon). Only non-area melee attacks can be riposted in this manner; you cannot use this Talent when negating the damage from melee Area Attacks. You treat an Amphistaff in Spear Form as a Simple Weapon (Ranged), not a Thrown Weapon, for the purposes of determining Range. Additionally, you may recall the thrown Amphistaff as a Swift Action, but it does not return until the end of your next turn. You have learned how to extend the range of an Amphistaff's Spit Venom. The Spit Venom attack range is increased to 20 squares (instead of 10 square), but attacks made beyond 10 squares incur a -2 penalty on the attack roll.", "benefit": "As a Reaction, you may negate a melee attack by making a successful Initiative check. The DC of the Initiative check is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty on your Initiative check for every time you have used since the beginning of your last turn. You may use this to negate melee Area Attacks. If you succeed on the Initiative check, you take half damage if the attack hits, and no damage if the attack misses. You must have an Amphistaff drawn and in the Quarterstaff or Spear Forms to use this Talent. You must be aware of the attack and not be Flat-Footed. Prerequisites: , Weapon Focus (Amphistaff), Base Attack Bonus +10 Once per encounter, as a Reaction, you may make an Amphistaff attack against a being whose attack you negated using the Talent. You cannot change the Form of the Amphistaff prior to making this attack (meaning, the attack can only be made with the Quarterstaff or Spear Forms of the weapon). Only non-area melee attacks can be riposted in this manner; you cannot use this Talent when negating the damage from melee Area Attacks. You treat an Amphistaff in Spear Form as a Simple Weapon (Ranged), not a Thrown Weapon, for the purposes of determining Range. Additionally, you may recall the thrown Amphistaff as a Swift Action, but it does not return until the end of your next turn. You have learned how to extend the range of an Amphistaff's Spit Venom. The Spit Venom attack range is increased to 20 squares (instead of 10 square), but attacks made beyond 10 squares incur a -2 penalty on the attack roll.", "class": "", "category": "", "costNumeric": null, "treeId": "d5b60c4f058c4085", "tags": ["action_economy", "battlefield_control", "block", "controller", "exotic_weapon", "feat_chain", "melee", "melee_defense", "mobility", "offense_melee", "positioning", "ranged", "reaction", "scout", "skills", "striker", "support", "swift_action", "talent_chain", "tree_d5b60c4f058c4085", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 10, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Amphistaff Block"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "a3ab3f2ad47c8775", "name": "Vindication", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Retribution", "benefit": "When an enemy you have damaged is reduced to 0 Hit Points or moved to the bottom of the Condition Track, your next attack made before the end of the encounter deals +1 die of damage.", "description": {"value": "When an enemy you have damaged is reduced to 0 Hit Points or moved to the bottom of the Condition Track, your next attack made before the end of the encounter deals +1 die of damage."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.retribution"}], "_source": "canonical-csv"}, "treeId": "bf3b07c1687a3ca2", "tags": ["condition-removal", "controller", "damage-reduction", "feat-chain", "scoundrel", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "88d35e6c-f119-4a21-b2cf-483748be4875", "name": "Vindication", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Vindication", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.vindication"}}}
{"_id": "a3ac90e84127805d", "name": "Ambush", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dirty Tactics", "benefit": "If you are not surprised, you may forgo your standard action so non-surprised allies in line of sight gain an extra move or may reroll Initiative and keep the better result.", "description": "If you hit an opponent that has not yet acted in combat, deal +2 dice of damage.", "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dirty_tactics"}], "_source": "canonical-csv"}, "treeId": "e91cc675fbf9ba6e", "tags": ["action-economy", "ambush", "controller", "feat-chain", "mobility", "noble", "skills", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.will", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}]}}, "effects": [{"_id": "f6eb1201-2070-44b8-928a-095eb1d1c20a", "name": "Ambush", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.all", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Ambush", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ambush"}}}
{"_id": "a3d0ac66cac192ec", "name": "Hit the Deck", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you make an Area Attack, each ally in the area takes no damage if your attack roll fails to overcome his or her Reflex Defense, and takes half damage if the attack hits.", "description": {"value": "Whenever you make an Area Attack, each ally in the area takes no damage if your attack roll fails to overcome his or her Reflex Defense, and takes half damage if the attack hits."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "4af97ad058b1b30f", "tags": ["battlefield-control", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Hit the Deck"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hit_the_deck", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a3f4bc7671830701", "name": "Team Recruiting", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Recruit Enemy", "benefit": "You can use your Recruit Enemy Talent whenever you or an ally would deal enough damage to kill a target, instead of only when you do.", "description": {"value": "You can use your Recruit Enemy Talent whenever you or an ally would deal enough damage to kill a target, instead of only when you do."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.recruit_enemy"}], "_source": "canonical-csv"}, "treeId": "a2c6962521c29361", "tags": ["feat-chain", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Team Recruiting"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.team_recruiting", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a40e25585a6f8c2b", "name": "Force Deception", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can use your Use the Force modifier instead of your Deception check modifier when making Deception checks, as you use The Force to cloak your vile treachery. You are considered Trained in the Deception skill. If you are entitled to a Deception check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations).", "description": {"value": "You can use your Use the Force modifier instead of your Deception check modifier when making Deception checks, as you use The Force to cloak your vile treachery. You are considered Trained in the Deception skill. If you are entitled to a Deception check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations)."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "d1037bc7a08ea80b", "tags": ["category_sith_apprentice", "controller", "dark_side", "deception", "force", "force_execution", "jedi", "skills", "social", "social_control", "striker", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Force Deception"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_deception", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a45e2213dd7eb4ca", "name": "Urgency", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Impel Ally I, Impel Ally II", "benefit": "Once per encounter, you can spend three Swift Actions on consecutive turns to increase the speed of all allies within your line of sight of you by 2. The increased speed lasts until the start of your next turn after the third Swift Action is spent.", "description": {"value": "Once per encounter, you can spend three Swift Actions on consecutive turns to increase the speed of all allies within your line of sight of you by 2. The increased speed lasts until the start of your next turn after the third Swift Action is spent."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.impel_ally_ii"}], "_source": "canonical-csv"}, "treeId": "560cc7994b357a0d", "tags": ["feat-chain", "mobility", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Urgency"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.urgency", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "a4629f24bd571414", "name": "Mercenary's Determination", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Mercenary's Grit", "benefit": "As a Free Action, on your turn, you can spend a Force Point to double your speed for 1 round. You must wait 5 rounds between each use of this ability.", "description": {"value": "As a Free Action, on your turn, you can spend a Force Point to double your speed for 1 round. You must wait 5 rounds between each use of this ability."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.mercenarys_grit"}], "_source": "canonical-csv"}, "treeId": "4007fa87192b5884", "tags": ["feat-chain", "mobility", "soldier", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Mercenary's Determination"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.mercenarys_determination", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a49074cc564848bb", "name": "Fear Me", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Attract Minion, Inspire Fear I, Inspire Fear II", "benefit": "Such is the fear you instill in your minions that when in your presence, they would rather die than disappoint you. Once per encounter, as a Reaction to one of your minions being moved down the Condition Track, you can reduce the number of steps the minion moves down the Condition Track by 1. Additionally, the target regains Hit Points equal to your Heroic Level. If the target is reduced to 0 Hit Points or moved to the bottom of the Condition Track, you cannot use this Talent on that target.", "description": {"value": "Such is the fear you instill in your minions that when in your presence, they would rather die than disappoint you. Once per encounter, as a Reaction to one of your minions being moved down the Condition Track, you can reduce the number of steps the minion moves down the Condition Track by 1. Additionally, the target regains Hit Points equal to your Heroic Level. If the target is reduced to 0 Hit Points or moved to the bottom of the Condition Track, you cannot use this Talent on that target."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.inspire_fear_ii"}, {"type": "talent", "id": "swse.talent.attract_minion"}], "_source": "canonical-csv"}, "treeId": "c1be604242cb328f", "tags": ["damage-reduction", "feat-chain", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Fear Me"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fear_me", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "a4fca56a9a3853a6", "name": "Squad Actions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Commanding Officer", "benefit": "You and your squad have learned to work together as a team, and have an established set of tactics that you have practiced to perfection. You can use any of the following Actions on your turn.", "description": {"value": "You and your squad have learned to work together as a team, and have an established set of tactics that you have practiced to perfection. You can use any of the following Actions on your turn.\n\nAutofire Barrage: As a Standard Action, you can make an Autofire attack against legal target spaces. For each of your Followers who is armed with a ranged Weapon set on Autofire and has a line of sight to the area targeted by your Autofire, you can designate one additional square as targeted by your Autofire (that square must be adjacent to your original target area).\nOpen Fire: As a Standard Action, make a ranged attack against a single target. For each of your Followers who is armed with a ranged Weapon and has a line of sight to the target, add +2 to your damage roll on a successful hit.\nPainted Target: As a Standard Action, make a ranged attack against a single target. You gain a competence bonus on your attack roll equal to the number of your Followers who are armed with a ranged Weapon and have line of sight to the target. Thus, if you have three armed Followers with line of sight to the target, you gain a +3 competence bonus on your attack roll."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "781feba15dc9e42f", "tags": ["burst-damage", "feat-chain", "positioning", "ranged", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged"], "enabled": true, "priority": 500, "description": "Squad Actions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.squad_actions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": ["attack.with-ranged"]}}}
{"_id": "a52044feeab3fe05", "name": "Coordinate", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "A Noble with this talent has a knack for getting people to work together. When you use this Talent as a Standard Action, all allies within your line of sight grant an additional +1 bonus when they use the Aid Another Action until the start of your next turn.", "description": {"value": "A Noble with this talent has a knack for getting people to work together. When you use this Talent as a Standard Action, all allies within your line of sight grant an additional +1 bonus when they use the Aid Another Action until the start of your next turn.\n\nYou may select this Talent multiple times; each time you do, the bonus granted by the coordinate ability increases by 1 (to a maximum of +5)."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "canonicalName": "Coordinate", "canonicalTree": "Bab +12", "treeId": "5964237d22681dc0", "tags": ["noble", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Coordinate"}]}}, "effects": [{"_id": "25b28077-6a3c-43d8-97ba-a128e768f614", "name": "Coordinate", "icon": "icons/svg/handshake.svg", "changes": [{"key": "system.actions.aidAnother", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Coordinate"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.coordinate", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.423Z", "detectedPredicates": []}}}
{"_id": "a594f0b9ff786a6c", "name": "Preserving Shot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you deal damage with a Vehicle Weapon that is equal to or greater than both the target Vehicle's current Hit Points and the target Vehicle's Damage Threshold (that is, when you would deal enough damage to destroy the target Vehicle), you can choose to use this Talent.", "description": {"value": "When you deal damage with a Vehicle Weapon that is equal to or greater than both the target Vehicle's current Hit Points and the target Vehicle's Damage Threshold (that is, when you would deal enough damage to destroy the target Vehicle), you can choose to use this Talent.\n\nInstead of dealing full damage, you instead deal half damage to your target and move it -1 step along the Condition Track. In addition, you disable the ship's sublight engines and Hyperdrive. The ship cannot move or make a jump to lightspeed until it receives repairs."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "df6678946610c554", "tags": ["controller", "mobility", "ranged", "scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Preserving Shot"}]}}, "effects": [{"_id": "c491d7e1-8ff0-41fe-8b47-8798d26a9786", "name": "Preserving Shot", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.vehicles.disable", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Preserving Shot"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.preserving_shot", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a64632cafe74b864", "name": "Lucky Stop", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Knack", "benefit": "A successful hit against you is mitigated by an item you just happen to be wearing or carrying, or glances off your armor or clothing in just the right way. Once per encounter, as a Reaction, you can negate the damage from a single attack that would normally reduce you to 0 Hit Points.", "description": {"value": "A successful hit against you is mitigated by an item you just happen to be wearing or carrying, or glances off your armor or clothing in just the right way. Once per encounter, as a Reaction, you can negate the damage from a single attack that would normally reduce you to 0 Hit Points."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.knack"}], "_source": "canonical-csv"}, "treeId": "cee9b9398682b7d0", "tags": ["damage-reduction", "feat-chain", "scoundrel", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Lucky Stop"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lucky_stop", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "a64c01df9eba3147", "name": "Masterwork Lightsaber", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you build a Lightsaber (see Advanced Lightsaber Construction), you do so with such expertise that it makes the Weapon even more refined and elegant. When you build a Lightsaber, you can choose to add one extra Lightsaber Accessory or Modification at the time of creation.", "description": {"value": "Whenever you build a Lightsaber (see Advanced Lightsaber Construction), you do so with such expertise that it makes the Weapon even more refined and elegant. When you build a Lightsaber, you can choose to add one extra Lightsaber Accessory or Modification at the time of creation.\n\nAnd, when you hit a target with a Lightsaber that you built, you can always choose to reroll one damage die from your damage roll, but you must accept the result of the reroll, even if it is worse.\n\nIn addition, you can mentor another character while they construct their own Lightsaber. When you do so, you reduce the Use the Force check DC for Advanced Lightsaber Construction by -5."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "76ecaa09bb7619cb", "tags": ["controller", "force", "force-control", "force-offense", "jedi", "light-side", "lightsaber", "melee", "mobility", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Masterwork Lightsaber"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.masterwork_lightsaber", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "a67a1a657fe5665c", "name": "Lead From the Front", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Face the Foe", "benefit": "If you do not have Cover from a target that you damaged with a ranged attack, all your allies gain a +2 morale bonus to attack rolls against that target and a +5 circumstance bonus to opposed Initiative checks against that target until the start of your next turn.", "description": {"value": "If you do not have Cover from a target that you damaged with a ranged attack, all your allies gain a +2 morale bonus to attack rolls against that target and a +5 circumstance bonus to opposed Initiative checks against that target until the start of your next turn."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.face_the_foe"}], "_source": "canonical-csv"}, "treeId": "b7a1211d08826500", "tags": ["feat-chain", "noble", "positioning", "ranged", "scout", "skills", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged"], "enabled": true, "priority": 500, "description": "Lead From the Front"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lead_from_the_front", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.with-ranged"]}}}
{"_id": "a68be9fa4ffe98af", "name": "Zone of Recuperation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Safe Zone", "benefit": "Any ally who catches a Second Wind while within your Safe Zone regains a number of additional Hit Points equal to your Class Level.", "description": {"value": "Any ally who catches a Second Wind while within your Safe Zone regains a number of additional Hit Points equal to your Class Level."}, "class": "4ee81a6708a516cd", "costNumeric": null, "category": "Pathfinder", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.safe_zone"}], "_source": "canonical-csv"}, "treeId": "383ff8d392488cf8", "tags": ["category_pathfinder", "cover", "feat_chain", "mobility", "positioning", "recon", "striker", "support", "survival", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Zone of Recuperation"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.zone_of_recuperation", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "a691cc0212b6176c", "name": "Force Recovery", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Equilibrium, Second Wind", "benefit": "When you use Second Wind, gain additional hit points: 1d6 per Force Point possessed (maximum 10d6).", "description": "When you use Second Wind, gain additional hit points per Force Point you possess.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.equilibrium"}], "_source": "canonical-csv"}, "treeId": "d3661aa9906bdc79", "tags": ["feat_chain", "force", "force_point_spend", "recovery", "resilience", "resource_recovery", "resource_spend", "striker", "talent_chain", "tree_d3661aa9906bdc79", "uncategorized_talent", "will_defense"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Force Recovery"}]}}, "effects": [{"_id": "f8f445aa-d5a2-46b1-b832-c97039ae43fb", "name": "Force Recovery", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.hp.regen", "mode": 2, "value": "1d6_per_fp"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Recovery"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_recovery", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "a6ad65c1275faa33", "name": "Force Treatment", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Use the Force replaces Treat Injury; can treat without a medkit or medpac and is considered trained.", "description": "Use the Force replaces Treat Injury; you may treat without a medkit or medpac.", "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "a2a7a376e4905da9", "tags": ["force", "jedi", "light-side", "skills"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Force Treatment"}]}}, "effects": [{"name": "Force Treatment (Trained)", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.skills.treatInjury.trained", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Treatment", "effectType": "skill-trained"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_treatment", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a6e38142447c64a9", "name": "Ranged Flank", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you are within 6 squares of a target and are armed with a Pistol or a Rifle, you can act as though you occupied the nearest square adjacent to the target for purposes of determining whether or not you or any allies are Flanking that target.", "description": {"value": "If you are within 6 squares of a target and are armed with a Pistol or a Rifle, you can act as though you occupied the nearest square adjacent to the target for purposes of determining whether or not you or any allies are Flanking that target.\n\nYou may only be considered to be Flanking a single target at a time. You must spend a Swift Action on your turn to designate the target you Flank at range."}, "class": "162d866ba36fce69", "costNumeric": null, "category": "Gunslinger", "treeId": "cb6f775cd227a3e3", "tags": ["positioning", "ranged"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Ranged Flank"}]}}, "effects": [{"_id": "f47d6f32-6931-418d-82cb-da5ab21395a9", "name": "Ranged Flank", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.flanking.range", "mode": 2, "value": "6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Ranged Flank"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ranged_flank", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a6fa8cb695f2882c", "name": "Signature Item", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You are famous for using certain items, and you have become skilled at wielding them. You select a single weapon, suit of armor, Vehicle, or other item. While wielding that weapon, wearing that armor, piloting that Vehicle, or otherwise using that item, you gain a +2 morale bonus on opposed Skill Checks.", "description": {"value": "You are famous for using certain items, and you have become skilled at wielding them. You select a single weapon, suit of armor, Vehicle, or other item. While wielding that weapon, wearing that armor, piloting that Vehicle, or otherwise using that item, you gain a +2 morale bonus on opposed Skill Checks.\n\nYou can select this Talent multiple times. Each time you do so, you choose a new object to be your Signature Item. The effects of multiple Signature Items are cumulative with one another, increasing this morale bonus by 1 point each time."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "a47ed82a822e3962", "tags": ["leader", "scaling", "scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Signature Item"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.signature_item", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a76198e5da0f6368", "name": "Echoes in the Force", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Use Farseeing on a location to view the past; DC 20 plus one per day into the past.", "description": "Use Farseeing on a location you are standing in to view past events.", "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "44554c28675292b6", "tags": ["force", "jedi", "light-side"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Echoes in the Force"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.echoes_in_the_force", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a7cb4c0dbcdd0fb8", "name": "Shift", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Move Action, you can move 1 square without provoking an Attack of Opportunity.", "description": {"value": "As a Move Action, you can move 1 square without provoking an Attack of Opportunity."}, "class": "74fa04f5afb5f6e1", "costNumeric": null, "category": "Assassin", "treeId": "186daeee7bd65a69", "tags": ["category_assassin", "controller", "defender", "mobility", "move_action", "precision_damage", "sniping", "stealth", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Shift"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.shift", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "a7d8c4da96eacad4", "name": "Notorious", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When your Minions invoke your name, others take note. If you have Minions, they may reroll any Persuasion checks made to intimidate others, but the result of the reroll must be accepted, even if it is worse. Reference Book: Star Wars Saga Edition Scum and Villainy Prerequisites: , Skill Focus (Persuasion) When you make a successful Persuasion check, you can immediately make a second Persuasion check against the same target, even if it is not normally allowed. The second Persuasion check need not be for the same use of the Persuasion skill as the first. For example, if you successfully Change Attitude of the target, you can immediately attempt to Change Attitude a second time, or you can attempt to Intimidate the target instead. Reference Book: Star Wars Saga Edition Unknown Regions Prerequisites: , Trained in Persuasion You can call in a small favor from someone who owes you. Once per day, make a DC 25 Persuasion check. If the check is successful, an informant gives you information, granting you a +10 competence bonus to one Gather Information or Knowledge check made within the next 24 hours. Reference Book: Star Wars Saga Edition Scum and Villainy", "description": "When your Minions invoke your name, others take note. If you have Minions, they may reroll any Persuasion checks made to intimidate others, but the result of the reroll must be accepted, even if it is worse. Reference Book: Star Wars Saga Edition Scum and Villainy Prerequisites: , Skill Focus (Persuasion) When you make a successful Persuasion check, you can immediately make a second Persuasion check against the same target, even if it is not normally allowed. The second Persuasion check need not be for the same use of the Persuasion skill as the first. For example, if you successfully Change Attitude of the target, you can immediately attempt to Change Attitude a second time, or you can attempt to Intimidate the target instead. Reference Book: Star Wars Saga Edition Unknown Regions Prerequisites: , Trained in Persuasion You can call in a small favor from someone who owes you. Once per day, make a DC 25 Persuasion check. If the check is successful, an informant gives you information, granting you a +10 competence bonus to one Gather Information or Knowledge check made within the next 24 hours. Reference Book: Star Wars Saga Edition Scum and Villainy", "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "c1be604242cb328f", "tags": ["leader", "scoundrel", "skills", "social", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Notorious"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.notorious", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a810b68876f7e44e", "name": "Intimate Knowledge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Surveillance", "benefit": "Experienced spies and Scouts remember many details from previous assignments, providing insights on later missions. Once per encounter as a Standard Action, you can Take 20 on a check involving a Knowledge skill you are Trained in, or Take 10 on a check involving a Knowledge skill you are Untrained in, even if circumstances would not normally allow you to Take 10 or Take 20.", "description": {"value": "Experienced spies and Scouts remember many details from previous assignments, providing insights on later missions. Once per encounter as a Standard Action, you can Take 20 on a check involving a Knowledge skill you are Trained in, or Take 10 on a check involving a Knowledge skill you are Untrained in, even if circumstances would not normally allow you to Take 10 or Take 20."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.surveillance"}], "_source": "canonical-csv"}, "treeId": "7c42882a1347ef18", "tags": ["feat-chain", "scout", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Intimate Knowledge"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.intimate_knowledge", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "a8347dda0f619f2d", "name": "Adversary Lore", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can peer into The Force and search for weaknesses in the defenses of your enemies. Make a Use the Force check against the Will Defense of a target creature within 12 squares of you and in your line of sight.", "description": {"value": "As a Standard Action, you can peer into The Force and search for weaknesses in the defenses of your enemies. Make a Use the Force check against the Will Defense of a target creature within 12 squares of you and in your line of sight.\n\nIf the Skill Check equals or exceeds the target's Will Defense, that target takes a -2 penalty to their Reflex Defense against you and all allies who can hear and understand you until the end of your next turn."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "e99cfa9db8493573", "tags": ["action-economy", "feat-chain", "force", "force-offense", "jedi", "light-side", "mobility", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Adversary Lore"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.adversary_lore", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "a86559a808738c98", "name": "Biotech Adept", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can reroll any Knowledge (Life Science) check, or Treat Injury checks made for Biotech Repair, but you must accept the result of the reroll, even if it is worse.", "description": {"value": "You can reroll any Knowledge (Life Science) check, or Treat Injury checks made for Biotech Repair, but you must accept the result of the reroll, even if it is worse."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "33c3210fcac8c664", "tags": ["mechanics", "scoundrel", "skills"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Biotech Adept"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.biotech_adept", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a8973662a2f1cf0f", "name": "Spotter", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Move Action, you can make a Perception check with a DC equal to 10 + the CL of a single target enemy in your line of sight. If you succeed on the check, you and all your allies that can hear and understand you gain a +1 insight bonus on attack rolls against that target until the end of your next turn.", "description": {"value": "As a Move Action, you can make a Perception check with a DC equal to 10 + the CL of a single target enemy in your line of sight. If you succeed on the check, you and all your allies that can hear and understand you gain a +1 insight bonus on attack rolls against that target until the end of your next turn."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "127a55c242e031f2", "tags": ["action-economy", "ambush", "melee", "perception", "positioning", "ranged", "scout", "skills", "stealth", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 5, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Spotter"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.spotter", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged"]}}}
{"_id": "a9a84d42b75f4fb1", "name": "Lesser Mark of Illumination", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Those who have been illuminated can withstand immense physical pain and torture. You are granted a bonus to your Damage Threshold equal to your Wisdom modifier. Prerequisites: , Greater Mark of Illumination Achievers of Chalactan Enlightenment are masters of within. You may spend a Force Point to become immune to all Mind-Affecting effects for the remainder of the encounter.", "benefit": "Those who have been illuminated can withstand immense physical pain and torture. You are granted a bonus to your Damage Threshold equal to your Wisdom modifier. Prerequisites: , Greater Mark of Illumination Achievers of Chalactan Enlightenment are masters of within. You may spend a Force Point to become immune to all Mind-Affecting effects for the remainder of the encounter.", "class": "", "category": "", "costNumeric": null, "treeId": "f3881205595248d4", "tags": ["defender", "force", "force_item", "force_offense", "force_point_spend", "illumination", "leader", "light_side", "resource_spend", "striker", "tree_f3881205595248d4", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Lesser Mark of Illumination"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "a9d5820271b1488b", "name": "Forewarn Allies", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": ""}, "benefit": "Once per turn, as a Swift Action, designate a 3x3 square area within your line of sight. Until the end of your next turn, if a target moves into that area you can enable one ally within your line of sight to make an Attack of Opportunity against that target. The ally you choose must be armed with a Weapon capable of making Attacks of Opportunity, and this counts toward the ally's normal limitations for Attacks of Opportunity made in a round.", "class": "", "category": "", "costNumeric": null, "treeId": "3a785c985eae4d00", "tags": ["action_economy", "ally_support", "ambush_defense", "battlefield_control", "controller", "mobility", "positioning", "reaction", "support", "sustained_damage", "swift_action", "tree_3a785c985eae4d00", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Forewarn Allies"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "aa2a3697eeab3e35", "name": "Blaster Turret III", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Blaster Turret I, Blaster Turret II", "benefit": "Your Turret gains the ability to fire twice per round, with a -5 penalty on each attack roll, and gains Damage Reduction 5.", "description": {"value": "Your Turret gains the ability to fire twice per round, with a -5 penalty on each attack roll, and gains Damage Reduction 5."}, "class": "de3f367749b82fcf", "costNumeric": null, "category": "Saboteur", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.blaster_turret_ii"}], "_source": "canonical-csv"}, "treeId": "92b30151b9b21109", "tags": ["feat-chain", "perception", "positioning", "ranged", "skills", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Blaster Turret III"}]}}, "effects": [{"_id": "16e4f0b4-fb25-4045-b580-216ea9304f44", "name": "Blaster Turret III", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.actions.turret", "mode": 5, "value": "advanced"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Blaster Turret III"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.blaster_turret_iii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "aa32a31a179fe5c1", "name": "Impel Ally I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can spend a Swift Action to grant one ally the ability to move its normal speed. The ally must move immediately on your turn, before you do anything else, or else the opportunity is wasted. You can use this Talent up to three times on your turn (spending a Swift Action each time).", "description": {"value": "You can spend a Swift Action to grant one ally the ability to move its normal speed. The ally must move immediately on your turn, before you do anything else, or else the opportunity is wasted. You can use this Talent up to three times on your turn (spending a Swift Action each time)."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "treeId": "560cc7994b357a0d", "tags": ["action-economy", "controller", "leader", "mobility", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Impel Ally I"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.impel_ally_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "aa39089c21cf488f", "name": "Pinning Shot", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Precision Shot", "description": {"value": "You can keep your target worrying about where the next shot is coming from instead of trying to flee. When you deal damage to an enemy that you have Aimed at, the target's speed is reduced to 2 squares, and the target cannot take either a Double Move Action or use the Run Action until the end of your next turn.\n\nThis is a Stunning effect."}, "benefit": "You can keep your target worrying about where the next shot is coming from instead of trying to flee. When you deal damage to an enemy that you have Aimed at, the target's speed is reduced to 2 squares, and the target cannot take either a Double Move Action or use the Run Action until the end of your next turn.", "class": "", "category": "", "costNumeric": null, "treeId": "d203a51d6d0a4c65", "tags": ["action_economy", "controller", "move_action", "offense_ranged", "positioning", "ranged", "sniping", "striker", "targeting", "tree_d203a51d6d0a4c65", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged"], "enabled": true, "priority": 500, "description": "Pinning Shot"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.with-ranged"]}}}
{"_id": "aa5b9fe99274274a", "name": "Prepared for Danger", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Farseeing", "benefit": "Whenever you have at least one unspent Farseeing Force Power in your Force Power Suite, you can spend that Farseeing Force Power to regain any one other Force Power as a Swift Action.", "description": {"value": "Whenever you have at least one unspent Farseeing Force Power in your Force Power Suite, you can spend that Farseeing Force Power to regain any one other Force Power as a Swift Action."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "44554c28675292b6", "tags": ["force", "jedi", "light-side"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Prepared for Danger"}]}}, "effects": [{"_id": "0f030bee-3296-4c23-baea-bfc611451fef", "name": "Prepared for Danger", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.forcePoints.recovery", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Prepared for Danger"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.prepared_for_danger", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "aa964478cf5b30e8", "name": "Virus", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Electronic Sabotage, Trained in Use Computer", "benefit": "You can substitute a Use Computer check for a Mechanics check when disabling a computerized device. The effort takes 1 minute and the DC is equal to the computer's Will Defense. In addition, whenever anyone accesses the afflicted computer using a Droid or another computer, that computer or Droid's Attitude immediately becomes Unfriendly.", "description": {"value": "You can substitute a Use Computer check for a Mechanics check when disabling a computerized device. The effort takes 1 minute and the DC is equal to the computer's Will Defense. In addition, whenever anyone accesses the afflicted computer using a Droid or another computer, that computer or Droid's Attitude immediately becomes Unfriendly."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.electronic_sabotage"}], "_source": "canonical-csv"}, "treeId": "64874e65579e4cf4", "tags": ["defender", "feat-chain", "mechanics", "scoundrel", "skills", "slicing", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Virus"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.virus", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "aa9b67c6737c2549", "name": "Attune Weapon", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You may spend a Force Point to attune a melee weapon. Attuning the weapon takes a Full-Round Action. From that point forward, whenever you wield the attuned weapon, you gain a +1 Force bonus on attack rolls.", "description": {"value": "You may spend a Force Point to attune a melee weapon. Attuning the weapon takes a Full-Round Action. From that point forward, whenever you wield the attuned weapon, you gain a +1 Force bonus on attack rolls.\n\nThe weapon is attuned to you alone; others who wield the weapon do not gain the Force bonus."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "treeId": "01e443d93e47f9c4", "tags": ["alchemy", "category_force_adept", "controller", "crafting", "empowerment", "force", "force_capacity", "force_execution", "force_offense", "force_point_spend", "force_training", "leader", "melee", "mystic", "resource_spend", "striker", "tree_01e443d93e47f9c4"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Attune Weapon"}]}}, "effects": [{"_id": "1fd6da0e-f546-4a44-a963-338b37a13313", "name": "Attune Weapon", "icon": "icons/svg/sword.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Attune Weapon"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.attune_weapon", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "aacde500ec811cd4", "name": "Fortune's Favor", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Whenever you score a Critical Hit with a melee or ranged attack, you gain a free Standard Action. You must take the extra Standard Action before the end of your turn, or else it is lost.", "description": {"value": "Whenever you score a Critical Hit with a melee or ranged attack, you gain a free Standard Action. You must take the extra Standard Action before the end of your turn, or else it is lost."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "cee9b9398682b7d0", "tags": ["action-economy", "precision", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Fortune's Favor"}]}}, "effects": [{"_id": "1318c3b8-7232-43b2-8a09-ec77ce56584f", "name": "Fortune's Favor", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.actions.free_standard", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Fortune's Favor"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fortunes_favor", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": ["attack.when-hit"]}}}
