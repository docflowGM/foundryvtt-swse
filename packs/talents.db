{"_id": "974c24246ed2b972", "name": "Distress to Discord", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You encourage your allies to sow discord among your enemies by fighting with renewed vigor. Whenever an ally within your line of sight takes its Second Wind, all enemies within 2 squares of that ally lose their Dexterity bonuses to their Reflex Defense until the end of your next turn.", "description": {"value": "You encourage your allies to sow discord among your enemies by fighting with renewed vigor. Whenever an ally within your line of sight takes its Second Wind, all enemies within 2 squares of that ally lose their Dexterity bonuses to their Reflex Defense until the end of your next turn."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "da34105c875650ae", "tags": ["action-economy", "condition-removal", "controller", "damage-reduction", "mobility", "noble", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Distress to Discord"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.distress_to_discord", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "976c36831fecbd2b", "name": "Blaster and Blade I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dual Weapon Mastery I, Weapon Proficiency (Advanced Melee Weapons), Weapon Proficiency (Pistols)", "benefit": "When you make a single attack with an Advanced Melee Weapon as a Standard Action, you can immediately make an attack with a Pistol as a Free Action, provided you have both the Advanced Melee Weapon and the Pistol in your hands when the melee attack is made. You apply the normal penalties for fighting with two weapons to both of these attacks.", "description": {"value": "When you make a single attack with an Advanced Melee Weapon as a Standard Action, you can immediately make an attack with a Pistol as a Free Action, provided you have both the Advanced Melee Weapon and the Pistol in your hands when the melee attack is made. You apply the normal penalties for fighting with two weapons to both of these attacks."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "df6678946610c554", "tags": ["action-economy", "burst-damage", "condition-removal", "controller", "damage-reduction", "defender", "dual-wield", "mechanics", "melee", "mobility", "positioning", "ranged", "scaling", "scoundrel", "skills", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 1, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Blaster and Blade I"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.blaster_and_blade_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "attack.with-ranged"]}}}
{"_id": "9780298d28d64954", "name": "Centerbreaker Charge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Improved Bantha Rush You are a legendary linebreaker in the smashball arena, your skill on either side worthy of the Suktub Trophy. You can do each of the following abilities once per encounter: Make a Charge attack. The distance you push a target with Improved Bantha Rush is a number of squares equal to your Strength modifier. Make a Charge attack. You can make Acrobatics checks to Tumble through Threatened Areas or an enemy's Fighting Space when you Charge. This does not count as Difficult Terrain; however, the DC to Tumble increases by 2 for each additional Threatened Area or enemy's Fighting Space you Tumble through. Make a Charge attack. At the end of the Charge, if you succeed on a Grab or Grapple check, the defender may not attempt to escape the Grab or Grapple until after the end of your next turn.", "benefit": "Improved Bantha Rush You are a legendary linebreaker in the smashball arena, your skill on either side worthy of the Suktub Trophy. You can do each of the following abilities once per encounter: Make a Charge attack. The distance you push a target with Improved Bantha Rush is a number of squares equal to your Strength modifier. Make a Charge attack. You can make Acrobatics checks to Tumble through Threatened Areas or an enemy's Fighting Space when you Charge. This does not count as Difficult Terrain; however, the DC to Tumble increases by 2 for each additional Threatened Area or enemy's Fighting Space you Tumble through. Make a Charge attack. At the end of the Charge, if you succeed on a Grab or Grapple check, the defender may not attempt to escape the Grab or Grapple until after the end of your next turn.", "class": "", "category": "", "costNumeric": null, "treeId": "bfc1356c66c74783", "tags": ["battlefield_control", "charge", "controller", "mobility", "positioning", "scaling", "smashball", "striker", "teamwork", "tree_bfc1356c66c74783", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Centerbreaker Charge"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "97a771d1f4627521", "name": "Dark Side Bane", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dark Side Sense", "benefit": "When you use a damage-dealing Force Power against a creature with a Dark Side Score of 1 or higher, you deal extra damage on a successful hit equal to your Charisma bonus (minimum +1).", "description": {"value": "When you use a damage-dealing Force Power against a creature with a Dark Side Score of 1 or higher, you deal extra damage on a successful hit equal to your Charisma bonus (minimum +1)."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dark_side_sense"}], "_source": "canonical-csv"}, "treeId": "36f18f3e974feb33", "tags": ["dark-side", "feat-chain", "force", "force-offense", "jedi", "light-side", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Dark Side Bane"}]}}, "effects": [{"_id": "8d67d93e-3514-4813-83be-682a025dd5f8", "name": "Dark Side Bane", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.force", "mode": 2, "value": "1d6"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Dark Side Bane"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_side_bane", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": []}}}
{"_id": "97eeb67b9428f0eb", "name": "Reset Initiative", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Acute Senses, Improved Initiative, Trained in Initiative", "benefit": "Once per encounter, at any time after the first round (that is, the first full round after the Surprise Round, if one occurs), you can set your Initiative Count to your current Initiative +5.", "description": {"value": "Once per encounter, at any time after the first round (that is, the first full round after the Surprise Round, if one occurs), you can set your Initiative Count to your current Initiative +5."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.improved_initiative"}], "_source": "canonical-csv"}, "treeId": "1c48d1cd9ab1f5c8", "tags": ["feat-chain", "scout", "skills", "striker", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 5, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Reset Initiative"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.reset_initiative", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "97faaefe3487494c", "name": "Medical Droid", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Knowledge (Life Sciences)", "description": "As a Full-Round Action, you can make a DC 15 Treat Injury check on an adjacent living creature to move it +1 step along the Condition Track. You can create an aura of unliving, emotionless, menace that no biological creature can match, and combine it with the cruel application of medical knowledge. You can use your Treat Injury modifier on a Persuasion check made to change a creature's Attitude, or to Intimidate. You must be adjacent to your target to use this ability, in addition to the normal requirements for these uses of the Persuasion Skill. When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains 2 Hit Points for every point by which your check exceeds the DC (rather than the normal 1 Hit Point). Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids You know the vulnerable spots to hit on most Species. As a Free Action, you make a DC 15 Knowledge (Life Sciences) check (DC 25 for rare Species, DC 35 for unknown Species, both as determined by the Gamemaster). If the check is successful, until the end of the encounter, whenever you make a successful melee or Unarmed attack that deals damage against a target of that Species, your target takes a -2 penalty to attack rolls until the end of your next turn. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids Prerequisites: , Trained in Knowledge (Life Sciences) You use your medical knowledge and advanced Droid processor to improve your treatment of medical conditions. When making a Treat Injury check to Treat Disease, Treat Poison, or Treat Radiation, you can also add your Intelligence modifier to your roll. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids You use your extensive databanks to better analyze scientific data. You can add double your Intelligence modifier to your Knowledge (Life Sciences) and Knowledge (Physical Sciences) skill checks. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids Prerequisites: , Trained in Treat Injury As a Standard Action, you can make a DC 20 Treat Injury check. If the check succeeds, you know if the organic characters within 6 squares and within your line of sight are below one half of their Hit Points and at what step they are along the Condition Track.", "benefit": "As a Full-Round Action, you can make a DC 15 Treat Injury check on an adjacent living creature to move it +1 step along the Condition Track. You can create an aura of unliving, emotionless, menace that no biological creature can match, and combine it with the cruel application of medical knowledge. You can use your Treat Injury modifier on a Persuasion check made to change a creature's Attitude, or to Intimidate. You must be adjacent to your target to use this ability, in addition to the normal requirements for these uses of the Persuasion Skill. When you use a Medpac to perform First Aid with the Treat Injury skill, the creature gains 2 Hit Points for every point by which your check exceeds the DC (rather than the normal 1 Hit Point). Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids You know the vulnerable spots to hit on most Species. As a Free Action, you make a DC 15 Knowledge (Life Sciences) check (DC 25 for rare Species, DC 35 for unknown Species, both as determined by the Gamemaster). If the check is successful, until the end of the encounter, whenever you make a successful melee or Unarmed attack that deals damage against a target of that Species, your target takes a -2 penalty to attack rolls until the end of your next turn. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids Prerequisites: , Trained in Knowledge (Life Sciences) You use your medical knowledge and advanced Droid processor to improve your treatment of medical conditions. When making a Treat Injury check to Treat Disease, Treat Poison, or Treat Radiation, you can also add your Intelligence modifier to your roll. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids You use your extensive databanks to better analyze scientific data. You can add double your Intelligence modifier to your Knowledge (Life Sciences) and Knowledge (Physical Sciences) skill checks. Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids Prerequisites: , Trained in Treat Injury As a Standard Action, you can make a DC 20 Treat Injury check. If the check succeeds, you know if the organic characters within 6 squares and within your line of sight are below one half of their Hit Points and at what step they are along the Condition Track.", "class": "", "category": "", "costNumeric": null, "treeId": "a212850887fe41da", "tags": ["action_economy", "condition_removal", "control", "controller", "droid", "feat_chain", "healing", "investigation", "knowledge", "martial_arts", "medical", "medicine", "melee", "mobility", "new_action", "offense_melee", "persuasion", "poison", "positioning", "scaling", "skills", "social", "standard_action", "striker", "support", "sustained_damage", "talent_chain", "trap", "tree_a212850887fe41da", "unarmed", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 1, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee"], "enabled": true, "priority": 500, "description": "Medical Droid"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee"]}}}
{"_id": "98355ed4f6473028", "name": "Armored Augmentation I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Armor Proficiency with Armor", "benefit": "Once per encounter, you may spend a Force Point as a Swift Action to augment your own ability to withstand damage by imbuing the Armor you are wearing with The Force. This allows you to add your Armor bonus to your Reflex Defense to your Damage Threshold until the end of the encounter.", "description": {"value": "Once per encounter, you may spend a Force Point as a Swift Action to augment your own ability to withstand damage by imbuing the Armor you are wearing with The Force. This allows you to add your Armor bonus to your Reflex Defense to your Damage Threshold until the end of the encounter."}, "class": "ec505163e5647cc6", "costNumeric": null, "category": "Imperial Knight", "treeId": "ea01d740c91888b3", "tags": ["action_economy", "armor", "category_imperial_knight", "damage_reduction", "defender", "defense", "feat_chain", "force", "force_point_spend", "imperial", "leader", "lightsaber", "resource_spend", "striker", "swift_action", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 2, "type": "untyped", "predicates": ["defense.fortitude"], "enabled": true, "priority": 500, "description": "Armored Augmentation I"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.armored_augmentation_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.422Z", "detectedPredicates": ["defense.fortitude"]}}}
