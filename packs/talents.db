{"_id": "89a8c710bb68901c", "name": "Dark Healing Field", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dark Healing, Improved Dark Healing", "benefit": "You can spend a Force Point to heal wounds by drawing life energy from up to three targeted creatures within 12 squares of you. Once per encounter, you can make a Use the Force check. If the check result equals or exceeds a target's Fortitude Defense, the target takes 1d6 points of Force damage per every Sith Apprentice and Sith Lord Class Level you possess.", "description": {"value": "You can spend a Force Point to heal wounds by drawing life energy from up to three targeted creatures within 12 squares of you. Once per encounter, you can make a Use the Force check. If the check result equals or exceeds a target's Fortitude Defense, the target takes 1d6 points of Force damage per every Sith Apprentice and Sith Lord Class Level you possess.\n\nYou heal half the total damage dealt (cumulative from all targets). If the attack fails, the target takes half damage, and you heal that amount."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "d1037bc7a08ea80b", "tags": ["category_sith_apprentice", "controller", "dark_side", "feat_chain", "force", "force_execution", "force_offense", "force_point_spend", "force_support", "healing", "jedi", "medicine", "positioning", "resource_spend", "skills", "striker", "support", "talent_chain", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Dark Healing Field"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_healing_field", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.420Z", "detectedPredicates": ["turn.once-per-round"]}}}
