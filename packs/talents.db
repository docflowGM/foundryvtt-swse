{"_id": "001ae84d5862af55", "name": "Oath of Duty", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When an ally within 12 squares of you and within your line of sight hits with a Lightsaber attack, you gain bonus Hit Points equal to 3 x your Class Level until the end of your next turn. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from different sources do not stack.", "description": {"value": "When an ally within 12 squares of you and within your line of sight hits with a Lightsaber attack, you gain bonus Hit Points equal to 3 x your Class Level until the end of your next turn. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from different sources do not stack."}, "class": "ec505163e5647cc6", "costNumeric": null, "category": "Imperial Knight", "treeId": "8048efd85ae61101", "tags": ["category_imperial_knight", "defense", "force", "imperial", "leader", "lightsaber", "melee", "offense_melee", "positioning", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Oath of Duty"}]}}, "effects": [{"_id": "1514641e-7c47-4b9c-9aff-d3020b04ca63", "name": "Oath of Duty", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.hp.regen", "mode": 2, "value": "3_per_level"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Oath of Duty"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.oath_of_duty", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "008b28849b74234d", "name": "Dark Healing", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can spend a Force Point to heal wounds by drawing life energy from another creature within 6 squares of you. Using this ability is a Standard Action, and you must succeed on a ranged attack roll. If the attack equals or exceeds the target's Fortitude Defense, you deal 1d6 points of damage per Class Level to the target, and you heal an equal amount of damage. If the attack fails, there is no effect.", "description": {"value": "You can spend a Force Point to heal wounds by drawing life energy from another creature within 6 squares of you. Using this ability is a Standard Action, and you must succeed on a ranged attack roll. If the attack equals or exceeds the target's Fortitude Defense, you deal 1d6 points of damage per Class Level to the target, and you heal an equal amount of damage. If the attack fails, there is no effect."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "d1037bc7a08ea80b", "tags": ["category_sith_apprentice", "controller", "dark_side", "defender", "force", "force_defense", "force_execution", "force_offense", "force_point_spend", "force_support", "healing", "jedi", "medicine", "new_action", "offense_ranged", "positioning", "resource_spend", "scaling", "skills", "standard_action", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 2, "type": "untyped", "predicates": ["defense.fortitude", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Dark Healing"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_healing", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["defense.fortitude", "turn.once-per-round"]}}}
{"_id": "00a9210772a64a19", "name": "Weapon Specialization (Lightsabers)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Focus (Lightsabers)", "description": {"value": "You gain a +2 bonus on melee damage rolls with Lightsabers."}, "benefit": "You gain a +2 bonus on melee damage rolls with Lightsabers.", "class": "", "category": "", "costNumeric": null, "treeId": "b3c5d90b5036f39b", "tags": ["burst_damage", "condition_removal", "controller", "damage_reduction", "damage_scaling", "defender", "force", "force_control", "force_offense", "leader", "lightsaber", "melee", "mobility", "offense_melee", "scaling", "striker", "sustained_damage", "uncategorized_talent", "weapon_specialization"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "target.is-prone"], "enabled": true, "priority": 500, "description": "Weapon Specialization (Lightsabers)"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "target.is-prone"]}}}
{"_id": "00c3231e4a4173fa", "name": "Noble Fencing Style", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Deception and Persuasion", "benefit": "This style of swordplay uses wit and force of personality to increase accuracy, taunting and distracting an opponent with feints, misdirection, and deception. When using a light melee weapon or a Lightsaber that you are proficient with, you can use your Charisma modifier instead of your Strength modifier on attack rolls.", "description": {"value": "This style of swordplay uses wit and force of personality to increase accuracy, taunting and distracting an opponent with feints, misdirection, and deception. When using a light melee weapon or a Lightsaber that you are proficient with, you can use your Charisma modifier instead of your Strength modifier on attack rolls."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "deceptionandpersuasion"}], "_source": "fix2-auto"}, "treeId": "9df067790c87e6bc", "tags": ["action-economy", "controller", "melee", "mobility", "noble", "positioning", "skills", "social", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 5, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Noble Fencing Style"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.noble_fencing_style", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "00deb8b4cce303b6", "name": "Force Intuition", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can use your Use the Force check modifier instead of your Initiative modifier when making Initiative checks. You are considered Trained in the Initiative skill. If you are entitled to an Initiative check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations).", "description": {"value": "You can use your Use the Force check modifier instead of your Initiative modifier when making Initiative checks. You are considered Trained in the Initiative skill. If you are entitled to an Initiative check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations).\n\nYou may use this Talent to determine the Initiative of a Starship if you are the Pilot."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "10c843cef8ce2798", "tags": ["dark-side", "force", "force-offense", "jedi", "light-side", "scout", "skills", "striker", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 5, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Force Intuition"}]}}, "effects": [{"_id": "8af800f1-3dbf-4a6b-8205-9eeb391a5869", "name": "Force Intuition", "icon": "icons/svg/brain.svg", "changes": [{"key": "system.skills.initiative.trained", "mode": 5, "value": "true", "priority": 20}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Force Intuition"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_intuition", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "014d291a6e16cc12", "name": "Friend or Foe", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Cast Suspicion", "benefit": "Whenever an ally within your line of sight is missed by a ranged attack, you can (as a Reaction, once per turn) designate one enemy adjacent to that ally. Compare the attack roll of the missed attack to the Reflex Defense of that enemy; if the attack would hit, the attack targets that enemy and is resolved as normal.", "description": {"value": "Whenever an ally within your line of sight is missed by a ranged attack, you can (as a Reaction, once per turn) designate one enemy adjacent to that ally. Compare the attack roll of the missed attack to the Reflex Defense of that enemy; if the attack would hit, the attack targets that enemy and is resolved as normal."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.cast_suspicion"}], "_source": "canonical-csv"}, "treeId": "da34105c875650ae", "tags": ["feat-chain", "noble", "positioning", "ranged", "striker", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Friend or Foe"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.friend_or_foe", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["attack.when-hit", "attack.with-ranged"]}}}
{"_id": "0178e98b17ab2bcc", "name": "Force Warning", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Allies within 12 squares can choose to reroll their Initiative checks at the start of combat, but must keep the result of the reroll, even if it is worse.", "description": {"value": "Allies within 12 squares can choose to reroll their Initiative checks at the start of combat, but must keep the result of the reroll, even if it is worse.\n\nFurthermore, if any allies within 12 squares are Surprised at the start of an encounter, but you are not, you can designate a number of those allies equal to your Wisdom modifier (minimum 1); those allies are no longer considered Surprised, and can act normally during the Surprise Round."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "77e3817ba5cfa0d5", "tags": ["action-economy", "ambush", "controller", "force", "force-control", "jedi", "light-side", "mobility", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Force Warning"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_warning", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": []}}}
{"_id": "01bcee2365b82ce6", "name": "Unreadable", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You gain a +5 bonus to your Will Defense against Skill Checks made to read your emotions and influence your Attitude. In addition, whenever you successfully Feint a target in combat, that target is Flat-Footed against all your attacks until the end of your next turn.", "description": {"value": "You gain a +5 bonus to your Will Defense against Skill Checks made to read your emotions and influence your Attitude. In addition, whenever you successfully Feint a target in combat, that target is Flat-Footed against all your attacks until the end of your next turn."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "e91cc675fbf9ba6e", "tags": ["controller", "defender", "noble", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.will", "type": "untyped", "value": 5, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.will"}]}}, "effects": [{"_id": "2eebd8ab-208e-47f3-9fef-94255136aabc", "name": "Unreadable", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.will", "mode": 2, "value": "5"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Unreadable", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unreadable"}}}
{"_id": "028e4e50565971ee", "name": "Temporal Awareness", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Findsman Ceremonies", "benefit": "Once per encounter when attacked, you can move your speed as an immediate reaction.", "description": {"value": ""}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.findsman_ceremonies"}], "_source": "canonical-csv"}, "treeId": "022b31d355c840a9", "tags": ["action-economy", "controller", "feat-chain", "mobility", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Temporal Awareness"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.temporal_awareness", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "0290634450ab1637", "name": "Electronic Sabotage", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Use Computer", "benefit": "You excel at causing havoc with computers and electronics. As a Standard Action, you can lock down a computer terminal by making a Use Computer check, making it potentially difficult for anyone else to access. That computer is considered Unfriendly to anyone other than you who attempts to use it, and the result of your Use Computer check replaces the computer's Will Defense on an attempt to change its Attitude.", "description": {"value": "You excel at causing havoc with computers and electronics. As a Standard Action, you can lock down a computer terminal by making a Use Computer check, making it potentially difficult for anyone else to access. That computer is considered Unfriendly to anyone other than you who attempts to use it, and the result of your Use Computer check replaces the computer's Will Defense on an attempt to change its Attitude.\n\nThis effect ends if anyone else succeeds in adjusting the computer's Attitude to Indifferent. You cannot Take 20 on this Use Computer check."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "usecomputer"}], "_source": "fix5F-canonical"}, "treeId": "64874e65579e4cf4", "tags": ["defender", "mechanics", "scoundrel", "skills", "slicing"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Electronic Sabotage"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.electronic_sabotage", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "02bf213d8104b017", "name": "Unbalancing Adaptation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Adapt and Survive", "benefit": "When you use the Adapt and Survive Talent, you also deny the target the bonus that triggered the Talent to one enemy within your line of sight.", "description": {"value": "When you use the Adapt and Survive Talent, you also deny the target the bonus that triggered the Talent to one enemy within your line of sight."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.adapt_and_survive"}], "_source": "canonical-csv"}, "treeId": "ab2c265c4b2f54f6", "tags": ["feat-chain", "scout", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "7c7bd68c-58e8-4cbb-bd0e-5ffa713d6184", "name": "Unbalancing Adaptation", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Unbalancing Adaptation", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unbalancing_adaptation"}}}
{"_id": "02c69474cc7bbedd", "name": "Dual Weapon Flourish II", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dual Weapon Mastery I, Dual Weapon Mastery II, Dual Weapon Flourish I, Master of Elegance, Weapon Finesse", "benefit": "When wielding only two light melee weapons or two Lightsabers, once per turn on your turn, you can make a Full Attack Action as a Standard Action, rather than a Full-Round Action, provided you attack with both weapons during the attack. You apply the normal penalties for fighting with two weapons to both of these attacks.", "description": {"value": "When wielding only two light melee weapons or two Lightsabers, once per turn on your turn, you can make a Full Attack Action as a Standard Action, rather than a Full-Round Action, provided you attack with both weapons during the attack. You apply the normal penalties for fighting with two weapons to both of these attacks."}, "class": "d87c05d2a34f5627", "costNumeric": null, "category": "Melee Duelist", "treeId": "1381bb8c9a838279", "tags": ["action-economy", "dual-wield", "feat-chain", "lightsaber", "melee", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Dual Weapon Flourish II"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dual_weapon_flourish_ii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "032242fb87215e06", "name": "Weapon Shift", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Gun Club", "benefit": "If you use a Ranged Weapon as a Melee Weapon (as with the Gun Club Talent), you gain a +2 bonus to melee attack rolls with that Weapon.", "description": {"value": "If you use a Ranged Weapon as a Melee Weapon (as with the Gun Club Talent), you gain a +2 bonus to melee attack rolls with that Weapon."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.gun_club"}], "_source": "canonical-csv"}, "treeId": "cb3751283ea8fa3d", "tags": ["feat-chain", "melee", "positioning", "ranged", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Weapon Shift"}]}}, "effects": [{"_id": "515a6c50-3236-4ed6-aeeb-6e2c83f033a0", "name": "Weapon Shift", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.melee_ranged_conversion", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Weapon Shift"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.weapon_shift", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged"]}}}
{"_id": "049820827d7ef32b", "name": "Cover Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Battle Analysis", "benefit": "When you make a ranged attack with a Pistol or Rifle, all allies within 6 squares of you when you made the attack gain a +1 bonus to Reflex Defense until the start of your next turn. Allies within range don't need to be within your line of sight to gain the bonus.", "description": {"value": "When you make a ranged attack with a Pistol or Rifle, all allies within 6 squares of you when you made the attack gain a +1 bonus to Reflex Defense until the start of your next turn. Allies within range don't need to be within your line of sight to gain the bonus."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.battle_analysis"}], "_source": "canonical-csv"}, "treeId": "798ed0945cbdac1c", "tags": ["defender", "feat-chain", "positioning", "ranged", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.will", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}]}}, "effects": [{"_id": "6a421fc4-15d4-4819-8d96-a2ffb7283d28", "name": "Cover Fire", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.all", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Cover Fire", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id