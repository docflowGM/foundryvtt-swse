{"_id": "bf23bf3704382723", "name": "Single Weapon Flourish II", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Double Attack with either Advanced Melee Weapons, an Exotic Weapon (Melee), or Lightsabers; Master of Elegance, Single Weapon Flourish I, Weapon Finesse", "benefit": "When you wield only a single light melee weapon, or a single Lightsaber, once per turn on your turn, you can make a Full Attack Action as a Standard Action, instead of a Full-Round Action.", "description": {"value": "When you wield only a single light melee weapon, or a single Lightsaber, once per turn on your turn, you can make a Full Attack Action as a Standard Action, instead of a Full-Round Action."}, "class": "d87c05d2a34f5627", "costNumeric": null, "category": "Melee Duelist", "treeId": "1381bb8c9a838279", "tags": ["action-economy", "feat-chain", "lightsaber", "melee", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Single Weapon Flourish II"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.single_weapon_flourish_ii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "bf6bcc2fc31411d2", "name": "Improved Suppression Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you successfully suppress an enemy using the Aid Another Action, that enemy takes a -5 penalty on its attack rolls until the start of your next turn. When targeting an area with an Autofire Weapon, each enemy in the attack area takes a -2 penalty on its attack rolls until the start of your next turn, regardless of whether your attack hits.", "description": {"value": "When you successfully suppress an enemy using the Aid Another Action, that enemy takes a -5 penalty on its attack rolls until the start of your next turn. When targeting an area with an Autofire Weapon, each enemy in the attack area takes a -2 penalty on its attack rolls until the start of your next turn, regardless of whether your attack hits."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "2e9265a596cc43f7", "tags": ["battlefield-control", "burst-damage", "soldier"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Improved Suppression Fire"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_suppression_fire", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": []}}}
{"_id": "bff3997bbdecc98a", "name": "Gun Club", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can use a ranged weapon as a melee weapon without taking a penalty on your attack roll. The weapon is otherwise treated as a Club in all respects.", "description": {"value": "You can use a ranged weapon as a melee weapon without taking a penalty on your attack roll. The weapon is otherwise treated as a Club in all respects.\n\nIf you are using a Rifle with a mounted Bayonet or Vibrobayonet, you may wield that weapon as a Double Weapon. The Bayonet or Vibrobayonet end is treated normally, and the other end is treated as a Club."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "cb3751283ea8fa3d", "tags": ["melee", "positioning", "ranged", "soldier", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Gun Club"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.gun_club", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged"]}}}
{"_id": "bffc3826d39f3946", "name": "Guard's Endurance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Ward", "benefit": "Whenever you begin your turn adjacent to the target of your Ward Talent, you gain Bonus Hit Points equal to your Character Level until the start of your next turn. Damage is subtracted from the Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from different sources do not stack.", "description": {"value": "Whenever you begin your turn adjacent to the target of your Ward Talent, you gain Bonus Hit Points equal to your Character Level until the start of your next turn. Damage is subtracted from the Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from different sources do not stack."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.ward"}], "_source": "canonical-csv"}, "treeId": "c92c2cbc79b8a515", "tags": ["feat-chain", "positioning", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Guard's Endurance"}]}}, "effects": [{"_id": "425b895c-dc8f-418e-8b84-42d3359cbd45", "name": "Guard's Endurance", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.hp.regen", "mode": 2, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Guard's Endurance"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.guards_endurance", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.427Z", "detectedPredicates": ["attack.when-hit"]}}}
