{"_id": "e3b7d8c87441a1f0", "name": "Knight's Morale", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When an ally within 12 squares of you and within your line of sight hits with a Lightsaber attack, you gain a +1 morale bonus to all your Defenses until the end of your next turn.", "description": {"value": "When an ally within 12 squares of you and within your line of sight hits with a Lightsaber attack, you gain a +1 morale bonus to all your Defenses until the end of your next turn."}, "class": "ec505163e5647cc6", "costNumeric": null, "category": "Imperial Knight", "treeId": "8048efd85ae61101", "tags": ["category_imperial_knight", "defense", "force", "imperial", "leader", "lightsaber", "melee", "offense_melee", "positioning", "striker", "support"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}]}}, "effects": [{"_id": "2ef1f20a-297a-42de-b6af-ff9c43898903", "name": "Knight's Morale", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.reflex", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Knight's Morale", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.knights_morale"}}}
