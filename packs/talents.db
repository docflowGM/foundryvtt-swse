{"_id": "84d4e92693185028", "name": "Improvised Device", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can create a temporary piece of almost any type of Equipment from the spare parts you have around. To do so, you must make a DC 25 Mechanics check and spend one hour building the device. The object can have a maximum value of 200 credits x your Class Level, it cannot have an availability of Rare or Illegal, and it cannot be unique.", "description": {"value": "You can create a temporary piece of almost any type of Equipment from the spare parts you have around. To do so, you must make a DC 25 Mechanics check and spend one hour building the device. The object can have a maximum value of 200 credits x your Class Level, it cannot have an availability of Rare or Illegal, and it cannot be unique.\n\nThe device you create must be something that you would be reasonably familiar with, and after 24 hours the object is destroyed. You can use this Talent once per day."}, "class": "db019dfbb271cdf6", "costNumeric": null, "category": "Improviser", "treeId": "7f37422819d7be6f", "tags": ["action_economy", "category_improviser", "condition_removal", "control", "controller", "damage_reduction", "defender", "gear", "heavy_weapons", "jury_rig", "leader", "mechanics", "mobility", "positioning", "skills", "striker", "support", "sustained_damage", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "attack.when-hit", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Improvised Device"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improvised_device", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.420Z", "detectedPredicates": ["defense.will", "attack.when-hit", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "852bca9332684a2b", "name": "Shield Gauntlet Defense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Once per round as a Reaction, you can negate a ranged attack by making a successful Use the Force check. The DC of the skill check is equal to the result of the attack roll you wish to negate. To use this this Talent, you must be wearing an active Shield Gauntlet, you must be aware of the attack, and you must not be Flat-Footed. You can spend a Force Point to use this Talent to negate a ranged attack against an adjacent character. Prerequisites: , Shield Gauntlet Deflect, Base Attack Bonus +5", "benefit": "Once per round as a Reaction, you can negate a ranged attack by making a successful Use the Force check. The DC of the skill check is equal to the result of the attack roll you wish to negate. To use this this Talent, you must be wearing an active Shield Gauntlet, you must be aware of the attack, and you must not be Flat-Footed. You can spend a Force Point to use this Talent to negate a ranged attack against an adjacent character. Prerequisites: , Shield Gauntlet Deflect, Base Attack Bonus +5", "class": "", "category": "", "costNumeric": null, "treeId": "2a1838832f6146e2", "tags": ["action_economy", "block", "controller", "defender", "defense", "deflect", "duelist", "force", "force_execution", "force_offense", "force_point_spend", "lightsaber_polearm", "melee_defense", "offense_ranged", "positioning", "ranged", "ranged_defense", "reaction", "resource_spend", "shield", "shields", "striker", "sustained_damage", "tree_2a1838832f6146e2", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 5, "type": "untyped", "predicates": ["attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Shield Gauntlet Defense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.420Z", "detectedPredicates": ["attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "85318987b48d5caa", "name": "Excellent Kit", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You always make sure that your allies have the best gear available. Whenever you purchase Weapons, Armor, or other Equipment (either legally or through the Black Market), all gear you purchase has 50% more Hit Points than normal and has 5 more DR than normal.", "description": {"value": "You always make sure that your allies have the best gear available. Whenever you purchase Weapons, Armor, or other Equipment (either legally or through the Black Market), all gear you purchase has 50% more Hit Points than normal and has 5 more DR than normal.\n\nIn addition, whenever one of your allies makes a Mechanics check on an object that you purchased, that ally gains a +2 Equipment bonus to the check."}, "class": "db019dfbb271cdf6", "costNumeric": null, "category": "Improviser", "treeId": "a0d6323d6c1bf911", "tags": ["category_improviser", "control", "damage_reduction", "defender", "gear", "jury_rig", "mechanics", "skills", "striker", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Excellent Kit"}]}}, "effects": [{"_id": "7c1538cf-807b-4467-82b4-8ba66e910d03", "name": "Excellent Kit", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.equipment.hp", "mode": 5, "value": "1.5x"}, {"key": "system.damageReduction", "mode": 2, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Excellent Kit"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.excellent_kit", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.420Z", "detectedPredicates": []}}}
