{"_id": "dd488c2dc43d14ab", "name": "Unsettling Presence", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Interrogation", "benefit": "You can spend a Force Point as a Standard Action to create an aura of unsettling discomfort around you. You make a Use the Force check when you activate this Talent and compare the check result to the Will Defense of any creature that comes within 6 squares of you.", "description": {"value": "You can spend a Force Point as a Standard Action to create an aura of unsettling discomfort around you. You make a Use the Force check when you activate this Talent and compare the check result to the Will Defense of any creature that comes within 6 squares of you.\n\nIf your Use the Force check result equals or exceeds the creature's Will Defense, that target takes a -2 penalty on attack rolls and Skill Checks while within 6 squares of you. This aura lasts for the remainder of the encounter."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.force_interrogation"}], "_source": "canonical-csv"}, "treeId": "a6ee1a0c534cbc73", "tags": ["category_force_adept", "controller", "feat_chain", "force", "force_capacity", "force_execution", "force_offense", "force_point_spend", "force_training", "mystic", "new_action", "positioning", "resource_spend", "standard_action", "striker", "talent_chain", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Unsettling Presence"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unsettling_presence", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.430Z", "detectedPredicates": []}}}
{"_id": "dd69400f0069f846", "name": "Improved Skirmisher", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Skirmisher", "benefit": "When you move at least 2 squares before your attack and end your move in a different square from where you started, you gain a +1 bonus to all your Defenses until the start of your next turn.", "description": {"value": "When you move at least 2 squares before your attack and end your move in a different square from where you started, you gain a +1 bonus to all your Defenses until the start of your next turn."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.skirmisher"}], "_source": "canonical-csv"}, "treeId": "67b59e020c1660eb", "tags": ["controller", "defender", "feat-chain", "mobility", "positioning", "scoundrel", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "attack", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.attacks"}]}}, "effects": [{"_id": "e973df40-4105-4fcd-8998-920241347e49", "name": "Improved Skirmisher", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Improved Skirmisher", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_skirmisher"}}}
