{"_id": "acb9d2dddeea7efd", "name": "Improved Quick Draw (lightsabers)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Quick Draw, Weapon Focus (Lightsabers)", "benefit": "If you are carrying a Lightsaber (either in your hand or at your belt), you can draw the Lightsaber, ignite it, and make a single attack during the Surprise Round, even if you are Surprised. If you are not Surprised, you can take any single Action of your choice, as normal.", "description": {"value": "If you are carrying a Lightsaber (either in your hand or at your belt), you can draw the Lightsaber, ignite it, and make a single attack during the Surprise Round, even if you are Surprised. If you are not Surprised, you can take any single Action of your choice, as normal."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "77e3817ba5cfa0d5", "tags": ["action-economy", "ambush", "feat-chain", "force", "force-offense", "jedi", "light-side", "lightsaber", "melee", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Improved Quick Draw (lightsabers)"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_quick_draw_lightsabers", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.424Z", "detectedPredicates": []}}}
{"_id": "ad418fa7b1716364", "name": "Find Openings", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per turn, when an enemy damages you with an Attack of Opportunity, you can make a single melee or ranged attack against a target in range as a Reaction. As a Swift Action, make an Initiative check, opposed by the Initiative check of an enemy within your line of sight. If your check result equals or exceeds the target's check, the target is considered Flat-Footed against the next attack you make before the end of your turn. If the target's check result is higher, you are considered Flat-Footed against the next attack made by the target before the start of your next turn.", "description": {"value": ""}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "4af97ad058b1b30f", "tags": ["action-economy", "controller", "melee", "mobility", "positioning", "ranged", "scoundrel", "scout", "skills", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Find Openings"}]}}, "effects": [{"_id": "36af72cc-2532-48af-a693-1b63e2199224", "name": "Find Openings", "icon": "icons/svg/sword.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Find Openings"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.find_openings", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.425Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged"]}}}
