{"_id": "f16128ef7a76aa03", "name": "Stymie", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per round, as a Swift Action, you can designate a target within 12 squares of you and in your line of sight as the target of this Talent. Until the beginning of your turn, you can cause that target to take a -5 penalty on all checks made with a single Skill.", "description": {"value": "Once per round, as a Swift Action, you can designate a target within 12 squares of you and in your line of sight as the target of this Talent. Until the beginning of your turn, you can cause that target to take a -5 penalty on all checks made with a single Skill.\n\nYou must have line of sight to your target to make use of this Talent, and declare which Skill is to be penalized at the time this Talent is activated. This is a Mind-Affecting effect."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "67b59e020c1660eb", "tags": ["positioning", "scoundrel", "striker", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Stymie"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stymie", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "f18fba568e414141", "name": "Retaliation Jab", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "If an enemy misses you with a melee attack, as a Reaction you can automatically deal damage equal to your Strength modifier (minimum 1 point of damage) to your attacker, if the attacker is within your Reach."}, "benefit": "If an enemy misses you with a melee attack, as a Reaction you can automatically deal damage equal to your Strength modifier (minimum 1 point of damage) to your attacker, if the attacker is within your Reach.", "class": "", "category": "", "costNumeric": null, "treeId": "abc3466390fe4050", "tags": ["action_economy", "controller", "counterattack", "martial_arts", "melee", "mobility", "offense_melee", "positioning", "reaction", "striker", "support", "tree_abc3466390fe4050", "unarmed", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "attack.with-melee", "proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Retaliation Jab"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["attack.when-hit", "attack.with-melee", "proximity.ally-nearby"]}}}
{"_id": "f23b63464e0aeff7", "name": "Surveillance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Perception", "benefit": "As a Full-Round Action, you can make a Perception check against a single target within line of sight. The DC is equal to 15 or the target's Stealth check result (if the target is actively trying to remain hidden), whichever is greater.", "description": {"value": "As a Full-Round Action, you can make a Perception check against a single target within line of sight. The DC is equal to 15 or the target's Stealth check result (if the target is actively trying to remain hidden), whichever is greater.\n\nIf the check is successful, you grant yourself and all allies within line of sight a +2 insight bonus on attack rolls against that target until the end of your next turn. Your allies must be able to hear and understand you to benefit from this bonus, and they do not lose the benefit if they move out of line of sight after it is used."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "43c5941072ec78af"}], "_source": "fix5F-canonical"}, "treeId": "7c42882a1347ef18", "tags": ["action-economy", "controller", "defender", "feat-chain", "leader", "mechanics", "mobility", "perception", "scout", "skills", "stealth", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 1, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Surveillance"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.surveillance", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "f259cf27c1b62c47", "name": "Tactical Superiority", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Spend two Swift Actions to select two allies. Each ally can move 2 squares as a Reaction. This movement does not provoke Attacks of Opportunity.", "description": {"value": "Spend two Swift Actions to select two allies. Each ally can move 2 squares as a Reaction. This movement does not provoke Attacks of Opportunity."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "treeId": "560cc7994b357a0d", "tags": ["defender", "positioning", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Tactical Superiority"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.tactical_superiority", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "f25d28252bade7d1", "name": "Hide in Plain Sight", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Hidden Movement, Improved Stealth", "benefit": "Once per encounter, when you are within 2 squares of Cover or Concealment, you can move to that Cover or Concealment and make a Stealth check to hide as a single Move Action.", "description": {"value": "Once per encounter, when you are within 2 squares of Cover or Concealment, you can move to that Cover or Concealment and make a Stealth check to hide as a single Move Action."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.hidden_movement"}], "_source": "canonical-csv"}, "treeId": "3926d582d2077489", "tags": ["action-economy", "controller", "feat-chain", "mobility", "positioning", "scout", "skills", "stealth", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Hide in Plain Sight"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hide_in_plain_sight", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "f29c25c955f24e57", "name": "Enhanced Danger Sense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You add your Wisdom bonus to your Reflex Defense whenever your Dexterity bonus would normally be denied to you. Whenever you arrive on a new planet, you can spend 10 minutes and a Force Point to acclimate yourself to the planet's unique ebb and flow of Force energy. While on the planet, you gain a +2 Force bonus to all Defenses against naturally occurring Hazards on the world, your Speed increases by 1 square, and you can sense what the weather will be like to the immediate area up to 24 hours in advance as a Full-Round Action. Once per day, you can spend 10 minutes meditating to seek visions of the future. At that time, you can spend a Force Point as a part of this meditation. Once during the rest of the day, whenever you or a Vehicle you Pilot are the target of an attack, you can choose to negate that attack provided the attack roll is not a Natural 20. At the end of the day, if you did not use this ability, you regain the Force Point spent on the meditation.", "benefit": "You add your Wisdom bonus to your Reflex Defense whenever your Dexterity bonus would normally be denied to you. Whenever you arrive on a new planet, you can spend 10 minutes and a Force Point to acclimate yourself to the planet's unique ebb and flow of Force energy. While on the planet, you gain a +2 Force bonus to all Defenses against naturally occurring Hazards on the world, your Speed increases by 1 square, and you can sense what the weather will be like to the immediate area up to 24 hours in advance as a Full-Round Action. Once per day, you can spend 10 minutes meditating to seek visions of the future. At that time, you can spend a Force Point as a part of this meditation. Once during the rest of the day, whenever you or a Vehicle you Pilot are the target of an attack, you can choose to negate that attack provided the attack roll is not a Natural 20. At the end of the day, if you did not use this ability, you regain the Force Point spent on the meditation.", "class": "", "category": "", "costNumeric": null, "treeId": "3e807e87cac844ba", "tags": ["action_economy", "battlefield_control", "danger_sense", "defender", "force", "force_defense", "force_offense", "force_point_spend", "initiative", "mobility", "perception", "pilot", "positioning", "resource_spend", "scout", "striker", "support", "sustained_damage", "tree_3e807e87cac844ba", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Enhanced Danger Sense"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "f29d5c0628459c94", "name": "Draw Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can distract opponents and convince them that you are the most tempting (or most dangerous) target in the area. As a Swift Action, make a Persuasion check and compare the result to the Will Defense of all opponents within line of sight.", "description": {"value": "You can distract opponents and convince them that you are the most tempting (or most dangerous) target in the area. As a Swift Action, make a Persuasion check and compare the result to the Will Defense of all opponents within line of sight.\n\nIf the check result exceeds an opponent's Will Defense, that opponent cannot attack any character within 6 squares of you until the start of your next turn as long as you do not have Cover against that opponent. (The affected opponent may still attack you, however.)\n\nIf you are the Pilot of a Vehicle, you may use this Talent to protect allied Vehicles. You may use it to protect Vehicles no more than one size category larger than your own."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "e91cc675fbf9ba6e", "tags": ["positioning", "soldier", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Draw Fire"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.draw_fire", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": []}}}
{"_id": "f2df5596a9db40c1", "name": "Blackguard Initiate", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You have learned to utilize the abilities of the Force Traditions you study. Select one Force Power; you may spend a Swift Action to replace a power in your Force Power Suite (that has not been expended) with the chosen Force Power. If you do not spend this Force Power before the end of the encounter, it is lost and the replaced power returns to your Force Power Suite. You may activate this Talent a number of times per encounter equal to your Wisdom modifier (minimum 1). This Talent may be selected multiple times. Each time you select this Talent, you must choose a different Force Power. Prerequisite: You are a stalwart defender of The Blackguard. As a Standard Action, you can grant yourself a bonus to your Defenses equal to your Dark Side Score or Wisdom modifier (whichever is lower). However, while this effect is active, you suffer a penalty to your attack rolls equal to your Dark Side Score. This effect lasts a number of rounds equal to your Wisdom modifier (minimum 1 round). Prerequisite: , Sneak Attack", "benefit": "You have learned to utilize the abilities of the Force Traditions you study. Select one Force Power; you may spend a Swift Action to replace a power in your Force Power Suite (that has not been expended) with the chosen Force Power. If you do not spend this Force Power before the end of the encounter, it is lost and the replaced power returns to your Force Power Suite. You may activate this Talent a number of times per encounter equal to your Wisdom modifier (minimum 1). This Talent may be selected multiple times. Each time you select this Talent, you must choose a different Force Power. Prerequisite: You are a stalwart defender of The Blackguard. As a Standard Action, you can grant yourself a bonus to your Defenses equal to your Dark Side Score or Wisdom modifier (whichever is lower). However, while this effect is active, you suffer a penalty to your attack rolls equal to your Dark Side Score. This effect lasts a number of rounds equal to your Wisdom modifier (minimum 1 round). Prerequisite: , Sneak Attack", "class": "", "category": "", "costNumeric": null, "treeId": "d2535361d1b146cd", "tags": ["action_economy", "bodyguard", "dark_side", "defender", "defense", "force", "force_capacity", "force_defense", "force_offense", "force_power_synergy", "leader", "mobility", "new_action", "precision", "scaling", "standard_action", "sustained_damage", "swift_action", "tree_d2535361d1b146cd", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Blackguard Initiate"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": []}}}
{"_id": "f3a1542edd5f4259", "name": "Dedicated Protector", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Harm's Way", "description": {"value": "Once per encounter, you can designate one ally within 6 squares of you. Until the end of the encounter, that ally gains a +1 morale bonus to their Reflex Defense as long as it remains adjacent to you. Any individual can only be the target of this Talent once per encounter."}, "benefit": "Once per encounter, you can designate one ally within 6 squares of you. Until the end of the encounter, that ally gains a +1 morale bonus to their Reflex Defense as long as it remains adjacent to you. Any individual can only be the target of this Talent once per encounter.", "class": "", "category": "", "costNumeric": null, "treeId": "798ed0945cbdac1c", "tags": ["action_economy", "ally_support", "battlefield_control", "bodyguard", "condition_removal", "controller", "damage_reduction", "defender", "defense", "evasion", "leader", "mobility", "positioning", "shields", "striker", "support", "tree_798ed0945cbdac1c", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby", "turn.once-per-round", "target.is-flanked"], "enabled": true, "priority": 500, "description": "Dedicated Protector"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.433Z", "detectedPredicates": ["proximity.ally-nearby", "turn.once-per-round", "target.is-flanked"]}}}
