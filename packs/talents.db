{"_id": "5e4a7f98b1e74326", "name": "Adept Spellcaster", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You may spend a Force Point reroll a Use the Force check to activate a Force Power with the [Dark Side] descriptor, but the result of the reroll must be accepted, even if it is worse. Prerequisites: , Illusionary Disguise Prerequisites: , Dark Lore You may reroll a Use the Force check made for the following uses; Search Your Feelings, Sense Force, and Sense Surroundings. Prerequisites: , Dark Lore When you spend a Force Point to reduce your Dark Side Score by 1, you may choose to instead reduce your Dark Side Score by 2.", "benefit": "You may spend a Force Point reroll a Use the Force check to activate a Force Power with the [Dark Side] descriptor, but the result of the reroll must be accepted, even if it is worse. Prerequisites: , Illusionary Disguise Prerequisites: , Dark Lore You may reroll a Use the Force check made for the following uses; Search Your Feelings, Sense Force, and Sense Surroundings. Prerequisites: , Dark Lore When you spend a Force Point to reduce your Dark Side Score by 1, you may choose to instead reduce your Dark Side Score by 2.", "class": "", "category": "", "costNumeric": null, "treeId": "cfd358ef61fb47bd", "tags": ["damage_reduction", "dark_side", "deception", "force", "force_capacity", "force_execution", "force_point_spend", "force_power_synergy", "illusion", "investigation", "knowledge", "resource_spend", "scout", "spellcasting", "sustained_damage", "tree_cfd358ef61fb47bd", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Adept Spellcaster"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.414Z", "detectedPredicates": []}}}
