{"_id": "2455d85114f52830", "name": "Lead by Example", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Once per encounter, when you deal damage, all allies gain +1 attack and +1 die of damage on non-area attacks for the remainder of the encounter.", "description": "When you deal damage, allies gain bonuses to attack and damage for the encounter.", "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "d65a4816379802ee", "tags": ["battlefield-control", "noble", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Lead by Example"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lead_by_example", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "247b9ba1f8d34683", "name": "Retrovirus", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Your mastery of genetic manipulation has extended to affecting those already alive and modifying how their genes are expressed. You can create a that allows a single Clone Scientist Trait to be expressed in a living being. Creation of the will only work for one individual and clones of that individual, and still requires all the costs and Skill Checks as if creating a clone of that person, with the addition of +20 increase to the Cloning DC. Further, each time a is used, the subject risks corrupting their DNA, and must resist an attack on their Fortitude Defense with an attack bonus of +5. A successful hit moves the target a Persistent -1 step on the Condition Track for cellular destabilization. At -5 steps, their DNA is hopelessly corrupted, and their cells break down, causing Death.", "benefit": "Your mastery of genetic manipulation has extended to affecting those already alive and modifying how their genes are expressed. You can create a that allows a single Clone Scientist Trait to be expressed in a living being. Creation of the will only work for one individual and clones of that individual, and still requires all the costs and Skill Checks as if creating a clone of that person, with the addition of +20 increase to the Cloning DC. Further, each time a is used, the subject risks corrupting their DNA, and must resist an attack on their Fortitude Defense with an attack bonus of +5. A successful hit moves the target a Persistent -1 step on the Condition Track for cellular destabilization. At -5 steps, their DNA is hopelessly corrupted, and their cells break down, causing Death.", "class": "", "category": "", "costNumeric": null, "treeId": "8e44e56069274319", "tags": ["biotech", "cloning", "condition_removal", "controller", "crafting", "defender", "dual_wield", "mobility", "science", "striker", "sustained_damage", "tree_8e44e56069274319", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 20, "type": "untyped", "predicates": ["defense.fortitude", "attack.when-hit"], "enabled": true, "priority": 500, "description": "Retrovirus"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["defense.fortitude", "attack.when-hit"]}}}
{"_id": "24bf81bc6d74fafd", "name": "Keep Them Reeling", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Ambush Specialist", "benefit": "Once per turn, make an opposed Initiative check vs your prime target; if you win, the prime target is flat-footed against you.", "description": "Make a melee attack; if it hits, deal no damage but force the target to move or withdraw next turn.", "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.ambush_specialist"}], "_source": "canonical-csv"}, "treeId": "12027e0ad5e4d260", "tags": ["controller", "feat-chain", "scout", "skills", "soldier", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Keep Them Reeling"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.keep_them_reeling", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "251462d5e3aaa4ce", "name": "Jedi Network", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You have access to a network of Jedi sympathizers. While in a civilized area, you can call upon this network of allies once per game session for one of the following purposes:", "description": {"value": "You have access to a network of Jedi sympathizers. While in a civilized area, you can call upon this network of allies once per game session for one of the following purposes:\n\nAcquire Equipment or Funds: You can use your contacts to obtain material that might otherwise be Licensed, Restricted, Military, or Illegal, provided the total value of the Equipment does not exceed your Jedi Knight Level x 500 credits. Alternatively, you can obtain a number of credits from your contacts equal to this amount to spend as you see fit.\nObtain Information: Your contacts provide you with information, automatically succeeding on a Gather Information check (and covering the credit cost of the check) provided the DC does not exceed 20.\nReceive Medical Attention: Your contacts provide you and up to three of your allies with medical attention as dispensed by a skilled physician or healer. The length of the treatment cannot exceed 24 hours, but is otherwise free of charge and completely private.\nSecure Safe House: One of your contacts provides a safe redoubt for you and up to three of your allies, for a number of days equal to your Jedi Knight Class Level. While in hiding, you have no contact with anyone other than the individual who is hiding you. Once the allotted time is up, you must leave the Safe House or risk discovery. For each day you remain in hiding past this deadline, the Gamemaster should roll 1d20. On a result of 15 or higher, your Safe House is discovered, and your contact's complicity in keeping you hidden is exposed."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "e303ddd025779062", "tags": ["force", "force-support", "jedi", "light-side", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Jedi Network"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.jedi_network", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "252285ae33a2a2d5", "name": "Uncanny Instincts", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per round whenever an opponent successfully deals damage to you, you can move 1 square as a Reaction. This movement does not provoke Attacks of Opportunity.", "description": {"value": "Once per round whenever an opponent successfully deals damage to you, you can move 1 square as a Reaction. This movement does not provoke Attacks of Opportunity."}, "class": "19ee85a788380256", "costNumeric": null, "category": "Outlaw", "treeId": "3caa80f6bef04200", "tags": ["action_economy", "battlefield_control", "category_outlaw", "controller", "defender", "duelist", "melee", "mobility", "opportunist", "positioning", "ranged", "reaction", "striker", "support", "survivability", "sustained_damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Uncanny Instincts"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.uncanny_instincts", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "defense.reflex", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "254b51a34600e2ef", "name": "Protector Actions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Inspire Loyalty", "benefit": "You and your Followers have learned to work together to great effect, ensuring that you remain safe while allowing them to do their duty. You can use any of the following actions on your turn:", "description": {"value": "You and your Followers have learned to work together to great effect, ensuring that you remain safe while allowing them to do their duty. You can use any of the following actions on your turn:\n\nBodyguard: As a Standard Action, you can make a melee or ranged attack against a target within Range. Until the end of your next turn, if that target damages you with an attack or Force Power, as a Reaction you can choose to redirect the attack or Force Power to an adjacent follower; the attack or Force Power is resolved against that ally as normal.\nDiversion Attack: As a Standard Action, you can make a melee or ranged attack against a target within Range. If that target attacks you or one of your allies before the beginning of your next turn, you can move one of your Followers up to its speed directly toward that target.\nThe Best Defense: As a Standard Action, you can make a melee or ranged attack against a target within Range. For each of your followers armed with a ranged weapon and having line of sight to the target, that target takes a -1 penalty on attack rolls until the beginning of your next turn."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "be2e649cbb7332fa", "tags": ["controller", "mobility", "noble", "positioning", "ranged"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged"], "enabled": true, "priority": 500, "description": "Protector Actions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.protector_actions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["attack.with-ranged"]}}}
{"_id": "25dd9d9b3b66c048", "name": "Telepathic Link", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You naturally and unconsciously influence those who are regularly around you. Whenever you roll a natural 20 on an attack roll or Use the Force check, instead of regaining all your spent Force Powers, you may instead choose to grant one ally within 12 squares of you a temporary Force Point. If your ally does not use this temporary Force Point before the end of the encounter, it is lost. Reference Book: Star Wars Saga Edition Knights of the Old Republic Campaign Guide You form an enhanced with a willing ally, that possesses the Force Sensitivity feat, as a Swift Action. The is maintained until you choose to remove it (no Action required). As long as you remain within one kilometer of your target, you and the target can communicate telepathically as though you were speaking. Once per encounter, you may use a Force Power from your target's Force Power Suite (if the target consents), or you may allow the target to use one of your Force Powers. You may only have one active at a time. Force Bond Talent created by TheSagaContinues user fairytalejedi. Prerequisite: A becomes permanent between yourself and another possessing the Force Sensitivity Feat. While out of combat, you and the bonded individual can freely speak as if in the same location. By spending a Force Point to make a DC 25 Use the Force check, you may give or take a single item of Diminutive size or smaller.", "description": "You naturally and unconsciously influence those who are regularly around you. Whenever you roll a natural 20 on an attack roll or Use the Force check, instead of regaining all your spent Force Powers, you may instead choose to grant one ally within 12 squares of you a temporary Force Point. If your ally does not use this temporary Force Point before the end of the encounter, it is lost. Reference Book: Star Wars Saga Edition Knights of the Old Republic Campaign Guide You form an enhanced with a willing ally, that possesses the Force Sensitivity feat, as a Swift Action. The is maintained until you choose to remove it (no Action required). As long as you remain within one kilometer of your target, you and the target can communicate telepathically as though you were speaking. Once per encounter, you may use a Force Power from your target's Force Power Suite (if the target consents), or you may allow the target to use one of your Force Powers. You may only have one active at a time. Force Bond Talent created by TheSagaContinues user fairytalejedi. Prerequisite: A becomes permanent between yourself and another possessing the Force Sensitivity Feat. While out of combat, you and the bonded individual can freely speak as if in the same location. By spending a Force Point to make a DC 25 Use the Force check, you may give or take a single item of Diminutive size or smaller.", "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "usetheforce"}], "_source": "fix5F-canonical"}, "treeId": "6ac3416fb6aada56", "tags": ["action_economy", "controller", "dual_wield", "force", "force_capacity", "force_control", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "leader", "light_side", "mobility", "positioning", "resource_spend", "skill_substitution", "support", "sustained_damage", "swift_action", "telekinesis", "telepathy", "tree_6ac3416fb6aada56", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Telepathic Link"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.telepathic_link", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "25f285b1cf4cff35", "name": "Pursuit", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dexterity 13", "benefit": "When Running, you are not restricted to a straight line; and you can reroll Endurance checks, keeping the better of the two results, while Running.", "description": {"value": "When Running, you are not restricted to a straight line; and you can reroll Endurance checks, keeping the better of the two results, while Running."}, "class": "61876f91a1633cdf", "costNumeric": null, "category": "Enforcer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "attribute", "ability": "dex", "min": 13}], "_source": "canonical-csv"}, "treeId": "2d164f62e17bed8c", "tags": ["category_enforcer", "control", "feat_chain", "force", "law_enforcement", "nonlethal", "pursuit", "ranged_support", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Pursuit"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.pursuit", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "26bece7080710c8d", "name": "Shoto Master", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you wield both a One-Handed Lightsaber and a Light Lightsaber (typically a Shoto Lightsaber or a Guard Shoto), you can consider the One-Handed Lightsaber to be a Light Weapon.", "description": {"value": "When you wield both a One-Handed Lightsaber and a Light Lightsaber (typically a Shoto Lightsaber or a Guard Shoto), you can consider the One-Handed Lightsaber to be a Light Weapon.\n\nAdditionally, if you have the Lightsaber Defense Talent, you can activate the Talent as a Free Action on your turn (instead of a Swift Action) whenever you wield both a One-Handed Lightsaber and a Light Lightsaber."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "b3c5d90b5036f39b", "tags": ["action-economy", "defender", "feat-chain", "jedi", "lightsaber", "melee", "ranged", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Shoto Master"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.shoto_master", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "271024ca2ac6c04b", "name": "Multiattack Proficiency (exotic)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Exotic Weapons Master", "benefit": "Reduce multiattack penalty by 2 for exotic weapons.", "description": "Reduce the attack penalty for making multiple attacks with exotic weapons by 2.", "class": "533f1066362655c7", "costNumeric": null, "category": "Gladiator", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.exotic_weapons_master"}], "_source": "canonical-csv"}, "treeId": "12a2a02b0901605d", "tags": ["damage-reduction", "feat-chain", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Multiattack Proficiency (exotic)"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.multiattack_proficiency_exotic", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "2739921a657a49a496885c456bcace65", "name": "Soft Reset", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"benefit": "You are adept at rerouting your internal electronics. If you are moved to the bottom of the Condition Track by any means other than taking damage exceeding your Damage Threshold, you automatically move +1 step along the Condition Track after being disabled for 2 rounds.", "description": "You are adept at rerouting your internal electronics. If you are moved to the bottom of the Condition Track by any means other than taking damage exceeding your Damage Threshold, you automatically move +1 step along the Condition Track after being disabled for 2 rounds.", "prerequisites": "", "class": "3b1ed5f1038d49fb", "category": "Independent Droid", "treeId": "9fe73a3703fa45fca628fd43cae6bf7f", "tags": ["category_independent_droid", "condition_removal", "controller", "defender", "droid", "durability", "feat_chain", "mobility", "recovery", "resource_recovery", "self_repair", "striker", "support", "sustained_damage", "talent_chain", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Soft Reset"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "27604b55a6fd41ffbc04f05cec16463d", "name": "Just a Droid", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"benefit": "You are adept at passing yourself off as an ordinary Droid. You can use each of the following Actions once per encounter.", "description": {"value": "You are adept at passing yourself off as an ordinary Droid. You can use each of the following Actions once per encounter.\n\nJust Another Droid: You are skilled at using Stealth to sneak past unwary enemies when moving in plain sight. You can use the Sneak application of the Stealth Skill when in plain sight of an enemy, if the enemy has no reason to doubt that you are just another Droid. You are considered Trained in Stealth for this Action.\nJust a Normal Droid: You can reroll Deception checks for Deceptive Appearance to make observers believe that you are carrying out a standard function when attempting to do something atypical for your Droid Model or function. You may keep either result."}, "prerequisites": "", "class": "3b1ed5f1038d49fb", "category": "Independent Droid", "treeId": "9fe73a3703fa45fca628fd43cae6bf7f", "tags": ["action_economy", "category_independent_droid", "deception", "droid", "durability", "feat_chain", "self_repair", "skill_stealth", "social_control", "social_defense", "stealth", "talent_chain", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Just a Droid"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "27dd504c877a4de5", "name": "Detective", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "You are skilled in locating individuals and using research and surveillance to learn some of their most intimate secrets. When you make a Gather Information check to locate an individual, the DC is reduced by 10, and the time and bribery cost are reduced by half."}, "benefit": "You are skilled in locating individuals and using research and surveillance to learn some of their most intimate secrets. When you make a Gather Information check to locate an individual, the DC is reduced by 10, and the time and bribery cost are reduced by half.", "class": "", "category": "", "costNumeric": null, "treeId": "a47ed82a822e3962", "tags": ["armor", "damage_reduction", "defender", "force", "investigation", "knowledge", "leader", "perception", "piloting", "skills", "striker", "tech", "tracking", "tree_a47ed82a822e3962", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Detective"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "2871d6138603fbcc", "name": "Get Some Distance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Advantageous Positioning, Shift", "benefit": "Once per encounter as a Standard Action you can make a melee attack against a target and then move up to your speed away from that target. This movement does not provoke an Attack of Opportunity.", "description": {"value": "Once per encounter as a Standard Action you can make a melee attack against a target and then move up to your speed away from that target. This movement does not provoke an Attack of Opportunity."}, "class": "74fa04f5afb5f6e1", "costNumeric": null, "category": "Assassin", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.advantageous_positioning"}], "_source": "canonical-csv"}, "treeId": "186daeee7bd65a69", "tags": ["category_assassin", "controller", "feat_chain", "melee", "mobility", "new_action", "offense_melee", "precision_damage", "sniping", "standard_action", "stealth", "striker", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Get Some Distance"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.get_some_distance", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["attack.with-melee", "turn.once-per-round"]}}}
{"_id": "28a61dadc073cd84", "name": "Tag", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Hunter's Mark, Hunter's Target", "benefit": "Whenever you damage an opponent whom you selected for your Hunter's Target, all allies gain a +2 bonus on their next attack roll against that opponent until the start of your next turn.", "description": {"value": "Whenever you damage an opponent whom you selected for your Hunter's Target, all allies gain a +2 bonus on their next attack roll against that opponent until the start of your next turn."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.hunters_target"}], "_source": "canonical-csv"}, "treeId": "a47ed82a822e3962", "tags": ["feat-chain", "scoundrel", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Tag"}]}}, "effects": [{"_id": "83a9d475-6e57-4b8b-b528-dc45d1835061", "name": "Tag", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.allies", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Tag"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.tag", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "28b781d7186a03a9", "name": "Sniping Marksman", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Sniping Assassin", "benefit": "Once per encounter, when you make a ranged attack against a target that is not at Point-Blank Range, you can ignore your target's Armor bonus to their Reflex Defense.", "description": {"value": "Once per encounter, when you make a ranged attack against a target that is not at Point-Blank Range, you can ignore your target's Armor bonus to their Reflex Defense."}, "class": "74fa04f5afb5f6e1", "costNumeric": null, "category": "Assassin", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.sniping_assassin"}], "_source": "canonical-csv"}, "treeId": "186daeee7bd65a69", "tags": ["armor", "category_assassin", "defender", "feat_chain", "mobility", "offense_ranged", "positioning", "precision_damage", "ranged", "sniping", "stealth", "striker", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Sniping Marksman"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.sniping_marksman", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["defense.reflex", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "28c306c37ccb9fcf", "name": "Weaken Resolve", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Presence", "benefit": "Once per round, when you deal damage equal to or greater than the target's Damage Threshold, you can make a Persuasion check as a Free Action; if the result equals or exceeds the target's Will Defense, you fill the target with terror, causing it to flee from you at top speed for 1 minute. The target can't take Standard Actions, Swift Actions, or Full-Round Actions while fleeing, but the target stops fleeing and can act normally if it is wounded. As a Free Action or Reaction, the target can spend a Force Point (if it has not already spent one earlier in the round) to negate the effect. The effect is automatically negated if the target's level is equal to or higher than your Character Level. This is a Mind-Affecting fear effect.", "description": {"value": "Once per round, when you deal damage equal to or greater than the target's Damage Threshold, you can make a Persuasion check as a Free Action; if the result equals or exceeds the target's Will Defense, you fill the target with terror, causing it to flee from you at top speed for 1 minute. The target can't take Standard Actions, Swift Actions, or Full-Round Actions while fleeing, but the target stops fleeing and can act normally if it is wounded. As a Free Action or Reaction, the target can spend a Force Point (if it has not already spent one earlier in the round) to negate the effect. The effect is automatically negated if the target's level is equal to or higher than your Character Level. This is a Mind-Affecting fear effect.\n\nUnlike with other Mind-Affecting effects, you need only to hail a Vehicle to weaken the crew's resolve. When you deal damage that equals or exceeds a Vehicle's Damage Threshold, you may use this Talent; in addition, you may Ready an Action to use this Talent after any Gunner on your Vehicle deals damage that equals or exceeds a Vehicle's Damage Threshold. You make your check against the Vehicle's Commander; all Nonheroic crews are assumed to have a Will Defense of 10. The effect is automatically negated if the target Vehicle's Challenge Level is greater than your Heroic Level or your Vehicle's Challenge Level."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.presence"}], "_source": "canonical-csv"}, "treeId": "8375b9b26b679901", "tags": ["noble", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Weaken Resolve"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.weaken_resolve", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "291937f2d45a01bc", "name": "Gradual Resistance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you take damage from the use of a Force Power, until the end of the encounter you gain a +2 Force bonus to all Defenses against that Force Power.", "description": {"value": "If you take damage from the use of a Force Power, until the end of the encounter you gain a +2 Force bonus to all Defenses against that Force Power."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "36f18f3e974feb33", "tags": ["defender", "dual-wield", "force", "force-defense", "force-offense", "jedi", "light-side", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.reflex", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}, {"target": "defense.will", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.all"}]}}, "effects": [{"_id": "1e47f98a-42c2-4118-ad65-a98901495208", "name": "Gradual Resistance", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.all", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Gradual Resistance", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.gradual_resistance"}}}
{"_id": "2931a9052148e79a", "name": "Creeping Approach", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Stealth", "benefit": "As a Swift Action, you can designate a single opponent within 12 squares that is unaware of you as the target of this Talent. Until the beginning of your next turn, that target may not make Perception checks to notice you, even if you enter the target's line of sight. If you or any of your allies attack the target, the effect of this Talent ends.", "description": {"value": "As a Swift Action, you can designate a single opponent within 12 squares that is unaware of you as the target of this Talent. Until the beginning of your next turn, that target may not make Perception checks to notice you, even if you enter the target's line of sight. If you or any of your allies attack the target, the effect of this Talent ends."}, "class": "e647ee8f065e1d19", "costNumeric": null, "category": "Infiltrator", "treeId": "7c7a8730e1b4381a", "tags": ["perception", "positioning", "skills"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Creeping Approach"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.creeping_approach", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "294bad1c8a7b4132", "name": "Make a Break for It", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Stellar Warrior", "benefit": "Once per encounter, move up to half your speed on a vehicle, or half the vehicle’s speed if you are the pilot, without provoking attacks of opportunity.", "description": "Once per encounter, move without provoking attacks of opportunity while aboard a vehicle.", "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.stellar_warrior"}], "_source": "canonical-csv"}, "treeId": "5ea8c79492d40713", "tags": ["controller", "feat-chain", "mobility", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Make a Break for It"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.make_a_break_for_it", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "299c45ac33bf1485", "name": "Visionary Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Farseeing, WatchCircle Initiate", "benefit": "As a Reaction, you can make a Use the Force check after you or an ally within 12 squares misses with a melee or ranged attack, removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had activated the Force Power). If your check result equals or exceeds the Will Defense of the target of that missed attack, the attacker can reroll the missed attack roll.", "description": {"value": "As a Reaction, you can make a Use the Force check after you or an ally within 12 squares misses with a melee or ranged attack, removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had activated the Force Power). If your check result equals or exceeds the Will Defense of the target of that missed attack, the attacker can reroll the missed attack roll.\n\nThis counts as using the Farseeing Force Power against the target, but this Talent replaces the normal rules and effects of Farseeing. Any attack can only be affected by this Talent once (thus, multiple characters cannot use this Talent on the same attack to allow multiple rerolls).\n\nYou take a cumulative -5 penalty on Use the Force checks until the beginning of your next turn when you use this Talent."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.watchcircle_initiate"}], "_source": "canonical-csv"}, "treeId": "e99cfa9db8493573", "tags": ["feat-chain", "force", "force-offense", "jedi", "light-side", "positioning", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Visionary Attack"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.visionary_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "29f73c36cabdeaf5", "name": "Hyperdriven", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per day while aboard a Starship, you can add your Class Level as a bonus on a single attack roll, Skill Check, or Ability Check. The decision to add this bonus can be made after the result of the check is known.", "description": {"value": "Once per day while aboard a Starship, you can add your Class Level as a bonus on a single attack roll, Skill Check, or Ability Check. The decision to add this bonus can be made after the result of the check is known."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "5ea8c79492d40713", "tags": ["scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Hyperdriven"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hyperdriven", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
