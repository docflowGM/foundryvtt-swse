{"_id": "6f6cd1c453dc1828", "name": "Concentrate All Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "When you aid another's attack with a vehicle weapon, the attack deals +1 die damage; an ally may only benefit once per attack.", "description": "When aiding another's vehicle attack, deal +1 die damage; an ally may benefit only once per attack.", "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "5f355ad4093d2bf8", "tags": ["scout", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Concentrate All Fire"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.concentrate_all_fire", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "6fe17dc4f0f03c12", "name": "Lightsaber Specialist", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Masterwork Lightsaber", "benefit": "Whenever you are armed with a Lightsaber that you built, you gain a +2 morale bonus on Use the Force checks made to use the Block and Deflect Talents.", "description": {"value": "Whenever you are armed with a Lightsaber that you built, you gain a +2 morale bonus on Use the Force checks made to use the Block and Deflect Talents."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "76ecaa09bb7619cb", "tags": ["feat-chain", "force", "jedi", "light-side", "lightsaber", "melee", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Lightsaber Specialist"}]}}, "effects": [{"_id": "c18f0a17-6aae-400f-b7ea-4b43f976f7f9", "name": "Lightsaber Specialist", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.actions.blockDeflect", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Lightsaber Specialist"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.lightsaber_specialist", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "700ec3d782794d11", "name": "Field Detection", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Prerequisites: Trained in Use the Force, Farseeing", "description": "Farseeing You are a Master of Luka Sene techniques and an expert in using sense-related Talents and Force Powers. Once per encounter, you gain a temporary Force Point that you must spend when activating a Talent from either the Sense Talent Tree or Luka Sene Talent Tree, when using the Farseeing Force Power, or on a Use the Force check made to use the Search Your Feelings or Sense Force applications of the skill. The Force Point is lost if not used before the end of the encounter. As a Free Action on your turn, you can make a Use the Force check against a living creature within 12 squares, removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had activated the Force Power). If your check result equals or exceeds the Will Defense of the target, you gain a +2 insight bonus on attack rolls against that target until the end of your turn. This counts as using the Farseeing Force Power against that target, but this Talent replaces the normal rules and effects of that Force Power.", "benefit": "Farseeing You are a Master of Luka Sene techniques and an expert in using sense-related Talents and Force Powers. Once per encounter, you gain a temporary Force Point that you must spend when activating a Talent from either the Sense Talent Tree or Luka Sene Talent Tree, when using the Farseeing Force Power, or on a Use the Force check made to use the Search Your Feelings or Sense Force applications of the skill. The Force Point is lost if not used before the end of the encounter. As a Free Action on your turn, you can make a Use the Force check against a living creature within 12 squares, removing one use of the Farseeing Force Power from your active Force Power Suite (as though you had activated the Force Power). If your check result equals or exceeds the Will Defense of the target, you gain a +2 insight bonus on attack rolls against that target until the end of your turn. This counts as using the Farseeing Force Power against that target, but this Talent replaces the normal rules and effects of that Force Power.", "class": "", "category": "", "costNumeric": null, "treeId": "e6e3fc102bb54b20", "tags": ["action_economy", "defender", "detection", "feat_chain", "force", "force_capacity", "force_defense", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "perception", "positioning", "resource_spend", "scout", "sensors", "skills", "striker", "talent_chain", "tree_e6e3fc102bb54b20", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will", "turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Field Detection"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["defense.will", "turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "705f100f5703e707", "name": "Improved Lightsaber Throw", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Lightsaber Throw", "benefit": "You can spend a Force Point as a Standard Action to throw your Lightsaber at a group of opponents. You make a single ranged attack roll (treating the Lightsaber as a Thrown Weapon) and compare the result to the Reflex Defense of all targets in a 6-square line originating in your square.", "description": {"value": "You can spend a Force Point as a Standard Action to throw your Lightsaber at a group of opponents. You make a single ranged attack roll (treating the Lightsaber as a Thrown Weapon) and compare the result to the Reflex Defense of all targets in a 6-square line originating in your square.\n\nIf your attack roll result exceeds a target's Reflex Defense, you deal normal Lightsaber damage to that target (dealing half damage if you fail to exceed the target's Reflex Defense). This attack is considered an Area Attack.\n\nYou can pull your Lightsaber back to your hand as a Swift Action by making a DC 20 Use the Force check."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "b3c5d90b5036f39b", "tags": ["controller", "force", "force-control", "jedi", "light-side", "lightsaber", "melee", "mobility", "ranged", "support", "sustained-damage"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Improved Lightsaber Throw"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.improved_lightsaber_throw", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "707dd4f0b5c744a6", "name": "Special:", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Pilot", "description": "This Talent Tree incorporates all the talents from the Rocket Jumper Talent Tree except for Jet Pack Training, which is partly covered by Hair-Trigger Throttle (see below). Their prerequisites have changed accordingly. Your skills with the flight controls have improved enough that you waste little fuel. Double the amount of charges that you can get out of a jet pack’s fuel cell - for you, a full fuel cell usually supplies 20 charges. Though still shaky with high-speed maneuvers, you can use some in short bursts. If your jet pack is activated, then by burning 2 charges, spending a swift action, and succeeding on a Pilot Check, DC 20, you can double your fly speed during one move action this turn. If your check fails, your swift action and charges are wasted. If and when you gain your Jumptrooper Qualification, you lose this speed boost maneuver. You’ve achieved the minimum proficiency with jet packs expected of jumptroopers. You replace the normal rules for Jet Pack use from its Saga Edition equipment entry with the Advanced Jet Pack Piloting house rules. You’re used to carrying your jet pack on your back for hours while performing other physically demanding tasks. Your jet pack counts only a third of its weight towards your Encumbrance and Carrying Capacity. Refer to the talent of the same name from the Rocket Jumper Talent Tree, though when using Advanced Jet Pack Piloting Rules, this maneuver requires 2 charges. It only takes one piloting mistake, mechanical malfunction, or lucky shot to turn your pleasure flight into a death trap. However, you regularly practice emergency maneuvers to better the odds that you can walk away from snafus alive and uninjured.", "benefit": "This Talent Tree incorporates all the talents from the Rocket Jumper Talent Tree except for Jet Pack Training, which is partly covered by Hair-Trigger Throttle (see below). Their prerequisites have changed accordingly. Your skills with the flight controls have improved enough that you waste little fuel. Double the amount of charges that you can get out of a jet pack’s fuel cell - for you, a full fuel cell usually supplies 20 charges. Though still shaky with high-speed maneuvers, you can use some in short bursts. If your jet pack is activated, then by burning 2 charges, spending a swift action, and succeeding on a Pilot Check, DC 20, you can double your fly speed during one move action this turn. If your check fails, your swift action and charges are wasted. If and when you gain your Jumptrooper Qualification, you lose this speed boost maneuver. You’ve achieved the minimum proficiency with jet packs expected of jumptroopers. You replace the normal rules for Jet Pack use from its Saga Edition equipment entry with the Advanced Jet Pack Piloting house rules. You’re used to carrying your jet pack on your back for hours while performing other physically demanding tasks. Your jet pack counts only a third of its weight towards your Encumbrance and Carrying Capacity. Refer to the talent of the same name from the Rocket Jumper Talent Tree, though when using Advanced Jet Pack Piloting Rules, this maneuver requires 2 charges. It only takes one piloting mistake, mechanical malfunction, or lucky shot to turn your pleasure flight into a death trap. However, you regularly practice emergency maneuvers to better the odds that you can walk away from snafus alive and uninjured.", "class": "", "category": "", "costNumeric": null, "treeId": "25d99948c9cb41ad", "tags": ["action_economy", "burst_damage", "controller", "feat_chain", "force", "force_control", "heavy_weapons", "mobility", "move_action", "pilot", "piloting", "ranged", "scaling", "skills", "striker", "support", "survivability", "swift_action", "talent_chain", "tree_25d99948c9cb41ad", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Special:"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "708a47d1be414990", "name": "Illusions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "The Illusion's size also affects your Use the Force check, applying a penalty for exceptionally large . The penalties are -1 for Huge , -2 for Gargantuan , -5 for Colossal , and -10 for Colossal (Frigate) or larger . This is a Mind-Affecting effect. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual", "benefit": "The Illusion's size also affects your Use the Force check, applying a penalty for exceptionally large . The penalties are -1 for Huge , -2 for Gargantuan , -5 for Colossal , and -10 for Colossal (Frigate) or larger . This is a Mind-Affecting effect. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual", "class": "", "category": "", "costNumeric": null, "treeId": "6ac3416fb6aada56", "tags": ["controller", "deception", "force", "force_execution", "illusion", "light_side", "skill_substitution", "support", "telekinesis", "telepathy", "tree_6ac3416fb6aada56", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Illusions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "70a06f3be4e9c216", "name": "Small Target", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you are the Pilot of a Colossal or smaller Vehicle, Capital Ship Weapons that take a -20 penalty on attack rolls against your Vehicle (such as Turbolasers) do not automatically score a Critical Hit on your Vehicle on a Natural 20. The attack is only a Critical Hit if the total attack roll (20 + the weapon's attack bonus) would normally hit your Vehicle. Otherwise, the attack deals normal damage.", "description": {"value": "When you are the Pilot of a Colossal or smaller Vehicle, Capital Ship Weapons that take a -20 penalty on attack rolls against your Vehicle (such as Turbolasers) do not automatically score a Critical Hit on your Vehicle on a Natural 20. The attack is only a Critical Hit if the total attack roll (20 + the weapon's attack bonus) would normally hit your Vehicle. Otherwise, the attack deals normal damage."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "treeId": "296772ab8e69c9ef", "tags": ["precision", "scout", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Small Target"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.small_target", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "714c38c0498a4eaf", "name": "Empowered Weapon", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Any additional damage you deal with an is considered to be Fire damage. As a Swift Action, you can use The Force to call forth the sparks of your goddess, wreathing your weapon in flames. Until the beginning of your next turn, any successful attack you make with a Melee Weapon deals an additional 1d6 points of Fire damage.", "benefit": "Any additional damage you deal with an is considered to be Fire damage. As a Swift Action, you can use The Force to call forth the sparks of your goddess, wreathing your weapon in flames. Until the beginning of your next turn, any successful attack you make with a Melee Weapon deals an additional 1d6 points of Fire damage.", "class": "", "category": "", "costNumeric": null, "treeId": "c6eee4889411411b", "tags": ["action_economy", "force", "force_execution", "force_offense", "melee", "melee_support", "mobility", "striker", "swift_action", "tree_c6eee4889411411b", "uncategorized_talent", "use_the_force", "vahl", "weapon_empowerment"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Empowered Weapon"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": []}}}
{"_id": "71bc6b43ab504b90", "name": "Inspire Fear II", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Inspire Fear I", "benefit": "As Inspire Fear I, except that the penalty increases to -2.", "description": {"value": "As Inspire Fear I, except that the penalty increases to -2."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.inspire_fear_i"}], "_source": "canonical-csv"}, "treeId": "c1be604242cb328f", "tags": ["feat-chain", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Inspire Fear II"}]}}, "effects": [{"_id": "93101939-886b-4faf-a5cd-092f86e11d0f", "name": "Inspire Fear II", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.morale.penalty", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Inspire Fear II"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.inspire_fear_ii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": []}}}
{"_id": "729a17e25b873f4f", "name": "Stick Together", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Comrades in Arms", "benefit": "You can spend a Move Action to activate this Talent. Until the beginning of your next turn, if an ally Moves you can immediately move up to your speed, provided you end your movement within 3 squares of that ally.", "description": {"value": "You can spend a Move Action to activate this Talent. Until the beginning of your next turn, if an ally Moves you can immediately move up to your speed, provided you end your movement within 3 squares of that ally."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.comrades_in_arms"}], "_source": "canonical-csv"}, "treeId": "eff10782c1e56598", "tags": ["controller", "feat-chain", "mobility", "positioning", "soldier", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["proximity.ally-nearby"], "enabled": true, "priority": 500, "description": "Stick Together"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.stick_together", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["proximity.ally-nearby"]}}}
{"_id": "72c644f7a09b1186", "name": "Deflect", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Reaction, you may negate a ranged attack by making a successful Use the Force check. The DC of the check is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty on your Use the Force check for every time you used Block or Deflect since the beginning of your last turn. You may spend a Force Point to use this Talent to negate an attack against an adjacent character.", "description": {"value": "As a Reaction, you may negate a ranged attack by making a successful Use the Force check. The DC of the check is equal to the result of the attack roll you wish to negate, and you take a cumulative -5 penalty on your Use the Force check for every time you used Block or Deflect since the beginning of your last turn. You may spend a Force Point to use this Talent to negate an attack against an adjacent character.\n\nYou can use this Talent to deflect some of the barrage of shots fired from a ranged weapon set on Autofire, or the Force Lightning Force Power. If you succeed on the Use the Force check, you take half damage if the attack hits, and no damage if the attack misses.\n\nYou must have a Lightsaber drawn and ignited to use this Talent, and you must be aware of the attack and not Flat-Footed.\n\nThis Talent cannot be used to negate attacks made by Colossal (Frigate) or larger-size Vehicles unless the attack is made with a Point-Defense Weapon System."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "2bc2572e852832e4", "tags": ["jedi", "lightsaber", "melee", "ranged"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Deflect"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.deflect", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": []}}}
{"_id": "72ccf7bbe3048453", "name": "Deny Move", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Reduce Mobility", "benefit": "When you score a Critical Hit with a melee or ranged attack, your target cannot Move on its next turn.", "description": {"value": "When you score a Critical Hit with a melee or ranged attack, your target cannot Move on its next turn."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.reduce_mobility"}], "_source": "canonical-csv"}, "treeId": "71e99c646b18d85c", "tags": ["controller", "feat-chain", "mobility", "precision", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Deny Move"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.deny_move", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "72cfc8816ea3ebf5", "name": "Know Your Enemy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You are well versed in the strengths and weaknesses of the enemies of your cause. As a Swift Action, you can select a single enemy within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL. If the check is successful, you immediately learn any two (your choice) of the following pieces of information:", "description": {"value": "You are well versed in the strengths and weaknesses of the enemies of your cause. As a Swift Action, you can select a single enemy within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL. If the check is successful, you immediately learn any two (your choice) of the following pieces of information:"}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "treeId": "d65a4816379802ee", "tags": ["action-economy", "battlefield-control", "defender", "leader", "noble", "positioning", "skills", "social", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 5, "type": "untyped", "predicates": ["defense.will", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Know Your Enemy"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.know_your_enemy", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["defense.will", "turn.once-per-round"]}}}
{"_id": "7355c8afe9509dad", "name": "Close Maneuvering", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per turn, you can use a Swift Action to designate a target. Until the start of your next turn, your movement does not provoke Attacks of Opportunity from that target, provided that you end your movement adjacent to that target.", "description": {"value": "Once per turn, you can use a Swift Action to designate a target. Until the start of your next turn, your movement does not provoke Attacks of Opportunity from that target, provided that you end your movement adjacent to that target."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "10c843cef8ce2798", "tags": ["controller", "force", "force-control", "force-offense", "jedi", "light-side", "mobility", "positioning"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["movement.while-moving"], "enabled": true, "priority": 500, "description": "Close Maneuvering"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.close_maneuvering", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["movement.while-moving"]}}}
{"_id": "744c2eaaa48e15af", "name": "Malkite Techniques", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, you can apply a toxin to any non-Energy Slashing or Piercing weapon as a Standard Action. If an attack roll with that weapon also exceeds the target's Fortitude Defense, that target is Poisoned.", "description": {"value": "Once per encounter, you can apply a toxin to any non-Energy Slashing or Piercing weapon as a Standard Action. If an attack roll with that weapon also exceeds the target's Fortitude Defense, that target is Poisoned.\n\nEach round on the creature's turn, the Poison makes an attack roll (1d20 + your Heroic Level) against the target's Fortitude Defense. If the attack succeeds, the target takes damage equal to 1d6 + one-half your Heroic Level and moves -1 step along the Condition Track.\n\nA target moved to the end of the Condition Track by the Poison is unconscious but continues to take damage as long as the Poison continues to attack. The Poison attacks each round until it misses, or until the victim is cured with a Treat Injury check (DC 10 + your Heroic Level)."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "c55b003333ff082d", "tags": ["defender", "scoundrel", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "defense.fortitude"], "enabled": true, "priority": 500, "description": "Malkite Techniques"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.malkite_techniques", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["defense.reflex", "defense.fortitude"]}}}
{"_id": "747458ee63cd4a2a", "name": "Defensive Roll", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Focus (Simple Weapons)", "description": "As a Reaction, when an attack exceeds your Damage Threshold and moves you down the Condition Track, you can choose to spend a Force Point to make a and not move down the Condition Track (but still take damage as normal). You can use your Use the Force check modifier instead of your Initiative modifier when making Initiative checks. You are considered Trained in the Initiative Skill. If you are entitled to an Initiative check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations). Prerequisite: After activating the Talent, you can move up to half your speed. You deal +2 points of damage with Unarmed Attacks.", "benefit": "As a Reaction, when an attack exceeds your Damage Threshold and moves you down the Condition Track, you can choose to spend a Force Point to make a and not move down the Condition Track (but still take damage as normal). You can use your Use the Force check modifier instead of your Initiative modifier when making Initiative checks. You are considered Trained in the Initiative Skill. If you are entitled to an Initiative check reroll, you may reroll your Use the Force check instead (subject to the same circumstances and limitations). Prerequisite: After activating the Talent, you can move up to half your speed. You deal +2 points of damage with Unarmed Attacks.", "class": "", "category": "", "costNumeric": null, "treeId": "11f99465ba4847e2", "tags": ["action_economy", "condition_removal", "controller", "defender", "defense", "feat_chain", "force", "force_control", "force_execution", "force_offense", "force_point_spend", "martial_arts", "mobility", "offense_melee", "reaction", "resource_spend", "scout", "skills", "striker", "survivability", "talent_chain", "tree_11f99465ba4847e2", "unarmed", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Defensive Roll"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": []}}}
{"_id": "74fb6b37af983a4c", "name": "Hunter's Mark", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you Aim before making a ranged attack, you move the target character -1 step along the Condition Track if the attack deals damage. This Talent can be used only against characters, not objects or Vehicles.", "description": {"value": "If you Aim before making a ranged attack, you move the target character -1 step along the Condition Track if the attack deals damage. This Talent can be used only against characters, not objects or Vehicles."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "a47ed82a822e3962", "tags": ["action-economy", "condition-removal", "controller", "dual-wield", "melee", "mobility", "positioning", "ranged", "scoundrel", "skills", "social", "stealth", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Hunter's Mark"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hunters_mark", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "7505fbdd592c04fd", "name": "Bodyguard's Sacrifice", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Reaction, you can interfere with any successful attack against an adjacent ally. You can choose to take any or all of that attack's damage, and the remainder is dealt to the target as normal. Once you use this Talent, you may not use it again until the end of your next turn.", "description": {"value": "As a Reaction, you can interfere with any successful attack against an adjacent ally. You can choose to take any or all of that attack's damage, and the remainder is dealt to the target as normal. Once you use this Talent, you may not use it again until the end of your next turn."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "c92c2cbc79b8a515", "tags": ["action-economy", "controller", "damage-reduction", "defender", "mobility", "positioning", "soldier", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Bodyguard's Sacrifice"}]}}, "effects": [{"_id": "f517bc4c-a0d0-4ded-8605-6fc9eb63c6f6", "name": "Bodyguard's Sacrifice", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damageReduction", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Bodyguard's Sacrifice"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.bodyguards_sacrifice", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["attack.when-hit", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "76352a9b615287f8", "name": "Protection", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Double Agent", "benefit": "As a Standard Action, you can designate one ally and make a Persuasion check, comparing the result against the Will Defense of all enemies in your line of sight who can hear and understand you. If your check result equals or exceeds a target's Will Defense, that target cannot attack the ally you designated until the beginning of your next turn.", "description": {"value": "As a Standard Action, you can designate one ally and make a Persuasion check, comparing the result against the Will Defense of all enemies in your line of sight who can hear and understand you. If your check result equals or exceeds a target's Will Defense, that target cannot attack the ally you designated until the beginning of your next turn.\n\nCharacters that use this Talent or the Draw Fire Talent cannot be targeted by or benefit from this Talent. You may not benefit from this Talent at the same time as the Misplaced Loyalty Talent."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.double_agent"}], "_source": "canonical-csv"}, "treeId": "4dc70f924e7794ac", "tags": ["defender", "feat-chain", "noble", "skills", "social", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Protection"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.protection", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["defense.will"]}}}
