{"_id": "64cfde2d0cf6c523", "name": "Art of Concealment", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Some smugglers are adept at hiding contraband and weapons, even on their person. When making a Stealth check to Conceal an item, you can Take 10 even under pressure. Additionally, you can Conceal an item as a Swift Action.", "description": {"value": "Some smugglers are adept at hiding contraband and weapons, even on their person. When making a Stealth check to Conceal an item, you can Take 10 even under pressure. Additionally, you can Conceal an item as a Swift Action."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "treeId": "9f7ca12cc084737a", "tags": ["action-economy", "ambush", "controller", "damage-reduction", "melee", "mobility", "positioning", "ranged", "scoundrel", "skills", "social", "support", "sustained-damage", "unarmed"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["attack.with-ranged"], "enabled": true, "priority": 500, "description": "Art of Concealment"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.art_of_concealment", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.415Z", "detectedPredicates": ["attack.with-ranged"]}}}
