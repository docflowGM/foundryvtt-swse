{"_id": "226aea42fcdd30b0", "name": "Jedi Hunter", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You are skilled at fighting Jedi and other Force-users. You gain a +1 insight bonus to your Fortitude Defense and Will Defense, and deal +1 die of damage against characters who have the Force Sensitivity feat.", "description": {"value": "You are skilled at fighting Jedi and other Force-users. You gain a +1 insight bonus to your Fortitude Defense and Will Defense, and deal +1 die of damage against characters who have the Force Sensitivity feat."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "treeId": "a47ed82a822e3962", "tags": ["defender", "force", "force-defense", "force-offense", "light-side", "scoundrel", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.fortitude"}, {"target": "defense.will", "type": "untyped", "value": 1, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.will"}]}}, "effects": [{"_id": "184c1e87-f486-499f-8a5e-fa3f03c4d23d", "name": "Jedi Hunter", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.fortitude", "mode": 2, "value": "1"}, {"key": "system.defenses.will", "mode": 2, "value": "1"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Jedi Hunter", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.jedi_hunter"}}}
{"_id": "226b0a05cebd81ab", "name": "Intentional Crash", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Trained in Pilot", "benefit": "You know how to intentionally crash an opponent's moving Vehicle. When you successfully deal damage to a Vehicle by Ramming it, your Vehicle takes half damage from the Ram. Additionally, if the target Vehicle is the same size as your Vehicle or smaller, that Vehicle cannot move in the following round.", "description": {"value": "You know how to intentionally crash an opponent's moving Vehicle. When you successfully deal damage to a Vehicle by Ramming it, your Vehicle takes half damage from the Ram. Additionally, if the target Vehicle is the same size as your Vehicle or smaller, that Vehicle cannot move in the following round."}, "class": "61876f91a1633cdf", "costNumeric": null, "category": "Enforcer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "skillTrained", "skill": "b8dad0c963f046c6"}], "_source": "fix5F-canonical"}, "treeId": "2d164f62e17bed8c", "tags": ["category_enforcer", "control", "controller", "force", "force_control", "force_offense", "law_enforcement", "mobility", "nonlethal", "pilot", "pursuit", "ranged_support", "striker", "sustained_damage", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Intentional Crash"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.intentional_crash", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "226e4f61e29df36f", "name": "Fearless Leader", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Born Leader", "benefit": "As a Swift Action, you can provide a courageous example for your allies. For the remainder of the encounter, your allies receive a +5 morale bonus to their Will Defense against any Fear effect. Your allies lose this benefit if they lose line of sight to you, or you are killed or knocked unconscious.", "description": {"value": "As a Swift Action, you can provide a courageous example for your allies. For the remainder of the encounter, your allies receive a +5 morale bonus to their Will Defense against any Fear effect. Your allies lose this benefit if they lose line of sight to you, or you are killed or knocked unconscious."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.born_leader"}], "_source": "canonical-csv"}, "treeId": "5964237d22681dc0", "tags": ["defender", "feat-chain", "noble", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.will", "type": "untyped", "value": 5, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.will"}]}}, "effects": [{"_id": "b95849c0-6e9e-407c-ab9a-450a3a5ca707", "name": "Fearless Leader", "icon": "icons/svg/shield.svg", "changes": [{"key": "system.defenses.will", "mode": 2, "value": "5"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Fearless Leader", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fearless_leader"}}}
{"_id": "22ce14b57f9b8c1a", "name": "Cortosis Retaliation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Cortosis Defense", "benefit": "Whenever you successfully use a Cortosis Gauntlet to parry an attack made with a Lightsaber, you may make an immediate Attack of Opportunity against the attacker.", "description": {"value": "Whenever you successfully use a Cortosis Gauntlet to parry an attack made with a Lightsaber, you may make an immediate Attack of Opportunity against the attacker."}, "class": "ec505163e5647cc6", "costNumeric": null, "category": "Imperial Knight", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.cortosis_defense"}], "_source": "canonical-csv"}, "treeId": "ea01d740c91888b3", "tags": ["armor", "category_imperial_knight", "defender", "defense", "feat_chain", "force", "imperial", "leader", "lightsaber", "melee", "offense_melee", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Cortosis Retaliation"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.cortosis_retaliation", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "22d2c4b0d4d9b784", "name": "Quick on Your Feet", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, you may move up to your Speed as a Reaction.", "description": {"value": "Once per encounter, you may move up to your Speed as a Reaction."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "ab2c265c4b2f54f6", "tags": ["controller", "mobility", "scout"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Quick on Your Feet"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.quick_on_your_feet", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "234f9d660d14220c", "name": "Hidden Weapons", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Art of Concealment", "benefit": "If you draw a concealed weapon and, before the end of the same round, make an attack against a target that failed to notice the item, the target is considered Flat-Footed against you. You can draw a concealed item or a stowed item as a Move Action. Additionally, if you have the Quick Draw feat, you can reduce this to a Swift Action.", "description": {"value": "If you draw a concealed weapon and, before the end of the same round, make an attack against a target that failed to notice the item, the target is considered Flat-Footed against you. You can draw a concealed item or a stowed item as a Move Action. Additionally, if you have the Quick Draw feat, you can reduce this to a Swift Action."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.art_of_concealment"}], "_source": "canonical-csv"}, "treeId": "9f7ca12cc084737a", "tags": ["action-economy", "controller", "feat-chain", "mobility", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Hidden Weapons"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hidden_weapons", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
{"_id": "236e5a8ef7bbcfa6", "name": "Dampen Presence", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you interact with another sentient creature, you can use a Swift Action to reduce the impression you leave on it. When you have finished interacting with the creature, you make a Use the Force check, and if the check result exceeds the target's Will Defense, it does not remember interacting with you once you are gone.", "description": {"value": "When you interact with another sentient creature, you can use a Swift Action to reduce the impression you leave on it. When you have finished interacting with the creature, you make a Use the Force check, and if the check result exceeds the target's Will Defense, it does not remember interacting with you once you are gone."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "36f18f3e974feb33", "tags": ["force", "jedi", "light-side", "striker"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Dampen Presence"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dampen_presence", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.406Z", "detectedPredicates": []}}}
