{"_id": "584bf5a0f7381648", "name": "Blaster and Blade III", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Blaster and Blade I, Blaster and Blade II, Dual Weapon Mastery I, Weapon Proficiency (Advanced Melee Weapons), Weapon Proficiency (Pistols)", "benefit": "When you are wielding both an Advanced Melee Weapon and a Pistol, you can make a Full Attack as a Standard Action instead of a Full-Round Action, provided you attack with both weapons.", "description": {"value": "When you are wielding both an Advanced Melee Weapon and a Pistol, you can make a Full Attack as a Standard Action instead of a Full-Round Action, provided you attack with both weapons."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "df6678946610c554", "tags": ["action-economy", "feat-chain", "melee", "ranged", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Blaster and Blade III"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.blaster_and_blade_iii", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": []}}}
{"_id": "585227ba15d24a37", "name": "Inspire Fear", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "As a Standard Action, you can make a Persuasion check against a target that is within your line of sight and that is also affected by your Talent. If you equal or exceed the target's Will Defense, then on its next turn the target must spend at least one Move Action to move away from you. If the target is somehow prevented from doing so, then the penalty from the Talent doubles until the start of your next turn. This is a Mind-Affecting Fear effect. Reference Book: Star Wars Saga Edition Scum and Villainy", "benefit": "As a Standard Action, you can make a Persuasion check against a target that is within your line of sight and that is also affected by your Talent. If you equal or exceed the target's Will Defense, then on its next turn the target must spend at least one Move Action to move away from you. If the target is somehow prevented from doing so, then the penalty from the Talent doubles until the start of your next turn. This is a Mind-Affecting Fear effect. Reference Book: Star Wars Saga Edition Scum and Villainy", "class": "", "category": "", "costNumeric": null, "treeId": "c1be604242cb328f", "tags": ["action_economy", "controller", "dark_side", "defender", "fear", "mobility", "move_action", "new_action", "persuasion", "skills", "social", "social_control", "standard_action", "tree_c1be604242cb328f", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Inspire Fear"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["defense.will"]}}}
{"_id": "58789f9d0a49f215", "name": "Bodyguard I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Attract Minion", "benefit": "Whenever you are adjacent to a minion gained with the Attract Minion Talent, once per turn as a Reaction to being attacked you can redirect the attack against that minion. Compare the attack roll to the minion's Defenses and resolve the attack as normal.", "description": {"value": "Whenever you are adjacent to a minion gained with the Attract Minion Talent, once per turn as a Reaction to being attacked you can redirect the attack against that minion. Compare the attack roll to the minion's Defenses and resolve the attack as normal."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.attract_minion"}], "_source": "canonical-csv"}, "treeId": "560cc7994b357a0d", "tags": ["action-economy", "controller", "defender", "melee", "mobility", "positioning", "ranged", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Bodyguard I"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.bodyguard_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "attack.with-melee", "attack.with-ranged", "turn.once-per-round"]}}}
{"_id": "588c176b47724734", "name": "Feign Harmlessness", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Prerequisites: When you successfully Feint an opponent, you may designate one ally within 12 squares. Your ally treats the target as Flat-Footed until the beginning of your next turn. Once per encounter, as a Reaction to an attack, you may make a Persuasion check and use that result in place of your Reflex Defense against that attack.", "benefit": "Prerequisites: When you successfully Feint an opponent, you may designate one ally within 12 squares. Your ally treats the target as Flat-Footed until the beginning of your next turn. Once per encounter, as a Reaction to an attack, you may make a Persuasion check and use that result in place of your Reflex Defense against that attack.", "class": "", "category": "", "costNumeric": null, "treeId": "acb91d3803eb4fcd", "tags": ["action_economy", "controller", "deception", "defender", "persuasion", "positioning", "reaction", "skills", "social", "social_control", "social_defense", "support", "survivability", "tree_acb91d3803eb4fcd", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Feign Harmlessness"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["defense.reflex", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "58a602ec4aa5b2dd", "name": "Extra First Aid", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You can use the First Aid application of the Treat Injury skill one additional time per day on a target that has already received First Aid for the day.", "description": {"value": "You can use the First Aid application of the Treat Injury skill one additional time per day on a target that has already received First Aid for the day."}, "class": "06f4d9029debf827", "costNumeric": null, "category": "Medic", "treeId": "61725c845d26ade0", "tags": ["category_medic", "healing", "medicine", "skills", "support", "survivability", "teamwork", "treat_injury"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Extra First Aid"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.extra_first_aid", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": []}}}
{"_id": "58c3d63d94288eb2", "name": "Deadly Repercussions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you reduce a target to 0 Hit Points or move the target to the bottom of the Condition Track, all your opponents within line of sight of both you and your target take a -2 penalty on attack rolls until the beginning of your next turn.", "description": {"value": "When you reduce a target to 0 Hit Points or move the target to the bottom of the Condition Track, all your opponents within line of sight of both you and your target take a -2 penalty on attack rolls until the beginning of your next turn."}, "costNumeric": null, "treeId": "db1b30c2163d0650", "tags": ["controller", "damage_reduction", "deception", "manipulation", "positioning", "tree_db1b30c2163d0650", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Deadly Repercussions"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.deadly_repercussions", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": []}}}
{"_id": "58e37d40d3aa7d4b", "name": "Precision Implant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Standard Action, you can give one adjacent living creature a Precision Implant. The target must be willing to receive this Implant, which grants the target a +1 Equipment bonus on attack rolls until the end of the encounter.", "description": {"value": "Once per encounter as a Standard Action, you can give one adjacent living creature a Precision Implant. The target must be willing to receive this Implant, which grants the target a +1 Equipment bonus on attack rolls until the end of the encounter."}, "class": "557e1a5ec72166fd", "costNumeric": null, "category": "Shaper", "treeId": "d8a71a6c5b2b7581", "tags": ["ability_enhancement", "action_economy", "biotech", "category_shaper", "crafting", "gear", "healing", "implant", "leader", "new_action", "positioning", "standard_action", "striker", "support", "tree_d8a71a6c5b2b7581"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Precision Implant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.precision_implant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "590178f76ad1b08a", "name": "Shield Expert", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Armor Proficiency (Light)", "benefit": "You are an expert in using Energy Shields for maximum effectiveness. Once per encounter, you can spend a Swift Action to regain 10 points of SR (up to the shield's maximum) on an active Energy Shield.", "description": {"value": "You are an expert in using Energy Shields for maximum effectiveness. Once per encounter, you can spend a Swift Action to regain 10 points of SR (up to the shield's maximum) on an active Energy Shield."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "treeId": "17cec542331cb4e4", "tags": ["action-economy", "armor", "defender", "feat-chain", "mobility", "shields", "soldier", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Shield Expert"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.shield_expert", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "594eb9e7f9084742a7d1cbc209d2f340", "name": "Swift Droid", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"benefit": "You move quickly when caught. You can make a Swift Action as a Reaction after failing a Deception check or a Stealth check.", "description": "You move quickly when caught. You can make a Swift Action as a Reaction after failing a Deception check or a Stealth check.", "prerequisites": "Any two Talents from the Autonomy Talent Tree", "class": "3b1ed5f1038d49fb", "category": "Independent Droid", "treeId": "9fe73a3703fa45fca628fd43cae6bf7f", "tags": ["action_economy", "category_independent_droid", "controller", "deception", "droid", "durability", "feat_chain", "mobility", "reaction", "self_repair", "skill_stealth", "skills", "social", "social_control", "stealth", "swift_action", "talent_chain", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 2, "type": "untyped", "predicates": ["movement.while-moving"], "enabled": true, "priority": 500, "description": "Swift Droid"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["movement.while-moving"]}}}
{"_id": "5989079457c8a3cf", "name": "Safe Zone", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "As a Standard Action, you can identify a Safe Zone, within which your allies gain certain advantages. You designate a 4-by-4 square area of the combat area as a Safe Zone; at least 1 square of the Safe Zone must be the square you currently occupy. Each ally who starts his or her turn within the Safe Zone gains a +2 circumstance bonus to his or her Fortitude Defense and Will Defense until the start of the ally's next turn. The Safe Zone lasts until the end of the encounter, and you can have only one Safe Zone in effect at a time.", "description": {"value": "As a Standard Action, you can identify a Safe Zone, within which your allies gain certain advantages. You designate a 4-by-4 square area of the combat area as a Safe Zone; at least 1 square of the Safe Zone must be the square you currently occupy. Each ally who starts his or her turn within the Safe Zone gains a +2 circumstance bonus to his or her Fortitude Defense and Will Defense until the start of the ally's next turn. The Safe Zone lasts until the end of the encounter, and you can have only one Safe Zone in effect at a time.\n\nYou can create a new Safe Zone as a Standard Action, dismissing the old Safe Zone and replacing it with the new one, but no square of the old Safe Zone can overlap with any square of the new Safe Zone. You cannot create a Safe Zone in a space that overlaps another Pathfinder's Safe Zone."}, "class": "4ee81a6708a516cd", "costNumeric": null, "category": "Pathfinder", "treeId": "383ff8d392488cf8", "tags": ["action_economy", "battlefield_control", "category_pathfinder", "controller", "cover", "defender", "mobility", "new_action", "positioning", "recon", "scaling", "standard_action", "striker", "support", "survival"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "type": "untyped", "value": 2, "enabled": true, "priority": 500, "description": "Migrated from AE system.defenses.reflex"}]}}, "effects": [{"_id": "50a259a4-551b-4151-a7f5-4445e24689f3", "name": "Safe Zone", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.defenses.reflex", "mode": 2, "value": "2"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Safe Zone", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.safe_zone"}}}
{"_id": "59b2b90ad0ae8eb8", "name": "Concealed Weapon Expert", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You are deadly with an Unarmed strike, Hold-Out Blaster Pistol, Knife, Vibrodagger, or other small concealable weapons (as determined by the Gamemaster). Once per round you can use a Swift Action to reroll an attack using one of these weapons, but you must accept the result of the reroll, even if it is worse.", "description": {"value": "You are deadly with an Unarmed strike, Hold-Out Blaster Pistol, Knife, Vibrodagger, or other small concealable weapons (as determined by the Gamemaster). Once per round you can use a Swift Action to reroll an attack using one of these weapons, but you must accept the result of the reroll, even if it is worse."}, "class": "e647ee8f065e1d19", "costNumeric": null, "category": "Infiltrator", "treeId": "7c7a8730e1b4381a", "tags": ["melee", "sustained-damage", "unarmed"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Concealed Weapon Expert"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.concealed_weapon_expert", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "5a2dee101c2217b3", "name": "Exotic Weapons Master", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Exotic Weapon Proficiency (Any)", "benefit": "You treat all Exotic Weapons as a single weapon group. If you already have Feats or Talents that grant you proficiency with, or augment the use of, one Exotic Weapon, those Feats now apply to all Exotic Weapons. For example, if you already had Exotic Weapon Proficiency (Shyarn), and Weapon Focus (Shyarn), you are now proficient with, and possess the Weapon Focus Feat for, all Exotic Weapons.", "description": {"value": "You treat all Exotic Weapons as a single weapon group. If you already have Feats or Talents that grant you proficiency with, or augment the use of, one Exotic Weapon, those Feats now apply to all Exotic Weapons. For example, if you already had Exotic Weapon Proficiency (Shyarn), and Weapon Focus (Shyarn), you are now proficient with, and possess the Weapon Focus Feat for, all Exotic Weapons."}, "class": "533f1066362655c7", "costNumeric": null, "category": "Gladiator", "treeId": "12a2a02b0901605d", "tags": ["action-economy", "burst-damage", "condition-removal", "controller", "damage-reduction", "mobility", "positioning", "scaling", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "movement.while-moving", "proximity.ally-nearby", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Exotic Weapons Master"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"skillSubstitution": true, "substitutionType": "exotic_focus", "description": "Grants Weapon Focus (exotic melee) for any weapon group", "id": "swse.talent.exotic_weapons_master", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["attack.when-hit", "movement.while-moving", "proximity.ally-nearby", "turn.once-per-round"]}}}
{"_id": "5b949c8cd8e78ee8", "name": "Force Harmony", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": null, "benefit": "Once per encounter, activate a Force talent that requires a Force Point without spending one.", "description": "Once per encounter, activate a Force talent that normally requires a Force Point without spending one.", "costNumeric": null, "treeId": "d3661aa9906bdc79", "tags": ["force", "force_point_spend", "recovery", "resilience", "resource_recovery", "resource_spend", "tree_d3661aa9906bdc79", "uncategorized_talent", "will_defense"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Force Harmony"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.force_harmony", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "5bdbf0148a6eb7b0", "name": "Field Tactics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Deployment Tactics", "benefit": "You know how to use existing terrain to your best advantage. By using a Move Action, you can make a DC 15 Knowledge (Tactics) check. If the check succeeds, you and all allies within 10 squares of you can use whatever Cover is available to gain a +10 Cover bonus to Reflex Defense (instead of the normal +5 Cover bonus). Allies must be able to hear and understand you to gain this benefit, and the bonus lasts until the start of your next turn. This Talent provides no benefit to anyone who doesn't have Cover. This is a Mind-Affecting effect.", "description": {"value": "You know how to use existing terrain to your best advantage. By using a Move Action, you can make a DC 15 Knowledge (Tactics) check. If the check succeeds, you and all allies within 10 squares of you can use whatever Cover is available to gain a +10 Cover bonus to Reflex Defense (instead of the normal +5 Cover bonus). Allies must be able to hear and understand you to gain this benefit, and the bonus lasts until the start of your next turn. This Talent provides no benefit to anyone who doesn't have Cover. This is a Mind-Affecting effect."}, "class": "30b9cd24b80ebf46", "costNumeric": null, "category": "Officer", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.deployment_tactics"}], "_source": "canonical-csv"}, "treeId": "9253ace716c3e966", "tags": ["feat-chain", "positioning", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Field Tactics"}]}}, "effects": [{"_id": "283d3697-cb75-47ef-8269-fe14c8b2e141", "name": "Field Tactics", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.cover.bonus", "mode": 2, "value": "10"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Field Tactics"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.field_tactics", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": []}}}
{"_id": "5bf2f1759ee54834", "name": "Advanced Planning", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "When you roll Initiative for combat, choose one willing ally within your line of sight. You and that ally swap Initiative results."}, "benefit": "When you roll Initiative for combat, choose one willing ally within your line of sight. You and that ally swap Initiative results.", "class": "", "category": "", "costNumeric": null, "treeId": "0ffc37dac946477d", "tags": ["action_economy", "condition_removal", "controller", "defender", "force", "force_control", "force_defense", "force_offense", "forecast_value", "leader", "melee", "mobility", "planning", "positioning", "ranged", "setup", "striker", "support", "tree_0ffc37dac946477d", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 5, "type": "untyped", "predicates": ["defense.against-ranged", "defense.against-melee", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "movement.while-moving", "proximity.ally-nearby", "turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Advanced Planning"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["defense.against-ranged", "defense.against-melee", "attack.when-hit", "attack.with-melee", "attack.with-ranged", "movement.while-moving", "proximity.ally-nearby", "turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "5c3036b82c047490", "name": "Call Out", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Personal Vendetta", "benefit": "When you use the Personal Vendetta Talent, you may designate one target of that Talent to take a -5 penalty to attacks against targets other than you, instead of the normal -2 penalty.", "description": {"value": "When you use the Personal Vendetta Talent, you may designate one target of that Talent to take a -5 penalty to attacks against targets other than you, instead of the normal -2 penalty."}, "class": "533f1066362655c7", "costNumeric": null, "category": "Gladiator", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.personal_vendetta"}], "_source": "canonical-csv"}, "treeId": "12a2a02b0901605d", "tags": ["feat-chain", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Call Out"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.call_out", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": []}}}
{"_id": "5cb9f0f6011a1bab", "name": "Friendly Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Enemy Tactics", "benefit": "If you are engaged in melee combat with an adjacent enemy and are the target of a ranged attack that misses you, compare the attack roll to the Reflex Defense of one adjacent enemy; if the attack equals or exceeds the target's Reflex Defense, that enemy becomes the new target of the attack, which is resolved as normal.", "description": {"value": "If you are engaged in melee combat with an adjacent enemy and are the target of a ranged attack that misses you, compare the attack roll to the Reflex Defense of one adjacent enemy; if the attack equals or exceeds the target's Reflex Defense, that enemy becomes the new target of the attack, which is resolved as normal."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.enemy_tactics"}], "_source": "canonical-csv"}, "treeId": "4dc70f924e7794ac", "tags": ["feat-chain", "melee", "noble", "positioning", "ranged", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "attack.with-ranged"], "enabled": true, "priority": 500, "description": "Friendly Fire"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.friendly_fire", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["attack.with-melee", "attack.with-ranged"]}}}
{"_id": "5cd160036d6bba05", "name": "Just What Is Needed", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You have a knack for finding the best quality replacement parts for broken Equipment. Whenever you use the Repair application of the Mechanics skill, you restore an extra 1d8 Hit Points with a successful Mechanics check, in addition to what you would normally restore.", "description": {"value": "You have a knack for finding the best quality replacement parts for broken Equipment. Whenever you use the Repair application of the Mechanics skill, you restore an extra 1d8 Hit Points with a successful Mechanics check, in addition to what you would normally restore.\n\nIf you use the Aid Another Action to assist an ally with Repairs, that ally also Repairs an extra 1d8 Hit Points with a successful Mechanics check. Any ally can only benefit from this Talent once per Mechanics check, regardless of how many allies with this Talent aid on the check."}, "class": "db019dfbb271cdf6", "costNumeric": null, "category": "Improviser", "treeId": "a0d6323d6c1bf911", "tags": ["category_improviser", "control", "gear", "jury_rig", "mechanics", "repair", "skills", "striker", "tech", "utility"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Just What Is Needed"}]}}, "effects": [{"_id": "71b55243-6f94-4984-a9b4-989cdfd25225", "name": "Just What Is Needed", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.repairs.success", "mode": 5, "value": "enhanced"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Just What Is Needed"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.just_what_is_needed", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "5d4a63123e5a5eb4", "name": "Acrobatic Recovery", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If any effect causes you to fall Prone, you can make a DC 20 Acrobatics check to remain on your feet.", "description": {"value": "If any effect causes you to fall Prone, you can make a DC 20 Acrobatics check to remain on your feet."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "2bc2572e852832e4", "tags": ["controller", "jedi", "lightsaber", "melee", "mobility", "positioning", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Acrobatic Recovery"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.acrobatic_recovery", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.413Z", "detectedPredicates": []}}}
