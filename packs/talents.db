{"_id": "e1cb0fd81f7f6d44", "name": "Crushing Assault", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Weapon Specialization", "benefit": "You use your attacks to beat down your opponents' defenses. When you successfully damage an opponent using a Bludgeoning weapon that you have the Weapon Specialization Talent for, your next attack against that opponent made before the end of the encounter gains a +2 bonus on the attack roll and to the damage roll. The effects of multiple Crushing Assaults do not stack.", "description": {"value": "You use your attacks to beat down your opponents' defenses. When you successfully damage an opponent using a Bludgeoning weapon that you have the Weapon Specialization Talent for, your next attack against that opponent made before the end of the encounter gains a +2 bonus on the attack roll and to the damage roll. The effects of multiple Crushing Assaults do not stack."}, "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.weapon_specialization"}], "_source": "canonical-csv"}, "treeId": "2e9265a596cc43f7", "tags": ["feat-chain", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Crushing Assault"}]}}, "effects": [{"_id": "9990658b-1ca2-4c3d-b44f-db4c5baac4bb", "name": "Crushing Assault", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.melee", "mode": 2, "value": "2"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Crushing Assault"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.crushing_assault", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", 