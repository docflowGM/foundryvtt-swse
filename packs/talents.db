{"_id": "8989464c43d81045", "name": "Cortosis Gauntlet Block", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Armor Proficiency (Light), Armor Proficiency (Medium)", "benefit": "You have received additional training in the use of Cortosis Gauntlets. You can use the Block Talent, even when not armed with a Lightsaber, provided you are wearing a Cortosis Gauntlet. If you successfully Block an attack with a Lightsaber while wearing a Cortosis Gauntlet, the attacking Lightsaber is deactivated.", "description": {"value": "You have received additional training in the use of Cortosis Gauntlets. You can use the Block Talent, even when not armed with a Lightsaber, provided you are wearing a Cortosis Gauntlet. If you successfully Block an attack with a Lightsaber while wearing a Cortosis Gauntlet, the attacking Lightsaber is deactivated."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "treeId": "2359c05ff13f3feb", "tags": ["feat-chain", "jedi", "lightsaber", "melee", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Cortosis Gauntlet Block"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.cortosis_gauntlet_block", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.420Z", "detectedPredicates": []}}}
