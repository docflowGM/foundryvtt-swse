{"_id": "2e96f06be6b9def8", "name": "Dark Side Scourge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dark Side Sense", "benefit": "Deal extra damage on melee attacks against Dark Side creatures equal to your Charisma modifier (minimum +1).", "description": "", "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.dark_side_sense"}], "_source": "canonical-csv"}, "treeId": "36f18f3e974feb33", "tags": ["dark-side", "feat-chain", "force", "force-offense", "jedi", "light-side", "melee", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 1, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Dark Side Scourge"}]}}, "effects": [{"_id": "0af97c28-a76f-4c03-aec5-976875dedfbc", "name": "Dark Side Scourge", "icon": "icons/svg/skull.svg", "changes": [{"key": "system.damage.force", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Dark Side Scourge"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dark_side_scourge", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "2ed2cffbd702c1c3", "name": "Mandalorian Glory", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Above everything else, Mandalorians fight for glory in battle. Once per encounter, when you reduce an opponent's Hit Points to 0, you gain a +5 attack bonus with your next attack roll during the same encounter.", "description": {"value": "Above everything else, Mandalorians fight for glory in battle. Once per encounter, when you reduce an opponent's Hit Points to 0, you gain a +5 attack bonus with your next attack roll during the same encounter."}, "class": "c4dbedcf989cb6b2", "costNumeric": null, "category": "Elite Trooper", "treeId": "4b8857716e056f62", "tags": ["action-economy", "armor", "battlefield-control", "controller", "damage-reduction", "defender", "feat-chain", "lightsaber", "melee", "mobility", "soldier", "striker", "support", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 5, "type": "untyped", "predicates": ["defense.fortitude", "attack.when-hit", "turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Mandalorian Glory"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.mandalorian_glory", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["defense.fortitude", "attack.when-hit", "turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "2f00c50f3bf6bf5a", "name": "Share Talent", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "At least 1 Talent from Lightsaber Combat Talent Tree, Duelist Talent Tree, or Lightsaber Forms Talent Tree", "benefit": "Choose a Talent that you already possess. The Talent you select must be from the Lightsaber Combat Talent Tree, the Duelist Talent Tree, or the Lightsaber Forms Talent Tree. Once per day, as a Standard Action, you can spend a Force Point to impart the benefits of the chosen Talent to one or more allies, effectively granting them the Talent (even if they don't meet the prerequisites).", "description": {"value": "Choose a Talent that you already possess. The Talent you select must be from the Lightsaber Combat Talent Tree, the Duelist Talent Tree, or the Lightsaber Forms Talent Tree. Once per day, as a Standard Action, you can spend a Force Point to impart the benefits of the chosen Talent to one or more allies, effectively granting them the Talent (even if they don't meet the prerequisites).\n\nAn ally must be within 12 squares of you, and must be able to see and hear you to gain the Talent; once gained, its benefits last until the end of the encounter.\n\nYou can share the Talent with a number of allies equal to one-half your Class Level (rounded down). Only allies who are Trained in the Use the Force Skill can gain the benefits of the Shared Talent.\n\nYou can take this Talent multiple times. Each time you do so, you must select a different Talent to share with this ability. You can share each Talent with your allies only once per day."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "303d91124d4548c0", "tags": ["force", "jedi", "leader", "light-side", "lightsaber", "melee", "positioning"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Share Talent"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.share_talent", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": []}}}
{"_id": "2f6bdc483d8f4aa8", "name": "Serene Courage", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You may enter a brief meditative state as a Full-Round Action. You may remain in this trance as long as you wish, and you are still aware of your surroundings. However, you loses your Dexterity bonus to Reflex Defense during your meditation. Upon emerging from the trance (a Swift Action), you may roll your first skill check or attack roll made in the following round twice, keeping the better result. You are immune to Mind-Affecting Fear effects.", "benefit": "You may enter a brief meditative state as a Full-Round Action. You may remain in this trance as long as you wish, and you are still aware of your surroundings. However, you loses your Dexterity bonus to Reflex Defense during your meditation. Upon emerging from the trance (a Swift Action), you may roll your first skill check or attack roll made in the following round twice, keeping the better result. You are immune to Mind-Affecting Fear effects.", "class": "", "category": "", "costNumeric": null, "treeId": "8955568285ba4115", "tags": ["action_economy", "defender", "force", "mobility", "new_option", "ritual", "spirit", "striker", "survivability", "sustained_damage", "swift_action", "tree_8955568285ba4115", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Serene Courage"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "2fc019fa8c4108a7", "name": "Focused Attack", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "When you roll a Natural 20 on an attack roll against a target with a Dark Side Score of 1 or higher, you can activate a single Force Power with the [Light Side] descriptor immediately as a Free Action. You can spend a Force Point to reroll an attack against a creature with a Dark Side Score of 1 or higher, keeping the better of the two results. Once per encounter, as a Swift Action, you can return any Force Power with the [Light Side] descriptor to your Force Power Suite without spending a Force Point. You can select this Talent multiple times. Each time you select it, you can use this Talent one additional time per encounter. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Jedi Masters (Part 1) You can draw upon the living Force to resist the negative effects of Aging. This requires a successful Use the Force check and the use of a Force Point each year, as well as each time the character is reduced to 0 Hit Points or moves -5 steps along the Condition Track. The DC for this Use the Force check is equal to 20 plus an additional 5 for each age range step the character’s true age takes them above their current physical age range. Success means the character remains physically unaged, but gains the bonuses to their Intelligence, Wisdom, and Charisma as bestowed by their true age. Failure means the character physically ages one age range step closer to their true age, incurring any penalties to their Strength, Dexterity, and Constitution. Failure by 5 or more means the character ages completely to their true age.", "description": "When you roll a Natural 20 on an attack roll against a target with a Dark Side Score of 1 or higher, you can activate a single Force Power with the [Light Side] descriptor immediately as a Free Action. You can spend a Force Point to reroll an attack against a creature with a Dark Side Score of 1 or higher, keeping the better of the two results. Once per encounter, as a Swift Action, you can return any Force Power with the [Light Side] descriptor to your Force Power Suite without spending a Force Point. You can select this Talent multiple times. Each time you select it, you can use this Talent one additional time per encounter. Homebrew Reference Book: Clone Wars Saga Edition Fan Sourcebook - Jedi Masters (Part 1) You can draw upon the living Force to resist the negative effects of Aging. This requires a successful Use the Force check and the use of a Force Point each year, as well as each time the character is reduced to 0 Hit Points or moves -5 steps along the Condition Track. The DC for this Use the Force check is equal to 20 plus an additional 5 for each age range step the character’s true age takes them above their current physical age range. Success means the character remains physically unaged, but gains the bonuses to their Intelligence, Wisdom, and Charisma as bestowed by their true age. Failure means the character physically ages one age range step closer to their true age, incurring any penalties to their Strength, Dexterity, and Constitution. Failure by 5 or more means the character ages completely to their true age.", "costNumeric": null, "treeId": "001a438135e03588", "tags": ["action_economy", "condition_removal", "controller", "damage_reduction", "dark_side", "force", "force_capacity", "force_control", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "healing", "light_side", "mobility", "positioning", "resource_recovery", "resource_spend", "scaling", "striker", "support", "survivability", "swift_action", "tree_001a438135e03588", "uncategorized_talent", "use_the_force"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Focused Attack"}]}}, "effects": [{"_id": "2b1c56e1-0a1a-4b26-9707-5f95bd3b944b", "name": "Focused Attack", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.vs_dark_side", "mode": 5, "value": "reroll"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Focused Attack"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.focused_attack", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "2fdf215a5da99e00", "name": "Adrenaline Implant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter as a Standard Action, you can give one adjacent living creature an Adrenaline Implant. The target must be willing to receive this Implant, which grants the target 10 bonus Hit Points at the start of each of it's turns. These bonus Hit Points do not accumulate. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from different sources do not stack.", "description": {"value": "Once per encounter as a Standard Action, you can give one adjacent living creature an Adrenaline Implant. The target must be willing to receive this Implant, which grants the target 10 bonus Hit Points at the start of each of it's turns. These bonus Hit Points do not accumulate. Damage is subtracted from the bonus Hit Points first, and any bonus Hit Points remaining at the end of the encounter go away. Bonus Hit Points from different sources do not stack."}, "class": "557e1a5ec72166fd", "costNumeric": null, "category": "Shaper", "treeId": "d8a71a6c5b2b7581", "tags": ["ability_enhancement", "action_economy", "biotech", "category_shaper", "crafting", "gear", "healing", "implant", "leader", "new_action", "positioning", "scaling", "standard_action", "striker", "support", "tree_d8a71a6c5b2b7581"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Adrenaline Implant"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.adrenaline_implant", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
