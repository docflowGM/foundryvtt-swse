{"_id": "776a0fa8ae532ccc", "name": "Affliction", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Your Force Powers carries the taint of The Dark Side more so than even other Dark Side users. When you damage a single opponent with one of your Force Powers, that target also takes 2d6 points of Force damage at the beginning of its next turn, before taking any Actions.", "description": {"value": "Your Force Powers carries the taint of The Dark Side more so than even other Dark Side users. When you damage a single opponent with one of your Force Powers, that target also takes 2d6 points of Force damage at the beginning of its next turn, before taking any Actions."}, "class": "1ba03b2d00245906", "costNumeric": null, "category": "Sith Apprentice", "treeId": "d1037bc7a08ea80b", "tags": ["action_economy", "category_sith_apprentice", "controller", "dark_side", "force", "force_execution", "force_offense", "jedi", "striker", "support"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Affliction"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.affliction", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "77ab82670aa14f33", "name": "Smashball Pass", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "You've mastered the art of making it easy for a catchback to receive your passes, regardless of their skill or distance. If you've Aimed with a Thrown weapon or object, you reduce the Range by one category for the purposes of that attack roll (for example, from Medium to Short Range). Additionally, if an ally has Readied an Action to receive a Thrown weapon or object from you, you can throw it to them as a Move Action, provided you Aim and the weapon or object is at least one size category smaller than you. This throw is automatically successful. At GM discretion, some objects may not be aerodynamic enough to work with this ability. As a linebreaker, you're expected to charge forth and break down the defenses of the opponents to create openings for your fellow players to score. When using the Charge Action, you can move up to double your Speed.", "benefit": "You've mastered the art of making it easy for a catchback to receive your passes, regardless of their skill or distance. If you've Aimed with a Thrown weapon or object, you reduce the Range by one category for the purposes of that attack roll (for example, from Medium to Short Range). Additionally, if an ally has Readied an Action to receive a Thrown weapon or object from you, you can throw it to them as a Move Action, provided you Aim and the weapon or object is at least one size category smaller than you. This throw is automatically successful. At GM discretion, some objects may not be aerodynamic enough to work with this ability. As a linebreaker, you're expected to charge forth and break down the defenses of the opponents to create openings for your fellow players to score. When using the Charge Action, you can move up to double your Speed.", "class": "", "category": "", "costNumeric": null, "treeId": "bfc1356c66c74783", "tags": ["action_economy", "charge", "controller", "damage_reduction", "defender", "mobility", "move_action", "positioning", "ranged", "smashball", "striker", "support", "teamwork", "tree_bfc1356c66c74783", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Smashball Pass"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.416Z", "detectedPredicates": []}}}
{"_id": "77d09ca0a54f4c36", "name": "Power Surge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "You temporarily surge your power systems to enhance your physical abilities. When you initiate a Power Surge (a Swift Action), you gain a +1 circumstance bonus on melee attack rolls, +1 die of damage on melee damage rolls, and an increase of 2 square to your speed. A Power Surge lasts for a number of rounds equal to one-half your Heroic Level (rounded down). When the Power Surge ends, you move -1 Persistent step along the Condition Track. The penalties imposed by this condition persist until you receive Repairs."}, "benefit": "You temporarily surge your power systems to enhance your physical abilities. When you initiate a Power Surge (a Swift Action), you gain a +1 circumstance bonus on melee attack rolls, +1 die of damage on melee damage rolls, and an increase of 2 square to your speed. A Power Surge lasts for a number of rounds equal to one-half your Heroic Level (rounded down). When the Power Surge ends, you move -1 Persistent step along the Condition Track. The penalties imposed by this condition persist until you receive Repairs.", "class": "", "category": "", "costNumeric": null, "treeId": "cec49bc60d1646b1", "tags": ["action_economy", "condition_removal", "controller", "droid", "mechanics", "melee", "mobility", "offense_melee", "positioning", "power_systems", "skills", "striker", "sustained_damage", "swift_action", "tech", "tree_cec49bc60d1646b1", "uncategorized_talent", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "skill", "value": 1, "type": "untyped", "predicates": ["attack.with-melee", "movement.while-moving"], "enabled": true, "priority": 500, "description": "Power Surge"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": ["attack.with-melee", "movement.while-moving"]}}}
{"_id": "782768cab6bd13de", "name": "Dread", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Hunter's Mark, Hunter's Target", "benefit": "As a Standard Action, you can instill bone-chilling fear in an opponent whom you selected for your Hunter's Target. Make a Persuasion check against your target's Will Defense. If you equal or exceed your target's Will Defense, that target takes a -5 penalty to its Will Defense.", "description": {"value": "As a Standard Action, you can instill bone-chilling fear in an opponent whom you selected for your Hunter's Target. Make a Persuasion check against your target's Will Defense. If you equal or exceed your target's Will Defense, that target takes a -5 penalty to its Will Defense.\n\nThis is a Mind-Affecting effect. The penalty remains as long as you have line of sight to your target and immediately ends if the line of sight is broken."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.hunters_target"}], "_source": "canonical-csv"}, "treeId": "a47ed82a822e3962", "tags": ["defender", "feat-chain", "scoundrel", "skills", "social", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.will", "value": 2, "type": "untyped", "predicates": ["defense.will"], "enabled": true, "priority": 500, "description": "Dread"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dread", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": ["defense.will"]}}}
