{"_id": "78955cbbe9504d7f", "name": "Patient Builder", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Prerequisites: Skill Focus (Mechanics), Cybernetic Surgery, You may upgrade a Cybernetic Prosthesis just as you would any other item via the Tech Specialist Feat, using any of the following benefits: Enhanced Dexterity: The limb provides a +1 Equipment bonus on all Dexterity-based skill checks. Enhanced Strength: The limb provides a +1 Equipment bonus on all Strength-based skill checks. Enhanced Capability: The limb provides a +1 Equipment bonus on all Mechanics and Use Computer checks.", "benefit": "Prerequisites: Skill Focus (Mechanics), Cybernetic Surgery, You may upgrade a Cybernetic Prosthesis just as you would any other item via the Tech Specialist Feat, using any of the following benefits: Enhanced Dexterity: The limb provides a +1 Equipment bonus on all Dexterity-based skill checks. Enhanced Strength: The limb provides a +1 Equipment bonus on all Strength-based skill checks. Enhanced Capability: The limb provides a +1 Equipment bonus on all Mechanics and Use Computer checks.", "class": "", "category": "", "costNumeric": null, "treeId": "38d7c18ce4664c66", "tags": ["crafting", "engineering", "mechanics", "skills", "slicing", "striker", "tech", "tree_38d7c18ce4664c66", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Patient Builder"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": []}}}
{"_id": "792ee3a45bf6f002", "name": "Hidden Eyes", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "If you have Concealment from a target, you gain a +5 circumstance bonus on all Perception checks made against that target.", "description": {"value": "If you have Concealment from a target, you gain a +5 circumstance bonus on all Perception checks made against that target."}, "class": "b5bed5d1b5f42958", "costNumeric": null, "category": "Scout", "treeId": "127a55c242e031f2", "tags": ["action-economy", "controller", "mobility", "perception", "scout", "skills", "stealth", "striker"], "executionModel": "PASSIVE", "subType": "MODIFIER", "abilityMeta": {"modifiers": [{"target": "skill.perception", "type": "untyped", "value": 5, "enabled": true, "priority": 500, "description": "Migrated from AE system.skills.perception"}]}}, "effects": [{"_id": "3ef570ff-fa95-4dee-b069-f450c7611d15", "name": "Hidden Eyes", "icon": "icons/svg/eye.svg", "changes": [{"key": "system.skills.perception", "mode": 2, "value": "5"}], "disabled": true, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Hidden Eyes", "migratedToPassive": true}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.hidden_eyes"}}}
{"_id": "797de6f9dab4d578", "name": "Persistent Haze", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Clear Mind, Force Haze", "benefit": "Whenever anyone concealed by your use of the Force Haze Talent attacks, you maintain Total Concealment without having to make another Use the Force check. Only those who do not attack remain concealed; the attacker no longer has Total Concealment, even when using his Talent.", "description": {"value": "Whenever anyone concealed by your use of the Force Haze Talent attacks, you maintain Total Concealment without having to make another Use the Force check. Only those who do not attack remain concealed; the attacker no longer has Total Concealment, even when using his Talent."}, "class": "fec1f8af44fcc35a", "costNumeric": null, "category": "Jedi", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.force_haze"}], "_source": "canonical-csv"}, "treeId": "36f18f3e974feb33", "tags": ["feat-chain", "force", "force-offense", "jedi", "light-side", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Persistent Haze"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.persistent_haze", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": []}}}
{"_id": "79eee1486dc34af5", "name": "Stinging Jab", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": {"value": "When you hit a target with an Unarmed attack, you can choose to deal half damage with your attack. If you do so, your enemy also deals half damage on all melee attacks he or she makes until the end of your next turn."}, "benefit": "When you hit a target with an Unarmed attack, you can choose to deal half damage with your attack. If you do so, your enemy also deals half damage on all melee attacks he or she makes until the end of your next turn.", "class": "", "category": "", "costNumeric": null, "treeId": "abc3466390fe4050", "tags": ["counterattack", "martial_arts", "offense_melee", "reaction", "striker", "tree_abc3466390fe4050", "unarmed", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit"], "enabled": true, "priority": 500, "description": "Stinging Jab"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": ["attack.when-hit"]}}}
{"_id": "7a024dac260bf9ec", "name": "Dumb Luck", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Knack, Lucky Shot", "benefit": "You are possessed of incredible luck and an uncanny ability to succeed where others would fail. You can use each of the following actions once per encounter as a Standard Action:", "description": {"value": "You are possessed of incredible luck and an uncanny ability to succeed where others would fail. You can use each of the following actions once per encounter as a Standard Action:\n\nElude Enemy: Make a single melee or ranged attack against any target within your Range. If you damage the target, you gain a +2 bonus to your Reflex Defense against this target until the beginning of your next turn.\nEscape: Make a single melee or ranged attack against any target within your Range. If that target successfully damages you before the start of your next turn, you can immediately move 2 squares as a Reaction. This movement does not provoke Attacks of Opportunity.\nMake your Own Luck: Make a single melee or ranged attack against any target within your Range. If you miss this target, you gain a +2 bonus on your next attack roll."}, "class": "21dfe84d159a1b7f", "costNumeric": null, "category": "Scoundrel", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.fools_luck"}, {"type": "talent", "id": "swse.talent.knack"}], "_source": "canonical-csv"}, "treeId": "cee9b9398682b7d0", "tags": ["controller", "defender", "feat-chain", "mobility", "positioning", "scoundrel", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Dumb Luck"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dumb_luck", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": ["defense.reflex", "turn.once-per-round"]}}}
{"_id": "7a049ee1ecc3891b", "name": "Attract Privateer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "You attract a loyal Privateer Lieutenant. The Lieutenant is a Nonheroic character who has a Class Level equal to three-quarters of your Character Level, rounded down.", "description": {"value": "You attract a loyal Privateer Lieutenant. The Lieutenant is a Nonheroic character who has a Class Level equal to three-quarters of your Character Level, rounded down.\n\nYou can select this Talent multiple times. Each time you do so, you gain another Privateer. Each Privateer who accompanies you on an adventure is entitled to an equal share of the total Experience Points earned for the adventure. For example, a Privateer who accompanies a party of five heroes on an adventure receives one-sixth of the XP that the group earns."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "df6678946610c554", "tags": ["scoundrel"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Attract Privateer"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.attract_privateer", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.417Z", "detectedPredicates": []}}}
