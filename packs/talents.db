{"_id": "4fc3fe4c1e7f9ba0", "name": "Armor Mastery", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Armored Defense", "benefit": "Increase the maximum Dexterity bonus you can apply while wearing armor by +1.", "description": "Your Reflex Defense bonus equals heroic level plus half armor bonus or armor bonus; counts as Armored and Improved Armored Defense.", "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.armored_defense"}], "_source": "canonical-csv"}, "treeId": "17cec542331cb4e4", "tags": ["armor", "defender", "feat-chain", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Armor Mastery"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.armor_mastery", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": []}}}
{"_id": "5004013069710c3e", "name": "Dual Weapon Flourish I", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Dual Weapon Mastery I, Weapon Finesse", "benefit": "When wielding only two light melee weapons or two Lightsabers, whenever you make a single attack as a Standard Action with one weapon, you can make a single attack with the other weapon as a Free Action against the same target. You apply the normal penalties for fighting with two weapons with this attack.", "description": {"value": "When wielding only two light melee weapons or two Lightsabers, whenever you make a single attack as a Standard Action with one weapon, you can make a single attack with the other weapon as a Free Action against the same target. You apply the normal penalties for fighting with two weapons with this attack."}, "class": "d87c05d2a34f5627", "costNumeric": null, "category": "Melee Duelist", "treeId": "1381bb8c9a838279", "tags": ["action-economy", "burst-damage", "controller", "damage-reduction", "dual-wield", "feat-chain", "lightsaber", "melee", "mobility", "scaling", "striker", "sustained-damage", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee", "turn.on-current-turn", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Dual Weapon Flourish I"}]}}, "effects": [{"_id": "4f9b4473-b5bf-4389-b36a-2d31234a5140", "name": "Dual Weapon Flourish I", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.dualWield", "mode": 5, "value": "true"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Dual Weapon Flourish I"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.dual_weapon_flourish_i", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["attack.with-melee", "turn.on-current-turn", "turn.once-per-round"]}}}
{"_id": "50073b86c51c52cd", "name": "Corporate Clout", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Impose Hesitation, Wrong Decision", "benefit": "You are adept at making deals that make opponents question which side they should be on. Once per encounter, as a Standard Action, you can make a Persuasion check against the Will Defense of an opponent within line of sight.", "description": {"value": "You are adept at making deals that make opponents question which side they should be on. Once per encounter, as a Standard Action, you can make a Persuasion check against the Will Defense of an opponent within line of sight.\n\nIf your check equals or exceeds the target's Will Defense, the target cannot attack you for the remainder of the encounter. If your check exceeds the target's Will Defense by 5 or more, the target will not attack you or your allies for the remainder of the encounter.\n\nIf your check exceeds the target's Will Defense by 10 or more, the target's Attitude toward you is now Friendly, and the target becomes your ally for the remainder of the encounter, remaining under the control of the Gamemaster. If you or one of your allies attacks the target, the target once again becomes Hostile.\n\nIf the target is a higher level than you, it gains a +5 bonus to its Will Defense. This is a Mind-Affecting Fear effect."}, "class": "fc815ae3ca4bf726", "costNumeric": null, "category": "Corporate Agent", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.impose_hesitation"}, {"type": "talent", "id": "swse.talent.wrong_decision"}], "_source": "canonical-csv"}, "treeId": "45c4007d09c01839", "tags": ["category_corporate_agent", "control", "deception", "feat_chain", "leader", "new_action", "persuasion", "skills", "social", "standard_action", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Corporate Clout"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.corporate_clout", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "50273d5ce8f84c31", "name": "Frighten", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Attract Minion, Inspire Fear I", "benefit": "Once per encounter, you can designate a minion as a Free Action to spread fear among your enemies. At any point before the end of the encounter, you can activate this ability to force all enemies adjacent to your minion to move 1 square away from the minion. This movement does not provoke Attacks of Opportunity. This is a Mind-Affecting effect.", "description": {"value": "Once per encounter, you can designate a minion as a Free Action to spread fear among your enemies. At any point before the end of the encounter, you can activate this ability to force all enemies adjacent to your minion to move 1 square away from the minion. This movement does not provoke Attacks of Opportunity. This is a Mind-Affecting effect."}, "class": "324631ca844a88be", "costNumeric": null, "category": "Crime Lord", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.inspire_fear_i"}, {"type": "talent", "id": "swse.talent.attract_minion"}], "_source": "canonical-csv"}, "treeId": "c1be604242cb328f", "tags": ["leader"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Frighten"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.frighten", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": []}}}
{"_id": "50285aaa58fed099", "name": "Raider's Surge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, as a Standard Action, you can make a Deception or Persuasion check (your choice) against each enemy within your line of sight. If the check result equals or exceeds the enemy's Will Defense, that enemy must Withdraw on its next Action or take a -1 penalty on its attack rolls until the end of the encounter. This is a Mind-Affecting effect.", "description": {"value": "Once per encounter, as a Standard Action, you can make a Deception or Persuasion check (your choice) against each enemy within your line of sight. If the check result equals or exceeds the enemy's Will Defense, that enemy must Withdraw on its next Action or take a -1 penalty on its attack rolls until the end of the encounter. This is a Mind-Affecting effect."}, "class": "fcf8cc428a6eb01a", "costNumeric": null, "category": "Master Privateer", "treeId": "61db5e2c0c44ef67", "tags": ["force", "force-offense", "mobility", "scoundrel", "skills", "social"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["turn.once-per-round"], "enabled": true, "priority": 500, "description": "Raider's Surge"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.raiders_surge", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": ["turn.once-per-round"]}}}
{"_id": "50598d8920bd46e9", "name": "White Current Adept", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "description": "Trained in Stealth You can use the Sneak application of the Stealth skill to hide from electronic surveillance and sensors. Any opponent attempting to detect you with sensors or electronic surveillance must beat your Stealth check with a Use Computer check. You need only roll a single Stealth check to avoid both electronic notice and notice by conventional means, using the same result as the DC for both Perception checks and Use Computer checks made to detect you. Prerequisites: , Trained in Stealth", "benefit": "Trained in Stealth You can use the Sneak application of the Stealth skill to hide from electronic surveillance and sensors. Any opponent attempting to detect you with sensors or electronic surveillance must beat your Stealth check with a Use Computer check. You need only roll a single Stealth check to avoid both electronic notice and notice by conventional means, using the same result as the DC for both Perception checks and Use Computer checks made to detect you. Prerequisites: , Trained in Stealth", "class": "", "category": "", "costNumeric": null, "treeId": "4509306f66d744bf", "tags": ["controller", "evasion", "force", "immersion", "perception", "precision", "skill_stealth", "skills", "slicing", "stealth", "striker", "tree_4509306f66d744bf", "uncategorized_talent", "white_current"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] White Current Adept"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.412Z", "detectedPredicates": []}}}
