{"_id": "e2690af7f6700f95", "name": "Knowledge is Strength", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "SpyNet Agent", "benefit": "As a Swift Action, you can designate a single target within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL. If the check is successful, for the remainder of the encounter you gain a +2 morale bonus on attack rolls against that target.", "description": {"value": "As a Swift Action, you can designate a single target within line of sight and make a Knowledge (Galactic Lore) check against a DC equal to 15 + the target's CL. If the check is successful, for the remainder of the encounter you gain a +2 morale bonus on attack rolls against that target."}, "costNumeric": null, "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.spynet_agent"}], "_source": "canonical-csv"}, "treeId": "d20682671d035cef", "tags": ["action_economy", "feat_chain", "investigation", "knowledge", "resources", "social", "social_network", "striker", "swift_action", "talent_chain", "tree_d20682671d035cef", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Knowledge is Strength"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.knowledge_is_strength", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
{"_id": "e289618b92890003", "name": "Treacherous", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Improved Soft Cover, Innocuous", "benefit": "Whenever you are attacked in combat and adjacent to a creature other than your attacker, you can move 1 square as a Reaction. The attack, intended for you, instead targets the adjacent creature, though if you move away from a creature that Threatens you, it can make an Attack of Opportunity before the original attack is resolved.", "description": {"value": "Whenever you are attacked in combat and adjacent to a creature other than your attacker, you can move 1 square as a Reaction. The attack, intended for you, instead targets the adjacent creature, though if you move away from a creature that Threatens you, it can make an Attack of Opportunity before the original attack is resolved."}, "class": "8da58194b3d58041", "costNumeric": null, "category": "Charlatan", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.improved_soft_cover"}], "_source": "canonical-csv"}, "treeId": "ab9b75bc19f8e983", "tags": ["action_economy", "category_charlatan", "control", "controller", "cover", "deception", "defense", "feat_chain", "mobility", "opportunist", "positioning", "reaction", "social", "social_control", "stealth", "talent_chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Treacherous"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.treacherous", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.431Z", "detectedPredicates": []}}}
