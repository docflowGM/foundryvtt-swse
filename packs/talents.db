{"_id": "c2447676a43a70a2", "name": "Luck Favors the Bold", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Face the Foe", "benefit": "If at least one enemy within your line of sight is aware of you and you do not have Cover against that enemy, at the start of your turn if you are conscious you gain a number of Bonus Hit Points equal to 5 + one-half your Heroic Level. Damage is subtracted from Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter are lost. Bonus Hit Points do not stack.", "description": {"value": "If at least one enemy within your line of sight is aware of you and you do not have Cover against that enemy, at the start of your turn if you are conscious you gain a number of Bonus Hit Points equal to 5 + one-half your Heroic Level. Damage is subtracted from Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter are lost. Bonus Hit Points do not stack."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.face_the_foe"}], "_source": "canonical-csv"}, "treeId": "b7a1211d08826500", "tags": ["feat-chain", "noble", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Luck Favors the Bold"}]}}, "effects": [{"_id": "4477d982-e418-40b7-917d-2c6b61db6fda", "name": "Luck Favors the Bold", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.hp.temp", "mode": 2, "value": "5"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Luck Favors the Bold"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.luck_favors_the_bold", "migratedToState": true, "migrationDate": 