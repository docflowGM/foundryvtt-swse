{"_id": "11cae48e1213c407", "name": "Telekinetic Power", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Move Object See also: Move Object Reality Check When you successfully use the Move Object Force Power to move an object of Large size or bigger, you can make an Area Attack with the object instead of throwing it at or dropping it on a single target, as normal for the Force Power. You must spend a Force Point when you activate the Force Power to do this, and the area you target is based on the size of the object: Large, 2x2; Huge, 3x3; Gargantuan, 4x4; Colossal and larger, 6x6. When you use Move Object to make an Area Attack with the object you are moving, you compare your Use the Force check to the Reflex Defense of each creature, Droid, and Vehicle in the target area. If your check equals or exceeds the target's Reflex Defense, it takes damage from the object (as determined by the Move Object Force Power). Otherwise, the target takes half damage. This is an Area Effect. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual", "description": "Move Object See also: Move Object Reality Check When you successfully use the Move Object Force Power to move an object of Large size or bigger, you can make an Area Attack with the object instead of throwing it at or dropping it on a single target, as normal for the Force Power. You must spend a Force Point when you activate the Force Power to do this, and the area you target is based on the size of the object: Large, 2x2; Huge, 3x3; Gargantuan, 4x4; Colossal and larger, 6x6. When you use Move Object to make an Area Attack with the object you are moving, you compare your Use the Force check to the Reflex Defense of each creature, Droid, and Vehicle in the target area. If your check equals or exceeds the target's Reflex Defense, it takes damage from the object (as determined by the Move Object Force Power). Otherwise, the target takes half damage. This is an Area Effect. Reference Book: Star Wars Saga Edition Jedi Academy Training Manual", "costNumeric": null, "treeId": "6ac3416fb6aada56", "tags": ["battlefield_control", "control", "controller", "defender", "droid", "force", "force_capacity", "force_control", "force_defense", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "light_side", "mobility", "pilot", "ranged", "resource_spend", "skill_substitution", "striker", "telekinesis", "telepathy", "trap", "tree_6ac3416fb6aada56", "uncategorized_talent", "use_the_force", "vehicle"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.reflex", "value": 2, "type": "untyped", "predicates": ["defense.reflex"], "enabled": true, "priority": 500, "description": "Telekinetic Power"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.telekinetic_power", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["defense.reflex"]}}}
{"_id": "11e8f858af268e8c", "name": "Fearsome", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Notorious", "benefit": "Your reputation precedes you, striking fear in your target. Any opponent within 6 squares whose level is equal to or less than your Heroic Level takes a -1 penalty on attack rolls made against you.", "description": {"value": "Your reputation precedes you, striking fear in your target. Any opponent within 6 squares whose level is equal to or less than your Heroic Level takes a -1 penalty on attack rolls made against you."}, "class": "336bba6d1e517c92", "costNumeric": null, "category": "Bounty Hunter", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.notorious"}], "_source": "canonical-csv"}, "treeId": "a47ed82a822e3962", "tags": ["feat-chain", "positioning", "scoundrel", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Fearsome"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.fearsome", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": []}}}
{"_id": "1215e1c464a087b0", "name": "Vital Encouragement", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "", "benefit": "Once per encounter, your Guardian Spirit offers you , urging you to press on despite adversity. As a Free Action, you gain Bonus Hit Points equal to 10 + one-half your Heroic Level. Damage is subtracted from Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter are lost. Bonus Hit Points from multiple sources do not stack.", "description": "Once per encounter, your Guardian Spirit offers you , urging you to press on despite adversity. As a Free Action, you gain Bonus Hit Points equal to 10 + one-half your Heroic Level. Damage is subtracted from Bonus Hit Points first, and any Bonus Hit Points remaining at the end of the encounter are lost. Bonus Hit Points from multiple sources do not stack.", "costNumeric": null, "treeId": "6629c34384c4ca53", "tags": ["action_economy", "ally_support", "guardian_spirit", "healing", "new_option", "scaling", "striker", "support", "tree_6629c34384c4ca53", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.when-hit", "turn.once-per-round"], "enabled": true, "priority": 500, "description": "Vital Encouragement"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.vital_encouragement", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["attack.when-hit", "turn.once-per-round"]}}}
{"_id": "125b5aa00f5a4d0a", "name": "Morgukai Resolve", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Exotic Weapon Proficiency (Cortosis Staff), Nikto Survival (Kajain'sa'Nikto)", "description": "Dexterity 13, Proficient in Armor Worn Morgukai warriors craft their armor from rare cortosis ore that has the unusual ability to repel Lightsaber strikes, and they train to maximize the effectiveness of this trait. You add your armor's Fortitude Defense bonus as an Equipment bonus to your Elite Trooper Damage Reduction (With a maximum bonus equal to your base Elite Trooper DR), a Lightsaber does not ignore your Damage Reduction. Additionally, you add your armor's Fortitude Defense bonus as an Equipment bonus to the reaction roll initiated by a successful Lightsaber attack to deactivate the Lightsaber.", "benefit": "Dexterity 13, Proficient in Armor Worn Morgukai warriors craft their armor from rare cortosis ore that has the unusual ability to repel Lightsaber strikes, and they train to maximize the effectiveness of this trait. You add your armor's Fortitude Defense bonus as an Equipment bonus to your Elite Trooper Damage Reduction (With a maximum bonus equal to your base Elite Trooper DR), a Lightsaber does not ignore your Damage Reduction. Additionally, you add your armor's Fortitude Defense bonus as an Equipment bonus to the reaction roll initiated by a successful Lightsaber attack to deactivate the Lightsaber.", "class": "", "category": "", "costNumeric": null, "treeId": "0a61ab9ece844326", "tags": ["action_economy", "anti_lightsaber", "armor", "cortosis", "damage_reduction", "defender", "duelist", "feat_chain", "lightsaber", "melee", "melee_defense", "offense_melee", "reaction", "striker", "support", "talent_chain", "tree_0a61ab9ece844326", "uncategorized_talent"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "defense.fortitude", "value": 2, "type": "untyped", "predicates": ["defense.fortitude"], "enabled": true, "priority": 500, "description": "Morgukai Resolve"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["defense.fortitude"]}}}
{"_id": "12b7eb5d32bd440e", "name": "Adept Spellcaster", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Ichor Creation", "description": "As a Swift Action, you can spend a Force Point to fly. You gain a fly speed equal to your base speed, and you can ascend at half speed or descend at double speed. The flight lasts until the start of your next turn; if you're still airborne at that time, you fall. Homebrew Reference Book: Dathomir Field Guide You can make Grab or Grapple attempts against any enemy within the reach of a Chain Sickle that you are wielding. These attempts use your weapon's attack bonus with in place of your Grapple modifier. When you would deal damage as part of a Grapple (such as through the Throw or Crush feats), you deal additional damage equal to your Dexterity modifier (minimum +1). Homebrew Reference Book: Dathomir Field Guide When you use a Chain Sickle or an Energy Bow, your damage die increases by one step (from d8s to d10s). In addition, you gain a +2 bonus to Use the Force checks made to Sense Surroundings. Homebrew Reference Book: Dathomir Field Guide Items you create through the Ichor Creation Force Power gain one applicable benefit as though enhanced by the Tech Specialist feat. Homebrew Reference Book: Dathomir Field Guide", "benefit": "As a Swift Action, you can spend a Force Point to fly. You gain a fly speed equal to your base speed, and you can ascend at half speed or descend at double speed. The flight lasts until the start of your next turn; if you're still airborne at that time, you fall. Homebrew Reference Book: Dathomir Field Guide You can make Grab or Grapple attempts against any enemy within the reach of a Chain Sickle that you are wielding. These attempts use your weapon's attack bonus with in place of your Grapple modifier. When you would deal damage as part of a Grapple (such as through the Throw or Crush feats), you deal additional damage equal to your Dexterity modifier (minimum +1). Homebrew Reference Book: Dathomir Field Guide When you use a Chain Sickle or an Energy Bow, your damage die increases by one step (from d8s to d10s). In addition, you gain a +2 bonus to Use the Force checks made to Sense Surroundings. Homebrew Reference Book: Dathomir Field Guide Items you create through the Ichor Creation Force Power gain one applicable benefit as though enhanced by the Tech Specialist feat. Homebrew Reference Book: Dathomir Field Guide", "class": "", "category": "", "costNumeric": null, "treeId": "ad16f3e5f4f7441b", "tags": ["action_economy", "exotic_weapon", "feat_chain", "force", "force_capacity", "force_execution", "force_offense", "force_point_spend", "force_power_synergy", "mobility", "ranged", "ranged_control", "resource_spend", "scout", "spellcasting", "striker", "sustained_damage", "swift_action", "talent_chain", "tree_ad16f3e5f4f7441b", "uncategorized_talent", "use_the_force", "witchcraft"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Adept Spellcaster"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": []}}}
{"_id": "12e6b524fc6959b6", "name": "Unbalance Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Expert Grappler", "benefit": "One opponent loses their Strength bonus to melee attack rolls against you (does not affect damage).", "description": "One opponent you grapple loses their Strength bonus to melee attack rolls against you.", "class": "f62ca2e639cab614", "costNumeric": null, "category": "Soldier", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.expert_grappler"}], "_source": "canonical-csv"}, "treeId": "67fdd8dce9abd6c1", "tags": ["feat-chain", "melee", "soldier", "striker", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 2, "type": "untyped", "predicates": ["attack.with-melee"], "enabled": true, "priority": 500, "description": "Unbalance Strike"}]}}, "effects": [{"_id": "134a5b32-6daf-419e-87b4-a765613b4522", "name": "Unbalance Strike", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.attacks.unarmed", "mode": 2, "value": "1"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Unbalance Strike"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.unbalance_strike", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": ["attack.with-melee"]}}}
{"_id": "12eea831f06c45f7", "name": "Focused Force Talisman", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Force Talisman", "benefit": "When you create a Force Talisman, you can select a single Force Power from your Force Power Suite. Whenever you are wearing this Focused Force Talisman and activate the selected Force Power, you can spend a Force Point to immediately regain all your expended uses of that spent Force Power, adding it to your Force Power Suite.", "description": {"value": "When you create a Force Talisman, you can select a single Force Power from your Force Power Suite. Whenever you are wearing this Focused Force Talisman and activate the selected Force Power, you can spend a Force Point to immediately regain all your expended uses of that spent Force Power, adding it to your Force Power Suite."}, "class": "289fcf920ef0e184", "costNumeric": null, "category": "Force Adept", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.force_talisman"}], "_source": "canonical-csv"}, "treeId": "01e443d93e47f9c4", "tags": ["alchemy", "category_force_adept", "controller", "crafting", "empowerment", "force", "force_capacity", "force_execution", "force_point_spend", "force_power_synergy", "force_training", "mystic", "resource_spend", "tree_01e443d93e47f9c4"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Focused Force Talisman"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.focused_force_talisman", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": []}}}
{"_id": "12ffb24378b60c13", "name": "Quick Trigger", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Expert Gunner", "benefit": "Whenever an enemy Vehicle moves out of your square, or an adjacent square, you may make a single attack against that Vehicle as an Attack of Opportunity.", "description": {"value": "Whenever an enemy Vehicle moves out of your square, or an adjacent square, you may make a single attack against that Vehicle as an Attack of Opportunity."}, "class": "9c9989c34714f920", "costNumeric": null, "category": "Ace Pilot", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.expert_gunner"}], "_source": "canonical-csv"}, "treeId": "43ead399d82b8142", "tags": ["feat-chain", "scout", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Quick Trigger"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.quick_trigger", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.404Z", "detectedPredicates": []}}}
