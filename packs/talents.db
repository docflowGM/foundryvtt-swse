{"_id": "0703de963a247170", "name": "Ignite Fervor", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "Bolster Ally, Inspire Confidence", "benefit": "Whenever you hit an opponent with a melee or ranged attack, you can (as a Free Action) choose to give one ally within your line of sight a bonus to damage on their next attack equal to their Character Level. Once their fervor has been ignited, the affected ally doesn't need to remain within line of sight of you; if their next attack misses, they lose the bonus to damage granted by this Talent.", "description": {"value": "Whenever you hit an opponent with a melee or ranged attack, you can (as a Free Action) choose to give one ally within your line of sight a bonus to damage on their next attack equal to their Character Level. Once their fervor has been ignited, the affected ally doesn't need to remain within line of sight of you; if their next attack misses, they lose the bonus to damage granted by this Talent.\n\nYou can't Ignite Fervor on yourself."}, "class": "8c58016e587dd2c7", "costNumeric": null, "category": "Noble", "prerequisitesStructured": {"type": "all", "conditions": [{"type": "talent", "id": "swse.talent.bolster_ally"}, {"type": "talent", "id": "swse.talent.inspire_confidence"}], "_source": "canonical-csv"}, "treeId": "72d32ebcbb607314", "tags": ["noble"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Ignite Fervor"}]}}, "effects": [{"_id": "464d9fb0-db44-4d22-8e5b-a00df6ec0f8e", "name": "Ignite Fervor", "icon": "icons/svg/item-bag.svg", "changes": [{"key": "system.damage.allies", "mode": 2, "value": "level"}], "disabled": false, "duration": {}, "flags": {"swse": {"source": "talent", "talentName": "Ignite Fervor"}}}], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.ignite_fervor", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.402Z", "detectedPredicates": []}}}
