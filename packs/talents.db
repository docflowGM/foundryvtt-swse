{"_id": "2dc6ad1667133f2d", "name": "Share Force Secret", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"prerequisites": "At least 1 Force Secret", "benefit": "When you take this Talent, choose one Force Secret that you know. Once per turn as a Swift Action, you can grant the use of this Force Secret to one ally within 12 squares of you who is Trained in the Use the Force Skill.", "description": {"value": "When you take this Talent, choose one Force Secret that you know. Once per turn as a Swift Action, you can grant the use of this Force Secret to one ally within 12 squares of you who is Trained in the Use the Force Skill.\n\nThe target gains the benefit of this Force Secret until the end of your next turn."}, "class": "fb5c2644f988e6bf", "costNumeric": null, "category": "Jedi Knight", "treeId": "303d91124d4548c0", "tags": ["feat-chain", "force", "jedi", "leader", "light-side", "positioning", "support", "talent-chain"], "executionModel": "PASSIVE", "subType": "STATE", "abilityMeta": {"modifiers": [{"target": "attack", "value": 0, "type": "untyped", "predicates": [], "enabled": false, "priority": 500, "description": "[REQUIRES MANUAL MAPPING] Share Force Secret"}]}}, "effects": [], "folder": null, "sort": 0, "ownership": {"default": 0}, "flags": {"swse": {"id": "swse.talent.share_force_secret", "migratedToState": true, "migrationDate": "2026-03-08T18:22:17.407Z", "detectedPredicates": []}}}
