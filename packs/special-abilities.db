{"_id":"abil-sith-alchemy-jagged-weapon","name":"Jagged Weapon","type":"combat-action","img":"icons/svg/blood.svg","system":{"description":"Sith alchemy weapon trait: any time the Sith Weapon damages a living creature, that creature takes 1d4 points of damage at the start of its next turn. PoisonEngine queues and resolves this start-of-turn damage.","source":"Sith Alchemy","actionType":"passive","executionModel":"passive-special-ability","specialAbility":{"id":"jagged-weapon","category":"sith-alchemy","automation":"poison-engine-recurring-damage","description":"Deferred recurring damage trait for Sith weapons."}},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"isActorAbility":true,"abilityKey":"jagged-weapon","sourceType":"compendium","sourceName":"Special Abilities","sithAlchemy":{"trait":"Jagged Weapon","jaggedWeapon":true}}}}
