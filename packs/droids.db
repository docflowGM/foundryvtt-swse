{"_id":"d5c5daf4f401b776","name":"B1-Series_Battle_Droid","type":"droid","img":"icons/svg/mystery-man.svg","system":{"degree":"4th-Degree","initiative":null,"senses":"Perception","perception":6,"reflexDefense":9,"flatFooted":9,"fortitudeDefense":11,"willDefense":10,"HP":10,"damageThreshold":11,"speed":6,"baseAttackBonus":null,"grapple":null,"attacks":{"melee":[{"name":"Unarmed","bonus":3,"damage":"1d3+1"}],"ranged":[{"name":"Blaster Carbine","bonus":1,"damage":"3d8"},{"name":"Blaster Carbine","bonus":1,"damage":"3d8"}]},"baseStats":{"abilities":{"strength":13,"dexterity":9,"intelligence":9,"wisdom":10,"charisma":10,"constitution":0}},"skills":{"Perception":6},"type":"droid","description":"","costNumeric":1800,"category":"droid","cost":1800,"droidDegreeKey":"4th-degree","droidRole":"battle","droidRoleLabel":"Battle","droidSystemText":"Walking Locomotion, Remote Receiver , 2 Hand Appendages, Internal Comlink , Vocabulator","droidSystems":{"processor":{"id":"remote-receiver","name":"Remote Receiver","source":"published"},"locomotion":[{"id":"walking-locomotion","name":"Walking Locomotion","source":"published"}],"appendages":[{"id":"2-hand-appendages","name":"2 Hand Appendages","source":"published"}],"sensors":[],"integratedSystems":[{"id":"internal-comlink","name":"Internal Comlink","source":"published"},{"id":"vocabulator","name":"Vocabulator","source":"published"}],"accessories":[],"weapons":[{"id":"blaster-carbine","name":"Blaster Carbine","mode":"ranged","damage":"3d8","attackBonus":1,"source":"published-attack"},{"id":"blaster-carbine","name":"Blaster Carbine","mode":"ranged","damage":"3d8","attackBonus":1,"source":"published-attack"}],"sourceText":"Walking Locomotion, Remote Receiver , 2 Hand Appendages, Internal Comlink , Vocabulator","sourcePossessions":"Blaster Carbine Availability: Military ; Cost: 1,800 credits B1-Series Battle Droid Protocol Format [ ] Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids See also: Protocol Format Medium 4th-Degree Droid Hit Points: 10 Damage Threshold : 11 System Actions [ ] Move (1 Swift Action , 2/Turn) [ ] The B1-Series Battle Droid moves 6 squares ( Walking ). Avoid Surprise ( Free Action ) [ ] The B1-Series Battle Droid makes a Perception check at the start of a battle. If the check is successful, the Droid's master avoids Surprise . Patrol Duty (1 Swift Action , 1/Turn) [ ] The B1-Series Battle Droid makes a Perception check against a target's Stealth check. If the check is successful, the Battle Droid detects the target. Support Fire (1 Swift Action , 1/Turn) [ ] The B1-Series Battle Droid makes a ranged attack at +1. If successful, the attack deals 3d8 points of damage. Tactical Assistance (1 Swift Action , 1/Turn) [ ] The B1-Series Battle Droid assists a character's ranged attack, providing a +2 bonus to the roll. Base Stats [ ]"},"cl":1},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"speedText":"6 Squares ( Walking )","droidSystemText":"Walking Locomotion, Remote Receiver , 2 Hand Appendages, Internal Comlink , Vocabulator"}}}
