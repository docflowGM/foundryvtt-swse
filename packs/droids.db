{"_id":"af71e64a8802bc62","name":"R2-Series_Astromech_Droid","type":"droid","img":"icons/svg/mystery-man.svg","system":{"degree":"2nd-Degree","initiative":null,"senses":"Perception","perception":8,"reflexDefense":13,"flatFooted":11,"fortitudeDefense":9,"willDefense":10,"HP":7,"damageThreshold":9,"speed":6,"baseAttackBonus":null,"grapple":null,"attacks":{"melee":[{"name":"Electroshock Probe","bonus":0,"damage":"1d8 ( Ion"}],"ranged":[]},"baseStats":{"abilities":{"strength":9,"dexterity":14,"intelligence":15,"wisdom":10,"charisma":7,"constitution":0}},"skills":{"Mechanics":13,"Perception":8,"Pilot":8,"Use Computer":13},"type":"droid","description":"","costNumeric":7500,"category":"droid","cost":7500,"droidDegreeKey":"2nd-degree","droidRole":"astromech","droidRoleLabel":"Astromech","droidSystemText":"Wheeled Locomotion, Walking Locomotion, Flying Locomotion ( Limited ), Magnetic Feet , Heuristic Processor , 6 Tool Appendages, 1 Claw Appendage, Compartment Space (2 kg), Darkvision , Diagnostics Package , Improved Sensor Package","droidSystems":{"processor":{"id":"heuristic-processor","name":"Heuristic Processor","source":"published"},"locomotion":[{"id":"wheeled-locomotion","name":"Wheeled Locomotion","source":"published"},{"id":"walking-locomotion","name":"Walking Locomotion","source":"published"},{"id":"flying-locomotion-limited","name":"Flying Locomotion ( Limited )","source":"published"}],"appendages":[{"id":"6-tool-appendages","name":"6 Tool Appendages","source":"published"},{"id":"1-claw-appendage","name":"1 Claw Appendage","source":"published"}],"sensors":[{"id":"darkvision","name":"Darkvision","source":"published"},{"id":"improved-sensor-package","name":"Improved Sensor Package","source":"published"}],"integratedSystems":[],"accessories":[{"id":"magnetic-feet","name":"Magnetic Feet","source":"published"},{"id":"compartment-space-2-kg","name":"Compartment Space (2 kg)","source":"published"},{"id":"diagnostics-package","name":"Diagnostics Package","source":"published"}],"weapons":[{"id":"electroshock-probe","name":"Electroshock Probe","mode":"melee","damage":"1d8 ( Ion","attackBonus":0,"source":"published-attack"}],"sourceText":"Wheeled Locomotion, Walking Locomotion, Flying Locomotion ( Limited ), Magnetic Feet , Heuristic Processor , 6 Tool Appendages, 1 Claw Appendage, Compartment Space (2 kg), Darkvision , Diagnostics Package , Improved Sensor Package","sourcePossessions":"Astrogation Buffer (Storage Device, 10 Memory Units), Circular Saw, Electroshock Probe , Fire Extinguisher , Electric Arc Welder, Holorecorder , Holoprojector Availability: Licensed ; Cost: 7,500 credits R2-Series Astromech Droid Protocol Format [ ] Reference Book: Star Wars Saga Edition Scavenger's Guide to Droids See also: Protocol Format Small 2nd-Degree Droid Hit Points: 7 Damage Threshold : 8 System Actions [ ] Move (1 Swift Action , 2/Turn) [ ] The R2-Series Astromech Droid moves 6 squares ( Wheeled ), 4 squares ( Walking ), or 9 squares ( Flying ). Copilot (1 Swift Action , 1/Turn) [ ] The R2-Series Astromech Droid aids a character's Pilot check, providing a +2 bonus to the check. Improve Access (2 Swift Actions , 1/Turn) [ ] The R2-Series Astromech Droid makes a Use Computer check against a target computer's Will Defense to improve the computer's Attitude toward it. Issue Routine Command (1 Swift Action , 1/Turn) [ ] The R2-Series Astromech Droid issues a routine command to a computer that has a Friendly Attitude toward it. Recharge Shields (2 Swift Actions , 1/Turn) [ ] The R2-Series Astromech Droid makes a DC 20 Mechanics check. If the check is successful, the Vehicle regains 5 SR, up to its normal maximum. Regulate Power (2 Swift Actions , 1/Turn) [ ] The R2-Series Astromech Droid makes a DC 20 Mechanics check. If the check is successful, the Vehicle moves +1 step on on Condition Track . Base Stats [ ]"},"cl":0},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"speedText":"6 Squares ( Wheeled ), 4 Squares ( Walking ), 9 Squares ( Flying ( Limited )); Magnetic Feet","droidSystemText":"Wheeled Locomotion, Walking Locomotion, Flying Locomotion ( Limited ), Magnetic Feet , Heuristic Processor , 6 Tool Appendages, 1 Claw Appendage, Compartment Space (2 kg), Darkvision , Diagnostics Package , Improved Sensor Package"}}}
