{"_id":"30cb2abcd11bf1bd","name":"Relentless Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one weapon group or Exotic Weapon for which you have the Double Attack Feat. Whenever you miss a target with that weapon, you gain a +2 competence bonus on your next attack roll made before the end of your next turn against the missed target.","prerequisite":"Double Attack (Chosen Weapon)","special":"You can select this Feat multiple times. Each time you select this Feat, it applies to a different weapon group or Exotic Weapon.","normalText":"","sourcebook":"Jedi Academy Training Manual","page":30,"tags":["feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Double Attack<br>(Chosen Weapon)</p>\n<p><strong>Effect:</strong> Choose one weapon group or<br>Exotic Weapon<br>for which you have the<br>Double Attack<br>Feat. Whenever you miss a target with that weapon, you gain a +2 competence bonus on your next attack roll made before the end of your next turn against the missed target.</p>\n<p><strong>Special:</strong> You can select this Feat multiple times. Each time you select this Feat, it applies to a different weapon group or<br>Exotic Weapon<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Relentless_Attack</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Relentless Attack","mechanicsMode":"conditional_choice_required","applicationScope":"roll_or_action_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":true,"predicateRequirements":[],"conditionSummary":"Choose the Double Attack weapon choice this feat modifies.","metadataPhase":"phase6-choice-backfill","metadataNotes":"Phase 6 captures the required persistent choice; roll/action execution remains context-gated.","disabledReason":"Phase 6: choice captured now; execution waits for roll/action context wiring."}],"mechanicsMode":"conditional_choice_required","applicationScope":"roll_or_action_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":true,"conditionSummary":"Choose the Double Attack weapon choice this feat modifies.","predicateRequirements":[],"metadataPhase":"phase6-choice-backfill","metadataNotes":"Phase 6 captures the required persistent choice; roll/action execution remains context-gated."},"shortSummary":"Gain a bonus on attack rolls after missing a target.","prerequisitesText":"Double Attack (Chosen Weapon)","referenceBooks":["Star Wars Saga Edition Jedi Academy Training Manual"],"sourceUrl":"https://swse.fandom.com/wiki/Relentless_Attack","choiceMeta":{"resolution":"immediate","required":true,"status":"phase6_choice_backfilled","choiceKind":"double_attack_followup_weapon","repeatable":true,"storagePath":"flags.swse.choices.relentless_attack_weapon","choiceSource":"prerequisiteDerived","optionRegistry":"data/feat-choice-options.json#choiceKinds.double_attack_followup_weapon","derivesFrom":["double_attack_weapon"],"consumes":"double_attack_weapon"},"effect":"Choose one weapon group or\nExotic Weapon\nfor which you have the\nDouble Attack\nFeat. Whenever you miss a target with that weapon, you gain a +2 competence bonus on your next attack roll made before the end of your next turn against the missed target."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.relentless_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Relentless_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"313095ada7504547","name":"Signature Device","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You designate a single weapon, suit of armor, vehicle, or other item as your Signature Item. When making Mechanics checks to modify that piece of Equipment, you can Take 10 on the check. In addition, you can allow the device to gain two Traits from the Tech Specialist feat.\n\nTo install the second Trait, you must succeed on a DC 30 Mechanics check. Once installed, the device can use only one Trait at a time, and switching from one Trait to the other requires a Swift Action to adjust the item's settings.\n\nYou can have only one Signature Device at a time, but you can designate another device as your Signature Item (the former item loses all benefits gained from this Feat).","prerequisite":"Tech Specialist","special":"","normalText":"","sourcebook":"Scum and Villainy","page":28,"tags":["feat","general","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Tech Specialist</p>\n<p><strong>Effect:</strong> You designate a single weapon, suit of armor, vehicle, or other item as your Signature Item. When making<br>Mechanics<br>checks to modify that piece of<br>Equipment<br>, you can<br>Take 10<br>on the check. In addition, you can allow the device to gain two Traits from the<br>Tech Specialist<br>feat.<br><br>To install the second Trait, you must succeed on a DC 30<br>Mechanics<br>check. Once installed, the device can use only one Trait at a time, and switching from one Trait to the other requires a<br>Swift Action<br>to adjust the item&#x27;s settings.<br><br>You can have only one Signature Device at a time, but you can designate another device as your Signature Item (the former item loses all benefits gained from this Feat).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Signature_Device</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"customization_context","applicationScope":"workbench_garage_shipyard_context","staticSheetPolicy":"exclude","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Signature Device depends on Tech Specialist/customization trait selection and item designation, so it is deferred to the dedicated customization UI/picker work.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"phase21_contextual_customization_ui","description":"Signature Device is implemented through contextual item/asset designation and second-trait support in the Tech Specialist modification UI. Switching the signature device warns that former benefits are lost and credits are not refunded.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Signature Device depends on Tech Specialist/customization trait selection and item designation, so it is deferred to the dedicated customization UI/picker work.","mechanicsMode":"metadata_only","applicationScope":"customization_picker_required","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"customizationCapabilities":[{"type":"SIGNATURE_DEVICE","contexts":["workbench","lightsaber","garage","shipyard"],"secondTrait":true,"take10":true,"activeTraitToggle":true}]},"shortSummary":"Install two Traits.","prerequisitesText":"Tech Specialist","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Signature_Device","effect":"You designate a single weapon, suit of armor, vehicle, or other item as your Signature Item. When making\nMechanics\nchecks to modify that piece of\nEquipment\n, you can\nTake 10\non the check. In addition, you can allow the device to gain two Traits from the\nTech Specialist\nfeat.\n\nTo install the second Trait, you must succeed on a DC 30\nMechanics\ncheck. Once installed, the device can use only one Trait at a time, and switching from one Trait to the other requires a\nSwift Action\nto adjust the item's settings.\n\nYou can have only one Signature Device at a time, but you can designate another device as your Signature Item (the former item loses all benefits gained from this Feat)."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.signature_device","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Signature_Device","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"32ab40ebbd9bbc16","name":"Spring Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making a melee attack, you may move both before and after the attack, up to your speed, without provoking attacks of opportunity from the target.","prerequisite":"Dex 13, Mobility","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","hit_and_run","mobility","move_action","offense","offense_melee","standard_action"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-melee"],"enabled":false,"priority":500,"description":"Spring Attack: Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.with-melee"],"conditionSummary":"Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Spring Attack now has explicit roll-context attack option metadata from its refreshed description.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","rules":[{"type":"ATTACK_OPTION","option":"springAttack","label":"Spring Attack","control":"flag","requiresAttackType":"melee","suppresses":["targetAttackOfOpportunityFromMovement"],"summary":"Move before and after a melee attack without provoking from the target."}],"status":"attack_option_phase10","description":"Spring Attack now has explicit roll-context attack option metadata from its refreshed description."},"shortSummary":"When making a melee attack, you may move both before and after the attack, up to your speed, without provoking attacks of opportunity from the target."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.with-melee"]}}}
{"_id":"32d1cd4b09ec0d3b","name":"Cleave","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you deal an opponent enough damage to reduce its hit points to 0, you get an immediate extra melee attack against another opponent within your reach. The extra attack is with the same weapon and at the same attack bonus as the attack that dropped the previous opponent. You can use this ability once per round.","prerequisite":"Strength 13, Power Attack Feat","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":85,"tags":["control","feat","general","grapple","offense","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Strength<br>13,<br>Power Attack<br>Feat</p>\n<p><strong>Effect:</strong> If you deal an opponent enough damage to reduce its hit points to 0, you get an immediate extra melee attack against another opponent within your reach. The extra attack is with the same weapon and at the same attack bonus as the attack that dropped the previous opponent. You can use this ability once per round.</p>\n<h3>Additional Cleave Effects</h3><p>Reference Book:<br>Star Wars Saga Edition Knights of the Old Republic Campaign Guide<br><br>Combined Feat (<br>Follow Through<br>):<br>If you have the<br>Follow Through<br>Feat, you can move up to your speed before making the extra melee attack granted by the Cleave Feat.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Cleave</em></p>\n<p><strong>Related Feat:</strong> Frightening Cleave: if you also have Frightening Cleave, immediately after you use Cleave each enemy within 6 squares and line of sight takes a -1 penalty to Reflex Defense, attack rolls, and skill checks against you until the end of the encounter. This stacks to a maximum of -5 and is mind-affecting; GM/player applies it manually.</p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rider_effect_phase7","description":"Cleave: modeled as a rider/action rule, not a numeric modifier.","rules":[{"type":"EXTRA_ATTACK","trigger":"onReduceTargetToZeroHp","attackType":"melee","sameWeapon":true,"sameAttackBonus":true,"limit":"oncePerRound"}],"modifiers":[{"target":"attack","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Cleave: numeric scaffold disabled by Phase 7 (description grants a conditional rider/action effect rather than a standing attack or defense bonus)","mechanicsMode":"metadata_note","applicationScope":"not_a_numeric_modifier","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"description grants a conditional rider/action effect rather than a standing attack or defense bonus","metadataPhase":"phase7-description-reimplementation"}],"mechanicsMode":"conditional","applicationScope":"extra_attack_on_drop","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"After reducing a target to 0 HP, grant one immediate extra melee attack once per round.","predicateRequirements":[],"metadataPhase":"phase7-description-reimplementation","metadataNotes":"Phase 7 re-read refreshed descriptions and converted old scaffold bonuses into explicit static/resource/attack-option/rider metadata.","synergyNotes":[{"feat":"Frightening Cleave","trigger":"afterUsingCleave","gmManaged":true,"description":"Related Feat - Frightening Cleave: if you also have Frightening Cleave, immediately after you use Cleave each enemy within 6 squares and line of sight takes a -1 penalty to Reflex Defense, attack rolls, and skill checks against you until the end of the encounter. This stacks to a maximum of -5 and is mind-affecting; GM/player applies it manually."}]},"shortSummary":"Extra melee attack after dropping target.","prerequisitesText":"Strength 13, Power Attack Feat","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Cleave","effect":"If you deal an opponent enough damage to reduce its hit points to 0, you get an immediate extra melee attack against another opponent within your reach. The extra attack is with the same weapon and at the same attack bonus as the attack that dropped the previous opponent. You can use this ability once per round."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.with-melee"],"id":"swse.feat.cleave","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Cleave","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"33905755bbb1ca10","name":"Binary Mind","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Enemies must roll twice, keeping the lower result, on Mind-Affecting effects.","prerequisite":"Cerean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["control","feat","grapple","racial","species","species_opportunity"],"bonus_feat_for":["species-cerean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Cerean</p>\n<p><strong>Effect:</strong> Whenever an enemy tries to use a<br>Mind-Affecting<br>effect against you, the enemy must roll twice and take the lower result.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Binary_Mind</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Enemies roll twice and keep lower on mind-affecting effects against you.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"targeted_defense_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Enemies roll twice and keep lower on mind-affecting effects against you.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"conditional_defense_rider_metadata_phase14","defenseRiders":[{"type":"ATTACKER_ROLL_TWICE_KEEP_LOWER","against":["mind-affecting"],"description":"Enemies roll twice and keep the lower result on mind-affecting effects against you."}]},"shortSummary":"Enemies must roll twice, keeping the lower result, on Mind-Affecting effects.","sourceUrl":"https://swse.fandom.com/wiki/Binary_Mind","rawImport":{"name":"Binary Mind","url":"https://swse.fandom.com/wiki/Binary_Mind","pageTitle":"Binary_Mind","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\binary_mind.html","referenceBooks":[],"prerequisitesText":"Cerean","prerequisites":["Cerean"],"effect":"Whenever an enemy tries to use a\nMind-Affecting\neffect against you, the enemy must roll twice and take the lower result.","benefit":"","normal":"","special":"","indexPrerequisites":"Cerean","indexBenefit":"Enemies must roll twice, keeping the lower result, on Mind-Affecting effects.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nThe dual nature of your mind makes it difficult for others to influence you.\n\nPrerequisite:\nCerean\n\nEffect:\nWhenever an enemy tries to use a\nMind-Affecting\neffect against you, the enemy must roll twice and take the lower result."},"prerequisitesText":"Cerean","effect":"Whenever an enemy tries to use a\nMind-Affecting\neffect against you, the enemy must roll twice and take the lower result."},"effects":[{"_id":"fa4ac368-0913-4d84-9920-9918a8564b1a","name":"Binary Mind","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Binary Mind","effectType":"mind_resistance","flagType":"binaryMindProtection"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.binary_mind"}}}
{"_id":"34071c4705615ce8","name":"Moving Target","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you end your turn at least 3 squares away from where you started, you gain a +1 dodge bonus to your Reflex Defense until the start of your next turn.","prerequisite":"Dodge","special":"","normalText":"","sourcebook":"Rebellion Era Campaign Guide","page":20,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Dodge</p>\n<p><strong>Effect:</strong> If you end your turn at least 3 squares away from where you started, you gain a +1 dodge bonus to your<br>Reflex Defense<br>until the start of your next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Moving_Target</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":false,"priority":500,"description":"Moving Target: Implemented as conditional defense metadata; not a global attack bonus.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.reflex"],"conditionSummary":"Implemented as conditional defense metadata; not a global attack bonus.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"defense_context","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Moving Target now exposes conditional defense metadata instead of a false numeric modifier.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 continued replacing false scaffold modifiers with concrete or diagnostics-ready metadata.","conditionalDefenseBonuses":[{"type":"CONDITIONAL_DEFENSE_BONUS","targets":["defense.reflex"],"value":1,"bonusType":"dodge","requiresContextFlags":["movedAtLeast3SquaresThisTurn"],"duration":"untilStartOfNextTurn","description":"After ending your turn at least 3 squares from where you started, gain +1 dodge Reflex until next turn."}],"status":"conditional_defense_phase10","description":"Moving Target now exposes conditional defense metadata instead of a false numeric modifier."},"shortSummary":"Gain a bonus to Reflex Defense when you remain mobile.","prerequisitesText":"Dodge","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Moving_Target","effect":"If you end your turn at least 3 squares away from where you started, you gain a +1 dodge bonus to your\nReflex Defense\nuntil the start of your next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.moving_target","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Moving_Target","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"34bc0c5808778bf5","name":"Improved Bantha Rush","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making a Bantha Rush, you push your opponent a number of additional squares away from you equal to half your Strength modifier (Round down, minimum 2 squares pushed total).","prerequisite":"Strength 15, Bantha Rush, Base Attack Bonus +1","special":"","normalText":"When using Bantha Rush, you normally push your opponent only 1 square away from you.","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["ability_strength","feat","general","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Strength<br>15,<br>Bantha Rush<br>,<br>Base Attack Bonus<br>+1</p>\n<p><strong>Effect:</strong> When making a<br>Bantha Rush<br>, you push your opponent a number of additional squares away from you equal to half your<br>Strength<br>modifier (Round down, minimum 2 squares pushed total).</p>\n<p><strong>Normal:</strong> When using<br>Bantha Rush<br>, you normally push your opponent only 1 square away from you.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Improved_Bantha_Rush</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":15}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"bantha_rush_push_distance","staticSheetPolicy":"roll_context_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Improved Bantha Rush: Bantha Rush push distance increases by half Strength modifier, minimum 2 squares total.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"bantha_rush_rider_metadata_phase16","description":"Improved Bantha Rush: Bantha Rush push distance increases by half Strength modifier, minimum 2 squares total.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Improved Bantha Rush: Bantha Rush push distance increases by half Strength modifier, minimum 2 squares total.","mechanicsMode":"metadata_only","applicationScope":"bantha_rush_push_distance","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"BANTHA_RUSH_PUSH_DISTANCE","valueFormula":"max(2, floor(str.mod / 2) + 1)","description":"When making a Bantha Rush, push additional squares equal to half Strength modifier; minimum 2 squares total."}]},"shortSummary":"Push foes away a number of squares equal to Strength modifier.","prerequisitesText":"Strength 15, Bantha Rush, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Improved_Bantha_Rush","effect":"When making a\nBantha Rush\n, you push your opponent a number of additional squares away from you equal to half your\nStrength\nmodifier (Round down, minimum 2 squares pushed total)."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.improved_bantha_rush","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improved_Bantha_Rush","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"357807a5ceb77203","name":"Double Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose a single Exotic Weapon or weapon group with which you are proficient. When you use the Full Attack action, you may make one additional attack when wielding such a weapon. However, you take a -5 penalty on all attack rolls until your next turn because you're trading precision for speed.","prerequisite":"Base Attack Bonus +6","special":"You may select this Feat multiple times. Each time you select this Feat, it applies to a different Exotic Weapon or weapon group. If you take this Feat with Heavy Weapons, it also applies with Vehicle Weapons.","normalText":"Making a single attack is a Standard Action.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general","offense"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus<br>+6</p>\n<p><strong>Effect:</strong> Choose a single<br>Exotic Weapon<br>or weapon group with which you are proficient. When you use the<br>Full Attack<br>action, you may make one additional attack when wielding such a weapon. However, you take a -5 penalty on all attack rolls until your next turn because you&#x27;re trading precision for speed.</p>\n<p><strong>Normal:</strong> Making a single attack is a<br>Standard Action<br>.</p>\n<p><strong>Special:</strong> You may select this Feat multiple times. Each time you select this Feat, it applies to a different<br>Exotic Weapon<br>or weapon group. If you take this Feat with<br>Heavy Weapons<br>, it also applies with<br>Vehicle Weapons<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Double_Attack</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":6}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.on-current-turn"],"enabled":false,"priority":500,"description":"Double Attack","mechanicsMode":"conditional_choice_required","applicationScope":"roll_or_action_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":true,"predicateRequirements":[],"conditionSummary":"Choose one proficient weapon group or exotic weapon for the extra Full Attack option.","metadataPhase":"phase6-choice-backfill","metadataNotes":"Phase 6 captures the required persistent choice; roll/action execution remains context-gated.","disabledReason":"Phase 6: choice captured now; execution waits for roll/action context wiring."}],"mechanicsMode":"conditional_choice_required","applicationScope":"roll_or_action_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":true,"conditionSummary":"Choose one proficient weapon group or exotic weapon for the extra Full Attack option.","predicateRequirements":[],"metadataPhase":"phase6-choice-backfill","metadataNotes":"Phase 6 captures the required persistent choice; roll/action execution remains context-gated.","combatActions":[{"id":"double-attack-full-attack","name":"Double Attack","actionType":"full-round","cost":1,"manualResolution":true,"resolutionMode":"manual","useLabel":"Use / Note","requiresSelectedChoice":true,"relatedSkills":[{"skill":"Attack Roll","when":"Resolve each attack in the Full Attack sequence"}],"resources":["Full Attack","Selected weapon group/exotic weapon"],"notes":"When using Full Attack with the selected weapon group or exotic weapon, make one additional attack. All attack rolls take a -5 penalty until your next turn.","description":"Choose a single exotic weapon or weapon group. During Full Attack with that weapon, make one additional attack; all attack rolls take a -5 penalty until your next turn."}],"combatActionCardSource":"phase-t13-ability-combat-action-cards","combatActionCardNotes":"Action card only; execution remains manual until multi-attack sequencing is automated."},"shortSummary":"Make an extra attack with chosen weapon during Full Attack, -5 penalty to all attacks.","prerequisitesText":"Base Attack Bonus +6","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Double_Attack","choiceMeta":{"resolution":"immediate","required":true,"status":"phase6_choice_backfilled","choiceKind":"double_attack_weapon","repeatable":true,"storagePath":"flags.swse.choices.double_attack_weapon","choiceSource":"prerequisiteDerived","optionRegistry":"data/feat-choice-options.json#choiceKinds.double_attack_weapon","derivesFrom":["weapon_proficiency"],"consumes":"weapon_proficiency","provides":"double_attack_weapon"},"effect":"Choose a single\nExotic Weapon\nor weapon group with which you are proficient. When you use the\nFull Attack\naction, you may make one additional attack when wielding such a weapon. However, you take a -5 penalty on all attack rolls until your next turn because you're trading precision for speed."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["turn.on-current-turn"],"id":"swse.feat.double_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Double_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"3595086bb17d4303","name":"Justice Seeker","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to damage rolls against those who harm your allies.","prerequisite":"Kel Dor","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","racial","species","species_opportunity"],"bonus_feat_for":["species-kel-dor"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Kel Dor</p>\n<p><strong>Effect:</strong> You gain a +2 bonus to damage rolls for attacks against targets that have damaged one of your allies since the end of your last turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Justice_Seeker</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"damage_roll_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Justice Seeker adds +2 damage against targets that damaged one of your allies since the end of your last turn.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"attack_option_phase17","description":"Justice Seeker adds +2 damage against targets that damaged one of your allies since the end of your last turn.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Justice Seeker adds +2 damage against targets that damaged one of your allies since the end of your last turn.","mechanicsMode":"metadata_only","applicationScope":"damage_roll_context","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"rules":[{"type":"ATTACK_OPTION","option":"justiceSeeker","label":"Justice Seeker","control":"passive","damageModifier":2,"requiresContextFlags":["targetDamagedAllySinceEndOfLastTurn"],"summary":"Gain +2 damage against a target that damaged one of your allies since the end of your last turn."}]},"shortSummary":"Gain a bonus to damage rolls against those who harm your allies.","sourceUrl":"https://swse.fandom.com/wiki/Justice_Seeker","rawImport":{"name":"Justice Seeker","url":"https://swse.fandom.com/wiki/Justice_Seeker","pageTitle":"Justice_Seeker","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\justice_seeker.html","referenceBooks":[],"prerequisitesText":"Kel Dor","prerequisites":["Kel Dor"],"effect":"You gain a +2 bonus to damage rolls for attacks against targets that have damaged one of your allies since the end of your last turn.","benefit":"","normal":"","special":"","indexPrerequisites":"Kel Dor","indexBenefit":"Gain a bonus to damage rolls against those who harm your allies.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou are willing to take the law into your own hands to bring justice to those who harm your allies.\n\nPrerequisite:\nKel Dor\n\nEffect:\nYou gain a +2 bonus to damage rolls for attacks against targets that have damaged one of your allies since the end of your last turn."},"prerequisitesText":"Kel Dor","effect":"You gain a +2 bonus to damage rolls for attacks against targets that have damaged one of your allies since the end of your last turn."},"effects":[{"_id":"4d14d994-e1db-4d72-ae3f-0bcd3fa34575","name":"Justice Seeker","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Justice Seeker","effectType":"combat_bonus","flagType":"Justice Seeker"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.justice_seeker"}}}
{"_id":"376d805d1b73f7e6","name":"Starship Tactics","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You add to your Starship Maneuver Suite a number of Starship Maneuvers equal to 1 + your Wisdom modifier (minimum 1). You can add the same Starship Maneuver more than once.","prerequisite":"Vehicular Combat, Trained in Pilot","special":"You can take this Feat more than once. Each time you take this Feat, you add to your Starship Maneuver Suite a number of new Starship Maneuvers equal to 1 + your Wisdom modifier (minimum 1). A character with the Gunnery Specialist Feat can take this Feat without meeting the other requirements but if they do not possess the other requirements they can only select [Gunner ] Starship Maneuvers when they select this Feat.","normalText":"","sourcebook":"Starships of the Galaxy","page":30,"tags":["feat","general","skill_pilot","vehicle","choice_required","grant_choice","deferred_choice","choice_source_grant_pool"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Vehicular Combat<br>,<br>Trained<br>in<br>Pilot</p>\n<p><strong>Effect:</strong> You add to your<br>Starship Maneuver Suite<br>a number of<br>Starship Maneuvers<br>equal to 1 + your<br>Wisdom<br>modifier (minimum 1). You can add the same<br>Starship Maneuver<br>more than once.</p>\n<p><strong>Special:</strong> You can take this Feat more than once. Each time you take this Feat, you add to your<br>Starship Maneuver Suite<br>a number of new<br>Starship Maneuvers<br>equal to 1 + your<br>Wisdom<br>modifier (minimum 1). A character with the<br>Gunnery Specialist<br>Feat can take this Feat without meeting the other requirements but if they do not possess the other requirements they can only select [<br>Gunner<br>]<br>Starship Maneuvers<br>when they select this Feat.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Starship_Tactics</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Progression grant metadata for Starship Maneuvers.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"grant_unlock","applicationScope":"progression_entitlement","staticSheetPolicy":"not_a_modifier","requiresRuntimeContext":false,"requiresSelectedChoice":true,"conditionSummary":"Progression grant metadata for Starship Maneuvers.","predicateRequirements":[],"metadataPhase":"phase13-next-feat-implementation-batch","metadataNotes":"Phase 13 converts clear remaining manual/scaffold feats into skill bonuses, attack options, action/resource metadata, or safer non-static rider metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"starship_tactics_metadata_phase13","grantRules":[{"type":"STARSHIP_MANEUVERS","countFormula":"max(1, 1 + wisdomModifier)","registry":"starshipManeuver","description":"Learn starship maneuvers using the Starship Tactics grant pool."}]},"choiceMeta":{"resolution":"deferred","required":true,"status":"phase13_grant_pool_metadata","choiceKind":"starship_maneuver_pick","repeatable":true,"optionRegistry":"data/feat-choice-options.json#choiceKinds.starship_maneuver_pick","storagePath":"flags.swse.pendingEntitlements.starship_maneuver_pick","choiceSource":"grantPool","grantType":"starship_maneuver","registry":"starshipManeuver"},"shortSummary":"You are trained to make use of Starship Maneuvers and are skilled at space combat.","prerequisitesText":"Vehicular Combat, Trained in Pilot","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Starship_Tactics","effect":"You add to your\nStarship Maneuver Suite\na number of\nStarship Maneuvers\nequal to 1 + your\nWisdom\nmodifier (minimum 1). You can add the same\nStarship Maneuver\nmore than once."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.starship_tactics","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Starship_Tactics","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"37aa58a3833bf34a","name":"Bad Feeling","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can always take a Move Action during a Surprise Round, even if you are Surprised. If you are not Surprised, you can take this Move Action in addition to any other Actions you are normally allowed to take in the Surprise Round.","prerequisite":"None","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":32,"tags":["action_economy","feat","general","move_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> You can always take a<br>Move Action<br>during a<br>Surprise Round<br>, even if you are<br>Surprised<br>. If you are not<br>Surprised<br>, you can take this<br>Move Action<br>in addition to any other Actions you are normally allowed to take in the<br>Surprise Round<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Bad_Feeling</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Surprise-round capability; no sheet modifier.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"passive_capability","applicationScope":"surprise_round_context","staticSheetPolicy":"not_a_modifier","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Surprise-round capability; no sheet modifier.","predicateRequirements":[],"metadataPhase":"phase13-next-feat-implementation-batch","metadataNotes":"Phase 13 converts clear remaining manual/scaffold feats into skill bonuses, attack options, action/resource metadata, or safer non-static rider metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"bad_feeling_metadata_phase13","actionRules":[{"type":"SURPRISE_ROUND_MOVE_ACTION","description":"You always have a Move Action available during the surprise round."}]},"shortSummary":"Always have a Move Action during the Surprise Round.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Bad_Feeling","effect":"You can always take a\nMove Action\nduring a\nSurprise Round\n, even if you are\nSurprised\n. If you are not\nSurprised\n, you can take this\nMove Action\nin addition to any other Actions you are normally allowed to take in the\nSurprise Round\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.bad_feeling","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Bad_Feeling","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"37cb4455a70876ad","name":"Forceful Saber Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Use the Force checks made to activate Saber Throw.","prerequisite":"Trained in Use the Force, Saber Throw","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","force","offense","offense_melee"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"+2 UTF applies only to Saber Throw activation checks.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"skill_roll_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"+2 UTF applies only to Saber Throw activation checks.","predicateRequirements":[],"metadataPhase":"phase13-next-feat-implementation-batch","metadataNotes":"Phase 13 converts clear remaining manual/scaffold feats into skill bonuses, attack options, action/resource metadata, or safer non-static rider metadata.","executionModel":"PASSIVE","subType":"RULE","skillCheckBonuses":[{"id":"forcefulSaberThrow.saberThrow","skillKey":"useTheForce","value":2,"type":"feat","applications":["Saber Throw"],"description":"+2 Use the Force checks to activate Saber Throw."}],"implementationStatus":"forceful_saber_throw_skill_bonus_phase13"},"shortSummary":"You gain a +2 bonus on Use the Force checks made to activate Saber Throw."},"effects":[{"_id":"a4d4bea4-b709-4277-b831-4968e0570216","name":"Forceful Saber Throw","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Forceful Saber Throw","effect