{"_id":"0066c394e5d636fb","name":"Spray Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you have a weapon set on Autofire, you can reduce the area targeted by your Autofire attack to 1 square.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":27,"tags":["area_pressure","autofire","feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> When you have a weapon set on<br>Autofire<br>, you can reduce the area targeted by your<br>Autofire<br>attack to 1 square.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Spray_Shot</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Spray Shot: No numeric bonus; represented as an autofire attack option.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"No numeric bonus; represented as an autofire attack option."}],"mechanicsMode":"conditional","applicationScope":"autofire_attack_option","staticSheetPolicy":"attack_option_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"When using Autofire, expose an option to reduce the targeted area to 1 square.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"attack_option_phase11","description":"When using Autofire, expose an option to reduce the targeted area to 1 square.","rules":[{"type":