{"_id":"dd2c0e394cdf08ba","name":"Mighty Swing","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can spend two Swift Actions in the same round to deal +1 die of damage on your next melee attack in the same round.","prerequisite":"Strength 13","special":"The effects of this Feat do not stack with the extra damage provided by the Rapid Strike Feat.","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["action_economy","feat","general","offense","swift_action"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Mighty_Swing</p>\n<p>You are capable of delivering jarring melee attacks.</p>\n<p><strong>Prerequisites:</strong> Strength 13</p>\n<h4>Effect</h4>\n<p>You can spend two Swift Actions in the same round to deal +1 die of damage on your next melee attack in the same round.</p>\n<h4>Special</h4>\n<p>The effects of this Feat do not stack with the extra damage provided by the Rapid Strike Feat.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-melee","turn.once-per-round"],"enabled":true,"priority":500,"description":"Mighty Swing"}]},"shortSummary":"Spend two Swift Actions to deal extra damage in melee.","prerequisitesText":"Strength 13","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Mighty_Swing"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["attack.with-melee","turn.once-per-round"],"id":"swse.feat.mighty_swing","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mighty_Swing","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"dd6ad0e712e9a314","name":"Spacer's Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a temporary Force Point when you roll a Natural 20 on a Pilot check.","prerequisite":"Duros","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["defense","feat","force_point_spend","racial","resource_spend","skill_pilot","skill_synergy","species","species_opportunity","survivability"],"bonus_feat_for":["species-duros"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a temporary Force Point when you roll a Natural 20 on a Pilot check."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Spacer's Surge"}]},"shortSummary":"Gain a temporary Force Point when you roll a Natural 20 on a Pilot check."},"effects":[{"_id":"b3fc588e-6694-4d1e-8cd9-2c08adb72883","name":"Spacer's Surge","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Spacer's Surge","effectType":"passive_effect","flagType":"Spacer's Surge"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.spacers_surge"}}}
{"_id":"ddbeb23013d9e917","name":"Force Sensitivity","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You can make Use the Force checks, and Use the Force is considered a Class Skill for you. In addition, whenever you gain a Talent, you have the option of selecting a Force Talent instead. You must meet the prerequisites of the Force Talent to select it.","prerequisite":"Cannot be a Droid","special":"","normalText":"You can't make Use the Force checks or select Force Talents unless you have the Force Sensitivity Feat.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","force","force_execution","skill_synergy","skill_use_the_force","use_the_force","mapped_phase_1","unlock_grant"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Force_Sensitivity</p>\n<p>You are Force-sensitive, allowing you to call on The Force and learn to draw on its powers.</p>\n<p><strong>Prerequisites:</strong> Cannot be a Droid</p>\n<h4>Effect</h4>\n<p>You can make Use the Force checks, and Use the Force is considered a Class Skill for you. In addition, whenever you gain a Talent, you have the option of selecting a Force Talent instead. You must meet the prerequisites of the Force Talent to select it.</p>\n<h4>Normal</h4>\n<p>You can&#x27;t make Use the Force checks or select Force Talents unless you have the Force Sensitivity Feat.</p>\n</div>"},"executionModel":"UNLOCK","abilityMeta":{"grants":[{"category":"SYSTEM_ACCESS","capability":"force_sensitivity","description":"Actor is Force-sensitive and may access Force-sensitive rules and prerequisites."}]},"shortSummary":"You can make Use the Force checks and gain access to Force Talents.","prerequisitesText":"Cannot be a Droid","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Force_Sensitivity"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.force_sensitivity","phase1Mapped":true,"manualMappingResolved":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Force_Sensitivity","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"de584ec0aaddcbad","name":"Wookiee Grip","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using a weapon in which you are proficient and that normally requires two hands, you can wield that weapon with a single hand. You take a -2 penalty to attack rolls with the weapon when it is used in this manner.","prerequisite":"Strength 13","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":27,"tags":["execution_mapped_phase10","feat","general","species_prerequisite_phase10","species_rule"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Wookiee_Grip</p>\n<p>Your strength is such that you need only one hand to use weapons that normally require two hands.</p>\n<p><strong>Prerequisites:</strong> Strength 13</p>\n<h4>Effect</h4>\n<p>When using a weapon in which you are proficient and that normally requires two hands, you can wield that weapon with a single hand. You take a -2 penalty to attack rolls with the weapon when it is used in this manner.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Wookiee Grip: may wield two-handed weapons in one hand. Exposed as a weapon handling rule hook.","rules":[{"type":"WEAPON_HANDLING_OVERRIDE","twoHandedAsOneHanded":true,"description":"Wield two-handed weapons in a single hand.","displayAsCondition":true,"displayLabel":"Wookiee Grip","displayNote":"May wield two-handed weapons in one hand."}]},"prerequisitesStructured":{"type":"all","conditions":[{"type":"species","species":["Wookiee"]}],"_source":"phase10_species_prereq"},"shortSummary":"Wield two-handed weapons in a single hand.","prerequisitesText":"Strength 13","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Wookiee_Grip"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.wookiee_grip","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Wookiee_Grip","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"dec7203bc81176dc","name":"Prime Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If none of your allies are closer to your target than you are when you make a ranged attack, you gain a +1 circumstance bonus to the attack roll. Your target must be at Short Range or closer to gain this bonus.","prerequisite":"Point-Blank Shot","special":"","normalText":"","sourcebook":"Rebellion Era Campaign Guide","page":20,"tags":["ally_support","feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Prime_Shot</p>\n<p>You know how to handle an enemy when none of your allies is closer.</p>\n<p><strong>Prerequisites:</strong> Point-Blank Shot</p>\n<h4>Effect</h4>\n<p>If none of your allies are closer to your target than you are when you make a ranged attack, you gain a +1 circumstance bonus to the attack roll. Your target must be at Short Range or closer to gain this bonus.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Prime Shot"}]},"shortSummary":"Gain a bonus to attack rolls when closer to your target than your allies.","prerequisitesText":"Point-Blank Shot","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Prime_Shot"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.prime_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Prime_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"df58db54c4b53539","name":"Shrewd Bargainer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Suppress opponents' insight and morale bonuses to Will Defense.","prerequisite":"Quarren","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-quarren"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Suppress opponents' insight and morale bonuses to Will Defense."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will"],"enabled":true,"priority":500,"description":"Shrewd Bargainer"}]},"shortSummary":"Suppress opponents' insight and morale bonuses to Will Defense."},"effects":[{"_id":"bde5ddf2-df5a-4f32-a0fb-40c66874662e","name":"Shrewd Bargainer","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Shrewd Bargainer","effectType":"skill_bonus","flagType":"Shrewd Bargainer"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["defense.will"],"id":"swse.feat.shrewd_bargainer"}}}
{"_id":"e0cdeb7d44cf44fd","name":"Brilliant Defense","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you can add your Intelligence modifier to your Reflex Defense as a Reaction; this benefit lasts until the start of your next turn.","prerequisite":"Intelligence 13","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":16,"tags":["ability_intelligence","defense","feat","general","reaction","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Brilliant_Defense</p>\n<p>You think quickly enough on your feet to stay alive in dangerous situations.</p>\n<p><strong>Prerequisites:</strong> Intelligence 13</p>\n<h4>Effect</h4>\n<p>Once per encounter, you can add your Intelligence modifier to your Reflex Defense as a Reaction; this benefit lasts until the start of your next turn.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Brilliant Defense"}]},"shortSummary":"Add your Intelligence bonus to your Reflex Defense as a Reaction.","prerequisitesText":"Intelligence 13","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Brilliant_Defense"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.brilliant_defense","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Brilliant_Defense","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e18eecc0f21a95f4","name":"Friends in Low Places","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you would acquire a license for a Restricted or Military object, you can substitute a Gather Information check for a Knowledge (Bureaucracy) check. Reduce the Black Market cost multiplier of such items by 1.","prerequisite":"Trained in Gather Information","special":"","normalText":"","sourcebook":"Scum and Villainy","page":23,"tags":["feat","general","social"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Friends_in_Low_Places</p>\n<p>Given enough time, you can dig up the right tool for the job.</p>\n<p><strong>Prerequisites:</strong> Trained in Gather Information</p>\n<h4>Effect</h4>\n<p>Whenever you would acquire a license for a Restricted or Military object, you can substitute a Gather Information check for a Knowledge (Bureaucracy) check. Reduce the Black Market cost multiplier of such items by 1.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"gatherinformation"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Friends in Low Places"}]},"shortSummary":"Reduce Black Market cost multiplier for Restricted Items by 1.","prerequisitesText":"Trained in Gather Information","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Friends_in_Low_Places"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.friends_in_low_places","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Friends_in_Low_Places","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e306ecce877537a9","name":"Grab Back","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus to your Reflex Defense against Grab and Grapple attacks. If an enemy misses you when making a Grab or Grapple attack, you can immediately make your own Grab attack against the same enemy as a Reaction.","prerequisite":"Dexterity 13","special":"If you have a Feat that enables you to make a Grapple attack (such as Pin or Trip), you can make a Grapple attack instead.","normalText":"","sourcebook":"Unknown Regions","page":21,"tags":["control","feat","general","grapple","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Grab_Back</p>\n<p>You are able to counter Grab and Grapple attacks, redirecting them back on your attacker.</p>\n<p><strong>Prerequisites:</strong> Dexterity 13</p>\n<h4>Effect</h4>\n<p>You gain a +2 bonus to your Reflex Defense against Grab and Grapple attacks. If an enemy misses you when making a Grab or Grapple attack, you can immediately make your own Grab attack against the same enemy as a Reaction.</p>\n<h4>Special</h4>\n<p>If you have a Feat that enables you to make a Grapple attack (such as Pin or Trip), you can make a Grapple attack instead.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Grab Back"}]},"shortSummary":"As a Reaction, make a Grab or Grapple attack following a failed Grab or Grapple attack made against you.","prerequisitesText":"Dexterity 13","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Grab_Back"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.grab_back","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Grab_Back","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e3b2b8360fb05d82","name":"Shield Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Reaction, when your Vehicle takes damage above its Shield Rating, after the Shield Rating is reduced you can reduce the amount of damage sustained by the Vehicle by an amount up to the remaining Shield Rating. However, the Shield Rating is immediately reduced by one point for every point of damage reduced.","prerequisite":"Droid or Cyborg Hybrid, Trained in Mechanics","special":"The Recharge Shields Action cannot be used on the Vehicle until a full round after the use of Shield Surge. You must have a Scomp Link or similar direct data link to the Vehicle to use this Feat.","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":25,"tags":["defense","feat","general","survivability","vehicle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Shield_Surge</p>\n<p>You can surge the power of a Vehicle&#x27;s shields through your direct data link at precisely the right moment to reduce the damage to the Vehicle from incoming enemy fire.</p>\n<p><strong>Prerequisites:</strong> Droid or Cyborg Hybrid, Trained in Mechanics</p>\n<h4>Effect</h4>\n<p>As a Reaction, when your Vehicle takes damage above its Shield Rating, after the Shield Rating is reduced you can reduce the amount of damage sustained by the Vehicle by an amount up to the remaining Shield Rating. However, the Shield Rating is immediately reduced by one point for every point of damage reduced.</p>\n<h4>Special</h4>\n<p>The Recharge Shields Action cannot be used on the Vehicle until a full round after the use of Shield Surge. You must have a Scomp Link or similar direct data link to the Vehicle to use this Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Shield Surge"}]},"shortSummary":"Trade Vehicle's Shield Rating for damage taken.","prerequisitesText":"Droid or Cyborg Hybrid, Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Shield_Surge"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.shield_surge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Shield_Surge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e4de79f4993a6690","name":"Deep Sight","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain Darkvision and ignore Total Concealment from darkness.","prerequisite":"Quarren","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["cover_play","execution_mapped_phase10","feat","racial","species","species_opportunity","species_rule"],"bonus_feat_for":["species-quarren"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain Darkvision and ignore Total Concealment from darkness."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Deep Sight: grants Darkvision and ignores Total Concealment from darkness.","rules":[{"type":"SENSE_GRANT","sense":"darkvision","description":"Gain Darkvision.","displayAsCondition":true,"displayLabel":"Deep Sight","displayNote":"Darkvision active; ignore Total Concealment from darkness."},{"type":"IGNORE_CONCEALMENT","concealment":"total","source":"darkness","description":"Ignore Total Concealment from darkness."}],"conditionNotes":[{"id":"deep-sight","label":"Deep Sight","severity":"info","text":"Darkvision active; ignore Total Concealment from darkness.","mechanical":true,"gmEnforced":false}]},"shortSummary":"Gain Darkvision and ignore Total Concealment from darkness."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.deep_sight"}}}
{"_id":"e5a77e8e4754fa5b","name":"Trample","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you use the Mounted Charge Action, your Mount can make a single melee attack as a Free Action. While Charging, compare the result to the Reflex Defense of each enemy whose square you Charge through. Each enemy hit by the attack takes Claw, Gore, or Slam damage from the Mount's Natural Weapons plus the Mount's Strength modifier. You or your Mount still can make a regular attack at the end of the Charge.","prerequisite":"Trained in Ride","special":"You can use this Feat if either you or your Mount has taken it. Mounts with this Feat do not require the prerequisite.","normalText":"","sourcebook":"Unknown Regions","page":27,"tags":["charge","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Trample</p>\n<p>When charging, your living Mount can flatten smaller targets between you and your target.</p>\n<p><strong>Prerequisites:</strong> Trained in Ride</p>\n<h4>Effect</h4>\n<p>When you use the Mounted Charge Action, your Mount can make a single melee attack as a Free Action. While Charging, compare the result to the Reflex Defense of each enemy whose square you Charge through. Each enemy hit by the attack takes Claw, Gore, or Slam damage from the Mount&#x27;s Natural Weapons plus the Mount&#x27;s Strength modifier. You or your Mount still can make a regular attack at the end of the Charge.</p>\n<h4>Special</h4>\n<p>You can use this Feat if either you or your Mount has taken it. Mounts with this Feat do not require the prerequisite.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Trample"}]},"shortSummary":"When using the Mounted Charge Action, attack enemies between you and your target.","prerequisitesText":"Trained in Ride","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Trample"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.trample","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Trample","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e5ab9392378400ec","name":"Resilient Reflexes","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Reflex Defense against effects that target Dexterity and may reroll a failed check once per encounter.","prerequisite":"Dex 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["defense","feat","general","survivability"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.reflex","value":2,"type":"untyped","predicates":["defense.reflex","turn.once-per-round"],"enabled":true,"priority":500,"description":"Resilient Reflexes"}]},"shortSummary":"You gain a +2 bonus on Reflex Defense against effects that target Dexterity and may reroll a failed check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["defense.reflex","turn.once-per-round"]}}}
{"_id":"e5d361d01d1b44e4","name":"Weapon Proficiency (Pistols)","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You are proficient with pistols and do not take the -5 penalty when using them.","prerequisite":"","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["build_enabler","feat","general","offense","offense_ranged","weapon_access","weapon_pistol","mapped_phase_1","unlock_grant","choice_variant"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"UNLOCK","abilityMeta":{"grants":[{"category":"PROFICIENCY","proficiencyType":"weapon","proficiencies":["pistols"],"description":"Weapon proficiency: pistols"}]},"choiceMeta":{"resolution":"already_resolved_static_variant","required":false,"choiceKind":"weapon_proficiency","value":"pistols","grants":["pistols"]},"shortSummary":"You are proficient with pistols and do not take the -5 penalty when using them."},"effects":[{"_id":"04733e85-193e-4f4b-8792-c359083557d1","name":"Weapon Proficiency (Pistols)","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Weapon Proficiency (Pistols)","effectType":"passive_effect","flagType":"Weapon Proficiency (Pistols)"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"phase1Mapped":true,"manualMappingResolved":true}}}
{"_id":"e73873cdc77a6451","name":"Powerful Charge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you Charge, you gain an additional +2 bonus on your melee attack roll. If your melee attack hits, you deal additional damage equal to one-half your level.","prerequisite":"Medium or larger size, Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["charge","feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Powerful_Charge</p>\n<p>You can Charge with extra force.</p>\n<p><strong>Prerequisites:</strong> Medium or larger size, Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When you Charge, you gain an additional +2 bonus on your melee attack roll. If your melee attack hits, you deal additional damage equal to one-half your level.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","abilityMeta":{"status":"attack_option_phase7","description":"Powerful Charge: attack option exposed through CombatOptionResolver; not applied automatically.","rules":[{"type":"ATTACK_OPTION","option":"powerfulCharge","label":"Powerful Charge","control":"toggle","requiresAttackType":"melee","requiresCharge":true,"damageModifier":2,"summary":"When charging with a melee attack, gain +2 damage."}]},"subType":"STATE","shortSummary":"Gain +2 bonus on your attack roll while Charging, and deal extra damage.","prerequisitesText":"Medium or larger size, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Powerful_Charge"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.powerful_charge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Powerful_Charge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e85f36d48d9c6989","name":"Meat Shield","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever an opponent attacks you while in Cover provided by another character, creature, or Droid, you are treated as being in Cover from attacks by that opponent.","prerequisite":"Point-Blank Shot, Precise Shot, Base Attack Bonus +4","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":22,"tags":["cover_play","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Meat_Shield</p>\n<p>You are adept at using an opponent&#x27;s defense to your own advantage.</p>\n<p><strong>Prerequisites:</strong> Point-Blank Shot, Precise Shot, Base Attack Bonus +4</p>\n<h4>Effect</h4>\n<p>Whenever an opponent attacks you while in Cover provided by another character, creature, or Droid, you are treated as being in Cover from attacks by that opponent.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Meat Shield"}]},"shortSummary":"Gain Cover bonus equal to opponent's Cover bonus.","prerequisitesText":"Point-Blank Shot, Precise Shot, Base Attack Bonus +4","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Meat_Shield"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.meat_shield","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Meat_Shield","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e896798c6d194345","name":"Fleet-Footed","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you Move both before and after you make an attack using the Running Attack Feat, your Speed is increased by 2 squares until the end of your turn.","prerequisite":"Running Attack","special":"","normalText":"","sourcebook":"Scum and Villainy","page":23,"tags":["feat","general","mobility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Fleet-Footed</p>\n<p>You gain a burst of speed when you attack while running.</p>\n<p><strong>Prerequisites:</strong> Running Attack</p>\n<h4>Effect</h4>\n<p>If you Move both before and after you make an attack using the Running Attack Feat, your Speed is increased by 2 squares until the end of your turn.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Fleet-Footed"}]},"shortSummary":"+2 Speed when making a Running Attack.","prerequisitesText":"Running Attack","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Fleet-Footed"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.fleet_footed","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fleet-Footed","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e8e6b74907471ad5","name":"Cornered","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you are Threatened by an opponent and unable to take the Withdraw Action, you gain a +2 bonus on attack rolls against opponents that threaten you.","prerequisite":"None","special":"","normalText":"","sourcebook":"Scum and Villainy","page":21,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Cornered</p>\n<p>You are vicious when cornered.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Whenever you are Threatened by an opponent and unable to take the Withdraw Action, you gain a +2 bonus on attack rolls against opponents that threaten you.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Cornered"}]},"shortSummary":"When unable to Withdraw, +2 on attacks.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Cornered"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.cornered","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Cornered","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e9147ce66a783fbb","name":"Starship Designer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can design a Starship from scratch. Doing so takes a minimum of 30 days and a DC 25 Mechanics check, adding 1 to the DC and 1 to the time for every additional 100,000 credits of the design's final cost beyond the first 100,000 credits (even a genius Starship Designer can spend years working out the blueprints for a Star Destroyer). Other characters Trained in the Mechanics skill may use the Aid Another action to assist your Mechanics check; if any assisting character also has the Starship Designer Feat, divide the Starship's cost by the number of characters who have this Feat (including the primary designer) when determining the time required.\n\nWhen making Starship Modifications, you never treat the work as though it were a Nonstandard Modification, even if it normally would be. Additionally, you can make custom modifications to Starships. Each of these modifications has a base cost of 5,000 credits (multiplied by the Starship Size Cost Modifier) and requires a DC 25 Mechanics check. On a failed check, the modification fails; you must spend half again as much time and money to make a second attempt, and you gain a +2 bonus on your Mechanics check for each attempt after the first.\n\nInstallation of a custom modification normally takes one day per 5,000 credits of the final cost. The same system can be customized multiple times, but doing so becomes increasingly difficult and expensive. For every previous custom modification on a given system, increase the DC by 5 and the base cost by 10,000 credits. No system can be customized more than three times. Multiple benefits from successive customizations stack. Typical customizations are described below. The Gamemaster may allow other modifications.\n\n- Add Emplacement: You add 1 unused Emplacement Point to a Starship.\n- Improve Hull: You add a number of Hit Points to a Starship equal to 1/2 its Strength score (rounded down to the nearest multiple of 10).\n- Improve Hyperdrive: You can reengineer a hyperdrive to improve its class by 1 step. The hyperdrive obeys all the restrictions of its new class.\n- Improve Shields: The Shield Rating of the shields is increased by 5.\n- Improve Weapons: You grant one Vehicle Weapon a +1 Equipment bonus on attack rolls.","prerequisite":"Tech Specialist, Trained in Mechanics","special":"","normalText":"","sourcebook":"Starships of the Galaxy","page":30,"tags":["feat","general","skill_pilot","tech","utility","vehicle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy; Star Wars Saga Edition Web Enhancements (Jedi Counseling)</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Starship_Designer</p>\n<p>You are trained to design (and redesign) Starships.</p>\n<p><strong>Prerequisites:</strong> Tech Specialist, Trained in Mechanics</p>\n<h4>Effect</h4>\n<p>You can design a Starship from scratch. Doing so takes a minimum of 30 days and a DC 25 Mechanics check, adding 1 to the DC and 1 to the time for every additional 100,000 credits of the design&#x27;s final cost beyond the first 100,000 credits (even a genius Starship Designer can spend years working out the blueprints for a Star Destroyer). Other characters Trained in the Mechanics skill may use the Aid Another action to assist your Mechanics check; if any assisting character also has the Starship Designer Feat, divide the Starship&#x27;s cost by the number of characters who have this Feat (including the primary designer) when determining the time required.</p>\n<p>When making Starship Modifications, you never treat the work as though it were a Nonstandard Modification, even if it normally would be. Additionally, you can make custom modifications to Starships. Each of these modifications has a base cost of 5,000 credits (multiplied by the Starship Size Cost Modifier) and requires a DC 25 Mechanics check. On a failed check, the modification fails; you must spend half again as much time and money to make a second attempt, and you gain a +2 bonus on your Mechanics check for each attempt after the first.</p>\n<p>Installation of a custom modification normally takes one day per 5,000 credits of the final cost. The same system can be customized multiple times, but doing so becomes increasingly difficult and expensive. For every previous custom modification on a given system, increase the DC by 5 and the base cost by 10,000 credits. No system can be customized more than three times. Multiple benefits from successive customizations stack. Typical customizations are described below. The Gamemaster may allow other modifications.</p>\n<ul><li><strong>Add Emplacement:</strong> You add 1 unused Emplacement Point to a Starship.</li><li><strong>Improve Hull:</strong> You add a number of Hit Points to a Starship equal to 1/2 its Strength score (rounded down to the nearest multiple of 10).</li><li><strong>Improve Hyperdrive:</strong> You can reengineer a hyperdrive to improve its class by 1 step. The hyperdrive obeys all the restrictions of its new class.</li><li><strong>Improve Shields:</strong> The Shield Rating of the shields is increased by 5.</li><li><strong>Improve Weapons:</strong> You grant one Vehicle Weapon a +1 Equipment bonus on attack rolls.</li></ul>\n<h4>Additional Starship Design Rules</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Web Enhancements (Jedi Counseling)</p>\n<p><strong>Q:</strong> I&#x27;ve run into some issues with the Starship Design rules in Starships of the Galaxy. It seems that you can&#x27;t make any existing Starships using these rules and starting with a Stock Starship. Am I doing something wrong?</p>\n<p><strong>A:</strong> Probably not. A vast number of individual Starships have been created over the last few decades since A New Hope came out, and at no point was there a cohesive Starship design system to guide authors of fiction or gaming products. As such, it is effectively impossible to reverse-engineer a design system that covers all these varied examples- or, at least, any such system would be so complex that it wouldn&#x27;t be easy to use in a game.</p>\n<p>Given that, we designed the system from the point of the typical hero who might be interested in modifying an existing Starship or scratch-building a new one. This hero doesn&#x27;t have the benefit of vast numbers of the best engineers and test pilots in the galaxy (like at the Corellian Engineering Corporation), nor does this hero have an entire star system dedicated to the building of city-sized Starships with mass-production facilities to match (like at Kuat Drive Yards).</p>\n<p>This hero, instead, is relegated to building &quot;A typical new Starship from a typical production facility,&quot; as noted at the bottom of Table 3–8: Stock Ship Types. The Stock Starships are designed to reflect that, making it possible to make something decent and functional, but not something that would easily outshine the big name starships.</p>\n<p>For example, a hero could build a decent light freighter, something comparable to a YT-1300 in stats and price.</p>\n<p>The biggest difference? The YT-1300 would have a lot of extra Emplacement Points left over- and that&#x27;s precisely what the Corellian Engineering Corporation is known for. Think about it: if any yahoo on a backwater planet could build a freighter that&#x27;s just as good, why would the YT-series freighters sell so well throughout the galaxy?</p>\n<p>Since most heroes won&#x27;t ever control a galaxy-spanning corporate giant and be able to use these resources, it seems a little silly to spend page space exploring the ins and outs of galactic-scale mass production. Similarly, we might give broad outlines of supply and demand by listing a planet&#x27;s major exports and imports, but we won&#x27;t be creating rules that account for macroeconomic cycles, unemployment, inflation, and so forth. (Let&#x27;s face it: Most of us are just here to shoot Stormtroopers.)</p>\n<p>Now, if you as the GM want to build Starships beyond what the Stock Starships can manage, there&#x27;s really not a reason for you to hamstring yourself with those rules: just write up stats that seem like a good challenge for your players, using similar Starships as benchmarks for things like price, appropriate game statistics for that type of ship, and so forth.</p>\n<p>And if you and your players really want more comprehensive rules that go beyond those in the book, by all means do so! You might look at Gear Templates to get some inspiration for coming up with appropriate special benefits and restrictions for different manufacturers.</p>\n<p>Alternatively, you might allow manufacturers to come up with &quot;Proprietary&quot; Stock Starships that are better than the typical ones listed in the book. For example, Kuat Drive Yards might have a really good &quot;Stock Star Destroyer&quot; and Corellian Engineering Corporation might have an outstanding &quot;Stock YT-Series,&quot; and they use these as the baseline for producing several similar Starship designs.</p>\n<p><strong>Q:</strong> When building a new design from a Stock Starship, can you remove or replace existing systems that come with the stock ship? For example, could I take those high-performance engines off a stock interceptor and use the cash to buy other systems?</p>\n<p><strong>A:</strong> You can, but it&#x27;s not very efficient. You get only 1/4 the listed value of any system you remove from a Starship, even a Stock Starship.</p>\n<p>Stock Starships usually get their starting systems at a substantial discount because they are so well integrated into the baseline design. Removing them requires a lot of inefficient workarounds, resulting in a lower price comparable to selling a used Starship component.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Starship Designer"}],"status":"starship_design_gm_enforced","description":"GM-enforced: Permits starship design, redesign, and custom modifications. Starship modification work is never treated as Nonstandard Modification. Design time, DC scaling, aid another division, and custom modification costs require GM adjudication. See Starship Designer rules in sourcebook."},"shortSummary":"You are trained to design (and redesign) Starships.","prerequisitesText":"Tech Specialist, Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy","Star Wars Saga Edition Web Enhancements (Jedi Counseling)"],"sourceUrl":"https://swse.fandom.com/wiki/Starship_Designer"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.starship_designer","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Starship_Designer","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e95252c02d2ae129","name":"Sensor Link","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Swift Action, you can broadcast the input from your audio, visual, and special sensors to a Droid ally, Comlink, communications system, or holographic receiver within 24 squares.\n\nThat ally is aware of anything you are aware of, and can use the Aid Another Action to aid on your Perception checks even if you do not have line of sight to one another. If both you and your ally have Sensor Link, you share information simultaneously, granting a +2 bonus to Perception checks.","prerequisite":"Droid or Cyborg Hybrid","special":"Cyborg Hybrids with built-in Subcutaneous Comlink can also take this Feat.","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":24,"tags":["ally_support","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Sensor_Link</p>\n<p>You can broadcast your sensor input to an ally, such as another Droid or a Friendly computer system.</p>\n<p><strong>Prerequisites:</strong> Droid or Cyborg Hybrid</p>\n<h4>Effect</h4>\n<p>As a Swift Action, you can broadcast the input from your audio, visual, and special sensors to a Droid ally, Comlink, communications system, or holographic receiver within 24 squares.</p>\n<p>That ally is aware of anything you are aware of, and can use the Aid Another Action to aid on your Perception checks even if you do not have line of sight to one another. If both you and your ally have Sensor Link, you share information simultaneously, granting a +2 bonus to Perception checks.</p>\n<h4>Special</h4>\n<p>Cyborg Hybrids with built-in Subcutaneous Comlink can also take this Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Sensor Link"}]},"shortSummary":"Share sensor data instantly with an ally.","prerequisitesText":"Droid or Cyborg Hybrid","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Sensor_Link"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.sensor_link","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Sensor_Link","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
