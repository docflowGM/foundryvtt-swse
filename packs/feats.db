{"_id":"9f1305cc6ada5d7a","name":"Devastating Bellow","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Deal more damage with your Bellow attacks.","prerequisite":"Ithorian","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-ithorian"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Ithorian</p>\n<p><strong>Effect:</strong> Your bellow attack deals 4d6 points of damage on a hit and half damage on a miss.</p>\n<p><strong>Normal:</strong> Without this feat, your bellow attack deals 3d6 points of damage on a hit.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Devastating_Bellow</em></p>\n<p><strong>Automation:</strong> Implemented in the Ithorian Bellow action: your Bellow base damage becomes 4d6 sonic and still deals half damage on a miss.</p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":false,"priority":500,"description":"Devastating Bellow: Improves Ithorian bellow damage to 4d6 and half on miss; not an attack bonus.","mechanicsMode":"implemented_species_ability_modifier","applicationScope":"ithorian_bellow_damage","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit"],"conditionSummary":"Improves Ithorian bellow damage to 4d6 and half on miss; not an attack bonus."}],"mechanicsMode":"implemented_species_ability_modifier","applicationScope":"ithorian_bellow_damage","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Enabled modifier is gated by runtime predicates and should not be treated as actor-wide static math.","predicateRequirements":["attack.when-hit"],"metadataPhase":"phase23-feat-cleanup","metadataNotes":"Phase 12 continues description-guided feat implementation by replacing false scaffold bonuses with explicit roll options, contextual predicates, resource/rider metadata, or supported static rules.","riderRules":[{"type":"SPECIAL_ATTACK_DAMAGE_OVERRIDE","id":"devastatingBellow","attack":"bellow","damage":"4d6","halfDamageOnMiss":true,"description":"Bellow attack deals 4d6 on hit and half damage on miss."}],"status":"implemented_bellow_damage_phase23","description":"Implemented by SpeciesActivatedAbilityEngine.useBellow(): Ithorian Bellow base damage becomes 4d6 instead of 3d6 and still deals half on miss.","gmManaged":false,"speciesAbilityRules":[{"id":"devastating_bellow_damage","ability":"bellow","effect":"baseDamageDice","baseDice":4,"die":"d6","damageType":"sonic","halfOnMiss":true,"description":"Bellow base damage becomes 4d6 sonic and deals half damage on a miss."}]},"shortSummary":"Deal more damage with your Bellow attacks.","sourceUrl":"https://swse.fandom.com/wiki/Devastating_Bellow","rawImport":{"name":"Devastating Bellow","url":"https://swse.fandom.com/wiki/Devastating_Bellow","pageTitle":"Devastating_Bellow","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\devastating_bellow.html","referenceBooks":[],"prerequisitesText":"Ithorian","prerequisites":["Ithorian"],"effect":"Your bellow attack deals 4d6 points of damage on a hit and half damage on a miss.","benefit":"","normal":"Without this feat, your bellow attack deals 3d6 points of damage on a hit.","special":"","indexPrerequisites":"Ithorian","indexBenefit":"Deal more damage with your Bellow attacks.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYour bellow produces greater sonic energy than do the bellows of other members of your species.\n\nPrerequisite:\nIthorian\n\nEffect:\nYour bellow attack deals 4d6 points of damage on a hit and half damage on a miss.\n\nNormal:\nWithout this feat, your bellow attack deals 3d6 points of damage on a hit."},"prerequisitesText":"Ithorian","effect":"Your bellow attack deals 4d6 points of damage on a hit and half damage on a miss."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.devastating_bellow"}}}
{"_id":"a12f6fd51e121a30","name":"Vitality Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can catch a Second Wind even if you are not at or below half your maximum Hit Points.","prerequisite":"Extra Second Wind","special":"","normalText":"Without this Feat, you can catch a Second Wind only if you are at or below half your maximum Hit Points.","sourcebook":"Rebellion Era Campaign Guide","page":23,"tags":["defense","durability","execution_mapped_phase8","feat","general","hit_points","recovery","resource_second_wind","second_wind","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Extra Second Wind</p>\n<p><strong>Effect:</strong> You can catch a<br>Second Wind<br>even if you are not at or below half your maximum Hit Points.</p>\n<p><strong>Normal:</strong> Without this Feat, you can catch a<br>Second Wind<br>only if you are at or below half your maximum Hit Points.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Vitality_Surge</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":false,"priority":500,"description":"Vitality Surge changes Second Wind eligibility, not attack rolls.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit"],"conditionSummary":"Vitality Surge changes Second Wind eligibility, not attack rolls."}],"resourceRules":{"secondWind":[{"type":"ALLOW_ABOVE_HALF_HP","description":"You may catch a Second Wind even when not at or below half hit points."}]},"mechanicsMode":"passive_resource","applicationScope":"secondWind_resource","staticSheetPolicy":"resource_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditi