{"_id":"a16af4c63582b44a","name":"Flash and Clear","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you damage a target with a Burst or Splash weapon, you gain Concealment against that target until the beginning of your next turn.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":23,"tags":["area_pressure","cover_play","feat","general","grenade","multi_target","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> When you damage a target with a<br>Burst<br>or<br>Splash<br>weapon, you gain<br>Concealment<br>against that target until the beginning of your next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Flash_and_Clear</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"burst_splash_damage_concealment","staticSheetPolicy":"roll_context_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Flash and Clear: damaging with a Burst or Splash weapon grants concealment against that target until your next turn.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"attack_rider_metadata_phase16","description":"Flash and Clear: damaging with a Burst or Splash weapon grants concealment against that target until your next turn.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Flash and Clear: damaging with a Burst or Splash weapon grants concealment against that target until your next turn.","mechanicsM