{"_id":"192923f60db38831","name":"Staggering Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using a melee weapon with which you are proficient, you can make an attack that disrupts an enemy's concentration. You take a -2 penalty on your attack roll, and if your attack deals damage, the target takes a -2 penalty to Skill Checks until the end of your next turn. Alternatively, you can take a -5 penalty to your attack roll, and if your attack deals damage, the target takes a -5 penalty to Skill Checks until end of your next turn.","prerequisite":"Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["control","feat","general","offense"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Sneak Attack<br>or<br>Rapid Shot<br>or<br>Rapid Strike</p>\n<p><strong>Effect:</strong> Any time you would deal additional damage from a<br>Feat<br>or<br>Talent<br>that grants one or more extra dice of damage, you can forgo the extra damage to move the target 2 squares per extra die sacrificed. This movement does not provoke<br>Attacks of Opportunity<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Staggering_Attack</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit","attack.with-melee","turn.once-per-round"],"enabled":false,"priority":500,"description":"Staggering Attack: Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit","attack.with-melee","turn.once-per-round"],"conditionSummary":"Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Staggering Attack now has explicit roll-context attack option metadata from its refreshed description.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","rules":[{"type":"ATTACK_OPTION","option":"staggeringAttackMinor","label":"Staggering Attack (-2)","control":"toggle","requiresAttackType":"melee","attackModifier":-2,"targetEffectsOnHit":[{"type":"SKILL_CHECK_PENALTY","target":"target","value":-2,"duration":"untilEndOfNextTurn","description":"Target takes -2 to Skill Checks until end of your next turn."}],"summary":"Take -2 on melee attack; on damage, target takes -2 to Skill Checks."},{"type":"ATTACK_OPTION","option":"staggeringAttackMajor","label":"Staggering Attack (-5)","control":"toggle","requiresAttackType":"melee","attackModifier":-5,"targetEffectsOnHit":[{"type":"SKILL_CHECK_PENALTY","target":"target","value":-5,"duration":"untilEndOfNextTurn","description":"Target takes -5 to Skill Checks until end of your next turn."}],"summary":"Take -5 on melee attack; on damage, target takes -5 to Skill Checks."}],"status":"attack_option_phase10","description":"Staggering Attack now has explicit roll-context attack option metadata from its refreshed description."},"shortSummary":"Impose penalties to enemy Skill Checks with a successful attack.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Staggering_Attack","effect":"Any time you would deal additional damage from a\nFeat\nor\nTalent\nthat grants one or more extra dice of damage, you can forgo the extra damage to move the target 2 squares per extra die sacrificed. This movement does not provoke\nAttacks of Opportunity\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["attack.when-hit","attack.with-melee","turn.once-per-round"],"id":"swse.feat.staggering_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Staggering_Attack_(GaW)","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"19ca8f89351e8fee","name":"Stunning Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you may move a target -1 step down the condition track when you hit with a melee attack.","prerequisite":"Base attack bonus +6","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["control","feat","general","offense","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit","attack.with-melee","turn.once-per-round"],"enabled":false,"priority":500,"description":"Stunning Strike: Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit","attack.with-melee","turn.once-per-round"],"conditionSummary":"Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Stunning Strike now has explicit roll-context attack option metadata from its refreshed description.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","rules":[{"type":"ATTACK_OPTION","option":"stunningStrike","label":"Stunning Strike","control":"toggle","requiresAttackType":"melee","on