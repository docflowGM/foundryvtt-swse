{"_id":"1dfbddf5f1aa57c3","name":"K'tara Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"martial_arts","benefit":"Deal extra damage against Flat-Footed enemy. Render target Mute.","prerequisite":"Martial Arts I, Trained in Stealth","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","feat_chain","martial_arts","martial_style","offense_melee","unarmed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Deal extra damage against Flat-Footed enemy. Render target Mute."},"martialArtsFeat":true,"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.reflex","value":2,"type":"untyped","predicates":["defense.reflex","defense.fortitude","turn.on-current-turn","turn.once-per-round"],"enabled":true,"priority":500,"description":"K'tara Training"}]},"shortSummary":"Deal extra damage against Flat-Footed enemy."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["defense.reflex","defense.fortitude","turn.on-current-turn","turn.once-per-round"],"id":"swse.feat.ktara_training"}}}
{"_id":"1e0222988b4e8714","name":"Force Regimen Mastery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You learn a number of Force Regimens equal to 1 + your Wisdom modifier (minimum 1).","prerequisite":"Force Sensitivity, Trained in Use the Force","special":"You can take this Feat more than once. Each time you take this Feat, you learn a number of additional Force Regimens equal to 1 + your Wisdom modifier (minimum 1). If your Wisdom modifier permanently increases, you immediately gain a number of Force Regimens equal to the number of Force Regimen Mastery Feats you have taken.","normalText":"","sourcebook":"Jedi Academy Training Manual","page":31,"tags":["ability_wisdom","feat","force"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Jedi Academy Training Manual</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Force_Regimen_Mastery</p>\n<p>You learn one or more Force Regimens, which you can use to enhance your regular training.</p>\n<p><strong>Prerequisites:</strong> Force Sensitivity, Trained in Use the Force</p>\n<h4>Effect</h4>\n<p>You learn a number of Force Regimens equal to 1 + your Wisdom modifier (minimum 1).</p>\n<h4>Special</h4>\n<p>You can take this Feat more than once. Each time you take this Feat, you learn a number of additional Force Regimens equal to 1 + your Wisdom modifier (minimum 1). If your Wisdom modifier permanently increases, you immediately gain a number of Force Regimens equal to the number of Force Regimen Mastery Feats you have taken.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"usetheforce"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Force Regimen Mastery"}]},"shortSummary":"Learn a number of Force Regimens equal to 1 + your Wisdom modifier (minimum of 1).","prerequisitesText":"Force Sensitivity, Trained in Use the Force","referenceBooks":["Star Wars Saga Edition Jedi Academy Training Manual"],"sourceUrl":"https://swse.fandom.com/wiki/Force_Regimen_Mastery"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.force_regimen_mastery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Force_Regimen_Mastery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1e21ddf471811265","name":"Tumble Defense","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When an opponent attempts to Tumble through a square you threaten with a melee weapon with which you are proficient, add your Base Attack Bonus to the DC of the Acrobatics check made to Tumble. If the target fails the Acrobatics check to Tumble, you can make an Attack of Opportunity against that opponent as normal.","prerequisite":"None","special":"You cannot use this Feat when you are Flat-Footed.","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":30,"tags":["defense","feat","general","mobility","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Tumble_Defense</p>\n<p>You can use your melee weapon to hinder acrobatic enemies.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When an opponent attempts to Tumble through a square you threaten with a melee weapon with which you are proficient, add your Base Attack Bonus to the DC of the Acrobatics check made to Tumble. If the target fails the Acrobatics check to Tumble, you can make an Attack of Opportunity against that opponent as normal.</p>\n<h4>Special</h4>\n<p>You cannot use this Feat when you are Flat-Footed.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Tumble Defense"}]},"shortSummary":"Your martial ability makes it harder for opponents to Tumble past.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Tumble_Defense"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.tumble_defense","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Tumble_Defense","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1ea7da65feb15b18","name":"Exotic Weapon Proficiency","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Select a single weapon from either the Exotic Weapons (Melee) or Exotic Weapons (Ranged) weapon groups; you make attack rolls with the selected weapon without penalty.","prerequisite":"Base Attack Bonus +1","special":"You can gain this Feat multiple times. Each time you take this Feat, it applies to a different Exotic Weapon.","normalText":"A character who uses a weapon without being proficient with it takes a -5 penalty to attack rolls.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["build_enabler","feat","general","offense","weapon_access","choice_required","immediate_choice","weapon_choice","exotic_weapon_choice","legacy_choice_alias","choice_source_fixed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Exotic_Weapon_Proficiency</p>\n<p>You are skilled at wielding an unusual weapon with ease, allowing you to utilize it in combat more effectively.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>Select a single weapon from either the Exotic Weapons (Melee) or Exotic Weapons (Ranged) weapon groups; you make attack rolls with the selected weapon without penalty.</p>\n<h4>Normal</h4>\n<p>A character who uses a weapon without being proficient with it takes a -5 penalty to attack rolls.</p>\n<h4>Special</h4>\n<p>You can gain this Feat multiple times. Each time you take this Feat, it applies to a different Exotic Weapon.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Exotic Weapon Proficiency"}]},"choiceMeta":{"resolution":"immediate","required":true,"status":"tagged_for_later_dialog_backfill","choiceKind":"weapon_proficiency","routeThrough":"Weapon Proficiency","branch":"exotic","repeatable":true,"legacyChoiceAliasOf":"Weapon Proficiency","optionRegistry":"data/feat-choice-options.json#weapon_proficiency.exotic","storagePath":"flags.swse.choices.weaponProficiency","notes":"Legacy feat row retained for compatibility; future UI should prefer the grouped Weapon Proficiency feat exotic branch.","choiceSource":"fixed","provides":"weapon_proficiency","resultShape":"exotic_weapon"},"shortSummary":"Wield an Exotic Weapon without penalty.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Exotic_Weapon_Proficiency"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.exotic_weapon_proficiency","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Exotic_Weapon_Proficiency","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1ec2b64343aca60e","name":"Close Combat Escape","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully use Acrobatics to escape a Grapple, you can spend a Swift Action to make a single attack with a melee weapon or an Unarmed attack against the opponent that had Grappled you. If the attack hits, it deals normal damage, and your opponent is considered Flat-Footed until the start of its next turn.","prerequisite":"Trained in Acrobatics","special":"","normalText":"","sourcebook":"Scum and Villainy","page":20,"tags":["control","feat","general","grapple"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Close_Combat_Escape</p>\n<p>When you slip free from your opponent, you can deliver a parting attack.</p>\n<p><strong>Prerequisites:</strong> Trained in Acrobatics</p>\n<h4>Effect</h4>\n<p>When you successfully use Acrobatics to escape a Grapple, you can spend a Swift Action to make a single attack with a melee weapon or an Unarmed attack against the opponent that had Grappled you. If the attack hits, it deals normal damage, and your opponent is considered Flat-Footed until the start of its next turn.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"a6c5e98148aad9a9"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Close Combat Escape"}]},"shortSummary":"Escape Grapple and attack.","prerequisitesText":"Trained in Acrobatics","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Close_Combat_Escape"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.close_combat_escape","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Close_Combat_Escape","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1f2f70d34a17667d","name":"Vehicular Combat","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per round (as a Reaction), when you are piloting a Vehicle or Starship, you may negate a weapon hit by making a successful Pilot check. The DC of the Skill Check is equal to the result of the attack roll you wish to negate. In addition, while you are piloting a Vehicle, you are considered proficient with pilot-operated Vehicle Weapons.","prerequisite":"Trained in Pilot","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","skill_pilot","skill_synergy","vehicle"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Vehicular_Combat</p>\n<p>You can avoid attacks made against your Vehicle.</p>\n<p><strong>Prerequisites:</strong> Trained in Pilot</p>\n<h4>Effect</h4>\n<p>Once per round (as a Reaction), when you are piloting a Vehicle or Starship, you may negate a weapon hit by making a successful Pilot check. The DC of the Skill Check is equal to the result of the attack roll you wish to negate. In addition, while you are piloting a Vehicle, you are considered proficient with pilot-operated Vehicle Weapons.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"b8dad0c963f046c6"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":2,"type":"untyped","predicates":["attack.when-hit","turn.once-per-round"],"enabled":true,"priority":500,"description":"Vehicular Combat"}]},"shortSummary":"Negate one attack per round against the Vehicle you're piloting.","prerequisitesText":"Trained in Pilot","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Vehicular_Combat"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.when-hit","turn.once-per-round"],"id":"swse.feat.vehicular_combat","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Vehicular_Combat","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1f404db00518aeed","name":"Damage Conversion","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you take damage from an attack against you (other than an Area Attack, or an attack that deals Ion or Force damage) and that damage equals or exceeds your Damage Threshold, you can take an additional 10 points of damage instead of moving down the Condition Track. Each subsequent time you use this Feat in a single encounter, the additional damage you take increases by 5 points.","prerequisite":"Droid, Dexterity 13","special":"","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":19,"tags":["condition_track","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Damage_Conversion</p>\n<p>You can make last-minute moves to take hits on more durable portions of your chassis and/or armor, altering the damage dealt to you.</p>\n<p><strong>Prerequisites:</strong> Droid, Dexterity 13</p>\n<h4>Effect</h4>\n<p>When you take damage from an attack against you (other than an Area Attack, or an attack that deals Ion or Force damage) and that damage equals or exceeds your Damage Threshold, you can take an additional 10 points of damage instead of moving down the Condition Track. Each subsequent time you use this Feat in a single encounter, the additional damage you take increases by 5 points.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Damage Conversion"}]},"shortSummary":"Take additional Hit Point damage instead of moving down the Condition Track.","prerequisitesText":"Droid, Dexterity 13","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Damage_Conversion"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.damage_conversion","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Damage_Conversion","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1f594024b4757109","name":"Lightning Draw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you can draw a holstered weapon and attack as a single Standard Action.","prerequisite":"Quick Draw","special":"","normalText":"With the Quick Draw feat, drawing or holstering a weapon is a Swift Action.","sourcebook":"Scum and Villainy","page":26,"tags":["feat","general","standard_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Lightning_Draw</p>\n<p>You can draw and fire in one smooth action.</p>\n<p><strong>Prerequisites:</strong> Quick Draw</p>\n<h4>Effect</h4>\n<p>Once per encounter, you can draw a holstered weapon and attack as a single Standard Action.</p>\n<h4>Normal</h4>\n<p>With the Quick Draw feat, drawing or holstering a weapon is a Swift Action.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Lightning Draw"}]},"shortSummary":"Draw and fire as a Standard Action.","prerequisitesText":"Quick Draw","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Lightning_Draw"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.lightning_draw","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Lightning_Draw","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"203f7fa521105d0b","name":"Tool Frenzy","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Standard Action, using Appendages not normally considered Weapons, you can make several strikes as a single attack against a single target. Make an Unarmed melee attack with a +2 bonus; until the end of your next turn, you take a -2 penalty to your Reflex Defense. Use the damage die of the highest rated Appendage when determining damage.","prerequisite":"Droid, Small size or larger, 2+ Tool Appendages","special":"True melee or ranged Weapons are not considered Tools for the purposes of this Feat.","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":26,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Tool_Frenzy</p>\n<p>You use all your built-in Appendages, Claws, Probes, Instruments, and Tools at once to slash, pierce, burn, or cut your enemy in a frenzied melee attack.</p>\n<p><strong>Prerequisites:</strong> Droid, Small size or larger, 2+ Tool Appendages</p>\n<h4>Effect</h4>\n<p>As a Standard Action, using Appendages not normally considered Weapons, you can make several strikes as a single attack against a single target. Make an Unarmed melee attack with a +2 bonus; until the end of your next turn, you take a -2 penalty to your Reflex Defense. Use the damage die of the highest rated Appendage when determining damage.</p>\n<h4>Special</h4>\n<p>True melee or ranged Weapons are not considered Tools for the purposes of this Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Tool Frenzy"}]},"shortSummary":"Gain +2 to attack rolls and damage rolls with nonweapon Appendages in exchange for a -2 penalty to Reflex Defense.","prerequisitesText":"Droid, Small size or larger, 2+ Tool Appendages","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Tool_Frenzy"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.tool_frenzy","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Tool_Frenzy","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"21a0af5ef58172a0","name":"Quick Comeback","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Recover quickly after being moved down the Condition Track by damage.","prerequisite":"Gamorrean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["condition_track","cover_play","feat","racial","species","species_opportunity"],"bonus_feat_for":["Gamorrean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Recover quickly after being moved down the Condition Track by damage."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Quick Comeback"}]},"shortSummary":"Recover quickly after being moved down the Condition Track by damage."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.quick_comeback"}}}
{"_id":"223a5c14f2ea4737","name":"Ample Foraging","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Grant a bonus to allies' Fortitude Defense by foraging.","prerequisite":"Ewok","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","racial","species","species_opportunity"],"bonus_feat_for":["species-ewok"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Grant a bonus to allies' Fortitude Defense by foraging."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":2,"type":"untyped","predicates":["defense.fortitude"],"enabled":true,"priority":500,"description":"Ample Foraging"}]},"shortSummary":"Grant a bonus to allies' Fortitude Defense by foraging."},"effects":[{"_id":"a7c4a3cf-075d-4986-9273-6b3570e80a35","name":"Ample Foraging","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Ample Foraging","effectType":"skill_bonus","flagType":"Ample Foraging"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["defense.fortitude"],"id":"swse.feat.ample_foraging"}}}
{"_id":"225c535ebc74e54a","name":"Deft Charge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"After you Charge, you can take Swift Actions, Reactions, and Free Actions before your turn ends.","prerequisite":"None","special":"","normalText":"Without this Feat, Charging ends your turn immediately after the attack is resolved.","sourcebook":"Rebellion Era Campaign Guide","page":18,"tags":["action_economy","charge","feat","free_action","general","offense","offense_melee","reaction","swift_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Deft_Charge</p>\n<p>When you Charge, it is merely part of a larger attack pattern that you continue to execute.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>After you Charge, you can take Swift Actions, Reactions, and Free Actions before your turn ends.</p>\n<h4>Normal</h4>\n<p>Without this Feat, Charging ends your turn immediately after the attack is resolved.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Deft Charge"}]},"shortSummary":"Take Swift Actions, Reactions, and Free Actions after you Charge before your turn ends.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Deft_Charge"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.deft_charge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Deft_Charge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"22d0f64aa8ac99df","name":"Riflemaster","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make a ranged attack with a Rifle with which you are proficient, you gain one of the following benefits, depending on the kind of Rifle you use.\n\n- Blaster Carbine: You can Brace a Blaster Carbine set to Autofire, even though it is not an Autofire -only weapon.\n- Blaster Rifle: You treat the Blaster Rifle as an Accurate Weapon.\n- Heavy Blaster Rifle: When you use a Heavy Blaster Rifle, the damage dice increase from d10 to d12.\n- Light Repeating Blaster: You treat the Light Repeating Blaster as if it were Medium instead of Large.","prerequisite":"Weapon Proficiency (Rifles)","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["feat","general","offense_ranged","weapon_rifle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Riflemaster</p>\n<p>You are skilled in the use of Rifles and gain certain benefits depending on which weapon you use.</p>\n<p><strong>Prerequisites:</strong> Weapon Proficiency (Rifles)</p>\n<h4>Effect</h4>\n<p>When you make a ranged attack with a Rifle with which you are proficient, you gain one of the following benefits, depending on the kind of Rifle you use.</p>\n<ul><li><strong>Blaster Carbine:</strong> You can Brace a Blaster Carbine set to Autofire, even though it is not an Autofire -only weapon.</li><li><strong>Blaster Rifle:</strong> You treat the Blaster Rifle as an Accurate Weapon.</li><li><strong>Heavy Blaster Rifle:</strong> When you use a Heavy Blaster Rifle, the damage dice increase from d10 to d12.</li><li><strong>Light Repeating Blaster:</strong> You treat the Light Repeating Blaster as if it were Medium instead of Large.</li></ul>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Riflemaster"}]},"shortSummary":"Gain benefits when using certain Rifles.","prerequisitesText":"Weapon Proficiency (Rifles)","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Riflemaster"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.riflemaster","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Riflemaster","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2357f4a68fe571fb","name":"Sharp Senses","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Increase the die type when adding Force Points to a Perception check.","prerequisite":"Mon Calamari","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","feat","force_point_spend","racial","resource_spend","skill_perception","skill_synergy","species","species_opportunity","species_rule"],"bonus_feat_for":["species-mon-calamari"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Increase the die type when adding Force Points to a Perception check."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Sharp Senses: increase Force Point die type on Perception checks.","rules":[{"type":"FORCE_POINT_DIE_STEP","value":1,"domains":["skill"],"skills":["perception"],"description":"Increase the die type when adding Force Points to a Perception check."}]},"shortSummary":"Increase the die type when adding Force Points to a Perception check."},"effects":[{"_id":"73c8fbc0-142d-460e-ba02-c9455de3a848","name":"Sharp Senses","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Sharp Senses","effectType":"special","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.sharp_senses"}}}
{"_id":"252b67d6e31c377e","name":"Weapon Finesse","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using a Light Melee Weapon or a Lightsaber, you may use your Dexterity modifier instead of your Strength modifier on attack rolls.","prerequisite":"Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["ability_dexterity","ability_strength","accuracy","dexterity_synergy","feat","finesse","general","lightsaber","offense_melee"],"bonus_feat_for":["b5bed5d1b5f42958","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Weapon_Finesse</p>\n<p>You are especially skilled at using weapons that can benefit as much from Dexterity as Strength.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When using a Light Melee Weapon or a Lightsaber, you may use your Dexterity modifier instead of your Strength modifier on attack rolls.</p>\n<h4>Additional Weapon Finesse Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Weapon Focus): When you are wielding a single one-handed weapon for which you have Weapon Focus, you can treat that weapon as a Light Weapon.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-melee"],"enabled":true,"priority":500,"description":"Weapon Finesse"}]},"shortSummary":"Use Dexterity modifier instead of Strength modifier on attack rolls with Light Melee Weapons and Lightsabers.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Weapon_Finesse"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.with-melee"],"id":"swse.feat.weapon_finesse","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Weapon_Finesse","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"25aaf859b6109c02","name":"Predictive Defense","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use either your Dexterity modifier or your Intelligence modifier to determine your Reflex Defense.","prerequisite":"Intelligence 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["ability_dexterity","ability_intelligence","defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Predictive_Defense</p>\n<p>The sharpness of your mind, not the speed of your reactions, allows you to avoid incoming attacks.</p>\n<p><strong>Prerequisites:</strong> Intelligence 13</p>\n<h4>Effect</h4>\n<p>You can use either your Dexterity modifier or your Intelligence modifier to determine your Reflex Defense.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Predictive Defense"}]},"shortSummary":"Use Dexterity or Intelligence to determine Reflex Defense.","prerequisitesText":"Intelligence 13","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Predictive_Defense"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.predictive_defense","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Predictive_Defense","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"25ba21b021086a71","name":"Disturbing Presence","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you succeed on a DC 15 Deception check, you can move through the Threatened area or Fighting Space of an enemy as part of your move action without provoking an attack of opportunity. Each Threatened space or occupied space that you move through in this manner counts as 2 squares of movement.","prerequisite":"Trained in Deception","special":"","normalText":"You can Tumble through an occupied enemy square only by using the Acrobatics Skill.","sourcebook":"Galaxy of Intrigue","page":18,"tags":["feat","general","multi_target","skill_deception","skill_synergy","social"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Disturbing_Presence</p>\n<p>Your presence is such that enemies let you move past them freely.</p>\n<p><strong>Prerequisites:</strong> Trained in Deception</p>\n<h4>Effect</h4>\n<p>If you succeed on a DC 15 Deception check, you can move through the Threatened area or Fighting Space of an enemy as part of your move action without provoking an attack of opportunity. Each Threatened space or occupied space that you move through in this manner counts as 2 squares of movement.</p>\n<h4>Normal</h4>\n<p>You can Tumble through an occupied enemy square only by using the Acrobatics Skill.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Disturbing Presence"}]},"shortSummary":"Make a Deception check to move through a Threatened Area without provoking Attacks of Opportunity.","prerequisitesText":"Trained in Deception","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Disturbing_Presence"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.disturbing_presence","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Disturbing_Presence","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"25ce950a142f969d","name":"Adaptable Talent","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one Talent that you meet the prerequisites for, from a Class you possess. Once per day, after at least 6 hours of rest, you can choose to swap out one of your current Talents for the Talent you chose for this Feat. The Talent you swap out cannot be the prerequisite for any other Talent you have. You can swap back to your original Talent after at least 6 hours of rest.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":23,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Adaptable_Talent</p>\n<p>You&#x27;re a multitalented being, capable of pulling all kinds of tricks out of your sleeve.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Choose one Talent that you meet the prerequisites for, from a Class you possess. Once per day, after at least 6 hours of rest, you can choose to swap out one of your current Talents for the Talent you chose for this Feat. The Talent you swap out cannot be the prerequisite for any other Talent you have. You can swap back to your original Talent after at least 6 hours of rest.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Adaptable Talent"}]},"shortSummary":"Temporarily gain access to an additional Talent.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Adaptable_Talent"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.adaptable_talent","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Adaptable_Talent","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2624254a23604d5b","name":"Poison Resistance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +5 bonus to your Fortitude Defense when attacked by Poison. If the attack succeeds, you take only half damage.","prerequisite":"Constitution 13","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":28,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Poison_Resistance</p>\n<p>You are naturally more resistant to the effects of Poison.</p>\n<p><strong>Prerequisites:</strong> Constitution 13</p>\n<h4>Effect</h4>\n<p>You gain a +5 bonus to your Fortitude Defense when attacked by Poison. If the attack succeeds, you take only half damage.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"con","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Poison Resistance"}]},"shortSummary":"You are inherently more resistant to Poison.","prerequisitesText":"Constitution 13","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Poison_Resistance"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.poison_resistance","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Poison_Resistance","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2866d953b4b6245d","name":"Dive for Cover","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per turn, as a Reaction to being targeted by a ranged attack, you can make a Jump check to Long Jump. If you land in a square that provides you with Cover from your attacker, you gain the normal Cover bonus against the attack, even if you didn't have Cover at the time the attack was made. When you use this Feat, you always land Prone.","prerequisite":"Trained in Jump","special":"","normalText":"","sourcebook":"Galaxy at War","page":22,"tags":["cover_play","defense","feat","general","reaction","skill_jump","skill_synergy","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Dive_for_Cover</p>\n<p>You can leap behind cover, even when caught out in the open.</p>\n<p><strong>Prerequisites:</strong> Trained in Jump</p>\n<h4>Effect</h4>\n<p>Once per turn, as a Reaction to being targeted by a ranged attack, you can make a Jump check to Long Jump. If you land in a square that provides you with Cover from your attacker, you gain the normal Cover bonus against the attack, even if you didn&#x27;t have Cover at the time the attack was made. When you use this Feat, you always land Prone.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Dive for Cover"}]},"shortSummary":"Jump for Cover as a Reaction.","prerequisitesText":"Trained in Jump","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Dive_for_Cover"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.dive_for_cover","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Dive_for_Cover","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"289588197d691d64","name":"Advantageous Cover","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you have Cover, you take no damage from Area Attacks, even if the attack roll exceeds your Reflex Defense.","prerequisite":"Trained in Stealth","special":"","normalText":"You take no damage from Area Attacks when you have Cover only if the attack roll misses.","sourcebook":"The Force Unleashed Campaign Guide","page":32,"tags":["cover_play","defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Advantageous_Cover</p>\n<p>You know how to make the best use of available Cover as shelter from enemy attacks.</p>\n<p><strong>Prerequisites:</strong> Trained in Stealth</p>\n<h4>Effect</h4>\n<p>When you have Cover, you take no damage from Area Attacks, even if the attack roll exceeds your Reflex Defense.</p>\n<h4>Normal</h4>\n<p>You take no damage from Area Attacks when you have Cover only if the attack roll misses.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"6d2ac22d9fcf402f"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Advantageous Cover"}]},"shortSummary":"Gain additional benefits from Cover.","prerequisitesText":"Trained in Stealth","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Advantageous_Cover"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.advantageous_cover","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Advantageous_Cover","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"28a02f0e5412dd53","name":"Fortifying Recovery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you take the Recover Action, you also gain a number of Bonus Hit Points equal to 2 x your Constitution bonus (Minimum 2). Damage is subtracted from the Bonus Hit Points first, and any Bonus Hit Points remaining at the end of encounter are lost. Bonus Hit Points do not stack.","prerequisite":"Constitution 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":23,"tags":["cover_play","defense","durability","feat","general","hit_points","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Fortifying_Recovery</p>\n<p>Even as you reel from attacks, you can get yourself back into the fight and make a difference.</p>\n<p><strong>Prerequisites:</strong> Constitution 13</p>\n<h4>Effect</h4>\n<p>When you take the Recover Action, you also gain a number of Bonus Hit Points equal to 2 x your Constitution bonus (Minimum 2). Damage is subtracted from the Bonus Hit Points first, and any Bonus Hit Points remaining at the end of encounter are lost. Bonus Hit Points do not stack.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Fortifying Recovery"}]},"shortSummary":"Gain Bonus Hit Points when you Recover.","prerequisitesText":"Constitution 13","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Fortifying_Recovery"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.fortifying_recovery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fortifying_Recovery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"29173ea2d8416eea","name":"Flèche","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When Charging, turn any natural attack roll of 17+ into a Critical Hit.","prerequisite":"Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":19,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Fl%C3%A8che</p>\n<p>You throw yourself at your opponent to make a single precise strike.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Flèche"}]},"shortSummary":"When Charging, turn any natural attack roll of 17+ into a Critical Hit.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Fl%C3%A8che"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.fl_che","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fl%C3%A8che","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2942c0676644251b","name":"Tactical Advantage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully damage an opponent using an Attack of Opportunity, you can immediately move 1 square in any direction. This movement does not provoke Attacks of Opportunity.","prerequisite":"Combat Reflexes","special":"","normalText":"","sourcebook":"Scum and Villainy","page":29,"tags":["feat","general","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Tactical_Advantage</p>\n<p>You can shift your position to take advantage of openings your opponent offers you.</p>\n<p><strong>Prerequisites:</strong> Combat Reflexes</p>\n<h4>Effect</h4>\n<p>When you successfully damage an opponent using an Attack of Opportunity, you can immediately move 1 square in any direction. This movement does not provoke Attacks of Opportunity.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Tactical Advantage"}]},"shortSummary":"Make Attack of Opportunity and move 1 square.","prerequisitesText":"Combat Reflexes","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Tactical_Advantage"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.tactical_advantage","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Tactical_Advantage","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2956acfbfd27967d","name":"Hideous Visage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, as a Swift Action, you can make a Deception check against one opponent that can see you. If the check equals or exceeds the opponent's Will Defense, you move the target 1 square away from you and it takes a -1 penalty on all attacks until the start of your next turn. This is a Mind-Affecting Fear effect.","prerequisite":"Shapeshift Species Trait","special":"","normalText":"","sourcebook":"Scum and Villainy","page":24,"tags":["feat","general","skill_deception","skill_synergy"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Hideous_Visage</p>\n<p>You can twist your features into a startling mask.</p>\n<p><strong>Prerequisites:</strong> Shapeshift Species Trait</p>\n<h4>Effect</h4>\n<p>Once per encounter, as a Swift Action, you can make a Deception check against one opponent that can see you. If the check equals or exceeds the opponent&#x27;s Will Defense, you move the target 1 square away from you and it takes a -1 penalty on all attacks until the start of your next turn. This is a Mind-Affecting Fear effect.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Hideous Visage"}]},"shortSummary":"Deception check to push opponent away.","prerequisitesText":"Shapeshift Species Trait","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Hideous_Visage"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.hideous_visage","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Hideous_Visage","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2bad688298402481","name":"Improved Stun","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +5 bonus on attack rolls made to stun an opponent.","prerequisite":"Int 13, Stun","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["control","feat","general"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Improved Stun"}]},"shortSummary":"You gain a +5 bonus on attack rolls made to stun an opponent."},"effects":[{"_id":"b7c4dc5d-6ade-4f1c-a95d-1657c43260f6","name":"Improved Stun","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Improved Stun","effectType":"combat_bonus","flagType":"Improved Stun"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[]}}}
{"_id":"2bb34366776f0371","name":"Cut the Red Tape","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use your Knowledge (Bureaucracy) modifier instead of your Gather Information modifier when making Gather Information checks. If you are entitled to a Gather Information check reroll, you can reroll your Knowledge (Bureaucracy) check instead (subject to the same circumstances and limitations). You are considered Trained in the Gather Information skill for the purposes of this check.","prerequisite":"Trained in Knowledge (Bureaucracy)","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":17,"tags":["feat","general","skill_gather_information","skill_knowledge","skill_synergy","social","skill_use_substitution","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Cut_the_Red_Tape</p>\n<p>You know how to work the bureaucratic system to get information you need.</p>\n<p><strong>Prerequisites:</strong> Trained in Knowledge (Bureaucracy)</p>\n<h4>Effect</h4>\n<p>You can use your Knowledge (Bureaucracy) modifier instead of your Gather Information modifier when making Gather Information checks. If you are entitled to a Gather Information check reroll, you can reroll your Knowledge (Bureaucracy) check instead (subject to the same circumstances and limitations). You are considered Trained in the Gather Information skill for the purposes of this check.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_use_substitution_phase8","description":"Cut the Red Tape: Gather Information skill uses may be rolled with Knowledge (Bureaucracy).","skillUseSubstitutions":[{"id":"cut-the-red-tape-gather-information-with-bureaucracy","fromSkill":"gatherInformation","toSkill":"knowledgeBureaucracy","applications":["Gather Information","Quick Intel","Find Black Market Object","Analysis"],"description":"Use Knowledge (Bureaucracy) for Gather Information skill uses."}]},"shortSummary":"Use Knowledge (Bureaucracy) in place of Gather Information.","prerequisitesText":"Trained in Knowledge (Bureaucracy)","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Cut_the_Red_Tape"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.cut_the_red_tape","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Cut_the_Red_Tape","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2bdb31b248f680e3","name":"Republic Military Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, as a Reaction, you gain Damage Reduction 10 against an incoming attack if you have Cover from the attacker. You can gain the Damage Reduction as long as you have Cover, even if your opponent uses Aim to ignore your Cover bonus to Reflex Defense.","prerequisite":"None","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":29,"tags":["background_opportunity","cover_play","faction_training","feat","general","military","species_opportunity"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Republic_Military_Training</p>\n<p>You are trained in Republic military fighting techniques, giving you an advantage in ranged combat. This training is generally given to members of the Republic military forces.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Once per encounter, as a Reaction, you gain Damage Reduction 10 against an incoming attack if you have Cover from the attacker. You can gain the Damage Reduction as long as you have Cover, even if your opponent uses Aim to ignore your Cover bonus to Reflex Defense.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Republic Military Training"}]},"shortSummary":"When behind Cover, you can reduce the damage of an incoming attack.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Republic_Military_Training"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.republic_military_training","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Republic_Military_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2cc20fb67232f92f","name":"Skill Challenge: Catastrophic Avoidance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Catastrophic Failures in a Skill Challenge occur less frequently, and with milder results.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":25,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Catastrophic Failures in a Skill Challenge occur less frequently, and with milder results."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Skill Challenge: Catastrophic Avoidance"}]},"shortSummary":"Catastrophic Failures in a Skill Challenge occur less frequently, and with milder results."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.skill_challenge_catastrophic_avoidance"}}}
{"_id":"2d680cc46a7972da","name":"Weapon Proficiency (Simple Weapons)","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You are proficient with simple weapons and do not take the -5 penalty when using them.","prerequisite":"","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["build_enabler","feat","general","offense","weapon_access","mapped_phase_1","unlock_grant","choice_variant"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958","21dfe84d159a1b7f","8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"UNLOCK","abilityMeta":{"grants":[{"category":"PROFICIENCY","proficiencyType":"weapon","proficiencies":["simple"],"description":"Weapon proficiency: simple"}]},"choiceMeta":{"resolution":"already_resolved_static_variant","required":false,"choiceKind":"weapon_proficiency","value":"simple","grants":["simple"]},"shortSummary":"You are proficient with simple weapons and do not take the -5 penalty when using them."},"effects":[{"_id":"220daaa7-e1b5-440d-98cd-10f5e586ef8b","name":"Weapon Proficiency (Simple Weapons)","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Weapon Proficiency (Simple Weapons)","effectType":"passive_effect","flagType":"Weapon Proficiency (Simple Weapons)"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"phase1Mapped":true,"manualMappingResolved":true}}}
{"_id":"2def724bf673c2fc","name":"Impersonate","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can make a Deception check to alter your features to that of a specific person. This Feat also allows you to change your voice to match the target's. You always treat impersonating a person as a Moderate Deception.","prerequisite":"Shapeshift Species Trait, Skill Focus (Deception)","special":"","normalText":"","sourcebook":"Scum and Villainy","page":24,"tags":["feat","general","social"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Impersonate</p>\n<p>You can alter your appearance to resemble a specific person.</p>\n<p><strong>Prerequisites:</strong> Shapeshift Species Trait, Skill Focus (Deception)</p>\n<h4>Effect</h4>\n<p>You can make a Deception check to alter your features to that of a specific person. This Feat also allows you to change your voice to match the target&#x27;s. You always treat impersonating a person as a Moderate Deception.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Impersonate"}]},"shortSummary":"Shapeshift to impersonate a specific person.","prerequisitesText":"Shapeshift Species Trait, Skill Focus (Deception)","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Impersonate"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.impersonate","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Impersonate","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2e5ada2de01fff4d","name":"Dreadful Countenance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you make a Persuasion check or a Use the Force check to activate a Fear effect, you may reroll the check, but the result of the reroll must be accepted, even if it is worse.","prerequisite":"Charisma 13, Member of The Sith","special":"","normalText":"","sourcebook":"Web Enhancements","page":1,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Web Enhancements (Behind the Threat: The Sith)</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Dreadful_Countenance</p>\n<p>Marked as Sith, your appearance inspires awe, dread, and fear in all who view it.</p>\n<p><strong>Prerequisites:</strong> Charisma 13, Member of The Sith</p>\n<h4>Effect</h4>\n<p>Whenever you make a Persuasion check or a Use the Force check to activate a Fear effect, you may reroll the check, but the result of the reroll must be accepted, even if it is worse.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Dreadful Countenance"}]},"shortSummary":"Marked as Sith, your appearance inspires awe, dread, and fear in all who view it.","prerequisitesText":"Charisma 13, Member of The Sith","referenceBooks":["Star Wars Saga Edition Web Enhancements (Behind the Threat: The Sith)"],"sourceUrl":"https://swse.fandom.com/wiki/Dreadful_Countenance"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.dreadful_countenance","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Dreadful_Countenance","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2eb0c304d99ef6ee","name":"Hold Together","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Reaction, you can spend a Force Point to delay the effect of damage dealt to a Vehicle you are riding in or piloting until the end of the round. The Vehicle must be of Colossal size or smaller.","prerequisite":"Trained in Mechanics","special":"","normalText":"","sourcebook":"Unknown Regions","page":22,"tags":["feat","general","vehicle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Hold_Together</p>\n<p>Sometimes Vehicles seem to hold together by your force of will.</p>\n<p><strong>Prerequisites:</strong> Trained in Mechanics</p>\n<h4>Effect</h4>\n<p>As a Reaction, you can spend a Force Point to delay the effect of damage dealt to a Vehicle you are riding in or piloting until the end of the round. The Vehicle must be of Colossal size or smaller.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Hold Together"}]},"shortSummary":"Delay the damage caused to a Vehicle until the end of the round.","prerequisitesText":"Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Hold_Together"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.hold_together","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Hold_Together","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"2ed1a3257175feb9","name":"Wroshyr Rage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain Bonus Hit Points when Raging.","prerequisite":"Wookiee","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["durability","execution_mapped_phase9","feat","hit_points","offense_melee","racial","rage","resource_spend","species","species_opportunity"],"bonus_feat_for":["species-wookiee"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain Bonus Hit Points when Raging."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rage_rule_phase9_needs_amount","description":"Wroshyr Rage is identified as a Rage bonus-hit-point hook. The pack text does not include the numeric amount, so this is tagged but not auto-applied.","rules":[{"type":"RAGE_BONUS_HIT_POINTS","status":"needs_formula","description":"Gain bonus Hit Points when Raging. Numeric amount must be supplied before automation."}]},"shortSummary":"Gain Bonus Hit Points when Raging."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.wroshyr_rage"}}}
{"_id":"2f2fa438a6fb54a0","name":"Triple Crit Specialist","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you score a critical hit with the selected weapon group, you deal triple damage and move the target -1 step down the condition track.","prerequisite":"Triple Crit, Weapon Specialization with selected weapon group","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["control","feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Triple Crit Specialist"}]},"shortSummary":"When you score a critical hit with the selected weapon group, you deal triple damage and move the target -1 step down the condition track."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.when-hit"]}}}
{"_id":"3036290329d5b3e6","name":"Shake It Off","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can spend two Swift Actions instead of three to move +1 step along the Condition Track.","prerequisite":"Constitution 13, Trained in Endurance","special":"","normalText":"It takes three Swift Actions to move +1 step up along the Condition Track.","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["action_economy","condition_track","feat","general","swift_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Shake_It_Off</p>\n<p>You have learned to shake off debilitating conditions.</p>\n<p><strong>Prerequisites:</strong> Constitution 13, Trained in Endurance</p>\n<h4>Effect</h4>\n<p>You can spend two Swift Actions instead of three to move +1 step along the Condition Track.</p>\n<h4>Normal</h4>\n<p>It takes three Swift Actions to move +1 step up along the Condition Track.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"con","min":13},{"type":"skillTrained","skill":"35df8faa4878f2c5"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Shake It Off"}]},"resourceRules":{"conditionTrack":[{"type":"SWIFT_ACTION_CONDITION_RECOVERY","swiftActionCost":2}]},"shortSummary":"Spend two Swift Actions to move +1 step along the Condition Track.","prerequisitesText":"Constitution 13, Trained in Endurance","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Shake_It_Off"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.shake_it_off","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Shake_It_Off","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"30cb2abcd11bf1bd","name":"Relentless Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one weapon group or Exotic Weapon for which you have the Double Attack Feat. Whenever you miss a target with that weapon, you gain a +2 competence bonus on your next attack roll made before the end of your next turn against the missed target.","prerequisite":"Double Attack (Chosen Weapon)","special":"You can select this Feat multiple times. Each time you select this Feat, it applies to a different weapon group or Exotic Weapon.","normalText":"","sourcebook":"Jedi Academy Training Manual","page":30,"tags":["feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Jedi Academy Training Manual</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Relentless_Attack</p>\n<p>You ensure the demise of your foe by turning misses into opportunities.</p>\n<p><strong>Prerequisites:</strong> Double Attack (Chosen Weapon)</p>\n<h4>Effect</h4>\n<p>Choose one weapon group or Exotic Weapon for which you have the Double Attack Feat. Whenever you miss a target with that weapon, you gain a +2 competence bonus on your next attack roll made before the end of your next turn against the missed target.</p>\n<h4>Special</h4>\n<p>You can select this Feat multiple times. Each time you select this Feat, it applies to a different weapon group or Exotic Weapon.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Relentless Attack"}]},"shortSummary":"Gain a bonus on attack rolls after missing a target.","prerequisitesText":"Double Attack (Chosen Weapon)","referenceBooks":["Star Wars Saga Edition Jedi Academy Training Manual"],"sourceUrl":"https://swse.fandom.com/wiki/Relentless_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.relentless_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Relentless_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"313095ada7504547","name":"Signature Device","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You designate a single weapon, suit of armor, vehicle, or other item as your Signature Item. When making Mechanics checks to modify that piece of Equipment, you can Take 10 on the check. In addition, you can allow the device to gain two Traits from the Tech Specialist feat.\n\nTo install the second Trait, you must succeed on a DC 30 Mechanics check. Once installed, the device can use only one Trait at a time, and switching from one Trait to the other requires a Swift Action to adjust the item's settings.\n\nYou can have only one Signature Device at a time, but you can designate another device as your Signature Item (the former item loses all benefits gained from this Feat).","prerequisite":"Tech Specialist","special":"","normalText":"","sourcebook":"Scum and Villainy","page":28,"tags":["feat","general","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Signature_Device</p>\n<p>You specialize in designing and modifying specific types of technology.</p>\n<p><strong>Prerequisites:</strong> Tech Specialist</p>\n<h4>Effect</h4>\n<p>You designate a single weapon, suit of armor, vehicle, or other item as your Signature Item. When making Mechanics checks to modify that piece of Equipment, you can Take 10 on the check. In addition, you can allow the device to gain two Traits from the Tech Specialist feat.</p>\n<p>To install the second Trait, you must succeed on a DC 30 Mechanics check. Once installed, the device can use only one Trait at a time, and switching from one Trait to the other requires a Swift Action to adjust the item&#x27;s settings.</p>\n<p>You can have only one Signature Device at a time, but you can designate another device as your Signature Item (the former item loses all benefits gained from this Feat).</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Signature Device"}]},"shortSummary":"Install two Traits.","prerequisitesText":"Tech Specialist","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Signature_Device"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":[],"id":"swse.feat.signature_device","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Signature_Device","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"32ab40ebbd9bbc16","name":"Spring Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making a melee attack, you may move both before and after the attack, up to your speed, without provoking attacks of opportunity from the target.","prerequisite":"Dex 13, Mobility","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","hit_and_run","mobility","move_action","offense","offense_melee","standard_action"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-melee"],"enabled":true,"priority":500,"description":"Spring Attack"}]},"shortSummary":"When making a melee attack, you may move both before and after the attack, up to your speed, without provoking attacks of opportunity from the target."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.with-melee"]}}}
{"_id":"32d1cd4b09ec0d3b","name":"Cleave","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you deal an opponent enough damage to reduce its hit points to 0, you get an immediate extra melee attack against another opponent within your reach. The extra attack is with the same weapon and at the same attack bonus as the attack that dropped the previous opponent. You can use this ability once per round.","prerequisite":"Strength 13, Power Attack Feat","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":85,"tags":["control","feat","general","grapple","offense","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Cleave</p>\n<p>You can follow through with a powerful melee attack.</p>\n<p><strong>Prerequisites:</strong> Strength 13, Power Attack Feat</p>\n<h4>Effect</h4>\n<p>If you deal an opponent enough damage to reduce its hit points to 0, you get an immediate extra melee attack against another opponent within your reach. The extra attack is with the same weapon and at the same attack bonus as the attack that dropped the previous opponent. You can use this ability once per round.</p>\n<h4>Additional Cleave Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Follow Through): If you have the Follow Through Feat, you can move up to your speed before making the extra melee attack granted by the Cleave Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-melee"],"enabled":true,"priority":500,"description":"Cleave"}]},"shortSummary":"Extra melee attack after dropping target.","prerequisitesText":"Strength 13, Power Attack Feat","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Cleave"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.380Z","detectedPredicates":["attack.with-melee"],"id":"swse.feat.cleave","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Cleave","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"33905755bbb1ca10","name":"Binary Mind","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Enemies must roll twice, keeping the lower result, on Mind-Affecting effects.","prerequisite":"Cerean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["control","feat","grapple","racial","species","species_opportunity"],"bonus_feat_for":["species-cerean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Enemies must roll twice, keeping the lower result, on Mind-Affecting effects."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Binary Mind"}]},"shortSummary":"Enemies must roll twice, keeping the lower result, on Mind-Affecting effects."},"effects":[{"_id":"fa4ac368-0913-4d84-9920-9918a8564b1a","name":"Binary Mind","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Binary Mind","effectType":"mind_resistance","flagType":"binaryMindProtection"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.binary_mind"}}}
{"_id":"34071c4705615ce8","name":"Moving Target","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you end your turn at least 3 squares away from where you started, you gain a +1 dodge bonus to your Reflex Defense until the start of your next turn.","prerequisite":"Dodge","special":"","normalText":"","sourcebook":"Rebellion Era Campaign Guide","page":20,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Moving_Target</p>\n<p>You know how to stay mobile, making it harder for your enemies to hit you with their attacks.</p>\n<p><strong>Prerequisites:</strong> Dodge</p>\n<h4>Effect</h4>\n<p>If you end your turn at least 3 squares away from where you started, you gain a +1 dodge bonus to your Reflex Defense until the start of your next turn.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Moving Target"}]},"shortSummary":"Gain a bonus to Reflex Defense when you remain mobile.","prerequisitesText":"Dodge","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Moving_Target"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.moving_target","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Moving_Target","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"34bc0c5808778bf5","name":"Improved Bantha Rush","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making a Bantha Rush, you push your opponent a number of additional squares away from you equal to half your Strength modifier (Round down, minimum 2 squares pushed total).","prerequisite":"Strength 15, Bantha Rush, Base Attack Bonus +1","special":"","normalText":"When using Bantha Rush, you normally push your opponent only 1 square away from you.","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["ability_strength","feat","general","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Improved_Bantha_Rush</p>\n<p>When using the Bantha Rush Feat, you push your opponent additional squares away from you.</p>\n<p><strong>Prerequisites:</strong> Strength 15, Bantha Rush, Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When making a Bantha Rush, you push your opponent a number of additional squares away from you equal to half your Strength modifier (Round down, minimum 2 squares pushed total).</p>\n<h4>Normal</h4>\n<p>When using Bantha Rush, you normally push your opponent only 1 square away from you.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":15}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Improved Bantha Rush"}]},"shortSummary":"Push foes away a number of squares equal to Strength modifier.","prerequisitesText":"Strength 15, Bantha Rush, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Improved_Bantha_Rush"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.improved_bantha_rush","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improved_Bantha_Rush","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"357807a5ceb77203","name":"Double Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose a single Exotic Weapon or weapon group with which you are proficient. When you use the Full Attack action, you may make one additional attack when wielding such a weapon. However, you take a -5 penalty on all attack rolls until your next turn because you're trading precision for speed.","prerequisite":"Base Attack Bonus +6","special":"You may select this Feat multiple times. Each time you select this Feat, it applies to a different Exotic Weapon or weapon group. If you take this Feat with Heavy Weapons, it also applies with Vehicle Weapons.","normalText":"Making a single attack is a Standard Action.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general","offense"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Double_Attack</p>\n<p>You can make an additional attack during a round of combat.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +6</p>\n<h4>Effect</h4>\n<p>Choose a single Exotic Weapon or weapon group with which you are proficient. When you use the Full Attack action, you may make one additional attack when wielding such a weapon. However, you take a -5 penalty on all attack rolls until your next turn because you&#x27;re trading precision for speed.</p>\n<h4>Normal</h4>\n<p>Making a single attack is a Standard Action.</p>\n<h4>Special</h4>\n<p>You may select this Feat multiple times. Each time you select this Feat, it applies to a different Exotic Weapon or weapon group. If you take this Feat with Heavy Weapons, it also applies with Vehicle Weapons.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":6}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.on-current-turn"],"enabled":true,"priority":500,"description":"Double Attack"}]},"shortSummary":"Make an extra attack with chosen weapon during Full Attack, -5 penalty to all attacks.","prerequisitesText":"Base Attack Bonus +6","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Double_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["turn.on-current-turn"],"id":"swse.feat.double_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Double_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"3595086bb17d4303","name":"Justice Seeker","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to damage rolls against those who harm your allies.","prerequisite":"Kel Dor","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","racial","species","species_opportunity"],"bonus_feat_for":["species-kel-dor"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to damage rolls against those who harm your allies."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Justice Seeker"}]},"shortSummary":"Gain a bonus to damage rolls against those who harm your allies."},"effects":[{"_id":"4d14d994-e1db-4d72-ae3f-0bcd3fa34575","name":"Justice Seeker","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Justice Seeker","effectType":"combat_bonus","flagType":"Justice Seeker"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.justice_seeker"}}}
{"_id":"376d805d1b73f7e6","name":"Starship Tactics","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You add to your Starship Maneuver Suite a number of Starship Maneuvers equal to 1 + your Wisdom modifier (minimum 1). You can add the same Starship Maneuver more than once.","prerequisite":"Vehicular Combat, Trained in Pilot","special":"You can take this Feat more than once. Each time you take this Feat, you add to your Starship Maneuver Suite a number of new Starship Maneuvers equal to 1 + your Wisdom modifier (minimum 1). A character with the Gunnery Specialist Feat can take this Feat without meeting the other requirements but if they do not possess the other requirements they can only select [Gunner ] Starship Maneuvers when they select this Feat.","normalText":"","sourcebook":"Starships of the Galaxy","page":30,"tags":["feat","general","skill_pilot","vehicle","choice_required","grant_choice","deferred_choice","choice_source_grant_pool"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Starship_Tactics</p>\n<p>You are trained to make use of Starship Maneuvers and are skilled at space combat.</p>\n<p><strong>Prerequisites:</strong> Vehicular Combat, Trained in Pilot</p>\n<h4>Effect</h4>\n<p>You add to your Starship Maneuver Suite a number of Starship Maneuvers equal to 1 + your Wisdom modifier (minimum 1). You can add the same Starship Maneuver more than once.</p>\n<h4>Special</h4>\n<p>You can take this Feat more than once. Each time you take this Feat, you add to your Starship Maneuver Suite a number of new Starship Maneuvers equal to 1 + your Wisdom modifier (minimum 1). A character with the Gunnery Specialist Feat can take this Feat without meeting the other requirements but if they do not possess the other requirements they can only select [Gunner ] Starship Maneuvers when they select this Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Starship Tactics"}]},"choiceMeta":{"resolution":"grant_entitlement","required":true,"status":"deferred_grant_step_not_immediate_choice","choiceKind":"starship_maneuver_pick","storagePath":"flags.swse.pendingEntitlements.starship_maneuver_pick","choiceSource":"grantPool","grantType":"starship_maneuver","grantRegistry":"starshipManeuver","countFormula":"max(1, 1 + wisdomModifier)","optionRegistry":"data/feat-choice-options.json#choiceKinds.starship_maneuver_pick","ability":"wis","minimum":1,"dynamic":true,"repeatable":true},"shortSummary":"You are trained to make use of Starship Maneuvers and are skilled at space combat.","prerequisitesText":"Vehicular Combat, Trained in Pilot","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Starship_Tactics"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.starship_tactics","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Starship_Tactics","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"37aa58a3833bf34a","name":"Bad Feeling","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can always take a Move Action during a Surprise Round, even if you are Surprised. If you are not Surprised, you can take this Move Action in addition to any other Actions you are normally allowed to take in the Surprise Round.","prerequisite":"None","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":32,"tags":["action_economy","feat","general","move_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Bad_Feeling</p>\n<p>You have developed an innate ability to sense when things are going badly, and thus can prepare yourself for the worst.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You can always take a Move Action during a Surprise Round, even if you are Surprised. If you are not Surprised, you can take this Move Action in addition to any other Actions you are normally allowed to take in the Surprise Round.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Bad Feeling"}]},"shortSummary":"Always have a Move Action during the Surprise Round.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Bad_Feeling"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.bad_feeling","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Bad_Feeling","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"37cb4455a70876ad","name":"Forceful Saber Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Use the Force checks made to activate Saber Throw.","prerequisite":"Trained in Use the Force, Saber Throw","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","force","offense","offense_melee"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Forceful Saber Throw"}]},"shortSummary":"You gain a +2 bonus on Use the Force checks made to activate Saber Throw."},"effects":[{"_id":"a4d4bea4-b709-4277-b831-4968e0570216","name":"Forceful Saber Throw","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Forceful Saber Throw","effectType":"skill_bonus","flagType":"Forceful Saber Throw"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[]}}}
{"_id":"3a847230d573a623","name":"Melee Defense","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you use a Standard Action to make a melee attack, you can take a penalty of up to -5 on your attack roll and add the same number (up to +5) as a dodge bonus to your Reflex Defense. This number may not exceed your Base Attack Bonus. The changes to attack rolls and Reflex Defense last until the start of your next turn.","prerequisite":"Intelligence 13","special":"","normalText":"A character without the Melee Defense Feat can Fight Defensively while using the attack action to take a -5 penalty on his attack roll and gain a +2 dodge bonus to his Reflex Defense.","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["defense","feat","general","melee_defense","offense_melee","survivability"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Melee_Defense</p>\n<p>You are trained at using your combat ability for defense as well as offense.</p>\n<p><strong>Prerequisites:</strong> Intelligence 13</p>\n<h4>Effect</h4>\n<p>When you use a Standard Action to make a melee attack, you can take a penalty of up to -5 on your attack roll and add the same number (up to +5) as a dodge bonus to your Reflex Defense. This number may not exceed your Base Attack Bonus. The changes to attack rolls and Reflex Defense last until the start of your next turn.</p>\n<h4>Normal</h4>\n<p>A character without the Melee Defense Feat can Fight Defensively while using the attack action to take a -5 penalty on his attack roll and gain a +2 dodge bonus to his Reflex Defense.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"int","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","abilityMeta":{"conditions":[{"type":"WEAPON_CATEGORY","value":"MELEE"}],"status":"attack_option_phase7","description":"Melee Defense: attack option exposed through CombatOptionResolver; not applied automatically.","rules":[{"type":"ATTACK_OPTION","option":"meleeDefense","label":"Melee Defense","control":"slider","max":5,"resource":"baseAttackBonus","requiresAttackType":"melee","attackModifierFormula":"-value","defenseModifier":{"target":"defense.reflex","type":"dodge","valueFormula":"value","duration":"untilStartOfNextTurn"},"summary":"Trade attack bonus for a dodge bonus to Reflex Defense until your next turn."}]},"subType":"STATE","shortSummary":"Trade attack bonus on melee attacks for a dodge bonus to Reflex Defense.","prerequisitesText":"Intelligence 13","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Melee_Defense"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["defense.against-melee","defense.reflex","attack.with-melee"],"id":"swse.feat.melee_defense","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Melee_Defense","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"3b1c70b0f6844126","name":"Noble Fencing Style","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When wielding a weapon with Weapon Finesse, you may use your Charisma modifier instead of Strength for attack rolls.","prerequisite":"Weapon Finesse, Noble level 1","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Noble Fencing Style"}]},"shortSummary":"When wielding a weapon with Weapon Finesse, you may use your Charisma modifier instead of Strength for attack rolls."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[]}}}
{"_id":"3b9b60551a3379ce","name":"Gearhead","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you can make Mechanics and Use Computer checks more quickly than normal. A check requiring a Full-Round Action can be attempted as a Standard Action, a check requiring a Standard Action can be attempted as a Move Action, and a check requiring a Move Action can be attempted as a Swift Action. Checks requiring multiple Swift Actions can be reduced by one Swift Action. Checks requiring more than a Full-Round Action can be attempted in one-half the amount of time required at a -10 penalty.","prerequisite":"None","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":26,"tags":["feat","general","skill_mechanics","skill_synergy","skill_use_computer"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Gearhead</p>\n<p>You are naturally talented with machines and electronics.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Once per encounter, you can make Mechanics and Use Computer checks more quickly than normal. A check requiring a Full-Round Action can be attempted as a Standard Action, a check requiring a Standard Action can be attempted as a Move Action, and a check requiring a Move Action can be attempted as a Swift Action. Checks requiring multiple Swift Actions can be reduced by one Swift Action. Checks requiring more than a Full-Round Action can be attempted in one-half the amount of time required at a -10 penalty.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Gearhead"}]},"shortSummary":"Make Mechanics and Use Computer checks quickly.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Gearhead"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.gearhead","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Gearhead","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"3ca2ebe34da486a5","name":"Greater Weapon Specialization","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on damage rolls with the selected weapon group. This stacks with Weapon Specialization.","prerequisite":"Weapon Specialization with selected weapon group, base attack bonus +12","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["damage_scaling","feat","general","weapon_mastery","choice_required","immediate_choice","weapon_choice","choice_source_prerequisite"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"damage.weapon","value":2,"type":"untyped","enabled":true,"priority":500,"description":"Greater Weapon Specialization: +2 damage with selected Weapon Specialization target","predicates":["attack.weapon-matches-selected-choice"]}]},"choiceMeta":{"resolution":"immediate","required":true,"status":"execution_mapped_phase6","choiceKind":"greater_weapon_specialization","repeatable":true,"optionRegistry":"data/feat-choice-options.json#choiceKinds.greater_weapon_specialization","storagePath":"flags.swse.choices.greater_weapon_specialization","choiceSource":"prerequisiteDerived","derivesFrom":["weapon_specialization"],"consumes":"weapon_specialization","provides":"greater_weapon_specialization","effectTarget":"damage.weapon","effectValue":2},"shortSummary":"You gain a +2 bonus on damage rolls with the selected weapon group."},"effects":[{"_id":"2609e320-82ca-4f97-bbc1-4e5e2b1dbcb9","name":"Greater Weapon Specialization","icon":"icons/svg/upgrade.svg","changes":[],"disabled":true,"duration":{},"flags":{"swse":{"source":"feat","featName":"Greater Weapon Specialization","effectType":"combat_bonus","flagType":"Greater Weapon Specialization","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"requiresImmediateChoice":true}}}
{"_id":"3cd647b126f1d171","name":"Reactive Stealth","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you may reroll a Stealth check and take the better result.","prerequisite":"Trained in Stealth","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["feat","general","skill_stealth","skill_synergy","stealth"],"bonus_feat_for":["21dfe84d159a1b7f","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8_implemented","description":"Reactive Stealth: reroll Stealth checks once per encounter and keep the better result.","skillRerolls":[{"id":"reactive-stealth","skillKeys":["stealth"],"outcome":"keepBetter","oncePer":"encounter","label":"Reactive Stealth","description":"Reactive Stealth: reroll Stealth checks once per encounter and keep the better result."}]},"shortSummary":"Once per encounter, you may reroll a Stealth check and take the better result."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["turn.once-per-round"]}}}
{"_id":"3d4a4e93ced26712","name":"Triple Crit","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one Weapon with which you are proficient. When you score a Critical Hit with the selected weapon, you deal triple damage. You may select \" Unarmed Attack \" as a Weapon for purposes of this Feat.","prerequisite":"Base Attack Bonus +8","special":"You can gain this Feat multiple times. The effects do not stack. Each time you take this Feat, it applies to a different Weapon. It's possible to take Triple Crit with a specific Vehicle Weapon.","normalText":"A Critical Hit normally deals double damage to the target.","sourcebook":"Galaxy at War","page":27,"tags":["control","feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Triple_Crit</p>\n<p>Choose one type of Weapon, such as a Blaster Pistol, Vibrodagger, or Lightsaber. You deal more damage on a Critical Hit with that Weapon.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +8</p>\n<h4>Effect</h4>\n<p>Choose one Weapon with which you are proficient. When you score a Critical Hit with the selected weapon, you deal triple damage. You may select &quot; Unarmed Attack &quot; as a Weapon for purposes of this Feat.</p>\n<h4>Normal</h4>\n<p>A Critical Hit normally deals double damage to the target.</p>\n<h4>Special</h4>\n<p>You can gain this Feat multiple times. The effects do not stack. Each time you take this Feat, it applies to a different Weapon. It&#x27;s possible to take Triple Crit with a specific Vehicle Weapon.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":8}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Triple Crit"}]},"shortSummary":"Deal triple damage on a Critical Hit.","prerequisitesText":"Base Attack Bonus +8","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Triple_Crit"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.triple_crit","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Triple_Crit","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"3eed0b4f1227cf91","name":"Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you successfully Trip an opponent with a Grapple attack, the opponent falls Prone in any unoccupied space you desire up to 1 square beyond your reach and take bludgeoning damage equal to your Unarmed attack damage. A Thrown opponent is no longer considered Grappled.","prerequisite":"Trip, Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["control","feat","general","grapple","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Throw</p>\n<p>You can Throw a creature that you&#x27;ve Grappled.</p>\n<p><strong>Prerequisites:</strong> Trip, Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>If you successfully Trip an opponent with a Grapple attack, the opponent falls Prone in any unoccupied space you desire up to 1 square beyond your reach and take bludgeoning damage equal to your Unarmed attack damage. A Thrown opponent is no longer considered Grappled.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Throw"}]},"shortSummary":"Throw a Grappled opponent up to 1 square beyond your reach and deal damage.","prerequisitesText":"Trip, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Throw"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.throw","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Throw","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"3f2e1b77ef19e244","name":"Mobile Fighting","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You may move up to your speed when using the withdraw action, and you gain a +2 bonus to Reflex Defense against attacks of opportunity provoked by movement.","prerequisite":"Dex 13, Dodge","special":"","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["feat","general"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.reflex","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Mobile Fighting"}]},"shortSummary":"You may move up to your speed when using the withdraw action, and you gain a +2 bonus to Reflex Defense against attacks of opportunity provoked by movement."},"effects":[{"name":"Mobile Fighting (vs AoO)","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.reflex.misc","mode":2,"value":"2","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"feat-conditional-defense","source":"Mobile Fighting","defenseType":"reflex","condition":"vs attacks of opportunity","toggleable":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["defense.reflex"]}}}
{"_id":"3f76464c43c73f84","name":"Power Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"On your turn, before making an attack roll, you may choose to subtract a number from all melee attack rolls and add the same number to all melee damage rolls. This number may not exceed your Base Attack Bonus. The penalty on attacks and bonus on damage rolls applies until the start of your next turn.","prerequisite":"Strength 13","special":"If you attack with a two-handed weapon, or with a one-handed weapon wielded in two hands, instead add twice the number subtracted from your attack rolls to your damage rolls. You can't add the bonus from Power Attack to the damage dealt against an object or Vehicle.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["damage_scaling","feat","feat_chain","general","offense","offense_melee","prereq_gateway","standard_action","strength_synergy"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Power_Attack</p>\n<p>You can make exceptionally powerful melee attacks.</p>\n<p><strong>Prerequisites:</strong> Strength 13</p>\n<h4>Effect</h4>\n<p>On your turn, before making an attack roll, you may choose to subtract a number from all melee attack rolls and add the same number to all melee damage rolls. This number may not exceed your Base Attack Bonus. The penalty on attacks and bonus on damage rolls applies until the start of your next turn.</p>\n<h4>Special</h4>\n<p>If you attack with a two-handed weapon, or with a one-handed weapon wielded in two hands, instead add twice the number subtracted from your attack rolls to your damage rolls. You can&#x27;t add the bonus from Power Attack to the damage dealt against an object or Vehicle.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","abilityMeta":{"status":"attack_option_phase7","description":"Power Attack: attack option exposed through CombatOptionResolver; not applied automatically.","rules":[{"type":"ATTACK_OPTION","option":"powerAttack","label":"Power Attack","control":"slider","max":5,"resource":"baseAttackBonus","requiresAttackType":"melee","attackModifierFormula":"-value","damageModifierFormula":"value","summary":"Trade attack bonus for bonus melee damage."}]},"subType":"STATE","shortSummary":"Trade attack bonus for damage on melee attacks (up to your Base Attack Bonus).","prerequisitesText":"Strength 13","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Power_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["attack.with-melee"],"id":"swse.feat.power_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Power_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"3fae4e25ba7ad3c2","name":"Elusive Target","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When fighting defensively or using the total defense action, you may redirect missed melee attacks to another target adjacent to you.","prerequisite":"Dex 13, Dodge","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense","value":2,"type":"untyped","predicates":["defense.against-melee","attack.with-melee"],"enabled":true,"priority":500,"description":"Elusive Target"}]},"shortSummary":"When fighting defensively or using the total defense action, you may redirect missed melee attacks to another target adjacent to you."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["defense.against-melee","attack.with-melee"]}}}
{"_id":"4025202b97ec451d","name":"Reckless Charge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you charge, you gain a +2 bonus on melee attack rolls but take a -2 penalty to Reflex Defense until the start of your next turn.","prerequisite":"Str 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["charge","feat","general","offense","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.reflex","value":2,"type":"untyped","predicates":["defense.reflex","attack.with-melee"],"enabled":true,"priority":500,"description":"Reckless Charge"}]},"shortSummary":"When you charge, you gain a +2 bonus on melee attack rolls but take a -2 penalty to Reflex Defense until the start of your next turn."},"effects":[{"_id":"54ed6adb-4bec-4864-9fd4-f8a974f2f3a0","name":"Reckless Charge","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Reckless Charge","effectType":"defense_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["defense.reflex","attack.with-melee"]}}}
{"_id":"40429365d8f28219","name":"Hasty Modification","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can exchange a Trait you have applied to a piece of Equipment or Droid for another one by spending 1 minute to make a DC 20 Mechanics check. If you succeed, the Equipment loses the old Trait and gains a new Trait until the end of the encounter, at which point the device loses all Traits previously acquired through use of the Tech Specialist Feat.","prerequisite":"Tech Specialist","special":"","normalText":"","sourcebook":"Scum and Villainy","page":24,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Hasty_Modification</p>\n<p>You can tweak and adapt equipment on the fly.</p>\n<p><strong>Prerequisites:</strong> Tech Specialist</p>\n<h4>Effect</h4>\n<p>You can exchange a Trait you have applied to a piece of Equipment or Droid for another one by spending 1 minute to make a DC 20 Mechanics check. If you succeed, the Equipment loses the old Trait and gains a new Trait until the end of the encounter, at which point the device loses all Traits previously acquired through use of the Tech Specialist Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Hasty Modification"}]},"shortSummary":"Swap one Trait for another Trait.","prerequisitesText":"Tech Specialist","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Hasty_Modification"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.hasty_modification","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Hasty_Modification","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"419a502e59264382","name":"Acrobatic Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you succeed in Tumbling to avoid an Attack of Opportunity, you gain a +2 competence bonus on the next attack roll you make against that foe as long as the attack occurs before the end of your current turn.","prerequisite":"Trained in Acrobatics","special":"","normalText":"","sourcebook":"Galaxy at War","page":23,"tags":["feat","general","offense","offense_melee"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Acrobatic_Strike</p>\n<p>Your dexterous maneuvers and skilled Acrobatics allow you to slip past a foe&#x27;s defenses and deliver an accurate strike against them.</p>\n<p><strong>Prerequisites:</strong> Trained in Acrobatics</p>\n<h4>Effect</h4>\n<p>If you succeed in Tumbling to avoid an Attack of Opportunity, you gain a +2 competence bonus on the next attack roll you make against that foe as long as the attack occurs before the end of your current turn.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"a6c5e98148aad9a9"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-melee"],"enabled":true,"priority":500,"description":"Acrobatic Strike"}]},"shortSummary":"Gain +2 competence bonus on next attack against opponent you Tumble past.","prerequisitesText":"Trained in Acrobatics","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Acrobatic_Strike"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["attack.with-melee"],"id":"swse.feat.acrobatic_strike","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Acrobatic_Strike","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"41a9ce755ecffb5b","name":"Heavy Weapon Proficiency","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You are proficient with heavy weapons and do not take the -5 penalty when using them.","prerequisite":"","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["build_enabler","feat","general","offense","offense_ranged","weapon_access","weapon_heavy","mapped_phase_1","unlock_grant","choice_variant"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"UNLOCK","abilityMeta":{"grants":[{"category":"PROFICIENCY","proficiencyType":"weapon","proficiencies":["heavy-weapons"],"description":"Weapon proficiency: heavy-weapons"}]},"choiceMeta":{"resolution":"already_resolved_static_variant","required":false,"choiceKind":"weapon_proficiency","value":"heavy-weapons","grants":["heavy-weapons"]},"shortSummary":"You are proficient with heavy weapons and do not take the -5 penalty when using them."},"effects":[{"_id":"8022df9b-54d6-420c-bc56-70dd4666b140","name":"Heavy Weapon Proficiency","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Heavy Weapon Proficiency","effectType":"passive_effect","flagType":"Heavy Weapon Proficiency"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"phase1Mapped":true,"manualMappingResolved":true}}}
{"_id":"423c5fffe7abe449","name":"Veteran Spacer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Use Computer checks made to Astrogate.","prerequisite":"Duros","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","skill_synergy","skill_use_computer","species","species_opportunity"],"bonus_feat_for":["species-duros"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to Use Computer checks made to Astrogate."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_bonus_phase8","description":"Veteran Spacer: +2 bonus to Use Computer checks made to Astrogate.","skillCheckBonuses":[{"id":"veteran-spacer","skillKeys":["useComputer"],"value":2,"type":"untyped","context":"astrogate","description":"Veteran Spacer: +2 to Use Computer checks for Astrogate."}]},"shortSummary":"Gain a bonus to Use Computer checks made to Astrogate."},"effects":[{"_id":"5e810754-78db-4b51-a879-83d55b7439cb","name":"Veteran Spacer","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Veteran Spacer","effectType":"skill_bonus","flagType":"Veteran Spacer"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.veteran_spacer"}}}
{"_id":"42dc0158ce091479","name":"Destructive Force","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you deal damage to an object or Vehicle that equals or exceeds the target's Damage Threshold and reduces the target to 0 Hit Points, you deal 1 die of damage (of the same type as the damage used in the attack) to all targets, including allies, that are adjacent to the Vehicle or object.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":21,"tags":["feat","general","vehicle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Destructive_Force</p>\n<p>You cause so much devastation to Vehicles and objects that you also deal damage to others around those targets.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When you deal damage to an object or Vehicle that equals or exceeds the target&#x27;s Damage Threshold and reduces the target to 0 Hit Points, you deal 1 die of damage (of the same type as the damage used in the attack) to all targets, including allies, that are adjacent to the Vehicle or object.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Destructive Force"}]},"shortSummary":"Deal damage to adjacent targets when you damage objects and Vehicles.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Destructive_Force"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.destructive_force","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Destructive_Force","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"42e2404790756700","name":"Tech Specialist","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can modify a device, suit of Armor, Weapon, Droid, or Vehicle so that it gains a special trait. Specific traits are given on the table below. You may perform only one modification at a time. Unless noted otherwise, you cannot grant more than one benefit to a single device, suit of Armor, Weapon, Droid, or Vehicle, and you cannot apply the same benefit more than once.\n\nBefore beginning the modification, you must pay one-tenth the cost of the device, suit of Armor, Weapon, Droid, or Vehicle you wish to modify or 1,000 credits, whichever is more. Completing the modification requires 1 day per 1,000 credits of the modification's cost. At the end of this time, make a DC 20 Mechanics check; you can't Take 10 or Take 20 on this check. If the check succeeds, the modification is completed successfully, and the object gains the desired trait. If the check fails, you lose all credits spent making the modification, and the object doesn't gain the desired trait. However, you may start over if you wish.\n\nOther characters Trained in the Mechanics Skill can assist you, reducing proportionately the time needed to complete the modification (for example, 3 people working together on a 1,000 credit modification would take 1/3 of one day). At the end of the modification process, they can make a Mechanics check to aid your check.\n\nThe market value of a modified item is equal to the base cost of the item + double the cost of the modifications made to it (not including credits wasted on failed modification attempts).\n\nARMOR TRAIT | BENEFIT\nAgile Armor | The Armor's Maximum Dexterity Bonus increases by 1.\nFortifying Armor | The Armor's Equipment bonus to Fortitude Defense increases by 1.\nProtective Armor | The Armor's Armor bonus to Reflex Defense increases by 1.\nDEVICE TRAIT | BENEFIT\nEnhanced Strength | Increase the device's Strength score by 2.\nImproved Durability | The device's Damage Reduction increases by 1, and it gains extra Hit Points equal to one-quarter of its maximum Hit Points.\nMastercraft Device | Skill Checks made using the device gain a +1 Equipment bonus, or the device's existing Equipment bonus increases by 1.\nDROID TRAIT | BENEFIT\nEnhanced Dexterity | Increase the Droid's Dexterity score by 2.\nEnhanced Intelligence | Increase the Droid's Intelligence score by 2.\nEnhanced Strength | Increase the Droid's Strength score by 2.\nVEHICLE TRAIT | BENEFIT\nEnhanced Dexterity | Increase the Vehicle's Dexterity score by 2.\nImproved Shields | Increase the Vehicle's Shield Rating by 5.\nImproved Speed | Increase the Vehicle's Speed by one-quarter of its base Speed (minimum 1 square).\nWEAPON TRAIT | BENEFIT\nImproved Accuracy | The Weapon gains a +1 Equipment bonus on attack rolls.\nImproved Damage | The Weapon deals +2 points of damage with a successful hit. If the weapon has a damage multiplier (for example, 6d10x2), apply the extra damage before applying the multiplier.\nSelective Fire | An Autofire -only ranged Weapon can be set to fire Single-Shots, or a Single-Shot Weapon can be made to have an Autofire mode. This cannot be applied to Weapons that have a Burst radius or Splash radius.","prerequisite":"Trained in Mechanics","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","tech","utility","vehicle"],"bonus_feat_for":["21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy; Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Tech_Specialist</p>\n<p>You can make custom modifications to Armor, Weapons, Vehicles, Droids, and devices.</p>\n<p><strong>Prerequisites:</strong> Trained in Mechanics</p>\n<h4>Effect</h4>\n<p>You can modify a device, suit of Armor, Weapon, Droid, or Vehicle so that it gains a special trait. Specific traits are given on the table below. You may perform only one modification at a time. Unless noted otherwise, you cannot grant more than one benefit to a single device, suit of Armor, Weapon, Droid, or Vehicle, and you cannot apply the same benefit more than once.</p>\n<p>Before beginning the modification, you must pay one-tenth the cost of the device, suit of Armor, Weapon, Droid, or Vehicle you wish to modify or 1,000 credits, whichever is more. Completing the modification requires 1 day per 1,000 credits of the modification&#x27;s cost. At the end of this time, make a DC 20 Mechanics check; you can&#x27;t Take 10 or Take 20 on this check. If the check succeeds, the modification is completed successfully, and the object gains the desired trait. If the check fails, you lose all credits spent making the modification, and the object doesn&#x27;t gain the desired trait. However, you may start over if you wish.</p>\n<p>Other characters Trained in the Mechanics Skill can assist you, reducing proportionately the time needed to complete the modification (for example, 3 people working together on a 1,000 credit modification would take 1/3 of one day). At the end of the modification process, they can make a Mechanics check to aid your check.</p>\n<p>The market value of a modified item is equal to the base cost of the item + double the cost of the modifications made to it (not including credits wasted on failed modification attempts).</p>\n<table class=\"swse-rules-table\"><tbody><tr><th>ARMOR TRAIT</th><th>BENEFIT</th></tr><tr><td>Agile Armor</td><td>The Armor&#x27;s Maximum Dexterity Bonus increases by 1.</td></tr><tr><td>Fortifying Armor</td><td>The Armor&#x27;s Equipment bonus to Fortitude Defense increases by 1.</td></tr><tr><td>Protective Armor</td><td>The Armor&#x27;s Armor bonus to Reflex Defense increases by 1.</td></tr><tr><td>DEVICE TRAIT</td><td>BENEFIT</td></tr><tr><td>Enhanced Strength</td><td>Increase the device&#x27;s Strength score by 2.</td></tr><tr><td>Improved Durability</td><td>The device&#x27;s Damage Reduction increases by 1, and it gains extra Hit Points equal to one-quarter of its maximum Hit Points.</td></tr><tr><td>Mastercraft Device</td><td>Skill Checks made using the device gain a +1 Equipment bonus, or the device&#x27;s existing Equipment bonus increases by 1.</td></tr><tr><td>DROID TRAIT</td><td>BENEFIT</td></tr><tr><td>Enhanced Dexterity</td><td>Increase the Droid&#x27;s Dexterity score by 2.</td></tr><tr><td>Enhanced Intelligence</td><td>Increase the Droid&#x27;s Intelligence score by 2.</td></tr><tr><td>Enhanced Strength</td><td>Increase the Droid&#x27;s Strength score by 2.</td></tr><tr><td>VEHICLE TRAIT</td><td>BENEFIT</td></tr><tr><td>Enhanced Dexterity</td><td>Increase the Vehicle&#x27;s Dexterity score by 2.</td></tr><tr><td>Improved Shields</td><td>Increase the Vehicle&#x27;s Shield Rating by 5.</td></tr><tr><td>Improved Speed</td><td>Increase the Vehicle&#x27;s Speed by one-quarter of its base Speed (minimum 1 square).</td></tr><tr><td>WEAPON TRAIT</td><td>BENEFIT</td></tr><tr><td>Improved Accuracy</td><td>The Weapon gains a +1 Equipment bonus on attack rolls.</td></tr><tr><td>Improved Damage</td><td>The Weapon deals +2 points of damage with a successful hit. If the weapon has a damage multiplier (for example, 6d10x2), apply the extra damage before applying the multiplier.</td></tr><tr><td>Selective Fire</td><td>An Autofire -only ranged Weapon can be set to fire Single-Shots, or a Single-Shot Weapon can be made to have an Autofire mode. This cannot be applied to Weapons that have a Burst radius or Splash radius.</td></tr></tbody></table>\n<h4>Additional Clarifications</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p>The bonuses provided by the Tech Specialist Feat and the Superior Tech Feat always stack with those provided by Equipment Upgrades; however, upgrades and other gear still follow the normal rules for stacking with one another. Additional clarifications are outlined below.</p>\n<p>Device Traits: Weapons, armor, and vehicles are also devices, so they are eligible for all of these modifications. (Droids are characters, not devices.) In addition to the listed modifications, it is possible to install an additional Upgrade Slot on any device using the Tech Specialist Feat. This modification can be made only once.</p>\n<p>Droid Traits: Any equipment with the Droidification upgrade is technically a Droid, so it is eligible for these modifications.</p>\n<p>Armor Traits: If a device or vehicle has an armor bonus to its Reflex Defense (either normally or because of an upgrade), it can benefit from the Protective Armor modification.</p>\n<p>Weapon Traits: If an Autofire -only weapon has the Selective Fire modification, it is still treated as an Autofire -only weapon for purposes of Bracing. An Autofire -only weapon with a Sniper Switch does not gain this benefit.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"745a5686d6f21e8c"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[PARTIAL IMPLEMENTATION: Standard workbench armor/weapon traits automated. Vehicles, droids, devices, and advanced traits deferred.]"}],"status":"customization_tech_specialist_partial","description":"TS-1/TS-2/TS-3 Complete: Agile Armor, Fortifying Armor, Protective Armor, Improved Accuracy fully automated in standard customization workbench. Vehicle/droid/device traits and advanced modifications deferred. See TECH_SPECIALIST_IMPLEMENTATION_PLAN.md.","customizationCapabilities":[{"type":"TECH_SPECIALIST_MODIFICATIONS"}]},"shortSummary":"You can make custom modifications to Armor, Weapons, Vehicles, Droids, and Devices.","prerequisitesText":"Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy","Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Tech_Specialist"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.tech_specialist","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Tech_Specialist","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"4330126d10dccd71","name":"Maniacal Charge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using the Charge Action, you can make a Persuasion check as a Free Action to Intimidate your target and each enemy you pass within 1 square of. When your check succeeds against an enemy you pass, it cannot make an Attack of Opportunity against you. When your check succeeds against your target, it loses its Dexterity bonus and is considered Flat-Footed until the start of your next turn.","prerequisite":"None","special":"You cannot use this Feat with the Intimidator Feat.","normalText":"","sourcebook":"Unknown Regions","page":26,"tags":["ability_dexterity","charge","feat","general","offense","offense_melee","rage","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Maniacal_Charge</p>\n<p>You Charge your enemies like a battle-crazed berserker.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When using the Charge Action, you can make a Persuasion check as a Free Action to Intimidate your target and each enemy you pass within 1 square of. When your check succeeds against an enemy you pass, it cannot make an Attack of Opportunity against you. When your check succeeds against your target, it loses its Dexterity bonus and is considered Flat-Footed until the start of your next turn.</p>\n<h4>Special</h4>\n<p>You cannot use this Feat with the Intimidator Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Maniacal Charge"}]},"shortSummary":"Intimidate your enemies when Charging, preventing adjacent characters from making Attacks of Opportunity and denying your target its Dexterity bonus.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Maniacal_Charge"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.maniacal_charge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Maniacal_Charge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"43a4b873d9a9984d","name":"Ion Shielding","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If the Ion damage (Before being halved) equals or exceeds your Damage Threshold, you move only -1 step on the Condition Track.","prerequisite":"(Droid and Strength 13) or (Cyborg Hybrid and Constitution 13)","special":"","normalText":"If the Ion damage (Before being halved) equals or exceeds your Damage Threshold, you normally move -2 steps on the Condition Track.","sourcebook":"Scavenger's Guide to Droids","page":21,"tags":["condition_track","damage_threshold","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Ion_Shielding</p>\n<p>Your systems are insulated to improve your resistance to Ion damage.</p>\n<p><strong>Prerequisites:</strong> (Droid and Strength 13) or (Cyborg Hybrid and Constitution 13)</p>\n<h4>Effect</h4>\n<p>If the Ion damage (Before being halved) equals or exceeds your Damage Threshold, you move only -1 step on the Condition Track.</p>\n<h4>Normal</h4>\n<p>If the Ion damage (Before being halved) equals or exceeds your Damage Threshold, you normally move -2 steps on the Condition Track.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[]},"resourceRules":{"damage":[{"type":"CAP_ION_DAMAGE_CT_TO_1_STEP"}]},"shortSummary":"Move only -1 step on Condition Track when Ion damage exceeds Damage Threshold.","prerequisitesText":"(Droid and Strength 13) or (Cyborg Hybrid and Constitution 13)","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Ion_Shielding"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.ion_shielding","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Ion_Shielding","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"44705a692e2f01a6","name":"Quick Draw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can Draw or Holster a Weapon as a Swift Action instead of a Move Action.","prerequisite":"Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["action_economy","draw_weapon","feat","general","setup","swift_action"],"bonus_feat_for":["f62ca2e639cab614","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Quick_Draw</p>\n<p>You can draw and holster weapons with startling quickness.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>You can Draw or Holster a Weapon as a Swift Action instead of a Move Action.</p>\n<h4>Additional Quick Draw Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Dual Weapon Mastery I): You can draw or holster two weapons with a single Swift Action; you must have both hands free to draw both weapons, and each weapon must be able to be held in one hand.</p>\n<p>Combined Feat (Weapon Proficiency (Lightsabers)): You can draw and ignite your Lightsaber as a single Swift Action.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Quick Draw"}]},"shortSummary":"Draw weapon as a Swift Action.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Quick_Draw"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.quick_draw","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Quick_Draw","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"44cce39d67c0979d","name":"Duck and Cover","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you are the target of an Area Attack that misses, once per turn you can Move 2 squares as a Reaction. This movement does not provoke Attacks of Opportunity.","prerequisite":"Trained in Stealth","special":"","normalText":"","sourcebook":"Scum and Villainy","page":22,"tags":["cover_play","defense","feat","general","multi_target","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Duck_and_Cover</p>\n<p>When exposed to an Area Attack, you can dive for cover.</p>\n<p><strong>Prerequisites:</strong> Trained in Stealth</p>\n<h4>Effect</h4>\n<p>Whenever you are the target of an Area Attack that misses, once per turn you can Move 2 squares as a Reaction. This movement does not provoke Attacks of Opportunity.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"6d2ac22d9fcf402f"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Duck and Cover"}]},"shortSummary":"You dive for Cover when you avoid Area Attacks.","prerequisitesText":"Trained in Stealth","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Duck_and_Cover"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"id":"swse.feat.duck_and_cover","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Duck_and_Cover","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"44ddf3506444cbbd","name":"Force Focus","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Use the Force checks made to activate a specific Force power you select when taking this feat.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":94,"tags":["feat","force","choice_required","immediate_choice","force_choice","choice_source_prerequisite"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Force Focus"}]},"choiceMeta":{"resolution":"immediate","required":true,"status":"tagged_for_later_dialog_backfill","choiceKind":"force_power_focus","repeatable":false,"storagePath":"flags.swse.choices.force_power_focus","choiceSource":"prerequisiteDerived","derivesFrom":["owned_force_powers"],"consumes":"owned_force_powers","provides":"force_power_focus","optionRegistry":"data/feat-choice-options.json#choiceKinds.force_power_focus"},"shortSummary":"You gain a +2 bonus on Use the Force checks made to activate a specific Force power you select when taking this feat."},"effects":[{"_id":"c848bbad-3457-473f-93d4-5bf788e39d60","name":"Force Focus","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Force Focus","effectType":"skill_bonus","flagType":"Force Focus"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":[],"requiresImmediateChoice":true}}}
{"_id":"45366d4f3a5e443d","name":"Dodge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"During your turn, you designate an opponent and receive a +1 dodge bonus to your Reflex Defense against attacks from that opponent. You can select a new opponent on any action. A situation that makes you lose your Dexterity bonus to Reflex Defense (if any) also makes you lose dodge bonuses. Also, dodge bonuses stack with each other, unlike most other types of bonuses.","prerequisite":"Dexterity 13","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":84,"tags":["defense","feat","general","reflex_defense","survivability"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy; Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Dodge</p>\n<p>You are adept at dodging blows.</p>\n<p><strong>Prerequisites:</strong> Dexterity 13</p>\n<h4>Effect</h4>\n<p>During your turn, you designate an opponent and receive a +1 dodge bonus to your Reflex Defense against attacks from that opponent. You can select a new opponent on any action. A situation that makes you lose your Dexterity bonus to Reflex Defense (if any) also makes you lose dodge bonuses. Also, dodge bonuses stack with each other, unlike most other types of bonuses.</p>\n<h4>Additional Dodge Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p>The Pilot of a Vehicle may use Dodge to grant the Vehicle a +1 dodge bonus against a single opponent (Whether a Vehicle or a single character).</p>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Charging Fire): You reduce your penalty to your Reflex Defense against all opponents to -1 when making a ranged attack at the end of a Charge.</p>\n<p>Combined Feat (Running Attack): You can add your Dodge bonus to your Reflex Defense against anyone who makes an Attack of Opportunity against you while using the Running Attack Feat.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.reflex","type":"untyped","value":1,"enabled":true,"priority":500,"description":"Migrated from AE system.defenses.reflex.misc"}]},"shortSummary":"Gain a +1 dodge bonus to Reflex Defense against a selected target.","prerequisitesText":"Dexterity 13","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy","Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Dodge"},"effects":[{"name":"Dodge","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.reflex.misc","mode":2,"value":"1","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"feat-defense-bonus","source":"Dodge","defenseType":"reflex","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.dodge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Dodge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"4595bed5d4117164","name":"Opportunistic Shooter","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Attacks of Opportunity with ranged weapons.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":25,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Opportunistic_Shooter</p>\n<p>You are quick to react when nearby enemies expose themselves to your attacks.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You gain a +2 bonus on Attacks of Opportunity with ranged weapons.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":true,"priority":500,"description":"Opportunistic Shooter"}]},"shortSummary":"Gain a bonus to Attacks of Opportunity with ranged weapons.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Opportunistic_Shooter"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.381Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.opportunistic_shooter","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Opportunistic_Shooter","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
