{"_id":"0166fcdddc548545","name":"Improved Charge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can make a Charge without having to move in a straight line, and you can alter your direction when making a Charge to avoid obstacles. All other Charge rules apply.","prerequisite":"Dexterity 13, Dodge, Mobility","special":"","normalText":"A character must Charge in an unobstructed straight line.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["charge","feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> Dexterity<br>13,<br>Dodge<br>,<br>Mobility</p>\n<p><strong>Effect:</strong> You can make a<br>Charge<br>without having to move in a straight line, and you can alter your direction when making a<br>Charge<br>to avoid obstacles. All other<br>Charge<br>rules apply.</p>\n<p><strong>Normal:</strong> A character must<br>Charge<br>in an unobstructed straight line.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Improved_Charge</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Improved Charge: No numeric bonus; represented as a charge movement flag.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"No numeric bonus; represented as a charge movement flag."}],"mechanicsMode":"conditional","applicationScope":"charge_movement_option","staticSheetPolicy":"attack_option_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Charge movement can bend around obstacles instead of requiring a straight line.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"movement_attack_option_phase11","description":"Charge movement can bend around obstacles instead of requiring a straight line.","rules":[{"type":"ATTACK_OPTION","option":"improvedCharge","label":"Improved Charge","control":"flag","requiresCharge":true,"allowsNonStraightCharge":true,"allowsChargeDirectionChange":true,"summary":"You can charge without moving in a straight line and may alter direction to avoid obstacles.","suppresses":["straightLineChargeRequirement"]}]},"shortSummary":"You can Charge without moving in a straight line.","prerequisitesText":"Dexterity 13, Dodge, Mobility","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Improved_Charge","effect":"You can make a\nCharge\nwithout having to move in a straight line, and you can alter your direction when making a\nCharge\nto avoid obstacles. All other\nCharge\nrules apply."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[],"id":"swse.feat.improved_charge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improved_Charge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"01dee6f32bbd8f85","name":"Battering Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you successfully move a creature with the Bantha Rush Feat, you also knock that target Prone.","prerequisite":"Bantha Rush, Trip","special":"","normalText":"","sourcebook":"Galaxy at War","page":20,"tags":["control","feat","general","knock_prone","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Bantha Rush<br>,<br>Trip</p>\n<p><strong>Effect:</strong> Whenever you successfully move a creature with the<br>Bantha Rush<br>Feat, you also knock that target<br>Prone<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Battering_Attack</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["target.is-prone"],"enabled":false,"priority":500,"description":"Battering Attack: Old migrated numeric modifier disabled; represented by non-numeric rider/resource metadata.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["target.is-prone"],"conditionSummary":"Old migrated numeric modifier disabled; represented by non-numeric rider/resource metadata."}],"mechanicsMode":"conditional","applicationScope":"rider_effect","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"When Bantha Rush successfully moves a target, also knock that target prone.","predicateRequirements":[],"metadataPhase":"phase9-feat-implementation-continuation","metadataNotes":"Phase 9 removes false numeric scaffolding and records description-driven rider metadata.","status":"rider_effect_phase9","description":"When Bantha Rush successfully moves a target, also knock that target prone.","rule