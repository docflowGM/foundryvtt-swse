{"_id":"47f21e32233bb910","name":"Resurgent Vitality","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain additional Hit Points when catching a Second Wind.","prerequisite":"Wookiee","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["defense","durability","execution_mapped_phase8","feat","hit_points","racial","recovery","resource_second_wind","second_wind","species","species_opportunity","survivability"],"bonus_feat_for":["species-wookiee"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Wookiee</p>\n<p><strong>Effect:</strong> Whenever you catch a<br>Second Wind<br>, you regain an additional number of Hit Points equal to twice your<br>Constitution<br>bonus (minimum +2).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Resurgent_Vitality</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":false,"priority":500,"description":"Resurgent Vitality is a Second Wind/resource rule, not an attack modifier.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit"],"conditionSummary":"Resurgent Vitality is a Second Wind/resource rule, not an attack modifier."}],"mechanicsMode":"passive_resource","applicationScope":"secondWind_resource","staticSheetPolicy":"resource_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Second Wind heals extra HP equal to twice Constitution modifier, minimum +2.","predicateRequirements":["attack.when-hit"],"metadataPhase":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics.","status":"second_wind_rule_phase8","description":"Resurgent Vitality: Second Wind heals extra HP equal to twice Constitution modifier, minimum +2.","resourceRules":{"secondWind":[{"type":"EXTRA_HEALING_CON_MOD_MULTIPLIER","multiplier":2,"minimum":2,"description":"Heal extra HP equal to twice Constitution modifier, minimum +2, when catching a Second Wind."}]}},"shortSummary":"Gain additional Hit Points when catching a Second Wind.","sourceUrl":"https://swse.fandom.com/wiki/Resurgent_Vitality","rawImport":{"name":"Resurgent Vitality","url":"https://swse.fandom.com/wiki/Resurgent_Vitality","pageTitle":"Resurgent_Vitality","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\resurgent_vitality.html","referenceBooks":[],"prerequisitesText":"Wookiee","prerequisites":["Wookiee"],"effect":"Whenever you catch a\nSecond Wind\n, you regain an additional number of Hit Points equal to twice your\nConstitution\nbonus (minimum +2).","benefit":"","normal":"","special":"","indexPrerequisites":"Wookiee","indexBenefit":"Gain additional Hit Points when catching a Second Wind .","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nThough your Species heals quickly over time, you can push through your pain in the short term and return to fighting form.\n\nPrerequisite:\nWookiee\n\nEffect:\nWhenever you catch a\nSecond Wind\n, you regain an additional number of Hit Points equal to twice your\nConstitution\nbonus (minimum +2)."},"prerequisitesText":"Wookiee","effect":"Whenever you catch a\nSecond Wind\n, you regain an additional number of Hit Points equal to twice your\nConstitution\nbonus (minimum +2)."},"effects":[{"_id":"6bd1b831-e5a0-42d5-9bfa-a2dd3dbfda4c","name":"Resurgent Vitality","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"fl