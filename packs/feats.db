{"_id":"08896a9f860ebca9","name":"Pitiless Warrior","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain Bonus Hit Points whenever you take down a foe.","prerequisite":"Trandoshan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["durability","feat","hit_points","racial","species","species_opportunity"],"bonus_feat_for":["species-trandoshan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trandoshan</p>\n<p><strong>Effect:</strong> Whenever you reduce a target to 0 Hit Points, you gain a number of<br>Bonus Hit Points<br>equal to 5 + one-half your Character Level. Damage is subtracted from<br>Bonus Hit Points<br>first, and any<br>Bonus Hit Points<br>remaining at the end of the encounter are lost.<br>Bonus Hit Points<br>do not stack.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Pitiless_Warrior</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":false,"priority":500,"description":"Pitiless Warrior: Old migrated numeric modifier disabled; represented by non-numeric rider/resource metadata.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit"],"conditionSummary":"Old migrated numeric modifier disabled; represented by non-numeric rider/resource metadata."}],"mechanicsMode":"conditional","applicationScope":"rider_effect","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"After reducing a target to 0 HP, gain bonus HP equal to 5 + half character level until encounter end.","predicateRequirements":[],"metadataPhase":"phase9-feat-implementation-continuation","metadataNotes":"Phase 9 removes false numeric scaffolding and records description-driven rider metadata.","status":"bonus_hp_rider_phase9","description":"After reducing a target to 0 HP, gain bonus HP equal to 5 + half character level until encounter end.","resourceRules":{"bonusHitPoints":[{"type":"ON_REDUCE_TARGET_TO_ZERO","valueFormula":"5+halfLevel","stacks":false,"duration":"encounter"}]}},"shortSummary":"Gain Bonus Hit Points whenever you take down a foe.","sourceUrl":"https://swse.fandom.com/wiki/Pitiless_Warrior","rawImport":{"name":"Pitiless Warrior","url":"https://swse.fandom.com/wiki/Pitiless_Warrior","pageTitle":"Pitiless_Warrior","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\pitiless_warrior.html","referenceBooks":[],"prerequisitesText":"Trandoshan","prerequisites":["Trandoshan"],"effect":"Whenever you reduce a target to 0 Hit Points, you gain a number of\nBonus Hit Points\nequal to 5 + one-half your Character Level. Damage is subtracted from\nBonus Hit Points\nfirst, and any\nBonus Hit Points\nremaining at the end of the encounter are lost.\nBonus Hit Points\ndo not stack.","benefit":"","normal":"","special":"","indexPrerequisites":"Trandoshan","indexBenefit":"Gain Bonus Hit Points whenever you take down a foe.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nWhenever you fell an opponent, the victory stokes your bloodlust and prepares you for more carnage.\n\nPrerequisite:\nTrandoshan\n\nEffect:\nWhenever you reduce a target to 0 Hit Points, you gain a number of\nBonus Hit Points\nequal to 5 + one-half your Character Level. Damage is subtracted from\nBonus Hit Points\nfirst, and any\nBonus Hit Points\nremaining at the end of the encounter are lost.\nBonus Hit Points\ndo not stack."},"prerequisitesText":"Trandoshan","effect":"Whenever you reduce a target to 0 Hit Points, you gain a number of\nBonus Hit Points\nequal to 5 + one-half your Character Level. Damage is subtracted from\nBonus Hit Points\nfirst, and any\nBonus Hit Points\nremaining at the end of the encounter are lost.\nBonus Hit Points\ndo not stack."},"effects":[{"_id":"f3ae6fcb-66f0-4608-afa0-a8f2d593188f","name":"Pitiless Warrior","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Pitiless Warrior","effectType":"combat_bonus","flagType":"Pitiless Warrior"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.pitiless_warrior"}}}
{"_id":"08a15012d82f0d16","name":"Scion of Dorin","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Fortitude Defense against Atmospheric Hazards.","prerequisite":"Kel Dor","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-kel-dor"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Kel Dor</p>\n<p><strong>Effect:</strong> You gain a +5<br>Species<br>bonus to your<br>Fortitude Defense<br>against all Natural<br>Hazards<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Scion_of_Dorin</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":5,"type":"species","predicates":["defense.fortitude","hazard.natural"],"enabled":true,"priority":500,"description":"Scion of Dorin: +5 species bonus to Fortitude Defense against natural/atmospheric hazards.","mechanicsMode":"conditional","applicationScope":"contextual_defense","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.fortitude","hazard.natural"],"conditionSummary":"+5 species bonus to Fortitude Defense against natural/atmospheric hazards."}],"mechanicsMode":"conditional","applicationScope":"contextual_defense","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Conditional Fortitude bonus against natural hazards only; not a reroll and never static.","predicateRequirements":[],"metadataPhase":"phase25-suspect-feat-cleanup","metadataNotes":"Phase 12 continues description-guided feat implementation by replacing false scaffold bonuses with explicit roll options, contextual predicates, resource/rider metadata, or supported static rules.","status":"natural_hazard_defense_metadata_phase25","de