{"_id":"0053d97632b02e4a","name":"Wary Sentries","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Perception checks when near allies.","prerequisite":"Trained in Perception","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_perception","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8","manual_resolution","teamwork_base_skill_bonus_phase15"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Perception</p>\n<p><strong>Effect:</strong> You gain a +3 competence bonus on<br>Perception<br>checks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).<br><br>Additionally, you can<br>Take 10<br>on<br>Perception<br>checks, even when threatened or rushed.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Wary_Sentries</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_with_manual_teamwork","applicationScope":"skill_roll_plus_manual_teamwork","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Wary Sentries: +3 competence skill bonus applies normally; nearby-ally scaling and other battlefield/teamwork clauses are GM/player managed.","predicateRequirements":[],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 avoids automating nearby-ally/battlefield positioning clauses; base skill bonuses are implemented where unambiguous and teamwork clauses are preserved as manual metadata.","implementationStatus":"base_skill_bonus_manual_teamwork_phase15","description":"Wary Sentries: base +3 competence skill bonus implemented; nearby-ally scaling and special teamwork clauses remain table-managed flavor/manual metadata.","skillCheckBonuses":[{"id":"wary-sentries","skillKey":"perception","type":"competence","featName":"Wary Sentries","description":"Wary Sentries: +3 competence bonus to perception checks. Nearby-ally scaling is manual/table-managed.","value":3}],"teamworkRules":[{"type":"TAKE_10_ALLOWED","skillKey":"perception","evenWhenThreatenedOrRushed":true,"description":"May Take 10 on Perception checks even when threatened or rushed.","automation":"manual","manualResolution":true}]},"shortSummary":"Gain bonuses on Perception checks when near allies.","sourceUrl":"https://swse.fandom.com/wiki/Wary_Sentries","rawImport":{"name":"Wary Sentries","url":"https://swse.fandom.com/wiki/Wary_Sentries","pageTitle":"Wary_Sentries","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\wary_sentries.html","referenceBooks":[],"prerequisitesText":"Trained\nin\nPerception","prerequisites":["Trained\nin\nPerception"],"effect":"You gain a +3 competence bonus on\nPerception\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, you can\nTake 10\non\nPerception\nchecks, even when threatened or rushed.","benefit":"","normal":"","special":"","indexPrerequisites":"Trained in Perception","indexBenefit":"Gain bonuses on Perception checks when near allies.","indexPage":"Specialization_Feats","indexSection":"Team Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nTeam Feats\n\nYou and your allies specialize in keeping tabs on your surroundings, making you excellent guards and advance scouts.\n\nPrerequisite:\nTrained\nin\nPerception\n\nEffect:\nYou gain a +3 competence bonus on\nPerception\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, you can\nTake 10\non\nPerception\nchecks, even when threatened or rushed."},"prerequisitesText":"Trained\nin\nPerception","effect":"You gain a +3 competence bonus on\nPerception\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, you can\nTake 10\non\nPerception\nchecks, even when threatened or rushed."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.375Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.wary_sentries"}}}
