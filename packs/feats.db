{"_id":"b9d4eb946079b555","name":"Mechanical Martial Arts","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully damage an enemy with an Unarmed Attack, the enemy takes a -5 penalty to all melee attack rolls and damage rolls until the start of your next turn.","prerequisite":"Droid, Martial Arts I, Base Attack Bonus +1","special":"If you strike an organic enemy while using this Feat during an Attack of Opportunity, the penalty lasts until the start of the enemy's next turn.","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":22,"tags":["feat","general","martial_style","offense_melee","tech","unarmed","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Droid<br>,<br>Martial Arts I<br>,<br>Base Attack Bonus<br>+1</p>\n<p><strong>Effect:</strong> When you successfully damage an enemy with an<br>Unarmed Attack<br>, the enemy takes a -5 penalty to all melee attack rolls and damage rolls until the start of your next turn.</p>\n<p><strong>Special:</strong> If you strike an organic enemy while using this Feat during an<br>Attack of Opportunity<br>, the penalty lasts until the start of the enemy&#x27;s next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Mechanical_Martial_Arts</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"unarmed_hit_rider","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Mechanical Martial Arts: unarmed damage imposes a melee attack/damage penalty on the target until the start of your next turn.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"unarmed_hit_rider_phase16","description":"Mechanical Martial Arts: unarmed damage imposes a melee attack/damage penalty on the target until the start of your next turn.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Mechanical Martial Arts: unarmed damage imposes a melee attack/damage penalty on the target until the start of your next turn.","mechanicsMode":"metadata_only","applicationScope":"unarmed_hit_rider","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"ATTACK_OPTION","option":"mechanicalMartialArts","label":"Mechanical Martial Arts","control":"passive","requiresUnarmed":true,"targetEffectsOnHit":[{"type":"ATTACK_AND_DAMAGE_PENALTY","targets":["meleeAttack","meleeDamage"],"value":-5,"duration":"untilStartOfNextTurn","description":"Target takes -5 on melee attack and melee damage rolls until the start of your next turn."}],"summary":"On damaging with an unarmed attack, target takes -5 melee attack/damage until your next turn."}]},"shortSummary":"Give an enemy a -5 penalty on attack and damage rolls for one round after striking it in Unarmed combat.","prerequisitesText":"Droid, Martial Arts I, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Mechanical_Martial_Arts","effect":"When you successfully damage an enemy with an\nUnarmed Attack\n, the enemy takes a -5 penalty to all melee attack rolls and damage rolls until the start of your next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.mechanical_martial_arts","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mechanical_Martial_Arts","updatedFields":["system.