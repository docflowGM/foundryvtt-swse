":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics.","status":"second_wind_rule_phase8","description":"Unstoppable Combatant: you are not limited to one Second Wind per encounter."},"resourceRules":{"secondWind":[{"type":"IGNORE_ENCOUNTER_CAP"}]},"shortSummary":"Catch more than one Second Wind in an encounter.","prerequisitesText":"Extra Second Wind","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Combatant","effect":"You can catch more than one\nSecond Wind\nper encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.unstoppable_combatant","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Combatant","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fb64065b4a779cd8","name":"Artillery Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make an attack with a Burst or Splash weapon with which you are proficient against a target at greater than Point-Blank Range, you can affect two additional squares adjacent to the normal Burst radius or Splash area.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":20,"tags":["area_pressure","feat","general","grenade","multi_target","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> When you make an attack with a<br>Burst<br>or<br>Splash<br>weapon with which you are proficient against a target at greater than Point-Blank<br>Range<br>, you can affect two additional squares adjacent to the normal<br>Burst<br>radius or<br>Splash<br>area.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Artillery_Shot</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"burst_splash_area_context","staticSheetPolicy":"roll_context_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Artillery Shot: proficient Burst/Splash weapon attacks beyond point-blank affect two additional adjacent squares.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"area_attack_metadata_phase16","description":"Artillery Shot: proficient Burst/Splash weapon attacks beyond point-blank affect two additional adjacent squares.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Artillery Shot: proficient Burst/Splash weapon attacks beyond point-blank affect two additional adjacent squares.","mechanicsMode":"metadata_only","applicationScope":"burst_splash_area_context","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"ATTACK_OPTION","option":"artilleryShot","label":"Artillery Shot","control":"passive","requiresWeaponText":["burst","splash","grenade"],"requiresRangeBand":["short","medium","long"],"areaBonusSquares":2,"summary":"Burst/Splash attack beyond point-blank affects two additional adjacent squares."}]},"shortSummary":"You increase the efficiency of your Burst and Splash weapon attacks.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Artillery_Shot","effect":"When you make an attack with a\nBurst\nor\nSplash\nweapon with which you are proficient against a target at greater than Point-Blank\nRange\n, you can affect two additional squares adjacent to the normal\nBurst\nradius or\nSplash\narea."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.artillery_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Artillery_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fbd561777651635e","name":"Autofire Sweep","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making an Autofire attack with a weapon with which you possess the Weapon Focus feat, you can attack all targets in a 6-Square Cone. The origin square of the cone can be any square in your line of sight and within Point-Blank Range.","prerequisite":"Weapon Focus (Chosen Weapon)","special":"This Feat cannot be used with the Autofire Assault feat or the Burst Fire feat. It can be used with the Improved Suppression Fire Talent.","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":16,"tags":["area_pressure","autofire","feat","general","multi_target","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Weapon Focus<br>(Chosen Weapon)</p>\n<p><strong>Effect:</strong> When making an<br>Autofire<br>attack with a weapon with which you possess the<br>Weapon Focus<br>feat, you can attack all targets in a 6-Square<br>Cone<br>. The origin square of the cone can be any square in your line of sight and within Point-Blank<br>Range<br>.</p>\n<p><strong>Special:</strong> This Feat cannot be used with the<br>Autofire Assault<br>feat or the<br>Burst Fire<br>feat. It can be used with the<br>Improved Suppression Fire<br>Talent.</p>\n<h3>Homebrew Autofire Sweep Data</h3><p>This Homebrew Content has not been reviewed in a meaningful manner. If you wish to review this content yourself, then see Untested for more details.<br><br>Autofire Sweep data created by Wikia user Chellewalker (formally Wikia user Lukewarner).<br><br>To prevent this feat from unbalancing a game, have all targets of an attack with the Autofire Sweep feat be treated as though they posses the<br>Evasion<br>Talent.<br><br>All targets take half damage from a successful attack, and no damage if the attack misses. If a target of an Autofire Sweep attack already possess the<br>Evasion<br>Talent, then they take no damage regardless of the attack roll.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Autofire_Sweep</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"active","applicationScope":"autofire_cone_attack_context","staticSheetPolicy":"roll_context_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Autofire Sweep: Weapon Focus autofire attack can target all creatures in a 6-square cone from a visible point in point-blank range.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"autofire_area_metadata_phase16","description":"Autofire Sweep: Weapon Focus autofire attack can target all creatures in a 6-square cone from a visible point in point-blank range.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Autofire Sweep: Weapon Focus autofire attack can target all creatures in a 6-square cone from a visible point in point-blank range.","mechanicsMode":"metadata_only","applicationScope":"autofire_cone_attack_context","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"ATTACK_OPTION","option":"autofireSweep","label":"Autofire Sweep","control":"flag","requiresAutofire":true,"requiresFeatSelectedChoiceMatch":["Weapon Focus"],"areaShape":"cone","areaSizeSquares":6,"origin":"visiblePointWithinPointBlank","summary":"Use autofire to attack all targets in a 6-square cone from a visible point within point-blank range."}]},"shortSummary":"Sweep a wide area while using Autofire mode.","prerequisitesText":"Weapon Focus (Chosen Weapon)","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Autofire_Sweep","effect":"When making an\nAutofire\nattack with a weapon with which you possess the\nWeapon Focus\nfeat, you can attack all targets in a 6-Square\nCone\n. The origin square of the cone can be any square in your line of sight and within Point-Blank\nRange\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.autofire_sweep","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Autofire_Sweep","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fc1e5f0a2367debb","name":"Bantha Rush","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"After making a successful melee attack against an opponent up to one size category larger than you, you can choose to move that opponent 1 square in any direction as a Free Action. You can't Bantha Rush an opponent that's being Grabbed or Grappled, and you can't Bantha Rush your opponent into a solid object or another creature's Fighting Space.","prerequisite":"Strength 13, Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Galaxy at War","page":23,"tags":["feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> Strength<br>13,<br>Base Attack Bonus<br>+1</p>\n<p><strong>Effect:</strong> After making a successful melee attack against an opponent up to one size category larger than you, you can choose to move that opponent 1 square in any direction as a Free Action. You can&#x27;t Bantha Rush an opponent that&#x27;s being<br>Grabbed<br>or<br>Grappled<br>, and you can&#x27;t Bantha Rush your opponent into a solid object or another creature&#x27;s<br>Fighting Space<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Bantha_Rush</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13},{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rider_effect_phase7","description":"Bantha Rush: modeled as a rider/action rule, not a numeric modifier.","rules":[{"type":"RIDER_EFFECT","trigger":"onSuccessfulMeleeAttack","effect":"pushTarget","distanceSquares":1,"maxTargetSizeDelta":1,"blockedIfTarget":["grabbed","grappled"],"requiresUnoccupiedDestination":true}],"modifiers":[{"target":"attack","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Bantha Rush: numeric scaffold disabled by Phase 7 (description grants a conditional rider/action effect rather than a standing attack or defense bonus)","mechanicsMode":"metadata_note","applicationScope":"not_a_numeric_modifier","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"description grants a conditional rider/action effect rather than a standing attack or defense bonus","metadataPhase":"phase7-description-reimplementation"}],"mechanicsMode":"conditional","applicationScope":"post_hit_movement_rider","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"After a successful melee hit, optionally push an eligible opponent 1 square; no attack bonus is granted.","predicateRequirements":[],"metadataPhase":"phase7-description-reimplementation","metadataNotes":"Phase 7 re-read refreshed descriptions and converted old scaffold bonuses into explicit static/resource/attack-option/rider metadata."},"shortSummary":"Push opponent 1 square after making a successful melee attack.","prerequisitesText":"Strength 13, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Bantha_Rush","effect":"After making a successful melee attack against an opponent up to one size category larger than you, you can choose to move that opponent 1 square in any direction as a Free Action. You can't Bantha Rush an opponent that's being\nGrabbed\nor\nGrappled\n, and you can't Bantha Rush your opponent into a solid object or another creature's\nFighting Space\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":["attack.when-hit","attack.with-melee"],"id":"swse.feat.bantha_rush","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Bantha_Rush","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fc56de4d0d15c95c","name":"Jedi Familiarity","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, when you are targeted or affected by a Force Power or Force Talent originating from an ally, you gain one temporary Force Point, which must be spent before the end of the encounter or it goes away. If the Force Power or Force Talent damages you or moves you down the Condition Track, you do not gain the benefit of this Feat.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":25,"tags":["ally_support","feat","force_point_spend","force_powers","general","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> Once per encounter, when you are targeted or affected by a<br>Force Power<br>or<br>Force Talent<br>originating from an ally, you gain one temporary<br>Force Point<br>, which must be spent before the end of the encounter or it goes away. If the<br>Force Power<br>or<br>Force Talent<br>damages you or moves you down the<br>Condition Track<br>, you do not gain the benefit of this Feat.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Jedi_Familiarity</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Temporary Force Point trigger when affected by an ally Force effect.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"force_power_trigger_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Temporary Force Point trigger when affected by an ally Force effect.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"temporary_force_point_metadata_phase14","resourceRules":{"forcePoints":[{"type":"TEMPORARY_FORCE_POINT_ON_ALLY_FORCE_TARGET","oncePer":"encounter","value":1,"description":"Gain 1 temporary Force Point when targeted/affected by an ally Force Power or Force Talent that does not damage you or move you down CT."}]}},"shortSummary":"Gain one temporary Force Point when targeted by an ally's Force Power or Force Talent.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Jedi_Familiarity","effect":"Once per encounter, when you are targeted or affected by a\nForce Power\nor\nForce Talent\noriginating from an ally, you gain one temporary\nForce Point\n, which must be spent before the end of the encounter or it goes away. If the\nForce Power\nor\nForce Talent\ndamages you or moves you down the\nCondition Track\n, you do not gain the benefit of this Feat."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.jedi_familiarity","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Jedi_Familiarity","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fda012e3b2b1e55f","name":"Resilient Talent","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per day, you may gain the benefit of any talent from a class you have levels in for 1 minute. You may use this talent even if you do not meet its prerequisites.","prerequisite":"Level 6","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":27,"tags":["defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"manual_gm_managed","applicationScope":"temporary_talent_selection_gm_managed","staticSheetPolicy":"exclude","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Resilient Talent requires a once-per-day temporary talent picker from classes you have levels in, so it is deferred to dedicated picker/effect UI.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"punted_gm_managed_phase22","description":"Resilient Talent grants a temporary talent with time-sensitive limits. The GM should assign/remove that temporary talent rather than the system guessing timing and eligibility.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"description":"Resilient Talent grants a temporary talent with time-sensitive limits. The GM should assign/remove that temporary talent rather than the system guessing timing and eligibility.","mechanicsMode":"metadata_only","applicationScope":"temporary_talent_selection_gm_managed","staticSheetPolicy":"exclude","metadataPhase":"phase22-force-regimen-skill-swap"}],"talentRules":[{"type":"DEFERRED_TEMPORARY_TALENT_PICKER","oncePer":"day","duration":"1minute","requiresClassLevelTalentList":true,"description":"Once per day, pick a talent from a class you have levels in for 1 minute; picker/effect UI required."}]},"shortSummary":"Once per day, you may gain the benefit of any talent from a class you have levels in for 1 minute."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[]}}}
{"_id":"febbb0f05c8a0883","name":"Forest Stalker","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Reroll Stealth checks, always keeping the better result.","prerequisite":"Ewok","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["control","feat","grapple","racial","reroll","skill_stealth","skill_synergy","species","species_opportunity","skill_reroll","execution_mapped_phase8"],"bonus_feat_for":["species-ewok"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Ewok</p>\n<p><strong>Effect:</strong> Whenever you reroll a<br>Stealth<br>check, you always keep the better result, even if you have multiple reroll abilities.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Forest_Stalker</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"skill_reroll_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Forest Stalker: whenever you reroll stealth, keep the better result.","predicateRequirements":["skill.stealth"],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 continues description-guided implementation by improving teamwork skill feats, skill substitutions, force/dark-side skill context, and several remaining action/resource rider feats.","implementationStatus":"reroll_outcome_upgrade_phase15","description":"Forest Stalker: improves stealth rerolls to keep the better result.","skillRerollOutcomeUpgrades":[{"id":"forest-stalker","skillKey":"stealth","outcome":"keepBetter","description":"Whenever you reroll stealth, keep the better result."}],"skillRerolls":[{"id":"forest-stalker","skillKey":"stealth","outcome":"keepBetter","label":"Forest Stalker","description":"Forest Stalker: reroll stealth and keep the better result."}]},"shortSummary":"Reroll Stealth checks, always keeping the better result.","sourceUrl":"https://swse.fandom.com/wiki/Forest_Stalker","rawImport":{"name":"Forest Stalker","url":"https://swse.fandom.com/wiki/Forest_Stalker","pageTitle":"Forest_Stalker","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\forest_stalker.html","referenceBooks":[],"prerequisitesText":"Ewok","prerequisites":["Ewok"],"effect":"Whenever you reroll a\nStealth\ncheck, you always keep the better result, even if you have multiple reroll abilities.","benefit":"","normal":"","special":"","indexPrerequisites":"Ewok","indexBenefit":"Reroll Stealth checks, always keeping the better result.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou are one of the most skilled hunters among your Species and have learned to move through the forest with nary a whisper.\n\nPrerequisite:\nEwok\n\nEffect:\nWhenever you reroll a\nStealth\ncheck, you always keep the better result, even if you have multiple reroll abilities."},"prerequisitesText":"Ewok","effect":"Whenever you reroll a\nStealth\ncheck, you always keep the better result, even if you have multiple reroll abilities."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.forest_stalker"}}}
{"_id":"ff76bea42641ca5b","name":"Forceful Stun","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Use the Force checks made to activate Force Stun.","prerequisite":"Trained in Use the Force, Force Stun","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["control","feat","force"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"+2 UTF applies only to Force Stun activation checks.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"skill_roll_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"+2 UTF applies only to Force Stun activation checks.","predicateRequirements":[],"metadataPhase":"phase13-next-feat-implementation-batch","metadataNotes":"Phase 13 converts clear remaining manual/scaffold feats into skill bonuses, attack options, action/resource metadata, or safer non-static rider metadata.","executionModel":"PASSIVE","subType":"RULE","skillCheckBonuses":[{"id":"forcefulStun.forceStun","skillKey":"useTheForce","value":2,"type":"feat","applications":["Force Stun"],"description":"+2 Use the Force checks to activate Force Stun."}],"implementationStatus":"forceful_stun_skill_bonus_phase13"},"shortSummary":"You gain a +2 bonus on Use the Force checks made to activate Force Stun."},"effects":[{"_id":"2a977ad3-fabc-43dc-80bc-bd75d8807383","name":"Forceful Stun","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Forceful Stun","effectType":"skill_bonus","flagType":"Forceful Stun"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[]}}}
{"_id":"ff8eaa4e2f6d1cf1","name":"Mobility","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You get a +5 dodge bonus to Reflex Defense against Attacks of Opportunity caused when you move out of or into a threatened area.","prerequisite":"Dexterity 13, Dodge","special":"A situation that makes you lose your Dexterity bonus to Reflex Defense (If any) also makes you lose dodge bonuses. Dodge bonuses also stack with each other, unlike most other types of bonuses.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["anti_opportunity_attack","defense","feat","general","mobility"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> Dexterity<br>13,<br>Dodge</p>\n<p><strong>Effect:</strong> You get a +5 dodge bonus to<br>Reflex Defense<br>against<br>Attacks of Opportunity<br>caused when you move out of or into a threatened area.</p>\n<p><strong>Special:</strong> A situation that makes you lose your<br>Dexterity<br>bonus to<br>Reflex Defense<br>(If any) also makes you lose dodge bonuses. Dodge bonuses also stack with each other, unlike most other types of bonuses.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Mobility</em></p>","executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.reflex","type":"untyped","value":5,"enabled":true,"priority":500,"description":"Mobility: +5 dodge bonus to Reflex Defense against movement-provoked attacks of opportunity.","predicates":["movement.opportunity-attack-from-movement"],"mechanicsMode":"conditional","applicationScope":"contextual_defense","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["movement.opportunity-attack-from-movement"],"conditionSummary":"+5 dodge bonus to Reflex Defense against movement-provoked attacks of opportunity."}],"mechanicsMode":"conditional","applicationScope":"contextual_defense","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Metadata only/conditional: +5 dodge bonus to Reflex Defense against attacks of opportunity provoked by movement. Never add to static Reflex Defense.","predicateRequirements":["movement.opportunity-attack-from-movement"],"metadataPhase":"phase25-suspect-feat-cleanup","metadataNotes":"Phase 12 continues description-guided feat implementation by replacing false scaffold bonuses with explicit roll options, contextual predicates, resource/rider metadata, or supported static rules.","status":"movement_aoo_defense_metadata_phase25","description":"+5 dodge bonus to Reflex Defense against movement-provoked attacks of opportunity."},"shortSummary":"Gain +5 dodge bonus to Reflex Defense against some Attacks of Opportunity.","prerequisitesText":"Dexterity 13, Dodge","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Mobility","effect":"You get a +5 dodge bonus to\nReflex Defense\nagainst\nAttacks of Opportunity\ncaused when you move out of or into a threatened area."},"effects":[{"name":"Mobility","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.reflex.bonus","mode":2,"value":"5","priority":20}],"transfer":true,"flags":{"swse":{"type":"conditional","condition":"vs attacks of opportunity","migratedToPassive":true}},"disabled":true}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.mobility","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mobility","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
