{"_id":"d3c4ae9f793b8573","name":"Jedi Heritage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain extra Force Powers when you take the Force Training Feat.","prerequisite":"Twi'lek, Force Sensitivity","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["conditional_opportunity","feat","force","force_capacity","force_multiplier","force_powers","force_training","forecast_value","racial","species","species_locked","species_opportunity","species_twilek"],"bonus_feat_for":["species-twi-lek"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Twi&#x27;lek<br>,<br>Force Sensitivity</p>\n<p><strong>Effect:</strong> Your<br>Wisdom<br>score is considered to be 4 points higher for the purpose of determining how many<br>Force Powers<br>you gain from the<br>Force Training<br>Feat, granting you two extra<br>Force Powers<br>for each<br>Force Training<br>Feat.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Jedi_Heritage</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Adds extra Force Power choices when taking Force Training.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"force_training_entitlement_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Adds extra Force Power choices when taking Force Training.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"force_training_entitlement_metadata_phase14","forceTrainingRules":[{"type":"EXTRA_FORCE_POWER_CHOICES_ON_FORCE_TRAINING","value":1,"description":"Gain one extra Force Power when taking Force Training."}]},"shortSummary":"Gain extra Force Powers when you take the Force Training Feat.","sourceUrl":"https://swse.fandom.com/wiki/Jedi_Heritage","rawImport":{"name":"Jedi Heritage","url":"https://swse.fandom.com/wiki/Jedi_Heritage","pageTitle":"Jedi_Heritage","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\jedi_heritage.html","referenceBooks":[],"prerequisitesText":"Twi'lek\n,\nForce Sensitivity","prerequisites":["Twi'lek","Force Sensitivity"],"effect":"Your\nWisdom\nscore is considered to be 4 points higher for the purpose of determining how many\nForce Powers\nyou gain from the\nForce Training\nFeat, granting you two extra\nForce Powers\nfor each\nForce Training\nFeat.","benefit":"","normal":"","special":"","indexPrerequisites":"Twi'lek , Force Sensitivity","indexBenefit":"Gain extra Force Powers when you take the Force Training Feat.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou come from a clan that has produced many Jedi, and you have overcome your Species' impulsiveness by becoming a master of\nThe Force\n.\n\nPrerequisites:\nTwi'lek\n,\nForce Sensitivity\n\nEffect:\nYour\nWisdom\nscore is considered to be 4 points higher for the purpose of determining how many\nForce Powers\nyou gain from the\nForce Training\nFeat, granting you two extra\nForce Powers\nfor each\nForce Training\nFeat."},"prerequisitesText":"Twi'lek\n,\nForce Sensitivity","effect":"Your\nWisdom\nscore is considered to be 4 points higher for the purpose of determining how many\nForce Powers\nyou gain from the\nForce Training\nFeat, granting you