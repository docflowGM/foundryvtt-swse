{"_id":"baff0da30d0bc8ee","name":"Force of Personality","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use either your Wisdom modifier or your Charisma modifier to determine your Will Defense.","prerequisite":"Charisma 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":23,"tags":["ability_charisma","ability_wisdom","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Charisma<br>13</p>\n<p><strong>Effect:</strong> You can use either your<br>Wisdom<br>modifier or your<br>Charisma<br>modifier to determine your<br>Will Defense<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Force_of_Personality</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.will"],"enabled":false,"priority":500,"description":"Force of Personality: Implemented by DefenseCalculator as best-of Wis/Cha Will ability selection.","mechanicsMode":"needs_review","applicationScope":"predicate_context_unknown","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.will"],"conditionSummary":"Implemented by DefenseCalculator as best-of Wis/Cha Will ability selection.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"passive","applicationScope":"static_actor","staticSheetPolicy":"include","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Force of Personality now changes Will Defense ability selection instead of using a fake attack modifier.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","defenseAbilityRules":[{"type":"USE_BETTER_ABILITY","defense":"will","abilities":["wis","cha"],"description":"Use the better of Wisdom or Charisma modifier for Will Defense."}],"status":"static_defense_ability_phase10","description":"Force of Personality now changes Will Defense ability selection instead of using a fake attack modifier."},"shortSummary":"Use Wisdom or Charisma to determine Will Defense.","prerequisitesText":"Charisma 13","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Force_of_Personality","effect":"You can use either your\nWisdom\nmodifier or your\nCharisma\nmodifier to determine your\nWill Defense\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.will"],"id":"swse.feat.force_of_personality","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Force_of_Personality","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"bb16070b5fdfccf4","name":"Mon Calamari Shipwright","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Reroute Power more quickly and without the risk of failure.","prerequisite":"Mon Calamari","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity","species_prerequisite_phase10"],"bonus_feat_for":["species-mon-calamari"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Mon Calamari</p>\n<p><strong>Effect:</strong> You need spend only two<br>Swift Actions<br>to move a<br>Vehicle<br>you occupy +1 step on the<br>Condition Track<br>. In addition, you automatically succeed on Mechanics checks to<br>Reroute Power<br>.</p>\n<p><strong>Normal:</strong> It takes three<br>Swift Actions<br>to use the<br>Reroute Power<br>Action.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Mon_Calamari_Shipwright</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"active","applicationScope":"vehicle_systems_action_context","staticSheetPolicy":"action_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Mon Calamari Shipwright reduces vehicle condition recovery to two swift actions and automatically succeeds on Reroute Power Mechanics checks.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"vehicle_action_metadata_phase17","description":"Mon Calamari Shipwright reduces vehicle condition recovery to two swift actions and automatically succeeds on Reroute Power Mechanics checks.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Mon Calamari Shipwright reduces vehicle condition recovery to two swift actions and automatically succeeds on Reroute Power Mechanics checks.","mechanicsMode":"metadata_only","applicationScope":"vehicle_systems_action_context","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"actionRules":[{"type":"VEHICLE_CONDITION_RECOVERY_ACTION_ECONOMY","swiftActions":2,"steps":1,"description":"Spend two swift actions to move an occupied vehicle +1 step on the Condition Track."},{"type":"AUTO_SUCCEED_REROUTE_POWER","skillKey":"mechanics","description":"Automatically succeed on Mechanics checks to Reroute Power."}]},"prerequisitesStructured":{"type":"all","conditions":[{"type":"species","species":["Mon Calamari"]}],"_source":"phase10_species_prereq"},"shortSummary":"Reroute Power more quickly and without the risk of failure.","sourceUrl":"https://swse.fandom.com/wiki/Mon_Calamari_Shipwright","rawImport":{"name":"Mon Calamari Shipwright","url":"https://swse.fandom.com/wiki/Mon_Calamari_Shipwright","pageTitle":"Mon_Calamari_Shipwright","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\mon_calamari_shipwright.html","referenceBooks":[],"prerequisitesText":"Mon Calamari","prerequisites":["Mon Calamari"],"effect":"You need spend only two\nSwift Actions\nto move a\nVehicle\nyou occupy +1 step on the\nCondition Track\n. In addition, you automatically succeed on Mechanics checks to\nReroute Power\n.","benefit":"","normal":"It takes three\nSwift Actions\nto use the\nReroute Power\nAction.","special":"","indexPrerequisites":"Mon Calamari","indexBenefit":"Reroute Power more quickly and without the risk of failure.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou have intimate knowledge of the workings of Starships and other Vehicles and can keep them running no matter what.\n\nPrerequisite:\nMon Calamari\n\nEffect:\nYou need spend only two\nSwift Actions\nto move a\nVehicle\nyou occupy +1 step on the\nCondition Track\n. In addition, you automatically succeed on Mechanics checks to\nReroute Power\n.\n\nNormal:\nIt takes three\nSwift Actions\nto use the\nReroute Power\nAction."},"prerequisitesText":"Mon Calamari","effect":"You need spend only two\nSwift Actions\nto move a\nVehicle\nyou occupy +1 step on the\nCondition Track\n. In addition, you automatically succeed on Mechanics checks to\nReroute Power\n."},"effects":[{"_id":"cdf1b6ac-e96a-47ce-b26b-4b35a6e0d0fb","name":"Mon Calamari Shipwright","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Mon Calamari Shipwright","effectType":"special","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.mon_calamari_shipwright"}}}
{"_id":"bb7a952715116e00","name":"Improved Opportunistic Trickery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever an opponent provokes an Attack of Opportunity from you, once per turn you can sacrifice the attack to reduce the target's Reflex Defense by 5 until the end of the target's next turn.","prerequisite":"Combat Reflexes, Opportunistic Trickery","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":20,"tags":["feat","general","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Combat Reflexes<br>,<br>Opportunistic Trickery</p>\n<p><strong>Effect:</strong> Whenever an opponent provokes an<br>Attack of Opportunity<br>from you, once per turn you can sacrifice the attack to reduce the target&#x27;s<br>Reflex Defense<br>by 5 until the end of the target&#x27;s next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Improved_Opportunistic_Trickery</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":false,"priority":500,"description":"Improved Opportunistic Trickery: Sacrifice an AoO to reduce target Reflex by 5; not an attack bonus.","mechanicsMode":"metadata_only","applicationScope":"explicit_rule_metadata","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.reflex"],"conditionSummary":"Sacrifice an AoO to reduce target Reflex by 5; not an attack bonus."}],"mechanicsMode":"conditional","applicationScope":"explicit_rider_or_attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rules text is conditional and current metadata has predicates. It must only apply when the runtime context satisfies those predicates.","predicateRequirements":["defense.reflex"],"metadataPhase":"phase12-feat-implementation-batch","metadataNotes":"Phase 12 continues description-guided feat implementation by replacing false scaffold bonuses with explicit roll options, contextual predicates, resource/rider metadata, or supported static rules.","rules":[{"type":"ATTACK_OPTION","id":"improvedOpportunisticTrickery","label":"Improved Opportunistic Trickery","control":"flag","requiresOpportunityAttack":true,"targetEffectsOnHit":[{"type":"SACRIFICE_ATTACK_FOR_DEFENSE_PENALTY","defense":"reflex","value":-5,"duration":"untilEndOfTargetNextTurn"}],"summary":"Once per turn, sacrifice a provoked AoO to reduce target Reflex by 5 until end of target next turn."}],"status":"improved_opportunistic_trickery_phase12","description":"Sacrifice an AoO to reduce target Reflex by 5; not an attack bonus."},"shortSummary":"Sacrifice Attack of Opportunity to reduce target's Reflex Defense by 5.","prerequisitesText":"Combat Reflexes, Opportunistic Trickery","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Improved_Opportunistic_Trickery","effect":"Whenever an opponent provokes an\nAttack of Opportunity\nfrom you, once per turn you can sacrifice the attack to reduce the target's\nReflex Defense\nby 5 until the end of the target's next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.improved_opportunistic_trickery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improved_Opportunistic_Trickery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"bcc7f3fe56008a28","name":"Unleashed","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can activate Unleashed Abilities by spending a Destiny Point. You must also have the Force Sensitivity Feat in order to activate Force Unleashed Abilities for Force Powers and Force Talents.","prerequisite":"Have a Destiny, Receive the Gamemaster's Approval","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":37,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Have a<br>Destiny<br>, Receive the Gamemaster&#x27;s Approval</p>\n<p><strong>Effect:</strong> You can activate<br>Unleashed Abilities<br>by spending a<br>Destiny Point<br>. You must also have the<br>Force Sensitivity<br>Feat in order to activate<br>Force Unleashed Abilities<br>for<br>Force Powers<br>and<br>Force Talents<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Unleashed</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"grant_unlock","applicationScope":"unleashed_ability_access","staticSheetPolicy":"capability_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Unleashed: unlocks Unleashed Abilities that spend Destiny Points; Force Unleashed abilities still require Force Sensitivity.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"unlock_metadata_phase16","description":"Unleashed: unlocks Unleashed Abilities that spend Destiny Points; Force Unleashed abilities still require Force Sensitivity.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Unleashed: unlocks Unleashed Abilities that spend Destiny Points; Force Unleashed abilities still require Force Sensitivity.","mechanicsMode":"metadata_only","applicationScope":"unleashed_ability_access","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"SYSTEM_ACCESS","key":"unleashed_abilities","resource":"destinyPoint","requiresForceSensitivityForForceAbilities":true,"description":"Can activate Unleashed Abilities by spending a Destiny Point."}]},"shortSummary":"Unlocks Unleashed Abilities.","prerequisitesText":"Have a Destiny, Receive the Gamemaster's Approval","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Unleashed","effect":"You can activate\nUnleashed Abilities\nby spending a\nDestiny Point\n. You must also have the\nForce Sensitivity\nFeat in order to activate\nForce Unleashed Abilities\nfor\nForce Powers\nand\nForce Talents\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.unleashed","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Unleashed","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"be1346b0cfb5ea78","name":"Regenerative Healing","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Regain more Hit Points (but more slowly) when you catch a Second Wind.","prerequisite":"Trandoshan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["durability","execution_mapped_phase8","feat","hit_points","racial","recovery","resource_second_wind","second_wind","species","species_opportunity"],"bonus_feat_for":["species-trandoshan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trandoshan</p>\n<p><strong>Effect:</strong> Once per day when you catch a<br>Second Wind<br>, you can regain no Hit Points immediately and instead regain 5 Hit Points at the end of each of your turns until you reach full Hit Points or until the end of the encounter (whichever comes first).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Regenerative_Healing</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":false,"priority":500,"description":"Regenerative Healing is a Second Wind/resource rule, not an attack modifier.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit"],"conditionSummary":"Regenerative Healing is a Second Wind/resource rule, not an attack modifier."}],"mechanicsMode":"conditional","applicationScope":"secondWind_resource","staticSheetPolicy":"resource_only","requiresRuntimeContext":true,"requiresSelectedChoice":true,"conditionSummary":"Optional delayed healing mode: 5 HP per turn until full HP or encounter end.","predicateRequirements":["attack.when-hit"],"metadataPhase":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics.","status":"second_wind_rule_phase8_partial","description":"Regenerative Healing: delayed Second Wind healing is recorded as a flag for turn/end-of-encounter handling.","resourceRules":{"secondWind":[{"type":"DELAYED_HEALING_ON_USE","amountPerTurn":5,"oncePer":"day","limit":"fullHpOrEncounterEnd","source":"Regenerative Healing","description":"Once per day, receive no immediate healing and heal 5 HP at end of each turn until full HP or encounter end."}]}},"shortSummary":"Regain more Hit Points (but more slowly) when you catch a Second Wind.","sourceUrl":"https://swse.fandom.com/wiki/Regenerative_Healing","rawImport":{"name":"Regenerative Healing","url":"https://swse.fandom.com/wiki/Regenerative_Healing","pageTitle":"Regenerative_Healing","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\regenerative_healing.html","referenceBooks":[],"prerequisitesText":"Trandoshan","prerequisites":["Trandoshan"],"effect":"Once per day when you catch a\nSecond Wind\n, you can regain no Hit Points immediately and instead regain 5 Hit Points at the end of each of your turns until you reach full Hit Points or until the end of the encounter (whichever comes first).","benefit":"","normal":"","special":"","indexPrerequisites":"Trandoshan","indexBenefit":"Regain more Hit Points (but more slowly) when you catch a Second Wind .","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYour natural regeneration can help you recuperate from wounds more quickly.\n\nPrerequisite:\nTrandoshan\n\nEffect:\nOnce per day when you catch a\nSecond Wind\n, you can regain no Hit Points immediately and instead regain 5 Hit Points at the end of each of your turns until you reach full Hit Points or until the end of the encounter (whichever comes first)."},"prerequisitesText":"Trandoshan","effect":"Once per day when you catch a\nSecond Wind\n, you can regain no Hit Points immediately and instead regain 5 Hit Points at the end of each of your turns until you reach full Hit Points or until the end of the encounter (whichever comes first)."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.regenerative_healing"}}}
{"_id":"be1b2f8015c971a5","name":"Increased Agility","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You increase your Climb Speed, Swim Speed and Jump distance by +2 squares and do not lose your Dexterity bonus to Reflex Defense when climbing.","prerequisite":"Conditioning","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":27,"tags":["feat","general","skill_climb","skill_jump","skill_swim","skill_synergy"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Conditioning</p>\n<p><strong>Effect:</strong> You increase your Climb Speed, Swim Speed and Jump distance by +2 squares and do not lose your<br>Dexterity<br>bonus to<br>Reflex Defense<br>when climbing.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Increased_Agility</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_capability","applicationScope":"movement_climb_swim_jump_context","staticSheetPolicy":"derived_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Increased Agility: +2 squares to Climb Speed, Swim Speed, and Jump distance; retain Dex bonus while climbing.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"movement_capability_metadata_phase16","description":"Increased Agility: +2 squares to Climb Speed, Swim Speed, and Jump distance; retain Dex bonus while climbing.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Increased Agility: +2 squares to Climb Speed, Swim Speed, and Jump distance; retain Dex bonus while climbing.","mechanicsMode":"metadata_only","applicationScope":"movement_climb_swim_jump_context","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"MOVEMENT_MODE_BONUS","modes":["climb","swim"],"value":2,"unit":"squares","description":"+2 squares to Climb and Swim speeds."},{"type":"JUMP_DISTANCE_BONUS","value":2,"unit":"squares","description":"+2 squares to Jump distance."},{"type":"RETAIN_DEX_TO_REFLEX_WHILE_CLIMBING","description":"Do not lose Dexterity bonus to Reflex Defense while climbing."}]},"shortSummary":"Increase Climb Speed, Swim Speed, and Jump distance by 2 squares.","prerequisitesText":"Conditioning","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Increased_Agility","effect":"You increase your Climb Speed, Swim Speed and Jump distance by +2 squares and do not lose your\nDexterity\nbonus to\nReflex Defense\nwhen climbing."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":[],"id":"swse.feat.increased_agility","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Increased_Agility","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"bee76d01da40677d","name":"Lightning Reflexes","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus to your Reflex Defense.","prerequisite":"None","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["defense","feat","general","survivability"],"bonus_feat_for":["b5bed5d1b5f42958","f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.reflex","type":"untyped","value":2,"enabled":true,"priority":500,"description":"Migrated from AE system.defenses.reflex.bonus","mechanicsMode":"passive","applicationScope":"static_actor","staticSheetPolicy":"include","requiresRuntimeContext":false,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"Always-on bonus to Reflex Defense."}],"mechanicsMode":"passive","applicationScope":"static_actor","staticSheetPolicy":"include","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Always-on bonus to Reflex Defense.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"You gain a +2 bonus to your Reflex Defense."},"effects":[{"name":"Lightning Reflexes","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.reflex.bonus","mode":2,"value":"2","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"defense-bonus","defense":"reflex","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"bf6c01fa590a3f75","name":"Biotech Specialist","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can modify a Biotech device, suit of armor, weapon, or Vehicle so that it gains a specific trait. You can perform only one modification at a time. Unless noted otherwise, you cannot grant more than one benefit to a single device, suit of armor, weapon, or Vehicle, and you cannot apply the same benefit more than once.\n\nBefore beginning the modification, you must pay one tenth the cost of the device, suit of armor, weapon, or Vehicle you wish to modify or 1,000 credits, whichever is more. Completing the modification requires one day per 1,000 credits of the modification cost. At the end of this time, make a DC 20 Mechanics check; you can't Take 10 or Take 20 on this check. If the check succeeds, the modification is completed successfully, and the object gains the desired trait. If the check fails, you lose all credits spent making the modification, and the object doesn't gain the desired trait. However, you may start over if you wish.\n\nDue to the specialized nature of Biotechnology, only other characters with the Biotech Specialist Feat can assist you, reducing proportionately the time needed to complete the modification. At the end of the modification process, they can make a Mechanics check to aid your check.\n\nThe market value of a modified item is equal to the base cost of the item + double the cost of the modifications made to it (not including credits wasted on failed attempts).\n\nARMOR TRAITS | BENEFIT\nAgile Armor | The armor's maximum Dexterity bonus increases by 1.\nFortifying Armor | The armor's Equipment bonus to Fortitude Defense increases by 1.\nProtective Armor | The armor's Armor bonus to Reflex Defense increases by 1.\nDEVICE TRAITS | BENEFIT\nAdd Device to Creature | Alter a bioengineered creature to accept a biotech or standard technological enhancement such as a miniaturized Sensor Pack.\nEnhanced Strength | Increase the device's Strength score by 2.\nImproved Durability | The device's Damage Reduction increases by 1, and it gains extra Hit Points equal to one-quarter of its maximum Hit Points.\nMastercraft Device | Skill Checks made using the device gain a +1 Equipment bonus, or the device's existing Equipment bonus increases by 1.\nVEHICLE TRAITS | BENEFIT\nDovin Basal Enhancement | Increase the effects of a Dovin Basal to grant one of the following benefits to a Starship: +1 additional square of movement at Starship Scale, +2 SR, or +1 die of damage when using a Dovin Basal.\nEnhanced Dexterity | Increase the Vehicle's Dexterity score by 2.\nImproved Speed | Increase the Vehicle's Speed by one-quarter of its base Speed (minimum 1 square).\nWEAPON TRAITS | BENEFIT\nImproved Accuracy | The weapon gains a +1 Equipment bonus on attack rolls.\nImproved Damage | The weapon deals +2 points of damage with a successful hit. If the weapon has a damage multiplier (for example, 6d10x2), apply the extra damage before applying the multiplier.\nSelective Fire | An Autofire -only ranged weapon can be set to fire single shots, or a single-shot weapon can be made to have an Autofire mode. This cannot be applied to weapons that have a Burst radius or Splash radius.","prerequisite":"Trained in Mechanics","special":"This Feat allows you to make Treat Injury checks on Biotechnology without the normal -5 penalty.","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":16,"tags":["feat","general","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Mechanics</p>\n<p><strong>Effect:</strong> You can modify a<br>Biotech<br>device, suit of armor, weapon, or<br>Vehicle<br>so that it gains a specific trait. You can perform only one modification at a time. Unless noted otherwise, you cannot grant more than one benefit to a single device, suit of armor, weapon, or<br>Vehicle<br>, and you cannot apply the same benefit more than once.<br><br>Before beginning the modification, you must pay one tenth the cost of the device, suit of armor, weapon, or<br>Vehicle<br>you wish to modify or 1,000 credits, whichever is more. Completing the modification requires one day per 1,000 credits of the modification cost. At the end of this time, make a DC 20<br>Mechanics<br>check; you can&#x27;t<br>Take 10<br>or<br>Take 20<br>on this check. If the check succeeds, the modification is completed successfully, and the object gains the desired trait. If the check fails, you lose all credits spent making the modification, and the object doesn&#x27;t gain the desired trait. However, you may start over if you wish.<br><br>Due to the specialized nature of<br>Biotechnology<br>, only other characters with the<br>Biotech Specialist<br>Feat can assist you, reducing proportionately the time needed to complete the modification. At the end of the modification process, they can make a<br>Mechanics<br>check to aid your check.<br><br>The market value of a modified item is equal to the base cost of the item + double the cost of the modifications made to it (not including credits wasted on failed attempts).<br><br>ARMOR TRAITS | BENEFIT<br>Agile Armor | The armor&#x27;s maximum Dexterity bonus increases by 1.<br>Fortifying Armor | The armor&#x27;s Equipment bonus to Fortitude Defense increases by 1.<br>Protective Armor | The armor&#x27;s Armor bonus to Reflex Defense increases by 1.<br>DEVICE TRAITS | BENEFIT<br>Add Device to Creature | Alter a bioengineered creature to accept a biotech or standard technological enhancement such as a miniaturized Sensor Pack .<br>Enhanced Strength | Increase the device&#x27;s Strength score by 2.<br>Improved Durability | The device&#x27;s Damage Reduction increases by 1, and it gains extra Hit Points equal to one-quarter of its maximum Hit Points.<br>Mastercraft Device | Skill Checks made using the device gain a +1 Equipment bonus, or the device&#x27;s existing Equipment bonus increases by 1.<br>VEHICLE TRAITS | BENEFIT<br>Dovin Basal Enhancement | Increase the effects of a Dovin Basal to grant one of the following benefits to a Starship: +1 additional square of movement at Starship Scale , +2 SR, or +1 die of damage when using a Dovin Basal .<br>Enhanced Dexterity | Increase the Vehicle&#x27;s Dexterity score by 2.<br>Improved Speed | Increase the Vehicle&#x27;s Speed by one-quarter of its base Speed (minimum 1 square).<br>WEAPON TRAITS | BENEFIT<br>Improved Accuracy | The weapon gains a +1 Equipment bonus on attack rolls.<br>Improved Damage | The weapon deals +2 points of damage with a successful hit. If the weapon has a damage multiplier (for example, 6d10x2), apply the extra damage before applying the multiplier.<br>Selective Fire | An Autofire -only ranged weapon can be set to fire single shots, or a single-shot weapon can be made to have an Autofire mode. This cannot be applied to weapons that have a Burst radius or Splash radius.</p>\n<p><strong>Special:</strong> This Feat allows you to make<br>Treat Injury<br>checks on<br>Biotechnology<br>without the normal -5 penalty.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Biotech_Specialist</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"745a5686d6f21e8c"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"deferred_major_ui","applicationScope":"customization_picker_required","staticSheetPolicy":"deferred","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Biotech Specialist is a custom biotechnology modification system and needs dedicated modification UI/picker support rather than fake passive modifiers.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"deferred_major_ui_picker","description":"Biotech Specialist is a custom biotechnology modification system and needs dedicated modification UI/picker support rather than fake passive modifiers.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Biotech Specialist is a custom biotechnology modification system and needs dedicated modification UI/picker support rather than fake passive modifiers.","mechanicsMode":"metadata_only","applicationScope":"customization_picker_required","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"customizationCapabilities":[{"type":"DEFERRED_CUSTOMIZATION_PICKER","requiresDedicatedUi":true,"description":"Biotech Specialist is a custom biotechnology modification system and needs dedicated modification UI/picker support rather than fake passive modifiers."}]},"shortSummary":"Make custom modifications to Yuuzhan Vong Biotech.","prerequisitesText":"Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Biotech_Specialist","effect":"You can modify a\nBiotech\ndevice, suit of armor, weapon, or\nVehicle\nso that it gains a specific trait. You can perform only one modification at a time. Unless noted otherwise, you cannot grant more than one benefit to a single device, suit of armor, weapon, or\nVehicle\n, and you cannot apply the same benefit more than once.\n\nBefore beginning the modification, you must pay one tenth the cost of the device, suit of armor, weapon, or\nVehicle\nyou wish to modify or 1,000 credits, whichever is more. Completing the modification requires one day per 1,000 credits of the modification cost. At the end of this time, make a DC 20\nMechanics\ncheck; you can't\nTake 10\nor\nTake 20\non this check. If the check succeeds, the modification is completed successfully, and the object gains the desired trait. If the check fails, you lose all credits spent making the modification, and the object doesn't gain the desired trait. However, you may start over if you wish.\n\nDue to the specialized nature of\nBiotechnology\n, only other characters with the\nBiotech Specialist\nFeat can assist you, reducing proportionately the time needed to complete the modification. At the end of the modification process, they can make a\nMechanics\ncheck to aid your check.\n\nThe market value of a modified item is equal to the base cost of the item + double the cost of the modifications made to it (not including credits wasted on failed attempts).\n\nARMOR TRAITS | BENEFIT\nAgile Armor | The armor's maximum Dexterity bonus increases by 1.\nFortifying Armor | The armor's Equipment bonus to Fortitude Defense increases by 1.\nProtective Armor | The armor's Armor bonus to Reflex Defense increases by 1.\nDEVICE TRAITS | BENEFIT\nAdd Device to Creature | Alter a bioengineered creature to accept a biotech or standard technological enhancement such as a miniaturized Sensor Pack .\nEnhanced Strength | Increase the device's Strength score by 2.\nImproved Durability | The device's Damage Reduction increases by 1, and it gains extra Hit Points equal to one-quarter of its maximum Hit Points.\nMastercraft Device | Skill Checks made using the device gain a +1 Equipment bonus, or the device's existing Equipment bonus increases by 1.\nVEHICLE TRAITS | BENEFIT\nDovin Basal Enhancement | Increase the effects of a Dovin Basal to grant one of the following benefits to a Starship: +1 additional square of movement at Starship Scale , +2 SR, or +1 die of damage when using a Dovin Basal .\nEnhanced Dexterity | Increase the Vehicle's Dexterity score by 2.\nImproved Speed | Increase the Vehicle's Speed by one-quarter of its base Speed (minimum 1 square).\nWEAPON TRAITS | BENEFIT\nImproved Accuracy | The weapon gains a +1 Equipment bonus on attack rolls.\nImproved Damage | The weapon deals +2 points of damage with a successful hit. If the weapon has a damage multiplier (for example, 6d10x2), apply the extra damage before applying the multiplier.\nSelective Fire | An Autofire -only ranged weapon can be set to fire single shots, or a single-shot weapon can be made to have an Autofire mode. This cannot be applied to weapons that have a Burst radius or Splash radius."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":[],"id":"swse.feat.biotech_specialist","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Biotech_Specialist","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"bf71e5f4171547ef","name":"Instinctive Perception","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a temporary Force Point when your Perception reroll is lower.","prerequisite":"Zabrak","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","force_point_spend","racial","reroll","resource_spend","skill_perception","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-zabrak"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Zabrak</p>\n<p><strong>Effect:</strong> Whenever you reroll a<br>Perception<br>check and take the second result, if your second result is lower than your first result, you gain a temporary<br>Force Point<br>. This<br>Force Point<br>can be spent only to add to the result of a<br>Perception<br>check, and if it is not spent before the end of the encounter, it is lost.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Instinctive_Perception</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Perception reroll with temporary Force Point rider if the reroll is lower.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"skill_roll_trigger_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Perception reroll with temporary Force Point rider if the reroll is lower.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementatio