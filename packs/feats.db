{"_id":"d40dea327376ec90","name":"Bothan Will","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Will Defense when an enemy fails to overcome your iron will.","prerequisite":"Bothan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["defense","feat","racial","species","species_opportunity","survivability"],"bonus_feat_for":["species-bothan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Bothan</p>\n<p><strong>Effect:</strong> Whenever an attack or<br>Skill Check<br>targets your<br>Will Defense<br>and fails to equal or exceed it, you gain a +2 circumstance bonus to your<br>Will Defense<br>until the start of your next turn</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Bothan_Will</em></p>","executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.will","type":"untyped","value":1,"enabled":true,"priority":500,"description":"Migrated from AE system.defenses.will.misc","predicates":["trigger.enemy-failed-will"],"mechanicsMode":"conditional","applicationScope":"triggered_will_defense_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["trigger.enemy-failed-will"],"conditionSummary":"Triggers from the specific Bothan Will circumstance; it is not a permanent Will Defense increase."}],"mechanicsMode":"conditional","applicationScope":"triggered_will_defense_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Triggers from the specific Bothan Will circumstance; it is not a permanent Will Defense increase.","predicateRequirements":["trigger.enemy-failed-will"],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Gain a bonus to Will Defense when an enemy fails to overcome your iron will.","sourceUrl":"https://swse.fandom.com/wiki/Bothan_Will","rawImport":{"name":"Bothan Will","url":"https://swse.fandom.com/wiki/Bothan_Will","pageTitle":"Bothan_Will","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\bothan_will.html","referenceBooks":[],"prerequisitesText":"Bothan","prerequisites":["Bothan"],"effect":"Whenever an attack or\nSkill Check\ntargets your\nWill Defense\nand fails to equal or exceed it, you gain a +2 circumstance bonus to your\nWill Defense\nuntil the start of your next turn","benefit":"","normal":"","special":"","indexPrerequisites":"Bothan","indexBenefit":"Gain a bonus to Will Defense when an enemy fails to overcome your iron will.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou epitomize the legendary willpower and resolve of the\nBothan\npeople.\n\nPrerequisite:\nBothan\n\nEffect:\nWhenever an attack or\nSkill Check\ntargets your\nWill Defense\nand fails to equal or exceed it, you gain a +2 circumstance bonus to your\nWill Defense\nuntil the start of your next turn"},"prerequisitesText":"Bothan","effect":"Whenever an attack or\nSkill Check\ntargets your\nWill Defense\nand fails to equal or exceed it, you gain a +2 circumstance bonus to your\nWill Defense\nuntil the start of your next turn"},"effects":[{"_id":"5e3995c0-0142-45f4-a0d7-27e1f0f89562","name":"Bothan Will","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.will.misc","mode":2,"value":"1"}],"disabled":true,"duration":{},"flags":{"swse":{"source":"feat","featName":"Bothan Will","effectType":"will_defense_bonus","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.bothan_will"}}}
{"_id":"d41076e442832c3e","name":"Natural Leader","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You become the leader of an Organization of your design. The Organization has a scale equal to one-half your Heroic Level plus your Charisma bonus and continues to grow in scale as you gain levels. You automatically begin with a +10 bonus to your Organization Score for your new Organization.","prerequisite":"Charisma 13","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","social"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Charisma<br>13</p>\n<p><strong>Effect:</strong> You become the leader of an<br>Organization<br>of your design. The<br>Organization<br>has a scale equal to one-half your Heroic Level plus your<br>Charisma<br>bonus and continues to grow in scale as you gain levels. You automatically begin with a +10 bonus to your<br>Organization Score<br>for your new<br>Organization<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Natural_Leader</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"cha","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":1,"type":"untyped","predicates":["turn.once-per-round"],"enabled":false,"priority":500,"description":"Natural Leader: Natural Leader is organization metadata, not a skill modifier.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["turn.once-per-round"],"conditionSummary":"Natural Leader is organization metadata, not a skill modifier.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"non_numeric_rule","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Natural Leader is organization metadata, not a skill modifier.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","organizationRules":[{"type":"CREATE_ORGANIZATION","scaleFormula":"halfHeroicLevel+chaMod","organizationScoreBonus":10,"description":"Create an organization with scale equal to half heroic level plus Charisma modifier and +10 Organization Score."}],"status":"organization_rule_phase10","description":"Natural Leader is organization metadata, not a skill modifier."},"shortSummary":"You become the leader of an Organization.","prerequisitesText":"Charisma 13","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Natural_Leader","effect":"You become the leader of an\nOrganization\nof your design. The\nOrganization\nhas a scale equal to one-half your Heroic Level plus your\nCharisma\nbonus and continues to grow in scale as you gain levels. You automatically begin with a +10 bonus to your\nOrganization Score\nfor your new\nOrganization\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.natural_leader","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Natural_Leader","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d445051370a88a7f","name":"Armor Proficiency (medium)","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you wear Medium Armor, you take no Armor Check Penalty on attack rolls or Skill Checks. Additionally, you benefit from all of the armor's special Equipment bonuses (if any).","prerequisite":"Armor Proficiency (Light) Feat","special":"","normalText":"A character who wears Medium Armor with which they are not proficient takes a -5 Armor Check Penalty on attack rolls as well as Skill Checks made using the following Skills: Acrobatics, Climb, Endurance, Initiative, Jump, Stealth, and Swim. Additionally, the character gains none of the armor's special Equipment bonuses.","sourcebook":"Saga Edition Core Rulebook","page":85,"tags":["armor","build_enabler","defense","feat","general","mapped_phase_1","unlock_grant","choice_variant","armor_access"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Armor_Proficiency_(Medium)</p>\n<p>You are proficient with Medium Armor, and can wear it without impediment.</p>\n<p><strong>Prerequisites:</strong> Armor Proficiency (Light) Feat</p>\n<h4>Effect</h4>\n<p>When you wear Medium Armor, you take no Armor Check Penalty on attack rolls or Skill Checks. Additionally, you benefit from all of the armor&#x27;s special Equipment bonuses (if any).</p>\n<h4>Normal</h4>\n<p>A character who wears Medium Armor with which they are not proficient takes a -5 Armor Check Penalty on attack rolls as well as Skill Checks made using the following Skills: Acrobatics, Climb, Endurance, Initiative, Jump, Stealth, and Swim. Additionally, the character gains none of the armor&#x27;s special Equipment bonuses.</p>\n</div>"},"executionModel":"UNLOCK","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Grants medium armor proficiency; armor penalty/equipment bonus handling consumes proficiency state.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"grant","applicationScope":"proficiency_grant","staticSheetPolicy":"exclude","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Grants medium armor proficiency; armor penalty/equipment bonus handling consumes proficiency state.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"proficiency_grant_metadata_phase14","proficiencyGrants":[{"type":"ARMOR_PROFICIENCY","armorCategory":"medium","description":"Grants proficiency with medium armor."}]},"choiceMeta":{"resolution":"already_resolved_static_variant","required":false,"choiceKind":"armor_proficiency","value":"medium","grants":["light","medium"]},"shortSummary":"No penalty on attacks and no Armor Check Penalty while wearing Light Armor or Medium Armor.","prerequisitesText":"Armor Proficiency (Light) Feat","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Armor_Proficiency_(Medium)"},"effects":[{"_id":"af0983df-e771-4593-8f88-f0aa43612597","name":"Armor Proficiency (Medium)","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.armorProficiency.medium","mode":5,"value":"true"}],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Armor Proficiency (Medium)","effectType":"armor_proficiency"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":[],"phase1Mapped":true,"manualMappingResolved":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Armor_Proficiency_(Medium)","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d48614f7ae500a5b","name":"Logic Upgrade: Skill Swap","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Swap a Trained Skill for an Untrained Skill on the fly.","prerequisite":"Droid, Basic Processor","special":"","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":22,"tags":["feat","general","knowledge","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Swap a Trained Skill for an Untrained Skill on the fly."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"choice_required","applicationScope":"selected_droid_skill_training","staticSheetPolicy":"include_selected_skill_training","requiresRuntimeContext":false,"requiresSelectedChoice":true,"conditionSummary":"Choose one untrained non-Use the Force skill during progression. The selected skill is treated as trained for this droid.","predicateRequirements":[],"metadataPhase":"phase22-force-regimen-skill-swap","metadataNotes":"Phase 22 implements Logic Upgrade: Skill Swap as a progression choice instead of a runtime-only deferred placeholder.","implementationStatus":"implemented_phase22_progression_choice","description":"Choose one untrained non-Use the Force skill. The selected skill is treated as trained for this droid.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Logic Upgrade: Skill Swap is resolved by the selected skill choice and derived skill training logic.","mechanicsMode":"metadata_only","applicationScope":"selected_droid_skill_training","staticSheetPolicy":"exclude","metadataPhase":"phase22-force-regimen-skill-swap"}],"skillUseRules":[{"type":"SELECTED_SKILL_TRAINING","choiceKind":"droid_untrained_skill","excludeSkills":["useTheForce"],"description":"Selected untrained droid skill counts as trained."}]},"shortSummary":"Choose one untrained non-Use the Forc