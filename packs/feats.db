{"_id":"e9d1e9099a3e4ecc","name":"Powerful Rage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +4 bonus to Strength checks and Strength -based Skill Checks when Raging.","prerequisite":"Rage Species Trait","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":35,"tags":["ability_strength","conditional_skill_bonus","execution_mapped_phase8","execution_mapped_phase9","feat","general","offense_melee","rage","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Powerful_Rage</p>\n<p>Your Rage produces feats of extreme strength.</p>\n<p><strong>Prerequisites:</strong> Rage Species Trait</p>\n<h4>Effect</h4>\n<p>You gain a +4 bonus to Strength checks and Strength -based Skill Checks when Raging.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rage_rule_phase9","description":"Powerful Rage: +4 on Strength checks and Strength-based skill checks while raging.","skillCheckBonuses":[{"id":"powerful-rage-strength-skills","skillKeys":["climb","jump","swim"],"value":4,"type":"untyped","requiresContextFlags":["raging"],"description":"Powerful Rage: +4 while raging."}],"rules":[{"type":"RAGE_STRENGTH_SKILL_BONUS","value":4,"skillKeys":["climb","jump","swim"],"description":"Gain +4 to Strength checks and Strength-based skill checks while raging."}]},"shortSummary":"Gain a +4 bonus on Strength checks and Strength -based Skill Checks.","prerequisitesText":"Rage Species Trait","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Powerful_Rage"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.powerful_rage","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Powerful_Rage","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ea684defcd3222ca","name":"Dual Weapon Mastery III","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you attack with two weapons, or with both ends of a double weapon as part of a Full Attack Action, you take no penalty on your attack rolls. You only gain this benefit if you are wielding a weapon with which you are proficient.","prerequisite":"Dexterity 17, Dual Weapon Mastery I, Dual Weapon Mastery II, Base Attack Bonus +11","special":"","normalText":"If you use a Full Attack Action to make more than one attack on your turn, you take a -10 penalty on all attack rolls for the round.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["action_economy","dual_wield","feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Dual_Weapon_Mastery_III</p>\n<p>You can wield two weapons or a double weapon without penalty.</p>\n<p><strong>Prerequisites:</strong> Dexterity 17, Dual Weapon Mastery I, Dual Weapon Mastery II, Base Attack Bonus +11</p>\n<h4>Effect</h4>\n<p>When you attack with two weapons, or with both ends of a double weapon as part of a Full Attack Action, you take no penalty on your attack rolls. You only gain this benefit if you are wielding a weapon with which you are proficient.</p>\n<h4>Normal</h4>\n<p>If you use a Full Attack Action to make more than one attack on your turn, you take a -10 penalty on all attack rolls for the round.</p>\n<h4>Additional Dual Weapon Mastery III Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p>Vehicle Weapons cannot be used in one hand, so this Feat has no effect on them.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":17},{"type":"bab","min":11}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Dual Weapon Mastery III"}]},"shortSummary":"Take no penalty on attacks when attacking with two weapons, or both ends of a double weapon.","prerequisitesText":"Dexterity 17, Dual Weapon Mastery I, Dual Weapon Mastery II, Base Attack Bonus +11","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Dual_Weapon_Mastery_III"},"effects":[{"_id":"8937b074-f7ef-40fa-889c-85578fc3e023","name":"Dual Weapon Mastery III","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Dual Weapon Mastery III","effectType":"passive_effect","flagType":"Dual Weapon Mastery III"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.dual_weapon_mastery_iii","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Dual_Weapon_Mastery_III","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"eaf7079b977d60b7","name":"Darkness Dweller","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Impose a penalty to Stealth checks made when close to you.","prerequisite":"Sullustan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","skill_stealth","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-sullustan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Impose a penalty to Stealth checks made when close to you."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Darkness Dweller"}]},"shortSummary":"Impose a penalty to Stealth checks made when close to you."},"effects":[{"_id":"1b28fe0a-2045-4172-866e-4a81cd6a662d","name":"Darkness Dweller","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Darkness Dweller","effectType":"passive_effect","flagType":"Darkness Dweller"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.darkness_dweller"}}}
{"_id":"eb33f5e4b5f6318c","name":"Surgical Precision","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Treat Injury checks and may reroll a failed check once per encounter.","prerequisite":"Trained in Treat Injury","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["feat","general","healing","skill_treat_injury","support"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":true,"priority":500,"description":"Surgical Precision"}]},"shortSummary":"You gain a +2 bonus on Treat Injury checks and may reroll a failed check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["turn.once-per-round"]}}}
{"_id":"ebe730776cd3e310","name":"Fatal Hit","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When your attack drops a target to 0 Hit Points, you may choose to automatically kill that enemy even if the damage does not exceed the target's Damage Threshold. In addition, you can perform the Coup de Grace Action as a Standard Action.","prerequisite":"Strength 13, Dexterity 13","special":"","normalText":"A creature that drops below 0 Hit Points becomes Unconscious if the damage dealt does not exceed its Damage Threshold. Performing a Coup de Grace is a Full-Round Action.","sourcebook":"Legacy Era Campaign Guide","page":18,"tags":["ally_support","durability","feat","general","hit_points","standard_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Fatal_Hit</p>\n<p>Enemies you take down don&#x27;t get up again.</p>\n<p><strong>Prerequisites:</strong> Strength 13, Dexterity 13</p>\n<h4>Effect</h4>\n<p>When your attack drops a target to 0 Hit Points, you may choose to automatically kill that enemy even if the damage does not exceed the target&#x27;s Damage Threshold. In addition, you can perform the Coup de Grace Action as a Standard Action.</p>\n<h4>Normal</h4>\n<p>A creature that drops below 0 Hit Points becomes Unconscious if the damage dealt does not exceed its Damage Threshold. Performing a Coup de Grace is a Full-Round Action.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13},{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Fatal Hit"}]},"shortSummary":"You automatically kill an enemy that you reduce to 0 Hit Points, and you can perform a Coup de Grace as a Standard Action.","prerequisitesText":"Strength 13, Dexterity 13","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Fatal_Hit"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.fatal_hit","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fatal_Hit","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ec8b6bb889f65dea","name":"Imperceptible Liar","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Increase the die type when adding Force Points to a Deception check.","prerequisite":"Twi'lek","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","force_point_spend","racial","resource_spend","skill_deception","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-twi-lek"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Increase the die type when adding Force Points to a Deception check."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Imperceptible Liar"}]},"shortSummary":"Increase the die type when adding Force Points to a Deception check."},"effects":[{"_id":"c7c4131d-2bcf-47cc-b358-46adefddbda8","name":"Imperceptible Liar","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Imperceptible Liar","effectType":"special","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.imperceptible_liar"}}}
{"_id":"ecc2471ac96ec2d4","name":"Weapon Proficiency","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one Weapon Group. You are proficient with all weapons of the selected group. Weapon Groups include the following:\n\n- Simple Weapons (includes Simple Weapons (Melee), Simple Weapons (Ranged), and Grenades)\n- Pistols\n- Rifles\n- Lightsabers\n- Heavy Weapons (includes both Heavy Weapons and Vehicle Weapons)\n- Advanced Melee Weapons","prerequisite":"None","special":"You can gain this Feat multiple times. Each time you take the Feat, it applies to a different Weapon Group. You cannot take Exotic Weapons as a weapon group; instead you must select the Exotic Weapon Proficiency Feat to gain proficiency with a specific Exotic Weapon.","normalText":"If you wield a weapon with which you are not proficient, you take a -5 penalty to your attack rolls.","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["build_enabler","feat","general","offense","weapon_access","choice_required","immediate_choice","weapon_choice","repeatable_choice","choice_source_fixed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Weapon_Proficiency</p>\n<p>You are proficient with a particular kind of weaponry.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Choose one Weapon Group. You are proficient with all weapons of the selected group. Weapon Groups include the following:</p>\n<ul><li>Simple Weapons (includes Simple Weapons (Melee), Simple Weapons (Ranged), and Grenades)</li><li>Pistols</li><li>Rifles</li><li>Lightsabers</li><li>Heavy Weapons (includes both Heavy Weapons and Vehicle Weapons)</li><li>Advanced Melee Weapons</li></ul>\n<h4>Normal</h4>\n<p>If you wield a weapon with which you are not proficient, you take a -5 penalty to your attack rolls.</p>\n<h4>Special</h4>\n<p>You can gain this Feat multiple times. Each time you take the Feat, it applies to a different Weapon Group. You cannot take Exotic Weapons as a weapon group; instead you must select the Exotic Weapon Proficiency Feat to gain proficiency with a specific Exotic Weapon.</p>\n<h4>Additional Weapon Proficiency</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Quick Draw): You can draw and ignite your Lightsaber as a single Swift Action.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Weapon Proficiency"}]},"choiceMeta":{"resolution":"immediate","required":true,"status":"tagged_for_later_dialog_backfill","choiceKind":"weapon_proficiency","repeatable":true,"optionRegistry":"data/feat-choice-options.json#weapon_proficiency","storagePath":"flags.swse.choices.weaponProficiency","notes":"Single grouped feat. Dialog should show weapon groups; choosing exotic opens melee/ranged and then a specific exotic weapon.","choiceSource":"fixed","provides":"weapon_proficiency","resultShape":"weapon_group_or_exotic_weapon"},"shortSummary":"Ignore -5 penalty on attack rolls with weapons of a particular type.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Weapon_Proficiency"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.weapon_proficiency","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Weapon_Proficiency","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"eccb2b4dbdbfa324","name":"Bone Crusher","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you deal damage to a Grappled opponent, the opponent also moves -1 step along the Condition Track.","prerequisite":"Crush, Pin","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":15,"tags":["condition_track","control","feat","general","grapple","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Bone_Crusher</p>\n<p>You are skilled at dealing lasting damage to Grappled opponents.</p>\n<p><strong>Prerequisites:</strong> Crush, Pin</p>\n<h4>Effect</h4>\n<p>When you deal damage to a Grappled opponent, the opponent also moves -1 step along the Condition Track.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Bone Crusher"}]},"shortSummary":"Move damaged Grappled opponent -1 step on the Condition Track.","prerequisitesText":"Crush, Pin","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Bone_Crusher"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.bone_crusher","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Bone_Crusher","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"edd8bb64c18d9a8a","name":"Clawed Subspecies","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Deal damage with sharp claws on Unarmed attacks.","prerequisite":"Quarren","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","feat","offense_melee","racial","species","species_opportunity","species_rule","unarmed"],"bonus_feat_for":["species-quarren"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Deal damage with sharp claws on Unarmed attacks."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_hook","description":"Clawed Subspecies: natural claw damage on unarmed attacks. Damage amount is exposed as a rule hook for unarmed/natural-weapon consumers.","rules":[{"type":"NATURAL_WEAPON_UNLOCK","naturalWeapon":"claws","attackFamily":"unarmed","description":"Deal damage with sharp claws on Unarmed attacks.","displayAsCondition":true,"displayLabel":"Clawed Subspecies","displayNote":"Claw natural weapon available for unarmed attacks."}]},"shortSummary":"Deal damage with sharp claws on Unarmed attacks."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.clawed_subspecies"}}}
{"_id":"ef64dc738a6afeeb","name":"Skill Challenge: Recovery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Treat a Skill Challenge as if it had the Recovery effect.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":26,"tags":["cover_play","defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Treat a Skill Challenge as if it had the Recovery effect."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Skill Challenge: Recovery"}]},"shortSummary":"Treat a Skill Challenge as if it had the Recovery effect."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.skill_challenge_recovery"}}}
{"_id":"f0afba1763ddff90","name":"Intimidator","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully use the Intimidate application of the Persuasion skill against a creature, instead of the normal results, the creature takes a -5 penalty to all Skill Checks (including Use the Force) and a -2 penalty to all attacks when you are within its line of sight, until the end of your next turn.\n\nIf aboard another Vehicle, your enemy must be able to see or detect your Vehicle.","prerequisite":"Trained in Persuasion","special":"You cannot use this Feat with the Maniacal Charge feat.","normalText":"","sourcebook":"Unknown Regions","page":25,"tags":["feat","general","social"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Intimidator</p>\n<p>When you Intimidate others, either physically or verbally, you shake their confidence so severely that it affects their performance.</p>\n<p><strong>Prerequisites:</strong> Trained in Persuasion</p>\n<h4>Effect</h4>\n<p>When you successfully use the Intimidate application of the Persuasion skill against a creature, instead of the normal results, the creature takes a -5 penalty to all Skill Checks (including Use the Force) and a -2 penalty to all attacks when you are within its line of sight, until the end of your next turn.</p>\n<p>If aboard another Vehicle, your enemy must be able to see or detect your Vehicle.</p>\n<h4>Special</h4>\n<p>You cannot use this Feat with the Maniacal Charge feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Intimidator"}]},"shortSummary":"When you successfully Intimidate, enemy takes -5 to Skill Checks and -2 to attack for one round.","prerequisitesText":"Trained in Persuasion","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Intimidator"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.intimidator","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Intimidator","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f2cbe2ac10195858","name":"Follow Through","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you deal enough damage to your opponent with a melee attack to reduce it to 0 Hit Points, you can immediately move up to your Speed. You can use this ability once per turn.","prerequisite":"None","special":"If you have the Cleave Feat, you can move up to your Speed before making the extra melee attack granted by the Cleave Feat.","normalText":"","sourcebook":"Jedi Academy Training Manual","page":28,"tags":["durability","feat","general","hit_points"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Jedi Academy Training Manual</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Follow_Through</p>\n<p>You have learned to take down an enemy with an attack and then use your momentum to dash across the battlefield.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>If you deal enough damage to your opponent with a melee attack to reduce it to 0 Hit Points, you can immediately move up to your Speed. You can use this ability once per turn.</p>\n<h4>Special</h4>\n<p>If you have the Cleave Feat, you can move up to your Speed before making the extra melee attack granted by the Cleave Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Follow Through"}]},"shortSummary":"Move when you reduce an enemy to 0 Hit Points.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Jedi Academy Training Manual"],"sourceUrl":"https://swse.fandom.com/wiki/Follow_Through"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.follow_through","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Follow_Through","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f313d17068d1cdea","name":"Informer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use your Perception modifier instead of your Gather Information modifier when making Gather Information checks. You are considered Trained in the Gather Information skill. If you are entitled to a Gather Information check reroll, you can reroll your Perception check instead (subject to the same circumstances and limitations).\n\nAdditionally, when you have favorable conditions for your Gather Information check (such as from operating on your home planet), you reduce by half the time it takes to make a Gather Information check.","prerequisite":"Trained in Perception","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":35,"tags":["feat","general","skill_gather_information","skill_perception","skill_synergy","social","skill_use_substitution","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Informer</p>\n<p>You are adept at prying into the affairs of others and dealing with those who are most interested in gaining that knowledge.</p>\n<p><strong>Prerequisites:</strong> Trained in Perception</p>\n<h4>Effect</h4>\n<p>You can use your Perception modifier instead of your Gather Information modifier when making Gather Information checks. You are considered Trained in the Gather Information skill. If you are entitled to a Gather Information check reroll, you can reroll your Perception check instead (subject to the same circumstances and limitations).</p>\n<p>Additionally, when you have favorable conditions for your Gather Information check (such as from operating on your home planet), you reduce by half the time it takes to make a Gather Information check.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"43c5941072ec78af"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_use_substitution_phase8","description":"Informer: Gather Information skill uses may be rolled with Perception instead.","skillUseSubstitutions":[{"id":"informer-gather-information-with-perception","fromSkill":"gatherInformation","toSkill":"perception","applications":["Gather Information","Quick Intel","Find Black Market Object","Analysis"],"description":"Use Perception for Gather Information skill uses."}]},"shortSummary":"Gather Information with Perception skill, and do it faster.","prerequisitesText":"Trained in Perception","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Informer"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.informer","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Informer","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f362e5a4ad0a98bd","name":"Echani Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"martial_arts","benefit":"You can double the damage bonus provided by your Strength modifier to Unarmed Attacks (minimum +1) provided you make only one Unarmed attack this turn.\n\nOnce per encounter when you deal damage to a target with an Unarmed Attack you may make an immediate Unarmed Attack against the target's Fortitude Defense as a Free Action; if successful, you knock your opponent to the ground (Prone) in their current square, provided they are no more than one size larger than you.","prerequisite":"Dexterity 13, Martial Arts I","special":"Targets gain a bonus to their Fortitude Defense against being knocked Prone based on their size: Large +5, Huge +10, Gargantuan +20, Colossal +50. Unusually stable creatures (such as those with four legs) gain a +5 bonus to their Fortitude Defense against being knock Prone as well.","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["control","feat","feat_chain","knock_prone","martial_arts","martial_style","offense_melee","unarmed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide; Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Echani_Training</p>\n<p>You are trained in Echani unarmed fighting techniques, giving you an advantage in hand-to-hand combat.</p>\n<p><strong>Prerequisites:</strong> Dexterity 13, Martial Arts I</p>\n<h4>Effect</h4>\n<p>You can double the damage bonus provided by your Strength modifier to Unarmed Attacks (minimum +1) provided you make only one Unarmed attack this turn.</p>\n<p>Once per encounter when you deal damage to a target with an Unarmed Attack you may make an immediate Unarmed Attack against the target&#x27;s Fortitude Defense as a Free Action; if successful, you knock your opponent to the ground (Prone) in their current square, provided they are no more than one size larger than you.</p>\n<h4>Special</h4>\n<p>Targets gain a bonus to their Fortitude Defense against being knocked Prone based on their size: Large +5, Huge +10, Gargantuan +20, Colossal +50. Unusually stable creatures (such as those with four legs) gain a +5 bonus to their Fortitude Defense against being knock Prone as well.</p>\n<h4>Additional Echani Training Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p>If you have the Echani Expertise Talent, whenever you score a Critical Hit with an Unarmed attack, the target is immediately knocked to the ground (Prone) in its current square, provided that the target is no more than one size larger than you</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"martialArtsFeat":true,"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":1,"type":"untyped","predicates":["defense.fortitude","attack.when-hit","turn.once-per-round","target.is-prone"],"enabled":true,"priority":500,"description":"Echani Training"}]},"shortSummary":"In Unarmed combat, increase damage, and knock opponent Prone on Critical Hit.","prerequisitesText":"Dexterity 13, Martial Arts I","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide","Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Echani_Training"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":["defense.fortitude","attack.when-hit","turn.once-per-round","target.is-prone"],"id":"swse.feat.echani_training","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Echani_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f401ac70ee67def1","name":"Impetuous Move","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you catch a Second Wind, you can choose to regain only half of the Hit Points you normally would with a Second Wind and immediately Move up to half of your Speed. This movement does not provoke Attacks of Opportunity.","prerequisite":"Constitution 13","special":"","normalText":"","sourcebook":"Scum and Villainy","page":25,"tags":["feat","general","recovery","second_wind"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Impetuous_Move</p>\n<p>You have an uncanny ability to call upon your reserves when you most need them.</p>\n<p><strong>Prerequisites:</strong> Constitution 13</p>\n<h4>Effect</h4>\n<p>When you catch a Second Wind, you can choose to regain only half of the Hit Points you normally would with a Second Wind and immediately Move up to half of your Speed. This movement does not provoke Attacks of Opportunity.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"con","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[]},"resourceRules":{"secondWind":[{"type":"GRANT_MOVEMENT_ON_USE"}]},"shortSummary":"Move when you catch a Second Wind.","prerequisitesText":"Constitution 13","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Impetuous_Move"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.impetuous_move","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Impetuous_Move","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f4604b0d477e5fe7","name":"Strafe","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make an Autofire attack, instead of attacking a 2-square-by-2-square area, you may attack a line 1 square wide and 4 squares long.","prerequisite":"Base Attack Bonus +1","special":"If you are using a Jet Pack, you can use the Strafe feat to make an Autofire attack against all squares you fly over.","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":36,"tags":["feat","general","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Strafe</p>\n<p>You can make a Strafing Attack without a Vehicle.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When you make an Autofire attack, instead of attacking a 2-square-by-2-square area, you may attack a line 1 square wide and 4 squares long.</p>\n<h4>Special</h4>\n<p>If you are using a Jet Pack, you can use the Strafe feat to make an Autofire attack against all squares you fly over.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["movement.while-moving"],"enabled":true,"priority":500,"description":"Strafe"}]},"shortSummary":"Attack multiple targets as you move past them.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Strafe"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":["movement.while-moving"],"id":"swse.feat.strafe","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Strafe","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f4e8244a4c8bb9a0","name":"Brink of Death","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you deal sufficient damage on an attack to kill a target, you may instead choose to reduce the target to 0 Hit Points, leaving it Unconscious but alive. Normal rules for being at 0 Hit Points apply.","prerequisite":"None","special":"","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":17,"tags":["durability","feat","general","hit_points"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Brink_of_Death</p>\n<p>You can take an enemy to the Brink of Death without killing them.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When you deal sufficient damage on an attack to kill a target, you may instead choose to reduce the target to 0 Hit Points, leaving it Unconscious but alive. Normal rules for being at 0 Hit Points apply.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Brink of Death"}]},"shortSummary":"Attacks that would kill your enemy reduces them to 0 Hit Points instead.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Brink_of_Death"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.brink_of_death","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Brink_of_Death","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f4f3706e393976b3","name":"Droid Focus","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Select a degree of Droid (1st-Degree, 2nd-Degree, 3rd-Degree, 4th-Degree, or 5th-Degree). You gain a +1 bonus to Deception, Mechanics, Perception, Persuasion, and Use Computer checks when used on or against a Droid of the selected degree, and a +1 bonus to all Defenses against attack rolls and Skill Checks made by Droids of the selected degree.","prerequisite":"Trained in Mechanics and Use Computer","special":"You can gain this Feat multiple times. Its effects do not stack. Each time you take this Feat, it applies to a different degree of Droid (1st-Degree, 2nd-Degree, 3rd-Degree, 4th-Degree, or 5th-Degree).","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":20,"tags":["feat","general","tech","utility","choice_required","immediate_choice","droid_choice","choice_source_fixed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Droid_Focus</p>\n<p>Choose a single degree of Droid (1st-Degree, 2nd-Degree, 3rd-Degree, 4th-Degree, or 5th-Degree). You are especially familiar with this class of Droid, gaining the listed bonuses while working on or against them.</p>\n<p><strong>Prerequisites:</strong> Trained in Mechanics and Use Computer</p>\n<h4>Effect</h4>\n<p>Select a degree of Droid (1st-Degree, 2nd-Degree, 3rd-Degree, 4th-Degree, or 5th-Degree). You gain a +1 bonus to Deception, Mechanics, Perception, Persuasion, and Use Computer checks when used on or against a Droid of the selected degree, and a +1 bonus to all Defenses against attack rolls and Skill Checks made by Droids of the selected degree.</p>\n<h4>Special</h4>\n<p>You can gain this Feat multiple times. Its effects do not stack. Each time you take this Feat, it applies to a different degree of Droid (1st-Degree, 2nd-Degree, 3rd-Degree, 4th-Degree, or 5th-Degree).</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Droid Focus"}]},"choiceMeta":{"resolution":"immediate","required":true,"status":"tagged_for_later_dialog_backfill","choiceKind":"droid_class_focus","repeatable":false,"storagePath":"flags.swse.choices.droid_class_focus","choiceSource":"fixed","optionRegistry":"data/feat-choice-options.json#choiceKinds.droid_class_focus"},"shortSummary":"+1 bonus to certain Skills and Defenses when dealing with a selected class of Droid.","prerequisitesText":"Trained in Mechanics and Use Computer","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Droid_Focus"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.droid_focus","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Droid_Focus","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f504c1a7962f08d8","name":"Friendly Fire Avoidance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You may choose to exclude a number of squares equal to your Dexterity modifier from the area of effect of your autofire attacks.","prerequisite":"Dex 13, Point Blank Shot","special":"","normalText":"","sourcebook":"Galaxy at War","page":25,"tags":["feat","general","offense"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Friendly Fire Avoidance"}]},"shortSummary":"You may choose to exclude a number of squares equal to your Dexterity modifier from the area of effect of your autofire attacks."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[]}}}
{"_id":"f59c9679c02b8896","name":"Metamorph","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Full-Round Action, you can change your mass when you use your Shapeshift Species Trait, increasing or decreasing your size by one step. You can maintain this form for a number of rounds per day equal to your Constitution score.\n\nIf you reduce your size to Small, you gain a +1 size bonus to your Reflex Defense and a +5 size bonus on Stealth checks, but your Carrying Capacity is three-quarters of what it was prior to your use of Metamorph.\n\nIf you increase your size to Large, you take a -1 penalty to your Reflex Defense and a -5 penalty on Stealth checks. However, your Carrying Capacity doubles, you gain a +5 size bonus to your Damage Threshold, and your Reach increases by 1 square.","prerequisite":"Constitution 13, Shapeshift Species Trait, Trained in Deception","special":"","normalText":"","sourcebook":"Scum and Villainy","page":26,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Metamorph</p>\n<p>You are a talented shapeshifter, capable of changing your appearance and body mass.</p>\n<p><strong>Prerequisites:</strong> Constitution 13, Shapeshift Species Trait, Trained in Deception</p>\n<h4>Effect</h4>\n<p>As a Full-Round Action, you can change your mass when you use your Shapeshift Species Trait, increasing or decreasing your size by one step. You can maintain this form for a number of rounds per day equal to your Constitution score.</p>\n<p>If you reduce your size to Small, you gain a +1 size bonus to your Reflex Defense and a +5 size bonus on Stealth checks, but your Carrying Capacity is three-quarters of what it was prior to your use of Metamorph.</p>\n<p>If you increase your size to Large, you take a -1 penalty to your Reflex Defense and a -5 penalty on Stealth checks. However, your Carrying Capacity doubles, you gain a +5 size bonus to your Damage Threshold, and your Reach increases by 1 square.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"con","min":13},{"type":"skillTrained","skill":"9410ce2dfb6cefcb"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Metamorph"}]},"shortSummary":"Change your size.","prerequisitesText":"Constitution 13, Shapeshift Species Trait, Trained in Deception","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Metamorph"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.metamorph","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Metamorph","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
