{"_id":"f362e5a4ad0a98bd","name":"Echani Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"martial_arts","benefit":"You can double the damage bonus provided by your Strength modifier to Unarmed Attacks (minimum +1) provided you make only one Unarmed attack this turn.\n\nOnce per encounter when you deal damage to a target with an Unarmed Attack you may make an immediate Unarmed Attack against the target's Fortitude Defense as a Free Action; if successful, you knock your opponent to the ground (Prone) in their current square, provided they are no more than one size larger than you.\n\nSpecial: Targets gain a bonus to their Fortitude Defense against being knocked Prone based on their size: Large +5, Huge +10, Gargantuan +20, Colossal +50. Unusually stable creatures (such as those with four legs) gain a +5 bonus to their Fortitude Defense against being knock Prone as well.","prerequisite":"Dexterity 13, Martial Arts I","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["action-economy","controller","defender","feat-chain","non-force","positioning","striker","support","sustained-damage","unarmed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"In <a class=\"mw-redirect\" href=\"/wiki/Unarmed\" title=\"Unarmed\">Unarmed</a> combat, increase damage, and knock opponent <a class=\"mw-redirect\" href=\"/wiki/Prone\" title=\"Prone\">Prone</a> on Critical Hit."},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"martialArtsFeat":true,"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":1,"type":"untyped","predicates":["defense.fortitude","attack.when-hit","turn.once-per-round","target.is-prone"],"enabled":true,"priority":500,"description":"Echani Training"}]}},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":["defense.fortitude","attack.when-hit","turn.once-per-round","target.is-prone"],"id":"swse.feat.echani_training"}}}
