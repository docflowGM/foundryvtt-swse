{"_id":"9de63b7a605768c2","name":"Advantageous Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make a successful attack against an enemy who has not yet acted in combat, you add your full Heroic Level to damage rolls.","prerequisite":"Base Attack Bonus +1","special":"","normalText":"Typically you add only one-half your Heroic Level to damage rolls.","sourcebook":"The Force Unleashed Campaign Guide","page":32,"tags":["feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Base Attack Bonus<br>+1</p>\n<p><strong>Effect:</strong> When you make a successful attack against an enemy who has not yet acted in combat, you add your full Heroic Level to damage rolls.</p>\n<p><strong>Normal:</strong> Typically you add only one-half your Heroic Level to damage rolls.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Advantageous_Attack</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Contextual heroic-level attack bonus when target speed condition is flagged.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Contextual heroic-level attack bonus when target speed condition is flagged.","predicateRequirements":[],"metadataPhase":"phase13-next-feat-implementation-batch","metadataNotes":"Phase 13 converts clear remaining manual/scaffold feats into skill bonuses, attack options, action/resource metadata, or safer non-static rider metadata.","executionModel":"