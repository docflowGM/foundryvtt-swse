},"prerequisitesText":"Wookiee","effect":"Whenever you spend a\nForce Point\nto add to an attack with a\nBowcaster\n, if you hit the target, you gain a competence bonus to your damage roll equal to the amount added to the attack."},"effects":[{"_id":"f376ea67-161a-4b7e-bcea-f967926d5867","name":"Bowcaster Marksman","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Bowcaster Marksman","effectType":"combat_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.bowcaster_marksman"}}}
