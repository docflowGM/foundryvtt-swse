{"_id":"08dbd76457db101f","name":"Saber Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You may throw your lightsaber as a ranged attack using Use the Force instead of a ranged attack roll. The lightsaber returns to your hand at the end of the turn.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":94,"tags":["feat","force","offense","offense_melee"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":false,"priority":500,"description":"Saber Throw: Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","mechanicsMode":"passive","applicationScope":"weapon_family_roll_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.with-ranged"],"conditionSummary":"Implemented as an explicit CombatOptionResolver rule; old migrated numeric modifier disabled.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Saber Throw now has explicit roll-context attack option metadata from its refreshed description.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","rules":[{"type":"ATTACK_OPTION","option":"saberThrow","label":"Saber Throw","control":"flag","requiresWeaponGroups":["lightsaber"],"requiresAttackType":"ranged","skillSubstitution":"useTheForce","returnsWeapon":true,"summary":"Throw a lightsaber as a ranged attack using Use the Force instead of a normal ranged attack roll. Skill substitution is exposed as metadata for the attack UI."}],"status":"attack_option_phase10","description":"Saber Throw now has explicit roll-context attack option metadata from its refreshed description."},"shortSummary":"You may throw your lightsaber as a ranged attack using Use the Force instead of a ranged attack roll."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["attack.with-ranged"]}}}
{"_id":"09d4eedfce05c6a3","name":"Pincer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully Pin an enemy, you can maintain the Pin beyond 1 round and can make subsequent Grapple checks against the Pinned enemy as a Swift Action. You can apply the Crush Feat whenever your subsequent checks are successful.","prerequisite":"Droid, Claw or Hand Appendage, Base Attack Bonus +1, Pin, Crush","special":"You must have a Claw or Hand Appendage to use this Feat.","normalText":"Grapple checks are a Standard Action. The Pin Feat must be rerolled each round as a new Grapple check.","sourcebook":"Scavenger's Guide to Droids","page":23,"tags":["action_economy","control","feat","general","grapple","swift_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Droid<br>,<br>Claw<br>or<br>Hand<br>Appendage,<br>Base Attack Bonus<br>+1,<br>Pin<br>,<br>Crush</p>\n<p><strong>Effect:</strong> When you successfully<br>Pin<br>an enemy, you can maintain the<br>Pin<br>beyond 1 round and can make subsequent<br>Grapple<br>checks against the<br>Pinned<br>enemy as a<br>Swift Action<br>. You can apply the<br>Crush<br>Feat whenever your subsequent checks are successful.</p>\n<p><strong>Normal:</strong> Grapple<br>checks are a<br>Standard Action<br>. The<br>Pin<br>Feat must be rerolled each round as a new<br>Grapple<br>check.</p>\n<p><strong>Special:</strong> You must have a<br>Claw<br>or<br>Hand<br>Appendage to use this Feat.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Pincer</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Pincer: No numeric attack bonus; represented as a Pin/Grapple rider.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"No numeric attack bonus; represented as a Pin/Grapple rider."}],"mechanicsMode":"conditional","applicationScope":"grapple_pin_context","staticSheetPolicy":"rider_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"After successfully Pinning, maintain the Pin and make later Grapple checks as swift actions; Crush can apply on later successes.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"grapple_rider_phase11","description":"After successfully Pinning, maintain the Pin and make later Grapple checks as swift actions; Crush can apply on later successes.","riderRules":[{"type":"PIN_MAINTENANCE","trigger":"after_successful_pin","allowsExtendedPin":true,"followupGrappleActionCost":"swift","allowsCrushOnFollowupSuccess":true,"description":"Maintain a Pin beyond 1 round and make subsequent Grapple checks as swift actions; apply Crush on successful follow-up checks."}]},"shortSummary":"Maintain Pin feat and make subsequent Grapple checks as a Swift Action. Apply Crush to each check.","prerequisitesText":"Droid, Claw or Hand Appendage, Base Attack Bonus +1, Pin, Crush","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Pincer","effect":"When you successfully\nPin\nan enemy, you can maintain the\nPin\nbeyond 1 round and can make subsequent\nGrapple\nchecks against the\nPinned\nenemy as a\nSwift Action\n. You can apply the\nCrush\nFeat whenever your subsequent checks are successful."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.pincer","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Pincer","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"09faea502795c45f","name":"Grapple Resistance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You get a +5 bonus to your Reflex Defense when an enemy makes a Grab or Grapple attack against you, and you get a +5 bonus to all opposed Grapple checks. All objects that you are holding or carrying gain a +5 bonus to their Reflex Defense when attacked (see Attack an Object).","prerequisite":"None","special":"","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":19,"tags":["control","feat","general","grapple","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> You get a +5 bonus to your<br>Reflex Defense<br>when an enemy makes a<br>Grab<br>or<br>Grapple<br>attack against you, and you get a +5 bonus to all opposed<br>Grapple<br>checks. All objects that you are holding or carrying gain a +5 bonus to their<br>Reflex Defense<br>when attacked (see<br>Attack an Object<br>).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Grapple_Resistance</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"grappleRules":[{"type":"RESIST_GRAB_AND_GRAPPLE","bonus":5}],"status":"grapple_resistance","description":"Grapple Resistance: +5 bonus to resist Grab and Grapple attacks (feat-driven via metadata).","mechanicsMode":"conditional","applicationScope":"skill_or_grapple_context","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Current metadata is implemented through skill/grapple helper payloads rather than generic static modifiers.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Gain a +5 bonus to resist Grab and Grapple attacks.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Grapple_Resistance","effect":"You get a +5 bonus to your\nReflex Defense\nwhen an enemy makes a\nGrab\nor\nGrapple\nattack against you, and you get a +5 bonus to all opposed\nGrapple\nchecks. All objects that you are holding or carrying gain a +5 bonus to their\nReflex Defense\nwhen attacked (see\nAttack an Object\n)."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.grapple_resistance","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Grapple_Resistance","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0a6c87a410bee1f2","name":"Unstoppable Force","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +5 insight bonus to Fortitude Defense and Will Defense against any attack or effect requiring a Use the Force check.","prerequisite":"None","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":35,"tags":["feat","force","force_execution","skill_synergy","skill_use_the_force","use_the_force"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> You gain a +5 insight bonus to<br>Fortitude Defense<br>and<br>Will Defense<br>against any attack or effect requiring a<br>Use the Force<br>check.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Unstoppable_Force</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.fortitude","defense.will"],"enabled":false,"priority":500,"description":"Unstoppable Force: Implemented as conditional defense metadata; excluded from static sheet totals.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.fortitude","defense.will"],"conditionSummary":"Implemented as conditional defense metadata; excluded from static sheet totals.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"defense_context","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Unstoppable Force now exposes conditional defense metadata instead of a false attack/static modifier.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","conditionalDefenseBonuses":[{"type":"CONDITIONAL_DEFENSE_BONUS","targets":["defense.fortitude","defense.will"],"value":5,"bonusType":"insight","requiresContextFlags":["useTheForceAttackOrEffect"],"description":"Gain +5 insight to Fortitude and Will against attacks/effects requiring Use the Force checks."}],"status":"conditional_defense_phase10","description":"Unstoppable Force now exposes conditional defense metadata instead of a false attack/static modifier."},"shortSummary":"Gain a +5 bonus to Fortitude Defense and Will Defense against any effect requiring a Use the Force check.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Force","effect":"You gain a +5 insight bonus to\nFortitude Defense\nand\nWill Defense\nagainst any attack or effect requiring a\nUse the Force\ncheck."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["defense.fortitude","defense.will"],"id":"swse.feat.unstoppable_force","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Force","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0ac76f1c0c1677cb","name":"Conditioning","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can reroll any\nStrength\n- or Constitution -based Skill Checks for Skills that you are Trained in. The result of the reroll must be accepted even if it is worse. Additionally, once per encounter you can add your Strength modifier to your Fortitude Defense as a Reaction ; this bonus lasts until the beginning of your next turn.","prerequisite":"Strength 13, Constitution 13","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":25,"tags":["ability_constitution","ability_strength","feat","general","reroll","skill_reroll","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Strength<br>13,<br>Constitution<br>13</p>\n<p><strong>Effect:</strong> You can reroll any<br>Strength<br>- or<br>Constitution<br>-based<br>Skill Checks<br>for<br>Skills<br>that you are<br>Trained<br>in. The result of the reroll must be accepted even if it is worse. Additionally, once per encounter you can add your<br>Strength<br>modifier to your<br>Fortitude Defense<br>as a<br>Reaction<br>; this bonus lasts until the beginning of your next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Conditioning</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13},{"type":"attribute","ability":"con","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8","description":"Conditioning: reroll Strength- and Constitution-based skill checks; accept the reroll result.","skillRerolls":[{"id":"conditioning","skillKeys":["climb","jump","swim","endurance"],"outcome":"keepSecond","label":"Conditioning","description":"Conditioning: reroll Strength- and Constitution-based skill checks; accept the reroll result."}],"mechanicsMode":"conditional","applicationScope":"reroll_or_resource_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rerolls/resources are not static sheet modifiers and require a check/encounter/resource context.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Reroll Strength and Constitution based Skill Checks.","prerequisitesText":"Strength 13, Constitution 13","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Conditioning","effect":"You can reroll any\nStrength\n- or\nConstitution\n-based\nSkill Checks\nfor\nSkills\nthat you are\nTrained\nin. The result of the reroll must be accepted even if it is worse. Additionally, once per encounter you can add your\nStrength\nmodifier to your\nFortitude Defense\nas a\nReaction\n; this bonus lasts until the beginning of your next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.conditioning","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Conditioning","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0c53cb8b7c29d865","name":"Stealthy","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Stealth checks and may reroll a failed Stealth check once per encounter.","prerequisite":"None","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","skill_stealth","skill_synergy","stealth"],"bonus_feat_for":["21dfe84d159a1b7f","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_with_bonus_phase8_implemented","description":"Stealthy: +2 bonus to Stealth checks; reroll Stealth checks once per encounter and keep the better result.","skillCheckBonuses":[{"id":"stealthy-bonus","skillKeys":["stealth"],"value":2,"type":"untyped","description":"Stealthy: +2 bonus to Stealth checks."}],"skillRerolls":[{"id":"stealthy-reroll","skillKeys":["stealth"],"outcome":"keepBetter","oncePer":"encounter","label":"Stealthy","description":"Stealthy: reroll Stealth checks once per encounter and keep the better result."}],"mechanicsMode":"conditional","applicationScope":"reroll_or_resource_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rerolls/resources are not static sheet modifiers and require a check/encounter/resource context.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"You gain a +2 bonus on Stealth checks and may reroll a failed Stealth check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["turn.once-per-round"]}}}
{"_id":"0d4d7c147c48cdab","name":"Burst Fire","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using a ranged weapon with Autofire capability, and that you are Proficient with, in Autofire mode, you may fire a short burst as a single attack against a single target. You take a -5 penalty on your attack roll, but deal +2 dice of damage.\n\nThe effects of this Feat do not stack with the extra damage provided by the Deadeye or Rapid Shot feats.\n\nIf you do not have a Strength of 13 or higher, increase the penalty on attacks to -10 when using this Feat with non- Vehicle Weapons.","prerequisite":"Proficient with Heavy Weapons","special":"Firing a burst expends five shots, and can only be done if the weapon has at least five shots remaining.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["area_pressure","autofire","feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Proficient with<br>Heavy Weapons</p>\n<p><strong>Effect:</strong> When using a ranged weapon with<br>Autofire<br>capability, and that you are Proficient with, in<br>Autofire<br>mode, you may fire a short burst as a single attack against a single target. You take a -5 penalty on your attack roll, but deal +2 dice of damage.<br><br>The effects of this Feat do not stack with the extra damage provided by the<br>Deadeye<br>or<br>Rapid Shot<br>feats.<br><br>If you do not have a<br>Strength<br>of 13 or higher, increase the penalty on attacks to -10 when using this Feat with non-<br>Vehicle Weapons<br>.</p>\n<p><strong>Special:</strong> Firing a burst expends five shots, and can only be done if the weapon has at least five shots remaining.</p>\n<h3>Additional Burst Fire Effects</h3><p>Reference Book:<br>Star Wars Saga Edition Starships of the Galaxy<br><br>Vehicle Weapons<br>capable of<br>Autofire<br>can be used with this feat normally. Additional dice of damage are added before any multiplier from the<br>Vehicle Weapon<br>is applied.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Burst_Fire</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"attack_option_phase7_refined","description":"Burst Fire: exposed through CombatOptionResolver; not applied as a passive sheet modifier.","rules":[{"type":"ATTACK_OPTION","option":"burstFire","label":"Burst Fire","summary":"Autofire as a single-target burst: attack penalty, extra weapon dice, and five-shot ammo cost.","control":"toggle","requiresAttackType":"ranged","requiresAutofire":true,"attackModifier":-5,"damageExtraWeaponDice":2,"ammunitionCost":5,"strengthPenaltyIfBelow":13,"nonVehicleAttackModifierIfStrengthBelow":-10,"nonStackingWith":["deadeye","rapidShot"]}],"mechanicsMode":"active","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Exposed as a deliberate combat option or passive roll-context option, not a static actor-sheet modifier.","predicateRequirements":[],"metadataPhase":"phase7-description-reimplementation","metadataNotes":"Phase 7 re-read refreshed descriptions and converted old scaffold bonuses into explicit static/resource/attack-option/rider metadata."},"shortSummary":"Take a -5 penalty on an Autofire attack to gain +2 dice of damage.","prerequisitesText":"Proficient with Heavy Weapons","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Burst_Fire","effect":"When using a ranged weapon with\nAutofire\ncapability, and that you are Proficient with, in\nAutofire\nmode, you may fire a short burst as a single attack against a single target. You take a -5 penalty on your attack roll, but deal +2 dice of damage.\n\nThe effects of this Feat do not stack with the extra damage provided by the\nDeadeye\nor\nRapid Shot\nfeats.\n\nIf you do not have a\nStrength\nof 13 or higher, increase the penalty on attacks to -10 when using this Feat with non-\nVehicle Weapons\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.burst_fire","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Burst_Fire","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0dbd1d12c0b99725","name":"Zero Range","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When firing a ranged weapon at a target within or adjacent to your Fighting Space, you gain a +1 bonus on the attack roll and deal +1 die of damage on a hit.","prerequisite":"Point-Blank Shot","special":"The effects of this Feat do not stack with the extra damage provided by the Burst Fire or Rapid Shot Feats. This Feat does not apply to Heavy Weapons or Vehicle Weapons, or in Vehicle Combat.","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":23,"tags":["attack_option","execution_mapped_phase8","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Point-Blank Shot</p>\n<p><strong>Effect:</strong> When firing a ranged weapon at a target within or adjacent to your<br>Fighting Space<br>, you gain a +1 bonus on the attack roll and deal +1 die of damage on a hit.</p>\n<p><strong>Special:</strong> The effects of this Feat do not stack with the extra damage provided by the<br>Burst Fire<br>or<br>Rapid Shot<br>Feats. This Feat does not apply to<br>Heavy Weapons<br>or<br>Vehicle Weapons<br>, or in<br>Vehicle Combat<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Zero_Range</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":false,"priority":500,"description":"Zero Range is implemented as an explicit attack option, not a passive attack modifier.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.with-ranged"],"conditionSummary":"Zero Range is implemented as an explicit attack option, not a passive attack modifier."}],"mechanicsMode":"active","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Against an adjacent/same-space target, gain +1 attack and +1 weapon die of damage.","predicateRequirements":["attack.with-ranged"],"metadataPhase":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics.","status":"attack_option_phase8","description":"Zero Range: ranged attack option for adjacent/same-space targets.","rules":[{"type":"ATTACK_OPTION","option":"zeroRange","label":"Zero Range","control":"toggle","requiresAttackType":"ranged","requiresRangeBand":["adjacent","same-space","point-blank"],"attackModifier":1,"damageExtraWeaponDice":1,"summary":"Against an adjacent/same-space target, gain +1 attack and +1 weapon die of damage."}]},"shortSummary":"Gain a +1 bonus on your attack roll and deal +1 die of damage when making a ranged attack against an adjacent target or a target in your Fighting Space.","prerequisitesText":"Point-Blank Shot","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Zero_Range","effect":"When firing a ranged weapon at a target within or adjacent to your\nFighting Space\n, you gain a +1 bonus on the attack roll and deal +1 die of damage on a hit."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.zero_range","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Zero_Range","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0e9aa3d941f4eb80","name":"Mounted Regiment","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Ride checks when near allies.","prerequisite":"Trained in Ride","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_ride","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8","manual_resolution","teamwork_base_skill_bonus_phase15"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Ride</p>\n<p><strong>Effect:</strong> You gain a +3 competence bonus on<br>Ride<br>checks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).<br><br>Additionally, once per round as a<br>Reaction<br>to your<br>Mount<br>being attacked, you can make a<br>Ride<br>check; if the result exceeds the Mount&#x27;s<br>Reflex Defense<br>, use your check result against the attack instead of using the Mount&#x27;s<br>Reflex Defense<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Mounted_Regiment</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_with_manual_teamwork","applicationScope":"skill_roll_plus_manual_teamwork","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Mounted Regiment: +3 competence skill bonus applies normally; nearby-ally scaling and other battlefield/teamwork clauses are GM/player managed.","predicateRequirements":[],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 avoids automating nearby-ally/battlefield positioning clauses; base skill bonuses are implemented where unambiguous and teamwork clauses are preserved as manual metadata.","implementationStatus":"base_skill_bonus_manual_teamwork_phase15","description":"Mounted Regiment: base +3 competence skill bonus implemented; nearby-ally scaling and special teamwork clauses remain table-managed flavor/manual metadata.","skillCheckBonuses":[{"id":"mounted-regiment","skillKey":"ride","type":"competence","featName":"Mounted Regiment","description":"Mounted Regiment: +3 competence bonus to ride checks. Nearby-ally scaling is manual/table-managed.","value":3}],"teamworkRules":[{"type":"MOUNT_DEFENSE_RIDE_CHECK_REACTION","skillKey":"ride","trigger":"mountAttacked","description":"Once per round as a reaction to mount being attacked, make Ride check; if check exceeds mount Reflex Defense, use check result as mount Reflex Defense.","automation":"manual","manualResolution":true}]},"shortSummary":"Gain bonuses on Ride checks when near allies.","sourceUrl":"https://swse.fandom.com/wiki/Mounted_Regiment","rawImport":{"name":"Mounted Regiment","url":"https://swse.fandom.com/wiki/Mounted_Regiment","pageTitle":"Mounted_Regiment","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\mounted_regiment.html","referenceBooks":[],"prerequisitesText":"Trained\nin\nRide","prerequisites":["Trained\nin\nRide"],"effect":"You gain a +3 competence bonus on\nRide\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, once per round as a\nReaction\nto your\nMount\nbeing attacked, you can make a\nRide\ncheck; if the result exceeds the Mount's\nReflex Defense\n, use your check result against the attack instead of using the Mount's\nReflex Defense\n.","benefit":"","normal":"","special":"","indexPrerequisites":"Trained in Ride","indexBenefit":"Gain bonuses on Ride checks when near allies.","indexPage":"Specialization_Feats","indexSection":"Team Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nTeam Feats\n\nYou and your allies act as mounted calvary, specializing in using\nBeasts\nin war.\n\nPrerequisite:\nTrained\nin\nRide\n\nEffect:\nYou gain a +3 competence bonus on\nRide\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, once per round as a\nReaction\nto your\nMount\nbeing attacked, you can make a\nRide\ncheck; if the result exceeds the Mount's\nReflex Defense\n, use your check result against the attack instead of using the Mount's\nReflex Defense\n."},"prerequisitesText":"Trained\nin\nRide","effect":"You gain a +3 competence bonus on\nRide\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, once per round as a\nReaction\nto your\nMount\nbeing attacked, you can make a\nRide\ncheck; if the result exceeds the Mount's\nReflex Defense\n, use your check result against the attack instead of using the Mount's\nReflex Defense\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["defense.reflex","proximity.count-allies-within-12","turn.once-per-round"],"id":"swse.feat.mounted_regiment"}}}
{"_id":"10a017a020aa4a9c","name":"Forceful Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Use the Force checks made to activate Move Object.","prerequisite":"Trained in Use the Force, Move Object","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","force","offense","offense_melee"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Forceful Throw: Implemented by skillCheckBonuses scoped to the Move Object Use the Force application.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"Implemented by skillCheckBonuses scoped to the Move Object Use the Force application."}],"mechanicsMode":"conditional","applicationScope":"skill_use_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Forceful Throw gives +2 on Use the Force checks made to activate Move Object.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"skill_bonus_phase11","description":"Forceful Throw gives +2 on Use the Force checks made to activate Move Object.","skillCheckBonuses":[{"id":"forceful-throw-move-object-bonus","skillKey":"useTheForce","value":2,"type":"untyped","applications":["Move Object"],"applicationIncludes":["Move Object"],"description":"Forceful Throw: +2 on Use the Force checks made to activate Move Object."}]},"shortSummary":"You gain a +2 bonus on Use the Force checks made to activate Move Object."},"effects":[{"_id":"f40c0e8c-27d6-4fb4-b60b-480437c9ad82","name":"Forceful Throw","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Forceful Throw","effectType":"skill_bonus","flagType":"Forceful Throw"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[]}}}
{"_id":"11db29efd899c438","name":"Toughness","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain +1 Hit Point per Character Level.","prerequisite":"None","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["defense","durability","execution_mapped_phase8","feat","general","hit_points","resource_hit_points","survivability"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> You gain +1 Hit Point per Character Level.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Toughness</em></p>","executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"hp.max","type":"untyped","value":5,"enabled":false,"priority":500,"description":"Toughness is implemented by resourceRules.hitPoints MAX_BONUS_PER_LEVEL; the old flat hp.max modifier is disabled to avoid non-scaling HP.","mechanicsMode":"passive","applicationScope":"static_actor","staticSheetPolicy":"exclude","requiresRuntimeContext":false,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"Always-on hit point increase. Current numeric scaling should be audited separately; it is not conditional."}],"mechanicsMode":"passive_resource","applicationScope":"hitPoints_resource","staticSheetPolicy":"resource_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Always-on HP scaling, recomputed by ActorEngine whenever level/feat data changes.","predicateRequirements":[],"metadataPhase":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics.","status":"hp_resource_rule_phase8","description":"Toughness: +1 maximum Hit Point per character level. ActorEngine.recomputeHP consumes this rule.","resourceRules":{"hitPoints":[{"type":"MAX_BONUS_PER_LEVEL","value":1,"description":"Gain +1 maximum Hit Point per character level."}]}},"shortSummary":"Gain +1 Hit Point per Character Level.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Toughness","effect":"You gain +1 Hit Point per Character Level."},"effects":[{"name":"Toughness","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.hitPoints.bonusPerLevel","mode":2,"value":"5","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"hit-points","perLevel":true,"migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.toughness","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Toughness","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1228a537592ad145","name":"Grazing Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully make a ranged attack against a single target, you can make a second attack roll against an additional target that is in direct line of sight, and no farther than 6 squares from the original target. If the second attack roll succeeds, make a single damage roll, and divide the damage equally between the two targets. If the second attack roll fails, you deal no damage to either target.","prerequisite":"Point-Blank Shot","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":19,"tags":["feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Point-Blank Shot</p>\n<p><strong>Effect:</strong> When you successfully make a ranged attack against a single target, you can make a second attack roll against an additional target that is in direct line of sight, and no farther than 6 squares from the original target. If the second attack roll succeeds, make a single damage roll, and divide the damage equally between the two targets. If the second attack roll fails, you deal no damage to either target.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Grazing_Shot</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"active","applicationScope":"ranged_multi_target_attack_option","staticSheetPolicy":"roll_context_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Grazing Shot: after a successful ranged attack, make a second attack against a nearby line-of-sight target and split damage only if the second attack hits.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"ranged_followup_metadata_phase16","description":"Grazing Shot: after a successful ranged attack, make a second attack against a nearby line-of-sight target and split damage only if the second attack hits.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Grazing Shot: after a successful ranged attack, make a second attack against a nearby line-of-sight target and split damage only if the second attack hits.","mechanicsMode":"metadata_only","applicationScope":"ranged_multi_target_attack_option","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"ATTACK_OPTION","option":"grazingShot","label":"Grazing Shot","control":"flag","requiresAttackType":"ranged","followupAttack":{"targetLimit":1,"maxDistanceFromPrimarySquares":6,"requiresLineOfSight":true,"damageMode":"splitBetweenPrimaryAndSecondaryOnSecondHit","failMode":"noDamage"},"summary":"After a successful ranged attack, roll against a second target within 6 squares of the first; split damage if it hits, no damage if it misses."}]},"shortSummary":"Strike two targets in direct line of sight, dealing half damage to each.","prerequisitesText":"Point-Blank Shot","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Grazing_Shot","effect":"When you successfully make a ranged attack against a single target, you can make a second attack roll against an additional target that is in direct line of sight, and no farther than 6 squares from the original target. If the second attack roll succeeds, make a single damage roll, and divide the damage equally between the two targets. If the second attack roll fails, you deal no damage to either target."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.grazing_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Grazing_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"125c328c4573890a","name":"Ascension Specialists","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Climb checks when near allies.","prerequisite":"Trained in Climb","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_climb","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8","manual_resolution","teamwork_base_skill_bonus_phase15"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Climb</p>\n<p><strong>Effect:</strong> You gain a +3 competence bonus on<br>Climb<br>checks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).<br><br>Additionally, when you climb, you climb at half your speed as a<br>Move Action<br>(or at your normal speed as a<br>Full-Round Action<br>).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Ascension_Specialists</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_with_manual_teamwork","applicationScope":"skill_roll_plus_manual_teamwork","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Ascension Specialists: +3 competence skill bonus applies normally; nearby-ally scaling and other battlefield/teamwork clauses are GM/player managed.","predicateRequirements":[],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 avoids automating nearby-ally/battlefield positioning clauses; base skill bonuses are implemented where unambiguous and teamwork clauses are preserved as manual metadata.","implementationStatus":"base_skill_bonus_manual_teamwork_phase15","description":"Ascension Specialists: base +3 competence skill bonus implemented; nearby-ally scaling and special teamwork clauses remain table-managed flavor/manual metadata.","skillCheckBonuses":[{"id":"ascension-specialists","skillKey":"climb","type":"competence","featName":"Ascension Specialists","description":"Ascension Specialists: +3 competence bonus to climb checks. Nearby-ally scaling is manual/table-managed.","value":3}],"teamworkRules":[{"type":"SKILL_MOVEMENT_RATE","skillKey":"climb","moveActionSpeedFraction":0.5,"fullRoundSpeedFraction":1,"description":"Climb at half speed as a move action or full speed as a full-round action.","automation":"manual","manualResolution":true}]},"shortSummary":"Gain bonuses on Climb checks when near allies.","sourceUrl":"https://swse.fandom.com/wiki/Ascension_Specialists","rawImport":{"name":"Ascension Specialists","url":"https://swse.fandom.com/wiki/Ascension_Specialists","pageTitle":"Ascension_Specialists","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\ascension_specialists.html","referenceBooks":[],"prerequisitesText":"Trained\nin\nClimb","prerequisites":["Trained\nin\nClimb"],"effect":"You gain a +3 competence bonus on\nClimb\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you climb, you climb at half your speed as a\nMove Action\n(or at your normal speed as a\nFull-Round Action\n).","benefit":"","normal":"","special":"","indexPrerequisites":"Trained in Climb","indexBenefit":"Gain bonuses on Climb checks when near allies.","indexPage":"Specialization_Feats","indexSection":"Team Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nTeam Feats\n\nYou and your allies train on the sheer cliffs of\nTeth\nand the sinkholes of\nUtapau\nas a matter of course.\n\nPrerequisite:\nTrained\nin\nClimb\n\nEffect:\nYou gain a +3 competence bonus on\nClimb\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you climb, you climb at half your speed as a\nMove Action\n(or at your normal speed as a\nFull-Round Action\n)."},"prerequisitesText":"Trained\nin\nClimb","effect":"You gain a +3 competence bonus on\nClimb\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you climb, you climb at half your speed as a\nMove Action\n(or at your normal speed as a\nFull-Round Action\n)."},"effects":[{"_id":"82f35e76-4fd1-4c6e-82bc-c846bae6eff2","name":"Ascension Specialists","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Ascension Specialists","effectType":"skill_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.ascension_specialists"}}}
{"_id":"12d064d086102ff0","name":"Rapid Reaction","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you can use two different Reactions in response to the same trigger. For example, if you use the Deflect Talent and fail to negate the attack, you can also use Negate Energy as a response to the same attack.","prerequisite":"None","special":"","normalText":"Without this Feat, you can use only one Reaction in response to a particular trigger.","sourcebook":"Rebellion Era Campaign Guide","page":21,"tags":["feat","general","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> Once per encounter, you can use two different<br>Reactions<br>in response to the same trigger. For example, if you use the<br>Deflect<br>Talent and fail to negate the attack, you can also use<br>Negate Energy<br>as a response to the same attack.</p>\n<p><strong>Normal:</strong> Without this Feat, you can use only one<br>Reaction<br>in response to a particular trigger.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Rapid_Reaction</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":false,"priority":500,"description":"Rapid Reaction: Rapid Reaction is a reaction economy rule, not an attack bonus.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["turn.once-per-round"],"conditionSummary":"Rapid Reaction is a reaction economy rule, not an attack bonus.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"non_numeric_rule","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rapid Reaction is a reaction economy rule, not an attack bonus.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","reactionRules":[{"type":"ALLOW_SECOND_REACTION_SAME_TRIGGER","oncePer":"encounter","description":"Once per encounter, use two different reactions in response to the same trigger."}],"status":"reaction_rules_phase10","description":"Rapid Reaction is a reaction economy rule, not an attack bonus."},"shortSummary":"React twice to the same trigger once per encounter.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Rapid_Reaction","effect":"Once per encounter, you can use two different\nReactions\nin response to the same trigger. For example, if you use the\nDeflect\nTalent and fail to negate the attack, you can also use\nNegate Energy\nas a response to the same attack."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.rapid_reaction","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Rapid_Reaction","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"139a80972fc3b8ee","name":"Confident Success","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a Force Point when you successfully Learn Secret Information.","prerequisite":"Bothan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","force_point_spend","racial","resource_spend","species","species_opportunity"],"bonus_feat_for":["species-bothan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Bothan</p>\n<p><strong>Effect:</strong> Whenever you successfully use the<br>Learn Secret Information<br>application of the<br>Gather Information<br>Skill, you gain 1<br>Force Point<br>. You cannot gain more than 3<br>Force Points<br>each level, and you cannot have more<br>Force Points<br>than you gained when you reached your current level.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Confident_Success</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"skill_success_resource_context","staticSheetPolicy":"resource_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Gain 1 Force Point on successful Learn Secret Information, limited to 3 per level and normal Force Point cap.","predicateRequirements":["skill.gatherInformation","application.learnSecretInformation","outcome.success"],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 continues description-guided implementation by improving teamwork skill feats, skill substitutions, force/dark-side skill context, and several remaining action/resource rider feats.","implementationStatus":"skill_success_force_point_metadata_phase15","description":"Confident Success: successful Learn Secret Information can grant 1 Force Point, limited by per-level/cap restrictions.","skillSuccessResourceRules":[{"type":"GRANT_FORCE_POINT_ON_SUCCESS","skillKey":"gatherInformation","applications":["Learn Secret Information"],"amount":1,"maxPerLevel":3,"respectForcePointCap":true,"description":"On successful Learn Secret Information, gain 1 Force Point, no more than 3 per level and not above normal FP cap."}],"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Confident Success grants Force Points from a specific Gather Information success; it is not a numeric attack or static modifier.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude","metadataPhase":"phase15-next-feat-batch"}]},"shortSummary":"Gain a Force Point when you successfully Learn Secret Information.","sourceUrl":"https://swse.fandom.com/wiki/Confident_Success","rawImport":{"name":"Confident Success","url":"https://swse.fandom.com/wiki/Confident_Success","pageTitle":"Confident_Success","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\confident_success.html","referenceBooks":[],"prerequisitesText":"Bothan","prerequisites":["Bothan"],"effect":"Whenever you successfully use the\nLearn Secret Information\napplication of the\nGather Information\nSkill, you gain 1\nForce Point\n. You cannot gain more than 3\nForce Points\neach level, and you cannot have more\nForce Points\nthan you gained when you reached your current level.","benefit":"","normal":"","special":"","indexPrerequisites":"Bothan","indexBenefit":"Gain a Force Point when you successfully Learn Secret Information .","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou have confidence in your ability to learn information that others consider secret, and in doing so, boost your confidence in other areas.\n\nPrerequisite:\nBothan\n\nEffect:\nWhenever you successfully use the\nLearn Secret Information\napplication of the\nGather Information\nSkill, you gain 1\nForce Point\n. You cannot gain more than 3\nForce Points\neach level, and you cannot have more\nForce Points\nthan you gained when you reached your current level."},"prerequisitesText":"Bothan","effect":"Whenever you successfully use the\nLearn Secret Information\napplication of the\nGather Information\nSkill, you gain 1\nForce Point\n. You cannot gain more than 3\nForce Points\neach level, and you cannot have more\nForce Points\nthan you gained when you reached your current level."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.confident_success"}}}
{"_id":"14f0d916e9228368","name":"Channel Rage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per day, instead of entering into a Rage, you gain a +5 bonus to your Will Defense until the end of the encounter. This bonus counts as using your Rage ability for that day.","prerequisite":"Rage Species Trait","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":16,"tags":["execution_mapped_phase9","feat","general","offense_melee","rage","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Rage Species Trait</p>\n<p><strong>Effect:</strong> Once per day, instead of entering into a Rage, you gain a +5 bonus to your<br>Will Defense<br>until the end of the encounter. This bonus counts as using your Rage ability for that day.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Channel_Rage</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rage_rule_phase9","description":"Channel Rage: alternate Rage mode grants +5 Will Defense instead of normal Rage.","rules":[{"type":"RAGE_ALTERNATE_MODE","mode":"channelRage","target":"defense.will","value":5,"description":"Instead of Raging, gain +5 to Will Defense."}],"mechanicsMode":"conditional","applicationScope":"rage_context","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Only applies while the actor is raging or using rage-specific rules.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Instead of Raging, gain +5 to Will Defense.","prerequisitesText":"Rage Species Trait","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Channel_Rage","effect":"Once per day, instead of entering into a Rage, you gain a +5 bonus to your\nWill Defense\nuntil the end of the encounter. This bonus counts as using your Rage ability for that day."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["defense.will"],"id":"swse.feat.channel_rage","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Channel_Rage","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1592aaedf4b6e40a","name":"Skill Focus","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one Skill in which you are Trained. You gain a +5 competence bonus on all Skill Checks made with that Skill.","prerequisite":"None","special":"This Feat may be selected multiple times. Its effects do not stack. Each time you take this Feat, it applies to a different Trained Skill.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","choice_required","immediate_choice","skill_choice","choice_source_fixed"],"bonus_feat_for":["8c58016e587dd2c7","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> Choose one<br>Skill<br>in which you are<br>Trained<br>. You gain a +5 competence bonus on all<br>Skill Checks<br>made with that<br>Skill<br>.</p>\n<p><strong>Special:</strong> This Feat may be selected multiple times. Its effects do not stack. Each time you take this Feat, it applies to a different<br>Trained Skill<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Skill_Focus</em></p>","executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"value":5,"type":"competence","enabled":true,"priority":500,"description":"Skill Focus: +5 competence bonus to selected skill","targetFromSelectedChoice":{"prefix":"skill."},"mechanicsMode":"passive_choice_required","applicationScope":"selected_skill_static_context","staticSheetPolicy":"selected_choice_only","requiresRuntimeContext":false,"requiresSelectedChoice":true,"predicateRequirements":[],"conditionSummary":"Always-on bonus after the trained skill is selected; should not apply before selectedChoice is known."}],"mechanicsMode":"passive_choice_required","applicationScope":"selected_skill_static_context","staticSheetPolicy":"selected_choice_only","requiresRuntimeContext":false,"requiresSelectedChoice":true,"conditionSummary":"Always-on bonus after the trained skill is selected; should not apply before selectedChoice is known.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"choiceMeta":{"resolution":"immediate","required":true,"status":"execution_mapped_phase6","choiceKind":"skill_focus","repeatable":true,"storagePath":"flags.swse.choices.skill_focus","choiceSource":"fixed","optionRegistry":"data/feat-choice-options.json#choiceKinds.skill_focus","effectTarget":"skill.selected","effectValue":5},"shortSummary":"Gain +5 competence bonus on Skill Checks with one Trained Skill.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Skill_Focus","effect":"Choose one\nSkill\nin which you are\nTrained\n. You gain a +5 competence bonus on all\nSkill Checks\nmade with that\nSkill\n."},"effects":[{"name":"Skill Focus","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.skills.perception.miscMod","mode":2,"value":"5","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"skill-bonus","skill":"43c5941072ec78af","source":"Skill Focus","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.skill_focus","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Skill_Focus","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"167c394e90424916","name":"Accelerated Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, when using only weapons with which you are proficient, you can take a Full Attack Action as a Standard Action.","prerequisite":"Base Attack Bonus +6","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":25,"tags":["feat","general","offense","offense_melee","standard_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Base Attack Bonus<br>+6</p>\n<p><strong>Effect:</strong> Once per encounter, when using only weapons with which you are proficient, you can take a<br>Full Attack<br>Action as a<br>Standard Action<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Accelerated_Strike</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":6}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":false,"priority":500,"description":"Accelerated Strike: Accelerated Strike is an action economy rule, not an attack bonus.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["turn.once-per-round"],"conditionSummary":"Accelerated Strike is an action economy rule, not an attack bonus.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"non_numeric_rule","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Accelerated Strike is an action economy rule, not an attack bonus.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","actionEconomyRules":[{"type":"FULL_ATTACK_AS_STANDARD","oncePer":"encounter","requiresProficientWeaponsOnly":true,"description":"Once per encounter, take a Full Attack action as a Standard action when using only proficient weapons."}],"status":"action_economy_phase10","description":"Accelerated Strike is an action economy rule, not an attack bonus.","combatActions":[{"id":"accelerated-strike-full-attack","name":"Accelerated Strike Full Attack","actionType":"standard","cost":1,"manualResolution":true,"resolutionMode":"manual","useLabel":"Use / Note","relatedSkills":[{"skill":"Attack Roll","when":"Resolve the Full Attack sequence manually"}],"resources":["Once per encounter"],"notes":"Once per encounter, when using only weapons with which you are proficient, take a Full Attack action as a Standard action.","description":"Take a Full Attack as a Standard action once per encounter when using only proficient weapons."}],"combatActionCardSource":"phase-t13-ability-combat-action-cards","combatActionCardNotes":"Action card only; execution remains manual until multi-attack sequencing is automated."},"shortSummary":"Once per encounter, make a Full Attack as a Standard Action.","prerequisitesText":"Base Attack Bonus +6","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Accelerated_Strike","effect":"Once per encounter, when using only weapons with which you are proficient, you can take a\nFull Attack\nAction as a\nStandard Action\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.accelerated_strike","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Accelerated_Strike","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"171f0d8d997c8bbc","name":"Wilderness First Aid","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per day, you can make a DC 20 Survival check. If the check is successful, when you use the Basic Survival application of the Survival skill, you are considered to have a Medpac for any Treat Injury checks made until the end of the day.","prerequisite":"Trained in Survival.","special":"The Gamemaster can adjust the DC for the current environment, raising it for harsh or desert climates or lowering it for diverse locales.","normalText":"","sourcebook":"Unknown Regions","page":28,"tags":["feat","general","healing","skill_survival","skill_synergy","skill_treat_injury","support","skill_use_access","equipment_waiver","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Survival<br>.</p>\n<p><strong>Effect:</strong> Once per day, you can make a DC 20<br>Survival<br>check. If the check is successful, when you use the<br>Basic Survival<br>application of the<br>Survival<br>skill, you are considered to have a<br>Medpac<br>for any<br>Treat Injury<br>checks made until the end of the day.</p>\n<p><strong>Special:</strong> The Gamemaster can adjust the DC for the current environment, raising it for harsh or desert climates or lowering it for diverse locales.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Wilderness_First_Aid</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_use_access_phase8","description":"Wilderness First Aid: equipment requirement for basic Treat Injury support is treated as a GM-enforced waiver; no medpac/toolkit validation is performed.","skillUseAccess":[{"id":"wilderness-first-aid-treat-injury-equipment-waiver","skillKeys":["treatInjury"],"applications":["First Aid","Treat Injury"],"waivesEquipmentRequirement":true,"description":"Treat basic Survival first-aid support as satisfying medpac access; equipment enforcement remains with the GM."}],"mechanicsMode":"conditional","applicationScope":"skill_or_grapple_context","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Current metadata is implemented through skill/grapple helper payloads rather than generic static modifiers.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Use basic Survival skills as if you have a Medpac for Treat Injury checks.","prerequisitesText":"Trained in Survival.","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Wilderness_First_Aid","effect":"Once per day, you can make a DC 20\nSurvival\ncheck. If the check is successful, when you use the\nBasic Survival\napplication of the\nSurvival\nskill, you are considered to have a\nMedpac\nfor any\nTreat Injury\nchecks made until the end of the day."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.wilderness_first_aid","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Wilderness_First_Aid","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"17e317292814e13e","name":"Forceful Will","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Will Defense against mind-affecting effects and may reroll a failed Will Defense check once per encounter.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["defense","feat","force","survivability"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will","effect.mind-affecting"],"enabled":true,"priority":500,"description":"Forceful Will: +2 Will Defense against mind-affecting effects; failed Will reroll once per encounter.","mechanicsMode":"conditional","applicationScope":"contextual_defense","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.will","effect.mind-affecting"],"conditionSummary":"+2 Will Defense against mind-affecting effects; failed Will reroll once per encounter."}],"mechanicsMode":"conditional","applicationScope":"contextual_defense","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rules text is conditional and current metadata has predicates. It must only apply when the runtime context satisfies those predicates.","predicateRequirements":["defense.will","turn.once-per-round"],"metadataPhase":"phase12-feat-implementation-batch","metadataNotes":"Phase 12 continues description-guided feat implementation by replacing false scaffold bonuses with explicit roll options, contextual predicates, resource/rider metadata, or supported static rules.","defenseRerolls":[{"id":"mind_affecting_will_reroll","type":"DEFENSE_REROLL","defense":"will","oncePer":"encoun