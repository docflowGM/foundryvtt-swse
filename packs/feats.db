{"_id":"f82323ee06f59735","name":"Resilient Will","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Will Defense against effects that target Wisdom and may reroll a failed check once per encounter.","prerequisite":"Wis 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["defense","feat","general","survivability"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will","turn.once-per-round"],"enabled":true,"priority":500,"description":"Resilient Will"}]},"shortSummary":"You gain a +2 bonus on Will Defense against effects that target Wisdom and may reroll a failed check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":["defense.will","turn.once-per-round"]}}}
{"_id":"f8748ba7993b6b17","name":"Sure Climber","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a Climb Speed of 4 squares.","prerequisite":"Sullustan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","execution_mapped_phase9","feat","racial","skill_climb","skill_synergy","species","species_opportunity","species_rule"],"bonus_feat_for":["species-sullustan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a Climb Speed of 4 squares."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Sure Climber: climb speed 4 squares. Exposed as a movement mode hook.","rules":[{"type":"MOVEMENT_MODE_SET","mode":"climb","value":4,"unit":"squares","description":"Gain a Climb Speed of 4 squares.","displayAsCondition":true,"displayLabel":"Sure Climber","displayNote":"Climb speed 4 squares."}]},"shortSummary":"Gain a Climb Speed of 4 squares."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.sure_climber"}}}
{"_id":"f8e2a30390d870e7","name":"Improved Defenses","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +1 bonus to your Reflex Defense, Fortitude Defense, and Will Defense.","prerequisite":"None","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["defense","feat","general","survivability"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958","8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Improved_Defenses</p>\n<p>You are skilled at fending off attacks of many forms.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You gain a +1 bonus to your Reflex Defense, Fortitude Defense, and Will Defense.</p>\n<h4>Additional Improved Defenses Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Special:</strong> This Feat does not apply to the Defenses of a Vehicle, even if you are piloting or commanding it. This is one reason many Pilots prefer the Dodge Feat to Improved Defenses.</p>\n</div>"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":1,"type":"untyped","enabled":true,"priority":500,"description":"Improved Defenses: +1 to Fortitude Defense"},{"target":"defense.reflex","value":1,"type":"untyped","enabled":true,"priority":500,"description":"Improved Defenses: +1 to Reflex Defense"},{"target":"defense.will","value":1,"type":"untyped","enabled":true,"priority":500,"description":"Improved Defenses: +1 to Will Defense"}]},"choiceMeta":{"resolution":"none","required":false,"status":"intrinsic_global_bonus","choiceKind":"improved_defenses","choiceSource":"none","repeatable":false,"effectTarget":"defense.all","effectValue":1},"shortSummary":"Gain +1 bonus to all Defenses.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Improved_Defenses"},"effects":[{"name":"Improved Defenses","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.reflex.bonus","mode":2,"value":"1","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"defense-bonus","defense":"reflex","migratedToPassive":true}}},{"name":"Improved Defenses","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.fortitude.bonus","mode":2,"value":"1","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"defense-bonus","defense":"fortitude","migratedToPassive":true}}},{"name":"Improved Defenses","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.will.bonus","mode":2,"value":"1","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"defense-bonus","defense":"will","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.improved_defenses","intrinsicNoChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improved_Defenses","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"f916516eeeaae10b","name":"Gungan Weapon Master","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Increase the die type when adding Force Points to attacks with an Atlatl or Cesta.","prerequisite":"Gungan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","feat","force_point_spend","racial","resource_spend","species","species_opportunity","species_prerequisite_phase10","species_rule"],"bonus_feat_for":["species-gungan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Increase the die type when adding Force Points to attacks with an Atlatl or Cesta."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Gungan Weapon Master: increase Force Point die type on attacks with Atlatl or Cesta.","rules":[{"type":"FORCE_POINT_DIE_STEP","value":1,"domains":["attack"],"weaponNames":["atlatl","cesta"],"description":"Increase the die type when adding Force Points to attacks with an Atlatl or Cesta."}]},"prerequisitesStructured":{"type":"all","conditions":[{"type":"species","species":["Gungan"]}],"_source":"phase10_species_prereq"},"shortSummary":"Increase the die type when adding Force Points to attacks with an Atlatl or Cesta."},"effects":[{"_id":"88fe2270-9c25-4453-a518-0fa6729d4afe","name":"Gungan Weapon Master","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Gungan Weapon Master","effectType":"special","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.gungan_weapon_master"}}}
{"_id":"f965ca153bb13aaf","name":"Nature Specialist","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Increase the die type when adding Force Points to a Knowledge (Life Sciences) check.","prerequisite":"Ithorian","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","feat","force_point_spend","racial","resource_spend","skill_knowledge","skill_synergy","species","species_opportunity","species_rule"],"bonus_feat_for":["species-ithorian"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Increase the die type when adding Force Points to a Knowledge (Life Sciences) check."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Nature Specialist: increase Force Point die type on Knowledge (Life Sciences) checks.","rules":[{"type":"FORCE_POINT_DIE_STEP","value":1,"domains":["skill"],"skills":["knowledgeLifeSciences"],"description":"Increase the die type when adding Force Points to a Knowledge (Life Sciences) check."}]},"shortSummary":"Increase the die type when adding Force Points to a Knowledge (Life Sciences) check."},"effects":[{"_id":"c632079d-0af6-4580-a501-594d7092128a","name":"Nature Specialist","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Nature Specialist","effectType":"special","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.nature_specialist"}}}
{"_id":"f9ae5b531ae01fd0","name":"Surgical Expertise","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can perform Surgery in 10 minutes.","prerequisite":"Trained in Treat Injury","special":"","normalText":"Performing Surgery typically takes 1 hour.","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["feat","general","healing","skill_treat_injury","support"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Surgical_Expertise</p>\n<p>You can perform skillful surgical procedures quickly.</p>\n<p><strong>Prerequisites:</strong> Trained in Treat Injury</p>\n<h4>Effect</h4>\n<p>You can perform Surgery in 10 minutes.</p>\n<h4>Normal</h4>\n<p>Performing Surgery typically takes 1 hour.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"treatinjury"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Surgical Expertise"}]},"shortSummary":"You can perform Surgery in 10 minutes instead of 1 hour.","prerequisitesText":"Trained in Treat Injury","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Surgical_Expertise"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.surgical_expertise","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Surgical_Expertise","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fa8a56961708bbdc","name":"Unstoppable Combatant","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can catch more than one Second Wind per encounter.","prerequisite":"Extra Second Wind","special":"","normalText":"Even if you can catch multiple Second Winds per day, without this Feat you are limited to one Second Wind per encounter.","sourcebook":"Rebellion Era Campaign Guide","page":22,"tags":["feat","general","recovery","second_wind"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Unstoppable_Combatant</p>\n<p>You can keep coming back for more punishment, no matter what your enemies throw at you.</p>\n<p><strong>Prerequisites:</strong> Extra Second Wind</p>\n<h4>Effect</h4>\n<p>You can catch more than one Second Wind per encounter.</p>\n<h4>Normal</h4>\n<p>Even if you can catch multiple Second Winds per day, without this Feat you are limited to one Second Wind per encounter.</p>\n</div>"},"executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Unstoppable Combatant"}],"resourceRules":{"secondWind":[{"type":"IGNORE_ENCOUNTER_CAP","description":"You may catch more than one Second Wind in an encounter, as long as uses remain."}]}},"resourceRules":{"secondWind":[{"type":"IGNORE_ENCOUNTER_CAP"}]},"shortSummary":"Catch more than one Second Wind in an encounter.","prerequisitesText":"Extra Second Wind","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Combatant"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.unstoppable_combatant","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Combatant","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fb64065b4a779cd8","name":"Artillery Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make an attack with a Burst or Splash weapon with which you are proficient against a target at greater than Point-Blank Range, you can affect two additional squares adjacent to the normal Burst radius or Splash area.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":20,"tags":["area_pressure","feat","general","grenade","multi_target","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Artillery_Shot</p>\n<p>You have learned to use the angle and distance between you and your target to devastating effect.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When you make an attack with a Burst or Splash weapon with which you are proficient against a target at greater than Point-Blank Range, you can affect two additional squares adjacent to the normal Burst radius or Splash area.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Artillery Shot"}]},"shortSummary":"You increase the efficiency of your Burst and Splash weapon attacks.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Artillery_Shot"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.artillery_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Artillery_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fbd561777651635e","name":"Autofire Sweep","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making an Autofire attack with a weapon with which you possess the Weapon Focus feat, you can attack all targets in a 6-Square Cone. The origin square of the cone can be any square in your line of sight and within Point-Blank Range.","prerequisite":"Weapon Focus (Chosen Weapon)","special":"This Feat cannot be used with the Autofire Assault feat or the Burst Fire feat. It can be used with the Improved Suppression Fire Talent.","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":16,"tags":["area_pressure","autofire","feat","general","multi_target","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Autofire_Sweep</p>\n<p>Your can sweep an area with your Autofire weapon, spraying fire in a 180-degree arc in front of you.</p>\n<p><strong>Prerequisites:</strong> Weapon Focus (Chosen Weapon)</p>\n<h4>Effect</h4>\n<p>When making an Autofire attack with a weapon with which you possess the Weapon Focus feat, you can attack all targets in a 6-Square Cone. The origin square of the cone can be any square in your line of sight and within Point-Blank Range.</p>\n<h4>Special</h4>\n<p>This Feat cannot be used with the Autofire Assault feat or the Burst Fire feat. It can be used with the Improved Suppression Fire Talent.</p>\n<h4>Homebrew Autofire Sweep Data</h4>\n<p>This Homebrew Content has not been reviewed in a meaningful manner. If you wish to review this content yourself, then see Untested for more details.</p>\n<p>Autofire Sweep data created by Wikia user Chellewalker (formally Wikia user Lukewarner).</p>\n<p>To prevent this feat from unbalancing a game, have all targets of an attack with the Autofire Sweep feat be treated as though they posses the Evasion Talent.</p>\n<p>All targets take half damage from a successful attack, and no damage if the attack misses. If a target of an Autofire Sweep attack already possess the Evasion Talent, then they take no damage regardless of the attack roll.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Autofire Sweep"}]},"shortSummary":"Sweep a wide area while using Autofire mode.","prerequisitesText":"Weapon Focus (Chosen Weapon)","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Autofire_Sweep"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.autofire_sweep","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Autofire_Sweep","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fc1e5f0a2367debb","name":"Bantha Rush","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"After making a successful melee attack against an opponent up to one size category larger than you, you can choose to move that opponent 1 square in any direction as a Free Action. You can't Bantha Rush an opponent that's being Grabbed or Grappled, and you can't Bantha Rush your opponent into a solid object or another creature's Fighting Space.","prerequisite":"Strength 13, Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Galaxy at War","page":23,"tags":["feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Bantha_Rush</p>\n<p>You can shove your opponents around the battlefield to gain a tactical advantage.</p>\n<p><strong>Prerequisites:</strong> Strength 13, Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>After making a successful melee attack against an opponent up to one size category larger than you, you can choose to move that opponent 1 square in any direction as a Free Action. You can&#x27;t Bantha Rush an opponent that&#x27;s being Grabbed or Grappled, and you can&#x27;t Bantha Rush your opponent into a solid object or another creature&#x27;s Fighting Space.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13},{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit","attack.with-melee"],"enabled":true,"priority":500,"description":"Bantha Rush"}]},"shortSummary":"Push opponent 1 square after making a successful melee attack.","prerequisitesText":"Strength 13, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Bantha_Rush"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":["attack.when-hit","attack.with-melee"],"id":"swse.feat.bantha_rush","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Bantha_Rush","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fc56de4d0d15c95c","name":"Jedi Familiarity","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, when you are targeted or affected by a Force Power or Force Talent originating from an ally, you gain one temporary Force Point, which must be spent before the end of the encounter or it goes away. If the Force Power or Force Talent damages you or moves you down the Condition Track, you do not gain the benefit of this Feat.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":25,"tags":["ally_support","feat","force_point_spend","force_powers","general","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Jedi_Familiarity</p>\n<p>You have worked alongside Jedi or other Force-users and have developed an excellent rapport.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Once per encounter, when you are targeted or affected by a Force Power or Force Talent originating from an ally, you gain one temporary Force Point, which must be spent before the end of the encounter or it goes away. If the Force Power or Force Talent damages you or moves you down the Condition Track, you do not gain the benefit of this Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Jedi Familiarity"}]},"shortSummary":"Gain one temporary Force Point when targeted by an ally's Force Power or Force Talent.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Jedi_Familiarity"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.jedi_familiarity","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Jedi_Familiarity","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"fda012e3b2b1e55f","name":"Resilient Talent","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per day, you may gain the benefit of any talent from a class you have levels in for 1 minute. You may use this talent even if you do not meet its prerequisites.","prerequisite":"Level 6","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":27,"tags":["defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Resilient Talent"}]},"shortSummary":"Once per day, you may gain the benefit of any talent from a class you have levels in for 1 minute."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[]}}}
{"_id":"febbb0f05c8a0883","name":"Forest Stalker","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Reroll Stealth checks, always keeping the better result.","prerequisite":"Ewok","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["control","feat","grapple","racial","reroll","skill_stealth","skill_synergy","species","species_opportunity","skill_reroll","execution_mapped_phase8"],"bonus_feat_for":["species-ewok"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Reroll Stealth checks, always keeping the better result."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8","description":"Forest Stalker: reroll Stealth checks and keep the better result.","skillRerolls":[{"id":"forest-stalker","skillKeys":["stealth"],"outcome":"keepBetter","label":"Forest Stalker","description":"Forest Stalker: reroll Stealth checks and keep the better result."}]},"shortSummary":"Reroll Stealth checks, always keeping the better result."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[],"id":"swse.feat.forest_stalker"}}}
{"_id":"ff76bea42641ca5b","name":"Forceful Stun","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Use the Force checks made to activate Force Stun.","prerequisite":"Trained in Use the Force, Force Stun","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["control","feat","force"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Forceful Stun"}]},"shortSummary":"You gain a +2 bonus on Use the Force checks made to activate Force Stun."},"effects":[{"_id":"2a977ad3-fabc-43dc-80bc-bd75d8807383","name":"Forceful Stun","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Forceful Stun","effectType":"skill_bonus","flagType":"Forceful Stun"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.389Z","detectedPredicates":[]}}}
{"_id":"ff8eaa4e2f6d1cf1","name":"Mobility","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You get a +5 dodge bonus to Reflex Defense against Attacks of Opportunity caused when you move out of or into a threatened area.","prerequisite":"Dexterity 13, Dodge","special":"A situation that makes you lose your Dexterity bonus to Reflex Defense (If any) also makes you lose dodge bonuses. Dodge bonuses also stack with each other, unlike most other types of bonuses.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["anti_opportunity_attack","defense","feat","general","mobility"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Mobility</p>\n<p>You are skilled at moving past opponents and avoiding opportunistic attacks.</p>\n<p><strong>Prerequisites:</strong> Dexterity 13, Dodge</p>\n<h4>Effect</h4>\n<p>You get a +5 dodge bonus to Reflex Defense against Attacks of Opportunity caused when you move out of or into a threatened area.</p>\n<h4>Special</h4>\n<p>A situation that makes you lose your Dexterity bonus to Reflex Defense (If any) also makes you lose dodge bonuses. Dodge bonuses also stack with each other, unlike most other types of bonuses.</p>\n</div>"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.reflex","type":"untyped","value":5,"enabled":true,"priority":500,"description":"Migrated from AE system.defenses.reflex.bonus"}]},"shortSummary":"Gain +5 dodge bonus to Reflex Defense against some Attacks of Opportunity.","prerequisitesText":"Dexterity 13, Dodge","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Mobility"},"effects":[{"name":"Mobility","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.reflex.bonus","mode":2,"value":"5","priority":20}],"transfer":true,"flags":{"swse":{"type":"conditional","condition":"vs attacks of opportunity","migratedToPassive":true}},"disabled":true}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.mobility","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mobility","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ffd5fecab0550bb6","name":"Forceful Vitality","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Endurance checks and may reroll a failed Endurance check once per encounter.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","force"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"skill.endurance","type":"untyped","value":2,"enabled":true,"priority":500,"description":"Migrated from AE system.skills.endurance.miscMod"}]},"shortSummary":"You gain a +2 bonus on Endurance checks and may reroll a failed Endurance check once per encounter."},"effects":[{"name":"Forceful Vitality","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.skills.endurance.miscMod","mode":2,"value":"2","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"feat-skill-bonus","source":"Forceful Vitality","skillKey":"endurance","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
