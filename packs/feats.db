{"_id":"18779d9a72b47a12","name":"Technical Experts","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Mechanics checks when near allies.","prerequisite":"Trained in Mechanics","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_mechanics","skill_synergy","team","teamwork","tech","utility","conditional_skill_bonus","execution_mapped_phase8","manual_resolution","teamwork_base_skill_bonus_phase15"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Mechanics</p>\n<p><strong>Effect:</strong> You gain a +3 competence bonus on<br>Mechanics<br>checks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).<br><br>Additionally, when you use the<br>Aid Another<br>Action to assist an ally who has this Feat with a<br>Mechanics<br>check, you provide a bonus of +4 instead of +2.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Technical_Experts</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_with_manual_teamwork","applicationScope":"skill_roll_plus_manual_teamwork","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Technical Experts: +3 competence skill bonus applies normally; nearby-ally scaling and other battlefield/teamwork clauses are GM/player managed.","predicateRequirements":[],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 avoids automating nearby-ally/battlefield positioning clauses; base skill bonuses are implemented where unambiguous and teamwork clauses are preserved as manual metadata.","implementationStatus":"base_skill_bonus_manual_teamwork_phase15","description":"Technical Experts: base +3 competence skill bonus implemented; nearby-ally scaling and special teamwork clauses remain table-managed flavor/manual metadata.","skillCheckBonuses":[{"id":"technical-experts","skillKey":"mechanics","type":"competence","featName":"Technical Experts","description":"Technical Experts: +3 competence bonus to mechanics checks. Nearby-ally scaling is manual/table-managed.","value":3}],"teamworkRules":[{"type":"AID_ANOTHER_BONUS_OVERRIDE","skillKey":"mechanics","bonus":4,"requiresAllyHasFeat":true,"description":"Aid Another provides +4 instead of +2 when assisting an ally with this feat on Mechanics.","automation":"manual","manualResolution":true}]},"shortSummary":"Gain bonuses on Mechanics checks when near allies.","sourceUrl":"https://swse.fandom.com/wiki/Technical_Experts","rawImport":{"name":"Technical Experts","url":"https://swse.fandom.com/wiki/Technical_Experts","pageTitle":"Technical_Experts","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\technical_experts.html","referenceBooks":[],"prerequisitesText":"Trained\nin\nMechanics","prerequisites":["Trained\nin\nMechanics"],"effect":"You gain a +3 competence bonus on\nMechanics\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you use the\nAid Another\nAction to assist an ally who has this Feat with a\nMechanics\ncheck, you provide a bonus of +4 instead of +2.","benefit":"","normal":"","special":"","indexPrerequisites":"Trained in Mechanics","indexBenefit":"Gain bonuses on Mechanics checks when near allies.","indexPage":"Specialization_Feats","indexSection":"Team Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nTeam Feats\n\nYou and your allies are just as comfortable in the vehicle pool as on the battlefield and are capable of maintaining heavy equipment.\n\nPrerequisite:\nTrained\nin\nMechanics\n\nEffect:\nYou gain a +3 competence bonus on\nMechanics\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you use the\nAid Another\nAction to assist an ally who has this Feat with a\nMechanics\ncheck, you provide a bonus of +4 instead of +2."},"prerequisitesText":"Trained\nin\nMechanics","effect":"You gain a +3 competence bonus on\nMechanics\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you use the\nAid Another\nAction to assist an ally who has this Feat with a\nMechanics\ncheck, you provide a bonus of +4 instead of +2."},"effects":[{"_id":"84fed409-8efc-4d98-b57c-e524969fea3c","name":"Technical Experts","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Technical Experts","effectType":"skill_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.technical_experts"}}}
{"_id":"18f535b84cff63c3","name":"Lucky Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you may reroll a ranged attack roll and take the better result.","prerequisite":"Point Blank Shot","special":"","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["feat","general","offense","offense_ranged"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"attack_reroll_phase8_implemented","description":"Lucky Shot: reroll ranged attack rolls once per encounter and keep the better result.","attackRerolls":[{"type":"ATTACK_REROLL","trigger":"rangedAttack","outcome":"keepBetter","oncePer":"encounter","description":"Lucky Shot: reroll ranged attack rolls once per encounter and keep the better result."}],"mechanicsMode":"conditional","applicationScope":"reroll_or_resource_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rerolls/resources are not static sheet modifiers and require a check/encounter/resource context.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Once per encounter, you may reroll a ranged attack roll and take the better result."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["attack.with-ranged","turn.once-per-round"]}}}
{"_id":"191aacaecaa92ce1","name":"Logic Upgrade: Self-Defense","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Grant yourself +2 to the Defense of your choice for 1 round.","prerequisite":"Droid","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":27,"tags":["defense","feat","general","knowledge","survivability","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Grant yourself +2 to the Defense of your choice for 1 round."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"ACTIVE","subType":"RULE","mechanicsMode":"active","applicationScope":"temporary_defense_choice_context","staticSheetPolicy":"resource_only","requiresRuntimeContext":true,"requiresSelectedChoice":true,"conditionSummary":"Active logic upgrade: choose one defense to gain +2 for 1 round.","predicateRequirements":["active.logicUpgrade"],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 continues description-guided implementation by improving teamwork skill feats, skill substitutions, force/dark-side skill context, and several remaining action/resource rider feats.","implementationStatus":"temporary_defense_choice_metadata_phase15","description":"Logic Upgrade: Self-Defense grants +2 to one chosen Defense for 1 round.","activeRules":[{"type":"TEMPORARY_DEFENSE_BONUS_CHOICE","targets":["defense.fortitude","defense.reflex","defense.will"],"value":2,"durationRounds":1,"description":"Choose one Defense; gain +2 to that Defense for 1 round."}],"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Logic Upgrade: Self-Defense is an active one-round defense choice, not a static modifier.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude","metadataPhase":"phase15-next-feat-batch"}]},"shortSummary":"Grant yourself +2 to 