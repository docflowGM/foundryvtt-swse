{"_id":"0053d97632b02e4a","name":"Wary Sentries","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Perception checks when near allies.","prerequisite":"Trained in Perception","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_perception","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain bonuses on Perception checks when near allies."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"conditional_skill_bonus_phase8","description":"Wary Sentries: +3 bonus to perception checks when the near-allies condition is confirmed.","skillCheckBonuses":[{"id":"wary-sentries","skillKeys":["perception"],"value":3,"type":"untyped","requiresContextFlags":["nearAllies"],"description":"Wary Sentries: +3 when near supporting allies."}]},"shortSummary":"Gain bonuses on Perception checks when near allies."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.375Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.wary_sentries"}}}
{"_id":"005e922d0430d86b","name":"Resurgence","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you catch your Second Wind, you immediately gain a Move Action to be used immediately.","prerequisite":"Trained in Endurance","special":"","normalText":"","sourcebook":"Scum and Villainy","page":27,"tags":["action_economy","defense","feat","general","move_action","recovery","second_wind","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Resurgence</p>\n<p>Catching your Second Wind allows you to seize the advantage in combat.</p>\n<p><strong>Prerequisites:</strong> Trained in Endurance</p>\n<h4>Effect</h4>\n<p>When you catch your Second Wind, you immediately gain a Move Action to be used immediately.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"35df8faa4878f2c5"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[]},"resourceRules":{"secondWind":[{"type":"GRANT_MOVE_ACTION_ON_USE"}]},"shortSummary":"Gain bonus Move Action when you catch your Second Wind.","prerequisitesText":"Trained in Endurance","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Resurgence"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[],"id":"swse.feat.resurgence","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Resurgence","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0066c394e5d636fb","name":"Spray Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you have a weapon set on Autofire, you can reduce the area targeted by your Autofire attack to 1 square.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":27,"tags":["area_pressure","autofire","feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Spray_Shot</p>\n<p>You can fire a short burst at an enemy while protecting nearby allies from errant shots.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When you have a weapon set on Autofire, you can reduce the area targeted by your Autofire attack to 1 square.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Spray Shot"}]},"shortSummary":"When using a weapon set on Autofire, you can reduce the area to 1 square.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Spray_Shot"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[],"id":"swse.feat.spray_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Spray_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0166fcdddc548545","name":"Improved Charge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can make a Charge without having to move in a straight line, and you can alter your direction when making a Charge to avoid obstacles. All other Charge rules apply.","prerequisite":"Dexterity 13, Dodge, Mobility","special":"","normalText":"A character must Charge in an unobstructed straight line.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["charge","feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Improved_Charge</p>\n<p>You can Charge around obstacles.</p>\n<p><strong>Prerequisites:</strong> Dexterity 13, Dodge, Mobility</p>\n<h4>Effect</h4>\n<p>You can make a Charge without having to move in a straight line, and you can alter your direction when making a Charge to avoid obstacles. All other Charge rules apply.</p>\n<h4>Normal</h4>\n<p>A character must Charge in an unobstructed straight line.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Improved Charge"}]},"shortSummary":"You can Charge without moving in a straight line.","prerequisitesText":"Dexterity 13, Dodge, Mobility","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Improved_Charge"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[],"id":"swse.feat.improved_charge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improved_Charge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"01dee6f32bbd8f85","name":"Battering Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you successfully move a creature with the Bantha Rush Feat, you also knock that target Prone.","prerequisite":"Bantha Rush, Trip","special":"","normalText":"","sourcebook":"Galaxy at War","page":20,"tags":["control","feat","general","knock_prone","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Battering_Attack</p>\n<p>You know how to use your strength to batter an opponent to the ground, knocking him or her Prone.</p>\n<p><strong>Prerequisites:</strong> Bantha Rush, Trip</p>\n<h4>Effect</h4>\n<p>Whenever you successfully move a creature with the Bantha Rush Feat, you also knock that target Prone.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["target.is-prone"],"enabled":true,"priority":500,"description":"Battering Attack"}]},"shortSummary":"Knock an opponent Prone when you use Bantha Rush.","prerequisitesText":"Bantha Rush, Trip","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Battering_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":["target.is-prone"],"id":"swse.feat.battering_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Battering_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
