{"_id":"db82e1df17c3110b","name":"Bowcaster Marksman","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to damage rolls when you spend a Force Point on a Bowcaster attack.","prerequisite":"Wookiee","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","force_point_spend","racial","resource_spend","species","species_opportunity"],"bonus_feat_for":["species-wookiee"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Wookiee</p>\n<p><strong>Effect:</strong> Whenever you spend a<br>Force Point<br>to add to an attack with a<br>Bowcaster<br>, if you hit the target, you gain a competence bonus to your damage roll equal to the amount added to the attack.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Bowcaster_Marksman</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":false,"priority":500,"description":"Bowcaster Marksman: Implemented as CombatOptionResolver/rider metadata; old migrated numeric modifier disabled.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit"],"conditionSummary":"Implemented as CombatOptionResolver/rider metadata; old migrated numeric modifier disabled.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Bowcaster Marksman now has explicit roll-context/rider metadata from its description.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 continued replacing false scaffo