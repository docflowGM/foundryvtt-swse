{"_id":"08896a9f860ebca9","name":"Pitiless Warrior","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain Bonus Hit Points whenever you take down a foe.","prerequisite":"Trandoshan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["durability","feat","hit_points","racial","species","species_opportunity"],"bonus_feat_for":["species-trandoshan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain Bonus Hit Points whenever you take down a foe."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Pitiless Warrior"}]},"shortSummary":"Gain Bonus Hit Points whenever you take down a foe."},"effects":[{"_id":"f3ae6fcb-66f0-4608-afa0-a8f2d593188f","name":"Pitiless Warrior","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Pitiless Warrior","effectType":"combat_bonus","flagType":"Pitiless Warrior"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.pitiless_warrior"}}}
{"_id":"08a15012d82f0d16","name":"Scion of Dorin","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Fortitude Defense against Atmospheric Hazards.","prerequisite":"Kel Dor","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-kel-dor"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to Fortitude Defense against Atmospheric Hazards."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":5,"type":"untyped","predicates":["defense.fortitude"],"enabled":true,"priority":500,"description":"Scion of Dorin"}]},"shortSummary":"Gain a bonus to Fortitude Defense against Atmospheric Hazards."},"effects":[{"_id":"8152154b-93e2-42e0-9f67-aefc79526f69","name":"Scion of Dorin","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Scion of Dorin","effectType":"defense_bonus","flagType":"Scion of Dorin"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["defense.fortitude"],"id":"swse.feat.scion_of_dorin"}}}
{"_id":"08dbd76457db101f","name":"Saber Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You may throw your lightsaber as a ranged attack using Use the Force instead of a ranged attack roll. The lightsaber returns to your hand at the end of the turn.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":94,"tags":["feat","force","offense","offense_melee"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":true,"priority":500,"description":"Saber Throw"}]},"shortSummary":"You may throw your lightsaber as a ranged attack using Use the Force instead of a ranged attack roll."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["attack.with-ranged"]}}}
{"_id":"09d4eedfce05c6a3","name":"Pincer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully Pin an enemy, you can maintain the Pin beyond 1 round and can make subsequent Grapple checks against the Pinned enemy as a Swift Action. You can apply the Crush Feat whenever your subsequent checks are successful.","prerequisite":"Droid, Claw or Hand Appendage, Base Attack Bonus +1, Pin, Crush","special":"You must have a Claw or Hand Appendage to use this Feat.","normalText":"Grapple checks are a Standard Action. The Pin Feat must be rerolled each round as a new Grapple check.","sourcebook":"Scavenger's Guide to Droids","page":23,"tags":["action_economy","control","feat","general","grapple","swift_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Pincer</p>\n<p>You use your mechanical strength to restrain and damage enemies.</p>\n<p><strong>Prerequisites:</strong> Droid, Claw or Hand Appendage, Base Attack Bonus +1, Pin, Crush</p>\n<h4>Effect</h4>\n<p>When you successfully Pin an enemy, you can maintain the Pin beyond 1 round and can make subsequent Grapple checks against the Pinned enemy as a Swift Action. You can apply the Crush Feat whenever your subsequent checks are successful.</p>\n<h4>Normal</h4>\n<p>Grapple checks are a Standard Action. The Pin Feat must be rerolled each round as a new Grapple check.</p>\n<h4>Special</h4>\n<p>You must have a Claw or Hand Appendage to use this Feat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Pincer"}]},"shortSummary":"Maintain Pin feat and make subsequent Grapple checks as a Swift Action. Apply Crush to each check.","prerequisitesText":"Droid, Claw or Hand Appendage, Base Attack Bonus +1, Pin, Crush","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Pincer"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.pincer","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Pincer","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"09faea502795c45f","name":"Grapple Resistance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You get a +5 bonus to your Reflex Defense when an enemy makes a Grab or Grapple attack against you, and you get a +5 bonus to all opposed Grapple checks. All objects that you are holding or carrying gain a +5 bonus to their Reflex Defense when attacked (see Attack an Object).","prerequisite":"None","special":"","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":19,"tags":["control","feat","general","grapple","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Grapple_Resistance</p>\n<p>You make it difficult for enemies to Grab or Grapple you, or attack objects in your possession.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You get a +5 bonus to your Reflex Defense when an enemy makes a Grab or Grapple attack against you, and you get a +5 bonus to all opposed Grapple checks. All objects that you are holding or carrying gain a +5 bonus to their Reflex Defense when attacked (see Attack an Object).</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"grappleRules":[{"type":"RESIST_GRAB_AND_GRAPPLE","bonus":5}],"status":"grapple_resistance","description":"Grapple Resistance: +5 bonus to resist Grab and Grapple attacks (feat-driven via metadata)."},"shortSummary":"Gain a +5 bonus to resist Grab and Grapple attacks.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Grapple_Resistance"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.grapple_resistance","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Grapple_Resistance","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0a6c87a410bee1f2","name":"Unstoppable Force","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +5 insight bonus to Fortitude Defense and Will Defense against any attack or effect requiring a Use the Force check.","prerequisite":"None","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":35,"tags":["feat","force","force_execution","skill_synergy","skill_use_the_force","use_the_force"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Unstoppable_Force</p>\n<p>Your constant exposure to Force-users has taught you methods of physically resisting their effect on you in battle.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You gain a +5 insight bonus to Fortitude Defense and Will Defense against any attack or effect requiring a Use the Force check.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.fortitude","defense.will"],"enabled":true,"priority":500,"description":"Unstoppable Force"}]},"shortSummary":"Gain a +5 bonus to Fortitude Defense and Will Defense against any effect requiring a Use the Force check.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Force"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["defense.fortitude","defense.will"],"id":"swse.feat.unstoppable_force","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Unstoppable_Force","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0ac76f1c0c1677cb","name":"Conditioning","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can reroll any\nStrength\n- or Constitution -based Skill Checks for Skills that you are Trained in. The result of the reroll must be accepted even if it is worse. Additionally, once per encounter you can add your Strength modifier to your Fortitude Defense as a Reaction ; this bonus lasts until the beginning of your next turn.","prerequisite":"Strength 13, Constitution 13","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":25,"tags":["ability_constitution","ability_strength","feat","general","reroll","skill_reroll","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Conditioning</p>\n<p>You are in excellent physical condition, enabling you to extend physical activities. You might not have great strength, but you have a lot of stamina.</p>\n<p><strong>Prerequisites:</strong> Strength 13, Constitution 13</p>\n<h4>Effect</h4>\n<p>You can reroll any\nStrength\n- or Constitution -based Skill Checks for Skills that you are Trained in. The result of the reroll must be accepted even if it is worse. Additionally, once per encounter you can add your Strength modifier to your Fortitude Defense as a Reaction; this bonus lasts until the beginning of your next turn.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13},{"type":"attribute","ability":"con","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8","description":"Conditioning: reroll Strength- and Constitution-based skill checks; accept the reroll result.","skillRerolls":[{"id":"conditioning","skillKeys":["climb","jump","swim","endurance"],"outcome":"keepSecond","label":"Conditioning","description":"Conditioning: reroll Strength- and Constitution-based skill checks; accept the reroll result."}]},"shortSummary":"Reroll Strength and Constitution based Skill Checks.","prerequisitesText":"Strength 13, Constitution 13","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Conditioning"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.conditioning","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Conditioning","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0c53cb8b7c29d865","name":"Stealthy","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Stealth checks and may reroll a failed Stealth check once per encounter.","prerequisite":"","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","skill_stealth","skill_synergy","stealth"],"bonus_feat_for":["21dfe84d159a1b7f","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_with_bonus_phase8_implemented","description":"Stealthy: +2 bonus to Stealth checks; reroll Stealth checks once per encounter and keep the better result.","skillCheckBonuses":[{"id":"stealthy-bonus","skillKeys":["stealth"],"value":2,"type":"untyped","description":"Stealthy: +2 bonus to Stealth checks."}],"skillRerolls":[{"id":"stealthy-reroll","skillKeys":["stealth"],"outcome":"keepBetter","oncePer":"encounter","label":"Stealthy","description":"Stealthy: reroll Stealth checks once per encounter and keep the better result."}]},"shortSummary":"You gain a +2 bonus on Stealth checks and may reroll a failed Stealth check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["turn.once-per-round"]}}}
{"_id":"0d4d7c147c48cdab","name":"Burst Fire","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using a ranged weapon with Autofire capability, and that you are Proficient with, in Autofire mode, you may fire a short burst as a single attack against a single target. You take a -5 penalty on your attack roll, but deal +2 dice of damage.\n\nThe effects of this Feat do not stack with the extra damage provided by the Deadeye or Rapid Shot feats.\n\nIf you do not have a Strength of 13 or higher, increase the penalty on attacks to -10 when using this Feat with non- Vehicle Weapons.","prerequisite":"Proficient with Heavy Weapons","special":"Firing a burst expends five shots, and can only be done if the weapon has at least five shots remaining.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["area_pressure","autofire","feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Burst_Fire</p>\n<p>When using a ranged weapon in Autofire mode, you can fire a short Burst at a single foe.</p>\n<p><strong>Prerequisites:</strong> Proficient with Heavy Weapons</p>\n<h4>Effect</h4>\n<p>When using a ranged weapon with Autofire capability, and that you are Proficient with, in Autofire mode, you may fire a short burst as a single attack against a single target. You take a -5 penalty on your attack roll, but deal +2 dice of damage.</p>\n<p>The effects of this Feat do not stack with the extra damage provided by the Deadeye or Rapid Shot feats.</p>\n<p>If you do not have a Strength of 13 or higher, increase the penalty on attacks to -10 when using this Feat with non- Vehicle Weapons.</p>\n<h4>Special</h4>\n<p>Firing a burst expends five shots, and can only be done if the weapon has at least five shots remaining.</p>\n<h4>Additional Burst Fire Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p>Vehicle Weapons capable of Autofire can be used with this feat normally. Additional dice of damage are added before any multiplier from the Vehicle Weapon is applied.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Burst Fire"}]},"shortSummary":"Take a -5 penalty on an Autofire attack to gain +2 dice of damage.","prerequisitesText":"Proficient with Heavy Weapons","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Burst_Fire"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.burst_fire","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Burst_Fire","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0dbd1d12c0b99725","name":"Zero Range","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When firing a ranged weapon at a target within or adjacent to your Fighting Space, you gain a +1 bonus on the attack roll and deal +1 die of damage on a hit.","prerequisite":"Point-Blank Shot","special":"The effects of this Feat do not stack with the extra damage provided by the Burst Fire or Rapid Shot Feats. This Feat does not apply to Heavy Weapons or Vehicle Weapons, or in Vehicle Combat.","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":23,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Zero_Range</p>\n<p>You are lethal when using ranged weapons against adjacent targets.</p>\n<p><strong>Prerequisites:</strong> Point-Blank Shot</p>\n<h4>Effect</h4>\n<p>When firing a ranged weapon at a target within or adjacent to your Fighting Space, you gain a +1 bonus on the attack roll and deal +1 die of damage on a hit.</p>\n<h4>Special</h4>\n<p>The effects of this Feat do not stack with the extra damage provided by the Burst Fire or Rapid Shot Feats. This Feat does not apply to Heavy Weapons or Vehicle Weapons, or in Vehicle Combat.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":true,"priority":500,"description":"Zero Range"}]},"shortSummary":"Gain a +1 bonus on your attack roll and deal +1 die of damage when making a ranged attack against an adjacent target or a target in your Fighting Space.","prerequisitesText":"Point-Blank Shot","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Zero_Range"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.zero_range","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Zero_Range","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0e9aa3d941f4eb80","name":"Mounted Regiment","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Ride checks when near allies.","prerequisite":"Trained in Ride","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_ride","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain bonuses on Ride checks when near allies."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"conditional_skill_bonus_phase8","description":"Mounted Regiment: +3 bonus to ride checks when the near-allies condition is confirmed.","skillCheckBonuses":[{"id":"mounted-regiment","skillKeys":["ride"],"value":3,"type":"untyped","requiresContextFlags":["nearAllies"],"description":"Mounted Regiment: +3 when near supporting allies."}]},"shortSummary":"Gain bonuses on Ride checks when near allies."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["defense.reflex","proximity.count-allies-within-12","turn.once-per-round"],"id":"swse.feat.mounted_regiment"}}}
{"_id":"10a017a020aa4a9c","name":"Forceful Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Use the Force checks made to activate Move Object.","prerequisite":"Trained in Use the Force, Move Object","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","force","offense","offense_melee"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Forceful Throw"}]},"shortSummary":"You gain a +2 bonus on Use the Force checks made to activate Move Object."},"effects":[{"_id":"f40c0e8c-27d6-4fb4-b60b-480437c9ad82","name":"Forceful Throw","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Forceful Throw","effectType":"skill_bonus","flagType":"Forceful Throw"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[]}}}
{"_id":"11db29efd899c438","name":"Toughness","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain +1 Hit Point per Character Level.","prerequisite":"None","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["defense","durability","feat","general","hit_points","survivability"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Toughness</p>\n<p>You are tougher than normal.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You gain +1 Hit Point per Character Level.</p>\n</div>"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"hp.max","type":"untyped","value":5,"enabled":true,"priority":500,"description":"Migrated from AE system.hitPoints.bonusPerLevel"}]},"shortSummary":"Gain +1 Hit Point per Character Level.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Toughness"},"effects":[{"name":"Toughness","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.hitPoints.bonusPerLevel","mode":2,"value":"5","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"hit-points","perLevel":true,"migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.toughness","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Toughness","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1228a537592ad145","name":"Grazing Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully make a ranged attack against a single target, you can make a second attack roll against an additional target that is in direct line of sight, and no farther than 6 squares from the original target. If the second attack roll succeeds, make a single damage roll, and divide the damage equally between the two targets. If the second attack roll fails, you deal no damage to either target.","prerequisite":"Point-Blank Shot","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":19,"tags":["feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Grazing_Shot</p>\n<p>Using precise aim, you can hit two targets with a single shot.</p>\n<p><strong>Prerequisites:</strong> Point-Blank Shot</p>\n<h4>Effect</h4>\n<p>When you successfully make a ranged attack against a single target, you can make a second attack roll against an additional target that is in direct line of sight, and no farther than 6 squares from the original target. If the second attack roll succeeds, make a single damage roll, and divide the damage equally between the two targets. If the second attack roll fails, you deal no damage to either target.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Grazing Shot"}]},"shortSummary":"Strike two targets in direct line of sight, dealing half damage to each.","prerequisitesText":"Point-Blank Shot","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Grazing_Shot"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":[],"id":"swse.feat.grazing_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Grazing_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"125c328c4573890a","name":"Ascension Specialists","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Climb checks when near allies.","prerequisite":"Trained in Climb","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_climb","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain bonuses on Climb checks when near allies."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"conditional_skill_bonus_phase8","description":"Ascension Specialists: +3 bonus to climb checks when the near-allies condition is confirmed.","skillCheckBonuses":[{"id":"ascension-specialists","skillKeys":["climb"],"value":3,"type":"untyped","requiresContextFlags":["nearAllies"],"description":"Ascension Specialists: +3 when near supporting allies."}]},"shortSummary":"Gain bonuses on Climb checks when near allies."},"effects":[{"_id":"82f35e76-4fd1-4c6e-82bc-c846bae6eff2","name":"Ascension Specialists","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Ascension Specialists","effectType":"skill_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.ascension_specialists"}}}
{"_id":"12d064d086102ff0","name":"Rapid Reaction","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you can use two different Reactions in response to the same trigger. For example, if you use the Deflect Talent and fail to negate the attack, you can also use Negate Energy as a response to the same attack.","prerequisite":"None","special":"","normalText":"Without this Feat, you can use only one Reaction in response to a particular trigger.","sourcebook":"Rebellion Era Campaign Guide","page":21,"tags":["feat","general","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Rapid_Reaction</p>\n<p>Your lightning reflexes allow you to complete complex actions in response to the actions of others.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Once per encounter, you can use two different Reactions in response to the same trigger. For example, if you use the Deflect Talent and fail to negate the attack, you can also use Negate Energy as a response to the same attack.</p>\n<h4>Normal</h4>\n<p>Without this Feat, you can use only one Reaction in response to a particular trigger.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":true,"priority":500,"description":"Rapid Reaction"}]},"shortSummary":"React twice to the same trigger once per encounter.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Rapid_Reaction"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.rapid_reaction","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Rapid_Reaction","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1301d047e26db40d","name":"Hard Target","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus to Reflex Defense against ranged attacks while moving at least 2 squares on your turn.","prerequisite":"Dex 13, Dodge","special":"","normalText":"","sourcebook":"Galaxy at War","page":25,"tags":["feat","general"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.reflex","value":2,"type":"untyped","predicates":["defense.against-ranged","defense.reflex","attack.with-ranged","movement.while-moving","turn.on-current-turn"],"enabled":true,"priority":500,"description":"Hard Target"}]},"shortSummary":"You gain a +2 bonus to Reflex Defense against ranged attacks while moving at least 2 squares on your turn."},"effects":[{"_id":"7b3fc818-71ba-46cf-9592-d4827b36904f","name":"Hard Target","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.reflex.misc","mode":2,"value":"2"}],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Hard Target","effectType":"reflex_bonus","flagType":"rangedDefenseBonus"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.378Z","detectedPredicates":["defense.against-ranged","defense.reflex","attack.with-ranged","movement.while-moving","turn.on-current-turn"]}}}
{"_id":"139a80972fc3b8ee","name":"Confident Success","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a Force Point when you successfully Learn Secret Information.","prerequisite":"Bothan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","force_point_spend","racial","resource_spend","species","species_opportunity"],"bonus_feat_for":["species-bothan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a Force Point when you successfully Learn Secret Information."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Confident Success"}]},"shortSummary":"Gain a Force Point when you successfully Learn Secret Information."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.confident_success"}}}
{"_id":"14f0d916e9228368","name":"Channel Rage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per day, instead of entering into a Rage, you gain a +5 bonus to your Will Defense until the end of the encounter. This bonus counts as using your Rage ability for that day.","prerequisite":"Rage Species Trait","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":16,"tags":["execution_mapped_phase9","feat","general","offense_melee","rage","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Channel_Rage</p>\n<p>You have learned to turn your Rage into pure will and focus.</p>\n<p><strong>Prerequisites:</strong> Rage Species Trait</p>\n<h4>Effect</h4>\n<p>Once per day, instead of entering into a Rage, you gain a +5 bonus to your Will Defense until the end of the encounter. This bonus counts as using your Rage ability for that day.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rage_rule_phase9","description":"Channel Rage: alternate Rage mode grants +5 Will Defense instead of normal Rage.","rules":[{"type":"RAGE_ALTERNATE_MODE","mode":"channelRage","target":"defense.will","value":5,"description":"Instead of Raging, gain +5 to Will Defense."}]},"shortSummary":"Instead of Raging, gain +5 to Will Defense.","prerequisitesText":"Rage Species Trait","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Channel_Rage"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["defense.will"],"id":"swse.feat.channel_rage","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Channel_Rage","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"1592aaedf4b6e40a","name":"Skill Focus","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one Skill in which you are Trained. You gain a +5 competence bonus on all Skill Checks made with that Skill.","prerequisite":"None","special":"This Feat may be selected multiple times. Its effects do not stack. Each time you take this Feat, it applies to a different Trained Skill.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","choice_required","immediate_choice","skill_choice","choice_source_fixed"],"bonus_feat_for":["8c58016e587dd2c7","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Skill_Focus</p>\n<p>One of your Skills is particularly well honed.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Choose one Skill in which you are Trained. You gain a +5 competence bonus on all Skill Checks made with that Skill.</p>\n<h4>Special</h4>\n<p>This Feat may be selected multiple times. Its effects do not stack. Each time you take this Feat, it applies to a different Trained Skill.</p>\n</div>"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"value":5,"type":"competence","enabled":true,"priority":500,"description":"Skill Focus: +5 competence bonus to selected skill","targetFromSelectedChoice":{"prefix":"skill."}}]},"choiceMeta":{"resolution":"immediate","required":true,"status":"execution_mapped_phase6","choiceKind":"skill_focus","repeatable":true,"storagePath":"flags.swse.choices.skill_focus","choiceSource":"fixed","optionRegistry":"data/feat-choice-options.json#choiceKinds.skill_focus","effectTarget":"skill.selected","effectValue":5},"shortSummary":"Gain +5 competence bonus on Skill Checks with one Trained Skill.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Skill_Focus"},"effects":[{"name":"Skill Focus","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.skills.perception.miscMod","mode":2,"value":"5","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"skill-bonus","skill":"43c5941072ec78af","source":"Skill Focus","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.skill_focus","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Skill_Focus","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"167c394e90424916","name":"Accelerated Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, when using only weapons with which you are proficient, you can take a Full Attack Action as a Standard Action.","prerequisite":"Base Attack Bonus +6","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":25,"tags":["feat","general","offense","offense_melee","standard_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Accelerated_Strike</p>\n<p>Your melee attack is exceptionally quick.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +6</p>\n<h4>Effect</h4>\n<p>Once per encounter, when using only weapons with which you are proficient, you can take a Full Attack Action as a Standard Action.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":6}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":true,"priority":500,"description":"Accelerated Strike"}]},"shortSummary":"Once per encounter, make a Full Attack as a Standard Action.","prerequisitesText":"Base Attack Bonus +6","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Accelerated_Strike"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.accelerated_strike","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Accelerated_Strike","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"171f0d8d997c8bbc","name":"Wilderness First Aid","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per day, you can make a DC 20 Survival check. If the check is successful, when you use the Basic Survival application of the Survival skill, you are considered to have a Medpac for any Treat Injury checks made until the end of the day.","prerequisite":"Trained in Survival.","special":"The Gamemaster can adjust the DC for the current environment, raising it for harsh or desert climates or lowering it for diverse locales.","normalText":"","sourcebook":"Unknown Regions","page":28,"tags":["feat","general","healing","skill_survival","skill_synergy","skill_treat_injury","support","skill_use_access","equipment_waiver","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Wilderness_First_Aid</p>\n<p>You know how to treat wounds in the wilderness, using only the natural materials around you.</p>\n<p><strong>Prerequisites:</strong> Trained in Survival.</p>\n<h4>Effect</h4>\n<p>Once per day, you can make a DC 20 Survival check. If the check is successful, when you use the Basic Survival application of the Survival skill, you are considered to have a Medpac for any Treat Injury checks made until the end of the day.</p>\n<h4>Special</h4>\n<p>The Gamemaster can adjust the DC for the current environment, raising it for harsh or desert climates or lowering it for diverse locales.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_use_access_phase8","description":"Wilderness First Aid: equipment requirement for basic Treat Injury support is treated as a GM-enforced waiver; no medpac/toolkit validation is performed.","skillUseAccess":[{"id":"wilderness-first-aid-treat-injury-equipment-waiver","skillKeys":["treatInjury"],"applications":["First Aid","Treat Injury"],"waivesEquipmentRequirement":true,"description":"Treat basic Survival first-aid support as satisfying medpac access; equipment enforcement remains with the GM."}]},"shortSummary":"Use basic Survival skills as if you have a Medpac for Treat Injury checks.","prerequisitesText":"Trained in Survival.","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Wilderness_First_Aid"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":[],"id":"swse.feat.wilderness_first_aid","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Wilderness_First_Aid","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"17e317292814e13e","name":"Forceful Will","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You gain a +2 bonus on Will Defense against mind-affecting effects and may reroll a failed Will Defense check once per encounter.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["defense","feat","force","survivability"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will","turn.once-per-round"],"enabled":true,"priority":500,"description":"Forceful Will"}]},"shortSummary":"You gain a +2 bonus on Will Defense against mind-affecting effects and may reroll a failed Will Defense check once per encounter."},"effects":[{"name":"Forceful Will (vs mind-affecting)","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.will.misc","mode":2,"value":"2","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"feat-conditional-defense","source":"Forceful Will","defenseType":"will","condition":"vs mind-affecting","toggleable":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.379Z","detectedPredicates":["defense.will","turn.once-per-round"]}}}
