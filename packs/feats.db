{"_id":"83abd1c384b58c3c","name":"Intimidating Presence","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You may use Persuasion to intimidate as a swift action instead of a standard action.","prerequisite":"Trained in Persuasion","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":26,"tags":["feat","general","social"],"bonus_feat_for":["8c58016e587dd2c7","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Intimidating Presence"}]},"shortSummary":"You may use Persuasion to intimidate as a swift action instead of a standard action."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.383Z","detectedPredicates":[]}}}
{"_id":"84d8866a57381620","name":"Dual Weapon Mastery I","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you attack with two weapons, or with both ends of a double weapon as part of a Full Attack Action, you take a -5 penalty (Instead of a -10 penalty) on all attack rolls until the start of your next turn. You only gain this reduced penalty if you are wielding a weapon with which you are proficient.","prerequisite":"Dexterity 13, Base Attack Bonus +1","special":"","normalText":"If you use a Full Attack Action to make more than one attack on your turn, you take a -10 penalty on all attack rolls for the round.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["action_economy","dual_wield","feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy; Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Dual_Weapon_Mastery_I</p>\n<p>You are adept at fighting with two weapons and double weapons.</p>\n<p><strong>Prerequisites:</strong> Dexterity 13, Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When you attack with two weapons, or with both ends of a double weapon as part of a Full Attack Action, you take a -5 penalty (Instead of a -10 penalty) on all attack rolls until the start of your next turn. You only gain this reduced penalty if you are wielding a weapon with which you are proficient.</p>\n<h4>Normal</h4>\n<p>If you use a Full Attack Action to make more than one attack on your turn, you take a -10 penalty on all attack rolls for the round.</p>\n<h4>Additional Dual Weapon Mastery I Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p>Vehicle Weapons cannot be used in one hand, so this Feat has no effect on them.</p>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Quick Draw): You can draw or holster two weapons with a single Swift Action; you must have both hands free to draw both weapons, and each weapon must be able to be held in one hand.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":13},{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Dual Weapon Mastery I"}]},"shortSummary":"Take a -5 penalty on attacks when attacking with two weapons, or both ends of a double weapon.","prerequisitesText":"Dexterity 13, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy","Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Dual_Weapon_Mastery_I"},"effects":[{"_id":"5e1f7aa0-8f41-4f6e-9a16-1710b2de25e9","name":"Dual Weapon Mastery I","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Dual Weapon Mastery I","effectType":"passive_effect","flagType":"Dual Weapon Mastery I"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.383Z","detectedPredicates":[],"id":"swse.feat.dual_weapon_mastery_i","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Dual_Weapon_Mastery_I","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8566edcae3a2f18c","name":"Forceful Telekinesis","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You may spend a Force Point to move a target -1 step down the condition track when using Move Object.","prerequisite":"Trained in Use the Force, Move Object","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","force"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Forceful Telekinesis"}]},"shortSummary":"You may spend a Force Point to move a target -1 step down the condition track when using Move Object."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.383Z","detectedPredicates":[]}}}
{"_id":"859d6b9f49118499","name":"Armor Proficiency (heavy)","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you wear Heavy Armor, you take no Armor Check Penalty on attack rolls or Skill Checks. Additionally, you benefit from all of the armor's special Equipment bonuses (if any).","prerequisite":"Armor Proficiency (Light) Feat, Armor Proficiency (Medium) Feat","special":"","normalText":"A character who wears Heavy Armor with which they are not proficient takes a -10 Armor Check Penalty on attack rolls as well as Skill Checks made using the following Skills: Acrobatics, Climb, Endurance, Initiative, Jump, Stealth, and Swim. Additionally, the character gains none of the armor's special Equipment bonuses.","sourcebook":"Saga Edition Core Rulebook","page":85,"tags":["armor","build_enabler","defense","feat","general","mapped_phase_1","unlock_grant","choice_variant","armor_access"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Armor_Proficiency_(Heavy)</p>\n<p>You are proficient with Heavy Armor, and can wear it without impediment.</p>\n<p><strong>Prerequisites:</strong> Armor Proficiency (Light) Feat, Armor Proficiency (Medium) Feat</p>\n<h4>Effect</h4>\n<p>When you wear Heavy Armor, you take no Armor Check Penalty on attack rolls or Skill Checks. Additionally, you benefit from all of the armor&#x27;s special Equipment bonuses (if any).</p>\n<h4>Normal</h4>\n<p>A character who wears Heavy Armor with which they are not proficient takes a -10 Armor Check Penalty on attack rolls as well as Skill Checks made using the following Skills: Acrobatics, Climb, Endurance, Initiative, Jump, Stealth, and Swim. Additionally, the character gains none of the armor&#x27;s special Equipment bonuses.</p>\n</div>"},"executionModel":"UNLOCK","abilityMeta":{"grants":[{"category":"PROFICIENCY","proficiencyType":"armor","proficiencies":["light","medium","heavy"],"description":"Armor proficiency: light, medium, heavy"}]},"choiceMeta":{"resolution":"already_resolved_static_variant","required":false,"choiceKind":"armor_proficiency","value":"heavy","grants":["light","medium","heavy"]},"shortSummary":"No penalty on attacks and no Armor Check Penalty while wearing Light Armor, Medium Armor, or Heavy Armor.","prerequisitesText":"Armor Proficiency (Light) Feat, Armor Proficiency (Medium) Feat","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Armor_Proficiency_(Heavy)"},"effects":[{"_id":"2c536333-89aa-4859-b875-3c23070a7e9b","name":"Armor Proficiency (Heavy)","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.armorProficiency.heavy","mode":5,"value":"true"}],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Armor Proficiency (Heavy)","effectType":"armor_proficiency"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"phase1Mapped":true,"manualMappingResolved":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Armor_Proficiency_(Heavy)","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"867e3fbd13642016","name":"Heroic Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you may take an additional standard or move action on your turn.","prerequisite":"","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["action_economy","burst_turn","defense","extra_action","feat","general","resource_spend","survivability"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.on-current-turn","turn.once-per-round"],"enabled":true,"priority":500,"description":"Heroic Surge"}]},"shortSummary":"Once per encounter, you may take an additional standard or move action on your turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["turn.on-current-turn","turn.once-per-round"]}}}
{"_id":"8778b4271420f789","name":"Sport Hunter","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make a ranged attack with a slugthrower or sporting weapon with which you are proficient, you gain one of the following benefits, depending on the kind of weapon you use.\n\n- Slugthrower Pistol: When you use a Slugthrower Pistol at Point-Blank Range, you deal +1 die of damage with the weapon.\n- Slugthrower Rifle: When you use a Slugthrower Rifle, the damage dice increase from d8 to d12.\n- Sporting Blaster Pistol: When you use a Sporting Blaster Pistol, reroll any result of 1 on the damage dice until you get a result other than 1.\n- Sporting Blaster Rifle: When using a Sporting Blaster Rifle, you gain a +1 bonus to attack rolls when you Aim before firing.","prerequisite":"Weapon Proficiency (Pistols) or Weapon Proficiency (Rifles)","special":"","normalText":"","sourcebook":"Galaxy at War","page":28,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Sport_Hunter</p>\n<p>You are skilled in the use of slugthrowers and sporting weapons and gain certain benefits depending on which weapon you use.</p>\n<p><strong>Prerequisites:</strong> Weapon Proficiency (Pistols) or Weapon Proficiency (Rifles)</p>\n<h4>Effect</h4>\n<p>When you make a ranged attack with a slugthrower or sporting weapon with which you are proficient, you gain one of the following benefits, depending on the kind of weapon you use.</p>\n<ul><li><strong>Slugthrower Pistol:</strong> When you use a Slugthrower Pistol at Point-Blank Range, you deal +1 die of damage with the weapon.</li><li><strong>Slugthrower Rifle:</strong> When you use a Slugthrower Rifle, the damage dice increase from d8 to d12.</li><li><strong>Sporting Blaster Pistol:</strong> When you use a Sporting Blaster Pistol, reroll any result of 1 on the damage dice until you get a result other than 1.</li><li><strong>Sporting Blaster Rifle:</strong> When using a Sporting Blaster Rifle, you gain a +1 bonus to attack rolls when you Aim before firing.</li></ul>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Sport Hunter"}]},"shortSummary":"Gain benefits with certain slugthrowers and sporting weapons.","prerequisitesText":"Weapon Proficiency (Pistols) or Weapon Proficiency (Rifles)","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Sport_Hunter"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.sport_hunter","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Sport_Hunter","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"87969fb8b12ff507","name":"Flawless Pilot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Reroll Pilot checks, always keeping the better result.","prerequisite":"Duros","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["control","feat","grapple","racial","reroll","skill_pilot","skill_synergy","species","species_opportunity","vehicle","skill_reroll","execution_mapped_phase8"],"bonus_feat_for":["species-duros"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Reroll Pilot checks, always keeping the better result."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8","description":"Flawless Pilot: reroll Pilot checks and keep the better result.","skillRerolls":[{"id":"flawless-pilot","skillKeys":["pilot"],"outcome":"keepBetter","label":"Flawless Pilot","description":"Flawless Pilot: reroll Pilot checks and keep the better result."}]},"shortSummary":"Reroll Pilot checks, always keeping the better result."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.flawless_pilot"}}}
{"_id":"88cdedff38b610c0","name":"Two-Weapon Fighting","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You reduce the penalty for fighting with two weapons by 2.","prerequisite":"Dex 13","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["action_economy","dual_wield","feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Two-Weapon Fighting"}]},"shortSummary":"You reduce the penalty for fighting with two weapons by 2."},"effects":[{"_id":"4f1d95ad-b4cd-4d39-875e-730213a08d56","name":"Two-Weapon Fighting","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Two-Weapon Fighting","effectType":"passive_effect","flagType":"Two-Weapon Fighting"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[]}}}
{"_id":"89c5695c7435b733","name":"Halt","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you hit with an Attack of Opportunity, while wielding a weapon for which you possess the Weapon Focus Feat, against an enemy of up to one size larger than you, compare the same die roll against the target's Grapple check. If the die roll succeeds against the Grapple check, the target immediately halts all movement and falls Prone in its current square. The target can spend any remaining Actions normally.\n\nIf your attack exceeds the target's Damage Threshold, the target loses any remaining Actions and ends its turn immediately. Apply damage normally to the target regardless of the results of this Feat.","prerequisite":"Trip, Weapon Focus (Chosen Weapon), Base Attack Bonus +8","special":"If the target is using the Charge Action when moving past you, its Charge is ended if you successfully knock it Prone, and the target cannot Charge again on this turn.","normalText":"","sourcebook":"Unknown Regions","page":21,"tags":["control","damage_threshold","feat","general","knock_prone","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Halt</p>\n<p>When making an Attack of Opportunity, you can stop an enemy in its tracks.</p>\n<p><strong>Prerequisites:</strong> Trip, Weapon Focus (Chosen Weapon), Base Attack Bonus +8</p>\n<h4>Effect</h4>\n<p>If you hit with an Attack of Opportunity, while wielding a weapon for which you possess the Weapon Focus Feat, against an enemy of up to one size larger than you, compare the same die roll against the target&#x27;s Grapple check. If the die roll succeeds against the Grapple check, the target immediately halts all movement and falls Prone in its current square. The target can spend any remaining Actions normally.</p>\n<p>If your attack exceeds the target&#x27;s Damage Threshold, the target loses any remaining Actions and ends its turn immediately. Apply damage normally to the target regardless of the results of this Feat.</p>\n<h4>Special</h4>\n<p>If the target is using the Charge Action when moving past you, its Charge is ended if you successfully knock it Prone, and the target cannot Charge again on this turn.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["target.is-prone"],"enabled":true,"priority":500,"description":"Halt"}]},"shortSummary":"Knock an enemy Prone after a successful Attack of Opportunity, immediately end the target's remaining Actions when also exceeding its Damage Threshold.","prerequisitesText":"Trip, Weapon Focus (Chosen Weapon), Base Attack Bonus +8","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Halt"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["target.is-prone"],"id":"swse.feat.halt","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Halt","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8a5cb28f625d6f02","name":"Great Cleave","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As the Cleave Feat, except that you have no limit to the number of times you can use it per round.","prerequisite":"Strength 13, Cleave, Power Attack, Base Attack Bonus +4.","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Great_Cleave</p>\n<p>You can wield a melee weapon with such power that you can strike multiple times when you drop your opponents.</p>\n<p><strong>Prerequisites:</strong> Strength 13, Cleave, Power Attack, Base Attack Bonus +4.</p>\n<h4>Effect</h4>\n<p>As the Cleave Feat, except that you have no limit to the number of times you can use it per round.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":4}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Great Cleave"}]},"shortSummary":"No limit to Cleave attacks each round.","prerequisitesText":"Strength 13, Cleave, Power Attack, Base Attack Bonus +4.","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Great_Cleave"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.great_cleave","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Great_Cleave","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8a78270d15aa4738","name":"Force Readiness","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can spend Force Points as a Free Action, even if it is not your turn. All other restrictions to Force Point use still apply.","prerequisite":"None","special":"","normalText":"Unless otherwise specified, you can spend Force Points only on your turn, preventing you from enhancing attacks and Skill Checks made as Reactions.","sourcebook":"Knights of the Old Republic Campaign Guide","page":26,"tags":["feat","force_point_spend","general","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Force_Readiness</p>\n<p>The Force is always with you, and you have a knack for succeeding even when the odds are against you.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You can spend Force Points as a Free Action, even if it is not your turn. All other restrictions to Force Point use still apply.</p>\n<h4>Normal</h4>\n<p>Unless otherwise specified, you can spend Force Points only on your turn, preventing you from enhancing attacks and Skill Checks made as Reactions.</p>\n</div>"},"executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Force Readiness"}],"resourceRules":{"forcePoints":[{"type":"SPEND_OUT_OF_TURN","description":"You may spend Force Points even if it is not your turn."}]}},"shortSummary":"Spend Force Points even if it is not your turn.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Force_Readiness"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.force_readiness","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Force_Readiness","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8a86aa95c54f6dad","name":"Never Surrender","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"The first time you would be reduced to 0 Hit Points in an encounter, you can make an Endurance check as a Reaction, with a DC equal to the number of points of damage being dealt to you. If your check succeeds, you are instead reduced to 1 Hit Point.","prerequisite":"Trained in Endurance","special":"","normalText":"","sourcebook":"Galaxy at War","page":24,"tags":["durability","feat","general","hit_points","skill_endurance","skill_synergy"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Never_Surrender</p>\n<p>You can fight your way back from the blackness of death and unconsciousness, staying alive in combat.</p>\n<p><strong>Prerequisites:</strong> Trained in Endurance</p>\n<h4>Effect</h4>\n<p>The first time you would be reduced to 0 Hit Points in an encounter, you can make an Endurance check as a Reaction, with a DC equal to the number of points of damage being dealt to you. If your check succeeds, you are instead reduced to 1 Hit Point.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Never Surrender"}]},"shortSummary":"Make an Endurance check to prevent falling to 0 Hit Points.","prerequisitesText":"Trained in Endurance","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Never_Surrender"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.never_surrender","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Never_Surrender","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8b1a9adee4e2e78e","name":"Steadying Position","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you are Prone and Aim before making a ranged attack, your target does not benefit from its Dexterity bonus to its Reflex Defense.","prerequisite":"Careful Shot","special":"","normalText":"","sourcebook":"Galaxy at War","page":28,"tags":["ability_dexterity","control","feat","general","knock_prone"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Steadying_Position</p>\n<p>You know how to fire from the optimal position, using the ground to steady your aim.</p>\n<p><strong>Prerequisites:</strong> Careful Shot</p>\n<h4>Effect</h4>\n<p>When you are Prone and Aim before making a ranged attack, your target does not benefit from its Dexterity bonus to its Reflex Defense.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex","target.is-prone"],"enabled":true,"priority":500,"description":"Steadying Position"}]},"shortSummary":"Deny target's Dexterity bonus to Reflex Defense when you are Prone and Aiming.","prerequisitesText":"Careful Shot","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Steadying_Position"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["defense.reflex","target.is-prone"],"id":"swse.feat.steadying_position","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Steadying_Position","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8b2f7862b3c76e61","name":"Frightening Cleave","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Immediately after you use the Cleave Feat, each enemy within 6 squares of you and within your line of sight takes a -1 penalty to its Reflex Defense, attack rolls, and Skill Checks against you until the end of the encounter. This penalty stacks with itself to a maximum of -5. This is a Mind-Affecting effect.","prerequisite":"Strength 13, Cleave, Power Attack, Base Attack Bonus +4","special":"","normalText":"","sourcebook":"Unknown Regions","page":20,"tags":["control","feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Frightening_Cleave</p>\n<p>Enemies that see you successfully use the Cleave Feat become fearful.</p>\n<p><strong>Prerequisites:</strong> Strength 13, Cleave, Power Attack, Base Attack Bonus +4</p>\n<h4>Effect</h4>\n<p>Immediately after you use the Cleave Feat, each enemy within 6 squares of you and within your line of sight takes a -1 penalty to its Reflex Defense, attack rolls, and Skill Checks against you until the end of the encounter. This penalty stacks with itself to a maximum of -5. This is a Mind-Affecting effect.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Frightening Cleave"}]},"shortSummary":"When you use the Cleave feat, each enemy within 6 squares and line of sight takes a penalty to Reflex Defense, Skill Checks, and attack rolls against you.","prerequisitesText":"Strength 13, Cleave, Power Attack, Base Attack Bonus +4","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Frightening_Cleave"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.frightening_cleave","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Frightening_Cleave","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8baf83743668f63a","name":"Desperate Gambit","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per turn, when you miss on an attack roll, you reroll the attack, but you take a -2 penalty to Reflex Defense until the end of your next turn. If your first attack missed because you rolled a Natural 1, you can still use this Feat, but you take a -5 penalty to Reflex Defense instead. You must accept the result of the second roll, even if it's worse than the first.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":24,"tags":["feat","general","reroll"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Desperate_Gambit</p>\n<p>You can draw upon your inner reserves to make a shot or strike count when it matters most.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Once per turn, when you miss on an attack roll, you reroll the attack, but you take a -2 penalty to Reflex Defense until the end of your next turn. If your first attack missed because you rolled a Natural 1, you can still use this Feat, but you take a -5 penalty to Reflex Defense instead. You must accept the result of the second roll, even if it&#x27;s worse than the first.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"attack_reroll_with_penalty_implemented","description":"Desperate Gambit: reroll missed attack; -2 penalty to Reflex Defense (or -5 if natural 1). Must accept reroll result.","attackRerolls":[{"type":"ATTACK_REROLL","trigger":"missedAttack","outcome":"keepSecond","cost":"reflexDefensePenalty","description":"Desperate Gambit: reroll a missed attack but take a penalty to Reflex Defense."}]},"shortSummary":"Reroll missed attack by taking a penalty to Reflex Defense.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Desperate_Gambit"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.desperate_gambit","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Desperate_Gambit","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8cf12d528b0d0478","name":"Opportunistic Trickery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever an opponent provokes an Attack of Opportunity from you, once per turn you can sacrifice that attack to reduce the target's Reflex Defense by 2 for the following round.","prerequisite":"Combat Reflexes, Sneak Attack","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":22,"tags":["feat","general","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Opportunistic_Trickery</p>\n<p>When your opponent lets down its guard, you know how to set it off balance for several moments.</p>\n<p><strong>Prerequisites:</strong> Combat Reflexes, Sneak Attack</p>\n<h4>Effect</h4>\n<p>Whenever an opponent provokes an Attack of Opportunity from you, once per turn you can sacrifice that attack to reduce the target&#x27;s Reflex Defense by 2 for the following round.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Opportunistic Trickery"}]},"shortSummary":"Sacrifice Attack of Opportunity to reduce target's Reflex Defense by 2.","prerequisitesText":"Combat Reflexes, Sneak Attack","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Opportunistic_Trickery"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.opportunistic_trickery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Opportunistic_Trickery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8d164553709dd068","name":"Pall of the Dark Side","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can add one-half your Dark Side Score (Minimum 1) to any Use the Force checks made to resist attempts to detect you with the Sense Force application of the Use the Force skill.","prerequisite":"Dark Side Score 1+","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":26,"tags":["dark_side","feat","force_execution","general","skill_synergy","skill_use_the_force","use_the_force","conditional_skill_bonus","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Pall_of_the_Dark_Side</p>\n<p>You are adept at hiding yourself from Force-users, thanks to the haze of The Dark Side.</p>\n<p><strong>Prerequisites:</strong> Dark Side Score 1+</p>\n<h4>Effect</h4>\n<p>You can add one-half your Dark Side Score (Minimum 1) to any Use the Force checks made to resist attempts to detect you with the Sense Force application of the Use the Force skill.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"conditional_skill_bonus_phase8","description":"Pall of the Dark Side: add half Dark Side Score to Use the Force checks to resist detection.","skillCheckBonuses":[{"id":"pall-dark-side-resist-detection","skillKeys":["useTheForce"],"valueFormula":"halfDarkSideScore","type":"untyped","requiresContextFlags":["resistDetection"],"description":"Pall of the Dark Side: +half Dark Side Score to resist detection."}]},"shortSummary":"Add half your Dark Side Score to Use the Force checks to resist detection.","prerequisitesText":"Dark Side Score 1+","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Pall_of_the_Dark_Side"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.pall_of_the_dark_side","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Pall_of_the_Dark_Side","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8d1747eda25693b0","name":"Cunning Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on attack rolls against a Flat-Footed enemy or one who is denied its Dexterity bonus to its Reflex Defense.","prerequisite":"None","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Cunning_Attack</p>\n<p>You are skilled at attacking unprepared opponents.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You gain a +2 bonus on attack rolls against a Flat-Footed enemy or one who is denied its Dexterity bonus to its Reflex Defense.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Cunning Attack"}]},"shortSummary":"Gain +2 bonus on attack rolls against Flat-Footed enemies.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Cunning_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.cunning_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Cunning_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"8ff15069dbf6270d","name":"Silver Tongue","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can Intimidate or Change Attitude as a Standard Action.","prerequisite":"Trained in Persuasion","special":"","normalText":"To Intimidate or Change Attitude requires a Full-Round Action.","sourcebook":"Galaxy of Intrigue","page":24,"tags":["feat","general","social","standard_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Silver_Tongue</p>\n<p>You are adept at quickly changing a creature&#x27;s Attitude toward you.</p>\n<p><strong>Prerequisites:</strong> Trained in Persuasion</p>\n<h4>Effect</h4>\n<p>You can Intimidate or Change Attitude as a Standard Action.</p>\n<h4>Normal</h4>\n<p>To Intimidate or Change Attitude requires a Full-Round Action.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Silver Tongue"}]},"shortSummary":"Intimidate a creature or change its Attitude as a Standard Action.","prerequisitesText":"Trained in Persuasion","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Silver_Tongue"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.silver_tongue","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Silver_Tongue","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"90a258aae2583994","name":"Survivor of Ryloth","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Make Survival checks to resist Extreme Heat and Extreme Cold.","prerequisite":"Twi'lek","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","skill_survival","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-twi-lek"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Make Survival checks to resist Extreme Heat and Extreme Cold."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":2,"type":"untyped","predicates":["defense.fortitude"],"enabled":true,"priority":500,"description":"Survivor of Ryloth"}]},"shortSummary":"Make Survival checks to resist Extreme Heat and Extreme Cold."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["defense.fortitude"],"id":"swse.feat.survivor_of_ryloth"}}}
{"_id":"9138c70e1ae07fe1","name":"Improved Knock Prone","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +5 bonus on attack rolls made to knock an opponent prone.","prerequisite":"Int 13, Knock Prone","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["control","feat","general","knock_prone","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":5,"type":"untyped","predicates":["target.is-prone"],"enabled":true,"priority":500,"description":"Improved Knock Prone"}]},"shortSummary":"You gain a +5 bonus on attack rolls made to knock an opponent prone."},"effects":[{"_id":"b1f63e24-9bc9-4ade-a65c-39ddd6f85205","name":"Improved Knock Prone","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Improved Knock Prone","effectType":"combat_bonus","flagType":"Improved Knock Prone"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["target.is-prone"]}}}
{"_id":"9244159a233a101a","name":"Dreadful Rage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"While Raging, your Rage bonus on melee attack rolls and melee damage rolls increases to +5.","prerequisite":"Rage Species Trait, Base Attack Bonus +1","special":"","normalText":"A character with the Rage Species Trait gains a +2 bonus on melee attack rolls and melee damage rolls while Raging.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["execution_mapped_phase9","feat","general","offense_melee","rage","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Dreadful_Rage</p>\n<p>You deal horrendous damage while raging.</p>\n<p><strong>Prerequisites:</strong> Rage Species Trait, Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>While Raging, your Rage bonus on melee attack rolls and melee damage rolls increases to +5.</p>\n<h4>Normal</h4>\n<p>A character with the Rage Species Trait gains a +2 bonus on melee attack rolls and melee damage rolls while Raging.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rage_rule_phase9","description":"Dreadful Rage: Rage melee attack and damage bonuses increase to +5.","rules":[{"type":"RAGE_ATTACK_DAMAGE_BONUS_OVERRIDE","attackBonus":5,"damageBonus":5,"description":"Rage bonus to melee attacks and damage increases to +5."}]},"shortSummary":"Rage bonus to attacks and damage increases to +5.","prerequisitesText":"Rage Species Trait, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Dreadful_Rage"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.dreadful_rage","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Dreadful_Rage","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"92f927c92ded9fcf","name":"Martial Arts I","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Damage dealt by your Unarmed Attacks increases by one die step. In addition, you gain a +1 dodge bonus to your Reflex Defense. Additionally, you do not provoke Attacks of Opportunity with Unarmed Attacks.","prerequisite":"None","special":"A situation that makes you lose your Dexterity bonus to Reflex Defense (if any) also makes you lose any dodge bonuses. Also, dodge bonuses stack with each other, unlike most other types of bonuses.","normalText":"The amount of damage you deal with a successful Unarmed Attack is based on your size: Small, 1d3; Medium, 1d4; Large, 1d6. You provoke Attacks of Opportunity when making Unarmed Attacks.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general","martial_style","offense_melee","unarmed","unarmed_damage_step","unarmed_no_provoke"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Martial_Arts_I</p>\n<p>You are adept at fighting Unarmed.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Damage dealt by your Unarmed Attacks increases by one die step. In addition, you gain a +1 dodge bonus to your Reflex Defense. Additionally, you do not provoke Attacks of Opportunity with Unarmed Attacks.</p>\n<h4>Normal</h4>\n<p>The amount of damage you deal with a successful Unarmed Attack is based on your size: Small, 1d3; Medium, 1d4; Large, 1d6. You provoke Attacks of Opportunity when making Unarmed Attacks.</p>\n<h4>Special</h4>\n<p>A situation that makes you lose your Dexterity bonus to Reflex Defense (if any) also makes you lose any dodge bonuses. Also, dodge bonuses stack with each other, unlike most other types of bonuses.</p>\n</div>"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.reflex","value":1,"type":"dodge","enabled":true,"priority":500,"description":"Martial Arts I: +1 dodge bonus to Reflex Defense"}],"rules":[{"type":"UNARMED_DAMAGE_STEP","params":{"steps":1},"description":"Martial Arts I: increase unarmed attack damage by one die step"},{"type":"UNARMED_DOES_NOT_PROVOKE_AOO","description":"Martial Arts I: unarmed attacks do not provoke attacks of opportunity"}]},"shortSummary":"Increases damage from Unarmed attacks by one die step; gain +1 bonus to Reflex Defense.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Martial_Arts_I"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.martial_arts_i","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Martial_Arts_I","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"931fae85d3d53c07","name":"Rancor Crush","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you successfully Pin an enemy with the Pin Feat and use the Crush Feat at the same time, the enemy moves -1 step down the Condition Track in addition to taking damage.","prerequisite":"Strength 15, Crush, Pin, Base Attack Bonus +1","special":"","normalText":"The Crush Feat deals damage to a Grappled enemy but does not move the enemy down the Condition Track.","sourcebook":"Legacy Era Campaign Guide","page":21,"tags":["condition_track","feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Rancor_Crush</p>\n<p>Your crushing hold on an enemy can knock it unconcious.</p>\n<p><strong>Prerequisites:</strong> Strength 15, Crush, Pin, Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When you successfully Pin an enemy with the Pin Feat and use the Crush Feat at the same time, the enemy moves -1 step down the Condition Track in addition to taking damage.</p>\n<h4>Normal</h4>\n<p>The Crush Feat deals damage to a Grappled enemy but does not move the enemy down the Condition Track.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":15},{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Rancor Crush"}]},"shortSummary":"Move an enemy -1 step down the Condition Track when using the Crush feat.","prerequisitesText":"Strength 15, Crush, Pin, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Rancor_Crush"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.rancor_crush","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Rancor_Crush","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"935212056c7968c8","name":"Power Blast","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Swift Action, before making an attack roll, you can choose to subtract a number from all ranged attack rolls and add the same number to all ranged damage rolls. This number cannot exceed your Base Attack Bonus. The penalty on attacks and bonus on damage applies until the start of your next turn but you gain no bonus to damage with Area Attacks or when attacking objects or Vehicles with this Feat.","prerequisite":"None","special":"If you do not have a Strength score of 13 or higher, you take a -5 penalty to attacks when using this Feat with non- Vehicle Weapons.","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":28,"tags":["feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Power_Blast</p>\n<p>You can make exceptionally powerful ranged attacks.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>As a Swift Action, before making an attack roll, you can choose to subtract a number from all ranged attack rolls and add the same number to all ranged damage rolls. This number cannot exceed your Base Attack Bonus. The penalty on attacks and bonus on damage applies until the start of your next turn but you gain no bonus to damage with Area Attacks or when attacking objects or Vehicles with this Feat.</p>\n<h4>Special</h4>\n<p>If you do not have a Strength score of 13 or higher, you take a -5 penalty to attacks when using this Feat with non- Vehicle Weapons.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":true,"priority":500,"description":"Power Blast"}]},"shortSummary":"Trade attack bonus for damage on ranged attacks (up to your Base Attack Bonus).","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Power_Blast"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.power_blast","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Power_Blast","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"94023012303ad257","name":"Disabler","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making a ranged attack with an Ion Weapon with which you are proficient, you gain one of the following benefits, depending on the kind of weapon you use.\n\n- Ion Grenade: When you use an Ion Grenade, the Grenade's Burst radius is 3 squares instead of 2 squares.\n- Ion Pistol: When you use an Ion Pistol, the damage dice increase from d6 to d8.\n- Ion Rifle: You treat the Ion Rifle as an Accurate Weapon.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":21,"tags":["control","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Disabler</p>\n<p>You are skilled in the use of Ion Weapons and gain certain benefits depending on which weapon you use.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When making a ranged attack with an Ion Weapon with which you are proficient, you gain one of the following benefits, depending on the kind of weapon you use.</p>\n<ul><li><strong>Ion Grenade:</strong> When you use an Ion Grenade, the Grenade&#x27;s Burst radius is 3 squares instead of 2 squares.</li><li><strong>Ion Pistol:</strong> When you use an Ion Pistol, the damage dice increase from d6 to d8.</li><li><strong>Ion Rifle:</strong> You treat the Ion Rifle as an Accurate Weapon.</li></ul>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Disabler"}]},"shortSummary":"Gain benefits when using certain Ion weapons.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Disabler"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.disabler","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Disabler","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"94b8751efb03536a","name":"Rapid Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using a ranged weapon with which you are proficient, you may fire two shots as a single attack against a single target. You take a -2 penalty on your attack roll, but you deal +1 die of damage with a successful attack.","prerequisite":"Base Attack Bonus +1","special":"Using this Feat fires two shots and can only be done if the weapon has sufficient ammunition remaining. The effects of this Feat do not stack with the extra damage provided by the Burst Fire Feat or the Deadeye Feat. If you do not have a Strength score of 13 or higher, increase the penalty to attacks to -5 when using this Feat with non- Vehicle Weapons.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["damage_scaling","feat","feat_chain","general","offense","offense_ranged","standard_action"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Rapid_Shot</p>\n<p>You can make two quick shots with a ranged weapon as a single attack.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When using a ranged weapon with which you are proficient, you may fire two shots as a single attack against a single target. You take a -2 penalty on your attack roll, but you deal +1 die of damage with a successful attack.</p>\n<h4>Special</h4>\n<p>Using this Feat fires two shots and can only be done if the weapon has sufficient ammunition remaining. The effects of this Feat do not stack with the extra damage provided by the Burst Fire Feat or the Deadeye Feat. If you do not have a Strength score of 13 or higher, increase the penalty to attacks to -5 when using this Feat with non- Vehicle Weapons.</p>\n<h4>Additional Rapid Shot Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Special:</strong> This Feat works normally with Vehicle Weapons. However, if you are using a Missile or a Torpedo and you miss with your attack roll, the projectile does not gain the benefit of this Feat for the second attack roll.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","abilityMeta":{"status":"attack_option_phase7","description":"Rapid Shot: attack option exposed through CombatOptionResolver; not applied automatically.","rules":[{"type":"ATTACK_OPTION","option":"rapidShot","label":"Rapid Shot","control":"toggle","requiresAttackType":"ranged","attackModifier":-2,"damageDiceStepBonus":1,"summary":"Take -2 on a ranged attack to deal +1 die of damage."}]},"subType":"STATE","shortSummary":"Take a -2 penalty on a ranged attack roll to deal +1 die of damage.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Rapid_Shot"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.rapid_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Rapid_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"94fc90a53d747f84","name":"Sniper Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When wielding only ranged weapons with which you are proficient, you gain a +2 bonus on all your ranged attacks until the beginning of your next turn, but you take a -5 penalty to Reflex Defense.","prerequisite":"None","special":"This Feat cannot be used with Vehicle Weapons or Heavy Weapons.","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":30,"tags":["feat","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Sniper_Shot</p>\n<p>You make a precision attack at the expense of your own defense.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When wielding only ranged weapons with which you are proficient, you gain a +2 bonus on all your ranged attacks until the beginning of your next turn, but you take a -5 penalty to Reflex Defense.</p>\n<h4>Special</h4>\n<p>This Feat cannot be used with Vehicle Weapons or Heavy Weapons.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Sniper Shot"}]},"shortSummary":"Increase accuracy at a -5 Reflex Defense penalty.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Sniper_Shot"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.sniper_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Sniper_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"95020f2ce5ad0e88","name":"Quick Skill","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you can Take 10 when rushed on a single Skill Check for a Skill you are Trained in, unless the Skill description explicitly forbids it. Alternatively, you can Take 20 when using a Skill you are Trained in at half the normal time required.","prerequisite":"None","special":"","normalText":"Taking 20 normally requires 20 times the amount of time needed by a regular Skill Check.","sourcebook":"Knights of the Old Republic Campaign Guide","page":29,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Quick_Skill</p>\n<p>Your cautious nature provides a bonus to accomplishing extremely dangerous tasks. You are steady and confident.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Once per encounter, you can Take 10 when rushed on a single Skill Check for a Skill you are Trained in, unless the Skill description explicitly forbids it. Alternatively, you can Take 20 when using a Skill you are Trained in at half the normal time required.</p>\n<h4>Normal</h4>\n<p>Taking 20 normally requires 20 times the amount of time needed by a regular Skill Check.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Quick Skill"}]},"shortSummary":"Take 10 on Skill Checks when rushed, Take 20 in half of the normal time.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Quick_Skill"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.quick_skill","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Quick_Skill","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9567c9e2fe8416e6","name":"Disarming Charm","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Skill Checks on targets whose Attitude you have improved.","prerequisite":"Sullustan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-sullustan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to Skill Checks on targets whose Attitude you have improved."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Disarming Charm"}]},"shortSummary":"Gain a bonus to Skill Checks on targets whose Attitude you have improved."},"effects":[{"_id":"3ce60f8f-157c-4b02-b329-cd961752b685","name":"Disarming Charm","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Disarming Charm","effectType":"skill_bonus","flagType":"Disarming Charm"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.disarming_charm"}}}
{"_id":"964f0781b3e3fc37","name":"Coordinated Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You are automatically successful when using the Aid Another action to aid an ally's attack, or suppress an enemy as long as the target is adjacent to you or within Point-Blank Range.","prerequisite":"Base Attack Bonus +2","special":"","normalText":"You must make an attack roll against a Reflex Defense of 10 to gain the benefits of the Aid Another action.","sourcebook":"Saga Edition Core Rulebook","page":85,"tags":["feat","general","offense"],"bonus_feat_for":["f62ca2e639cab614","8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Coordinated_Attack</p>\n<p>You are skilled at coordinating your attacks with your allies.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +2</p>\n<h4>Effect</h4>\n<p>You are automatically successful when using the Aid Another action to aid an ally&#x27;s attack, or suppress an enemy as long as the target is adjacent to you or within Point-Blank Range.</p>\n<h4>Normal</h4>\n<p>You must make an attack roll against a Reflex Defense of 10 to gain the benefits of the Aid Another action.</p>\n<h4>Additional Coordinated Attack Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p>You may use this Feat to aid an ally&#x27;s Vehicle attack. You can&#x27;t use the Aid Another action to suppress a Vehicle, but you can suppress an individual Gunner (such as the lead Gunner for a single Weapon Battery). You may use this Feat even if you are using the Aid Another action as a Sensor Operator using a Use Computer check or a Commander using a Knowledge (Tactics) check.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":2}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Coordinated Attack"}]},"shortSummary":"Automatic success with Aid Another action at Point-Blank Range.","prerequisitesText":"Base Attack Bonus +2","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Coordinated_Attack"},"effects":[{"_id":"64b1c39a-2f16-43e4-aa8b-0ee213caf7a2","name":"Coordinated Attack","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Coordinated Attack","effectType":"combat_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.coordinated_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Coordinated_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"96666de28ba99b64","name":"Improved Damage Threshold","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You increase your Damage Threshold by 5 points.","prerequisite":"None","special":"You may take this Feat more than once. It's effects stack. Each time you take this Feat, increase your Damage Threshold by 5 points.","normalText":"A creature without this Feat has a Damage Threshold equal to its Fortitude Defense plus its size modifier (+5 for Large, +10 for Huge, +20 for Gargantuan, +50 for Colossal).","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["damage_threshold","defense","feat","general","survivability"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Improved_Damage_Threshold</p>\n<p>You are harder to take down in a fight.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You increase your Damage Threshold by 5 points.</p>\n<h4>Normal</h4>\n<p>A creature without this Feat has a Damage Threshold equal to its Fortitude Defense plus its size modifier (+5 for Large, +10 for Huge, +20 for Gargantuan, +50 for Colossal).</p>\n<h4>Special</h4>\n<p>You may take this Feat more than once. It&#x27;s effects stack. Each time you take this Feat, increase your Damage Threshold by 5 points.</p>\n</div>"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.damageThreshold","value":5,"type":"untyped","enabled":true,"priority":500,"description":"Improved Damage Threshold: +5 damage threshold"}]},"shortSummary":"Damage Threshold increases by 5 points.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Improved_Damage_Threshold"},"effects":[{"name":"Improved Damage Threshold","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.damageThreshold","mode":2,"value":"5","priority":20}],"transfer":true,"disabled":true,"flags":{"swse":{"migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.improved_damage_threshold","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improved_Damage_Threshold","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9768963c7a36237d","name":"Fast Talk","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You may make a Persuasion check to feint in combat as a swift action instead of a standard action.","prerequisite":"Trained in Persuasion","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general","social"],"bonus_feat_for":["21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Fast Talk"}]},"shortSummary":"You may make a Persuasion check to feint in combat as a swift action instead of a standard action."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[]}}}
{"_id":"97dbebe63aa6af79","name":"Martial Arts III","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Damage dealt by your Unarmed attacks increases by one die step. In addition, you gain a +1 dodge bonus to your Reflex Defense (Which stacks with the dodge bonuses granted by the Martial Arts I and Martial Arts II Feats).","prerequisite":"Martial Arts I, Martial Arts II, Base Attack Bonus +6","special":"A situation that makes you lose your Dexterity bonus to Reflex Defense (If any) also makes you lose any dodge bonuses. Also, dodge bonuses stack with each other, unlike most other types of bonuses.","normalText":"The amount of damage you deal with a successful Unarmed attack is based on your size: Small, 1d3; Medium, 1d4; Large, 1d6.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general","martial_style","offense_melee","unarmed","unarmed_damage_step","unarmed_damage_scaling"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Martial_Arts_III</p>\n<p>Your Martial Arts prowess is second to none.</p>\n<p><strong>Prerequisites:</strong> Martial Arts I, Martial Arts II, Base Attack Bonus +6</p>\n<h4>Effect</h4>\n<p>Damage dealt by your Unarmed attacks increases by one die step. In addition, you gain a +1 dodge bonus to your Reflex Defense (Which stacks with the dodge bonuses granted by the Martial Arts I and Martial Arts II Feats).</p>\n<h4>Normal</h4>\n<p>The amount of damage you deal with a successful Unarmed attack is based on your size: Small, 1d3; Medium, 1d4; Large, 1d6.</p>\n<h4>Special</h4>\n<p>A situation that makes you lose your Dexterity bonus to Reflex Defense (If any) also makes you lose any dodge bonuses. Also, dodge bonuses stack with each other, unlike most other types of bonuses.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":6}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.reflex","value":1,"type":"dodge","enabled":true,"priority":500,"description":"Martial Arts III: +1 dodge bonus to Reflex Defense"}],"rules":[{"type":"UNARMED_DAMAGE_STEP","params":{"steps":1},"description":"Martial Arts III: increase unarmed attack damage by one die step"}]},"shortSummary":"Increases damage from Unarmed attacks by one die step; gain +1 bonus to Reflex Defense.","prerequisitesText":"Martial Arts I, Martial Arts II, Base Attack Bonus +6","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Martial_Arts_III"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.martial_arts_iii","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Martial_Arts_III","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"982b00394a73719e","name":"Bantha Herder","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you damage a Large or smaller creature with a ranged attack with a weapon you are proficient with, compare the result of your attack roll to the target's Will Defense. If your result equals or exceeds the target's Will Defense, you can move the target 1 square in any direction as a Free Action.\n\nIf your ranged attack deals damage to multiple eligible creatures, you can use this benefit against all of them. You can't move a target that's being Grabbed or Grappled, and you can't move a target into a solid object or into another creature's Fighting Space.","prerequisite":"Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Galaxy at War","page":20,"tags":["feat","general","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Bantha_Herder</p>\n<p>You know how to frame your targets with your ranged attacks, moving the targets where you want them to go.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When you damage a Large or smaller creature with a ranged attack with a weapon you are proficient with, compare the result of your attack roll to the target&#x27;s Will Defense. If your result equals or exceeds the target&#x27;s Will Defense, you can move the target 1 square in any direction as a Free Action.</p>\n<p>If your ranged attack deals damage to multiple eligible creatures, you can use this benefit against all of them. You can&#x27;t move a target that&#x27;s being Grabbed or Grappled, and you can&#x27;t move a target into a solid object or into another creature&#x27;s Fighting Space.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Bantha Herder"}]},"shortSummary":"Move a target damaged by your attack.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Bantha_Herder"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.bantha_herder","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Bantha_Herder","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"987bdca14576cf2f","name":"Mind of Reason","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Use Wisdom instead of Intelligence for Intelligence-based Skill Checks.","prerequisite":"Cerean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ability_intelligence","ability_wisdom","feat","racial","species","species_opportunity"],"bonus_feat_for":["species-cerean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Use Wisdom instead of Intelligence for Intelligence-based Skill Checks."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Mind of Reason"}]},"shortSummary":"Use Wisdom instead of Intelligence for Intelligence-based Skill Checks."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.mind_of_reason"}}}
{"_id":"98d9c2c211a7a458","name":"Unswerving Resolve","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you are targeted by a Fear effect or Mind-Affecting effect that fails to affect you, you gain a temporary Force Point. If this Force Point is not used before the end of your next turn, it goes away. If you negate the contingent effect in any way, you do not gain the benefit of this Feat.","prerequisite":"Base Attack Bonus +2","special":"","normalText":"","sourcebook":"Jedi Academy Training Manual","page":31,"tags":["defense","feat","force_point_spend","general","resource_spend","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Jedi Academy Training Manual</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Unswerving_Resolve</p>\n<p>You stand your ground in the face of terrifying or domineering opposition.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +2</p>\n<h4>Effect</h4>\n<p>Whenever you are targeted by a Fear effect or Mind-Affecting effect that fails to affect you, you gain a temporary Force Point. If this Force Point is not used before the end of your next turn, it goes away. If you negate the contingent effect in any way, you do not gain the benefit of this Feat.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":2}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Unswerving Resolve"}]},"shortSummary":"Whenever you resist a Fear or Mind-Affecting effect, you gain a temporary Force Point.","prerequisitesText":"Base Attack Bonus +2","referenceBooks":["Star Wars Saga Edition Jedi Academy Training Manual"],"sourceUrl":"https://swse.fandom.com/wiki/Unswerving_Resolve"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.384Z","detectedPredicates":[],"id":"swse.feat.unswerving_resolve","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Unswerving_Resolve","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"99b2114bb2fbc209","name":"Mighty Throw","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can add your Strength modifier (in addition to your Dexterity modifier) to your ranged attack bonus when using Thrown Weapons (including Grenades and grenadelike weapons). Also, you can increase the length of each Range category by a number of squares equal to your Strength modifier.","prerequisite":"Strength 13","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":35,"tags":["ability_strength","feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Mighty_Throw</p>\n<p>You are highly accurate with Thrown Weapons.</p>\n<p><strong>Prerequisites:</strong> Strength 13</p>\n<h4>Effect</h4>\n<p>You can add your Strength modifier (in addition to your Dexterity modifier) to your ranged attack bonus when using Thrown Weapons (including Grenades and grenadelike weapons). Also, you can increase the length of each Range category by a number of squares equal to your Strength modifier.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":true,"priority":500,"description":"Mighty Throw"}]},"shortSummary":"Add Strength bonus to ranged attack rolls.","prerequisitesText":"Strength 13","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Mighty_Throw"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.mighty_throw","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mighty_Throw","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"99e4f98cbcbdd9e1","name":"Erratic Target","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can reduce your Speed by up to 2 squares to increase your Dodge bonus by 1 for each square of speed you give up, until the start of your next turn. You must move at least 2 squares to gain this benefit.","prerequisite":"Droid, Hovering or Flying Locomotion, Dexterity 13, Dodge","special":"To use this Feat you must be equipped with and using Hovering or Flying Locomotion.","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":21,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Erratic_Target</p>\n<p>You bob, swerve, dip, and dive to avoid incoming shots and other attacks.</p>\n<p><strong>Prerequisites:</strong> Droid, Hovering or Flying Locomotion, Dexterity 13, Dodge</p>\n<h4>Effect</h4>\n<p>You can reduce your Speed by up to 2 squares to increase your Dodge bonus by 1 for each square of speed you give up, until the start of your next turn. You must move at least 2 squares to gain this benefit.</p>\n<h4>Special</h4>\n<p>To use this Feat you must be equipped with and using Hovering or Flying Locomotion.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Erratic Target"}]},"shortSummary":"Reduce Speed by up to 2 squares to increase dodge bonus to Reflex Defense.","prerequisitesText":"Droid, Hovering or Flying Locomotion, Dexterity 13, Dodge","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Erratic_Target"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.erratic_target","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Erratic_Target","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9a89576b3cc1347e","name":"Great Fortitude","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus to your Fortitude Defense.","prerequisite":"","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["defense","feat","general","survivability"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.fortitude","type":"untyped","value":2,"enabled":true,"priority":500,"description":"Migrated from AE system.defenses.fortitude.bonus"}]},"shortSummary":"You gain a +2 bonus to your Fortitude Defense."},"effects":[{"name":"Great Fortitude","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.fortitude.bonus","mode":2,"value":"2","priority":20}],"disabled":true,"duration":{},"transfer":true,"flags":{"swse":{"type":"defense-bonus","defense":"fortitude","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{}}
{"_id":"9ad13542c8370aef","name":"Combat Trickery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can spend two successive Swift Actions on the same turn to make a Deception check against a target's Will Defense. If the check is successful, the target is Flat-Footed against your next attack made before the end of your next turn. Additionally, you can spend a Force Point to extend your target's penalties until the end of encounter.","prerequisite":"Trained in Deception","special":"","normalText":"","sourcebook":"Unknown Regions","page":19,"tags":["action_economy","feat","general","skill_deception","skill_synergy","swift_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Combat_Trickery</p>\n<p>You excel at deceiving others with your tricks and masterful Feint in combat.</p>\n<p><strong>Prerequisites:</strong> Trained in Deception</p>\n<h4>Effect</h4>\n<p>You can spend two successive Swift Actions on the same turn to make a Deception check against a target&#x27;s Will Defense. If the check is successful, the target is Flat-Footed against your next attack made before the end of your next turn. Additionally, you can spend a Force Point to extend your target&#x27;s penalties until the end of encounter.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Combat Trickery"}]},"shortSummary":"Spend two Swift Actions to make Deception check to make enemy Flat-Footed.","prerequisitesText":"Trained in Deception","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Combat_Trickery"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":[],"id":"swse.feat.combat_trickery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Combat_Trickery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9af3ba38a2c671b8","name":"Feat of Strength","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter as a Full-Round Action, you can Take 20 on a Strength check or Strength -based Skill Check (You must be Trained in that Skill), even if distracted or threatened.","prerequisite":"Strength 15","special":"After using this Feat for the first time in a given encounter, make a DC 15 Endurance check (As a Free Action). If the check succeeds, you can use this Feat once more during the same encounter.","normalText":"You may not Take 20 when distracted or threatened, or in a single round.","sourcebook":"Legacy Era Campaign Guide","page":18,"tags":["ability_strength","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Feat_of_Strength</p>\n<p>You draw on inner reserves of physical power to perform great feats of strength, such as lifting heavy objects, leaping great distances, or hauling yourself up a cliff while weighed down by a Heavy Load.</p>\n<p><strong>Prerequisites:</strong> Strength 15</p>\n<h4>Effect</h4>\n<p>Once per encounter as a Full-Round Action, you can Take 20 on a Strength check or Strength -based Skill Check (You must be Trained in that Skill), even if distracted or threatened.</p>\n<h4>Normal</h4>\n<p>You may not Take 20 when distracted or threatened, or in a single round.</p>\n<h4>Special</h4>\n<p>After using this Feat for the first time in a given encounter, make a DC 15 Endurance check (As a Free Action). If the check succeeds, you can use this Feat once more during the same encounter.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":15}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Feat of Strength"}]},"shortSummary":"Take 10 or Take 20 on one Strength check or related Skill Check per encounter.","prerequisitesText":"Strength 15","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Feat_of_Strength"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":[],"id":"swse.feat.feat_of_strength","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Feat_of_Strength","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9b7b869a86f39190","name":"Force Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You add to your Force Power Suite a number of Force Powers equal to 1 + your Wisdom modifier (Minimum 1). You can add the same Force Power more than once.","prerequisite":"Force Sensitivity, Trained in Use the Force.","special":"You can take this Feat more than once. Each time you take this Feat, you add to your Force Power Suite a number of new Force Powers equal to 1 + your Wisdom modifier.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":94,"tags":["ability_wisdom","build_enabler","feat","force","force_capacity","force_powers","force_training","forecast_value","new_option","choice_required","grant_choice","deferred_choice","choice_source_grant_pool"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"forcePowerGrants":1,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Force_Training</p>\n<p>You learn one or more Force Powers.</p>\n<p><strong>Prerequisites:</strong> Force Sensitivity, Trained in Use the Force.</p>\n<h4>Effect</h4>\n<p>You add to your Force Power Suite a number of Force Powers equal to 1 + your Wisdom modifier (Minimum 1). You can add the same Force Power more than once.</p>\n<h4>Special</h4>\n<p>You can take this Feat more than once. Each time you take this Feat, you add to your Force Power Suite a number of new Force Powers equal to 1 + your Wisdom modifier.</p>\n<h4>Additional Force Training Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Improved Disarm): When you use the Force Disarm Force Power, you gain the +5 bonus from Improved Disarm on your Use the Force check as though you were making an attack roll.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"usetheforce"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Force Training"}]},"choiceMeta":{"resolution":"grant_entitlement","required":true,"status":"deferred_grant_step_not_immediate_choice","choiceKind":"force_power_pick","storagePath":"flags.swse.pendingEntitlements.force_power_pick","choiceSource":"grantPool","grantType":"force_power","grantRegistry":"forcePower","countFormula":"max(1, 1 + configuredForceTrainingAbilityModifier)","optionRegistry":"data/feat-choice-options.json#choiceKinds.force_power_pick","minimum":1,"dynamic":true,"repeatable":true},"shortSummary":"Learn a number of Force Powers equal to 1 + your Wisdom modifier (minimum 1).","prerequisitesText":"Force Sensitivity, Trained in Use the Force.","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Force_Training"},"effects":[{"_id":"d1c60a9b-78e6-4601-85a4-320794fa5a91","name":"Force Training","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Force Training","effectType":"passive_effect","flagType":"Force Training"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":[],"id":"swse.feat.force_training","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Force_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9c904590c02fb30a","name":"Targeted Area","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make a successful Area Attack with a weapon with which you are proficient, select a target hit by the attack. That target takes an additional 5 points of damage from the attack, before applying the effect of the Evasion Talent.","prerequisite":"Base Attack Bonus +5","special":"","normalText":"","sourcebook":"Unknown Regions","page":27,"tags":["feat","general","multi_target"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Targeted_Area</p>\n<p>Your Area Attacks deal more damage to one target within the area of effect.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +5</p>\n<h4>Effect</h4>\n<p>When you make a successful Area Attack with a weapon with which you are proficient, select a target hit by the attack. That target takes an additional 5 points of damage from the attack, before applying the effect of the Evasion Talent.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Targeted Area"}]},"shortSummary":"Deal an additional 5 points of damage against one target within a successful Area Attack.","prerequisitesText":"Base Attack Bonus +5","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Targeted_Area"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":[],"id":"swse.feat.targeted_area","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Targeted_Area","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9c9e98a70538855c","name":"Slammer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Standard Action, you slam two of your Appendages together from either side of an enemy, crushing your target between them. Make a melee attack. If the attack is successful, you deal Unarmed damage with double your Strength bonus. If you also exceed the target's Damage Threshold, it has a Persistent Condition that can only be removed with 8 hours of rest or a DC 20 Treat Injury check.","prerequisite":"Droid, Small size or larger, 2+ Appendages, Strength 13","special":"If you also have the Crush Feat, increase your Unarmed damage by 1 die when using Slammer.","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":25,"tags":["ability_strength","feat","general","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Slammer</p>\n<p>You clap two Hands, Claws, or Appendages together, delivering a crushing blow to an enemy.</p>\n<p><strong>Prerequisites:</strong> Droid, Small size or larger, 2+ Appendages, Strength 13</p>\n<h4>Effect</h4>\n<p>As a Standard Action, you slam two of your Appendages together from either side of an enemy, crushing your target between them. Make a melee attack. If the attack is successful, you deal Unarmed damage with double your Strength bonus. If you also exceed the target&#x27;s Damage Threshold, it has a Persistent Condition that can only be removed with 8 hours of rest or a DC 20 Treat Injury check.</p>\n<h4>Special</h4>\n<p>If you also have the Crush Feat, increase your Unarmed damage by 1 die when using Slammer.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-melee"],"enabled":true,"priority":500,"description":"Slammer"}]},"shortSummary":"Double Strength bonus to damage rolls on this special melee attack.","prerequisitesText":"Droid, Small size or larger, 2+ Appendages, Strength 13","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Slammer"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":["attack.with-melee"],"id":"swse.feat.slammer","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Slammer","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9d70c309eb95da5e","name":"Inborn Resilience","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Reduce one Defense bonus but increase another.","prerequisite":"Zabrak","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["defense","feat","racial","species","species_opportunity","survivability"],"bonus_feat_for":["species-zabrak"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Reduce one Defense bonus but increase another."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Inborn Resilience"}]},"shortSummary":"Reduce one Defense bonus but increase another."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":[],"id":"swse.feat.inborn_resilience"}}}
{"_id":"9de63b7a605768c2","name":"Advantageous Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make a successful attack against an enemy who has not yet acted in combat, you add your full Heroic Level to damage rolls.","prerequisite":"Base Attack Bonus +1","special":"","normalText":"Typically you add only one-half your Heroic Level to damage rolls.","sourcebook":"The Force Unleashed Campaign Guide","page":32,"tags":["feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Advantageous_Attack</p>\n<p>You know how to take advantage of slow-moving enemies in combat.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>When you make a successful attack against an enemy who has not yet acted in combat, you add your full Heroic Level to damage rolls.</p>\n<h4>Normal</h4>\n<p>Typically you add only one-half your Heroic Level to damage rolls.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Advantageous Attack"}]},"shortSummary":"Add full Heroic Level to attacks against slower enemies.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Advantageous_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":[],"id":"swse.feat.advantageous_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Advantageous_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"9f1305cc6ada5d7a","name":"Devastating Bellow","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Deal more damage with your Bellow attacks.","prerequisite":"Ithorian","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-ithorian"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Deal more damage with your Bellow attacks."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Devastating Bellow"}]},"shortSummary":"Deal more damage with your Bellow attacks."},"effects":[{"_id":"8ea0a750-3da1-4137-9cd3-6391ec6c80b9","name":"Devastating Bellow","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Devastating Bellow","effectType":"passive_effect","flagType":"Devastating Bellow"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.385Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.devastating_bellow"}}}
{"_id":"a12f6fd51e121a30","name":"Vitality Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can catch a Second Wind even if you are not at or below half your maximum Hit Points.","prerequisite":"Extra Second Wind","special":"","normalText":"Without this Feat, you can catch a Second Wind only if you are at or below half your maximum Hit Points.","sourcebook":"Rebellion Era Campaign Guide","page":23,"tags":["defense","durability","feat","general","hit_points","recovery","second_wind","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Vitality_Surge</p>\n<p>You can keep yourself in top fighting form at any point in the fight.</p>\n<p><strong>Prerequisites:</strong> Extra Second Wind</p>\n<h4>Effect</h4>\n<p>You can catch a Second Wind even if you are not at or below half your maximum Hit Points.</p>\n<h4>Normal</h4>\n<p>Without this Feat, you can catch a Second Wind only if you are at or below half your maximum Hit Points.</p>\n</div>"},"executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":true,"priority":500,"description":"Vitality Surge"}],"resourceRules":{"secondWind":[{"type":"ALLOW_ABOVE_HALF_HP","description":"You may catch a Second Wind even when not at or below half hit points."}]}},"shortSummary":"Catch a Second Wind even when not at or below half Hit Points.","prerequisitesText":"Extra Second Wind","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Vitality_Surge"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["attack.when-hit"],"id":"swse.feat.vitality_surge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Vitality_Surge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a16af4c63582b44a","name":"Flash and Clear","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you damage a target with a Burst or Splash weapon, you gain Concealment against that target until the beginning of your next turn.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":23,"tags":["area_pressure","cover_play","feat","general","grenade","multi_target","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Flash_and_Clear</p>\n<p>You can use the smoke, noise, light, and confusion caused by your Grenade attacks to move unseen near your foes.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When you damage a target with a Burst or Splash weapon, you gain Concealment against that target until the beginning of your next turn.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Flash and Clear"}]},"shortSummary":"Gain Concealment against a target you damage with a Burst or Splash weapon.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Flash_and_Clear"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.flash_and_clear","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Flash_and_Clear","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a16df0d4edf3e7bf","name":"Heavy Hitter","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When making an attack roll using a Weapon Emplacement or a Weapon System, you add an additional 1 point of damage for every 5 points you roll above the target's Reflex Defense. If you exceed the target's Damage Threshold, then on its next turn the target cannot attack and its speed is reduced by 2 squares (1 square Starship Scale).","prerequisite":"Weapon Focus (Heavy Weapons)","special":"","normalText":"","sourcebook":"Unknown Regions","page":22,"tags":["damage_threshold","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Heavy_Hitter</p>\n<p>You know how to pound targets when firing heavy-weapons emplacements and vehicle weaponry.</p>\n<p><strong>Prerequisites:</strong> Weapon Focus (Heavy Weapons)</p>\n<h4>Effect</h4>\n<p>When making an attack roll using a Weapon Emplacement or a Weapon System, you add an additional 1 point of damage for every 5 points you roll above the target&#x27;s Reflex Defense. If you exceed the target&#x27;s Damage Threshold, then on its next turn the target cannot attack and its speed is reduced by 2 squares (1 square Starship Scale).</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Heavy Hitter"}]},"shortSummary":"Add +1 point of damage for every 5 points rolled above the target's Reflex Defense, plus additional benefits when you exceed the target's Damage Threshold.","prerequisitesText":"Weapon Focus (Heavy Weapons)","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Heavy_Hitter"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.heavy_hitter","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Heavy_Hitter","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a2708e8daf121947","name":"Rapport","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using the Aid Another Action, you grant an additional +2 insight bonus on Skill Checks and attack rolls to the character you are assisting. This bonus does not stack with any bonus provided by the Noble's Coordinate Talent.","prerequisite":"Wisdom 13","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":36,"tags":["feat","general","social"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Rapport</p>\n<p>You are adept at working with certain individuals, able to anticipate their next move.</p>\n<p><strong>Prerequisites:</strong> Wisdom 13</p>\n<h4>Effect</h4>\n<p>When using the Aid Another Action, you grant an additional +2 insight bonus on Skill Checks and attack rolls to the character you are assisting. This bonus does not stack with any bonus provided by the Noble&#x27;s Coordinate Talent.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Rapport"}]},"shortSummary":"Grant an additional +2 bonus when using the Aid Another action.","prerequisitesText":"Wisdom 13","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Rapport"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.rapport","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Rapport","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a51721a36b699c7c","name":"Fight Through Pain","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use your Will Defense instead of your Fortitude Defense when determining your Damage Threshold.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":22,"tags":["damage_threshold","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Fight_Through_Pain</p>\n<p>Through sheer willpower, you can keep yourself at peak fighting performance, ignoring physical pain and negative effects.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You can use your Will Defense instead of your Fortitude Defense when determining your Damage Threshold.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.will"],"enabled":true,"priority":500,"description":"Fight Through Pain"}]},"shortSummary":"Use your Will Defense to determine your Damage Threshold.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Fight_Through_Pain"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.will"],"id":"swse.feat.fight_through_pain","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fight_Through_Pain","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a65c4d3ad1c3202f","name":"Resilient Strength","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use either your Strength modifier or your Constitution modifier to determine your Fortitude Defense.","prerequisite":"Strength 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["ability_constitution","ability_strength","defense","feat","general","survivability"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Resilient_Strength</p>\n<p>Your brute strength and physical conditioning allow you to shrug off effects that would debilitate others.</p>\n<p><strong>Prerequisites:</strong> Strength 13</p>\n<h4>Effect</h4>\n<p>You can use either your Strength modifier or your Constitution modifier to determine your Fortitude Defense.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":2,"type":"untyped","predicates":["defense.fortitude","turn.once-per-round"],"enabled":true,"priority":500,"description":"Resilient Strength"}]},"shortSummary":"Use Strength or Constitution to determine Fortitude Defense.","prerequisitesText":"Strength 13","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Resilient_Strength"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.fortitude","turn.once-per-round"],"id":"swse.feat.resilient_strength","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Resilient_Strength","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a6890bb21adad47e","name":"Expert Briber","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using the Haggle or Bribery applications of the Persuasion skill, you reduce the DC to reduce the price of the item haggled over by 10.","prerequisite":"Charisma 13","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":18,"tags":["feat","general","social"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Expert_Briber</p>\n<p>You are adept at greasing the palms of contacts to minimize the amount of the Bribe normally required.</p>\n<p><strong>Prerequisites:</strong> Charisma 13</p>\n<h4>Effect</h4>\n<p>When using the Haggle or Bribery applications of the Persuasion skill, you reduce the DC to reduce the price of the item haggled over by 10.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Expert Briber"}]},"shortSummary":"Reduce the time and cost of Bribery attempts.","prerequisitesText":"Charisma 13","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Expert_Briber"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.expert_briber","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Expert_Briber","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a717435c8094e7fb","name":"Superior Tech","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Select one of the following: Armor, Weapons, Droids, Vehicles, or Devices. You can install advanced Traits when modifying the selected type of equipment. These Traits replace the Traits granted by the Tech Specialist Feat. You may still use the Tech Specialist options if you so choose.\n\nYou must pay one-fifth the cost of the Device, Armor, Weapon, Droid, or vehicle you wish to modify or 2,000 credits, whichever is more, before beginning the modification. This fee replaces the normal cost of modification from the Tech Specialist Feat. Completing the modification requires 1 day per 1,000 credits of the modification's cost. At the end of this time, make a DC 30 Mechanics check; you cannot Take 10 or Take 20 on this check. If the check succeeds, the modification is completed successfully, and the object gains the desired Trait. If the check fails, you lose all credits spent on making the modification, and the object does not gain the desired Trait. However, you can start over from scratch if you wish.\n\nOnly characters with the Tech Specialist Feat can assist you, reducing proportionately the time needed to complete the modification. At the end of the modification process, they can make a Mechanics check to aid your check.\n\nThe market value of a modified item is equal to the base cost of the item plus double the cost of the modifications made to it (not including credits wasted on failed modification attempts).","prerequisite":"Intelligence 17, Tech Specialist, 9th Character Level","special":"You may select this Feat multiple times. Each time you do so, you must choose a different set of Traits (Armor, Devices, Droids, Vehicles, or Weapons).\n\nARMOR TRAIT | BENEFIT\nMobile Armor | Increases Speed by 1 square (Medium Armor and Heavy Armor only).\nReinforced Armor | Grants Damage Reduction 2.\nSuperior Agile Armor | The Armor's maximum Dexterity bonus increases by +2.\nSuperior Fortifying Armor | The Armor's Equipment bonus to Fortitude Defense increases by +2.\nSuperior Helmet Package | Grants wearer a +5 Equipment bonus on Perception checks.\nSuperior Protective Armor | The Armor's Armor bonus to Reflex Defense increases by +2.\nDEVICE TRAIT | BENEFIT\nSuperior Strength | Increase the Device's Strength score by +4.\nSuperior Durability | The Device's Damage Reduction increases by +2, and increase its Hit Points by 150%.\nReinforced Device | The Device's Break DC increases by +5.\nSuperior Mastercraft | Skill Checks made using the device gain a +2 Equipment bonus, or its existing Equipment bonus increases by +2.\nDROID TRAIT | BENEFIT\nIon Dispersal Coating | Droid gains Damage Reduction 5 against Ion damage.\nSuperior Ability | Increase Droids Dexterity, Intelligence, or Strength score by +4.\nVEHICLE TRAIT | BENEFIT\nSuperior Ability | Increase the Vehicle's Dexterity by +4 or its Strength by +2.\nSuperior Sensors | Increase the Vehicle's Perception modifier by +2.\nSuperior Shields | Increase the Vehicle's Shield Rating by +10.\nSuperior Speed | Increase the Vehicle's Speed by one-third of its base Speed (minimum 1 square).\nWEAPON TRAIT | BENEFIT\nSuperior Accuracy | The Weapon gains a +2 Equipment bonus on attack rolls.\nSuperior Capacity | The Weapon's Power Pack provides double the number of shots.\nSuperior Damage | The Weapon deals +5 damage with a successful hit. If the weapon has a damage multiplier apply the extra damage before applying the multiplier.\nSuperior Range | The Weapon's Ranges all increase by 50%.","normalText":"","sourcebook":"Scum and Villainy","page":29,"tags":["feat","general","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Superior_Tech</p>\n<p>You expand your knowledge of technology and can apply a variety of other Traits to equipment you modify.</p>\n<p><strong>Prerequisites:</strong> Intelligence 17, Tech Specialist, 9th Character Level</p>\n<h4>Effect</h4>\n<p>Select one of the following: Armor, Weapons, Droids, Vehicles, or Devices. You can install advanced Traits when modifying the selected type of equipment. These Traits replace the Traits granted by the Tech Specialist Feat. You may still use the Tech Specialist options if you so choose.</p>\n<p>You must pay one-fifth the cost of the Device, Armor, Weapon, Droid, or vehicle you wish to modify or 2,000 credits, whichever is more, before beginning the modification. This fee replaces the normal cost of modification from the Tech Specialist Feat. Completing the modification requires 1 day per 1,000 credits of the modification&#x27;s cost. At the end of this time, make a DC 30 Mechanics check; you cannot Take 10 or Take 20 on this check. If the check succeeds, the modification is completed successfully, and the object gains the desired Trait. If the check fails, you lose all credits spent on making the modification, and the object does not gain the desired Trait. However, you can start over from scratch if you wish.</p>\n<p>Only characters with the Tech Specialist Feat can assist you, reducing proportionately the time needed to complete the modification. At the end of the modification process, they can make a Mechanics check to aid your check.</p>\n<p>The market value of a modified item is equal to the base cost of the item plus double the cost of the modifications made to it (not including credits wasted on failed modification attempts).</p>\n<h4>Special</h4>\n<p>You may select this Feat multiple times. Each time you do so, you must choose a different set of Traits (Armor, Devices, Droids, Vehicles, or Weapons).</p>\n<table class=\"swse-rules-table\"><tbody><tr><th>ARMOR TRAIT</th><th>BENEFIT</th></tr><tr><td>Mobile Armor</td><td>Increases Speed by 1 square (Medium Armor and Heavy Armor only).</td></tr><tr><td>Reinforced Armor</td><td>Grants Damage Reduction 2.</td></tr><tr><td>Superior Agile Armor</td><td>The Armor&#x27;s maximum Dexterity bonus increases by +2.</td></tr><tr><td>Superior Fortifying Armor</td><td>The Armor&#x27;s Equipment bonus to Fortitude Defense increases by +2.</td></tr><tr><td>Superior Helmet Package</td><td>Grants wearer a +5 Equipment bonus on Perception checks.</td></tr><tr><td>Superior Protective Armor</td><td>The Armor&#x27;s Armor bonus to Reflex Defense increases by +2.</td></tr><tr><td>DEVICE TRAIT</td><td>BENEFIT</td></tr><tr><td>Superior Strength</td><td>Increase the Device&#x27;s Strength score by +4.</td></tr><tr><td>Superior Durability</td><td>The Device&#x27;s Damage Reduction increases by +2, and increase its Hit Points by 150%.</td></tr><tr><td>Reinforced Device</td><td>The Device&#x27;s Break DC increases by +5.</td></tr><tr><td>Superior Mastercraft</td><td>Skill Checks made using the device gain a +2 Equipment bonus, or its existing Equipment bonus increases by +2.</td></tr><tr><td>DROID TRAIT</td><td>BENEFIT</td></tr><tr><td>Ion Dispersal Coating</td><td>Droid gains Damage Reduction 5 against Ion damage.</td></tr><tr><td>Superior Ability</td><td>Increase Droids Dexterity, Intelligence, or Strength score by +4.</td></tr><tr><td>VEHICLE TRAIT</td><td>BENEFIT</td></tr><tr><td>Superior Ability</td><td>Increase the Vehicle&#x27;s Dexterity by +4 or its Strength by +2.</td></tr><tr><td>Superior Sensors</td><td>Increase the Vehicle&#x27;s Perception modifier by +2.</td></tr><tr><td>Superior Shields</td><td>Increase the Vehicle&#x27;s Shield Rating by +10.</td></tr><tr><td>Superior Speed</td><td>Increase the Vehicle&#x27;s Speed by one-third of its base Speed (minimum 1 square).</td></tr><tr><td>WEAPON TRAIT</td><td>BENEFIT</td></tr><tr><td>Superior Accuracy</td><td>The Weapon gains a +2 Equipment bonus on attack rolls.</td></tr><tr><td>Superior Capacity</td><td>The Weapon&#x27;s Power Pack provides double the number of shots.</td></tr><tr><td>Superior Damage</td><td>The Weapon deals +5 damage with a successful hit. If the weapon has a damage multiplier apply the extra damage before applying the multiplier.</td></tr><tr><td>Superior Range</td><td>The Weapon&#x27;s Ranges all increase by 50%.</td></tr></tbody></table>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"int","min":17}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Superior Tech"}]},"shortSummary":"Install superior equipment upgrades.","prerequisitesText":"Intelligence 17, Tech Specialist, 9th Character Level","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Superior_Tech"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.superior_tech","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Superior_Tech","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a75d5d6b3ce5bc6f","name":"Logic Upgrade: Tactician","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Grant a +5 bonus to attack with a successful Aid Another attempt.","prerequisite":"Droid, Base Attack Bonus +4","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":27,"tags":["feat","general","knowledge","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Grant a +5 bonus to attack with a successful Aid Another attempt."},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":4}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Logic Upgrade: Tactician"}]},"shortSummary":"Grant a +5 bonus to attack with a successful Aid Another attempt."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.logic_upgrade_tactician"}}}
{"_id":"a8511e47656ef4dd","name":"Trip","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you succeed on a Grappling attack and your opponent fails the opposed Grapple check, it falls Prone in its space and is no longer considered Grappled. A Prone opponent takes a -5 penalty on melee attack rolls. Melee attacks made against a Prone target gain a +5 bonus, while ranged attack made against a prone target take a -5 penalty.","prerequisite":"Base Attack Bonus +1","special":"You cannot use the Pin and Trip Feats in the same round.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["control","feat","general","grapple","knock_prone","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Trip</p>\n<p>You are skilled at Tripping Grappled foes.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +1</p>\n<h4>Effect</h4>\n<p>If you succeed on a Grappling attack and your opponent fails the opposed Grapple check, it falls Prone in its space and is no longer considered Grappled. A Prone opponent takes a -5 penalty on melee attack rolls. Melee attacks made against a Prone target gain a +5 bonus, while ranged attack made against a prone target take a -5 penalty.</p>\n<h4>Special</h4>\n<p>You cannot use the Pin and Trip Feats in the same round.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["target.is-prone"],"enabled":true,"priority":500,"description":"Trip"}]},"shortSummary":"Trip an opponent that you've Grappled, knocking it Prone.","prerequisitesText":"Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Trip"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["target.is-prone"],"id":"swse.feat.trip","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Trip","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a945e2f5ffb5a7ed","name":"Charging Fire","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you Charge, you may make a ranged attack instead of a melee attack at the end of your movement. Unlike a normal Charge, your momentum does not help you overcome your target, so you gain no bonus on your attack roll. As with a normal Charge, you still take a -2 penalty to your Reflex Defense.","prerequisite":"Base Attack Bonus +4","special":"","normalText":"You can make a single melee attack with a +2 bonus on your attack roll at the end of a Charge.","sourcebook":"Galaxy at War","page":24,"tags":["charge","feat","general","offense"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Charging_Fire</p>\n<p>You are able to make ranged attacks while Charging.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +4</p>\n<h4>Effect</h4>\n<p>When you Charge, you may make a ranged attack instead of a melee attack at the end of your movement. Unlike a normal Charge, your momentum does not help you overcome your target, so you gain no bonus on your attack roll. As with a normal Charge, you still take a -2 penalty to your Reflex Defense.</p>\n<h4>Normal</h4>\n<p>You can make a single melee attack with a +2 bonus on your attack roll at the end of a Charge.</p>\n<h4>Additional Charging Fire Effects</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p>Combined Feat (Dodge): You reduce your penalty to your Reflex Defense against all opponents to -1 when making a ranged attack at the end of a Charge.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":4}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex","attack.with-ranged"],"enabled":true,"priority":500,"description":"Charging Fire"}]},"shortSummary":"Make ranged attack at end of a Charge; take a -2 penalty to Reflex Defense.","prerequisitesText":"Base Attack Bonus +4","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Charging_Fire"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.reflex","attack.with-ranged"],"id":"swse.feat.charging_fire","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Charging_Fire","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"a9a59c85cddbda1f","name":"Warrior Heritage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Will Defense when using an Atlatl or Cesta.","prerequisite":"Gungan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-gungan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to Will Defense when using an Atlatl or Cesta."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will"],"enabled":true,"priority":500,"description":"Warrior Heritage"}]},"shortSummary":"Gain a bonus to Will Defense when using an Atlatl or Cesta."},"effects":[{"_id":"d81202e0-20b2-409c-8d32-45838433244f","name":"Warrior Heritage","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Warrior Heritage","effectType":"defense_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.will"],"id":"swse.feat.warrior_heritage"}}}
{"_id":"a9f6de36f24ef202","name":"Skill Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one Untrained Skill from your list of Class Skills. You become Trained in that Skill.","prerequisite":"None","special":"This Feat may be selected multiple times. Each time you take this Feat, it applies to a different Class Skill.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["build_enabler","feat","forecast_value","general","new_option","prereq_gateway","skill_recovery","skill_training","choice_required","choice_source_fixed"],"bonus_feat_for":["8c58016e587dd2c7","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Skill_Training</p>\n<p>You are considered Trained in a new Skill.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Choose one Untrained Skill from your list of Class Skills. You become Trained in that Skill.</p>\n<h4>Special</h4>\n<p>This Feat may be selected multiple times. Each time you take this Feat, it applies to a different Class Skill.</p>\n</div>"},"executionModel":"UNLOCK","abilityMeta":{"grants":[{"category":"SKILL_TRAINING","skills":"selectedChoice","description":"Skill Training: selected skill becomes trained."}],"status":"skill_training_implemented","description":"Skill Training: Select one Class Skill. You become trained in that skill."},"choiceMeta":{"resolution":"immediate","required":true,"status":"execution_mapped_phase6","choiceKind":"skill_training","choiceSource":"fixed","repeatable":true,"optionRegistry":"data/feat-choice-options.json#choiceKinds.skill_training","storagePath":"flags.swse.choices.skill_training","effectTarget":"skillTraining.selected"},"shortSummary":"You become Trained in one Class Skill.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Skill_Training"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.skill_training","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Skill_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"aaa730a68f195111","name":"Savage Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one weapon groups or Exotic Weapon you have selected for the Double Attack Feat. When you use a Full Attack Action and successfully hit the target with your first attack, you deal +1 die of damage on each successful attack remaining in the Full Attack made against that target.","prerequisite":"Double Attack (Chosen Weapon)","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["feat","general","offense"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Savage_Attack</p>\n<p>You are well trained in attacking multiple times in a round.</p>\n<p><strong>Prerequisites:</strong> Double Attack (Chosen Weapon)</p>\n<h4>Effect</h4>\n<p>Choose one weapon groups or Exotic Weapon you have selected for the Double Attack Feat. When you use a Full Attack Action and successfully hit the target with your first attack, you deal +1 die of damage on each successful attack remaining in the Full Attack made against that target.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Savage Attack"}]},"shortSummary":"Add +1 die of damage when successful on a Full Attack.","prerequisitesText":"Double Attack (Chosen Weapon)","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Savage_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.savage_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Savage_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"acb7efcc70769b9f","name":"Mounted Defense","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When riding a Beast as a Mount or on a Speeder Bike (as a passenger or a Pilot), once per encounter you can redirect any attack made against you at your Mount or Vehicle instead. The decision to redirect the attack is made after the result of the attack roll is determined but before damage or other effects are resolved.","prerequisite":"Trained in Pilot or Ride","special":"","normalText":"","sourcebook":"Threats of the Galaxy","page":20,"tags":["defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Threats of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Mounted_Defense</p>\n<p>You are able to react to incoming attacks, using your Mount or Speeder Bike to absorb attacks against you.</p>\n<p><strong>Prerequisites:</strong> Trained in Pilot or Ride</p>\n<h4>Effect</h4>\n<p>When riding a Beast as a Mount or on a Speeder Bike (as a passenger or a Pilot), once per encounter you can redirect any attack made against you at your Mount or Vehicle instead. The decision to redirect the attack is made after the result of the attack roll is determined but before damage or other effects are resolved.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Mounted Defense"}]},"shortSummary":"You are able to react to incoming attacks, using you Mount or Speeder Bike to absorb attacks against you.","prerequisitesText":"Trained in Pilot or Ride","referenceBooks":["Star Wars Saga Edition Threats of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Mounted_Defense"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.mounted_defense","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mounted_Defense","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ad2b32e5dfa38a3f","name":"Sadistic Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you deliver a Coup de Grace to a Helpless creature, all opponents within line of sight move -1 step on the Condition Track until the end of encounter.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":24,"tags":["condition_track","feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Sadistic_Strike</p>\n<p>By dispatching a Helpless creature, you terrify opponents around you.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When you deliver a Coup de Grace to a Helpless creature, all opponents within line of sight move -1 step on the Condition Track until the end of encounter.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Sadistic Strike"}]},"resourceRules":{"conditionTrack":[{"type":"MOVE_TARGET_CT_ON_COUP_DE_GRACE"}]},"shortSummary":"Move opponents -1 step on the Condition Track when you deliver a Coup de Grace.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Sadistic_Strike"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.sadistic_strike","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Sadistic_Strike","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ad740c563485664d","name":"Lasting Influence","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"After a successful Persuasion check, gain a bonus to future Persuasion checks.","prerequisite":"Bothan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","skill_persuasion","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-bothan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"After a successful Persuasion check, gain a bonus to future Persuasion checks."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will"],"enabled":true,"priority":500,"description":"Lasting Influence"}]},"shortSummary":"After a successful Persuasion check, gain a bonus to future Persuasion checks."},"effects":[{"_id":"d140a858-0a44-4f95-a88f-cfa9d35d16fa","name":"Lasting Influence","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Lasting Influence","effectType":"passive_effect","flagType":"Lasting Influence"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.will"],"id":"swse.feat.lasting_influence"}}}
{"_id":"adc9cac4d22b3090","name":"Assured Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you deal damage to a target with an attack and you roll multiple damage dice, you can reroll the lowest damage die but must keep the second result, even if it is worse.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":23,"tags":["feat","general","offense","reroll"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Assured_Attack</p>\n<p>You have become so practiced with your attacks that you always deal significant damage.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>Whenever you deal damage to a target with an attack and you roll multiple damage dice, you can reroll the lowest damage die but must keep the second result, even if it is worse.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"damage_reroll_phase8","description":"Assured Attack: reroll the lowest damage die on successful attack.","damageRerolls":[{"id":"assured-attack","type":"DAMAGE_DIE_REROLL","trigger":"successfulAttack","target":"lowestDie","outcome":"keepBetter","description":"Assured Attack: reroll the lowest damage die when making a successful attack."}]},"shortSummary":"Reroll the lowest damage die when making a successful attack.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Assured_Attack"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.assured_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Assured_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ae4dece84c32c3ac","name":"Droidcraft","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use the Repair Droid aspect of the Mechanics skill in 10 minutes.","prerequisite":"Trained in Mechanics","special":"","normalText":"Using Repair Droid typically takes 1 hour.","sourcebook":"Clone Wars Campaign Guide","page":21,"tags":["feat","general","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Droidcraft</p>\n<p>You can repair Droids quickly.</p>\n<p><strong>Prerequisites:</strong> Trained in Mechanics</p>\n<h4>Effect</h4>\n<p>You can use the Repair Droid aspect of the Mechanics skill in 10 minutes.</p>\n<h4>Normal</h4>\n<p>Using Repair Droid typically takes 1 hour.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"745a5686d6f21e8c"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Droidcraft"}]},"shortSummary":"Repair a Droid in 10 minutes instead of 1 hour.","prerequisitesText":"Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Droidcraft"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.droidcraft","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Droidcraft","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ae5c34d352d6dff7","name":"Intuitive Initiative","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You may reroll your Initiative check and take the better result. You must keep the new result even if it is worse.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"Jedi Academy Training Manual","page":31,"tags":["feat","force","skill_initiative","skill_synergy"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Intuitive Initiative"}]},"shortSummary":"You may reroll your Initiative check and take the better result."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[]}}}
{"_id":"af5caa92d8fc0e3a","name":"Mounted Combat","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can make a DC 20 Ride check as a Swift Action to spur your living Mount to move faster than its normal speed. If the check fails, your Mount's Speed does not increase and it moves -1 step on the Condition Track. If the check succeeds, your Mount's Speed increases by 2 squares until the start of your next turn. You cannot Take 10 on this check. Your Mount must succeed on a DC 20 Endurance check prior to each subsequent attempt to use this Feat in the same encounter.\n\nAdditionally, once per round, as a Reaction, when you are riding a Mount, you can negate a weapon hit against either you or the Mount by making a successful Ride check. The DC of the Skill Check is equal to the result of the attack roll you want to negate.","prerequisite":"Trained in Ride","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Unknown Regions</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Mounted_Combat</p>\n<p>You know how to get the most from a Mount in combat and in other dangerous situations.</p>\n<p><strong>Prerequisites:</strong> Trained in Ride</p>\n<h4>Effect</h4>\n<p>You can make a DC 20 Ride check as a Swift Action to spur your living Mount to move faster than its normal speed. If the check fails, your Mount&#x27;s Speed does not increase and it moves -1 step on the Condition Track. If the check succeeds, your Mount&#x27;s Speed increases by 2 squares until the start of your next turn. You cannot Take 10 on this check. Your Mount must succeed on a DC 20 Endurance check prior to each subsequent attempt to use this Feat in the same encounter.</p>\n<p>Additionally, once per round, as a Reaction, when you are riding a Mount, you can negate a weapon hit against either you or the Mount by making a successful Ride check. The DC of the Skill Check is equal to the result of the attack roll you want to negate.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":2,"type":"untyped","predicates":["attack.when-hit","turn.once-per-round"],"enabled":true,"priority":500,"description":"Mounted Combat"}]},"shortSummary":"Increase Speed and avoid attacks when riding a Mount.","prerequisitesText":"Trained in Ride","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Mounted_Combat"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["attack.when-hit","turn.once-per-round"],"id":"swse.feat.mounted_combat","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mounted_Combat","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b00e0a883da4edda","name":"K'thri Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"martial_arts","benefit":"Make swift Unarmed attacks. Deal half damage on misses.","prerequisite":"Dual Weapon Mastery I, Martial Arts I","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","feat_chain","martial_arts","martial_style","offense_melee","unarmed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Make swift Unarmed attacks. Deal half damage on misses."},"martialArtsFeat":true,"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":true,"priority":500,"description":"K'thri Training"}]},"shortSummary":"Make swift Unarmed attacks."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.kthri_training"}}}
