{"_id":"d2e86b15327ae544","name":"Hunter's Instincts","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Reroll Perception checks, always keeping the better result.","prerequisite":"Rodian","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["control","feat","grapple","racial","reroll","skill_perception","skill_synergy","species","species_opportunity","skill_reroll","execution_mapped_phase8"],"bonus_feat_for":["species-rodian"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Rodian</p>\n<p><strong>Effect:</strong> Whenever you reroll a<br>Perception<br>check, you always keep the better result, even if you have multiple reroll abilities.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Hunter&#x27;s_Instincts</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8","description":"Hunter's Instincts: reroll Perception checks and keep the better result.","skillRerolls":[{"id":"hunters-instincts","skillKeys":["perception"],"outcome":"keepBetter","label":"Hunter's Instincts","description":"Hunter's Instincts: reroll Perception checks and keep the better result."}],"mechanicsMode":"conditional","applicationScope":"reroll_or_resource_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rerolls/resources are not static sheet modifiers and require a check/encounter/resource context.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Reroll Perception checks, always keeping the better result.","sourceUrl":"https://swse.fandom.com/wiki/Hunter's_Instincts","rawImport":{"name":"Hunter's Instincts","url":"https://swse.fandom.com/wiki/Hunter's_Instincts","pag