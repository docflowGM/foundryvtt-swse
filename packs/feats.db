{"_id":"47c92eae6c1a0b84","name":"Pinpoint Accuracy","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When using the Aiming Accuracy Feat, a target you damage cannot take the Recover Action until the end of its next turn.","prerequisite":"Droid, Aiming Accuracy, Point-Blank Shot, Precise Shot","special":"","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":24,"tags":["condition_track","control","feat","general","grapple"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Droid<br>,<br>Aiming Accuracy<br>,<br>Point-Blank Shot<br>,<br>Precise Shot</p>\n<p><strong>Effect:</strong> When using the<br>Aiming Accuracy<br>Feat, a target you damage cannot take the<br>Recover<br>Action until the end of its next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Pinpoint_Accuracy</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit"],"enabled":false,"priority":500,"description":"Pinpoint Accuracy: Old migrated numeric modifier disabled; represented by non-numeric rider/resource metadata.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit"],"conditionSummary":"Old migrated numeric modifier disabled; represented by non-numeric rider/resource metadata."}],"mechanicsMode":"conditional","applicationScope":"rider_effect","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"When using Aiming Accuracy, a damaged target cannot Recover until end of its next turn.","predicateRequirements":[],"metadataPhase":"phase9-feat-implementation-continuation","metadataNotes":"Phase 9 removes false numeric scaffolding and records descriptio