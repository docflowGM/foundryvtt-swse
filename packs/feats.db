{"_id":"e73873cdc77a6451","name":"Powerful Charge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you Charge, you gain an additional +2 bonus on your melee attack roll. If your melee attack hits, you deal additional damage equal to one-half your level.","prerequisite":"Medium or larger size, Base Attack Bonus +1","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["charge","feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> Medium or larger size,<br>Base Attack Bonus<br>+1</p>\n<p><strong>Effect:</strong> When you<br>Charge<br>, you gain an additional +2 bonus on your melee attack roll. If your melee attack hits, you deal additional damage equal to one-half your level.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Powerful_Charge</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":1}],"_source":"canonical-csv"},"executionModel":"PASSIVE","abilityMeta":{"status":"attack_option_phase7_refined","description":"Powerful Charge: exposed through CombatOptionResolver; not applied as a passive sheet modifier.","rules":[{"type":"ATTACK_OPTION","option":"powerfulCharge","label":"Powerful Charge","summary":"When charging with a melee attack, gain +2 attack and add half level to damage on hit.","control":"toggle","requiresAttackType":"melee","requiresCharge":true,"attackModifier":2,"damageModifierFormula":"halfLevel"}],"mechanicsMode":"active","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Exposed as a deliberate combat option or passive roll-context option, not a static actor-sheet modifier.","predicateRequirements":[],"metadataPhase":"phase7-description-reimplementation","metadataNotes":"Phase 7 re-read refreshed descriptions and converted old scaffold bonuses into explicit static/resource/attack-option/rider metadata."},"subType":"STATE","shortSummary":"Gain +2 bonus on your attack roll while Charging, and deal extra damage.","prerequisitesText":"Medium or larger size, Base Attack Bonus +1","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Powerful_Charge","effect":"When you\nCharge\n, you gain an additional +2 bonus on your melee attack roll. If your melee attack hits, you deal additional damage equal to one-half your level."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.powerful_charge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Powerful_Charge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e85f36d48d9c6989","name":"Meat Shield","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever an opponent attacks you while in Cover provided by another character, creature, or Droid, you are treated as being in Cover from attacks by that opponent.","prerequisite":"Point-Blank Shot, Precise Shot, Base Attack Bonus +4","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":22,"tags":["cover_play","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Point-Blank Shot<br>,<br>Precise Shot<br>,<br>Base Attack Bonus<br>+4</p>\n<p><strong>Effect:</strong> Whenever an opponent attacks you while in<br>Cover<br>provided by another character, creature, or Droid, you are treated as being in<br>Cover<br>from attacks by that opponent.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Meat_Shield</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"soft_cover_defense_context","staticSheetPolicy":"defense_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Meat Shield treats you as having cover from an opponent who attacks you while you have cover provided by another character/creature/droid.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"cover_defense_metadata_phase17","description":"Meat Shield treats you as having cover from an opponent who attacks you while you have cover provided by another character/creature/droid.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Meat Shield treats you as having cover from an opponent who attacks you while you have cover provided by another character/creature/droid.","mechanicsMode":"metadata_only","applicationScope":"soft_cover_defense_context","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"defenseRules":[{"type":"GAIN_COVER_FROM_ATTACKER_WHEN_USING_SOFT_COVER","requiresSoftCoverProviderType":["character","creature","droid"],"description":"When an opponent attacks you while you have soft cover from another character/creature/droid, you are treated as in cover from that opponent."}]},"shortSummary":"Gain Cover bonus equal to opponent's Cover bonus.","prerequisitesText":"Point-Blank Shot, Precise Shot, Base Attack Bonus +4","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Meat_Shield","effect":"Whenever an opponent attacks you while in\nCover\nprovided by another character, creature, or Droid, you are treated as being in\nCover\nfrom attacks by that opponent."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.meat_shield","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Meat_Shield","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e896798c6d194345","name":"Fleet-Footed","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you Move both before and after you make an attack using the Running Attack Feat, your Speed is increased by 2 squares until the end of your turn.","prerequisite":"Running Attack","special":"","normalText":"","sourcebook":"Scum and Villainy","page":23,"tags":["feat","general","mobility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Running Attack</p>\n<p><strong>Effect:</strong> If you Move both before and after you make an attack using the<br>Running Attack<br>Feat, your Speed is increased by 2 squares until the end of your turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Fleet-Footed</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"running_attack_movement_context","staticSheetPolicy":"action_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Fleet-Footed: when moving both before and after a Running Attack, speed increases by 2 squares until end of turn.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"movement_metadata_phase16","description":"Fleet-Footed: when moving both before and after a Running Attack, speed increases by 2 squares until end of turn.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Fleet-Footed: when moving both before and after a Running Attack, speed increases by 2 squares until end of turn.","mechanicsMode":"metadata_only","applicationScope":"running_attack_movement_context","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"actionRules":[{"type":"RUNNING_ATTACK_SPEED_BONUS","value":2,"duration":"untilEndOfTurn","requiresMoveBeforeAndAfterAttack":true,"description":"+2 speed until end of turn if you move both before and after an attack using Running Attack."}]},"shortSummary":"+2 Speed when making a Running Attack.","prerequisitesText":"Running Attack","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Fleet-Footed","effect":"If you Move both before and after you make an attack using the\nRunning Attack\nFeat, your Speed is increased by 2 squares until the end of your turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.fleet_footed","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fleet-Footed","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e8e6b74907471ad5","name":"Cornered","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you are Threatened by an opponent and unable to take the Withdraw Action, you gain a +2 bonus on attack rolls against opponents that threaten you.","prerequisite":"None","special":"","normalText":"","sourcebook":"Scum and Villainy","page":21,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> Whenever you are<br>Threatened<br>by an opponent and unable to take the<br>Withdraw<br>Action, you gain a +2 bonus on attack rolls against opponents that threaten you.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Cornered</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Contextual attack bonus when unable to withdraw.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Contextual attack bonus when unable to withdraw.","predicateRequirements":[],"metadataPhase":"phase13-next-feat-implementation-batch","metadataNotes":"Phase 13 converts clear remaining manual/scaffold feats into skill bonuses, attack options, action/resource metadata, or safer non-static rider metadata.","executionModel":"PASSIVE","subType":"RULE","rules":[{"type":"ATTACK_OPTION","id":"cornered","label":"Cornered","control":"passive","requiresContextFlags":["cannotWithdraw"],"attackModifier":2,"summary":"Gain +2 attack when you cannot withdraw from your enemies."}],"implementationStatus":"cornered_attack_option_phase13"},"shortSummary":"When unable to Withdraw, +2 on attacks.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Cornered","effect":"Whenever you are\nThreatened\nby an opponent and unable to take the\nWithdraw\nAction, you gain a +2 bonus on attack rolls against opponents that threaten you."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.cornered","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Cornered","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e9147ce66a783fbb","name":"Starship Designer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can design a Starship from scratch. Doing so takes a minimum of 30 days and a DC 25 Mechanics check, adding 1 to the DC and 1 to the time for every additional 100,000 credits of the design's final cost beyond the first 100,000 credits (even a genius Starship Designer can spend years working out the blueprints for a Star Destroyer). Other characters Trained in the Mechanics skill may use the Aid Another action to assist your Mechanics check; if any assisting character also has the Starship Designer Feat, divide the Starship's cost by the number of characters who have this Feat (including the primary designer) when determining the time required.\n\nWhen making Starship Modifications, you never treat the work as though it were a Nonstandard Modification, even if it normally would be. Additionally, you can make custom modifications to Starships. Each of these modifications has a base cost of 5,000 credits (multiplied by the Starship Size Cost Modifier) and requires a DC 25 Mechanics check. On a failed check, the modification fails; you must spend half again as much time and money to make a second attempt, and you gain a +2 bonus on your Mechanics check for each attempt after the first.\n\nInstallation of a custom modification normally takes one day per 5,000 credits of the final cost. The same system can be customized multiple times, but doing so becomes increasingly difficult and expensive. For every previous custom modification on a given system, increase the DC by 5 and the base cost by 10,000 credits. No system can be customized more than three times. Multiple benefits from successive customizations stack. Typical customizations are described below. The Gamemaster may allow other modifications.\n\n- Add Emplacement: You add 1 unused Emplacement Point to a Starship.\n- Improve Hull: You add a number of Hit Points to a Starship equal to 1/2 its Strength score (rounded down to the nearest multiple of 10).\n- Improve Hyperdrive: You can reengineer a hyperdrive to improve its class by 1 step. The hyperdrive obeys all the restrictions of its new class.\n- Improve Shields: The Shield Rating of the shields is increased by 5.\n- Improve Weapons: You grant one Vehicle Weapon a +1 Equipment bonus on attack rolls.","prerequisite":"Tech Specialist, Trained in Mechanics","special":"","normalText":"","sourcebook":"Starships of the Galaxy","page":30,"tags":["feat","general","skill_pilot","tech","utility","vehicle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Tech Specialist<br>,<br>Trained<br>in<br>Mechanics</p>\n<p><strong>Effect:</strong> You can design a<br>Starship<br>from scratch. Doing so takes a minimum of 30 days and a DC 25<br>Mechanics<br>check, adding 1 to the DC and 1 to the time for every additional 100,000 credits of the design&#x27;s final cost beyond the first 100,000 credits (even a genius Starship Designer can spend years working out the blueprints for a Star Destroyer). Other characters<br>Trained<br>in the<br>Mechanics<br>skill may use the<br>Aid Another<br>action to assist your<br>Mechanics<br>check; if any assisting character also has the Starship Designer Feat, divide the Starship&#x27;s cost by the number of characters who have this Feat (including the primary designer) when determining the time required.<br><br>When making<br>Starship Modifications<br>, you never treat the work as though it were a<br>Nonstandard Modification<br>, even if it normally would be. Additionally, you can make custom modifications to Starships. Each of these modifications has a base cost of 5,000 credits (multiplied by the Starship Size Cost Modifier) and requires a DC 25<br>Mechanics<br>check. On a failed check, the modification fails; you must spend half again as much time and money to make a second attempt, and you gain a +2 bonus on your<br>Mechanics<br>check for each attempt after the first.<br><br>Installation of a custom modification normally takes one day per 5,000 credits of the final cost. The same system can be customized multiple times, but doing so becomes increasingly difficult and expensive. For every previous custom modification on a given system, increase the DC by 5 and the base cost by 10,000 credits. No system can be customized more than three times. Multiple benefits from successive customizations stack. Typical customizations are described below. The Gamemaster may allow other modifications.<br><br>- Add Emplacement: You add 1 unused Emplacement Point to a Starship.<br>- Improve Hull: You add a number of Hit Points to a Starship equal to 1/2 its Strength score (rounded down to the nearest multiple of 10).<br>- Improve Hyperdrive: You can reengineer a hyperdrive to improve its class by 1 step. The hyperdrive obeys all the restrictions of its new class.<br>- Improve Shields: The Shield Rating of the shields is increased by 5.<br>- Improve Weapons: You grant one Vehicle Weapon a +1 Equipment bonus on attack rolls.</p>\n<h3>Additional Starship Design Rules</h3><p>Reference Book:<br>Star Wars Saga Edition Web Enhancements<br>(<br>Jedi Counseling<br>)<br><br>Q:<br>I&#x27;ve run into some issues with the Starship Design rules in<br>Starships of the Galaxy<br>. It seems that you can&#x27;t make any existing Starships using these rules and starting with a Stock Starship. Am I doing something wrong?<br><br>A:<br>Probably not. A vast number of individual Starships have been created over the last few decades since<br>A New Hope<br>came out, and at no point was there a cohesive Starship design system to guide authors of fiction or gaming products. As such, it is effectively impossible to reverse-engineer a design system that covers all these varied examples- or, at least, any such system would be so complex that it wouldn&#x27;t be easy to use in a game.<br><br>Given that, we designed the system from the point of the typical hero who might be interested in modifying an existing Starship or scratch-building a new one. This hero doesn&#x27;t have the benefit of vast numbers of the best engineers and test pilots in the galaxy (like at the Corellian Engineering Corporation), nor does this hero have an entire star system dedicated to the building of city-sized Starships with mass-production facilities to match (like at Kuat Drive Yards).<br><br>This hero, instead, is relegated to building &quot;A typical new Starship from a typical production facility,&quot; as noted at the bottom of Table 3–8:<br>Stock Ship Types<br>. The Stock Starships are designed to reflect that, making it possible to make something decent and functional, but not something that would easily outshine the big name starships.<br><br>For example, a hero could build a decent light freighter, something comparable to a<br>YT-1300<br>in stats and price.<br><br>The biggest difference? The<br>YT-1300<br>would have a lot of extra<br>Emplacement Points<br>left over- and that&#x27;s precisely what the Corellian Engineering Corporation is known for. Think about it: if any yahoo on a backwater planet could build a freighter that&#x27;s just as good, why would the YT-series freighters sell so well throughout the galaxy?<br><br>Since most heroes won&#x27;t ever control a galaxy-spanning corporate giant and be able to use these resources, it seems a little silly to spend page space exploring the ins and outs of galactic-scale mass production. Similarly, we might give broad outlines of supply and demand by listing a planet&#x27;s major exports and imports, but we won&#x27;t be creating rules that account for macroeconomic cycles, unemployment, inflation, and so forth. (Let&#x27;s face it: Most of us are just here to shoot Stormtroopers.)<br><br>Now, if you as the GM want to build Starships beyond what the<br>Stock Starships<br>can manage, there&#x27;s really not a reason for you to hamstring yourself with those rules: just write up stats that seem like a good challenge for your players, using similar Starships as benchmarks for things like price, appropriate game statistics for that type of ship, and so forth.<br><br>And if you and your players really want more comprehensive rules that go beyond those in the book, by all means do so! You might look at<br>Gear Templates<br>to get some inspiration for coming up with appropriate special benefits and restrictions for different manufacturers.<br><br>Alternatively, you might allow manufacturers to come up with &quot;Proprietary&quot; Stock Starships that are better than the typical ones listed in the book. For example, Kuat Drive Yards might have a really good &quot;Stock Star Destroyer&quot; and Corellian Engineering Corporation might have an outstanding &quot;Stock YT-Series,&quot; and they use these as the baseline for producing several similar Starship designs.<br><br>Q:<br>When building a new design from a Stock Starship, can you remove or replace existing systems that come with the stock ship? For example, could I take those high-performance engines off a stock interceptor and use the cash to buy other systems?<br><br>A:<br>You can, but it&#x27;s not very efficient. You get only 1/4 the listed value of any system you remove from a Starship, even a Stock Starship.<br><br>Stock Starships usually get their starting systems at a substantial discount because they are so well integrated into the baseline design. Removing them requires a lot of inefficient workarounds, resulting in a lower price comparable to selling a used Starship component.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Starship_Designer</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"manual_punted","applicationScope":"gm_player_starship_design","staticSheetPolicy":"manual_punted","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Starship Designer is punted to GM/player handling; no automatic implementation should be attempted in feat metadata.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"punted_to_gm_player","description":"Starship Designer is punted to GM/player handling; no automatic implementation should be attempted in feat metadata.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Starship Designer is punted to GM/player handling; no automatic implementation should be attempted in feat metadata.","mechanicsMode":"metadata_only","applicationScope":"gm_player_starship_design","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"puntedTo":"GM/player"},"shortSummary":"You are trained to design (and redesign) Starships.","prerequisitesText":"Tech Specialist, Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy","Star Wars Saga Edition Web Enhancements (Jedi Counseling)"],"sourceUrl":"https://swse.fandom.com/wiki/Starship_Designer","effect":"You can design a\nStarship\nfrom scratch. Doing so takes a minimum of 30 days and a DC 25\nMechanics\ncheck, adding 1 to the DC and 1 to the time for every additional 100,000 credits of the design's final cost beyond the first 100,000 credits (even a genius Starship Designer can spend years working out the blueprints for a Star Destroyer). Other characters\nTrained\nin the\nMechanics\nskill may use the\nAid Another\naction to assist your\nMechanics\ncheck; if any assisting character also has the Starship Designer Feat, divide the Starship's cost by the number of characters who have this Feat (including the primary designer) when determining the time required.\n\nWhen making\nStarship Modifications\n, you never treat the work as though it were a\nNonstandard Modification\n, even if it normally would be. Additionally, you can make custom modifications to Starships. Each of these modifications has a base cost of 5,000 credits (multiplied by the Starship Size Cost Modifier) and requires a DC 25\nMechanics\ncheck. On a failed check, the modification fails; you must spend half again as much time and money to make a second attempt, and you gain a +2 bonus on your\nMechanics\ncheck for each attempt after the first.\n\nInstallation of a custom modification normally takes one day per 5,000 credits of the final cost. The same system can be customized multiple times, but doing so becomes increasingly difficult and expensive. For every previous custom modification on a given system, increase the DC by 5 and the base cost by 10,000 credits. No system can be customized more than three times. Multiple benefits from successive customizations stack. Typical customizations are described below. The Gamemaster may allow other modifications.\n\n- Add Emplacement: You add 1 unused Emplacement Point to a Starship.\n- Improve Hull: You add a number of Hit Points to a Starship equal to 1/2 its Strength score (rounded down to the nearest multiple of 10).\n- Improve Hyperdrive: You can reengineer a hyperdrive to improve its class by 1 step. The hyperdrive obeys all the restrictions of its new class.\n- Improve Shields: The Shield Rating of the shields is increased by 5.\n- Improve Weapons: You grant one Vehicle Weapon a +1 Equipment bonus on attack rolls."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.starship_designer","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Starship_Designer","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e95252c02d2ae129","name":"Sensor Link","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a Swift Action, you can broadcast the input from your audio, visual, and special sensors to a Droid ally, Comlink, communications system, or holographic receiver within 24 squares.\n\nThat ally is aware of anything you are aware of, and can use the Aid Another Action to aid on your Perception checks even if you do not have line of sight to one another. If both you and your ally have Sensor Link, you share information simultaneously, granting a +2 bonus to Perception checks.","prerequisite":"Droid or Cyborg Hybrid","special":"Cyborg Hybrids with built-in Subcutaneous Comlink can also take this Feat.","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":24,"tags":["ally_support","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Droid<br>or<br>Cyborg Hybrid</p>\n<p><strong>Effect:</strong> As a<br>Swift Action<br>, you can broadcast the input from your audio, visual, and special sensors to a Droid ally,<br>Comlink<br>, communications system, or holographic receiver within 24 squares.<br><br>That ally is aware of anything you are aware of, and can use the<br>Aid Another<br>Action to aid on your<br>Perception<br>checks even if you do not have line of sight to one another. If both you and your ally have Sensor Link, you share information simultaneously, granting a +2 bonus to<br>Perception<br>checks.</p>\n<p><strong>Special:</strong> Cyborg Hybrids<br>with built-in<br>Subcutaneous Comlink<br>can also take this Feat.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Sensor_Link</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"active","applicationScope":"nearby_ally_or_positioning_context","staticSheetPolicy":"manual_or_table_context","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Sensor Link broadcasts sensor input to an ally within 24 squares; mutual Sensor Link grants +2 Perception and otherwise enables Aid Another without line of sight.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"table_context_metadata_phase17","description":"Sensor Link broadcasts sensor input to an ally within 24 squares; mutual Sensor Link grants +2 Perception and otherwise enables Aid Another without line of sight.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Sensor Link broadcasts sensor input to an ally within 24 squares; mutual Sensor Link grants +2 Perception and otherwise enables Aid Another without line of sight.","mechanicsMode":"metadata_only","applicationScope":"nearby_ally_or_positioning_context","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"actionRules":[{"type":"SENSOR_SHARE_SWIFT_ACTION","rangeSquares":24,"allowsAidAnotherPerceptionWithoutLos":true,"manualResolution":true,"description":"Sensor Link broadcasts sensor input to an ally within 24 squares; mutual Sensor Link grants +2 Perception and otherwise enables Aid Another without line of sight."}]},"shortSummary":"Share sensor data instantly with an ally.","prerequisitesText":"Droid or Cyborg Hybrid","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Sensor_Link","effect":"As a\nSwift Action\n, you can broadcast the input from your audio, visual, and special sensors to a Droid ally,\nComlink\n, communications system, or holographic receiver within 24 squares.\n\nThat ally is aware of anything you are aware of, and can use the\nAid Another\nAction to aid on your\nPerception\nchecks even if you do not have line of sight to one another. If both you and your ally have Sensor Link, you share information simultaneously, granting a +2 bonus to\nPerception\nchecks."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.sensor_link","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Sensor_Link","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"e97cc5c5128a55ce","name":"Thick Skin","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a +2 Species bonus to your Fortitude Defense.","prerequisite":"Trandoshan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-trandoshan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trandoshan</p>\n<p><strong>Effect:</strong> You gain a +2<br>Species<br>bonus to your<br>Fortitude Defense<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Thick_Skin</em></p>","executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.fortitude","type":"untyped","value":2,"enabled":true,"priority":500,"description":"Migrated from AE flags.swse defense_bonus (Thick Skin)","mechanicsMode":"passive","applicationScope":"static_actor","staticSheetPolicy":"include","requiresRuntimeContext":false,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"Always-on species bonus to Fortitude Defense."}],"mechanicsMode":"passive","applicationScope":"static_actor","staticSheetPolicy":"include","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Always-on species bonus to Fortitude Defense.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Gain a +2 Species bonus to your Fortitude Defense.","sourceUrl":"https://swse.fandom.com/wiki/Thick_Skin","rawImport":{"name":"Thick Skin","url":"https://swse.fandom.com/wiki/Thick_Skin","pageTitle":"Thick_Skin","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\thick_skin.html","referenceBooks":[],"prerequisitesText":"Trandoshan","prerequisites":["Trandoshan"],"effect":"You gain a +2\nSpecies\nbonus to your\nFortitude Defense\n.","benefit":"","normal":"","special":"","indexPrerequisites":"Trandoshan","indexBenefit":"Gain a +2 Species bonus to your Fortitude Defense .","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYour thick hide protects you from damage and fends off toxins and other hazards.\n\nPrerequisite:\nTrandoshan\n\nEffect:\nYou gain a +2\nSpecies\nbonus to your\nFortitude Defense\n."},"prerequisitesText":"Trandoshan","effect":"You gain a +2\nSpecies\nbonus to your\nFortitude Defense\n."},"effects":[{"_id":"b3b93b78-9b9c-46c8-9f9b-dde02270f63c","name":"Thick Skin","icon":"icons/svg/upgrade.svg","changes":[],"disabled":true,"duration":{},"flags":{"swse":{"source":"feat","featName":"Thick Skin","effectType":"defense_bonus","flagType":"Thick Skin","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.thick_skin"}}}
{"_id":"e99d9284a73cf505","name":"Conditioned","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Endurance checks and may reroll a failed Endurance check once per encounter.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":24,"tags":["feat","general"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":false,"priority":500,"description":"Conditioned: Implemented by SkillFeatResolver as a skill bonus plus once-per-encounter failed-check reroll.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["turn.once-per-round"],"conditionSummary":"Implemented by SkillFeatResolver as a skill bonus plus once-per-encounter failed-check reroll.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"passive","applicationScope":"skill_roll_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Conditioned now uses skill roll metadata: +2 Endurance and once-per-encounter failed-check reroll.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","skillCheckBonuses":[{"id":"conditioned-endurance-bonus","skillKey":"endurance","value":2,"type":"untyped","description":"Conditioned: +2 on Endurance checks."}],"skillRerolls":[{"id":"conditioned-endurance-reroll","skillKey":"endurance","outcome":"keepSecond","oncePer":"encounter","trigger":"failedSkillCheck","label":"Conditioned","description":"Conditioned: reroll one failed Endurance check once per encounter; keep the reroll."}],"status":"skill_bonus_reroll_phase10","description":"Conditioned now uses skill roll metadata: +2 Endurance and once-per-encounter failed-check reroll."},"shortSummary":"You gain a +2 bonus on Endurance checks and may reroll a failed Endurance check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["turn.once-per-round"]}}}
{"_id":"e9d1e9099a3e4ecc","name":"Powerful Rage","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +4 bonus to Strength checks and Strength -based Skill Checks when Raging.","prerequisite":"Rage Species Trait","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":35,"tags":["ability_strength","conditional_skill_bonus","execution_mapped_phase8","execution_mapped_phase9","feat","general","offense_melee","rage","resource_spend"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Rage Species Trait</p>\n<p><strong>Effect:</strong> You gain a +4 bonus to<br>Strength<br>checks and<br>Strength<br>-based<br>Skill Checks<br>when Raging.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Powerful_Rage</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"rage_rule_phase9","description":"Powerful Rage: +4 on Strength checks and Strength-based skill checks while raging.","skillCheckBonuses":[{"id":"powerful-rage-strength-skills","skillKeys":["climb","jump","swim"],"value":4,"type":"untyped","requiresContextFlags":["raging"],"description":"Powerful Rage: +4 while raging."}],"rules":[{"type":"RAGE_STRENGTH_SKILL_BONUS","value":4,"skillKeys":["climb","jump","swim"],"description":"Gain +4 to Strength checks and Strength-based skill checks while raging."}],"mechanicsMode":"conditional","applicationScope":"rage_context","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Only applies while the actor is raging or using rage-specific rules.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Gain a +4 bonus on Strength checks and Strength -based Skill Checks.","prerequisitesText":"Rage Species Trait","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Powerful_Rage","effect":"You gain a +4 bonus to\nStrength\nchecks and\nStrength\n-based\nSkill Checks\nwhen Raging."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.powerful_rage","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Powerful_Rage","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ea684defcd3222ca","name":"Dual Weapon Mastery III","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you attack with two weapons, or with both ends of a double weapon as part of a Full Attack Action, you take no penalty on your attack rolls. You only gain this benefit if you are wielding a weapon with which you are proficient.","prerequisite":"Dexterity 17, Dual Weapon Mastery I, Dual Weapon Mastery II, Base Attack Bonus +11","special":"","normalText":"If you use a Full Attack Action to make more than one attack on your turn, you take a -10 penalty on all attack rolls for the round.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["action_economy","dual_wield","feat","general","offense_melee"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Dexterity<br>17,<br>Dual Weapon Mastery I<br>,<br>Dual Weapon Mastery II<br>,<br>Base Attack Bonus<br>+11</p>\n<p><strong>Effect:</strong> When you attack with two weapons, or with both ends of a double weapon as part of a<br>Full Attack<br>Action, you take no penalty on your attack rolls. You only gain this benefit if you are wielding a weapon with which you are proficient.</p>\n<p><strong>Normal:</strong> If you use a<br>Full Attack<br>Action to make more than one attack on your turn, you take a -10 penalty on all attack rolls for the round.</p>\n<h3>Additional Dual Weapon Mastery III Effects</h3><p>Reference Book:<br>Star Wars Saga Edition Starships of the Galaxy<br><br>Vehicle Weapons<br>cannot be used in one hand, so this Feat has no effect on them.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Dual_Weapon_Mastery_III</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":17},{"type":"bab","min":11}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Two-weapon full-attack penalty metadata; consumed once multiattack UI resolves selected attack mode.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"multiattack_penalty_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Two-weapon full-attack penalty metadata; consumed once multiattack UI resolves selected attack mode.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"multiattack_metadata_phase14","multiAttackRules":[{"type":"TWO_WEAPON_FULL_ATTACK_PENALTY","penalty":0,"description":"Penalty for attacking with two weapons becomes 0."}]},"shortSummary":"Take no penalty on attacks when attacking with two weapons, or both ends of a double weapon.","prerequisitesText":"Dexterity 17, Dual Weapon Mastery I, Dual Weapon Mastery II, Base Attack Bonus +11","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Dual_Weapon_Mastery_III","effect":"When you attack with two weapons, or with both ends of a double weapon as part of a\nFull Attack\nAction, you take no penalty on your attack rolls. You only gain this benefit if you are wielding a weapon with which you are proficient."},"effects":[{"_id":"8937b074-f7ef-40fa-889c-85578fc3e023","name":"Dual Weapon Mastery III","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Dual Weapon Mastery III","effectType":"passive_effect","flagType":"Dual Weapon Mastery III"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.dual_weapon_mastery_iii","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Dual_Weapon_Mastery_III","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"eaf7079b977d60b7","name":"Darkness Dweller","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Impose a penalty to Stealth checks made when close to you.","prerequisite":"Sullustan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","skill_stealth","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-sullustan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Sullustan</p>\n<p><strong>Effect:</strong> Any enemy that makes a<br>Stealth<br>check within 10 squares of you takes a -2 penalty to the check. This penalty does not stack with the same penalty imposed by other characters with this Feat.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Darkness_Dweller</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"proximity_stealth_penalty_aura","staticSheetPolicy":"manual_or_table_context","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Darkness Dweller: nearby enemies take a Stealth penalty; proximity is table/token context and not a static skill modifier.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"aura_metadata_phase16","description":"Darkness Dweller: nearby enemies take a Stealth penalty; proximity is table/token context and not a static skill modifier.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Darkness Dweller: nearby enemies take a Stealth penalty; proximity is table/token context and not a static skill modifier.","mechanicsMode":"metadata_only","applicationScope":"proximity_stealth_penalty_aura","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"riderRules":[{"type":"PROXIMITY_SKILL_PENALTY_AURA","skillKey":"stealth","value":-5,"description":"Impose a penalty to Stealth checks made close to you; proximity remains scene/table context."}]},"shortSummary":"Impose a penalty to Stealth checks made when close to you.","sourceUrl":"https://swse.fandom.com/wiki/Darkness_Dweller","rawImport":{"name":"Darkness Dweller","url":"https://swse.fandom.com/wiki/Darkness_Dweller","pageTitle":"Darkness_Dweller","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\darkness_dweller.html","referenceBooks":[],"prerequisitesText":"Sullustan","prerequisites":["Sullustan"],"effect":"Any enemy that makes a\nStealth\ncheck within 10 squares of you takes a -2 penalty to the check. This penalty does not stack with the same penalty imposed by other characters with this Feat.","benefit":"","normal":"","special":"","indexPrerequisites":"Sullustan","indexBenefit":"Impose a penalty to Stealth checks made when close to you.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou have lived underground for so long that you can spot sneaky enemies easily and make it hard for them to slip past your allies.\n\nPrerequisite:\nSullustan\n\nEffect:\nAny enemy that makes a\nStealth\ncheck within 10 squares of you takes a -2 penalty to the check. This penalty does not stack with the same penalty imposed by other characters with this Feat."},"prerequisitesText":"Sullustan","effect":"Any enemy that makes a\nStealth\ncheck within 10 squares of you takes a -2 penalty to the check. This penalty does not stack with the same penalty imposed by other characters with this Feat."},"effects":[{"_id":"1b28fe0a-2045-4172-866e-4a81cd6a662d","name":"Darkness Dweller","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Darkness Dweller","effectType":"passive_effect","flagType":"Darkness Dweller"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.darkness_dweller"}}}
{"_id":"eb33f5e4b5f6318c","name":"Surgical Precision","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Treat Injury checks and may reroll a failed check once per encounter.","prerequisite":"Trained in Treat Injury","special":"","normalText":"","sourcebook":"Galaxy at War","page":27,"tags":["feat","general","healing","skill_treat_injury","support"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":2,"type":"untyped","predicates":["turn.once-per-round"],"enabled":false,"priority":500,"description":"Surgical Precision: Implemented by SkillFeatResolver as a skill bonus plus once-per-encounter failed-check reroll.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["turn.once-per-round"],"conditionSummary":"Implemented by SkillFeatResolver as a skill bonus plus once-per-encounter failed-check reroll.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"passive","applicationScope":"skill_roll_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Surgical Precision now uses skill roll metadata: +2 Treat Injury and once-per-encounter failed-check reroll.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","skillCheckBonuses":[{"id":"surgical-precision-treatInjury-bonus","skillKey":"treatInjury","value":2,"type":"untyped","description":"Surgical Precision: +2 on Treat Injury checks."}],"skillRerolls":[{"id":"surgical-precision-treatInjury-reroll","skillKey":"treatInjury","outcome":"keepSecond","oncePer":"encounter","trigger":"failedSkillCheck","label":"Surgical Precision","description":"Surgical Precision: reroll one failed Treat Injury check once per encounter; keep the reroll."}],"status":"skill_bonus_reroll_phase10","description":"Surgical Precision now uses skill roll metadata: +2 Treat Injury and once-per-encounter failed-check reroll."},"shortSummary":"You gain a +2 bonus on Treat Injury checks and may reroll a failed check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["turn.once-per-round"]}}}
{"_id":"ebe730776cd3e310","name":"Fatal Hit","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When your attack drops a target to 0 Hit Points, you may choose to automatically kill that enemy even if the damage does not exceed the target's Damage Threshold. In addition, you can perform the Coup de Grace Action as a Standard Action.","prerequisite":"Strength 13, Dexterity 13","special":"","normalText":"A creature that drops below 0 Hit Points becomes Unconscious if the damage dealt does not exceed its Damage Threshold. Performing a Coup de Grace is a Full-Round Action.","sourcebook":"Legacy Era Campaign Guide","page":18,"tags":["ally_support","durability","feat","general","hit_points","standard_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Strength<br>13,<br>Dexterity<br>13</p>\n<p><strong>Effect:</strong> When your attack drops a target to 0 Hit Points, you may choose to automatically kill that enemy even if the damage does not exceed the target&#x27;s<br>Damage Threshold<br>. In addition, you can perform the<br>Coup de Grace<br>Action as a<br>Standard Action<br>.</p>\n<p><strong>Normal:</strong> A creature that drops below 0 Hit Points becomes<br>Unconscious<br>if the damage dealt does not exceed its<br>Damage Threshold<br>. Performing a<br>Coup de Grace<br>is a<br>Full-Round Action<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Fatal_Hit</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"str","min":13},{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Automatically kill enemies reduced to 0 HP and make coup de grace as standard action.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"action_or_reaction_hook","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Automatically kill enemies reduced to 0 HP and make coup de grace as standard action.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"action_metadata_phase14","actionRules":[{"type":"AUTO_KILL_ZERO_HP_TARGET"},{"type":"COUP_DE_GRACE_AS_STANDARD_ACTION"}]},"shortSummary":"You automatically kill an enemy that you reduce to 0 Hit Points, and you can perform a Coup de Grace as a Standard Action.","prerequisitesText":"Strength 13, Dexterity 13","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Fatal_Hit","effect":"When your attack drops a target to 0 Hit Points, you may choose to automatically kill that enemy even if the damage does not exceed the target's\nDamage Threshold\n. In addition, you can perform the\nCoup de Grace\nAction as a\nStandard Action\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.fatal_hit","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fatal_Hit","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ec8b6bb889f65dea","name":"Imperceptible Liar","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Increase the die type when adding Force Points to a Deception check.","prerequisite":"Twi'lek","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","force_point_spend","racial","resource_spend","skill_deception","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-twi-lek"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Twi&#x27;lek</p>\n<p><strong>Effect:</strong> Whenever you spend a<br>Force Point<br>to add to a<br>Deception<br>check, increase the die type by two steps (From d6 to d10, or from d8 to d12).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Imperceptible_Liar</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"deception_force_point_die_context","staticSheetPolicy":"resource_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Imperceptible Liar: increase the Force Point die type when adding Force Points to Deception checks.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"force_point_skill_die_metadata_phase16","description":"Imperceptible Liar: increase the Force Point die type when adding Force Points to Deception checks.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Imperceptible Liar: increase the Force Point die type when adding Force Points to Deception checks.","mechanicsMode":"metadata_only","applicationScope":"deception_force_point_die_context","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"resourceRules":{"forcePoints":[{"type":"SKILL_FORCE_POINT_DIE_SIZE","skillKey":"deception","dieSize":8,"description":"Use an increased Force Point die when adding a Force Point to a Deception check."}]}},"shortSummary":"Increase the die type when adding Force Points to a Deception check.","sourceUrl":"https://swse.fandom.com/wiki/Imperceptible_Liar","rawImport":{"name":"Imperceptible Liar","url":"https://swse.fandom.com/wiki/Imperceptible_Liar","pageTitle":"Imperceptible_Liar","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\imperceptible_liar.html","referenceBooks":[],"prerequisitesText":"Twi'lek","prerequisites":["Twi'lek"],"effect":"Whenever you spend a\nForce Point\nto add to a\nDeception\ncheck, increase the die type by two steps (From d6 to d10, or from d8 to d12).","benefit":"","normal":"","special":"","indexPrerequisites":"Twi'lek","indexBenefit":"Increase the die type when adding Force Points to a Deception check.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou have worked hard to eliminate your behavioral tells, making it almost impossible to discern when you are lying.\n\nPrerequisite:\nTwi'lek\n\nEffect:\nWhenever you spend a\nForce Point\nto add to a\nDeception\ncheck, increase the die type by two steps (From d6 to d10, or from d8 to d12)."},"prerequisitesText":"Twi'lek","effect":"Whenever you spend a\nForce Point\nto add to a\nDeception\ncheck, increase the die type by two steps (From d6 to d10, or from d8 to d12)."},"effects":[{"_id":"c7c4131d-2bcf-47cc-b358-46adefddbda8","name":"Imperceptible Liar","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Imperceptible Liar","effectType":"special","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.imperceptible_liar"}}}
{"_id":"ecc2471ac96ec2d4","name":"Weapon Proficiency","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Choose one Weapon Group. You are proficient with all weapons of the selected group. Weapon Groups include the following:\n\n- Simple Weapons (includes Simple Weapons (Melee), Simple Weapons (Ranged), and Grenades)\n- Pistols\n- Rifles\n- Lightsabers\n- Heavy Weapons (includes both Heavy Weapons and Vehicle Weapons)\n- Advanced Melee Weapons","prerequisite":"None","special":"You can gain this Feat multiple times. Each time you take the Feat, it applies to a different Weapon Group. You cannot take Exotic Weapons as a weapon group; instead you must select the Exotic Weapon Proficiency Feat to gain proficiency with a specific Exotic Weapon.","normalText":"If you wield a weapon with which you are not proficient, you take a -5 penalty to your attack rolls.","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["build_enabler","feat","general","offense","weapon_access","choice_required","immediate_choice","weapon_choice","repeatable_choice","choice_source_fixed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> Choose one Weapon Group. You are proficient with all weapons of the selected group. Weapon Groups include the following:<br><br>- Simple Weapons (includes Simple Weapons (Melee) , Simple Weapons (Ranged) , and Grenades )<br>- Pistols<br>- Rifles<br>- Lightsabers<br>- Heavy Weapons (includes both Heavy Weapons and Vehicle Weapons )<br>- Advanced Melee Weapons</p>\n<p><strong>Normal:</strong> If you wield a weapon with which you are not proficient, you take a -5 penalty to your attack rolls.</p>\n<p><strong>Special:</strong> You can gain this Feat multiple times. Each time you take the Feat, it applies to a different Weapon Group. You cannot take<br>Exotic Weapons<br>as a weapon group; instead you must select the<br>Exotic Weapon Proficiency<br>Feat to gain proficiency with a specific Exotic Weapon.</p>\n<h3>Additional Weapon Proficiency</h3><p>Reference Book:<br>Star Wars Saga Edition Knights of the Old Republic Campaign Guide<br><br>Combined Feat<br>(<br>Quick Draw<br>):<br>You can draw and ignite your<br>Lightsaber<br>as a single<br>Swift Action<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Weapon_Proficiency</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Weapon Proficiency","mechanicsMode":"grant_unlock","applicationScope":"progression_or_proficiency_grant","staticSheetPolicy":"not_a_modifier","requiresRuntimeContext":false,"requiresSelectedChoice":true,"predicateRequirements":[],"conditionSummary":"Name and metadata indicate a grant/unlock/proficiency rather than a numeric passive modifier."}],"mechanicsMode":"grant_unlock","applicationScope":"progression_or_proficiency_grant","staticSheetPolicy":"not_a_modifier","requiresRuntimeContext":false,"requiresSelectedChoice":true,"conditionSummary":"Name and metadata indicate a grant/unlock/proficiency rather than a numeric passive modifier.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"choiceMeta":{"resolution":"immediate","required":true,"status":"tagged_for_later_dialog_backfill","choiceKind":"weapon_proficiency","repeatable":true,"optionRegistry":"data/feat-choice-options.json#weapon_proficiency","storagePath":"flags.swse.choices.weaponProficiency","notes":"Single grouped feat. Dialog should show weapon groups; choosing exotic opens melee/ranged and then a specific exotic weapon.","choiceSource":"fixed","provides":"weapon_proficiency","resultShape":"weapon_group_or_exotic_weapon"},"shortSummary":"Ignore -5 penalty on attack rolls with weapons of a particular type.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Weapon_Proficiency","effect":"Choose one Weapon Group. You are proficient with all weapons of the selected group. Weapon Groups include the following:\n\n- Simple Weapons (includes Simple Weapons (Melee) , Simple Weapons (Ranged) , and Grenades )\n- Pistols\n- Rifles\n- Lightsabers\n- Heavy Weapons (includes both Heavy Weapons and Vehicle Weapons )\n- Advanced Melee Weapons"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.weapon_proficiency","requiresImmediateChoice":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Weapon_Proficiency","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"eccb2b4dbdbfa324","name":"Bone Crusher","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you deal damage to a Grappled opponent, the opponent also moves -1 step along the Condition Track.","prerequisite":"Crush, Pin","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":15,"tags":["condition_track","control","feat","general","grapple","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Crush<br>,<br>Pin</p>\n<p><strong>Effect:</strong> When you deal damage to a<br>Grappled<br>opponent, the opponent also moves -1 step along the<br>Condition Track<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Bone_Crusher</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Condition-track rider when damaging a grappled opponent.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"condition_track_rider","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Condition-track rider when damaging a grappled opponent.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"condition_track_rider_metadata_phase14","riderRules":[{"type":"MOVE_GRAPPLED_TARGET_CT_ON_DAMAGE","steps":-1,"description":"When damaging a grappled opponent, move it -1 step on the Condition Track."}]},"shortSummary":"Move damaged Grappled opponent -1 step on the Condition Track.","prerequisitesText":"Crush, Pin","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Bone_Crusher","effect":"When you deal damage to a\nGrappled\nopponent, the opponent also moves -1 step along the\nCondition Track\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.bone_crusher","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Bone_Crusher","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"edd8bb64c18d9a8a","name":"Clawed Subspecies","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Deal damage with sharp claws on Unarmed attacks.","prerequisite":"Quarren","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","feat","offense_melee","racial","species","species_opportunity","species_rule","unarmed"],"bonus_feat_for":["species-quarren"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Quarren</p>\n<p><strong>Effect:</strong> You have Natural Weapons in the form of claws. When you make an<br>Unarmed Attack<br>, you can use your claws, dealing 1d6 points of Slashing damage with that attack instead of normal<br>Unarmed<br>damage. You are always considered armed with your Natural Weapons.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Clawed_Subspecies</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_hook","description":"Clawed Subspecies: natural claw damage on unarmed attacks. Damage amount is exposed as a rule hook for unarmed/natural-weapon consumers.","rules":[{"type":"NATURAL_WEAPON_UNLOCK","naturalWeapon":"claws","attackFamily":"unarmed","description":"Deal damage with sharp claws on Unarmed attacks.","displayAsCondition":true,"displayLabel":"Clawed Subspecies","displayNote":"Claw natural weapon available for unarmed attacks."}],"mechanicsMode":"passive","applicationScope":"rule_hook","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Implemented by a rule hook; exact static-sheet behavior depends on the consuming engine.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Deal damage with sharp claws on Unarmed attacks.","sourceUrl":"https://swse.fandom.com/wiki/Clawed_Subspecies","rawImport":{"name":"Clawed Subspecies","url":"https://swse.fandom.com/wiki/Clawed_Subspecies","pageTitle":"Clawed_Subspecies","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\clawed_subspecies.html","referenceBooks":[],"prerequisitesText":"Quarren","prerequisites":["Quarren"],"effect":"You have Natural Weapons in the form of claws. When you make an\nUnarmed Attack\n, you can use your claws, dealing 1d6 points of Slashing damage with that attack instead of normal\nUnarmed\ndamage. You are always considered armed with your Natural Weapons.","benefit":"","normal":"","special":"","indexPrerequisites":"Quarren","indexBenefit":"Deal damage with sharp claws on Unarmed attacks.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou come from a\nQuarren\nsubspecies that has sharp claws at the tips of its fingers.\n\nPrerequisite:\nQuarren\n\nEffect:\nYou have Natural Weapons in the form of claws. When you make an\nUnarmed Attack\n, you can use your claws, dealing 1d6 points of Slashing damage with that attack instead of normal\nUnarmed\ndamage. You are always considered armed with your Natural Weapons."},"prerequisitesText":"Quarren","effect":"You have Natural Weapons in the form of claws. When you make an\nUnarmed Attack\n, you can use your claws, dealing 1d6 points of Slashing damage with that attack instead of normal\nUnarmed\ndamage. You are always considered armed with your Natural Weapons."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.clawed_subspecies"}}}
{"_id":"ef64dc738a6afeeb","name":"Skill Challenge: Recovery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Treat a Skill Challenge as if it had the Recovery effect.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":26,"tags":["cover_play","defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Treat a Skill Challenge as if it had the Recovery effect."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"manual_punted","applicationScope":"skill_challenge_table_context","staticSheetPolicy":"manual_punted","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Skill Challenge: Recovery treats a Skill Challenge as having the Recovery effect; skill challenge recovery structure remains GM/table-managed.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"punted_to_skill_challenge_table_resolution","description":"Skill Challenge: Recovery treats a Skill Challenge as having the Recovery effect; skill challenge recovery structure remains GM/table-managed.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Skill Challenge: Recovery treats a Skill Challenge as having the Recovery effect; skill challenge recovery structure remains GM/table-managed.","mechanicsMode":"metadata_only","applicationScope":"skill_challenge_table_context","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"skillChallen