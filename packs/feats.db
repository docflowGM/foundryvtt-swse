{"_id":"adc9cac4d22b3090","name":"Assured Attack","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you deal damage to a target with an attack and you roll multiple damage dice, you can reroll the lowest damage die but must keep the second result, even if it is worse.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":23,"tags":["feat","general","offense","reroll"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> Whenever you deal damage to a target with an attack and you roll multiple damage dice, you can reroll the lowest damage die but must keep the second result, even if it is worse.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Assured_Attack</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"damage_reroll_phase8","description":"Assured Attack: reroll the lowest damage die on successful attack.","damageRerolls":[{"id":"assured-attack","type":"DAMAGE_DIE_REROLL","trigger":"successfulAttack","target":"lowestDie","outcome":"keepBetter","description":"Assured Attack: reroll the lowest damage die when making a successful attack."}],"mechanicsMode":"conditional","applicationScope":"reroll_or_resource_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rerolls/resources are not static sheet modifiers and require a check/encounter/resource context.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Reroll the lowest damage die when making a successful attack.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Assured_Attack","effect":"Whenever you deal damage to a target with an attack and you roll multiple damage dice, you can reroll the lowest damage die but must keep the second result, even if it is worse."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.assured_attack","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Assured_Attack","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ae4dece84c32c3ac","name":"Droidcraft","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use the Repair Droid aspect of the Mechanics skill in 10 minutes.","prerequisite":"Trained in Mechanics","special":"","normalText":"Using Repair Droid typically takes 1 hour.","sourcebook":"Clone Wars Campaign Guide","page":21,"tags":["feat","general","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Mechanics</p>\n<p><strong>Effect:</strong> You can use the<br>Repair Droid<br>aspect of the<br>Mechanics<br>skill in 10 minutes.</p>\n<p><strong>Normal:</strong> Using<br>Repair Droid<br>typically takes 1 hour.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Droidcraft</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"745a5686d6f21e8c"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Droidcraft: No roll bonus; represented as Repair Droid skill-use time override.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"No roll bonus; represented as Repair Droid skill-use time override."}],"mechanicsMode":"conditional","applicationScope":"mechanics_repair_droid_context","staticSheetPolicy":"skill_use_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Repair Droid can be completed in 10 minutes instead of 1 hour.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"skill_use_rule_phase11","description":"Repair Droid can be completed in 10 minutes instead of 1 hour.","skillUseRules":[{"type":"SKILL_USE_TIME_OVERRIDE","skillKey":"mechanics","applications":["Repair Droid"],"duration":"10 minutes","description":"Use Repair Droid in 10 minutes instead of 1 hour."}]},"shortSummary":"Repair a Droid in 10 minutes instead of 1 hour.","prerequisitesText":"Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Droidcraft","effect":"You can use the\nRepair Droid\naspect of the\nMechanics\nskill in 10 minutes."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.droidcraft","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Droidcraft","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"ae5c34d352d6dff7","name":"Intuitive Initiative","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You may reroll your Initiative check and take the better result. You must keep the new result even if it is worse.","prerequisite":"Trained in Use the Force","special":"","normalText":"","sourcebook":"Jedi Academy Training Manual","page":31,"tags":["feat","force","skill_initiative","skill_synergy"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Initiative reroll, keeping the second result per current benefit text.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"skill_roll_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Initiative reroll, keeping the second result per current benefit text.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"skill_reroll_phase14","skillRerolls":[{"id":"intuitiveInitiative.initiative","skillKey":"initiative","outcome":"keepSecond","description":"Reroll Initiative; current source text says the new result must be kept."}]},"shortSummary":"You may reroll your Initiative check and take the better result."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[]}}}
{"_id":"af5caa92d8fc0e3a","name":"Mounted Combat","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can make a DC 20 Ride check as a Swift Action to spur your living Mount to move faster than its normal speed. If the check fails, your Mount's Speed does not increase and it moves -1 step on the Condition Track. If the check succeeds, your Mount's Speed increases by 2 squares until the start of your next turn. You cannot Take 10 on this check. Your Mount must succeed on a DC 20 Endurance check prior to each subsequent attempt to use this Feat in the same encounter.\n\nAdditionally, once per round, as a Reaction, when you are riding a Mount, you can negate a weapon hit against either you or the Mount by making a successful Ride check. The DC of the Skill Check is equal to the result of the attack roll you want to negate.","prerequisite":"Trained in Ride","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Ride</p>\n<p><strong>Effect:</strong> You can make a DC 20<br>Ride<br>check as a<br>Swift Action<br>to spur your living<br>Mount<br>to move faster than its normal speed. If the check fails, your Mount&#x27;s Speed does not increase and it moves -1 step on the<br>Condition Track<br>. If the check succeeds, your Mount&#x27;s Speed increases by 2 squares until the start of your next turn. You cannot<br>Take 10<br>on this check. Your<br>Mount<br>must succeed on a DC 20<br>Endurance<br>check prior to each subsequent attempt to use this Feat in the same encounter.<br><br>Additionally, once per round, as a<br>Reaction<br>, when you are riding a<br>Mount<br>, you can negate a weapon hit against either you or the<br>Mount<br>by making a successful<br>Ride<br>check. The DC of the<br>Skill Check<br>is equal to the result of the attack roll you want to negate.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Mounted_Combat</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":2,"type":"untyped","predicates":["attack.when-hit","turn.once-per-round"],"enabled":false,"priority":500,"description":"Mounted Combat: Mounted Combat is a Ride-based reaction and mount speed action, not a skill bonus.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.when-hit","turn.once-per-round"],"conditionSummary":"Mounted Combat is a Ride-based reaction and mount speed action, not a skill bonus.","metadataPhase":"phase10-feat-implementation-continuation"}],"mechanicsMode":"conditional","applicationScope":"non_numeric_rule","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Mounted Combat is a Ride-based reaction and mount speed action, not a skill bonus.","predicateRequirements":[],"metadataPhase":"phase10-feat-implementation-continuation","metadataNotes":"Phase 10 uses refreshed descriptions to replace old migrated scaffold modifiers with concrete defense, skill, attack-option, reaction, or resource metadata.","reactionRules":[{"type":"NEGATE_MOUNT_OR_RIDER_HIT_WITH_RIDE","trigger":"mountOrRiderHit","action":"reaction","oncePer":"round","skillKey":"ride","dc":"attackRollTotal","description":"Once per round while mounted, make Ride vs attack roll to negate a weapon hit against you or your mount."}],"status":"reaction_skill_rule_phase10","description":"Mounted Combat is a Ride-based reaction and mount speed action, not a skill bonus."},"shortSummary":"Increase Speed and avoid attacks when riding a Mount.","prerequisitesText":"Trained in Ride","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Mounted_Combat","effect":"You can make a DC 20\nRide\ncheck as a\nSwift Action\nto spur your living\nMount\nto move faster than its normal speed. If the check fails, your Mount's Speed does not increase and it moves -1 step on the\nCondition Track\n. If the check succeeds, your Mount's Speed increases by 2 squares until the start of your next turn. You cannot\nTake 10\non this check. Your\nMount\nmust succeed on a DC 20\nEndurance\ncheck prior to each subsequent attempt to use this Feat in the same encounter.\n\nAdditionally, once per round, as a\nReaction\n, when you are riding a\nMount\n, you can negate a weapon hit against either you or the\nMount\nby making a successful\nRide\ncheck. The DC of the\nSkill Check\nis equal to the result of the attack roll you want to negate."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["attack.when-hit","turn.once-per-round"],"id":"swse.feat.mounted_combat","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Mounted_Combat","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b00e0a883da4edda","name":"K'thri Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"martial_arts","benefit":"Make swift Unarmed attacks. Deal half damage on misses.","prerequisite":"Dual Weapon Mastery I, Martial Arts I","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","feat_chain","martial_arts","martial_style","offense_melee","unarmed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Dual Weapon Mastery I<br>,<br>Martial Arts I</p>\n<p><strong>Effect:</strong> Once per round, you can spend a<br>Swift Action<br>to make a single<br>Unarmed Attack<br>against one enemy within<br>Reach<br>, dealing your base<br>Unarmed<br>damage with no bonus to the damage roll from your<br>Strength<br>or Heroic Level.<br><br>Once per encounter, when you make an<br>Unarmed Attack<br>that misses the target, you deal half damage to the target.<br><br>You must be wearing<br>Light Armor<br>or no Armor to gain the benefits of this<br>Feat<br>.</p>\n<p><strong>Special:</strong> If you have the<br>K&#x27;thri Expertise<br>Talent, once per encounter when making a<br>Full Attack<br>, you can reroll one of your<br>Unarmed<br>attack rolls; however, you must accept the result of the reroll, even if it is worse. You must be wearing<br>Light Armor<br>or no Armor to gain this special benefit.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/K&#x27;thri_Training</em></p>","martialArtsFeat":true,"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"K'thri Training: Removed old +2 attack scaffold; feat grants action/damage-mode options instead.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"Removed old +2 attack scaffold; feat grants action/damage-mode options instead."}],"mechanicsMode":"conditional","applicationScope":"unarmed_attack_option","staticSheetPolicy":"attack_option_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Once per round, make a swift unarmed attack using base unarmed damage only; once per encounter, deal half damage on a missed unarmed attack.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"attack_option_phase11","description":"Once per round, make a swift unarmed attack using base unarmed damage only; once per encounter, deal half damage on a missed unarmed attack.","rules":[{"type":"ATTACK_OPTION","option":"kthriSwiftUnarmedAttack","label":"K'thri Swift Unarmed Attack","control":"flag","requiresAttackType":"melee","requiresUnarmed":true,"oncePer":"round","actionCost":"swift","suppressDamageAbilityAndLevel":true,"damageMode":"baseOnly","summary":"Once per round, spend a swift action to make one unarmed attack using base unarmed damage only."}],"riderRules":[{"type":"HALF_DAMAGE_ON_MISSED_UNARMED_ATTACK","oncePer":"encounter","description":"Once per encounter, when an unarmed attack misses, deal half damage to the target."}]},"shortSummary":"Make swift Unarmed attacks.","sourceUrl":"https://swse.fandom.com/wiki/K'thri_Training","rawImport":{"name":"K'thri Training","url":"https://swse.fandom.com/wiki/K'thri_Training","pageTitle":"K'thri_Training","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\k_thri_training.html","referenceBooks":[],"prerequisitesText":"Dual Weapon Mastery I\n,\nMartial Arts I","prerequisites":["Dual Weapon Mastery I","Martial Arts I"],"effect":"Once per round, you can spend a\nSwift Action\nto make a single\nUnarmed Attack\nagainst one enemy within\nReach\n, dealing your base\nUnarmed\ndamage with no bonus to the damage roll from your\nStrength\nor Heroic Level.\n\nOnce per encounter, when you make an\nUnarmed Attack\nthat misses the target, you deal half damage to the target.\n\nYou must be wearing\nLight Armor\nor no Armor to gain the benefits of this\nFeat\n.","benefit":"","normal":"","special":"If you have the\nK'thri Expertise\nTalent, once per encounter when making a\nFull Attack\n, you can reroll one of your\nUnarmed\nattack rolls; however, you must accept the result of the reroll, even if it is worse. You must be wearing\nLight Armor\nor no Armor to gain this special benefit.","indexPrerequisites":"Dual Weapon Mastery I , Martial Arts I","indexBenefit":"Make swift Unarmed attacks. Deal half damage on misses.","indexPage":"Specialization_Feats","indexSection":"Martial Arts Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nMartial Arts Feats\n\nYou are trained in the K'thri style of\nUnarmed\nfighting, striking with flashy moves and incredible speed.\n\nPrerequisites:\nDual Weapon Mastery I\n,\nMartial Arts I\n\nEffect:\nOnce per round, you can spend a\nSwift Action\nto make a single\nUnarmed Attack\nagainst one enemy within\nReach\n, dealing your base\nUnarmed\ndamage with no bonus to the damage roll from your\nStrength\nor Heroic Level.\n\nOnce per encounter, when you make an\nUnarmed Attack\nthat misses the target, you deal half damage to the target.\n\nYou must be wearing\nLight Armor\nor no Armor to gain the benefits of this\nFeat\n.\n\nSpecial:\nIf you have the\nK'thri Expertise\nTalent, once per encounter when making a\nFull Attack\n, you can reroll one of your\nUnarmed\nattack rolls; however, you must accept the result of the reroll, even if it is worse. You must be wearing\nLight Armor\nor no Armor to gain this special benefit."},"prerequisitesText":"Dual Weapon Mastery I\n,\nMartial Arts I","effect":"Once per round, you can spend a\nSwift Action\nto make a single\nUnarmed Attack\nagainst one enemy within\nReach\n, dealing your base\nUnarmed\ndamage with no bonus to the damage roll from your\nStrength\nor Heroic Level.\n\nOnce per encounter, when you make an\nUnarmed Attack\nthat misses the target, you deal half damage to the target.\n\nYou must be wearing\nLight Armor\nor no Armor to gain the benefits of this\nFeat\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.kthri_training"}}}
{"_id":"b0feacaeae4860e9","name":"Teräs Käsi Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"martial_arts","benefit":"Treat target's Damage Threshold as lower.","prerequisite":"Strength 13, Martial Arts I","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["damage_threshold","feat","feat_chain","martial_arts","martial_style","offense_melee","unarmed"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Strength<br>13,<br>Martial Arts I</p>\n<p><strong>Effect:</strong> Once per round when you make a successful<br>Unarmed Attack<br>, you reduce the target&#x27;s<br>Damage Threshold<br>by 5 when determining the effect of the attack.</p>\n<p><strong>Special:</strong> If you have the<br>Teräs Käsi Basics<br>Talent, you are considered to be one size category larger when determining the damage of your<br>Unarmed Attacks<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Ter%C3%A4s_K%C3%A4si_Training</em></p>","martialArtsFeat":true,"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Teräs Käsi Training: Removed old +2 attack scaffold; feat changes Damage Threshold for a successful unarmed attack.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"Removed old +2 attack scaffold; feat changes Damage Threshold for a successful unarmed attack."}],"mechanicsMode":"conditional","applicationScope":"unarmed_attack_rider","staticSheetPolicy":"attack_option_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Once per round on a successful unarmed attack, reduce the target's Damage Threshold by 5 for that attack.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"attack_option_phase11","description":"Once per round on a successful unarmed attack, reduce the target's Damage Threshold by 5 for that attack.","rules":[{"type":"ATTACK_OPTION","option":"terasKasiThreshold","label":"Teräs Käsi Threshold","control":"passive","requiresAttackType":"melee","requiresUnarmed":true,"oncePer":"round","targetEffectsOnHit":[{"type":"REDUCE_DAMAGE_THRESHOLD_FOR_ATTACK","value":5,"duration":"currentAttack"}],"summary":"Once per round, reduce the target's Damage Threshold by 5 for a successful unarmed attack."}]},"shortSummary":"Treat target's Damage Threshold as lower.","sourceUrl":"https://swse.fandom.com/wiki/Ter%C3%A4s_K%C3%A4si_Training","rawImport":{"name":"Teräs Käsi Training","url":"https://swse.fandom.com/wiki/Ter%C3%A4s_K%C3%A4si_Training","pageTitle":"Teräs_Käsi_Training","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\ter_s_k_si_training.html","referenceBooks":[],"prerequisitesText":"Strength\n13,\nMartial Arts I","prerequisites":["Strength\n13","Martial Arts I"],"effect":"Once per round when you make a successful\nUnarmed Attack\n, you reduce the target's\nDamage Threshold\nby 5 when determining the effect of the attack.","benefit":"","normal":"","special":"If you have the\nTeräs Käsi Basics\nTalent, you are considered to be one size category larger when determining the damage of your\nUnarmed Attacks\n.","indexPrerequisites":"Strength 13, Martial Arts I","indexBenefit":"Treat target's Damage Threshold as lower.","indexPage":"Specialization_Feats","indexSection":"Martial Arts Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nMartial Arts Feats\n\nYou are trained in the Teräs Käsi\nUnarmed\nfighting style and can send an enemy reeling with a single punch.\n\nPrerequisites:\nStrength\n13,\nMartial Arts I\n\nEffect:\nOnce per round when you make a successful\nUnarmed Attack\n, you reduce the target's\nDamage Threshold\nby 5 when determining the effect of the attack.\n\nSpecial:\nIf you have the\nTeräs Käsi Basics\nTalent, you are considered to be one size category larger when determining the damage of your\nUnarmed Attacks\n."},"prerequisitesText":"Strength\n13,\nMartial Arts I","effect":"Once per round when you make a successful\nUnarmed Attack\n, you reduce the target's\nDamage Threshold\nby 5 when determining the effect of the attack."},"effects":[{"_id":"13c55868-397b-4d06-8f97-8ad4743c04d3","name":"Teräs Käsi Training","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Teräs Käsi Training","effectType":"special","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.ter_s_k_si_training"}}}
{"_id":"b1299c242802a260","name":"Fringe Benefits","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Reduce the cost multiplier of goods bought on the Black Market.","prerequisite":"Rodian","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["species-rodian"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Rodian</p>\n<p><strong>Effect:</strong> Whenever you buy goods on the<br>Black Market<br>, reduce the cost multiplier by 2 (For example, from x5 to x3), to a minimum of x1.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Fringe_Benefits</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_capability","applicationScope":"black_market_cost_context","staticSheetPolicy":"commerce_metadata","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Fringe Benefits reduces Black Market cost multiplier by 2, minimum x1; store/black-market automation can consume this commerce metadata later.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"commerce_metadata_phase17","description":"Fringe Benefits reduces Black Market cost multiplier by 2, minimum x1; store/black-market automation can consume this commerce metadata later.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Fringe Benefits reduces Black Market cost multiplier by 2, minimum x1; store/black-market automation can consume this commerce metadata later.","mechanicsMode":"metadata_only","applicationScope":"black_market_cost_context","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"commerceRules":[{"type":"BLACK_MARKET_COST_MULTIPLIER_REDUCTION","value":2,"minimumMultiplier":1,"description":"Reduce Black Market cost multiplier by 2, minimum x1."}]},"shortSummary":"Reduce the cost multiplier of goods bought on the Black Market.","sourceUrl":"https://swse.fandom.com/wiki/Fringe_Benefits","rawImport":{"name":"Fringe Benefits","url":"https://swse.fandom.com/wiki/Fringe_Benefits","pageTitle":"Fringe_Benefits","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\fringe_benefits.html","referenceBooks":[],"prerequisitesText":"Rodian","prerequisites":["Rodian"],"effect":"Whenever you buy goods on the\nBlack Market\n, reduce the cost multiplier by 2 (For example, from x5 to x3), to a minimum of x1.","benefit":"","normal":"","special":"","indexPrerequisites":"Rodian","indexBenefit":"Reduce the cost multiplier of goods bought on the Black Market .","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou are a well-known member of criminal society and can get the best deal possible on illicit goods.\n\nPrerequisite:\nRodian\n\nEffect:\nWhenever you buy goods on the\nBlack Market\n, reduce the cost multiplier by 2 (For example, from x5 to x3), to a minimum of x1."},"prerequisitesText":"Rodian","effect":"Whenever you buy goods on the\nBlack Market\n, reduce the cost multiplier by 2 (For example, from x5 to x3), to a minimum of x1."},"effects":[{"_id":"a9baf594-dbf5-4166-97f6-28942f1b2f16","name":"Fringe Benefits","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Fringe Benefits","effectType":"passive_effect","flagType":"Fringe Benefits"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.fringe_benefits"}}}
{"_id":"b1970c18996d44dd","name":"Unified Squadron","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Pilot checks checks when near allies.","prerequisite":"Trained in Pilot","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_pilot","skill_synergy","team","teamwork","vehicle","conditional_skill_bonus","execution_mapped_phase8","manual_resolution","teamwork_base_skill_bonus_phase15"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Pilot</p>\n<p><strong>Effect:</strong> You gain a +3 competence bonus on<br>Pilot<br>checks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).<br><br>Additionally, you always succeed when trying to<br>Avoid Collision<br>with<br>Vehicles<br>piloted by allies who also have this Feat (no<br>Collisions<br>occur, even on<br>Character Scale<br>).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Unified_Squadron</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_with_manual_teamwork","applicationScope":"skill_roll_plus_manual_teamwork","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Unified Squadron: +3 competence skill bonus applies normally; nearby-ally scaling and other battlefield/teamwork clauses are GM/player managed.","predicateRequirements":[],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 avoids automating nearby-ally/battlefield positioning clauses; base skill bonuses are implemented where unambiguous and teamwork clauses are preserved as manual metadata.","implementationStatus":"base_skill_bonus_manual_teamwork_phase15","description":"Unified Squadron: base +3 competence skill bonus implemented; nearby-ally scaling and special teamwork clauses remain table-managed flavor/manual metadata.","skillCheckBonuses":[{"id":"unified-squadron","skillKey":"pilot","type":"competence","featName":"Unified Squadron","description":"Unified Squadron: +3 competence bonus to pilot checks. Nearby-ally scaling is manual/table-managed.","value":3}],"teamworkRules":[{"type":"AUTO_SUCCEED_SKILL_USE","skillKey":"pilot","application":"Avoid Collision","requiresAlliedVehiclePilotHasFeat":true,"description":"Automatically succeed to Avoid Collision with vehicles piloted by allies who also have this feat.","automation":"manual","manualResolution":true}]},"shortSummary":"Gain bonuses on Pilot checks checks when near allies.","sourceUrl":"https://swse.fandom.com/wiki/Unified_Squadron","rawImport":{"name":"Unified Squadron","url":"https://swse.fandom.com/wiki/Unified_Squadron","pageTitle":"Unified_Squadron","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\unified_squadron.html","referenceBooks":[],"prerequisitesText":"Trained\nin\nPilot","prerequisites":["Trained\nin\nPilot"],"effect":"You gain a +3 competence bonus on\nPilot\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, you always succeed when trying to\nAvoid Collision\nwith\nVehicles\npiloted by allies who also have this Feat (no\nCollisions\noccur, even on\nCharacter Scale\n).","benefit":"","normal":"","special":"","indexPrerequisites":"Trained in Pilot","indexBenefit":"Gain bonuses on Pilot checks checks when near allies.","indexPage":"Specialization_Feats","indexSection":"Team Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nTeam Feats\n\nYou and your allies are excellent pilots whose skills shine when you fly together, making you better as a unit than as individuals.\n\nPrerequisite:\nTrained\nin\nPilot\n\nEffect:\nYou gain a +3 competence bonus on\nPilot\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, you always succeed when trying to\nAvoid Collision\nwith\nVehicles\npiloted by allies who also have this Feat (no\nCollisions\noccur, even on\nCharacter Scale\n)."},"prerequisitesText":"Trained\nin\nPilot","effect":"You gain a +3 competence bonus on\nPilot\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, you always succeed when trying to\nAvoid Collision\nwith\nVehicles\npiloted by allies who also have this Feat (no\nCollisions\noccur, even on\nCharacter Scale\n)."},"effects":[{"_id":"318db08e-459c-45f8-b86e-3e67175b59ee","name":"Unified Squadron","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Unified Squadron","effectType":"skill_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.unified_squadron"}}}
{"_id":"b2296a4d5cef8a61","name":"Frightful Presence","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"As a standard action, you may make a Persuasion check to intimidate all enemies within 6 squares. On a success, targets move -1 step down the condition track.","prerequisite":"Charisma 15","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["control","feat","general","social"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Active Persuasion area intimidation action.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"active_action","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Active Persuasion area intimidation action.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"active_action_metadata_phase14","actionRules":[{"type":"AREA_INTIMIDATE_ACTION","skillKey":"persuasion","rangeSquares":6,"targetDefense":"will","effect":"conditionTrack","steps":-1,"description":"Standard action Persuasion check to intimidate enemies within 6 squares."}]},"shortSummary":"As a standard action, you may make a Persuasion check to intimidate all enemies within 6 squares."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[]}}}
{"_id":"b26497554169ac38","name":"Instinctive Defense","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"On your turn, as a Free Action, you can spend a Force Point to increase all of your Defenses by 2 until the start of your next turn.","prerequisite":"Cannot be a Droid","special":"","normalText":"","sourcebook":"Unknown Regions","page":25,"tags":["defense","feat","force_point_spend","general","resource_spend","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Cannot be a<br>Droid</p>\n<p><strong>Effect:</strong> On your turn, as a<br>Free Action<br>, you can spend a<br>Force Point<br>to increase all of your<br>Defenses<br>by 2 until the start of your next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Instinctive_Defense</em></p>","executionModel":"ACTIVE","subType":"RESOURCE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Instinctive Defense: Activated resource effect; not a passive attack modifier.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"Activated resource effect; not a passive attack modifier."}],"mechanicsMode":"active","applicationScope":"force_point_defense_resource","staticSheetPolicy":"resource_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"As a free action on your turn, spend a Force Point to gain +2 to all defenses until the start of your next turn.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"active_resource_phase11","description":"As a free action on your turn, spend a Force Point to gain +2 to all defenses until the start of your next turn.","resourceRules":{"forcePoints":[{"type":"SPEND_FOR_TEMP_DEFENSE","value":2,"targets":["defense.fortitude","defense.reflex","defense.will"],"actionCost":"free","activationTiming":"onOwnTurn","duration":"untilStartOfNextTurn","description":"Spend a Force Point as a free action on your turn to increase Fortitude, Reflex, and Will Defense by +2 until the start of your next turn."}]},"activeEffectTemplate":{"label":"Instinctive Defense","changes":[{"key":"system.activeEffects","mode":"ADD","value":{"target":"defense","value":2,"source":"Instinctive Defense"},"priority":20}],"duration":{"rounds":1}}},"activation":{"type":"reaction","cost":1,"resource":"forcePoint"},"shortSummary":"Spend a Force Point to increase all Defenses by +2 for 1 round.","prerequisitesText":"Cannot be a Droid","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Instinctive_Defense","effect":"On your turn, as a\nFree Action\n, you can spend a\nForce Point\nto increase all of your\nDefenses\nby 2 until the start of your next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.instinctive_defense","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Instinctive_Defense","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b3965f7a31f310ec","name":"Cybernetic Surgery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can install Cybernetic Devices on living beings. The surgical procedure takes 1 hour of uninterrupted work, after which you must make a DC 20 Treat Injury check. If the check succeeds, the Cybernetic Device is installed correctly. If the check fails, the device is not properly installed; however, you can try again after another uninterrupted hour of surgery.","prerequisite":"Trained in Treat Injury","special":"You can install a Cybernetic Prosthesis or Energy-Binding Prosthesis on yourself, but you take a -5 penalty on the Treat Injury skill check (you cannot install a Rhen-Orm Biocomputer or a Subelectronic Converter on yourself). If you have the Surgical Expertise Feat, you can install a Cybernetic Device in 10 minutes instead of 1 hour.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["defense","feat","general","healing","skill_treat_injury","support","survivability","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> Trained<br>in<br>Treat Injury</p>\n<p><strong>Effect:</strong> You can install<br>Cybernetic Devices<br>on living beings. The surgical procedure takes 1 hour of uninterrupted work, after which you must make a DC 20<br>Treat Injury<br>check. If the check succeeds, the<br>Cybernetic Device<br>is installed correctly. If the check fails, the device is not properly installed; however, you can try again after another uninterrupted hour of surgery.</p>\n<p><strong>Special:</strong> You can install a<br>Cybernetic Prosthesis<br>or<br>Energy-Binding Prosthesis<br>on yourself, but you take a -5 penalty on the<br>Treat Injury<br>skill check (you cannot install a<br>Rhen-Orm Biocomputer<br>or a<br>Subelectronic Converter<br>on yourself). If you have the<br>Surgical Expertise<br>Feat, you can install a<br>Cybernetic Device<br>in 10 minutes instead of 1 hour.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Cybernetic_Surgery</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"treatinjury"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"manual_punted","applicationScope":"gm_player_cybernetic_surgery","staticSheetPolicy":"manual_punted","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Cybernetic Surgery is punted to GM/player handling; cybernetic installation remains a table/workbench procedure.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"punted_to_gm_player","description":"Cybernetic Surgery is punted to GM/player handling; cybernetic installation remains a table/workbench procedure.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Cybernetic Surgery is punted to GM/player handling; cybernetic installation remains a table/workbench procedure.","mechanicsMode":"metadata_only","applicationScope":"gm_player_cybernetic_surgery","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"puntedTo":"GM/player"},"shortSummary":"Install a Cybernetic Prosthesis onto a living being.","prerequisitesText":"Trained in Treat Injury","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Cybernetic_Surgery","effect":"You can install\nCybernetic Devices\non living beings. The surgical procedure takes 1 hour of uninterrupted work, after which you must make a DC 20\nTreat Injury\ncheck. If the check succeeds, the\nCybernetic Device\nis installed correctly. If the check fails, the device is not properly installed; however, you can try again after another uninterrupted hour of surgery."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.cybernetic_surgery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Cybernetic_Surgery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b3984239e21c64ca","name":"Suppression Fire","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you use the Aid Another action to impose a penalty to an enemy's attack rolls and your attack roll exceeds the target's Will Defense, that enemy must end its next turn in a position where it has Cover from you if possible. Targets whose level is equal to or higher than your Character Level are immune to the effect of Suppression Fire. This is a Mind-Affecting Fear effect.","prerequisite":"Strength 13, Burst Fire, Weapon Proficiency (Heavy Weapons)","special":"","normalText":"","sourcebook":"Threats of the Galaxy","page":21,"tags":["area_pressure","control","feat","general","grapple","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Strength<br>13,<br>Burst Fire<br>,<br>Weapon Proficiency (Heavy Weapons)</p>\n<p><strong>Effect:</strong> When you use the<br>Aid Another<br>action to impose a penalty to an enemy&#x27;s attack rolls and your attack roll exceeds the target&#x27;s<br>Will Defense<br>, that enemy must end its next turn in a position where it has<br>Cover<br>from you if possible. Targets whose level is equal to or higher than your Character Level are immune to the effect of Suppression Fire. This is a<br>Mind-Affecting<br>Fear effect.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Suppression_Fire</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"active","applicationScope":"aid_another_suppression_context","staticSheetPolicy":"manual_or_table_context","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Suppression Fire: Aid Another suppression rider against Will Defense; battlefield cover behavior is preserved as metadata, not automated.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"aid_another_rider_metadata_phase16","description":"Suppression Fire: Aid Another suppression rider against Will Defense; battlefield cover behavior is preserved as metadata, not automated.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Suppression Fire: Aid Another suppression rider against Will Defense; battlefield cover behavior is preserved as metadata, not automated.","mechanicsMode":"metadata_only","applicationScope":"aid_another_suppression_context","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"actionRules":[{"type":"AID_ANOTHER_SUPPRESSION_FIRE","targetDefense":"will","tags":["mind-affecting","fear"],"description":"When using Aid Another to impose an attack penalty, if your attack roll exceeds target Will Defense, target must seek cover by end of next turn if possible. GM/table adjudicates cover availability."}]},"shortSummary":"You can lay down a hail of blaster fire to pin your opponents.","prerequisitesText":"Strength 13, Burst Fire, Weapon Proficiency (Heavy Weapons)","referenceBooks":["Star Wars Saga Edition Threats of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Suppression_Fire","effect":"When you use the\nAid Another\naction to impose a penalty to an enemy's attack rolls and your attack roll exceeds the target's\nWill Defense\n, that enemy must end its next turn in a position where it has\nCover\nfrom you if possible. Targets whose level is equal to or higher than your Character Level are immune to the effect of Suppression Fire. This is a\nMind-Affecting\nFear effect."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.suppression_fire","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Suppression_Fire","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b3dfdfd783cf16be","name":"A Few Maneuvers","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When piloting a Vehicle of Colossal size or smaller, you grant a +2 dodge bonus to your Vehicle's Reflex Defense. Furthermore, if you are the target of a missile or torpedo attack and the attack roll misses by 5 or more, the projectile self-destructs harmlessly.","prerequisite":"Dodge, Vehicular Combat","special":"","normalText":"","sourcebook":"Threats of the Galaxy","page":20,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Dodge<br>,<br>Vehicular Combat</p>\n<p><strong>Effect:</strong> When piloting a<br>Vehicle<br>of Colossal size or smaller, you grant a +2 dodge bonus to your Vehicle&#x27;s<br>Reflex Defense<br>. Furthermore, if you are the target of a missile or torpedo attack and the attack roll misses by 5 or more, the projectile self-destructs harmlessly.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/A_Few_Maneuvers</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"vehicle_piloting_defense_context","staticSheetPolicy":"vehicle_context_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"A Few Maneuvers grants +2 dodge Reflex to a Colossal-or-smaller vehicle you pilot and harmlessly self-destructs missile/torpedo misses by 5+; vehicle context remains metadata.","predicateRequirements":[],"metadataPhase":"phase17-next-feat-batch","metadataNotes":"Phase 17 clears the remaining Phase 16 active backlog by implementing engine-supported skill/reroll/attack-option rules where possible, and explicitly reclassifying table-state/picker-heavy feats as manual, punted, or deferred instead of leaving them as unincorporated placeholders.","implementationStatus":"vehicle_defense_metadata_phase17","description":"A Few Maneuvers grants +2 dodge Reflex to a Colossal-or-smaller vehicle you pilot and harmlessly self-destructs missile/torpedo misses by 5+; vehicle context remains metadata.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"A Few Maneuvers grants +2 dodge Reflex to a Colossal-or-smaller vehicle you pilot and harmlessly self-destructs missile/torpedo misses by 5+; vehicle context remains metadata.","mechanicsMode":"metadata_only","applicationScope":"vehicle_piloting_defense_context","staticSheetPolicy":"exclude","metadataPhase":"phase17-next-feat-batch"}],"vehicleDefenseRules":[{"type":"PILOTED_VEHICLE_REFLEX_BONUS","bonus":2,"bonusType":"dodge","maxVehicleSize":"colossal","description":"When piloting a Colossal-or-smaller vehicle, grant +2 dodge bonus to its Reflex Defense."}],"reactionRules":[{"type":"MISSILE_TORPEDO_SELF_DESTRUCT_ON_MISS_BY","missBy":5,"description":"Missile/torpedo attacks against you that miss by 5+ self-destruct harmlessly."}]},"shortSummary":"You can weave, juke, and roll to avoid enemy fire in the thick of combat.","prerequisitesText":"Dodge, Vehicular Combat","referenceBooks":["Star Wars Saga Edition Threats of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/A_Few_Maneuvers","effect":"When piloting a\nVehicle\nof Colossal size or smaller, you grant a +2 dodge bonus to your Vehicle's\nReflex Defense\n. Furthermore, if you are the target of a missile or torpedo attack and the attack roll misses by 5 or more, the projectile self-destructs harmlessly."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.a_few_maneuvers","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/A_Few_Maneuvers","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b4c1dbb468777c09","name":"Rebel Military Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Whenever you use the Running Attack feat to move both before and after making an attack, you gain a +2 dodge bonus to your Reflex Defense until the start of your next turn.","prerequisite":"Running Attack","special":"","normalText":"","sourcebook":"Rebellion Era Campaign Guide","page":21,"tags":["attack_option","background_opportunity","execution_mapped_phase8","faction_training","feat","general","military","species_opportunity"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Running Attack</p>\n<p><strong>Effect:</strong> Whenever you use the<br>Running Attack<br>feat to move both before and after making an attack, you gain a +2 dodge bonus to your<br>Reflex Defense<br>until the start of your next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Rebel_Military_Training</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":false,"priority":500,"description":"Rebel Military Training is implemented as an explicit attack option, not a passive attack modifier.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.reflex"],"conditionSummary":"Rebel Military Training is implemented as an explicit attack option, not a passive attack modifier."}],"mechanicsMode":"active","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"When using Running Attack, gain +2 dodge bonus to Reflex until next turn.","predicateRequirements":["defense.reflex"],"metadataPhase":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics.","status":"attack_option_phase8","description":"Rebel Military Training: Running Attack rider grants +2 Reflex until next turn.","rules":[{"type":"ATTACK_OPTION","option":"rebelMilitaryTraining","label":"Rebel Military Training","control":"flag","requiresAttackType":"any","requiresOption":"runningAttack","defenseModifier":{"target":"defense.reflex","type":"dodge","value":2,"duration":"untilStartOfNextTurn"},"summary":"When using Running Attack, gain +2 dodge bonus to Reflex until next turn."}]},"shortSummary":"Gain a dodge bonus to Reflex Defense when using Running Attack.","prerequisitesText":"Running Attack","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Rebel_Military_Training","effect":"Whenever you use the\nRunning Attack\nfeat to move both before and after making an attack, you gain a +2 dodge bonus to your\nReflex Defense\nuntil the start of your next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.rebel_military_training","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Rebel_Military_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b531781f373c3031","name":"Master of Disguise","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +5 insight bonus to your Deception check when creating a Deceptive Appearance. In addition, you can rush the process by taking a -2 penalty to the Deception check.","prerequisite":"Trained in Deception, Charisma 13","special":"","normalText":"When you rush the creation of a Deceptive Appearance, you take a -10 penalty to your Deception check.","sourcebook":"Galaxy of Intrigue","page":21,"tags":["feat","general","social"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Deception<br>,<br>Charisma<br>13</p>\n<p><strong>Effect:</strong> You gain a +5 insight bonus to your<br>Deception<br>check when creating a<br>Deceptive Appearance<br>. In addition, you can rush the process by taking a -2 penalty to the<br>Deception<br>check.</p>\n<p><strong>Normal:</strong> When you rush the creation of a<br>Deceptive Appearance<br>, you take a -10 penalty to your<br>Deception<br>check.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Master_of_Disguise</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"+5 Deception applies only to disguise/forgery-style uses.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"skill_roll_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"+5 Deception applies only to disguise/forgery-style uses.","predicateRequirements":[],"metadataPhase":"phase13-next-feat-implementation-batch","metadataNotes":"Phase 13 converts clear remaining manual/scaffold feats into skill bonuses, attack options, action/resource metadata, or safer non-static rider metadata.","executionModel":"PASSIVE","subType":"RULE","skillCheckBonuses":[{"id":"masterOfDisguise.disguiseForgery","skillKey":"deception","value":5,"type":"feat","applications":["Deceptive Appearance","Forged Document","Disguise","Forgery"],"description":"+5 Deception when creating a deceptive appearance or forged document."}],"implementationStatus":"master_of_disguise_skill_bonus_phase13"},"shortSummary":"Gain +5 to creating a Deceptive Appearance or a Forged Document, and reduce the penalty for rushing.","prerequisitesText":"Trained in Deception, Charisma 13","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Master_of_Disguise","effect":"You gain a +5 insight bonus to your\nDeception\ncheck when creating a\nDeceptive Appearance\n. In addition, you can rush the process by taking a -2 penalty to the\nDeception\ncheck."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.master_of_disguise","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Master_of_Disguise","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b573d4f48af37b42","name":"Attack Combo (Ranged)","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"If you hit a single target with two consecutive ranged attacks during the same turn, any additional ranged attacks you make until the end of your next turn (including Attacks of Opportunity and attacks made as Reactions) deal +1 die of damage on a hit. This extra damage stacks with extra damage granted by other Feats or Talents.","prerequisite":"Base Attack Bonus +3","special":"","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":15,"tags":["feat","general","offense"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Base Attack Bonus<br>+3</p>\n<p><strong>Effect:</strong> If you hit a single target with two consecutive ranged attacks during the same turn, any additional ranged attacks you make until the end of your next turn (including<br>Attacks of Opportunity<br>and attacks made as<br>Reactions<br>) deal +1 die of damage on a hit. This extra damage stacks with extra damage granted by other<br>Feats<br>or<br>Talents<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Attack_Combo_(Ranged)</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":3}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.when-hit","attack.with-ranged"],"enabled":false,"priority":500,"description":"Attack Combo (Ranged): Converted from false attack bonus to a follow-up damage option that adds +1 weapon die after the combo is primed.","mechanicsMode":"metadata_only","applicationScope":"explicit_rule_metadata","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":true,"predicateRequirements":["attack.when-hit","attack.with-ranged"],"conditionSummary":"Converted from false attack bonus to a follow-up damage option that adds +1 weapon die after the combo is primed."}],"mechanicsMode":"conditional","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":true,"conditionSummary":"Rules text or predicates require a selected choice before the modifier can be safely applied.","predicateRequirements":["attack.when-hit","attack.with-ranged"],"metadataPhase":"phase12-feat-implementation-batch","metadataNotes":"Phase 12 continues description-guided feat implementation by replacing false scaffold bonuses with explicit roll options, contextual predicates, resource/rider metadata, or supported static rules.","rules":[{"type":"ATTACK_OPTION","id":"attackComboRanged","label":"Attack Combo (Ranged)","control":"toggle","damageExtraWeaponDice":1,"summary":"After hitting the same target twice as required by this feat, toggle this for +1 weapon die on qualifying follow-up attacks until the end of your next turn.","requiresAttackType":"ranged"}],"status":"attackComboRanged_attack_option_phase12","description":"Converted from false attack bonus to a follow-up damage option that adds +1 weapon die after the combo is primed."},"shortSummary":"Deal +1 die of damage on ranged attacks until the end of your next turn after hitting an enemy with two ranged attacks.","prerequisitesText":"Base Attack Bonus +3","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Attack_Combo_(Ranged)","effect":"If you hit a single target with two consecutive ranged attacks during the same turn, any additional ranged attacks you make until the end of your next turn (including\nAttacks of Opportunity\nand attacks made as\nReactions\n) deal +1 die of damage on a hit. This extra damage stacks with extra damage granted by other\nFeats\nor\nTalents\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["attack.when-hit","attack.with-ranged"],"id":"swse.feat.attack_combo_ranged","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Attack_Combo_(Ranged)","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b5a8d5899e02139c","name":"Far Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you use a ranged weapon against targets at Short, Medium, or Long Range, the Range category is considered one less. In other words, you take no penalty on ranged attack rolls made at Short Range, a -2 penalty on ranged attack rolls made against targets at Medium Range, and a -5 penalty on ranged attack rolls made against targets at Long Range.","prerequisite":"Point-Blank Shot","special":"","normalText":"When making a ranged attack roll, a character takes a -2 penalty against targets at Short Range, a -5 penalty against targets at Medium Range, and a -10 penalty against targets at Long Range.","sourcebook":"Saga Edition Core Rulebook","page":86,"tags":["feat","general","offense","offense_ranged"],"bonus_feat_for":["f62ca2e639cab614","b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Point-Blank Shot</p>\n<p><strong>Effect:</strong> When you use a ranged weapon against targets at Short, Medium, or Long<br>Range<br>, the<br>Range<br>category is considered one less. In other words, you take no penalty on ranged attack rolls made at Short<br>Range<br>, a -2 penalty on ranged attack rolls made against targets at Medium<br>Range<br>, and a -5 penalty on ranged attack rolls made against targets at Long<br>Range<br>.</p>\n<p><strong>Normal:</strong> When making a ranged attack roll, a character takes a -2 penalty against targets at Short<br>Range<br>, a -5 penalty against targets at Medium<br>Range<br>, and a -10 penalty against targets at Long<br>Range<br>.</p>\n<h3>Additional Far Shot Effects</h3><p>Reference Book:<br>Star Wars Saga Edition Starships of the Galaxy<br><br>This<br>Feat works normally with<br>Vehicle Weapons<br>. However, if you are using a<br>Missile or a Torpedo<br>and you miss with your attack roll, the projectile does not gain the benefit of this Feat for the second attack roll.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Far_Shot</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"passive_roll_option_phase7","description":"Far Shot: passive roll-context option; applies only when the attack context matches the refreshed rules text.","rules":[{"type":"ATTACK_OPTION","option":"farShot","label":"Far Shot","control":"passive","summary":"Treat ranged targets at short, medium, or long range as one range category closer.","requiresAttackType":"ranged","rangePenaltyAdjustment":"oneStepCloser"}],"mechanicsMode":"conditional","applicationScope":"roll_context_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Passive for eligible rolls only. Missing range/action context fails closed and never changes static sheet totals.","predicateRequirements":[],"metadataPhase":"phase7-description-reimplementation","metadataNotes":"Phase 7 re-read refreshed descriptions and converted old scaffold bonuses into explicit static/resource/attack-option/rider metadata."},"shortSummary":"Range penalties for Short-, Medium-, and Long-ranged attacks are reduced.","prerequisitesText":"Point-Blank Shot","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Far_Shot","effect":"When you use a ranged weapon against targets at Short, Medium, or Long\nRange\n, the\nRange\ncategory is considered one less. In other words, you take no penalty on ranged attack rolls made at Short\nRange\n, a -2 penalty on ranged attack rolls made against targets at Medium\nRange\n, and a -5 penalty on ranged attack rolls made against targets at Long\nRange\n."},"effects":[{"_id":"95e717d6-e35f-4987-aa9f-df3ad86b403f","name":"Far Shot","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Far Shot","effectType":"passive_effect","flagType":"Far Shot"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.far_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Far_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b60e581b6c102cfc","name":"Long Haft Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you use a Lightsaber Pike or a Long-Handle Lightsaber, you can attack with both ends of the weapon, treating it as a double weapon.","prerequisite":"None","special":"","normalText":"","sourcebook":"Jedi Academy Training Manual","page":29,"tags":["feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> When you use a<br>Lightsaber Pike<br>or a<br>Long-Handle Lightsaber<br>, you can attack with both ends of the weapon, treating it as a double weapon.</p>\n<h3>Homebrew Long Haft Strike Data</h3><p>This Homebrew Content has not been reviewed in a meaningful manner. If you wish to review this content yourself, then see Untested for more details.<br><br>Long Shaft Strike data created by Wikia user Chellewalker (formally Wikia user Lukewarner).<br><br>A character may apply the effects of the Long Haft Strike Feat to any melee weapon one size category larger than themselves. For example, a Small character may use this Feat with Medium melee weapons, and Medium characters may use this Feat with Large melee weapons.<br><br>Characters may attack with both ends of the weapon as a<br>Full-Round Action<br>, but both attack rolls have a -10 penalty; certain<br>Feats<br>and<br>Talents<br>can reduce these penalties. The bludgeoning damage dealt by this bonus damage is determined by the chart below.<br><br>CHARACTER SIZE | WEAPON SIZE | DAMAGE<br>Small | Medium | 1d4<br>Medium | Large | 1d6<br>Large | Huge | 1d8</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Long_Haft_Strike</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"conditional","applicationScope":"weapon_property_context","staticSheetPolicy":"weapon_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Long Haft Strike: Lightsaber Pike or Long-Handle Lightsaber can be treated as a double weapon.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"weapon_property_metadata_phase16","description":"Long Haft Strike: Lightsaber Pike or Long-Handle Lightsaber can be treated as a double weapon.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Long Haft Strike: Lightsaber Pike or Long-Handle Lightsaber can be treated as a double weapon.","mechanicsMode":"metadata_only","applicationScope":"weapon_property_context","staticSheetPolicy":"exclude","metadataPhase":"phase16-next-feat-batch"}],"rules":[{"type":"WEAPON_PROPERTY_OVERRIDE","requiresWeaponText":["lightsaber pike","long-handle lightsaber","long handle lightsaber"],"addProperty":"double-weapon","description":"Treat the listed weapon as a double weapon."}]},"shortSummary":"You can wield a long-handled weapon as a Double Weapon.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Jedi Academy Training Manual"],"sourceUrl":"https://swse.fandom.com/wiki/Long_Haft_Strike","effect":"When you use a\nLightsaber Pike\nor a\nLong-Handle Lightsaber\n, you can attack with both ends of the weapon, treating it as a double weapon."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.long_haft_strike","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Long_Haft_Strike","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"b648515a5e8dd612","name":"Tireless Squad","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Endurance checks when near allies.","prerequisite":"Trained in Endurance","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_endurance","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8","manual_resolution","teamwork_base_skill_bonus_phase15"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Endurance</p>\n<p><strong>Effect:</strong> You gain a +3 competence bonus on<br>Endurance<br>checks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).<br><br>Additionally, when you use the<br>Aid Another<br>Action to assist an ally who has this Feat with a<br>Endurance<br>check, you provide a bonus of +4 instead of +2.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Tireless_Squad</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"passive_with_manual_teamwork","applicationScope":"skill_roll_plus_manual_teamwork","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Tireless Squad: +3 competence skill bonus applies normally; nearby-ally scaling and other battlefield/teamwork clauses are GM/player managed.","predicateRequirements":[],"metadataPhase":"phase15-next-feat-batch","metadataNotes":"Phase 15 avoids automating nearby-ally/battlefield positioning clauses; base skill bonuses are implemented where unambiguous and teamwork clauses are preserved as manual metadata.","implementationStatus":"base_skill_bonus_manual_teamwork_phase15","description":"Tireless Squad: base +3 competence skill bonus implemented; nearby-ally scaling and special teamwork clauses remain table-managed flavor/manual metadata.","skillCheckBonuses":[{"id":"tireless-squad","skillKey":"endurance","type":"competence","featName":"Tireless Squad","description":"Tireless Squad: +3 competence bonus to endurance checks. Nearby-ally scaling is manual/table-managed.","value":3}],"teamworkRules":[{"type":"AID_ANOTHER_BONUS_OVERRIDE","skillKey":"endurance","bonus":4,"requiresAllyHasFeat":true,"description":"Aid Another provides +4 instead of +2 when assisting an ally with this feat on Endurance.","automation":"manual","manualResolution":true}]},"shortSummary":"Gain bonuses on Endurance checks when near allies.","sourceUrl":"https://swse.fandom.com/wiki/Tireless_Squad","rawImport":{"name":"Tireless Squad","url":"https://swse.fandom.com/wiki/Tireless_Squad","pageTitle":"Tireless_Squad","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\tireless_squad.html","referenceBooks":[],"prerequisitesText":"Trained\nin\nEndurance","prerequisites":["Trained\nin\nEndurance"],"effect":"You gain a +3 competence bonus on\nEndurance\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you use the\nAid Another\nAction to assist an ally who has this Feat with a\nEndurance\ncheck, you provide a bonus of +4 instead of +2.","benefit":"","normal":"","special":"","indexPrerequisites":"Trained in Endurance","indexBenefit":"Gain bonuses on Endurance checks when near allies.","indexPage":"Specialization_Feats","indexSection":"Team Feats","indexReferenceBooks":["Star Wars Saga Edition Galaxy at War"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Galaxy at War\n\nSee also:\nFeats\n,\nTeam Feats\n\nYou and your allies train for combat scenarios in which your ability to hang in for the long haul is the difference between victory and defeat.\n\nPrerequisite:\nTrained\nin\nEndurance\n\nEffect:\nYou gain a +3 competence bonus on\nEndurance\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you use the\nAid Another\nAction to assist an ally who has this Feat with a\nEndurance\ncheck, you provide a bonus of +4 instead of +2."},"prerequisitesText":"Trained\nin\nEndurance","effect":"You gain a +3 competence bonus on\nEndurance\nchecks. At the time you make a check, for each ally within 12 squares of you who also has this Feat, the competence bonus increases by +1 (to a maximum of +7).\n\nAdditionally, when you use the\nAid Another\nAction to assist an ally who has this Feat with a\nEndurance\ncheck, you provide a bonus of +4 instead of +2."},"effects":[{"_id":"173e71a3-9001-4b47-95b2-9143a098273a","name":"Tireless Squad","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Tireless Squad","effectType":"skill_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.tireless_squad"}}}
{"_id":"b754b5e064c20cc0","name":"Improvised Weapon Mastery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You treat all Improvised Weapons as Simple Weapons, and you can use them without penalty and with Talents and Feats designed for use with Simple Weapons. You also deal an additional 1d6 points of damage on a successful hit.","prerequisite":"Weapon Proficiency (Simple Weapons)","special":"","normalText":"","sourcebook":"Unknown Regions","page":24,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Weapon Proficiency (Simple Weapons)</p>\n<p><strong>Effect:</strong> You treat all<br>Improvised Weapons<br>as<br>Simple Weapons<br>, and you can use them without penalty and with<br>Talents<br>and<br>Feats<br>designed for use with<br>Simple Weapons<br>. You also deal an additional 1d6 points of damage on a successful hit.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Improvised_Weapon_Mastery</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"grants":[{"category":"PROFICIENCY","proficiencyType":"weapon","proficiencies":["improvised"],"description":"Weapon proficiency: improvised weapons treated as simple"}],"status":"improvised_weapon_mastery_partial","description":"Improvised Weapon Mastery: Treat improvised weapons as Simple Weapons (proficiency automation). +1d6 damage and feat/talent interaction remain GM-enforced.","ruleNotes":[{"id":"improvised-weapon-mastery-damage","label":"+1d6 Damage","text":"+1d6 damage with improvised weapons (manual tracking).","mechanical":true,"gmEnforced":true},{"id":"improvised-weapon-mastery-talents","label":"Feat/Talent Interaction","text":"Feats and talents designed for Simple Weapons apply to improvised weapons when treated as simple (manual determination).","mechanical":true,"gmEnforced":true}],"mechanicsMode":"grant_unlock","applicationScope":"progression_or_system_access","staticSheetPolicy":"not_a_modifier","requiresRuntimeContext":false,"requiresSelectedChoice":false,"conditionSummary":"Current metadata uses grants rather than numeric modifiers.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"prerequisitesStructured":{"type":"all","conditions":[{"type":"feat","feat":"Weapon Proficiency (Simple Weapons)"}],"_source":"metadata-update"},"shortSummary":"Treat Improvised Weapons as Simple Weapons, deal +1d6 points of damage.","prerequisitesText":"Weapon Proficiency (Simple Weapons)","referenceBooks":["Star Wars Saga Edition Unknown Regions"],"sourceUrl":"https://swse.fandom.com/wiki/Improvised_Weapon_Mastery","effect":"You treat all\nImprovised Weapons\nas\nSimple Weapons\n, and you can use them without penalty and with\nTalents\nand\nFeats\ndesigned for use with\nSimple Weapons\n. You also deal an additional 1d6 points of damage on a successful hit."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.386Z","detectedPredicates":[],"id":"swse.feat.improvised_weapon_mastery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Improvised_Weapon_Mastery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
