{"_id":"3036290329d5b3e6","name":"Shake It Off","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can spend two Swift Actions instead of three to move +1 step along the Condition Track.","prerequisite":"Constitution 13, Trained in Endurance","special":"","normalText":"It takes three Swift Actions to move +1 step up along the Condition Track.","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["action_economy","condition_track","feat","general","swift_action"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Prerequisites:</strong> Constitution<br>13,<br>Trained<br>in<br>Endurance</p>\n<p><strong>Effect:</strong> You can spend two<br>Swift Actions<br>instead of three to move +1 step along the<br>Condition Track<br>.</p>\n<p><strong>Normal:</strong> It takes three<br>Swift Actions<br>to move +1 step up along the<br>Condition Track<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Shake_It_Off</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"con","min":13},{"type":"skillTrained","skill":"35df8faa4878f2c5"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Spend two swift actions to improve your Condition Track by 1 step.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"condition_track_action","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Spend two swift actions to improve your Condition Track by 1 step.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues 