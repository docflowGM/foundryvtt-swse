{"_id":"4788389dadb5cb0a","name":"Stay Up","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, when you would normally take damage from an attack, you can instead choose to take half damage and move -1 step along the Condition Track.","prerequisite":"Trained in Endurance","special":"","normalText":"","sourcebook":"Scum and Villainy","page":28,"tags":["condition_track","defense","feat","general","survivability"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Trained<br>in<br>Endurance</p>\n<p><strong>Effect:</strong> Once per encounter, when you would normally take damage from an attack, you can instead choose to take half damage and move -1 step along the<br>Condition Track<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Stay_Up</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"35df8faa4878f2c5"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"executionModel":"PASSIVE","subType":"RULE","mechanicsMode":"active","applicationScope":"damage_reduction_condition_tradeoff","staticSheetPolicy":"reaction_metadata","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Stay Up: once per encounter take half damage from an attack and move -1 step on the Condition Track.","predicateRequirements":[],"metadataPhase":"phase16-next-feat-batch","metadataNotes":"Phase 16 applies the latest user triage, implements another description-guided feat batch, and keeps positioning/GM-heavy rules as explicit metadata instead of false numeric bonuses.","implementationStatus":"damage_reaction_metadata_phase16","description":"Stay Up: once per encounter take half damage from an attack and move -1 step on the Condition Track.","modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Stay Up: