{"_id":"d133d3fad058c35f","name":"Master Tracker","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Increase the die type when adding Force Points to a Survival check.","prerequisite":"Rodian","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","feat","force_point_spend","racial","resource_spend","skill_survival","skill_synergy","species","species_opportunity","species_rule"],"bonus_feat_for":["species-rodian"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Rodian</p>\n<p><strong>Effect:</strong> Whenever you spend a<br>Force Point<br>to add to a<br>Survival<br>check, increase the die type by two steps (From d6 to d10, or from d8 to d12).</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Master_Tracker</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Master Tracker: increase Force Point die type on Survival checks.","rules":[{"type":"FORCE_POINT_DIE_STEP","value":1,"domains":["skill"],"skills":["survival"],"description":"Increase the die type when adding Force Points to a Survival check."}],"mechanicsMode":"passive","applicationScope":"rule_hook","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Implemented by a rule hook; exact static-sheet behavior depends on the consuming engine.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Increase the die type when adding Force Points to a Survival check.","sourceUrl":"https://swse.fandom.com/wiki/Master_Tracker","rawImport":{"name":"Master Tracker","url":"https://swse.fandom.com/wiki/Master_Tracker","pageTitle":"Master_Tracker","htmlCachePath":"C:\