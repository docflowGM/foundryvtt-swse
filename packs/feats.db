{"_id":"03593bdccdd70fa2","name":"Galactic Alliance Military Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You do not move down the Condition Track the first time an attack exceeds your Damage Threshold in an encounter.","prerequisite":"None","special":"","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":19,"tags":["background_opportunity","condition_track","damage_threshold","faction_training","feat","general","military","species_opportunity"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> You do not move down the<br>Condition Track<br>the first time an attack exceeds your<br>Damage Threshold<br>in an encounter.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Galactic_Alliance_Military_Training</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Prevent the first condition-track movement from damage exceeding DT each encounter.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"damage_resolution_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Prevent the first condition-track movement from damage exceeding DT each encounter.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"damage_rule_phase14","resourceRules":{"damage":[{"type":"PREVENT_FIRST_THRESHOLD_EXCEEDANCE_PER_ENCOUNTER","description":"First time each encounter damage exceeds DT, do not move down the Condition Track."}]}},"resourceRules":{"damage":[{"type":"PREVENT_FIRST_THRESHOLD_EXCEEDANCE_PER_ENCOUNTER"}]},"shortSummary":"You do not move down the Condition Track the first time an attack exceeds your Damage Threshold.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Galactic_Alliance_Military_Training","effect":"You do not move down the\nCondition Track\nthe first time an attack exceeds your\nDamage Threshold\nin an encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[],"id":"swse.feat.galactic_alliance_military_training","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Galactic_Alliance_Military_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0365722a629eed1f","name":"Increased Resistance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Fortitude Defense when an enemy fails to affect you.","prerequisite":"Gamorrean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["Gamorrean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Gamorrean</p>\n<p><strong>Effect:</strong> Whenever an attack or<br>Skill Check<br>targets your<br>Fortitude Defense<br>and fails to equal or exceed it, you gain a +2 circumstance bonus to your<br>Fortitude Defense<br>until the start of your next turn.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Increased_Resistance</em></p>\n<p><strong>Automation:</strong> Punted to GM/player handling. If an attack or skill check misses your Fortitude Defense, the GM/player should manually track the +2 circumstance bonus to Fortitude Defense until the start of your next turn.</p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":2,"type":"untyped","predicates":["defense.fortitude"],"enabled":false,"priority":500,"description":"Feat: GM/player-managed; no automatic modifier is applied. Punted to GM/player handling. If an attack or skill check misses your Fortitude Defense, the GM/player should manually track the +2 circumstance bonus to Fortitude Defense until the start of your next turn.","mechanicsMode":"gm_managed","applicationScope":"table_adjudicated","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.fortitude"],"conditionSummary":"Triggered Fortitude bonus after an enemy fails to affect your Fortitude Defense; tracked as a temporary defense rider, not a permanent bonus."}],"mechanicsMode":"gm_managed","applicationScope":"table_adjudicated","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Punted to GM/player handling. If an attack or skill check misses your Fortitude Defense, the GM/player should manually track the +2 circumstance bonus to Fortitude Defense until the start of your next turn.","predicateRequirements":["defense.fortitude"],"metadataPhase":"phase23-feat-cleanup","metadataNotes":"Phase 12 continues description-guided feat implementation by replacing false scaffold bonuses with explicit roll options, contextual predicates, resource/rider metadata, or supported static rules.","status":"gm_managed_phase23","description":"Punted to GM/player handling. If an attack or skill check misses your Fortitude Defense, the GM/player should manually track the +2 circumstance bonus to Fortitude Defense until the start of your next turn.","gmManaged":true,"archived_triggeredDefenseRules":[{"id":"increased_resistance_fortitude","type":"TEMPORARY_DEFENSE_BONUS_ON_FAILED_ATTACK","defense":"fortitude","value":2,"bonusType":"circumstance","duration":"untilStartOfNextTurn","trigger":"attackOrSkillFailsAgainstFortitude"}]},"shortSummary":"Gain a bonus to Fortitude Defense when an enemy fails to affect you.","sourceUrl":"https://swse.fandom.com/wiki/Increased_Resistance","rawImport":{"name":"Increased Resistance","url":"https://swse.fandom.com/wiki/Increased_Resistance","pageTitle":"Increased_Resistance","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\increased_resistance.html","referenceBooks":[],"prerequisitesText":"Gamorrean","prerequisites":["Gamorrean"],"effect":"Whenever an attack or\nSkill Check\ntargets your\nFortitude Defense\nand fails to equal or exceed it, you gain a +2 circumstance bonus to your\nFortitude Defense\nuntil the start of your next turn.","benefit":"","normal":"","special":"","indexPrerequisites":"Gamorrean","indexBenefit":"Gain a bonus to Fortitude Defense when an enemy fails to affect you.","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou remain resilient against attacks that target your vitality, making it difficult for enemies to sap your strength.\n\nPrerequisite:\nGamorrean\n\nEffect:\nWhenever an attack or\nSkill Check\ntargets your\nFortitude Defense\nand fails to equal or exceed it, you gain a +2 circumstance bonus to your\nFortitude Defense\nuntil the start of your next turn."},"prerequisitesText":"Gamorrean","effect":"Whenever an attack or\nSkill Check\ntargets your\nFortitude Defense\nand fails to equal or exceed it, you gain a +2 circumstance bonus to your\nFortitude Defense\nuntil the start of your next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["defense.fortitude"],"id":"swse.feat.increased_resistance"}}}
{"_id":"03e16cbf16cdc81d","name":"Slippery Maneuver","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can apply the effects of the Dodge Feat against attacks made from two opponents. In addition, when you use the Withdraw Action to move away from a target against whom you use the Dodge Feat, you can move at your full Speed. You still provoke an Attack of Opportunity if you must move more than 1 square to escape a Threatened Area.","prerequisite":"Dodge","special":"","normalText":"The benefit of Dodge applies to one target. Once you clear a Threatened Area, you can continue to move up to a total of half you Speed.","sourcebook":"Galaxy at War","page":27,"tags":["feat","general"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Dodge</p>\n<p><strong>Effect:</strong> You can apply the effects of the<br>Dodge<br>Feat against attacks made from two opponents. In addition, when you use the<br>Withdraw<br>Action to move away from a target against whom you use the<br>Dodge<br>Feat, you can move at your full Speed. You still provoke an<br>Attack of Opportunity<br>if you must move more than 1 square to escape a<br>Threatened Area<br>.</p>\n<p><strong>Normal:</strong> The benefit of<br>Dodge<br>applies to one target. Once you clear a<br>Threatened Area<br>, you can continue to move up to a total of half you Speed.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Slippery_Maneuver</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"Slippery Maneuver: No static bonus; handled as Dodge-target capacity and Withdraw movement metadata.","mechanicsMode":"manual","applicationScope":"metadata_only","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":[],"conditionSummary":"No static bonus; handled as Dodge-target capacity and Withdraw movement metadata."}],"mechanicsMode":"conditional","applicationScope":"dodge_withdraw_context","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Dodge can cover two opponents; Withdraw from a Dodge target can use full speed.","predicateRequirements":[],"metadataPhase":"phase11-feat-implementation-continuation","metadataNotes":"Phase 11 uses refreshed descriptions to replace manual/scaffold metadata with executable defense/skill/attack-option rules or explicit safe metadata for future hooks.","status":"defense_movement_metadata_phase11","description":"Dodge can cover two opponents; Withdraw from a Dodge target can use full speed.","dodgeRules":[{"type":"DODGE_TARGET_CAPACITY","maxTargets":2,"description":"Apply Dodge against attacks from two opponents."}],"movementRules":[{"type":"WITHDRAW_FULL_SPEED_FROM_DODGE_TARGET","description":"When withdrawing from a Dodge target, move at full speed rather than half speed."}]},"shortSummary":"Dodge two targets, Withdraw at full Speed.","prerequisitesText":"Dodge","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Slippery_Maneuver","effect":"You can apply the effects of the\nDodge\nFeat against attacks made from two opponents. In addition, when you use the\nWithdraw\nAction to move away from a target against whom you use the\nDodge\nFeat, you can move at your full Speed. You still provoke an\nAttack of Opportunity\nif you must move more than 1 square to escape a\nThreatened Area\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":[],"id":"swse.feat.slippery_maneuver","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Slippery_Maneuver","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"047f06ec480d841f","name":"Primitive Warrior","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Deal +1 die of damage with Simple Weapons (Melee).","prerequisite":"Gamorrean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","execution_mapped_phase9","feat","racial","species","species_opportunity","species_rule"],"bonus_feat_for":["Gamorrean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Gamorrean</p>\n<p><strong>Effect:</strong> You deal +1 die of damage with<br>Simple Weapons (Melee)<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Primitive_Warrior</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Primitive Warrior: +1 die of damage with Simple Weapons (Melee). Exposed as a weapon damage die-step rule hook.","rules":[{"type":"WEAPON_DAMAGE_DIE_STEP","value":1,"weaponGroups":["simpleWeaponsMelee","simple-weapons-melee","simple melee"],"description":"Deal +1 die of damage with Simple Weapons (Melee)."}],"conditionNotes":[{"id":"primitive-warrior","label":"Primitive Warrior","severity":"info","text":"+1 damage die with Simple Weapons (Melee).","mechanical":true,"gmEnforced":false}],"mechanicsMode":"passive","applicationScope":"rule_hook","staticSheetPolicy":"contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Implemented by a rule hook; exact static-sheet behavior depends on the consuming engine.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"Deal +1 die of damage with Simple Weapons (Melee).","sourceUrl":"https://swse.fandom.com/wiki/Primitive_Warrior","rawImport":{"name":"Primitive Warrior","url":"https://swse.fandom.com/wiki/Primitive_Warrior","pageTitle":"Primitive_Warrior","htmlCachePath":"C:\\Users\\Owner\\Downloads\\swse_cache\\feats_html\\primitive_warrior.html","referenceBooks":[],"prerequisitesText":"Gamorrean","prerequisites":["Gamorrean"],"effect":"You deal +1 die of damage with\nSimple Weapons (Melee)\n.","benefit":"","normal":"","special":"","indexPrerequisites":"Gamorrean","indexBenefit":"Deal +1 die of damage with Simple Weapons (Melee) .","indexPage":"Specialization_Feats","indexSection":"Species Feats","indexReferenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sections":[],"rawText":"Reference Book:\nStar Wars Saga Edition Rebellion Era Campaign Guide\n\nSee also:\nFeats\n,\nSpecies Feats\n\nYou have learned to make the most of primitive weapons and can wield them with deadly results.\n\nPrerequisite:\nGamorrean\n\nEffect:\nYou deal +1 die of damage with\nSimple Weapons (Melee)\n."},"prerequisitesText":"Gamorrean","effect":"You deal +1 die of damage with\nSimple Weapons (Melee)\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":[],"id":"swse.feat.primitive_warrior"}}}
{"_id":"0536f81eff886234","name":"Flurry","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When wielding only Light weapons or Lightsabers, you can make a flurry of attacks. You take a -5 penalty to your Reflex Defense, but you gain a +2 bonus on your melee attack rolls. This bonus on attacks and penalty to Reflex Defense apply until the start of your next turn.","prerequisite":"Dexterity 13","special":"You can use this Feat in place of the Point-Blank Shot Feat to qualify for the Elite Trooper Prestige Class.","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":26,"tags":["attack_option","execution_mapped_phase8","feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Dexterity<br>13</p>\n<p><strong>Effect:</strong> When wielding only Light weapons or<br>Lightsabers<br>, you can make a flurry of attacks. You take a -5 penalty to your<br>Reflex Defense<br>, but you gain a +2 bonus on your melee attack rolls. This bonus on attacks and penalty to<br>Reflex Defense<br>apply until the start of your next turn.</p>\n<p><strong>Special:</strong> You can use this Feat in place of the<br>Point-Blank Shot<br>Feat to qualify for the<br>Elite Trooper<br>Prestige Class.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Flurry</em></p>","prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":false,"priority":500,"description":"Flurry is implemented as an explicit attack option, not a passive attack modifier.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["defense.reflex"],"conditionSummary":"Flurry is implemented as an explicit attack option, not a passive attack modifier."}],"mechanicsMode":"active","applicationScope":"attack_option","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"With only light weapons or lightsabers, gain +2 attack and take -5 Reflex until next turn.","predicateRequirements":["defense.reflex"],"metadataPhase":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics.","status":"attack_option_phase8","description":"Flurry: light melee/lightsaber attack option with Reflex penalty rider.","rules":[{"type":"ATTACK_OPTION","option":"flurry","label":"Flurry","control":"toggle","requiresAttackType":"melee","requiresWeaponGroups":["light","lightsaber"],"attackModifier":2,"defenseModifier":{"target":"defense.reflex","type":"untyped","value":-5,"duration":"untilStartOfNextTurn"},"summary":"With only light weapons or lightsabers, gain +2 attack and take -5 Reflex until next turn."}]},"shortSummary":"Increases attack bonus, with penalties to Reflex Defense.","prerequisitesText":"Dexterity 13","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Flurry","effect":"When wielding only Light weapons or\nLightsabers\n, you can make a flurry of attacks. You take a -5 penalty to your\nReflex Defense\n, but you gain a +2 bonus on your melee attack rolls. This bonus on attacks and penalty to\nReflex Defense\napply until the start of your next turn."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.flurry","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Flurry","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"05459ac4d439f229","name":"Point-Blank Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You get a +1 bonus on attack and damage rolls with ranged weapons against opponents within Point-Blank Range.","prerequisite":"None","special":"This Feat works normally with Vehicle Weapons. However, if you are using a Missile or a Torpedo and you miss with your attack roll, the projectile does not gain the benefit of this Feat for the second attack roll.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["accuracy","damage_scaling","feat","feat_chain","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> You get a +1 bonus on attack and damage rolls with ranged weapons against opponents within Point-Blank<br>Range<br>.</p>\n<p><strong>Special:</strong> This Feat works normally with<br>Vehicle Weapons<br>. However, if you are using a<br>Missile<br>or a<br>Torpedo<br>and you miss with your attack roll, the projectile does not gain the benefit of this Feat for the second attack roll.</p>\n<h3>Additional Rangefinders and Targeting Scopes</h3><p>Reference Book:<br>Star Wars Saga Edition Galaxy at War<br><br>Under most circumstances, a character with the Point-Blank Shot Feat receives a bonus to attack rolls and damage rolls only when the target is within his or her weapon&#x27;s Point-Blank<br>Range<br>.<br><br>The use of a<br>Targeting Scope<br>does not change how far your target is from you, so taking an<br>Aim<br>Action with a<br>Targeting Scope<br>on a<br>Blaster Rifle<br>to attack a target that is 50 squares away does not give you the +1 bonus to attack rolls and damage rolls that you would receive if the target were within 30 squares. This is the same for the<br>Rangefinder<br>upgrade, which negates the penalty for attacking a target that is at Short<br>Range<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Point-Blank_Shot</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack.bonus","value":1,"type":"untyped","predicates":["attack.with-ranged","range.within-point-blank"],"enabled":true,"priority":500,"description":"Point-Blank Shot: +1 ranged attack within point-blank range","mechanicsMode":"conditional","applicationScope":"ranged_attack_range_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.with-ranged","range.within-point-blank"],"conditionSummary":"Applies only to ranged attack and damage rolls against a target within point-blank range. Never add to static sheet totals."},{"target":"damage.ranged","value":1,"type":"untyped","predicates":["attack.with-ranged","range.within-point-blank"],"enabled":true,"priority":500,"description":"Point-Blank Shot: +1 ranged damage within point-blank range","mechanicsMode":"conditional","applicationScope":"ranged_attack_range_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["attack.with-ranged","range.within-point-blank"],"conditionSummary":"Applies only to ranged attack and damage rolls against a target within point-blank range. Never add to static sheet totals."}],"mechanicsMode":"conditional","applicationScope":"ranged_attack_range_context","staticSheetPolicy":"roll_context_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Applies only to ranged attack and damage rolls against a target within point-blank range. Never add to static sheet totals.","predicateRequirements":["attack.with-ranged","range.within-point-blank"],"metadataPhase":"phase9-feat-implementation-continuation","metadataNotes":"CombatOptionResolver now consumes safe roll-context damage modifiers such as damage.ranged with range.within-point-blank.","status":"roll_modifier_consumed_phase9","description":"Point-Blank Shot: +1 ranged attack and +1 ranged damage within point-blank range. Damage modifier is now consumed by CombatOptionResolver."},"shortSummary":"+1 bonus on ranged attacks and damage against foes within Point-Blank Range.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Point-Blank_Shot","effect":"You get a +1 bonus on attack and damage rolls with ranged weapons against opponents within Point-Blank\nRange\n."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.point_blank_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Point-Blank_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"058de949e909d9ae","name":"Low Profile","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain cover from enemies at long range and may reroll Stealth checks made to avoid detection.","prerequisite":"Dex 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["feat","general","stealth"],"bonus_feat_for":["b5bed5d1b5f42958","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8","description":"Low Profile: reroll Stealth checks and keep the better result.","skillRerolls":[{"id":"low-profile","skillKeys":["stealth"],"outcome":"keepBetter","label":"Low Profile","description":"Low Profile: reroll Stealth checks to avoid detection and keep the better result."}],"mechanicsMode":"conditional","applicationScope":"reroll_or_resource_context","staticSheetPolicy":"manual_or_contextual_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Rerolls/resources are not static sheet modifiers and require a check/encounter/resource context.","predicateRequirements":[],"metadataPhase":"phase3-static-vs-context","metadataNotes":"Phase 3 classification separates true static sheet bonuses from roll/target/action/choice-specific mechanics."},"shortSummary":"You gain cover from enemies at long range and may reroll Stealth checks made to avoid detection."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":[]}}}
{"_id":"05d8053002347946","name":"Fast Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"On your turn, you can catch a Second Wind as a Free Action instead of a Swift Action.","prerequisite":"None","special":"","normalText":"","sourcebook":"Jedi Academy Training Manual","page":30,"tags":["action_economy","defense","execution_mapped_phase8","feat","force","free_action","recovery","resource_second_wind","second_wind","survivability"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> None</p>\n<p><strong>Effect:</strong> On your turn, you can catch a<br>Second Wind<br>as a<br>Free Action<br>instead of a<br>Swift Action<br>.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Fast_Surge</em></p>","executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.on-current-turn"],"enabled":false,"priority":500,"description":"Fast Surge changes Second Wind action economy, not attack rolls.","mechanicsMode":"conditional","applicationScope":"runtime_predicate_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"predicateRequirements":["turn.on-current-turn"],"conditionSummary":"Fast Surge changes Second Wind action economy, not attack rolls."}],"resourceRules":{"secondWind":[{"type":"ACTION_COST","action":"free","description":"Catch a Second Wind as a Free Action on your turn."}]},"mechanicsMode":"passive_resource","applicationScope":"secondWind_resource","staticSheetPolicy":"resource_only","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Second Wind action-cost metadata is consumed by SecondWindRules/ActorEngine.","predicateRequirements":["turn.on-current-turn"],"metadataPhase":"phase8-feat-implementation-continuation","metadataNotes":"Phase 3 classification separates true static she