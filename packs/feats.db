{"_id":"dd6ad0e712e9a314","name":"Spacer's Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a temporary Force Point when you roll a Natural 20 on a Pilot check.","prerequisite":"Duros","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["defense","feat","force_point_spend","racial","resource_spend","skill_pilot","skill_synergy","species","species_opportunity","survivability"],"bonus_feat_for":["species-duros"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":"<p><strong>Prerequisites:</strong> Duros</p>\n<p><strong>Effect:</strong> Whenever you roll a Natural 20 on a<br>Pilot<br>check, you gain 1 temporary<br>Force Point<br>. If that Force Point is not spent before the end of the encounter, it is lost.</p>\n<p><em>Source URL: https://swse.fandom.com/wiki/Spacer&#x27;s_Surge</em></p>","executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"metadata","value":0,"type":"untyped","enabled":false,"priority":500,"description":"Temporary Force Point trigger on natural 20 Pilot checks.","mechanicsMode":"metadata_only","applicationScope":"non_static_context","staticSheetPolicy":"exclude"}],"mechanicsMode":"conditional","applicationScope":"skill_roll_trigger_context","staticSheetPolicy":"exclude","requiresRuntimeContext":true,"requiresSelectedChoice":false,"conditionSummary":"Temporary Force Point trigger on natural 20 Pilot checks.","predicateRequirements":[],"metadataPhase":"phase14-next-feat-implementation-batch","metadataNotes":"Phase 14 continues description-guided feat implementation: Force-skill bonuses, attack rerolls, condition-track rules, weapon-family rules, and safe action/resource metadata.","executionModel":"PASSIVE","subType":"RULE","implementationStatus":"temporary_force_point_metadata_phase14","resourceRules":{"forcePoints":[{"type":"TEMPORARY_FORCE_POINT_ON_SKILL_NATURAL_20","skillKey":"pilot","value":1,"description":"Gain 