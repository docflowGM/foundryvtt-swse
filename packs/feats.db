{"_id":"d40dea327376ec90","name":"Bothan Will","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Will Defense when an enemy fails to overcome your iron will.","prerequisite":"Bothan","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["defense","feat","racial","species","species_opportunity","survivability"],"bonus_feat_for":["species-bothan"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to Will Defense when an enemy fails to overcome your iron will."},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"defense.will","type":"untyped","value":1,"enabled":true,"priority":500,"description":"Migrated from AE system.defenses.will.misc"}]},"shortSummary":"Gain a bonus to Will Defense when an enemy fails to overcome your iron will."},"effects":[{"_id":"5e3995c0-0142-45f4-a0d7-27e1f0f89562","name":"Bothan Will","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.defenses.will.misc","mode":2,"value":"1"}],"disabled":true,"duration":{},"flags":{"swse":{"source":"feat","featName":"Bothan Will","effectType":"will_defense_bonus","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.bothan_will"}}}
{"_id":"d41076e442832c3e","name":"Natural Leader","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You become the leader of an Organization of your design. The Organization has a scale equal to one-half your Heroic Level plus your Charisma bonus and continues to grow in scale as you gain levels. You automatically begin with a +10 bonus to your Organization Score for your new Organization.","prerequisite":"Charisma 13","special":"","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":88,"tags":["feat","general","social"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Force Unleashed Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Natural_Leader</p>\n<p>You are a natural leader, and you founded your own Organization.</p>\n<p><strong>Prerequisites:</strong> Charisma 13</p>\n<h4>Effect</h4>\n<p>You become the leader of an Organization of your design. The Organization has a scale equal to one-half your Heroic Level plus your Charisma bonus and continues to grow in scale as you gain levels. You automatically begin with a +10 bonus to your Organization Score for your new Organization.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"cha","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"skill","value":1,"type":"untyped","predicates":["turn.once-per-round"],"enabled":true,"priority":500,"description":"Natural Leader"}]},"shortSummary":"You become the leader of an Organization.","prerequisitesText":"Charisma 13","referenceBooks":["Star Wars Saga Edition Force Unleashed Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Natural_Leader"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":["turn.once-per-round"],"id":"swse.feat.natural_leader","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Natural_Leader","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d445051370a88a7f","name":"Armor Proficiency (medium)","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you wear Medium Armor, you take no Armor Check Penalty on attack rolls or Skill Checks. Additionally, you benefit from all of the armor's special Equipment bonuses (if any).","prerequisite":"Armor Proficiency (Light) Feat","special":"","normalText":"A character who wears Medium Armor with which they are not proficient takes a -5 Armor Check Penalty on attack rolls as well as Skill Checks made using the following Skills: Acrobatics, Climb, Endurance, Initiative, Jump, Stealth, and Swim. Additionally, the character gains none of the armor's special Equipment bonuses.","sourcebook":"Saga Edition Core Rulebook","page":85,"tags":["armor","build_enabler","defense","feat","general","mapped_phase_1","unlock_grant","choice_variant","armor_access"],"bonus_feat_for":["f62ca2e639cab614"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Core Rulebook</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Armor_Proficiency_(Medium)</p>\n<p>You are proficient with Medium Armor, and can wear it without impediment.</p>\n<p><strong>Prerequisites:</strong> Armor Proficiency (Light) Feat</p>\n<h4>Effect</h4>\n<p>When you wear Medium Armor, you take no Armor Check Penalty on attack rolls or Skill Checks. Additionally, you benefit from all of the armor&#x27;s special Equipment bonuses (if any).</p>\n<h4>Normal</h4>\n<p>A character who wears Medium Armor with which they are not proficient takes a -5 Armor Check Penalty on attack rolls as well as Skill Checks made using the following Skills: Acrobatics, Climb, Endurance, Initiative, Jump, Stealth, and Swim. Additionally, the character gains none of the armor&#x27;s special Equipment bonuses.</p>\n</div>"},"executionModel":"UNLOCK","abilityMeta":{"grants":[{"category":"PROFICIENCY","proficiencyType":"armor","proficiencies":["light","medium"],"description":"Armor proficiency: light, medium"}]},"choiceMeta":{"resolution":"already_resolved_static_variant","required":false,"choiceKind":"armor_proficiency","value":"medium","grants":["light","medium"]},"shortSummary":"No penalty on attacks and no Armor Check Penalty while wearing Light Armor or Medium Armor.","prerequisitesText":"Armor Proficiency (Light) Feat","referenceBooks":["Star Wars Saga Edition Core Rulebook"],"sourceUrl":"https://swse.fandom.com/wiki/Armor_Proficiency_(Medium)"},"effects":[{"_id":"af0983df-e771-4593-8f88-f0aa43612597","name":"Armor Proficiency (Medium)","icon":"icons/svg/upgrade.svg","changes":[{"key":"system.armorProficiency.medium","mode":5,"value":"true"}],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Armor Proficiency (Medium)","effectType":"armor_proficiency"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":[],"phase1Mapped":true,"manualMappingResolved":true,"featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Armor_Proficiency_(Medium)","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d48614f7ae500a5b","name":"Logic Upgrade: Skill Swap","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Swap a Trained Skill for an Untrained Skill on the fly.","prerequisite":"Droid, Basic Processor","special":"","normalText":"","sourcebook":"Scavenger's Guide to Droids","page":22,"tags":["feat","general","knowledge","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Swap a Trained Skill for an Untrained Skill on the fly."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Logic Upgrade: Skill Swap"}]},"shortSummary":"Swap a Trained Skill for an Untrained Skill on the fly."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":[],"id":"swse.feat.logic_upgrade_skill_swap"}}}
{"_id":"d518e8c1220af930","name":"Droid Shield Mastery","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You automatically succeed on Endurance checks to restore your Shield Rating by 5 points (up to your normal Shield Rating). Additionally, you replenish your shields in two Swift Actions.","prerequisite":"Droid, Shield Generator (Droid Accessory)","special":"","normalText":"Three Swift Actions and a DC 20 Endurance check are normally required to restore lost shield power.","sourcebook":"Scavenger's Guide to Droids","page":20,"tags":["action_economy","ally_support","charge","feat","general","swift_action","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scavenger&#x27;s Guide to Droids</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Droid_Shield_Mastery</p>\n<p>You quickly replenish your onboard shields.</p>\n<p><strong>Prerequisites:</strong> Droid, Shield Generator (Droid Accessory)</p>\n<h4>Effect</h4>\n<p>You automatically succeed on Endurance checks to restore your Shield Rating by 5 points (up to your normal Shield Rating). Additionally, you replenish your shields in two Swift Actions.</p>\n<h4>Normal</h4>\n<p>Three Swift Actions and a DC 20 Endurance check are normally required to restore lost shield power.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Droid Shield Mastery"}]},"shortSummary":"Automatically Recharge Shields in two Swift Actions.","prerequisitesText":"Droid, Shield Generator (Droid Accessory)","referenceBooks":["Star Wars Saga Edition Scavenger's Guide to Droids"],"sourceUrl":"https://swse.fandom.com/wiki/Droid_Shield_Mastery"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":[],"id":"swse.feat.droid_shield_mastery","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Droid_Shield_Mastery","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d612e7a708edf75b","name":"Frightening Presence","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you use Frightful Presence, targets that fail their Will Defense check move -2 steps down the condition track instead of -1.","prerequisite":"Charisma 15, Frightful Presence","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":25,"tags":["control","feat","general","social"],"bonus_feat_for":["8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will"],"enabled":true,"priority":500,"description":"Frightening Presence"}]},"shortSummary":"When you use Frightful Presence, targets that fail their Will Defense check move -2 steps down the condition track instead of -1."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.387Z","detectedPredicates":["defense.will"]}}}
{"_id":"d6e528de87b25b95","name":"Wary Defender","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you use the Fight Defensively Action, you gain a +2 competence bonus to your Fortitude Defense and Will Defense until the beginning of your next turn.","prerequisite":"None","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":29,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Wary_Defender</p>\n<p>Even in the heat of battle you can bolster yourself against nearly anything that comes your way.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>When you use the Fight Defensively Action, you gain a +2 competence bonus to your Fortitude Defense and Will Defense until the beginning of your next turn.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.fortitude","defense.will"],"enabled":true,"priority":500,"description":"Wary Defender"}]},"shortSummary":"Gain a +2 bonus to Fortitude Defense and Will Defense while Fighting Defensively.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Wary_Defender"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["defense.fortitude","defense.will"],"id":"swse.feat.wary_defender","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Wary_Defender","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d7736c072de9b86c","name":"Vehicle Systems Expertise","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You may use the Recharge Shields or Reroute Power Actions by spending two Swift Actions. Also, once per encounter, you may attempt to use either of these Actions as a single Swift Action by making a DC 30 Mechanics check.","prerequisite":"Tech Specialist, Trained in Mechanics.","special":"","normalText":"The Recharge Shields and Reroute Power Actions normally requires you to spend three Swift Actions.","sourcebook":"Legacy Era Campaign Guide","page":22,"tags":["charge","feat","general","tech","utility","vehicle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Vehicle_Systems_Expertise</p>\n<p>You may use your technical expertise to manipulate a Vehicle&#x27;s systems more quickly than usual.</p>\n<p><strong>Prerequisites:</strong> Tech Specialist, Trained in Mechanics.</p>\n<h4>Effect</h4>\n<p>You may use the Recharge Shields or Reroute Power Actions by spending two Swift Actions. Also, once per encounter, you may attempt to use either of these Actions as a single Swift Action by making a DC 30 Mechanics check.</p>\n<h4>Normal</h4>\n<p>The Recharge Shields and Reroute Power Actions normally requires you to spend three Swift Actions.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"745a5686d6f21e8c"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Vehicle Systems Expertise"}]},"shortSummary":"Recharge Shields or Reroute Power on a Vehicle faster than normal.","prerequisitesText":"Tech Specialist, Trained in Mechanics.","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Vehicle_Systems_Expertise"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.vehicle_systems_expertise","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Vehicle_Systems_Expertise","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d7a139003afc04b8","name":"Indomitable Personality","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"Once per encounter, you can add your Charisma modifier to your Will Defense as a Reaction; this benefit lasts until the end of your next turn.","prerequisite":"Charisma 13","special":"","normalText":"","sourcebook":"Galaxy of Intrigue","page":21,"tags":["ability_charisma","feat","general","reaction"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy of Intrigue</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Indomitable_Personality</p>\n<p>Your powerful personality helps you cope with attacks that assault your will.</p>\n<p><strong>Prerequisites:</strong> Charisma 13</p>\n<h4>Effect</h4>\n<p>Once per encounter, you can add your Charisma modifier to your Will Defense as a Reaction; this benefit lasts until the end of your next turn.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.will"],"enabled":true,"priority":500,"description":"Indomitable Personality"}]},"shortSummary":"Add your Charisma bonus to your Will Defense as a Reaction.","prerequisitesText":"Charisma 13","referenceBooks":["Star Wars Saga Edition Galaxy of Intrigue"],"sourceUrl":"https://swse.fandom.com/wiki/Indomitable_Personality"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["defense.will"],"id":"swse.feat.indomitable_personality","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Indomitable_Personality","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d874a33284de77e4","name":"Fast Swimmer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to your Swim Speed.","prerequisite":"Mon Calamari","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","skill_swim","skill_synergy","species","species_opportunity"],"bonus_feat_for":["species-mon-calamari"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to your Swim Speed."},"executionModel":"PASSIVE","subType":"MODIFIER","abilityMeta":{"modifiers":[{"target":"speed.base","type":"untyped","value":2,"enabled":true,"priority":500,"description":"Migrated from flag AE: Fast Swimmer"}],"rules":[]},"shortSummary":"Gain a bonus to your Swim Speed."},"effects":[{"_id":"023f0cf2-0c15-4090-ac2d-78a65e120824","name":"Fast Swimmer","icon":"icons/svg/upgrade.svg","changes":[],"disabled":true,"duration":{},"flags":{"swse":{"source":"feat","featName":"Fast Swimmer","effectType":"passive_effect","flagType":"Fast Swimmer","migratedToPassive":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"id":"swse.feat.fast_swimmer"}}}
{"_id":"d976f03c298fb1be","name":"Officer Candidacy Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus to your Rank and Privilege Organization Score.","prerequisite":"None","special":"","normalText":"","sourcebook":"Galaxy at War","page":25,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Officer_Candidacy_Training</p>\n<p>You have received special training in commanding others in combat.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You gain a +2 bonus to your Rank and Privilege Organization Score.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Officer Candidacy Training"}]},"shortSummary":"Gain a bonus to your Rank and Privilege Score.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Officer_Candidacy_Training"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.officer_candidacy_training","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Officer_Candidacy_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"d9ecf143e6a9f889","name":"Critical Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"While wielding a weapon for which you possess the Weapon Focus feat, you can take two consecutive Swift Actions in the same round to increase the critical threat range of your next melee attack by 1.\n\nThus, if a weapon scores a Critical Hit on a Natural 20, it can score a Critical Hit on a natural roll of 19 or 20 instead. However, any roll other than a Natural 20 is not considered an automatic hit; if you roll a Natural 19 and miss the target, you do not score a Critical Hit. You lose the benefits of Critical Strike if you lose line of sight to your target or if you take any other Action before making your attack.","prerequisite":"Base Attack Bonus +9, Weapon Focus (Chosen Weapon)","special":"","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":25,"tags":["feat","general","offense","offense_melee"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Critical_Strike</p>\n<p>At the cost of speed, you can make a devastating attack.</p>\n<p><strong>Prerequisites:</strong> Base Attack Bonus +9, Weapon Focus (Chosen Weapon)</p>\n<h4>Effect</h4>\n<p>While wielding a weapon for which you possess the Weapon Focus feat, you can take two consecutive Swift Actions in the same round to increase the critical threat range of your next melee attack by 1.</p>\n<p>Thus, if a weapon scores a Critical Hit on a Natural 20, it can score a Critical Hit on a natural roll of 19 or 20 instead. However, any roll other than a Natural 20 is not considered an automatic hit; if you roll a Natural 19 and miss the target, you do not score a Critical Hit. You lose the benefits of Critical Strike if you lose line of sight to your target or if you take any other Action before making your attack.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"bab","min":9}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Critical Strike"}]},"shortSummary":"Increase critical threat range of an attack.","prerequisitesText":"Base Attack Bonus +9, Weapon Focus (Chosen Weapon)","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Critical_Strike"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.critical_strike","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Critical_Strike","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"da2e6fb7a11b3d63","name":"Pistoleer","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When you make a ranged attack with a Pistol with which you are proficient, you gain one of the following benefits, depending on the kind of Pistol you use.\n\n- Blaster Pistol: You treat the Blaster Pistol as an Accurate Weapon.\n- Heavy Blaster Pistol: You do not treat the Heavy Blaster Pistol as an Inaccurate Weapon.\n- Hold-Out Blaster Pistol: If you fire a Hold-Out Blaster Pistol at a target that has not yet acted in combat, you gain a +2 bonus to your attack rolls with that weapon against that target. This bonus applies to all such attacks until the target attacks.","prerequisite":"Weapon Proficiency (Pistols)","special":"","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["feat","general","offense_ranged","weapon_pistol"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Pistoleer</p>\n<p>You are skilled in the use of Pistols and gain certain benefits depending on which weapon you use.</p>\n<p><strong>Prerequisites:</strong> Weapon Proficiency (Pistols)</p>\n<h4>Effect</h4>\n<p>When you make a ranged attack with a Pistol with which you are proficient, you gain one of the following benefits, depending on the kind of Pistol you use.</p>\n<ul><li><strong>Blaster Pistol:</strong> You treat the Blaster Pistol as an Accurate Weapon.</li><li><strong>Heavy Blaster Pistol:</strong> You do not treat the Heavy Blaster Pistol as an Inaccurate Weapon.</li><li><strong>Hold-Out Blaster Pistol:</strong> If you fire a Hold-Out Blaster Pistol at a target that has not yet acted in combat, you gain a +2 bonus to your attack rolls with that weapon against that target. This bonus applies to all such attacks until the target attacks.</li></ul>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Pistoleer"}]},"shortSummary":"Gain benefits when using certain Pistols.","prerequisitesText":"Weapon Proficiency (Pistols)","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Pistoleer"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.pistoleer","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Pistoleer","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"da8e272f5dae09b9","name":"Tactical Genius","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You regain all spent Starship Maneuvers at the end of any round in which you roll a Natural 20 on an attack roll.","prerequisite":"Starship Tactics, Vehicular Combat, Trained in Pilot","special":"","normalText":"Only a Natural 20 rolled on a Pilot check to activate a Starship Maneuver restores all Starship Maneuvers.","sourcebook":"Starships of the Galaxy","page":30,"tags":["feat","general","vehicle"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Starships of the Galaxy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Tactical_Genius</p>\n<p>You are a master at using multiple starship tactics over the course of long space combats.</p>\n<p><strong>Prerequisites:</strong> Starship Tactics, Vehicular Combat, Trained in Pilot</p>\n<h4>Effect</h4>\n<p>You regain all spent Starship Maneuvers at the end of any round in which you roll a Natural 20 on an attack roll.</p>\n<h4>Normal</h4>\n<p>Only a Natural 20 rolled on a Pilot check to activate a Starship Maneuver restores all Starship Maneuvers.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Tactical Genius"}]},"shortSummary":"You are a master at using multiple starship tactics over the course of long space combats.","prerequisitesText":"Starship Tactics, Vehicular Combat, Trained in Pilot","referenceBooks":["Star Wars Saga Edition Starships of the Galaxy"],"sourceUrl":"https://swse.fandom.com/wiki/Tactical_Genius"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":[],"id":"swse.feat.tactical_genius","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Tactical_Genius","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"daf0594fbb48e61e","name":"Wilderness Specialists","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"team","benefit":"Gain bonuses on Survival checks when near allies.","prerequisite":"Trained in Survival","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["ally_support","feat","skill_survival","skill_synergy","team","teamwork","conditional_skill_bonus","execution_mapped_phase8"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain bonuses on Survival checks when near allies."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"conditional_skill_bonus_phase8","description":"Wilderness Specialists: +3 bonus to survival checks when the near-allies condition is confirmed.","skillCheckBonuses":[{"id":"wilderness-specialists","skillKeys":["survival"],"value":3,"type":"untyped","requiresContextFlags":["nearAllies"],"description":"Wilderness Specialists: +3 when near supporting allies."}]},"shortSummary":"Gain bonuses on Survival checks when near allies."},"effects":[{"_id":"4e6b6849-eae9-4126-ab01-44509e3fe819","name":"Wilderness Specialists","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Wilderness Specialists","effectType":"skill_bonus","requiresCustomLogic":true}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.388Z","detectedPredicates":["proximity.count-allies-within-12"],"id":"swse.feat.wilderness_specialists"}}}
