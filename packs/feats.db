{"_id":"029c3935e9bed6eb","name":"Expert Droid Repair","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can use Repair Droid to a number of Droids equal to your Intelligence modifier (Minimum 2) simultaneously. You make Mechanics checks for each Droid as normal.","prerequisite":"Trained in Mechanics","special":"","normalText":"","sourcebook":"Clone Wars Campaign Guide","page":22,"tags":["feat","general","tech","utility"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Clone Wars Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Expert_Droid_Repair</p>\n<p>You can repair multiple Droids simultaneously.</p>\n<p><strong>Prerequisites:</strong> Trained in Mechanics</p>\n<h4>Effect</h4>\n<p>You can use Repair Droid to a number of Droids equal to your Intelligence modifier (Minimum 2) simultaneously. You make Mechanics checks for each Droid as normal.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"skillTrained","skill":"745a5686d6f21e8c"}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Expert Droid Repair"}]},"shortSummary":"Repair multiple Droids simultaneously.","prerequisitesText":"Trained in Mechanics","referenceBooks":["Star Wars Saga Edition Clone Wars Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Expert_Droid_Repair"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[],"id":"swse.feat.expert_droid_repair","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Expert_Droid_Repair","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"02ac414f546a539a","name":"Forceful Strike","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"You may spend a Force Point to move a target -1 step down the condition track when using Force Stun.","prerequisite":"Trained in Use the Force, Force Stun","special":"","normalText":"","sourcebook":"The Force Unleashed Campaign Guide","page":34,"tags":["feat","force","offense","offense_melee"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Forceful Strike"}]},"shortSummary":"You may spend a Force Point to move a target -1 step down the condition track when using Force Stun."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[]}}}
{"_id":"03593bdccdd70fa2","name":"Galactic Alliance Military Training","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You do not move down the Condition Track the first time an attack exceeds your Damage Threshold in an encounter.","prerequisite":"None","special":"","normalText":"","sourcebook":"Legacy Era Campaign Guide","page":19,"tags":["background_opportunity","condition_track","damage_threshold","faction_training","feat","general","military","species_opportunity"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Legacy Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Galactic_Alliance_Military_Training</p>\n<p>Service in The Galactic Alliance has honed your toughness.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You do not move down the Condition Track the first time an attack exceeds your Damage Threshold in an encounter.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[]},"resourceRules":{"damage":[{"type":"PREVENT_FIRST_THRESHOLD_EXCEEDANCE_PER_ENCOUNTER"}]},"shortSummary":"You do not move down the Condition Track the first time an attack exceeds your Damage Threshold.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Legacy Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Galactic_Alliance_Military_Training"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.376Z","detectedPredicates":[],"id":"swse.feat.galactic_alliance_military_training","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Galactic_Alliance_Military_Training","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0365722a629eed1f","name":"Increased Resistance","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Gain a bonus to Fortitude Defense when an enemy fails to affect you.","prerequisite":"Gamorrean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["feat","racial","species","species_opportunity"],"bonus_feat_for":["Gamorrean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Gain a bonus to Fortitude Defense when an enemy fails to affect you."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.fortitude","value":2,"type":"untyped","predicates":["defense.fortitude"],"enabled":true,"priority":500,"description":"Increased Resistance"}]},"shortSummary":"Gain a bonus to Fortitude Defense when an enemy fails to affect you."},"effects":[{"_id":"1ff0c51e-0b38-4518-add6-25bb5eb5225f","name":"Increased Resistance","icon":"icons/svg/upgrade.svg","changes":[],"disabled":false,"duration":{},"flags":{"swse":{"source":"feat","featName":"Increased Resistance","effectType":"skill_bonus","flagType":"Increased Resistance"}}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["defense.fortitude"],"id":"swse.feat.increased_resistance"}}}
{"_id":"03e16cbf16cdc81d","name":"Slippery Maneuver","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You can apply the effects of the Dodge Feat against attacks made from two opponents. In addition, when you use the Withdraw Action to move away from a target against whom you use the Dodge Feat, you can move at your full Speed. You still provoke an Attack of Opportunity if you must move more than 1 square to escape a Threatened Area.","prerequisite":"Dodge","special":"","normalText":"The benefit of Dodge applies to one target. Once you clear a Threatened Area, you can continue to move up to a total of half you Speed.","sourcebook":"Galaxy at War","page":27,"tags":["feat","general"],"bonus_feat_for":["b5bed5d1b5f42958"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Scum and Villainy</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Slippery_Maneuver</p>\n<p>You are adept at finding ways out of tough situations.</p>\n<p><strong>Prerequisites:</strong> Dodge</p>\n<h4>Effect</h4>\n<p>You can apply the effects of the Dodge Feat against attacks made from two opponents. In addition, when you use the Withdraw Action to move away from a target against whom you use the Dodge Feat, you can move at your full Speed. You still provoke an Attack of Opportunity if you must move more than 1 square to escape a Threatened Area.</p>\n<h4>Normal</h4>\n<p>The benefit of Dodge applies to one target. Once you clear a Threatened Area, you can continue to move up to a total of half you Speed.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":0,"type":"untyped","predicates":[],"enabled":false,"priority":500,"description":"[REQUIRES MANUAL MAPPING] Slippery Maneuver"}]},"shortSummary":"Dodge two targets, Withdraw at full Speed.","prerequisitesText":"Dodge","referenceBooks":["Star Wars Saga Edition Scum and Villainy"],"sourceUrl":"https://swse.fandom.com/wiki/Slippery_Maneuver"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":[],"id":"swse.feat.slippery_maneuver","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Slippery_Maneuver","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"047f06ec480d841f","name":"Primitive Warrior","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"species","benefit":"Deal +1 die of damage with Simple Weapons (Melee).","prerequisite":"Gamorrean","special":"","normalText":"","sourcebook":"Star Wars Saga Edition","page":0,"tags":["execution_mapped_phase10","execution_mapped_phase9","feat","racial","species","species_opportunity","species_rule"],"bonus_feat_for":["Gamorrean"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"Deal +1 die of damage with Simple Weapons (Melee)."},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"species_rule_phase10_executable_hook","description":"Primitive Warrior: +1 die of damage with Simple Weapons (Melee). Exposed as a weapon damage die-step rule hook.","rules":[{"type":"WEAPON_DAMAGE_DIE_STEP","value":1,"weaponGroups":["simpleWeaponsMelee","simple-weapons-melee","simple melee"],"description":"Deal +1 die of damage with Simple Weapons (Melee)."}],"conditionNotes":[{"id":"primitive-warrior","label":"Primitive Warrior","severity":"info","text":"+1 damage die with Simple Weapons (Melee).","mechanical":true,"gmEnforced":false}]},"shortSummary":"Deal +1 die of damage with Simple Weapons (Melee)."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":[],"id":"swse.feat.primitive_warrior"}}}
{"_id":"0536f81eff886234","name":"Flurry","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"When wielding only Light weapons or Lightsabers, you can make a flurry of attacks. You take a -5 penalty to your Reflex Defense, but you gain a +2 bonus on your melee attack rolls. This bonus on attacks and penalty to Reflex Defense apply until the start of your next turn.","prerequisite":"Dexterity 13","special":"You can use this Feat in place of the Point-Blank Shot Feat to qualify for the Elite Trooper Prestige Class.","normalText":"","sourcebook":"Knights of the Old Republic Campaign Guide","page":26,"tags":["feat","general"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Knights of the Old Republic Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Flurry</p>\n<p>You attack using a series of quick strikes, sacrificing defense in the process.</p>\n<p><strong>Prerequisites:</strong> Dexterity 13</p>\n<h4>Effect</h4>\n<p>When wielding only Light weapons or Lightsabers, you can make a flurry of attacks. You take a -5 penalty to your Reflex Defense, but you gain a +2 bonus on your melee attack rolls. This bonus on attacks and penalty to Reflex Defense apply until the start of your next turn.</p>\n<h4>Special</h4>\n<p>You can use this Feat in place of the Point-Blank Shot Feat to qualify for the Elite Trooper Prestige Class.</p>\n</div>"},"prerequisitesStructured":{"type":"all","conditions":[{"type":"attribute","ability":"dex","min":13}],"_source":"canonical-csv"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["defense.reflex"],"enabled":true,"priority":500,"description":"Flurry"}]},"shortSummary":"Increases attack bonus, with penalties to Reflex Defense.","prerequisitesText":"Dexterity 13","referenceBooks":["Star Wars Saga Edition Knights of the Old Republic Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Flurry"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["defense.reflex"],"id":"swse.feat.flurry","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Flurry","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"05459ac4d439f229","name":"Point-Blank Shot","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You get a +1 bonus on attack and damage rolls with ranged weapons against opponents within Point-Blank Range.","prerequisite":"None","special":"This Feat works normally with Vehicle Weapons. However, if you are using a Missile or a Torpedo and you miss with your attack roll, the projectile does not gain the benefit of this Feat for the second attack roll.","normalText":"","sourcebook":"Saga Edition Core Rulebook","page":87,"tags":["accuracy","damage_scaling","feat","feat_chain","general","offense","offense_ranged"],"bonus_feat_for":[],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Point-Blank_Shot</p>\n<p>You are skilled at making well-placed shots with ranged weapons at Point-Blank Range.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>You get a +1 bonus on attack and damage rolls with ranged weapons against opponents within Point-Blank Range.</p>\n<h4>Special</h4>\n<p>This Feat works normally with Vehicle Weapons. However, if you are using a Missile or a Torpedo and you miss with your attack roll, the projectile does not gain the benefit of this Feat for the second attack roll.</p>\n<h4>Additional Rangefinders and Targeting Scopes</h4>\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Galaxy at War</p>\n<p>Under most circumstances, a character with the Point-Blank Shot Feat receives a bonus to attack rolls and damage rolls only when the target is within his or her weapon&#x27;s Point-Blank Range.</p>\n<p>The use of a Targeting Scope does not change how far your target is from you, so taking an Aim Action with a Targeting Scope on a Blaster Rifle to attack a target that is 50 squares away does not give you the +1 bonus to attack rolls and damage rolls that you would receive if the target were within 30 squares. This is the same for the Rangefinder upgrade, which negates the penalty for attacking a target that is at Short Range.</p>\n</div>"},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["attack.with-ranged"],"enabled":true,"priority":500,"description":"Point-Blank Shot"}]},"shortSummary":"+1 bonus on ranged attacks and damage against foes within Point-Blank Range.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Galaxy at War"],"sourceUrl":"https://swse.fandom.com/wiki/Point-Blank_Shot"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["attack.with-ranged"],"id":"swse.feat.point_blank_shot","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Point-Blank_Shot","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"058de949e909d9ae","name":"Low Profile","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain cover from enemies at long range and may reroll Stealth checks made to avoid detection.","prerequisite":"Dex 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["feat","general","stealth"],"bonus_feat_for":["b5bed5d1b5f42958","21dfe84d159a1b7f"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"status":"skill_reroll_phase8","description":"Low Profile: reroll Stealth checks and keep the better result.","skillRerolls":[{"id":"low-profile","skillKeys":["stealth"],"outcome":"keepBetter","label":"Low Profile","description":"Low Profile: reroll Stealth checks to avoid detection and keep the better result."}]},"shortSummary":"You gain cover from enemies at long range and may reroll Stealth checks made to avoid detection."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":[]}}}
{"_id":"05d8053002347946","name":"Fast Surge","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"force","benefit":"On your turn, you can catch a Second Wind as a Free Action instead of a Swift Action.","prerequisite":"None","special":"","normalText":"","sourcebook":"Jedi Academy Training Manual","page":30,"tags":["action_economy","defense","feat","force","free_action","recovery","second_wind","survivability"],"bonus_feat_for":["fec1f8af44fcc35a"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{"value":"<div class=\"swse-feat-description\">\n<p><strong>Reference Book:</strong> Star Wars Saga Edition Rebellion Era Campaign Guide</p>\n<p><strong>Source:</strong> https://swse.fandom.com/wiki/Fast_Surge</p>\n<p>You can return to the fight in the blink of an eye, giving your enemies no time to find an opening.</p>\n<p><strong>Prerequisites:</strong> None</p>\n<h4>Effect</h4>\n<p>On your turn, you can catch a Second Wind as a Free Action instead of a Swift Action.</p>\n</div>"},"executionModel":"PASSIVE","subType":"RULE","abilityMeta":{"modifiers":[{"target":"attack","value":2,"type":"untyped","predicates":["turn.on-current-turn"],"enabled":true,"priority":500,"description":"Fast Surge"}],"resourceRules":{"secondWind":[{"type":"ACTION_COST","action":"free","description":"Catch a Second Wind as a Free Action on your turn."}]}},"shortSummary":"Catch a Second Wind as a Free Action on your turn.","prerequisitesText":"None","referenceBooks":["Star Wars Saga Edition Rebellion Era Campaign Guide"],"sourceUrl":"https://swse.fandom.com/wiki/Fast_Surge"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["turn.on-current-turn"],"id":"swse.feat.fast_surge","featContentRefresh":{"source":"swse_feats.json","sourceUrl":"https://swse.fandom.com/wiki/Fast_Surge","updatedFields":["system.description.value","system.benefit","system.prerequisite","system.special","system.normalText","system.shortSummary"]}}}}
{"_id":"0794112a41461b05","name":"Indomitable Will","type":"feat","img":"icons/svg/upgrade.svg","system":{"featType":"general","benefit":"You gain a +2 bonus on Will Defense against mind-affecting effects and may reroll a failed Will Defense check once per encounter.","prerequisite":"Wis 13","special":"","normalText":"","sourcebook":"Galaxy at War","page":26,"tags":["defense","feat","general","survivability"],"bonus_feat_for":["f62ca2e639cab614","8c58016e587dd2c7"],"uses":{"current":0,"max":0,"perDay":false},"costNumeric":null,"description":{},"executionModel":"PASSIVE","subType":"STATE","abilityMeta":{"modifiers":[{"target":"defense.will","value":2,"type":"untyped","predicates":["defense.will","turn.once-per-round"],"enabled":true,"priority":500,"description":"Indomitable Will"}]},"shortSummary":"You gain a +2 bonus on Will Defense against mind-affecting effects and may reroll a failed Will Defense check once per encounter."},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"migratedToState":true,"migrationDate":"2026-03-08T18:22:17.377Z","detectedPredicates":["defense.will","turn.once-per-round"]}}}
