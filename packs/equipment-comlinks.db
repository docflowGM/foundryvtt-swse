municationRangeKm":null,"communicationRangeLabel":"line of sight","encryptedCommunications":true,"encryptionInterceptDcModifier":null,"scrambledTransmissionDecryptDc":null,"communicationJammer":false,"communicationJammerRadiusKm":null,"beacon":false,"distressBeacon":false,"lineOfSightCommunication":true,"stealthCommunication":true,"handheld":false,"wearable":true,"holographic":false,"audioOnly":false,"communicationNotes":"Line-of-sight encrypted laser communication; passive interception only if directly in beam path."},"skillHooks":[{"skill":"useComputer","useKey":"intercept-communications","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Tightbeam Comlink","note":"Passive interception cannot pick up tightbeam messages unless the interceptor is directly in the path."},{"skill":"perception","useKey":"eavesdrop","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Tightbeam Comlink","note":"Line-of-sight beam reduces passive interception opportunities; GM adjudicates eavesdropping only when physically in the beam path."}],"normalizationStatus":"equipment-comlinks-phase5-normalized","sourceStatus":"fandom-communications-devices-reviewed","flags":{}},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"comlinks","equipmentPhase":"comlinks-phase5"}}}
