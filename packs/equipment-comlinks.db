{"_id":"comms-com-scrambler","name":"Com Scrambler","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","countermeasure","scrambler","jammer","military","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"cost":6000,"weight":10,"size":"small","availability":"Military","quantity":1,"description":"<p>A backpack-frame communications countermeasure that blankets an area with white noise and disrupts Comlinks, HoloNet signals, and Droid Remote Receivers.</p>","notes":"<p><strong>Rules:</strong> Covers a 20-kilometer radius. Getting a signal into or out of the affected area requires a Use Computer check against the Com Scrambler's default Use Computer +10. The check is repeated every minute as the scrambler adapts.</p>","sourcebook":"Galaxy at War","costNumeric":6000,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"communications-countermeasure","equipmentTypeLabel":"Communications Countermeasure","itemRole":"gear","itemRoleLabel":"Gear","value":6000,"weightLabel":"10 kg","restriction":"military","equipped":false,"integrated":false,"source":"Galaxy at War","page":null,"traits":["communications","comlinks","comlink","gear","countermeasure","scrambler","jammer","military","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"deployed","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":6000,"weight":10},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"communicationDevice":false,"communicationAddon":false,"communicationDataTypes":[],"optionalCommunicationDataTypes":[],"communicationRangeKm":null,"communicationRangeLabel":"","encryptedCommunications":false,"encryptionInterceptDcModifier":null,"scrambledTransmissionDecryptDc":null,"communicationJammer":true,"communicationJammerRadiusKm":20,"beacon":false,"distressBeacon":false,"lineOfSightCommunication":false,"stealthCommunication":false,"handheld":false,"wearable":false,"holographic":false,"audioOnly":false,"communicationNotes":"Disrupts all communications in 20 km radius; opposed by Use Computer vs default +10 each minute."},"skillHooks":[{"skill":"useComputer","useKey":"overcome-communication-jamming","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Com Scrambler","note":"Signals into or out of the scrambled area require Use Computer against the Com Scrambler's default Use Computer +10 each minute."},{"skill":"useComputer","useKey":"intercept-communications","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Com Scrambler","note":"Creates area denial against normal communications rather than providing secure transmission."}],"normalizationStatus":"equipment-comlinks-phase5-normalized","sourceStatus":"fandom-communications-devices-reviewed","flags":{}},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"comlinks","equipmentPhase":"comlinks-phase5"}}}
{"_id":"comms-comlink-long-range","name":"Comlink, Long-Range","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","long-range","audio","optional-video","optional-holo","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"cost":250,"weight":1,"size":"small","availability":"Standard","quantity":1,"description":"<p>A backpack-sized long-range comset/comlink. A Long-Range Comlink has a range of 200 kilometers or high orbit.</p>","notes":"<p><strong>Rules:</strong> Base data type is Audio. For double the cost, a Long-Range Comlink can be miniaturized to a wrist-sized unit. Video costs twice base cost; Holo costs five times base cost; hardwired encryption costs ten times base cost and adds +10 to interception DCs.</p>","sourcebook":"Core Rulebook","costNumeric":250,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"communications-device","equipmentTypeLabel":"Communications Device","itemRole":"gear","itemRoleLabel":"Gear","value":250,"weightLabel":"1 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["communications","comlinks","comlink","gear","long-range","audio","optional-video","optional-holo","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":250,"weight":1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"communicationDevice":true,"communicationAddon":false,"communicationDataTypes":["audio"],"optionalCommunicationDataTypes":["video","holo"],"communicationRangeKm":200,"communicationRangeLabel":"200 km or high orbit","encryptedCommunications":true,"encryptionInterceptDcModifier":10,"scrambledTransmissionDecryptDc":null,"communicationJammer":false,"communicationJammerRadiusKm":null,"beacon":false,"distressBeacon":false,"lineOfSightCommunication":false,"stealthCommunication":false,"handheld":false,"wearable":false,"holographic":false,"audioOnly":false,"communicationNotes":"Can be miniaturized to wrist-sized unit for double cost; optional encryption/video/holo by cost multiplier."},"skillHooks":[{"skill":"useComputer","useKey":"intercept-communications","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Long-Range Comlink","note":"Encrypted comlink upgrade increases the Use Computer DC to intercept the transmission by +10."},{"skill":"useComputer","useKey":"decrypt-transmission","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Long-Range Comlink","note":"May be fitted with hardwired encryption; track upgrade/cost manually until item upgrade support is added."}],"normalizationStatus":"equipment-comlinks-phase5-normalized","sourceStatus":"fandom-communications-devices-reviewed","flags":{}},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"comlinks","equipmentPhase":"comlinks-phase5"}}}
{"_id":"comms-comlink-short-range","name":"Comlink, Short-Range","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","short-range","audio","optional-video","optional-holo","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"cost":25,"weight":0.1,"size":"small","availability":"Standard","quantity":1,"description":"<p>A personal communications transceiver. A Short-Range Comlink has a range of 50 kilometers or low orbit and can be built into helmets and armor.</p>","notes":"<p><strong>Rules:</strong> Base data type is Audio. Video capability costs twice the base cost; Holo capability costs five times the base cost. Hardwired encryption costs ten times the base cost and adds +10 to the DC of Use Computer checks made to intercept the transmission.</p>","sourcebook":"Core Rulebook","costNumeric":25,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"communications-device","equipmentTypeLabel":"Communications Device","itemRole":"gear","itemRoleLabel":"Gear","value":25,"weightLabel":"0.1 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["communications","comlinks","comlink","gear","short-range","audio","optional-video","optional-holo","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":25,"weight":0.1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"communicationDevice":true,"communicationAddon":false,"communicationDataTypes":["audio"],"optionalCommunicationDataTypes":["video","holo"],"communicationRangeKm":50,"