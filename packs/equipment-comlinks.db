{"_id":"comms-earbud-comlink","name":"Earbud Comlink","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","earbud","concealed","audio","deception-linked","equipped","equipment-bucket-comlinks","communications-phase5"],"cost":200,"weight":0,"size":"small","availability":"Standard","quantity":1,"description":"<p>A tiny ear-fitted Comlink used for unobtrusive private communication. It can initiate or receive a transmission through subtle touch, teeth-clicking, or similar gestures.</p>","notes":"<p><strong>Rules:</strong> Range is the same as a Short-Range Comlink: 50 kilometers or low orbit. Its size, shape, and color grant a +5 Equipment bonus to Deception checks made to hide its presence.</p>","sourcebook":"Galaxy of Intrigue","costNumeric":200,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"communications-device","equipmentTypeLabel":"Communications Device","itemRole":"gear","itemRoleLabel":"Gear","value":200,"weightLabel":"—","restriction":"common","equipped":false,"integrated":false,"source":"Galaxy of Intrigue","page":null,"traits":["communications","comlinks","comlink","gear","earbud","concealed","audio","deception-linked","equipped","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"equipped","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":200,"weight":0},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"communicationDevice":true,"communicationAddon":false,"communicationDataTypes":["audio"],"optionalCommunicationDataTypes":[],"communicationRangeKm":50,"communicationRangeLabel":"50 km or low orbit","encryptedCommunications":false,"encryptionInterceptDcModif