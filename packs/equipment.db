{"_id":"medical-kit","name":"Medical Kit","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","skill-linked","medical-kit"],"cost":600,"weight":20,"size":"small","availability":"Standard","quantity":1,"description":"<p>A comprehensive medical kit with diagnostic equipment, surgical tools, and medical supplies for field treatment.</p>\n      <p><strong>Special:</strong> Required for many Treat Injury checks. Contains 25 uses.</p>","notes":"<p><strong>Rules:</strong> Required to Revivify, Treat Disease, Treat Poison, or Treat Radiation. Grants +2 Equipment bonus on First Aid.</p>","sourcebook":"Core Rulebook","costNumeric":600,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":600,"weightLabel":"20 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["medical","gear","skill-linked","medical-kit"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"consumeOn":"","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"medical-kit","externalMedpacPouches":6,"requiredFor":["revivify","treatDisease","treatPoison","treatRadiation"]}},"container":{"capacity":null,"contents":[]},"economics":{"cost":600,"weight":20},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"medicalUse":"medical-kit","externalMedpacPouches":6,"requiredFor":["revivify","treatDisease","treatPoison","treatRadiation"]},"skillHooks":[{"skill":"treatInjury","useKey":"first-aid","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":2,"label":"+2 Equipment bonus to First Aid"},"source":"Medical Kit","note":"Using a Medical Kit grants +2 Equipment bonus to First Aid."},{"skill":"tre