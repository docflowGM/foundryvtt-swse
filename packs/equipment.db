{"_id":"medical-bacta-tank-empty","name":"Bacta Tank (Empty)","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","skill-linked","bacta-treatment-facility"],"cost":100000,"weight":500,"size":"small","availability":"Licensed","quantity":1,"description":"<p>A large medical tank for immersing patients in bacta for advanced healing. Requires bacta to function.</p>\n      <p><strong>Special:</strong> When filled with bacta, allows accelerated healing and treatment of critical injuries.</p>","notes":"<p><strong>Rules:</strong> Can be used with Surgery to add HP equal to character level on a successful Treat Injury check; grants +5 Equipment bonus when treating Disease, Poison, or Radiation.</p>","sourcebook":"Core Rulebook","costNumeric":100000,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":100000,"weightLabel":"500 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["medical","gear","skill-linked","bacta-treatment-facility"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"facility","consumable":false,"consumeOn":"","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"bacta-treatment-facility","capacityLiters":300,"requiresBactaLiters":300}},"container":{"capacity":null,"contents":[]},"economics":{"cost":100000,"weight":500},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"medicalUse":"bacta-treatment-facility","capacityLiters":300,"requiresBactaLiters":300},"skillHooks":[{"skill":"treatInjury","useKey":"perform-surgery","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Bacta Tank","note":"When used with Surgery and the Treat Injury check succeeds, the patient heals additional HP equal to character level."},{"skill":"treatInjury","useKey":"treat-disease","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":5,"label":"+5 Equipment bonus when treating disease in a bacta tank"},"source":"Bacta Tank","note":"Grants +5 Equipment bonus when treating Disease."},{"skill":"treatInjury","useKey":"treat-poison","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":5,"label":"+5 Equipment bonus when treating poison in a bacta tank"},"source":"Bacta Tank","note":"Grants +5 Equipment bonus when treating Poison."},{"skill":"treatInjury","useKey":"treat-radiation","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":5,"label":"+5 Equipment bonus when treating radiation in a bacta tank"},"source":"Bacta Tank","note":"Grants +5 Equipment bonus when treating Radiation."}],"normalizationStatus":"equipment-medical-phase2-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"medical","equipmentPhase":"medical-phase2","medicalUse":"bacta-treatment-facility"}}}
{"_id":"medical-bioscanner","name":"Bioscanner","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","skill-linked","diagnostic-scanner"],"cost":3500,"weight":0.5,"size":"small","availability":"Licensed","quantity":1,"description":"<p>An advanced medical scanner that provides detailed biological analysis and life sign detection.</p>\n      <p><strong>Special:</strong> Grants +5 bonus to Treat Injury and Life Sciences checks. Can detect life signs at range.</p>","notes":"<p><strong>Rules:</strong> Grants +2 bonus on Knowledge (Life Sciences) checks made to identify ailments.</p>","sourcebook":"Clone Wars Campaign Guide","costNumeric":3500,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":3500,"weightLabel":"0.5 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Clone Wars Campaign Guide","page":null,"traits":["medical","gear","skill-linked","diagnostic-scanner"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"active","consumable":false,"consumeOn":"","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"diagnostic-scanner","actionTime":"one or two passes"}},"container":{"capacity":null,"contents":[]},"economics":{"cost":3500,"weight":0.5},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"medicalUse":"diagnostic-scanner","actionTime":"one or two passes"},"skillHooks":[{"skill":"knowledgeLifeSciences","useKey":"identify-ailment","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":2,"label":"+2 bonus to identify ailments"},"source":"Bioscanner","note":"Grants +2 bonus on Knowledge (Life Sciences) checks to identify ailments."}],"normalizationStatus":"equipment-medical-phase2-normalized"},"effe