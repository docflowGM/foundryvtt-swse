{"_id":"computer-spike","name":"Computer Spike","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["computer","tech","gear","computer-spike","consumable","use-computer-linked","illegal"],"cost":1500,"weight":1,"size":"small","availability":"Illegal","quantity":1,"description":"<p>An illegal device used to slice into computer systems. Provides bonuses to Use Computer checks when hacking systems.</p>\n      <p><strong>Special:</strong> Grants a +2 equipment bonus to Use Computer checks made to hack or slice computer systems.</p>","notes":"<p><strong>Rules:</strong> Single-use program. Activate as a Swift Action; it makes one Use Computer check with +2 or higher, usable only to Improve Access. This compendium item represents the 1,500-credit +2 version.</p>","sourcebook":"Threats of the Galaxy","costNumeric":1500,"schemaVersion":4,"category":"tech","equipmentBucket":"tech","equipmentBucketLabel":"Tech","equipmentType":"computer","equipmentTypeLabel":"Computer","itemRole":"consumable","itemRoleLabel":"Consumable","value":1500,"weightLabel":"1 kg","restriction":"illegal","equipped":false,"integrated":false,"source":"Threats of the Galaxy","page":null,"traits":["computer","tech","gear","computer-spike","consumable","use-computer-linked","illegal"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"consumable","consumable":true,"charges":{"current":null,"max":null},"consumeOn":"onAttempt"},"modifiers":{"equipmentPhase":{"techPhase4":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":1500,"weight":1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":true,"container":false,"upgrade":false,"technologyDevice":true,"computerSpike":true,"spikeBonus":2,"swiftActionActivation":true,"useComputerUse":"improve-access"},"skillHooks":[{"skill":"useComputer","useKey":"improve-access","mode":"enables","required":true,"consumes":{"type":"quantity","amount":1,"timing":"onAttempt","reason":"Computer Spike activated for Improve Access"},"bonus":{"type":"equipment","value":2,"label":"+2 Computer Spike bonus to Improve Access"},"source":"Computer Spike","note":"Single-use +2 Computer Spike for Improve Access; activate as a Swift Action."}],"normalizationStatus":"equipment-tech-phase4-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"tech","equipmentPhase":"tech-phase4"}}}
{"_id":"computer-triangulation-visor","name":"Triangulation Visor","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["computer","tech","gear","visor","targeting-support","solid-projectile-weapons"],"cost":1400,"weight":0.5,"size":"small","availability":"Military","quantity":1,"description":"<p>A tactical visor that calculates distances, angles, and trajectories in real-time, assisting with ranged attacks and navigation.</p>\n      <p><strong>Special:</strong> Grants a +2 equipment bonus to Perception checks to determine range and a +1 bonus to ranged attack rolls at long range.</p>","notes":"<p><strong>Rules:</strong> Targeting visor for Heavy Weapons that fire solid rounds. Reduces range by one category for qualifying weapons. Does not apply to blasters, lasers, or other energy weapons.</p>","sourcebook":"Galaxy at War","costNumeric":1400,"schemaVersion":4,"category":"tech","equipmentBucket":"tech","equipmentBucketLabel":"Tech","equipmentType":"computer","equipmentTypeLabel":"Computer","itemRole":"gear","itemRoleLabel":"Gear","value":1400,"weightLabel":"0.5 kg","restriction":"military","equipped":false,"integrated":false,"source":"Galaxy at War","page":null,"traits":["computer","tech","gear","visor","targeting-support","solid-projectile-weapons"],"properties":[],"equippable":{"equipped":false,"slot":"head"},"usage":{"mode":"equipped","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"techPhase4":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":1400,"weight":0.5},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false,"technologyDevice":true,"headWorn":true,"cannotCombineHeadgear":true,"weaponSupport":true,"supportedWeaponFamilies":["slugthrower","mortar-launcher","missile-launcher","grenade-launcher"],"rangeCategoryReduction":1},"skillHooks":[],"normalizationStatus":"equipment-tech-phase4-normalized"},"effects":[],"fol