{"_id":"cyber-energy-binding-prosthesis","name":"Energy-Binding Prosthesis","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["cybernetic","tech","gear","prosthesis"],"cost":0,"weight":0,"size":"small","availability":"Rare","quantity":1,"description":"<p>A rare and experimental cybernetic prosthesis that can channel Force energy. Extremely rare even in the Old Republic era.</p>\n      <p><strong>Special:</strong> Does not impose the standard -1 penalty to Use the Force checks.</p>","notes":"<p><strong>Rules:</strong> Cybernetic prosthesis/replacement. Installation and special effects are handled through cybernetics rules/GM approval, not a generic skill hook.</p>","sourcebook":"Knights of the Old Republic Campaign Guide","costNumeric":0,"schemaVersion":4,"category":"tech","equipmentBucket":"tech","equipmentBucketLabel":"Tech","equipmentType":"cybernetic","equipmentTypeLabel":"Cybernetic","itemRole":"gear","itemRoleLabel":"Gear","value":0,"weightLabel":"0 kg","restriction":"rare","equipped":false,"integrated":true,"source":"Knights of the Old Republic Campaign Guide","page":null,"traits":["cybernetic","tech","gear","prosthesis"],"properties":[],"equippable":{"equipped":false,"slot":"implant"},"usage":{"mode":"installed","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"techPhase4":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":0,"weight":0},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false,"technologyDevice":true,"cybernetic":true,"installed":true,"prosthesis":true},"skillHooks":[],"normalizationStatus":"equipment-tech-phase4-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"tech","equipmentPhase":"tech-phase4"}}}
{"_id":"cyber-prosthesis","name":"Cybernetic Prosthesis","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["cybernetic","tech","gear","prosthesis"],"cost":1500,"weight":0,"size":"small","availability":"Licensed","quantity":1,"description":"<p>A cybernetic replacement for a lost limb or damaged organ. Can be made to look natural or obviously artificial.</p>\n      <p><strong>Installation Cost:</strong> 500 credits</p>\n      <p><strong>Special:</strong> Each cybernetic device imposes a -1 penalty to Use the Force checks (maximum -5).</p>","notes":"<p><strong>Rules:</strong> Replacement cybernetic prosthesis. Installation uses cybernetics rules; no automatic skill hook.</p>","sourcebook":"Core Rulebook","installCost":500,"costNumeric":1500,"schemaVersion":4,"category":"tech","equipmentBucket":"tech","equipmentBucketLabel":"Tech","equipmentType":"cybernetic","equipmentTypeLabel":"Cybernetic","itemRole":"gear","itemRoleLabel":"Gear","value":1500,"weightLabel":"0 kg","restriction":"licensed","equipped":false,"integrated":true,"source":"Core Rulebook","page":null,"traits":["cybernetic","tech","gear","prosthesis"],"properties":[],"equippable":{"equipped":false,"slot":"implant"},"usage":{"mode":"installed","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"techPhase4":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":1500,"weight":0},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false,"technologyDevice":true,"cybernetic":true,"installed":true,"prosthesis":true},"skillHooks":[],"normalizationStatus":"equipment-tech-phase4-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"tech","equipmentPhase":"tech-phase4"}}}
{"_id":"cyber-rhen-orm-biocomputer","name":"Rhen-Orm Biocomputer","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["cybernetic","tech","gear","biocomputer","survival-linked","track"],"cost":3500,"weight":0.2,"size":"small","availability":"Restricted","quantity":1,"description":"<p>An organic computer implanted in the brain, providing enhanced mental processing and data storage capabilities.</p>\n      <p><strong>Installation Cost:</strong> 10,000 credits</p>\n      <p><strong>Special:</strong> Grants a +4 equipment bonus to Knowledge checks and allows perfect recall of stored information. Imposes -1 penalty to Use the Force checks.</p>","notes":"<p><strong>Rules:</strong> Installed cybernetic. When making Survival checks to Track an opponent, add the quarry's Force Point total as an Equipment bonus. Dynamic bonus is noted but not auto-applied.</p>","sourcebook":"Threats of the Galaxy","installCost":10000,"costNumeric":3500,"schemaVersion":4,"category":"tech","equipmentBucket":"tech","equipmentBucketLabel":"Tech","equipmentType":"cybernetic","equipmentTypeLabel":"Cybernetic","itemRole":"gear","itemRoleLabel":"Gear","value":3500,"weightLabel":"0.2 kg","restriction":"restricted","equipped":false,"integrated":true,"source":"Threats of the Galaxy","page":null,"traits":["cybernetic","tech","gear","biocomputer","survival-linked","track"],"properties":[],"equippable":{"equipped":false,"slot":"implant"},"usage":{"mode":"installed","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"techPhase4":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":3500,"weight":0.2},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"technologyDevice":true,"cybernetic":true,"installed":true,"installationCost":10000,"requiresCyberneticSurgery":true,"survivalTrackDynamicBonus":"quarry Force Point total"},"skillHooks":[{"skill":"survival","useKey":"track","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Rhen-Orm Biocomputer","note":"When tracking a quarry, add the quarry's Force Point total as an Equipment bonus; dynamic value is GM/player-entered."}],"normalizationStatus":"equipment-tech-phase4-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"tech","equipmentPhase":"tech-phase4"}}}
{"_id":"cyber-subelectronic-converter","name":"Subelectronic Converter","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["cybernetic","tech","gear","force-linked","droid-control"],"cost":23000,"weight":0,"size":"small","availability":"Rare","quantity":1,"description":"<p>An advanced cybernetic implant that enhances neural processing speed and reflex response times.</p>\n      <p><strong>Installation Cost:</strong> 500 credits</p>\n      <p><strong>Special:</strong> Grants a +2 equipment bonus to Initiative checks. Imposes -1 penalty to Use the Force checks.</p>","notes":"<p><strong>Rules:</strong> Implanted converter enabling special Force interaction with Droids, including Mind Trick-style effects where normally unavailable. Track as special/GM-adjudicated capability rather than generic skill automation.</p>","sourcebook":"Jedi Academy Training Manual","installCost":500,"costNumeric":23000,"schemaVersion":4,"category":"tech","equipmentBucket":"tech","equipmentBucketLabel":"Tech","equipmentType":"cybernetic","equipmentTypeLabel":"Cybernetic","itemRole":"gear","itemRoleLabel":"Gear","value":23000,"weightLabel":"0 kg","restriction":"rare","equipped":false,"integrated":true,"source":"Jedi Academy Training Manual","page":null,"traits":["cybernetic","tech","gear","force-linked","droid-control"],"properties":[],"equippable":{"equipped":false,"slot":"implant"},"usage":{"mode":"installed","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"techPhase4":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":23000,"weight":0},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"technologyDevice":true,"cybernetic":true,"installed":true,"installationCost":500,"requiresCyberneticSurgery":true,"forceAffectsDroids":true,"mindTrickDroids":true},"skillHooks":[{"skill":"useTheForce","useKey":"mind-trick-droid","mode":"enables","required":fal