{"_id":"comms-pocket-scrambler","name":"Pocket Scrambler","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","scrambler","encryption","communications-addon","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"cost":400,"weight":0.5,"size":"small","availability":"Licensed","quantity":1,"description":"<p>A simple add-on device that automatically encodes outgoing messages from a linked communications device.</p>","notes":"<p><strong>Rules:</strong> A scrambled message can be read only by a communications device equipped with a linked Pocket Scrambler. Anyone intercepting the scrambled message must succeed at a DC 30 Use Computer check to decrypt it.</p>","sourcebook":"Core Rulebook","costNumeric":400,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"communications-addon","equipmentTypeLabel":"Communications Addon","itemRole":"gear","itemRoleLabel":"Gear","value":400,"weightLabel":"0.5 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["communications","comlinks","comlink","gear","scrambler","encryption","communications-addon","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"attached","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":400,"weight":0.5},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"communicationDevice":false,"communicationAddon":true,"communicationDataTypes":[],"optionalCommunicationDataTypes":[],"communicationRangeKm":null,"communicationRangeLabel":"","encryptedCommunications":true,"encryptionInterceptDcModifier":null,"scrambledTransmissionDecryptDc":30,"communicationJammer":false,"communicationJammerRadiusKm":null,"beacon":false,"distressBeacon":false,"lineOfSightCommunication":false,"stealthCommunication":false,"handheld":true,"wearable":false,"holographic":false,"audioOnly":false,"communicationNotes":"Linked Pocket Scramblers can read each other; unlinked interceptors must decrypt at DC 30."},"skillHooks":[{"skill":"useComputer","useKey":"decrypt-transmission","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Pocket Scrambler","note":"Sets the intercepted scrambled-message decrypt check to DC 30 unless the receiver has a linked Pocket Scrambler."},{"skill":"useComputer","useKey":"intercept-communications","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Pocket Scrambler","note":"Scrambles outgoing messages from the attached communications device."}],"normalizationStatus":"equipment-comlinks-phase5-normalized","sourceStatus":"fandom-communications-devices-reviewed","flags":{}},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"comlinks","equipmentPhase":"comlinks-phase5"}}}
