{"_id":"comms-hands-free-comlink","name":"Hands-Free Comlink","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","hands-free","audio","stealth-comms","equipped","equipment-bucket-comlinks","communications-phase5"],"cost":150,"weight":0.1,"size":"small","availability":"Standard","quantity":1,"description":"<p>A face-pad and earpiece Comlink that allows hands-free, whisper-level audio communication while both hands remain free.</p>","notes":"<p><strong>Rules:</strong> Range is 50 kilometers or low orbit. Processes Audio only and can be built into helmets or armor.</p>","sourcebook":"Legacy Era Campaign Guide","costNumeric":150,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"communications-device","equipmentTypeLabel":"Communications Device","itemRole":"gear","itemRoleLabel":"Gear","value":150,"weightLabel":"0.1 kg","restriction":"common","equipped":false,"integrated":false,"source":"Legacy Era Campaign Guide","page":null,"traits":["communications","comlinks","comlink","gear","hands-free","audio","stealth-comms","equipped","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"equipped","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":150,"weight":0.1},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false,"communicationDevice":true,"communicationAddon":false,"communicationDataTypes":["audio"],"optionalCommunicationDataTypes":[],"communicationRangeKm":50,"communicationRangeLabel":"50 km or low orbit","encryptedCommunications":false,"encryptionInterceptDcModifier":null,"scrambledTransmissionDecryptDc":null,"communicationJammer":false,"communicationJammerRadiusKm":null,"beac