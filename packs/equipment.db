{"_id":"comms-targeting-beacon","name":"Targeting Beacon","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","targeting-beacon","beacon","military","target-designation","equipment-bucket-comlinks","communications-phase5"],"cost":300,"weight":0.1,"size":"small","availability":"Military","quantity":1,"description":"<p>A specialized transmitter that broadcasts a homing signal for orbital strikes, airstrikes, or guided missiles.</p>","notes":"<p><strong>Rules:</strong> Target-designation/transmitter gear. This pass records the capability but does not automate attack, vehicle, or weapon-lock behavior.</p>","sourcebook":"Galaxy at War","costNumeric":300,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"targeting-beacon","equipmentTypeLabel":"Targeting Beacon","itemRole":"gear","itemRoleLabel":"Gear","value":300,"weightLabel":"0.1 kg","restriction":"military","equipped":false,"integrated":false,"source":"Galaxy at War","page":null,"traits":["communications","comlinks","comlink","gear","targeting-beacon","beacon","military","target-designation","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"deployed","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":300,"weight":0.1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"communicationDevice":false,"communicationAddon":false,"communicationDataTypes":[],"optionalCommunicationDataTypes":[],"communicationRangeKm":null,"communicationRangeLabel":"","encryptedCommunications":false,"encryptionInterceptDcModifier":null,"scrambledTransmissionDecryptDc":null,"communicationJammer":false,"communicationJammerRadiusKm":null,"beacon":true