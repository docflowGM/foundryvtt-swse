{"_id":"accessory-bandolier","name":"Bandolier","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","container","ammunition","grenade-support","quick-access"],"cost":100,"weight":2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A bandolier for carrying ammunition, power packs, and grenades. Worn across the chest.</p>","notes":["A Bandolier has 12 slots. Each slot can hold one Tiny weapon or one piece of Equipment weighing up to 0.5 kg. Any item on the Bandolier can be retrieved as a Move Action."],"sourcebook":"Core Rulebook","costNumeric":100,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"container","itemRoleLabel":"Container","value":100,"weightLabel":"2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","container"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"container","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":100,"weight":2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":true,"upgrade":false,"containerSlots":12,"slotCapacityKg":0.5,"retrievalAction":"move","storesTinyWeapons":true,"storesAmmunition":true,"storesGrenades":true,"comesStocked":false,"quickAccess":true},"skillHooks":[],"normalizationStatus":"source-verified-other-bucket"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"other","equipmentPhase":"phase1-normalized"}}}
{"_id":"accessory-helmet-package","name":"Helmet Package","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","armor-upgrade","helmet","perception","low-light","comlink","integrated-equipment"],"cost":4000,"weight":1,"size":"small","availability":"Licensed","quantity":1,"description":"<p>An integrated helmet system with comlink, low-light vision, and tactical display.</p>\n      <p><strong>Special:</strong> Grants low-light vision and integrated comlink.</p>","notes":["When installed in armor, grants +2 Equipment bonus on Perception checks, Low-Light Vision, and an integrated hands-free comlink. Installing takes 1 hour and a DC 20 Mechanics check."],"sourcebook":"Core Rulebook","costNumeric":4000,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"upgrade","itemRoleLabel":"Upgrade","value":4000,"weightLabel":"1 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","gear","upgrade"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":4000,"weight":1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":true,"armorUpgrade":true,"upgradePointCost":0,"installSkill":"mechanics","installDC":20,"installTime":"1 hour","lowLightVision":true,"integratedHandsFreeComlink":true,"perceptionEquipmentBonus":2,"requiresHelmetOrArmor":true},"skillHooks":[{"skill":"perception","useKey":"all","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":2,"label":"+2 Equipment bonus to Perception","requiresEquipped":true},"requiresEquipped":true,"allowsUnt