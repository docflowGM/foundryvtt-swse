{"_id":"comms-tightbeam-comlink","name":"Tightbeam Comlink","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["communications","comlinks","comlink","gear","tightbeam","encrypted","line-of-sight","stealth-comms","equipped","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"cost":300,"weight":0.5,"size":"small","availability":"Military","quantity":1,"description":"<p>A line-of-sight laser communications add-on worn on a helmet or headpiece. It sends encrypted messages to another character also equipped with a Tightbeam Comlink.</p>","notes":"<p><strong>Rules:</strong> The two users must have line of sight. Tightbeam messages ignore darkness, smoke, and other atmospheric hazards for communication, and passive interception cannot detect the message unless the interceptor is directly in the path between users.</p>","sourcebook":"Galaxy at War","costNumeric":300,"schemaVersion":3,"category":"tech","equipmentBucket":"comlinks","equipmentBucketLabel":"Comlinks","equipmentType":"communications-addon","equipmentTypeLabel":"Communications Addon","itemRole":"gear","itemRoleLabel":"Gear","value":300,"weightLabel":"0.5 kg","restriction":"military","equipped":false,"integrated":false,"source":"Galaxy at War","page":null,"traits":["communications","comlinks","comlink","gear","tightbeam","encrypted","line-of-sight","stealth-comms","equipped","use-computer-linked","equipment-bucket-comlinks","communications-phase5"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"equipped","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"comlinksPhase5":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":300,"weight":0.5},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"communicationDevice":true,"communicationAddon":true,"communicationDataTypes":["audio"],"optionalCommunicationDataTypes":[],"communicationRangeKm":null,"communicationRangeLabel":"line of sight","encryptedCommunications":true,"encryptionInterceptDcModifier":null,"scrambledTransmissionDecryptDc":null,"communicationJammer":false,"communicationJammerRadiusKm":null,"beacon":false,"distressBeacon":false,"lineOfSightCommunication":true,"stealthCommunication":true,"handheld":false,"wearable":true,"holographic":false,"audioOnly":false,"communicationNotes":"Line-of-sight encrypted laser communication; passive interception only if directly in beam path."},"skillHooks":[{"skill":"useComputer","useKey":"intercept-communications","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Tightbeam Comlink","note":"Passive interception cannot pick up tightbeam messages unless the interceptor is directly in the path."},{"skill":"perception","useKey":"eavesdrop","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Tightbeam Comlink","note":"Line-of-sight beam reduces passive interception opportunities; GM adjudicates eavesdropping only when physically in the beam path."}],"normalizationStatus":"equipment-comlinks-phase5-normalized","sourceStatus":"fandom-communications-devices-reviewed","flags":{}},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"comlinks","equipmentPhase":"comlinks-phase5"}}}
