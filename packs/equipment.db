{"_id":"medical-antidote-synthesizer","name":"Antidote Synthesizer","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","skill-linked","poison-antidote-synthesis"],"cost":2500,"weight":0.8,"size":"small","availability":"Restricted","quantity":1,"description":"<p>A portable device that analyzes toxins and synthesizes custom antidotes on demand.</p>\n      <p><strong>Special:</strong> Can create antidotes to most poisons with a DC 20 Treat Injury check.</p>","notes":"<p><strong>Rules:</strong> Analyzes a poison/toxin sample and creates 1d4 antivenom/antitoxin doses in 1d6 rounds; each dose grants +2 to a Treat Injury check made to treat that poison/toxin.</p>","sourcebook":"Unknown Regions","costNumeric":2500,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":2500,"weightLabel":"0.8 kg","restriction":"restricted","equipped":false,"integrated":false,"source":"Unknown Regions","page":null,"traits":["medical","gear","skill-linked","poison-antidote-synthesis"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"active","consumable":false,"consumeOn":"","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"poison-antidote-synthesis","output":"1d4 antidote doses","actionTime":"1d6 rounds"}},"container":{"capacity":null,"contents":[]},"economics":{"cost":2500,"weight":0.8},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"medicalUse":"poison-antidote-synthesis","output":"1d4 antidote doses","actionTime":"1d6 rounds"},"skillHooks":[{"skill":"treatInjury","useKey":"treat-poison","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":2,"label":"+2 bonus from synthesized antitoxin/antivenom dose"},"source":"Antidote Synthesizer","no