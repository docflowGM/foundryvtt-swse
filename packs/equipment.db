{"_id":"accessory-holster-concealed","name":"Holster, Concealed","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","container","holster","concealment","stealth","quick-access"],"cost":50,"weight":0.2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A concealed holster that hides a pistol under clothing.</p>\n      <p><strong>Special:</strong> Grants +5 bonus to conceal a pistol.</p>","notes":["Allows drawing a concealed weapon as a Move Action instead of a Standard Action, but applies a -5 penalty on the Stealth check to conceal that weapon."],"sourcebook":"Core Rulebook","costNumeric":50,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"container","itemRoleLabel":"Container","value":50,"weightLabel":"0.2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","container"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"container","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":50,"weight":0.2},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":true,"upgrade":false,"holdsWeapon":true,"weaponSizeLimit":"Medium or smaller","concealedCarry":true,"concealedDrawAction":"move","normalConcealedDrawAction":"standard","stealthConcealPenalty":-5},"skillHooks":[{"skill":"stealth","useKey":"conceal-item-on-self","mode":"modifies","required":false,"consumes":null,"bonus":null,"requiresEquipped":false,"allowsUntrained":false,"trainingOverride":null,"note":"Concealed Holster enables Move Action draw of a concealed weapon, but applies -5 to the Stealth check to conceal it.","source":""}],"normalizationStatus":"source-ve