{"_id":"life-vacuum-mask","name":"Vacuum Mask","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","survival","vacuum","breathing","gear"],"cost":650,"weight":0.3,"size":"small","availability":"Licensed","quantity":1,"description":"<p>A compact emergency mask for sudden loss of atmosphere aboard spacecraft and stations.</p><p><strong>Special:</strong> Provides 10 minutes of breathable air, automatically beginning when sensors detect no breathable atmosphere.</p>","notes":"Short-term emergency air supply, not a full space suit.","sourcebook":"Knights of the Old Republic Campaign Guide","costNumeric":650,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":650,"weightLabel":"0.3 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Knights of the Old Republic Campaign Guide","page":null,"traits":["life-support","survival","gear","vacuum","breathing"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":650,"weight":0.3},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"lifeSupport":{"breathableAtmosphereMinutes":10,"vacuumEmergency":true}},"skillHooks":[{"skill":"endurance","useKey":"hold-breath","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Vacuum Mask","note":"Provides 10 minutes of breathable air in an emergency loss of atmosphere."}],"normalizationStatus":"equipment-survival-phase6-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"survival-phase6"}}}
{"_id":"medical-anti-rad-dose","name":"Anti-Rad Dose","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","consumable","skill-linked","radiation-countermeasure"],"cost":50,"weight":0,"size":"small","availability":"Licensed","quantity":1,"description":"<p>An injection that provides temporary protection against radiation exposure.</p>\n      <p><strong>Special:</strong> Grants +5 bonus to Fortitude Defense against radiation for 24 hours.</p>","notes":"<p><strong>Rules:</strong> Grants +10 Equipment bonus to the target's Fortitude Defense against Radiation and +5 Equipment bonus to Treat Injury checks to cure damage caused by Radiation.</p>","sourcebook":"Galaxy at War","costNumeric":50,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"consumable","itemRoleLabel":"Consumable","value":50,"weightLabel":"0 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Galaxy at War","page":null,"traits":["medical","consumable","skill-linked","radiation-countermeasure"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"consumable","consumable":true,"consumeOn":"manual","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"radiation-countermeasure","fortitudeDefenseBonus":{"value":10,"type":"equipment","against":"radiation","duration":"24 hours"}}},"container":{"capacity":null,"contents":[]},"economics":{"cost":50,"weight":0},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":true,"container":false,"upgrade":false,"medicalUse":"radiation-countermeasure","fortitudeDefenseBonus":{"value":10,"type":"equipment","against":"radiation","duration":"24 hours"}},"skillHooks":[{"skill":"treatInjury","useKey":"treat-radiation","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":5,"label":"+5 Equipment bonu