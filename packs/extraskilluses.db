{"_id": "22cb3a66f71449d1", "name": "Place Other in Force Trance (Use the Force, Trained Only)", "type": "extra-skill-use", "img": "icons/svg/skill.svg", "system": {"skill": "useTheForce", "skillLabel": "Use the Force", "application": "Place Other in Force Trance (Use the Force, Trained Only)", "trainedOnly": true, "requiresForceSensitivity": true, "actionType": "standard", "actionTypeRaw": "full-round action", "dc": 15, "target": "", "effect": "Place adjacent willing ally into Force Trance (deep coma, Helpless condition). Each hour target regains HP equal to Character Level. After 4 consecutive hours emerges fully rested. Target can go 10\u00d7 as long without air/food/water. Only you can bring target out (swift action, adjacent). Unwilling targets cannot be placed in trance.", "description": "Place adjacent willing ally into Force Trance (deep coma, Helpless condition). Each hour target regains HP equal to Character Level. After 4 consecutive hours emerges fully rested. Target can go 10\u00d7 as long without air/food/water. Only you can bring target out (swift action, adjacent). Unwilling targets cannot be placed in trance.", "special": "", "category": "skill-use", "tags": ["useTheForce"], "sourcebook": "Saga Edition", "page": null}, "effects": [], "folder": null, "sort": 92, "ownership": {"default": 0}, "flags": {}, "_stats": {"created": "2026-04-14T17:16:10.622507Z", "modified": "2026-04-14T17:16:10.622507Z", "lastModifiedBy": null}}
