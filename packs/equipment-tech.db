{"_id":"computer-interface-visor","name":"Computer Interface Visor","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["computer","tech","gear","visor","use-computer-linked","trained-override"],"cost":1200,"weight":0.5,"size":"small","availability":"Licensed","quantity":1,"description":"<p>A heads-up display visor that provides direct neural interface with computer systems, allowing hands-free operation.</p>\n      <p><strong>Special:</strong> Grants a +2 equipment bonus to Use Computer checks.</p>","notes":"<p><strong>Rules:</strong> While worn and connected to a computer system, allows trained-only Use Computer applications even if untrained and grants +2 Equipment bonus on Use Computer checks. Cannot be worn with armor helmet/headgear.</p>","sourcebook":"Knights of the Old Republic Campaign Guide","costNumeric":1200,"schemaVersion":4,"category":"tech","equipmentBucket":"tech","equipmentBucketLabel":"Tech","equipmentType":"computer","equipmentTypeLabel":"Computer","itemRole":"gear","itemRoleLabel":"Gear","value":1200,"weightLabel":"0.5 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Knights of the Old Republic Campaign Guide","page":null,"traits":["computer","tech","gear","visor","use-computer-linked","trained-override"],"properties":[],"equippable":{"equipped":false,"slot":"head"},"usage":{"mode":"equipped","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{"equipmentPhase":{"techPhase4":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":1200,"weight":0.5},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"technologyDevice":true,"headWorn":true,"cannotCombineHeadgear":true,"allowsUntrainedUseComputerTrainedApplications":true},"skillHooks":[{"skill":"useComputer","useKey":"all","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":2,"label":"+2 Equipment bonus to Use Computer