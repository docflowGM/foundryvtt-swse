quires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"A Tool Kit is required to repair damaged objects, devices, and Vehicles."},{"skill":"mechanics","useKey":"repair","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"A Tool Kit is required for Repair applications of Mechanics."},{"skill":"mechanics","useKey":"jury-rig","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"A Tool Kit is required for emergency repairs and jury-rigged fixes unless a rule explicitly waives tools."},{"skill":"mechanics","useKey":"reprogram-droid","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"A Tool Kit is required to reprogram a Droid."},{"skill":"mechanics","useKey":"modify-droid","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"A Tool Kit is required for Droid modification Mechanics checks."},{"skill":"mechanics","useKey":"build-object","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"Building an object requires a proper Tool Kit and raw materials."},{"skill":"mechanics","useKey":"biotech-adaptation","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"Biotech Adaptation Mechanics applications require a Tool Kit."},{"skill":"mechanics","useKey":"booby-trap","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Tool Kit","note":"Installing a booby trap through Mechanics requires a Tool Kit."}],"normalizationStatus":"equipment-tools-phase3-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"tools","equipmentPhase":"tools-security-phase3"}}}
