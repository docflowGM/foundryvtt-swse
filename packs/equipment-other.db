{"_id":"accessory-bandolier","name":"Bandolier","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","container","ammunition","grenade-support","quick-access"],"cost":100,"weight":2.0,"size":"small","availability":"Standard","quantity":1,"description":"<p>A bandolier for carrying ammunition, power packs, and grenades. Worn across the chest.</p>","notes":["A Bandolier has 12 slots. Each slot can hold one Tiny weapon or one piece of Equipment weighing up to 0.5 kg. Any item on the Bandolier can be retrieved as a Move Action."],"sourcebook":"Core Rulebook","costNumeric":100,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"container","itemRoleLabel":"Container","value":100,"weightLabel":"2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","container"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"container","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":100,"weight":2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":true,"upgrade":false,"containerSlots":12,"slotCapacityKg":0.5,"retrievalAction":"move","storesTinyWeapons":true,"storesAmmunition":true,"storesGrenades":true,"comesStocked":false,"quickAccess":true},"skillHooks":[],"normalizationStatus":"source-verified-other-bucket"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"other","equipmentPhase":"phase1-normalized"}}}
{"_id":"accessory-helmet-package","name":"Helmet Package","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","armor-upgrade","helmet","perception","low-light","comlink","integrated-equipment"],"cost":4000,"weight":1.0,"size":"small","availability":"Licensed","quantity":1,"description":"<p>An integrated helmet system with comlink, low-light vision, and tactical display.</p>\n      <p><strong>Special:</strong> Grants low-light vision and integrated comlink.</p>","notes":["When installed in armor, grants +2 Equipment bonus on Perception checks, Low-Light Vision, and an integrated hands-free comlink. Installing takes 1 hour and a DC 20 Mechanics check."],"sourcebook":"Core Rulebook","costNumeric":4000,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"upgrade","itemRoleLabel":"Upgrade","value":4000,"weightLabel":"1 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","gear","upgrade"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":4000,"weight":1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":true,"armorUpgrade":true,"upgradePointCost":0,"installSkill":"mechanics","installDC":20,"installTime":"1 hour","lowLightVision":true,"integratedHandsFreeComlink":true,"perceptionEquipmentBonus":2,"requiresHelmetOrArmor":true},"skillHooks":[{"skill":"perception","useKey":"all","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":2,"label":"+2 Equipment bonus to Perception","requiresEquipped":true},"requiresEquipped":true,"allowsUntrained":false,"trainingOverride":null,"note":"Helmet Package grants +2 Equipment bonus to Perception checks when installed/equipped.","source":""}],"normalizationStatus":"source-verified-other-bucket"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"other","equipmentPhase":"phase1-normalized"}}}
{"_id":"accessory-holster-concealed","name":"Holster, Concealed","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","container","holster","concealment","stealth","quick-access"],"cost":50,"weight":0.2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A concealed holster that hides a pistol under clothing.</p>\n      <p><strong>Special:</strong> Grants +5 bonus to conceal a pistol.</p>","notes":["Allows drawing a concealed weapon as a Move Action instead of a Standard Action, but applies a -5 penalty on the Stealth check to conceal that weapon."],"sourcebook":"Core Rulebook","costNumeric":50,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"container","itemRoleLabel":"Container","value":50,"weightLabel":"0.2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","container"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"container","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":50,"weight":0.2},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":true,"upgrade":false,"holdsWeapon":true,"weaponSizeLimit":"Medium or smaller","concealedCarry":true,"concealedDrawAction":"move","normalConcealedDrawAction":"standard","stealthConcealPenalty":-5},"skillHooks":[{"skill":"stealth","useKey":"conceal-item-on-self","mode":"modifies","required":false,"consumes":null,"bonus":null,"requiresEquipped":false,"allowsUntrained":false,"trainingOverride":null,"note":"Concealed Holster enables Move Action draw of a concealed weapon, but applies -5 to the Stealth check to conceal it.","source":""}],"normalizationStatus":"source-verified-other-bucket"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"other","equipmentPhase":"phase1-normalized"}}}
{"_id":"accessory-holster-hip","name":"Holster, Hip","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","container","holster","quick-access"],"cost":25,"weight":0.5,"size":"small","availability":"Standard","quantity":1,"description":"<p>A standard hip holster for quick-draw access to a pistol.</p>","notes":["A visible, easily accessed holster for a Medium or smaller weapon."],"sourcebook":"Core Rulebook","costNumeric":25,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"container","itemRoleLabel":"Container","value":25,"weightLabel":"0.5 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","container"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"container","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":25,"weight":0.5},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":true,"upgrade":false,"holdsWeapon":true,"weaponSizeLimit":"Medium or smaller","visibleCarry":true,"quickAccess":true},"skillHooks":[],"normalizationStatus":"source-verified-other-bucket"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"other","equipmentPhase":"phase1-normalized"}}}
{"_id":"accessory-targeting-scope-enhanced-low-light","name":"Targeting Scope, Enhanced Low-Light","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","weapon-upgrade","targeting-scope","accuracy","range-support","ranged","aim","low-light","darkness"],"cost":1000,"weight":1.2,"size":"small","availability":"Licensed","quantity":1,"description":"<p>An advanced scope with electronic magnification and low-light enhancement.</p>\n      <p><strong>Special:</strong> Grants +2 bonus to attack rolls at long range. Negates concealment from darkness.</p>","notes":["Functions as a standard Targeting Scope in normal light. After aiming, it also ignores concealment, but not total concealment, from darkness against that target."],"sourcebook":"Core Rulebook","costNumeric":1000,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"weapon-upgrade","itemRoleLabel":"Weapon Upgrade","value":1000,"weightLabel":"1.2 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","gear","weapon-upgrade"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":1000,"weight":1.2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":true,"weaponUpgrade":true,"upgradePointCost":0,"installSkill":"mechanics","installDC":10,"installTime":"10 minutes","appliesToWeaponGroups":["pistol","rifle"],"requiresAim":true,"rangeCategoryReduction":1,"accuracySupport":true,"lowLightTargeting":true,"ignoreDarknessConcealmentAfterAim":true,"doesNotIgnoreTotalConcealment":true},"skillHooks":[],"normalizationStatus":"source-verified-other-bucket"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"other","equipmentPhase":"phase1-normalized"}}}
{"_id":"accessory-targeting-scope-standard","name":"Targeting Scope, Standard","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["weapon-armor-accessory","other","accessory","weapon-upgrade","targeting-scope","accuracy","range-support","ranged","aim"],"cost":100,"weight":0.2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A basic optical scope that aids with ranged attacks.</p>\n      <p><strong>Special:</strong> Grants +1 bonus to attack rolls at long range.</p>","notes":["Installed on a rifle or pistol with 10 minutes and a DC 10 Mechanics check. After aiming, reduces the target range by one category until target/line of sight changes."],"sourcebook":"Core Rulebook","costNumeric":100,"schemaVersion":3,"category":"gear","equipmentBucket":"other","equipmentBucketLabel":"Other","equipmentType":"accessory","equipmentTypeLabel":"Accessory","itemRole":"weapon-upgrade","itemRoleLabel":"Weapon Upgrade","value":100,"weightLabel":"0.2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["weapon-armor-accessory","other","accessory","gear","weapon-upgrade"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":100,"weight":0.2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":true,"weaponUpgrade":true,"upgradePointCost":0,"installSkill":"mechanics","installDC":10,"installTime":"10 minutes","appliesToWeaponGroups":["pistol","rifle"],"requiresAim":true,"rangeCategoryReduction":1,"accuracySupport":true},"skillHooks":[],"normalizationStatus":"source-verified-other-bucket"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"other","equipmentPhase":"phase1-normalized"}}}
