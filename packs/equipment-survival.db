{"_id":"life-aquata-breather","name":"Aquata Breather","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","survival","underwater","breathing","swim","gear"],"cost":350,"weight":0.2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A small mouthpiece that extracts oxygen from water, allowing breathing underwater indefinitely.</p><p><strong>Special:</strong> Allows breathing underwater, but does not work in airless environments.</p>","notes":"Underwater breathing support.","sourcebook":"Core Rulebook","costNumeric":350,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":350,"weightLabel":"0.2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["life-support","survival","gear","underwater","breathing","swim"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":350,"weight":0.2},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"lifeSupport":{"underwaterBreathing":true,"airlessEnvironment":false}},"skillHooks":[{"skill":"swim","useKey":"swim-tread-water","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Aquata Breather","note":"Allows breathing underwater while swimming or treading water."}],"normalizationStatus":"equipment-survival-phase6-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"survival-phase6"}}}
{"_id":"life-breath-mask","name":"Breath Mask","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","survival","breathing","poison-immunity","atmosphere","gear"],"cost":200,"weight":2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A personal atmosphere-filtering mask with a portable life support supply.</p><p><strong>Special:</strong> Provides 1 hour of breathable atmosphere and immunity to inhaled poisons, including poisonous atmospheres. It does not protect against extreme temperatures or hard vacuum.</p>","notes":"Requires replacement filter/atmosphere canister after use; no protection from extreme temperatures or hard vacuum.","sourcebook":"Core Rulebook","costNumeric":200,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":200,"weightLabel":"2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["life-support","survival","gear","breathing","poison-immunity","atmosphere"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":200,"weight":2},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"lifeSupport":{"breathableAtmosphereMinutes":60,"inhaledPoisonImmunity":true,"hardVacuumProtection":false,"temperatureProtection":false}},"skillHooks":[{"skill":"endurance","useKey":"hold-breath","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Breath Mask","note":"Provides 1 hour of breathable atmosphere and prevents inhaled poison exposure while functional."}],"normalizationStatus":"equipment-survival-phase6-normalized"},"effects":[],"fo