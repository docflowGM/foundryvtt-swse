{"_id":"survival-field-camouflage-netting","name":"Field Camouflage Netting","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["survival","camouflage","stealth","concealment","gear"],"cost":2000,"weight":5,"size":"small","availability":"Military","quantity":1,"description":"<p>Lightweight camouflage netting for concealing equipment or positions.</p><p><strong>Special:</strong> Covers a 5-by-5 meter area and grants +5 to Stealth checks to conceal the covered area or position.</p>","notes":"Area/position concealment support rather than personal stealth.","sourcebook":"Galaxy at War","costNumeric":2000,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"survival","equipmentTypeLabel":"Survival Gear","itemRole":"gear","itemRoleLabel":"Gear","value":2000,"weightLabel":"5 kg","restriction":"military","equipped":false,"integrated":false,"source":"Galaxy at War","page":null,"traits":["survival","gear","camouflage","stealth","concealment"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":2000,"weight":5},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"camouflage":{"areaMeters":"5x5","stealthEquipmentBonus":5}},"skillHooks":[{"skill":"stealth","useKey":"conceal-large-item","mode":"modifies","required":false,"consumes":null,"bonus":{"type":"equipment","value":5,"label":"+5 Equipment bonus to conceal covered area"},"source":"Field Camouflage Netting","note":"Covers a 5x5 meter area and helps conceal equipment or a position."}],"normalizationStatus":"equipment-survival-phase6-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"survival-phase6"}}}
