umes":null,"bonus":null,"source":"Field Kit","note":"Required to make Survival checks to endure extreme temperatures."},{"skill":"survival","useKey":"basic-survival","mode":"modifies","required":false,"consumes":null,"bonus":null,"source":"Field Kit","note":"Contains food, water, shelter, signaling, and life-support survival supplies."}],"normalizationStatus":"equipment-survival-phase6-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"survival-phase6"}}}
