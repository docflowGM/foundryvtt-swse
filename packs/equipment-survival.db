{"_id":"life-antiox-breath-mask","name":"Antiox Breath Mask","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","species-support","survival","gear"],"cost":2000,"weight":2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A Kel Dor antiox breath mask and goggles assembly for use outside Dorin's atmosphere.</p><p><strong>Special:</strong> Required for Kel Dor to breathe and see normally in common nitrogen/oxygen atmospheres. Replacement filters are a separate GM-tracked expense.</p>","notes":"Kel Dor characters normally begin play with this equipment at no cost. Listed for replacement purchases and store availability.","sourcebook":"Core Rulebook","costNumeric":2000,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":2000,"weightLabel":"2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["life-support","species-support","survival","gear"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":2000,"weight":2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false},"skillHooks":[],"normalizationStatus":"equipment-phase1-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"speciesSupport":["Kel Dor"]},"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"phase1-normalized"}}}
{"_id":"life-aquata-breather","name":"Aquata Breather","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","survival","gear"],"cost":350,"weight":0.2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A small mouthpiece that extracts oxygen from water, allowing breathing underwater indefinitely.</p>\n      <p><strong>Special:</strong> Allows breathing underwater. Does not work in airless environments.</p>","notes":"","sourcebook":"Core Rulebook","costNumeric":350,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":350,"weightLabel":"0.2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["life-support","survival","gear"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":350,"weight":0.2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false},"skillHooks":[],"normalizationStatus":"equipment-phase1-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"phase1-normalized"}}}
{"_id":"life-breath-mask","name":"Breath Mask","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","survival","gear"],"cost":200,"weight":2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A face-covering mask with air filters and a 1-hour oxygen supply. Protects against toxic atmospheres.</p>\n      <p><strong>Special:</strong> Provides 1 hour of breathable air. Filters toxic gases.</p>","notes":"","sourcebook":"Core Rulebook","costNumeric":200,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":200,"weightLabel":"2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["life-support","survival","gear"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":200,"weight":2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false},"skillHooks":[],"normalizationStatus":"equipment-phase1-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"phase1-normalized"}}}
{"_id":"life-breathing-apparatus","name":"Breathing Apparatus","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","species-support","survival","gear"],"cost":2000,"weight":2,"size":"small","availability":"Standard","quantity":1,"description":"<p>A sealed breathing apparatus for species that cannot tolerate standard atmospheres.</p><p><strong>Special:</strong> Commonly required by Gand and similar species when away from their native atmosphere.</p>","notes":"Species/environmental penalties are GM-adjudicated; this item exists so the required support gear can be bought and tracked.","sourcebook":"Core Rulebook","costNumeric":2000,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":2000,"weightLabel":"2 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["life-support","species-support","survival","gear"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":2000,"weight":2},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false},"skillHooks":[],"normalizationStatus":"equipment-phase1-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"speciesSupport":["Gand","Ubese"]},"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"phase1-normalized"}}}
{"_id":"life-celegian-support-chamber","name":"Celegian Life-Support Chamber","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","species-support","survival","gear"],"cost":2000,"weight":15,"size":"medium","availability":"Rare","quantity":1,"description":"<p>A sealed life-support chamber that maintains the cyanogen-rich atmosphere required by Celegians.</p><p><strong>Special:</strong> Celegians suffocate without an appropriate life-support chamber when exposed to oxygen atmospheres.</p>","notes":"Exact cost/availability may vary by campaign; included to support species equipment tracking.","sourcebook":"Unknown Regions","costNumeric":2000,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":2000,"weightLabel":"15 kg","restriction":"rare","equipped":false,"integrated":false,"source":"Unknown Regions","page":null,"traits":["life-support","species-support","survival","gear"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":2000,"weight":15},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false},"skillHooks":[],"normalizationStatus":"equipment-phase1-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"speciesSupport":["Celegian"]},"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"phase1-normalized"}}}
{"_id":"life-emergency-vacuum-seal","name":"Emergency Vacuum Seal","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["life-support","survival","gear"],"cost":750,"weight":0.9,"size":"small","availability":"Standard","quantity":1,"description":"<p>A compact emergency kit that creates a temporary seal around hull breaches or provides emergency pressure protection.</p>\n      <p><strong>Special:</strong> Can seal a 2-meter breach or provide 30 minutes of emergency pressure protection.</p>","notes":"","sourcebook":"Unknown Regions","costNumeric":750,"schemaVersion":3,"category":"survival","equipmentBucket":"survival","equipmentBucketLabel":"Survival","equipmentType":"life-support","equipmentTypeLabel":"Life Support","itemRole":"gear","itemRoleLabel":"Gear","value":750,"weightLabel":"0.9 kg","restriction":"common","equipped":false,"integrated":false,"source":"Unknown Regions","page":null,"traits":["life-support","survival","gear"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"charges":{"current":null,"max":null},"consumeOn":""},"modifiers":{},"container":{"capacity":null,"contents":[]},"economics":{"cost":750,"weight":0.9},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false},"skillHooks":[],"normalizationStatus":"equipment-phase1-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"survival","equipmentPhase":"phase1-normalized"}}}
