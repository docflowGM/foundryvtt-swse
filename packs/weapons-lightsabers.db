{"_id":"lightsaber-chassis-archaic-lightfoil","name":"Archaic Lightfoil","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"archaic-lightfoil","constructible":true,"baseBuildDc":20,"baseCost":2250,"damage":"2d8","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":0.5,"cost":4500,"equipped":false,"description":"<p>A delicately balanced Lightfoil favored by Makashi practitioners. Can be treated as Small weapon. Cannot be wielded two-handed.</p>","properties":["Lightsaber","Throwable","Finesse"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d8","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Throwable","Finesse"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-archaic-lightsaber","name":"Archaic Lightsaber","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"archaic-lightsaber","constructible":true,"baseBuildDc":15,"baseCost":1000,"damage":"2d6","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":1,"cost":2000,"equipped":false,"description":"<p>An ancient lightsaber with an external belt-mounted power pack connected by cord. Less powerful than modern lightsabers but iconic in appearance.</p>","properties":["Lightsaber","Throwable","Archaic"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":1,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d6","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Throwable","Archaic"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-crossguard","name":"Crossguard Lightsaber","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"crossguard","constructible":true,"baseBuildDc":25,"baseCost":2000,"damage":"2d8","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":0.7,"cost":4000,"equipped":false,"description":"<p>A rare duelist's lightsaber with three blades: one primary and two secondary crossguards at 45-135 degree angles. Secondary blades protect the hand and enable superior blocking vs lightsaber attacks (-2 cumulative instead of -5). However, -2 penalty on Deflect checks vs ranged attacks. Can be thrown.</p>","properties":["Lightsaber","Throwable","Duelist"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d8","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Throwable","Duelist"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-double","name":"Lightsaber (Double-Bladed)","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"double","constructible":true,"baseBuildDc":20,"baseCost":6000,"damage":"2d8","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":3,"cost":12000,"equipped":false,"description":"<p>A double-bladed lightsaber with blades on both ends. Requires specialized training to use effectively.</p>","properties":[],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d8","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-dual-phase","name":"Dual-Phase Lightsaber","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"dual-phase","constructible":true,"baseBuildDc":25,"baseCost":3000,"damage":"2d8","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":0.5,"cost":6000,"equipped":false,"description":"<p>A sophisticated lightsaber with multiple crystals allowing blade length adjustment. Default form: standard reach. Extended form (Swift Action): +1 reach, -2 Reflex Defense vs adjacent.</p>","properties":["Lightsaber","Throwable","Dual-Form"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":3,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d8","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Throwable","Dual-Form"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-dueling","name":"Dueling Lightsaber","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"dueling","constructible":true,"baseBuildDc":25,"baseCost":1500,"damage":"2d8","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":0.3,"cost":3000,"equipped":false,"description":"<p>A curved-hilt lightsaber favored for one-handed finesse fighting. Grants +1 Equipment bonus on attack rolls when making Attacks of Opportunity one-handed.</p>","properties":["Lightsaber","Throwable","Finesse"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d8","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Throwable","Finesse"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-great","name":"Great Lightsaber","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"great","constructible":true,"baseBuildDc":20,"baseCost":2500,"damage":"2d10","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":5,"cost":5000,"equipped":false,"description":"<p>An oversized lightsaber favored by Large creatures. Only Large+ creatures can use it with weapon feats/talents. Can be thrown by Large species only.</p>","properties":["Lightsaber","Large-Only"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d10","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Large-Only"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-guard-shoto","name":"Guard Shoto","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"guard-shoto","constructible":true,"baseBuildDc":20,"baseCost":3500,"damage":"2d4","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":1,"cost":7000,"equipped":false,"description":"<p>A guard-style shoto with a second handle at 90 degrees for defensive positioning. Grants +2 Equipment bonus on Use the Force checks to block/deflect. Phrik-laced handle makes it resistant to lightsaber damage.</p>","properties":["Lightsaber","Throwable","Guard"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d4","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Throwable","Guard"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-lightwhip","name":"Lightwhip","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"lightwhip","constructible":true,"baseBuildDc":25,"baseCost":2500,"damage":"2d4","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":1,"cost":5000,"equipped":false,"description":"<p>A flexible energy whip with 2-square reach. Deals damage and allows grab/grapple initiation. Target can escape with DC 15 Acrobatics. Can use Pin and Trip but not Crush or Throw feats.</p>","properties":["Lightsaber","Reach","Whip"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d4","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Reach","Whip"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-longhandle","name":"Long-Handle Lightsaber","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"longhandle","constructible":true,"baseBuildDc":20,"baseCost":2250,"damage":"2d8","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":2,"cost":4500,"equipped":false,"description":"<p>A lightsaber with oversized grip for two-handed leverage. Two-handed: can forgo STR bonus doubling to increase base damage to 2d10. Can use as double weapon with Long Haft Strike feat (haft deals 1d6 bludgeoning).</p>","properties":["Lightsaber","TwoHanded"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d8","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","TwoHanded"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-modern-lightfoil","name":"Modern Lightfoil","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"modern-lightfoil","constructible":true,"baseBuildDc":15,"baseCost":1250,"damage":"2d6","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":0.5,"cost":2500,"equipped":false,"description":"<p>A modern recreation of the archaic lightfoil, built without Force training. Delicately balanced, can be treated as Small weapon. Cannot be wielded two-handed. Can be thrown.</p>","properties":["Lightsaber","Throwable","Finesse"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d6","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Throwable","Finesse"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
{"_id":"lightsaber-chassis-pike","name":"Lightsaber Pike","type":"weapon","img":"icons/svg/sword.svg","system":{"subtype":"lightsaber","chassisId":"pike","constructible":true,"baseBuildDc":20,"baseCost":2000,"damage":"2d8","damageType":"energy","attackBonus":0,"attackAttribute":"str","range":"melee","weight":2,"cost":4000,"equipped":false,"description":"<p>A polearm with lightsaber blade, favored by Emperor's Shadow Guard. Increases reach by 1 square but -2 penalty on block/deflect. Phrik haft is lightsaber-resistant. Can use as double weapon with Long Haft Strike feat.</p>","properties":["Lightsaber","Reach"],"ammunition":{"type":"none","current":0,"max":0},"weaponCategory":"melee","proficiency":"exotic","upgradeSlots":2,"installedUpgrades":[],"combat":{"attack":{"ability":"str","bonus":0},"damage":{"dice":"2d8","bonus":0,"type":"energy","ability":"str"}},"equippable":{"equipped":false,"slot":"hand"},"rangeProfile":"melee","weaponType":"melee","traits":["Lightsaber","Reach"]},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"swse":{"builtBy":null,"builtAt":null,"attunedBy":null}}}
