{"_id":"medical-medpac","name":"Medpac","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","consumable","skill-linked","medpac"],"cost":100,"weight":1,"size":"small","availability":"Standard","quantity":1,"description":"<p>A portable medical kit with sterile bandages, antibiotics, and basic medical supplies. Single-use.</p>\n      <p><strong>Special:</strong> Allows a Treat Injury check to restore HP. Single use.</p>","notes":"<p><strong>Rules:</strong> Required for First Aid. Contents are expended once used even if the Treat Injury check fails. A creature can benefit from a Medpac only once per 24 hours.</p>","sourcebook":"Core Rulebook","costNumeric":100,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"consumable","itemRoleLabel":"Consumable","value":100,"weightLabel":"1 kg","restriction":"common","equipped":false,"integrated":false,"source":"Core Rulebook","page":null,"traits":["medical","consumable","skill-linked","medpac"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"consumable","consumable":true,"consumeOn":"onAttempt","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"medpac","singleUse":true,"medpacFamily":true,"medpacCooldown":"24 hours"}},"container":{"capacity":null,"contents":[]},"economics":{"cost":100,"weight":1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":true,"container":false,"upgrade":false,"medicalUse":"medpac","singleUse":true,"medpacFamily":true,"medpacCooldown":"24 hours"},"skillHooks":[{"skill":"treatInjury","useKey":"first-aid","mode":"enables","required":true,"consumes":{"type":"quantity","amount":1,"timing":"onAttempt","reason":"Medpac contents are expended even if the Treat Injury check fails.","priority":10},"bonus":null,"source":"Medpac","note":"Required for First Aid; expended on attempt; one successful Medpac benefit per target per 24 hours."},{"skill":"treatInjury","useKey":"critical-care","mode":"enables","required":true,"consumes":{"type":"quantity","amount":1,"timing":"onAttempt","reason":"Critical Care expends one Medpac.","priority":10},"bonus":null,"source":"Medpac","note":"Required for Critical Care and expended on attempt."}],"normalizationStatus":"equipment-medical-phase2-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"medical","equipmentPhase":"medical-phase2","medicalUse":"medpac"}}}
