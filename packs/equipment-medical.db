{"_id":"medical-hypoinjector-wristband","name":"Hypoinjector Wristband","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","auto-injector"],"cost":350,"weight":0.1,"size":"small","availability":"Licensed","quantity":1,"description":"<p>A wrist-mounted auto-injector that can deliver pre-loaded medications with a button press.</p>\n      <p><strong>Special:</strong> Holds up to 3 doses. Can be triggered as a swift action.</p>","notes":"<p><strong>Rules:</strong> Stores up to 8 doses of vaccines, antidotes, or medication and can automatically inject an appropriate drug when a harmful substance is detected.</p>","sourcebook":"Unknown Regions","costNumeric":350,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":350,"weightLabel":"0.1 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Unknown Regions","page":null,"traits":["medical","gear","auto-injector"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"container","consumable":false,"consumeOn":"","charges":{"current":8,"max":8}},"modifiers":{"medical":{"skillLinked":false,"medicalUse":"auto-injector","storesDoses":8,"refillTime":"standard action per dose or 4 rounds for all doses","power":"two energy cells for 5 days constant use"}},"container":{"capacity":null,"contents":[]},"economics":{"cost":350,"weight":0.1},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":true,"upgrade":false,"medicalUse":"auto-injector","storesDoses":8,"refillTime":"standard action per dose or 4 rounds for all doses","power":"two energy cells for 5 days constant use"},"skillHooks":[],"normalizationStatus":"equipment-medical-phase2-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"medical","equip