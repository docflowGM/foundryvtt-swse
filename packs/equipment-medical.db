{"_id":"medical-fastflesh-medpac","name":"FastFlesh Medpac","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","consumable","skill-linked","enhanced-medpac"],"cost":600,"weight":0.5,"size":"small","availability":"Licensed","quantity":1,"description":"<p>An advanced medpac with fast-acting tissue regeneration compounds.</p>\n      <p><strong>Special:</strong> Restores more HP than a standard medpac. Grants +2 bonus to Treat Injury check.</p>","notes":"<p><strong>Rules:</strong> Functions as a standard Medpac and grants +5 Equipment bonus to First Aid. Single use; shares the normal Medpac 24-hour benefit limit.</p>","sourcebook":"Threats of the Galaxy","costNumeric":600,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"consumable","itemRoleLabel":"Consumable","value":600,"weightLabel":"0.5 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Threats of the Galaxy","page":null,"traits":["medical","consumable","skill-linked","enhanced-medpac"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"consumable","consumable":true,"consumeOn":"onAttempt","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"enhanced-medpac","singleUse":true,"medpacFamily":true,"medpacCooldown":"24 hours"}},"container":{"capacity":null,"contents":[]},"economics":{"cost":600,"weight":0.5},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":true,"container":false,"upgrade":false,"medicalUse":"enhanced-medpac","singleUse":true,"medpacFamily":true,"medpacCooldown":"24 hours"},"skillHooks":[{"skill":"treatInjury","useKey":"first-aid","mode":"enables","required":true,"consumes":{"type":"quantity","amount":1,"timing":"onAttempt","reason":"FastFlesh Medpac has enough material for a single use.","priority":50},"bonus":{"type":"equipment","value":5,"a