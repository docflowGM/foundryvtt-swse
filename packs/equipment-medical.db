{"_id":"medical-cryogenic-pouch","name":"Cryogenic Pouch","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","field-stabilization"],"cost":600,"weight":1.5,"size":"small","availability":"Licensed","quantity":1,"description":"<p>A portable cryogenic container that preserves critically injured patients in stasis for transport.</p>\n      <p><strong>Special:</strong> Stabilizes dying characters and preserves them for up to 72 hours.</p>","notes":"<p><strong>Rules:</strong> Full-Round Action to wrap an unconscious creature; a creature at 0 HP due to Poison, Radiation, or damage exceeding Damage Threshold can be stabilized within 1d3 rounds, remains unconscious, and moves -5 steps on the Condition Track.</p>","sourcebook":"Galaxy at War","costNumeric":600,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":600,"weightLabel":"1.5 kg","restriction":"licensed","equipped":false,"integrated":false,"source":"Galaxy at War","page":null,"traits":["medical","gear","field-stabilization"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"active","consumable":false,"consumeOn":"","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":false,"medicalUse":"field-stabilization","actionTime":"full-round action","duration":"24 hours","damageReduction":5}},"container":{"capacity":null,"contents":[]},"economics":{"cost":600,"weight":1.5},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false,"medicalUse":"field-stabilization","actionTime":"full-round action","duration":"24 hours","damageReduction":5},"skillHooks":[],"normalizationStatus":"equipment-medical-phase2-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"foundryvtt-swse":{"equipmentBucket":"medical","equip