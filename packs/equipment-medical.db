{"_id":"medical-antitoxin-patch","name":"Antitoxin Patch","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","consumable","poison-defense"],"cost":25,"weight":0,"size":"small","availability":"Standard","quantity":1,"description":"<p>A dermal patch that releases broad-spectrum antitoxins when applied.</p>\n      <p><strong>Special:</strong> Grants +2 bonus to Fortitude Defense against poisons for 8 hours.</p>","notes":"<p><strong>Rules:</strong> Grants +10 Equipment bonus to Fortitude Defense against Ingested Poisons and +5 against Inhaled Poisons for 24 hours; consecutive daily use moves the target -1 step on the Condition Track.</p>","sourcebook":"Galaxy of Intrigue","costNumeric":25,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"consumable","itemRoleLabel":"Consumable","value":25,"weightLabel":"0 kg","restriction":"common","equipped":false,"integrated":false,"source":"Galaxy of Intrigue","page":null,"traits":["medical","consumable","poison-defense"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"consumable","consumable":true,"consumeOn":"manual","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":false,"medicalUse":"poison-defense","fortitudeDefenseBonus":[{"value":10,"type":"equipment","against":"ingested poison","duration":"24 hours"},{"value":5,"type":"equipment","against":"inhaled poison","duration":"24 hours"}],"conditionRisk":"For each consecutive day worn, target moves -1 step on the Condition Track."}},"container":{"capacity":null,"contents":[]},"economics":{"cost":25,"weight":0},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":true,"container":false,"upgrade":false,"medicalUse":"poison-defense","fortitudeDefenseBonus":[{"value":10,"type":"equipment","against":"ingested poison","duration":"24 hours"},{"value":5,"type":"equipment"