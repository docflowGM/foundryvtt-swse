{"_id":"medical-bundle","name":"Medical Bundle","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","skill-linked","compact-treatment-kit"],"cost":200,"weight":1,"size":"small","availability":"Standard","quantity":1,"description":"<p>A basic medical supply pack with bandages, antiseptics, and emergency medications.</p>\n      <p><strong>Special:</strong> Contains 5 uses. Can stabilize dying characters.</p>","notes":"<p><strong>Rules:</strong> Compact Jedi medical bundle for treating ailments and diseases. It is modeled as enabling Treat Disease, Treat Poison, and Treat Radiation, but not First Aid Medpac consumption or Surgery.</p>","sourcebook":"Jedi Academy Training Manual","costNumeric":200,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":200,"weightLabel":"1 kg","restriction":"common","equipped":false,"integrated":false,"source":"Jedi Academy Training Manual","page":null,"traits":["medical","gear","skill-linked","compact-treatment-kit"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"passive","consumable":false,"consumeOn":"","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":true,"medicalUse":"compact-treatment-kit","compactMedicalKit":true,"lacksBactaPatches":true}},"container":{"capacity":null,"contents":[]},"economics":{"cost":200,"weight":1},"capabilities":{"skillHooksReady":true,"skillLinked":true,"consumable":false,"container":false,"upgrade":false,"medicalUse":"compact-treatment-kit","compactMedicalKit":true,"lacksBactaPatches":true},"skillHooks":[{"skill":"treatInjury","useKey":"treat-disease","mode":"requires","required":true,"consumes":null,"bonus":null,"source":"Medical Kit","note":"Required to Treat Disease."},{"skill":"treatInjury","useKey":"treat-poison","mode":"requires","required":true,"consumes":null