{"_id":"medical-medisensor","name":"Medisensor","type":"equipment","img":"icons/svg/upgrade.svg","system":{"tags":["medical","gear","vitals-sensor"],"cost":75,"weight":0.1,"size":"small","availability":"Standard","quantity":1,"description":"<p>A handheld diagnostic device that scans vital signs and identifies injuries and diseases.</p>\n      <p><strong>Special:</strong> Grants +2 equipment bonus to Treat Injury checks for diagnosis.</p>","notes":"<p><strong>Rules:</strong> Swift Action on an adjacent creature to learn current HP, Condition Track position, and whether Disease, Poison, or Radiation exposure is present.</p>","sourcebook":"Threats of the Galaxy","costNumeric":75,"schemaVersion":4,"category":"medical","equipmentBucket":"medical","equipmentBucketLabel":"Medical","equipmentType":"medical","equipmentTypeLabel":"Medical Gear","itemRole":"gear","itemRoleLabel":"Gear","value":75,"weightLabel":"0.1 kg","restriction":"common","equipped":false,"integrated":false,"source":"Threats of the Galaxy","page":null,"traits":["medical","gear","vitals-sensor"],"properties":[],"equippable":{"equipped":false,"slot":null},"usage":{"mode":"active","consumable":false,"consumeOn":"","charges":{"current":null,"max":null}},"modifiers":{"medical":{"skillLinked":false,"medicalUse":"vitals-sensor","actionTime":"swift action","range":"adjacent","reveals":["current hit points","condition track","presence of disease","presence of poison","presence of radiation exposure"]}},"container":{"capacity":null,"contents":[]},"economics":{"cost":75,"weight":0.1},"capabilities":{"skillHooksReady":true,"skillLinked":false,"consumable":false,"container":false,"upgrade":false,"medicalUse":"vitals-sensor","actionTime":"swift action","range":"adjacent","reveals":["current hit points","condition track","presence of disease","presence of poison","presence of radiation exposure"]},"skillHooks":[],"normalizationStatus":"equipment-medical-phase2-normalized"},"effects":[],"folder":null,"sort":0,"ownership":{