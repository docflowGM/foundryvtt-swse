<section class="swse-entity-dialog__hero swse-entity-dialog__hero--item">
  <div>
    <div class="swse-entity-dialog__hero-kicker">Gear Profile</div>
    <h3>{{item.name}}</h3>
    <p>General equipment uses the existing <code>equipment</code> item schema. Categories here are presentation/store/inventory helpers, not new item types.</p>
  </div>
  <div class="swse-entity-dialog__stat-strip">
    <div class="swse-entity-dialog__stat"><span>Bucket</span><strong>{{entityDialog.equipment.equipmentBucketLabel}}</strong></div>
    <div class="swse-entity-dialog__stat"><span>Qty</span><strong>{{entityDialog.equipment.quantity}}</strong></div>
    <div class="swse-entity-dialog__stat"><span>Weight</span><strong>{{entityDialog.equipment.totalWeight}}</strong></div>
    <div class="swse-entity-dialog__stat"><span>Cost</span><strong>{{entityDialog.equipment.cost}}</strong></div>
  </div>
</section>

<section class="item-editor__section swse-entity-dialog__callout swse-entity-dialog__callout--resolver">
  <h3 class="item-editor__section-title">Equipment Data Source</h3>
  <p class="swse-entity-dialog__hint">This body reads normalized bucket, quantity, encumbrance, store value, usage metadata, and workbench fields from the equipment schema. Skill hooks are declarative metadata for later extra-skill-use integration; currently loaded hooks: {{entityDialog.equipment.skillHookCount}}.</p>
</section>

<div class="item-editor__grid item-editor__grid--two-col swse-entity-dialog__gear-grid">
  <section class="item-editor__section">
    <h3 class="item-editor__section-title">Inventory</h3>

    <div class="item-editor__grid item-editor__grid--two-col">
      <div class="form-field">
        <label>Bucket</label>
        <select name="system.equipmentBucket">
          {{#each entityDialog.equipment.equipmentBucketOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.equipmentBucket this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Category</label>
        <select name="system.category">
          {{#each entityDialog.equipment.categoryOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.category this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Equipment Type</label>
        <input type="text" name="system.equipmentType" value="{{entityDialog.equipment.equipmentType}}" placeholder="medical, tool, comlink, life-support" />
      </div>

      <div class="form-field">
        <label>Item Role</label>
        <input type="text" name="system.itemRole" value="{{entityDialog.equipment.itemRole}}" placeholder="gear, consumable, container, upgrade" />
      </div>

      <div class="form-field">
        <label>Size</label>
        <select name="system.size">
          {{#each entityDialog.equipment.sizeOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.size this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Quantity</label>
        <input type="number" name="system.quantity" value="{{entityDialog.equipment.quantity}}" min="1" step="1" data-dtype="Number" />
      </div>

      <div class="form-field">
        <label>Weight</label>
        <input type="number" name="system.weight" value="{{entityDialog.equipment.weight}}" step="0.1" data-dtype="Number" />
      </div>

      <div class="form-field">
        <label>Cost</label>
        <input type="number" name="system.cost" value="{{entityDialog.equipment.cost}}" data-dtype="Number" />
      </div>

      <div class="form-field">
        <label>Value</label>
        <input type="number" name="system.value" value="{{entityDialog.equipment.value}}" data-dtype="Number" />
      </div>

      <div class="form-field">
        <label>Availability</label>
        <select name="system.availability">
          {{#each entityDialog.equipment.availabilityOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.availabilityKey this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Total Weight</label>
        <input type="number" value="{{entityDialog.equipment.totalWeight}}" disabled />
        <p class="swse-entity-dialog__field-note">Readout only: quantity × weight. Encumbrance continues to use <code>system.quantity</code> and <code>system.weight</code>.</p>
      </div>

      <div class="form-field">
        <label>Usage Mode</label>
        <input type="text" name="system.usage.mode" value="{{entityDialog.equipment.usageMode}}" placeholder="passive, consumable, charges, container" />
      </div>

      <div class="form-field">
        <label>Consume On</label>
        <input type="text" name="system.usage.consumeOn" value="{{entityDialog.equipment.consumeOn}}" placeholder="manual, onAttempt, onSuccess" />
      </div>
    </div>
  </section>

  <section class="item-editor__section">
    <h3 class="item-editor__section-title">Skill Use Hooks</h3>
    <p class="swse-entity-dialog__hint">Optional primary hook used by the equipment skill-use resolver and suggestion engine. Leave Uses Skill and Skill Use Key blank for passive equipment.</p>

    <div class="item-editor__grid item-editor__grid--two-col">
      <div class="form-field">
        <label>Uses Skill</label>
        <select name="system.skillHooks.0.skill">
          {{#each entityDialog.equipment.skillOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.primarySkillHook.skill this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Skill Use Key</label>
        <input type="text" name="system.skillHooks.0.useKey" value="{{entityDialog.equipment.primarySkillHook.useKey}}" placeholder="first-aid, disable-device, endure-extreme-temperatures" />
      </div>

      <div class="form-field">
        <label>Hook Mode</label>
        <select name="system.skillHooks.0.mode">
          {{#each entityDialog.equipment.skillHookModeOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.primarySkillHook.mode this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Bonus Type</label>
        <select name="system.skillHooks.0.bonus.type">
          {{#each entityDialog.equipment.bonusTypeOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.primarySkillHook.bonusType this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Bonus</label>
        <input type="number" name="system.skillHooks.0.bonus.amount" value="{{entityDialog.equipment.primarySkillHook.bonusAmount}}" step="1" data-dtype="Number" placeholder="2" />
      </div>

      <div class="form-field">
        <label>Bonus Applies To</label>
        <input type="text" name="system.skillHooks.0.bonus.appliesTo" value="{{entityDialog.equipment.primarySkillHook.bonusAppliesTo}}" placeholder="all, first-aid, perception, installed/equipped only" />
      </div>

      <div class="form-field">
        <label>Consumes Type</label>
        <input type="text" name="system.skillHooks.0.consumes.type" value="{{entityDialog.equipment.primarySkillHook.consumeType}}" placeholder="quantity, charge, dose" />
      </div>

      <div class="form-field">
        <label>Consume Amount</label>
        <input type="number" name="system.skillHooks.0.consumes.amount" value="{{entityDialog.equipment.primarySkillHook.consumeAmount}}" step="1" data-dtype="Number" placeholder="1" />
      </div>

      <div class="form-field">
        <label>Consume Timing</label>
        <select name="system.skillHooks.0.consumes.timing">
          {{#each entityDialog.equipment.consumeTimingOptions}}
          <option value="{{this.value}}" {{#if (eq ../entityDialog.equipment.primarySkillHook.consumeTiming this.value)}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-field">
        <label>Hook Note</label>
        <input type="text" name="system.skillHooks.0.note" value="{{entityDialog.equipment.primarySkillHook.note}}" placeholder="Required, bonus limits, once-per-day notes, etc." />
      </div>
    </div>

    <div class="swse-entity-dialog__toggle-grid">
      <input type="hidden" name="system.skillHooks.0.required" value="false" />
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.skillHooks.0.required" value="true" {{#if entityDialog.equipment.primarySkillHook.required}}checked{{/if}} /> Required Gear</label>
      <input type="hidden" name="system.skillHooks.0.requiresEquipped" value="false" />
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.skillHooks.0.requiresEquipped" value="true" {{#if entityDialog.equipment.primarySkillHook.requiresEquipped}}checked{{/if}} /> Equipped Only</label>
    </div>
  </section>


  <section class="item-editor__section swse-entity-dialog__implant-panel">
    <h3 class="item-editor__section-title">Implant / Cybernetics Rules</h3>
    <p class="swse-entity-dialog__hint">Use this only for KOTOR-style implants or explicit bio-implant gear. Generic cybernetic prostheses should remain untagged unless the GM wants implant drawbacks to apply.</p>

    <div class="item-editor__grid item-editor__grid--two-col">
      <div class="form-field">
        <label>Implant Status</label>
        <input type="text" value="{{entityDialog.equipment.implantStatusLabel}}" disabled />
      </div>

      <div class="form-field">
        <label>Implant Notes</label>
        <input type="text" name="system.implantRules.notes" value="{{entityDialog.equipment.implantRules.notes}}" placeholder="Source/page, GM ruling, procedure notes" />
      </div>
    </div>

    <div class="swse-entity-dialog__toggle-grid">
      <input type="hidden" name="system.implantRules.countAsImplant" value="false" />
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.implantRules.countAsImplant" value="true" {{#if entityDialog.equipment.implantRules.countAsImplant}}checked{{/if}} /> Counts as Implant</label>

      <input type="hidden" name="system.installed" value="false" />
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.installed" value="true" {{#if entityDialog.equipment.installed}}checked{{/if}} /> Installed</label>

      <input type="hidden" name="system.active" value="false" />
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.active" value="true" {{#if entityDialog.equipment.active}}checked{{/if}} /> Active</label>

      <input type="hidden" name="system.implantRules.activeByOwnership" value="false" />
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.implantRules.activeByOwnership" value="true" {{#if entityDialog.equipment.implantRules.activeByOwnership}}checked{{/if}} /> Active While Owned</label>
    </div>

    {{#if entityDialog.equipment.implantPenaltyNote}}
      <p class="swse-entity-dialog__field-note swse-entity-dialog__field-note--implant">{{entityDialog.equipment.implantPenaltyNote}}</p>
    {{/if}}
  </section>

  <section class="item-editor__section">
    <h3 class="item-editor__section-title">Workbench / Store Hooks</h3>

    <div class="item-editor__grid item-editor__grid--two-col">
      <div class="form-field">
        <label>Upgrade Slots</label>
        <input type="number" name="system.upgradeSlots" value="{{entityDialog.equipment.upgradeSlots}}" data-dtype="Number" />
      </div>

      <div class="form-field">
        <label>Template Cost</label>
        <input type="number" name="system.templateCost" value="{{entityDialog.equipment.templateCost}}" data-dtype="Number" />
      </div>

      <div class="form-field">
        <label>Primary Template</label>
        <input type="text" name="system.gearTemplate" value="{{entityDialog.equipment.gearTemplate}}" placeholder="Existing template key" />
      </div>

      <div class="form-field">
        <label>Secondary Template</label>
        <input type="text" name="system.gearTemplateSecondary" value="{{entityDialog.equipment.gearTemplateSecondary}}" placeholder="Optional secondary template" />
      </div>
    </div>

    <div class="swse-entity-dialog__toggle-grid">
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.equipped" {{#if entityDialog.equipment.equipped}}checked{{/if}} /> Equipped</label>
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.integrated" {{#if entityDialog.equipment.integrated}}checked{{/if}} /> Integrated</label>
      <label class="swse-entity-dialog__toggle"><input type="checkbox" name="system.sizeIncreaseApplied" {{#if entityDialog.equipment.sizeIncreaseApplied}}checked{{/if}} /> Size Increase Applied</label>
    </div>
  </section>
</div>

<section class="item-editor__section">
  <h3 class="item-editor__section-title">Tags & Notes</h3>
  <div class="item-editor__grid item-editor__grid--two-col">
    <div class="form-field form-field--full">
      <label>Tags (comma-separated)</label>
      <input type="text" name="system.tags" value="{{entityDialog.equipment.tagsText}}" placeholder="medical, consumable, security" />
    </div>

    <div class="form-field form-field--full">
      <label>Properties (comma-separated)</label>
      <input type="text" name="system.properties" value="{{entityDialog.equipment.propertiesText}}" placeholder="single-use, container, toolkit" />
    </div>
  </div>
</section>
