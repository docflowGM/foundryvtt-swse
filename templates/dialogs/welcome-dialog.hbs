{{> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame.hbs"
  frameOuterClass="swse-first-run-frame swse-ui-shell swse-datapad flexcol"
  frameDataApp="first-run-experience"
  frameStyleInline=themeStyleInline
  frameStyleInlineExtra=motionStyleInline
  shellSurface=shellSurface
  shellTheme=themeKey
  shellMotionStyle=motionStyle
  shellStyleInline=themeStyleInline
  shellStyleInlineExtra=motionStyleInline
  shellExtraClass="swse-sheet-v2-shell--first-run"
  tabletExtraClass="swse-first-run-tablet"
  screenExtraClass="swse-first-run-screen-shell"
  serialLabel="FRX-1138-WELCOME"
  serialAria="First run welcome datapad"
  controlsLabel="First run welcome controls"
  topHomeAction="open-gm-window"
  topHomeNavTo="home"
  closeAction="first-run-close"
  expandAction="first-run-expand"
  dragTitle="First-run welcome datapad"
  dragLabel="First-run welcome datapad drag rail"
  showResize=true
}}
  <div class="swse-datapad swse-screen swse-first-run-screen flexcol">
    <div class="swse-shell-surface swse-shell-surface--welcome" data-shell-region="first-run-welcome">
      <div class="swse-shell-surface__header swse-welcome-header">
        <div>
          <div class="swse-welcome-kicker">FIRST RUN TRANSMISSION</div>
          <div class="swse-welcome-title">Welcome to Star Wars Saga Edition</div>
        </div>
        <button class="swse-btn ghost" data-action="open-gm-window" type="button">
          <i class="fa-solid fa-tablet-screen-button"></i>
          <span>Open GM Window</span>
        </button>
      </div>

      <div class="swse-shell-surface__body swse-welcome-body">
        <section class="swse-welcome-hero swse-panel">
          <div class="swse-welcome-hero__sigil"><i class="fa-solid fa-jedi"></i></div>
          <div class="swse-welcome-hero__copy">
            <h2>Hello there, {{gmName}}.</h2>
            <p>
              Thank you for launching this table. This system has been built with a lot of care to make
              Star Wars Saga Edition feel fast, cinematic, readable, and alive inside Foundry VTT.
            </p>
            <p>
              The goal is simple: help players build memorable heroes, give GMs better campaign tools,
              and let the table spend less time hunting for buttons and more time telling Star Wars stories.
            </p>
          </div>
        </section>

        <section class="swse-welcome-note swse-panel">
          <div class="swse-panel-head">◆ What this datapad is trying to do</div>
          <p>
            SWSE is a wonderfully crunchy game. This project tries to keep that depth while presenting it through
            guided flows, contextual advice, automation where it helps, and in-world tools that feel like they belong
            at the table.
          </p>
        </section>

        <section class="swse-welcome-feature-grid">
          {{#each welcomeFeatures}}
          <article class="swse-welcome-feature swse-panel">
            <div class="swse-welcome-feature__icon"><i class="{{this.icon}}"></i></div>
            <div class="swse-welcome-feature__text">
              <h3>{{this.title}}</h3>
              <p>{{this.text}}</p>
            </div>
          </article>
          {{/each}}
        </section>

        <section class="swse-welcome-note swse-panel swse-welcome-note--suggestions">
          <div class="swse-panel-head">◇ A note about suggestions</div>
          <p>
            The surveys offered throughout a character's life matter. They give the suggestion engine a sense of
            who the character is, what they value, and what kind of path they may be walking. But the most important
            signal is still the player's choices. The system is here to advise, not to take the character away from them.
          </p>
        </section>

        <section class="swse-welcome-note swse-panel">
          <div class="swse-panel-head">✦ Where to go next</div>
          <p>
            Open the GM Window to manage the campaign side of the system. Players can use their Holopad to register,
            train, level up, review settings, and open the System Manual from the Settings app when they want a guided tour.
          </p>
        </section>

        <div class="swse-welcome-footer-row">
          <label class="swse-welcome-checkbox">
            <input type="checkbox" id="swse-no-welcome-again" />
            <span>Don't show this again</span>
          </label>

          <div class="swse-welcome-actions">
            <button class="swse-btn ghost" data-action="open-gm-window" type="button">
              <i class="fa-solid fa-tablet-screen-button"></i>
              <span>Open GM Window</span>
            </button>
            <button class="swse-btn primary" data-action="got-it" type="button">
              <i class="fa-solid fa-check"></i>
              <span>Begin the Session</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
{{> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame-close.hbs"
  bottomHomeAction="open-gm-window"
  bottomHomeTitle="Open GM Window"
  bottomHomeLabel="Open GM Window"
  bottomEngraving="WELCOME DATAPAD - FIRST RUN EXPERIENCE - DEFAULT HOLOSHELL THEME"
  showResize=true
}}
