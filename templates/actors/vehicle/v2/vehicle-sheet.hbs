<section class="sheet-shell swse-sheet-ui swse-ui-shell swse-vehicle-sheet swse-vehicle-shell v2 flexcol">

    <header class="sheet-header swse-ui-frame">
      <div class="flexrow" style="align-items:center; gap:12px;">
        <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" width="52" height="52" style="border-radius:8px;"/>
        <div class="flexcol" style="gap:4px;">
          <input name="name" type="text" value="{{actor.name}}" style="font-size:1.25rem; font-weight:800;"/>
          <div class="muted" style="opacity:0.8;">v2 Vehicle Sheet — Phase 3 Rule Surfaces</div>
        </div>
      </div>
    </header>

    <section class="sheet-body flexcol">

      <nav class="sheet-tabs tabs flexrow swse-ui-tabs swse-vehicle-tabs" data-group="primary">
        <a class="item" data-tab="overview">Overview</a>
        <a class="item" data-tab="weapons">Weapons</a>
        <a class="item" data-tab="crew">Crew</a>
        <a class="item" data-tab="systems">Systems</a>
        <a class="item" data-tab="cargo">Cargo</a>
      </nav>

      <section class="sheet-content swse-vehicle-content">

        <!-- OVERVIEW TAB: Identity, defenses, health, crew summary, cargo summary, turn phase -->
        <section class="tab flexcol" data-group="primary" data-tab="overview">
          {{#if vehiclePanels.headerSummaryPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-header-summary-panel.hbs" panel=vehiclePanels.headerSummaryPanel}}
          {{/if}}

          {{#if vehiclePanels.hpConditionPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-hp-condition-panel.hbs" panel=vehiclePanels.hpConditionPanel}}
          {{/if}}

          {{#if vehiclePanels.defensesPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-defenses-panel-full.hbs" panel=vehiclePanels.defensesPanel}}
          {{/if}}

          {{#if vehiclePanels.crewSummaryPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-crew-summary-panel.hbs" panel=vehiclePanels.crewSummaryPanel}}
          {{/if}}

          {{#if vehiclePanels.cargoSummaryPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-cargo-summary-panel.hbs" panel=vehiclePanels.cargoSummaryPanel}}
          {{/if}}

          {{#if vehiclePanels.turnPhasePanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-turn-phase-panel.hbs" panel=vehiclePanels.turnPhasePanel}}
          {{/if}}
        </section>

        <!-- WEAPONS TAB: Mounted weapons, pilot maneuvers -->
        <section class="tab flexcol" data-group="primary" data-tab="weapons">
          {{#if vehiclePanels.weaponMountPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-weapon-mount-panel.hbs" panel=vehiclePanels.weaponMountPanel}}
          {{/if}}

          {{#if vehiclePanels.pilotManeuverPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-pilot-maneuver-panel.hbs" panel=vehiclePanels.pilotManeuverPanel}}
          {{/if}}
        </section>

        <!-- CREW TAB: Crew summary, station assignments, commander orders -->
        <section class="tab flexcol" data-group="primary" data-tab="crew">
          {{#if vehiclePanels.crewSummaryPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-crew-summary-panel.hbs" panel=vehiclePanels.crewSummaryPanel}}
          {{/if}}

          {{#if vehiclePanels.crewAssignmentPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-crew-assignment-panel.hbs" panel=vehiclePanels.crewAssignmentPanel}}
          {{/if}}

          {{#if vehiclePanels.commanderOrderPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-commander-order-panel.hbs" panel=vehiclePanels.commanderOrderPanel}}
          {{/if}}
        </section>

        <!-- SYSTEMS TAB: Subsystems, shields, power -->
        <section class="tab flexcol" data-group="primary" data-tab="systems">
          {{#if vehiclePanels.subsystemDetailPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-subsystem-detail-panel.hbs" panel=vehiclePanels.subsystemDetailPanel}}
          {{/if}}

          {{#if vehiclePanels.shieldManagementPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-shield-management-panel.hbs" panel=vehiclePanels.shieldManagementPanel}}
          {{/if}}

          {{#if vehiclePanels.powerSummaryPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-power-summary-panel.hbs" panel=vehiclePanels.powerSummaryPanel}}
          {{/if}}
        </section>

        <!-- CARGO TAB: Cargo manifest -->
        <section class="tab flexcol" data-group="primary" data-tab="cargo">
          {{#if vehiclePanels.cargoSummaryPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-cargo-summary-panel.hbs" panel=vehiclePanels.cargoSummaryPanel}}
          {{/if}}

          {{#if vehiclePanels.cargoManifestPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/vehicle/v2/partials/vehicle-cargo-manifest-panel.hbs" panel=vehiclePanels.cargoManifestPanel}}
          {{/if}}
        </section>

      </section>

    </section>

</section>
