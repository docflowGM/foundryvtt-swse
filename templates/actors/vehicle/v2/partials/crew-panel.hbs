<div class="holo-panel swse-ui-panel swse-crew-suite" data-drop-zone="crew">
  <div class="section-bar">
    <h3 class="section-header">Crew Management</h3>
  </div>

  <div class="swse-store-section">
    {{#if actor.system.ownedActors}}
      <div class="crew-list swse-store-stage">
        {{#each actor.system.ownedActors as |entry|}}
          {{#with (lookup ownedActorMap entry.id)}}
          <div class="crew-entry swse-row-surface">
            <div class="crew-ident">
              <strong>{{this.name}}</strong><br>
              <span class="crew-meta">{{entry.type}}</span>
            </div>
            <button type="button"
                    class="crew-open-btn swse-ui-button"
                    data-action="open-owned"
                    data-actor-id="{{this.id}}">
              Open
            </button>
            <button type="button"
                    class="crew-remove-btn swse-ui-button"
                    data-action="remove-owned"
                    data-actor-id="{{this.id}}">
              Remove
            </button>
          </div>
          {{/with}}
        {{/each}}
      </div>
    {{else}}
      <div class="muted empty-state">No crew members. Drag characters/NPCs here to add them.</div>
    {{/if}}
  </div>
</div>
