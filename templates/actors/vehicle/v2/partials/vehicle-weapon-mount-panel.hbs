<section class="swse-vehicle-panel">
  <header class="swse-vehicle-panel-header">
    <h3 class="swse-vehicle-panel-title">{{panel.title}}</h3>
  </header>

  <div class="swse-vehicle-panel-body">
    <div class="swse-vehicle-weapon-list">
      {{#each panel.mounts as |mount|}}
        <div class="swse-vehicle-weapon-card">
          <div class="swse-vehicle-weapon-titlebar">
            <h4 class="swse-vehicle-weapon-name">{{mount.name}}</h4>
            <span class="swse-vehicle-weapon-chip">{{mount.arc}}</span>
          </div>

          <div class="swse-vehicle-weapon-meta">
            <span class="swse-vehicle-weapon-chip">
              <span class="swse-vehicle-weapon-stat-label">Gunner:</span>
              {{mount.gunner}}
            </span>
            <span class="swse-vehicle-weapon-chip">
              <span class="swse-vehicle-weapon-stat-label">Fire Control:</span>
              {{mount.fireControl}}
            </span>
          </div>

          <div class="swse-vehicle-weapon-statline">
            <div class="swse-vehicle-weapon-stat">
              <span class="swse-vehicle-weapon-stat-label">Attack</span>
              <span class="swse-vehicle-weapon-stat-value">{{mount.attackSummary}}</span>
            </div>
            <div class="swse-vehicle-weapon-stat">
              <span class="swse-vehicle-weapon-stat-label">Damage</span>
              <span class="swse-vehicle-weapon-stat-value">{{mount.damageSummary}}</span>
            </div>
          </div>

          {{#if mount.linkedGroup}}
            <div style="margin-top: 0.45rem; padding-top: 0.45rem; border-top: 1px solid rgba(255,255,255,0.08); font-size: 0.72rem; color: var(--swse-vehicle-text-muted);">
              <span style="text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700;">Linked:</span> {{mount.linkedGroup}}
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  </div>
</section>
