<section class="swse-vehicle-panel swse-vehicle-enhanced-panel" data-panel="vehicle-turn-controller">
  <header class="swse-vehicle-panel-header">
    <h3 class="swse-vehicle-panel-title">{{panel.title}}</h3>
    <span class="swse-vehicle-rule-chip">Vehicle Turn Controller</span>
  </header>

  <div class="swse-vehicle-panel-body">
    <div class="swse-vehicle-active-readout">
      <div class="swse-vehicle-active-label">{{panel.roundLabel}}</div>
      <div class="swse-vehicle-active-value">{{panel.currentPhase}}</div>
    </div>

    <div class="swse-vehicle-phase-list">
      {{#each panel.phases as |phase|}}
        <div class="swse-vehicle-phase-step {{#if phase.active}}is-active{{else if phase.completed}}is-complete{{/if}}">
          <div class="swse-vehicle-phase-indicator"></div>
          <div class="swse-vehicle-phase-label">{{phase.label}}</div>
        </div>
      {{/each}}
    </div>

    <div class="swse-vehicle-panel-actions">
      <button type="button" class="swse-v2-btn" data-action="advance-phase">Advance Phase</button>
      <button type="button" class="swse-v2-btn" data-action="reset-turn">Start/Reset Turn</button>
    </div>
  </div>
</section>
