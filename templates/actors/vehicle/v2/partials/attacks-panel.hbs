<div class="holo-panel">
  <div class="section-bar">
    <h3 class="section-header">{{localize "SWSE.ActorUI.Attacks"}}</h3>
    <div class="muted">{{localize "SWSE.ActorUI.EquippedWeaponsDataOnlyPreview"}}</div>
  </div>

  <div class="swse-v2-attacks">
    <div class="swse-v2-attack-header">
      <span class="name">{{localize "SWSE.ActorUI.Weapon"}}</span>
      <span class="meta">{{localize "SWSE.ActorUI.Type"}}</span>
      <span class="meta">{{localize "SWSE.ActorUI.Range"}}</span>
      <span class="meta">{{localize "SWSE.ActorUI.Damage"}}</span>
      <span class="meta">{{localize "SWSE.ActorUI.Resources"}}</span>
      <span class="meta"></span>
    </div>
    {{#each derived.attacks.list}}
      <div class="swse-v2-attack-row" title="{{localize 'SWSE.ActorUI.ClickNameToOpenItem'}}">
        <a class="name swse-v2-open-item" data-item-id="{{this.id}}">{{this.name}}</a>
        <span class="meta">{{this.type}}</span>
        <span class="meta">{{this.range}}</span>
        <span class="meta">{{this.damage}}</span>
        <span class="meta">
          {{#if this.resources.length}}
            <div class="swse-v2-resources">
              {{#each this.resources as |r|}}
                <div class="swse-v2-resource" data-kind="{{r.kind}}">
                  <span class="ticks {{r.sizeClass}}">
                    {{#each r.ticks as |t|}}
                      <span class="tick {{#if t.filled}}filled{{/if}}"></span>
                    {{/each}}
                  </span>
                  <span class="count">{{r.labelText}}</span>
                </div>
              {{/each}}
            </div>
          {{/if}}
        </span>
        <span class="meta" style="text-align:right;">
          <button type="button" class="swse-v2-btn" data-action="roll-weapon" data-item-id="{{this.id}}">{{localize "SWSE.ActorUI.Attack"}}</button>
        </span>
      </div>
    {{/each}}

    {{#unless derived.attacks.list.length}}
      <div class="muted" style="padding:6px 0;">{{localize "SWSE.ActorUI.NoEquippedWeapons"}}</div>
    {{/unless}}
  </div>
</div>
