<div class="swse-v2-resources">
  <div class="swse-v2-resource" data-kind="hp" title="{{localize 'SWSE.ActorUI.HitPoints'}}">
    <span class="label">{{localize "SWSE.ActorUI.HP"}}</span>
    <div style="display:flex; gap:8px; align-items:center;">
      <span class="count">{{system.hp.value}}/{{system.hp.max}}</span>
    </div>
  </div>

  <div class="swse-v2-resource" data-kind="sr" title="{{localize 'SWSE.ActorUI.ShieldRating'}}">
    <span class="label">{{localize "SWSE.ActorUI.SR"}}</span>
    <div style="display:flex; gap:8px; align-items:center;">
      <span class="count">{{system.shieldRating}}</span>
    </div>
  </div>

  <div class="swse-v2-resource" data-kind="dr" title="{{localize 'SWSE.ActorUI.DamageReduction'}}">
    <span class="label">{{localize "SWSE.ActorUI.DR"}}</span>
    <div style="display:flex; gap:8px; align-items:center;">
      <span class="count">{{system.damageReduction}}</span>
    </div>
  </div>

  <div class="swse-v2-resource" data-kind="speed" title="{{localize 'SWSE.ActorUI.MaxVelocity'}}">
    <span class="label">{{localize "SWSE.ActorUI.Speed"}}</span>
    <div style="display:flex; gap:8px; align-items:center;">
      <span class="count">{{system.maxVelocity}}</span>
    </div>
  </div>

  <div class="swse-v2-resource" data-kind="crew" title="{{localize 'SWSE.ActorUI.CrewCapacity'}}">
    <span class="label">{{localize "SWSE.ActorUI.Crew"}}</span>
    <div style="display:flex; gap:8px; align-items:center;">
      <span class="count">{{system.crewCapacity}}</span>
    </div>
  </div>
</div>
