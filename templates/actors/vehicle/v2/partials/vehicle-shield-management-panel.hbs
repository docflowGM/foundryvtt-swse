<section class="swse-vehicle-shield-panel swse-vehicle-panel">
  <header class="swse-vehicle-panel-header">
    <h3 class="swse-vehicle-panel-title">{{panel.title}}</h3>
  </header>

  <div class="swse-vehicle-panel-body">
    <!-- SHIELD CAPACITY BAR -->
    <div class="swse-vehicle-shield-capacity-bar">
      <div class="swse-vehicle-shield-capacity-fill" style="width: {{#if (gt panel.max 0)}}{{#multiply panel.total panel.max}}{{/multiply}}{{else}}0{{/if}}%;"></div>
      <div class="swse-vehicle-shield-capacity-label">
        <span class="swse-vehicle-shield-capacity-value">{{panel.total}}/{{panel.max}}</span>
      </div>
    </div>

    <!-- SHIELD ZONE GRID -->
    <div class="swse-vehicle-shield-list">
      {{#each panel.zones as |zone|}}
        <div class="swse-vehicle-shield-zone swse-vehicle-shield-zone--{{zone.state}}">
          <div class="swse-vehicle-shield-zone-name">{{zone.label}}</div>
          <div class="swse-vehicle-shield-zone-value">{{zone.value}}</div>
        </div>
      {{/each}}
    </div>

    <!-- SHIELD STATS -->
    <div class="swse-vehicle-shield-stats">
      <div class="swse-vehicle-stat-row">
        <span class="swse-vehicle-stat-label">Max Capacity:</span>
        <span class="swse-vehicle-stat-value">{{panel.max}}</span>
      </div>
      <div class="swse-vehicle-stat-row">
        <span class="swse-vehicle-stat-label">Recharge Rate:</span>
        <span class="swse-vehicle-stat-value">{{panel.rechargeRate}} per round</span>
      </div>
    </div>

    {{#if panel.notes}}
      <div class="swse-vehicle-shield-notes">
        {{#each panel.notes as |note|}}
          <div class="swse-vehicle-note-item">{{note}}</div>
        {{/each}}
      </div>
    {{/if}}
  </div>
</section>
