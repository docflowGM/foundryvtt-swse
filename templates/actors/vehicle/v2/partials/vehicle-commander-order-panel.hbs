<section class="swse-vehicle-panel swse-vehicle-enhanced-panel" data-panel="enhanced-commander">
  <header class="swse-vehicle-panel-header">
    <h3 class="swse-vehicle-panel-title">{{panel.title}}</h3>
    <span class="swse-vehicle-rule-chip">Enhanced Commander</span>
  </header>

  <div class="swse-vehicle-panel-body">
    {{#if panel.currentOrder}}
      <div class="swse-vehicle-active-readout">
        <div class="swse-vehicle-active-label">Active Order</div>
        <div class="swse-vehicle-active-value">{{panel.currentOrder.label}}</div>
      </div>
    {{/if}}

    {{#if panel.orders}}
      <div class="swse-vehicle-order-list">
        {{#each panel.orders as |order|}}
          <button type="button" class="swse-vehicle-order-card {{#if order.active}}is-active{{/if}}" data-action="set-order" data-order="{{order.key}}">
            <div class="swse-vehicle-order-header">
              <span class="swse-vehicle-order-name">{{order.label}}</span>
              {{#if order.active}}
                <span class="swse-vehicle-active-badge">Active</span>
              {{/if}}
            </div>
            <div class="swse-vehicle-order-summary">{{order.summary}}</div>
          </button>
        {{/each}}
      </div>
    {{/if}}
  </div>
</section>
