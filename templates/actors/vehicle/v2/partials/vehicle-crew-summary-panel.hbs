<section class="swse-vehicle-crew-panel swse-vehicle-panel">
  <header class="swse-vehicle-panel-header">
    <h3 class="swse-vehicle-panel-title">{{panel.title}}</h3>
  </header>

  <div class="swse-vehicle-panel-body">
    <div class="swse-vehicle-crew-stats">
      <div class="swse-vehicle-crew-stat">
        <span class="swse-vehicle-crew-stat-label">Crew:</span>
        <span class="swse-vehicle-crew-stat-value">{{panel.filledSlots}}/{{panel.totalSlots}}</span>
      </div>
      <div class="swse-vehicle-crew-stat">
        <span class="swse-vehicle-crew-stat-label">Quality:</span>
        <span class="swse-vehicle-crew-stat-value">{{panel.quality}}</span>
      </div>
      <div class="swse-vehicle-crew-stat">
        <span class="swse-vehicle-crew-stat-label">{{panel.passengers}}</span>
      </div>
    </div>
  </div>
</section>
