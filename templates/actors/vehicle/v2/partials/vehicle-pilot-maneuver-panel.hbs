<section class="swse-vehicle-panel swse-vehicle-enhanced-panel" data-panel="enhanced-pilot">
  <header class="swse-vehicle-panel-header">
    <h3 class="swse-vehicle-panel-title">{{panel.title}}</h3>
    <span class="swse-vehicle-rule-chip">Enhanced Pilot</span>
  </header>

  <div class="swse-vehicle-panel-body">
    {{#if panel.currentManeuver}}
      <div class="swse-vehicle-active-readout">
        <div class="swse-vehicle-active-label">Active Maneuver</div>
        <div class="swse-vehicle-active-value">{{panel.currentManeuver.label}}</div>
      </div>
    {{/if}}

    {{#if panel.maneuvers}}
      <div class="swse-vehicle-maneuver-list">
        {{#each panel.maneuvers as |maneuver|}}
          <button type="button" class="swse-vehicle-maneuver-card {{#if maneuver.active}}is-active{{/if}}" data-action="set-maneuver" data-maneuver="{{maneuver.key}}">
            <div class="swse-vehicle-maneuver-header">
              <span class="swse-vehicle-maneuver-name">{{maneuver.label}}</span>
              {{#if maneuver.active}}
                <span class="swse-vehicle-active-badge">Active</span>
              {{/if}}
            </div>
            <div class="swse-vehicle-maneuver-summary">{{maneuver.summary}}</div>
          </button>
        {{/each}}
      </div>
    {{/if}}
  </div>
</section>
