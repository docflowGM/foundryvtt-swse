<section class="swse-vehicle-panel swse-vehicle-hp-panel {{#if panel.critical}}is-critical{{else if panel.warning}}is-warning{{/if}}">
  <header class="swse-vehicle-panel-header">
    <h3 class="swse-vehicle-panel-title">{{panel.title}}</h3>
  </header>

  <div class="swse-vehicle-panel-body">
    <div class="swse-vehicle-hp-topline">
      <span class="swse-vehicle-hp-title">Hull Integrity</span>
      <span class="swse-vehicle-hp-value">{{panel.hp.value}}/{{panel.hp.max}}</span>
    </div>

    <div class="swse-vehicle-hp-bar">
      <div class="swse-vehicle-hp-fill" style="--fill-pct: {{panel.hp.percent}}%;"></div>
    </div>

    <div class="swse-vehicle-hp-stats">
      <div class="swse-vehicle-hp-stat">
        <span class="swse-vehicle-hp-stat-label">Threshold</span>
        <span class="swse-vehicle-hp-stat-value">{{panel.damageThreshold}}</span>
      </div>
      <div class="swse-vehicle-hp-stat">
        <span class="swse-vehicle-hp-stat-label">Reduction</span>
        <span class="swse-vehicle-hp-stat-value">{{panel.damageReduction}}</span>
      </div>
      {{#if (gt panel.hp.temp 0)}}
        <div class="swse-vehicle-hp-stat">
          <span class="swse-vehicle-hp-stat-label">Temp HP</span>
          <span class="swse-vehicle-hp-stat-value">{{panel.hp.temp}}</span>
        </div>
      {{/if}}
    </div>

    <div class="swse-vehicle-condition-state {{#if panel.condition.severity}}is-{{panel.condition.severity}}{{/if}}">
      {{panel.condition.label}}
      {{#if (gt panel.condition.penalty 0)}}
        <span style="margin-left: 0.5rem;">−{{panel.condition.penalty}}</span>
      {{/if}}
    </div>
  </div>
</section>
