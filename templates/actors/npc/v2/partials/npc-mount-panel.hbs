<section class="swse-npc-card swse-npc-mount-card">
  <header class="swse-npc-card__header">
    <div class="swse-npc-card__header-main">
      <h3 class="swse-section-title">{{localize "SWSE.ActorUI.MountOperations"}}</h3>
      <p class="swse-npc-card__subhead">
        {{localize "SWSE.ActorUI.RiderFacingOperationalSummaryForThisMountProfile"}}
      </p>
    </div>

    <div class="swse-npc-badges">
      <span class="swse-npc-badge swse-npc-badge--subtype">{{localize "SWSE.ActorUI.Mount"}}</span>
      {{#if mountSummary.battleTrained}}
        <span class="swse-npc-badge swse-npc-badge--warning">{{localize "SWSE.ActorUI.BattleTrained"}}</span>
      {{/if}}
    </div>
  </header>

  <div class="swse-npc-card__body">
    <div class="swse-npc-summary-grid">
      <div class="swse-npc-summary-stat">
        <label class="swse-npc-summary-stat__label">{{localize "SWSE.ActorUI.Rider"}}</label>
        <div class="swse-npc-summary-stat__value">
          {{#if mountSummary.riderName}}{{mountSummary.riderName}}{{else}}—{{/if}}
        </div>
      </div>

      <div class="swse-npc-summary-stat">
        <label class="swse-npc-summary-stat__label">{{localize "SWSE.ActorUI.BattleTrained"}}</label>
        <div class="swse-npc-summary-stat__value">
          {{#if mountSummary.battleTrained}}Yes{{else}}No{{/if}}
        </div>
      </div>

      <div class="swse-npc-summary-stat">
        <label class="swse-npc-summary-stat__label">{{localize "SWSE.ActorUI.PassengerSlots"}}</label>
        <div class="swse-npc-summary-stat__value">
          {{#if mountSummary.passengerSlots}}{{mountSummary.passengerSlots}}{{else}}—{{/if}}
        </div>
      </div>

      <div class="swse-npc-summary-stat">
        <label class="swse-npc-summary-stat__label">{{localize "SWSE.ActorUI.CarryingCapacity"}}</label>
        <div class="swse-npc-summary-stat__value">
          {{#if mountSummary.carryingCapacity}}{{mountSummary.carryingCapacity}}{{else}}—{{/if}}
        </div>
      </div>
    </div>

    <dl class="swse-npc-meta-list">
      <div class="swse-npc-meta-list__row">
        <dt>{{localize "SWSE.ActorUI.Saddle"}}</dt>
        <dd>{{#if mountSummary.saddle}}{{mountSummary.saddle}}{{else}}None listed{{/if}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>{{localize "SWSE.ActorUI.MovementNotes"}}</dt>
        <dd>{{#if mountSummary.mountedMovementNotes}}{{mountSummary.mountedMovementNotes}}{{else}}No mounted movement notes recorded.{{/if}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>{{localize "SWSE.ActorUI.Notes"}}</dt>
        <dd>{{#if mountSummary.notes}}{{mountSummary.notes}}{{else}}No additional mount notes recorded.{{/if}}</dd>
      </div>
    </dl>

    {{#if hasRiderLink}}
      <div class="swse-npc-detail-block">
        <div class="swse-npc-detail-block__label">{{localize "SWSE.ActorUI.LinkedRiderSheet"}}</div>
        {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-related-actor-card.hbs" riderLink}}
      </div>
    {{/if}}

    {{#unless mountSummary.riderName}}
      <p class="swse-npc-empty-state">
        {{localize "SWSE.ActorUI.NoRiderIsAssignedToThisMount"}}
      </p>
    {{/unless}}
  </div>
</section>
