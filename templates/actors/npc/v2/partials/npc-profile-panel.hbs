<section class="swse-npc-card swse-npc-profile-card">
  <header class="swse-npc-card__header">
    <div class="swse-npc-card__header-main">
      <h3 class="swse-section-title">NPC Profile</h3>
    </div>

    <div class="swse-npc-badges">
      <span class="swse-npc-badge swse-npc-badge--kind">{{npcKindLabel}}</span>
      <span class="swse-npc-badge swse-npc-badge--mode">{{npcModeLabel}}</span>
      {{#if npcImported}}
        <span class="swse-npc-badge swse-npc-badge--subtype">Imported</span>
      {{/if}}
      {{#if isBeastNpc}}
        <span class="swse-npc-badge swse-npc-badge--subtype">Creature</span>
      {{/if}}
      {{#if isMountNpc}}
        <span class="swse-npc-badge swse-npc-badge--subtype">Mounted</span>
      {{/if}}
      {{#if isOwnerSyncMode}}
        <span class="swse-npc-badge swse-npc-badge--subtype">Owner Sync</span>
      {{/if}}
    </div>
  </header>

  <div class="swse-npc-card__body">
    <p class="swse-npc-card__lead">
      {{profileDescription}}
    </p>

    <dl class="swse-npc-meta-list">
      <div class="swse-npc-meta-list__row">
        <dt>Profile</dt>
        <dd>{{npcKindLabel}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>Sheet Mode</dt>
        <dd>{{npcModeLabel}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>Source Authority</dt>
        <dd>{{npcSourceAuthorityLabel}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>Legal Profile</dt>
        <dd>{{npcLegalProfileLabel}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>Legal State</dt>
        <dd>{{npcLegalStateLabel}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>Class Items</dt>
        <dd>{{#if npcHasClassItems}}{{npcClassItemCount}}{{else}}None / statblock source{{/if}}</dd>
      </div>

      <div class="swse-npc-meta-list__row">
        <dt>Relationships</dt>
        <dd>{{#if showRelationshipsTab}}Active{{else}}None{{/if}}</dd>
      </div>

      {{#if npcProfileMissing}}
        <div class="swse-npc-meta-list__row">
          <dt>Profile Metadata</dt>
          <dd>Inferred, not written</dd>
        </div>
      {{/if}}

      {{#if isFollowerNpc}}
        <div class="swse-npc-meta-list__row">
          <dt>Owner Resolved</dt>
          <dd>{{#if followerSummary.isOwnerResolved}}Yes{{else}}No{{/if}}</dd>
        </div>

        <div class="swse-npc-meta-list__row">
          <dt>Template Resolved</dt>
          <dd>{{#if followerSummary.isTemplateResolved}}Yes{{else}}No{{/if}}</dd>
        </div>
      {{/if}}
    </dl>
  </div>
</section>
