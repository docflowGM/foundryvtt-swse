{{!--
  NPC Sheet V2 — shared holopad shell host.
  The current NPC body is intentionally preserved for Phase 1; later phases can
  refactor panels/statblock modes after the shell entry point is stable.
--}}
{{> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame.hbs"
  frameOuterClass="swse-npc-sheet-wrapper swse-npc-sheet-form-root swse-sheet-ui swse-sheet swse-sheet--concept"
  frameDataSheetForm="npc"
  shellSurface=shellSurface
  shellTheme=sheetTheme
  shellMotionStyle=sheetMotionStyle
  shellStyleInline=sheetSurfaceStyleInline
  topHomeAction="tablet-home"
  bottomHomeAction="tablet-home"
  tabletExtraClass="swse-npc-tablet"
  screenExtraClass="swse-npc-screen"
  showResize=true
}}
{{#if shellIsSheet}}
<div class="swse swse-sheet v2 flexcol swse-sheet-ui swse-ui-shell">
  {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-header-dossier.hbs"}}

  <nav class="sheet-tabs tabs swse-ui-tabs" data-tab-group="primary">
    <a class="item swse-ui-tab active" data-action="tab" data-tab="overview">Overview</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="statblock">Statblock</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="legal-review">Legal Review</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="combat">Combat</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="stats">Stats</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="abilities">Abilities</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="talents">Talents</a>
    {{#if system.forceSensitive}}<a class="item swse-ui-tab" data-action="tab" data-tab="force">Force</a>{{/if}}
    {{#if items}}<a class="item swse-ui-tab" data-action="tab" data-tab="gear">Gear</a>{{/if}}
    {{#if system.isDroid}}<a class="item swse-ui-tab" data-action="tab" data-tab="systems">Systems</a>{{/if}}
    {{#if showBeastPanel}}<a class="item swse-ui-tab" data-action="tab" data-tab="beast">Beast</a>{{/if}}
    <a class="item swse-ui-tab" data-action="tab" data-tab="relationships">Relationships</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="notes">Notes</a>
  </nav>

  <section class="sheet-body flexcol">
    <section class="tab active flexcol" data-tab-group="primary" data-tab="overview">
      <div class="swse-npc-overview-layout">
        <div class="swse-npc-overview-main">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-mode-panel.hbs"}}
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-profile-panel.hbs"}}
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-statblock-authority-panel.hbs"}}
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-play-statblock-panel.hbs"}}
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-legal-review-panel.hbs"}}

          {{#if showProgressionPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-progression-panel.hbs"}}
          {{/if}}
        </div>

        <aside class="swse-npc-overview-side">
          {{#if showOwnerPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-owner-panel.hbs"}}
          {{/if}}

          {{#if showBeastPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-beast-panel.hbs"}}
          {{/if}}

          {{#if showMountPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-mount-panel.hbs"}}
          {{/if}}
        </aside>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="statblock">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-play-statblock-panel.hbs"}}
        </div>
      </div>
    </section>


    <section class="tab flexcol" data-tab-group="primary" data-tab="legal-review">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-legal-review-panel.hbs"}}
        </div>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="combat">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/shared/v2-concept/partials/panels/action-economy-indicator.hbs"}}
        </div>

        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/attacks-panel.hbs"}}
        </div>

        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/actions-panel.hbs"}}
        </div>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="stats">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/shared/v2-concept/partials/panels/abilities-panel.hbs"}}
        </div>

        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/skills-panel.hbs"}}
        </div>

        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/feats-panel.hbs"}}
        </div>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="abilities">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/shared/v2-concept/partials/panels/abilities-panel.hbs"}}
        </div>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="talents">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
        </div>
      </div>
    </section>

    {{#if system.forceSensitive}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="force">
      {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/tabs/force-suite-tab.hbs"}}
    </section>
    {{/if}}

    {{#if items}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="gear">
      {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-gear-panel.hbs"}}
    </section>
    {{/if}}

    {{#if system.isDroid}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="systems">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/droid-systems-panel.hbs"}}
        </div>

        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/droid-build-history.hbs"}}
        </div>
      </div>
    </section>
    {{/if}}

    {{#if showBeastPanel}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="beast">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-beast-panel.hbs"}}
        </div>
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-play-statblock-panel.hbs"}}
        </div>
      </div>
    </section>
    {{/if}}

    <section class="tab flexcol" data-tab-group="primary" data-tab="relationships">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-relationships-panel.hbs"}}
        </div>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="notes">
      <div class="swse-v2-sheet-grid">
        <div class="swse-v2-full">
          {{> "systems/foundryvtt-swse/templates/partials/suggestion-card.hbs"}}
        </div>
      </div>
    </section>
  </section>
</div>

  {{> "systems/foundryvtt-swse/templates/shell/shell-surface.hbs"}}
{{else}}
  <div class="swse-shell-screen-surface swse-shell-screen-surface--{{shellSurface}}">
    {{> "systems/foundryvtt-swse/templates/shell/shell-surface.hbs"}}
  </div>
{{/if}}
{{> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame-close.hbs"
  bottomHomeAction="tablet-home"
  bottomHomeTitle="Return to holopad home"
  bottomHomeLabel="Return to holopad home"
  bottomEngraving="CEC ID 31 · NPC OPS · SOURCE AUTHORITY"
}}
