{{!--
  NPC Concept Sheet V2 — conservative/readable NPC dossier.
  Implements the uploaded concept using the existing NPC sheet host, shell surface,
  profile builder, legal review, follower, beast, mount, and progression wiring.
--}}
{{> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame.hbs"
  frameOuterClass="swse-npc-sheet-wrapper swse-npc-sheet-form-root swse-sheet-ui swse-sheet swse-sheet--concept"
  frameDataSheetForm="npc"
  shellSurface=shellSurface
  shellTheme=sheetTheme
  shellMotionStyle=sheetMotionStyle
  shellStyleInline=sheetSurfaceStyleInline
  topHomeAction="tablet-home"
  bottomHomeAction="tablet-home"
  tabletExtraClass="swse-npc-tablet"
  screenExtraClass="swse-npc-screen"
  showResize=true
}}
{{#if shellIsSheet}}
<div class="swse swse-sheet v2 flexcol swse-sheet-ui swse-ui-shell swse-npc-concept-sheet swse-npc-kind--{{npcConcept.kind}}">
  {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-header-dossier.hbs"}}

  <nav class="sheet-tabs tabs swse-ui-tabs swse-npc-concept-tabs" data-tab-group="primary" aria-label="NPC sheet tabs">
    <a class="item swse-ui-tab active" data-action="tab" data-tab="overview">Overview</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="combat">Combat</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="stats">Stats</a>
    <a class="item swse-ui-tab" data-action="tab" data-tab="features">Features</a>
    {{#if npcConcept.showGearTab}}<a class="item swse-ui-tab" data-action="tab" data-tab="gear">Gear</a>{{/if}}
    {{#if npcConcept.showRelationshipsTab}}<a class="item swse-ui-tab" data-action="tab" data-tab="relationships">Relationships</a>{{/if}}
    {{#if npcConcept.showBeastTab}}<a class="item swse-ui-tab" data-action="tab" data-tab="beast">{{npcConcept.beastTabLabel}}</a>{{/if}}
    {{#if npcConcept.showForceTab}}<a class="item swse-ui-tab" data-action="tab" data-tab="force">Force</a>{{/if}}
    {{#if npcConcept.showGmTab}}<a class="item swse-ui-tab swse-npc-gm-tab" data-action="tab" data-tab="gm">GM</a>{{/if}}
  </nav>

  <section class="sheet-body flexcol swse-npc-concept-body">
    <section class="tab active flexcol" data-tab-group="primary" data-tab="overview">
      {{#if npcConcept.isDependent}}
        <div class="swse-npc-two-col swse-npc-overview-dependent">
          <div class="swse-npc-col-stack">
            {{#if showOwnerPanel}}
              {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-owner-panel.hbs"}}
            {{/if}}

            <section class="swse-npc-card swse-npc-card--quickref">
              <header class="swse-npc-card__header">
                <div>
                  <h3 class="swse-section-title">Combat Reference</h3>
                  <p class="swse-npc-card__subhead">Fast table-facing values for dependent NPC play.</p>
                </div>
              </header>
              <div class="swse-npc-card__body">
                <div class="swse-npc-progress-grid swse-npc-progress-grid--compact">
                  {{#each npcConcept.quickStats as |stat|}}
                    <div class="swse-npc-progress-stat">
                      <label class="swse-npc-progress-stat__label">{{stat.label}}</label>
                      <div class="swse-npc-progress-stat__value">{{stat.value}}</div>
                    </div>
                  {{/each}}
                </div>
              </div>
            </section>
          </div>

          <aside class="swse-npc-col-stack">
            {{#if showProgressionPanel}}
              {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-progression-panel.hbs"}}
            {{else}}
              {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-mode-panel.hbs"}}
            {{/if}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-statblock-authority-panel.hbs"}}
          </aside>
        </div>
      {{else}}
        {{#if npcConcept.isCreature}}
          <div class="swse-npc-two-col swse-npc-overview-creature">
            <div class="swse-npc-col-stack">
              {{#if showBeastPanel}}
                {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-beast-panel.hbs"}}
              {{/if}}
              {{#if showMountPanel}}
                {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-mount-panel.hbs"}}
              {{/if}}
              {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-play-statblock-panel.hbs"}}
            </div>
            <aside class="swse-npc-col-stack">
              <section class="swse-npc-card swse-npc-card--quickref">
                <header class="swse-npc-card__header"><h3 class="swse-section-title">Defenses</h3></header>
                <div class="swse-npc-card__body">
                  <div class="swse-npc-progress-grid swse-npc-progress-grid--compact">
                    {{#each npcConcept.defenseChips as |def|}}
                      <div class="swse-npc-progress-stat">
                        <label class="swse-npc-progress-stat__label">{{def.label}}</label>
                        <div class="swse-npc-progress-stat__value">{{def.value}}</div>
                      </div>
                    {{/each}}
                  </div>
                </div>
              </section>
              {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-statblock-authority-panel.hbs"}}
            </aside>
          </div>
        {{else}}
          <div class="swse-npc-two-col swse-npc-overview-standard">
            <div class="swse-npc-col-stack">
              {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-play-statblock-panel.hbs"}}
            </div>
            <aside class="swse-npc-col-stack">
              <section class="swse-npc-card swse-npc-card--mode-summary">
                <header class="swse-npc-card__header"><h3 class="swse-section-title">Rules Mode</h3></header>
                <div class="swse-npc-card__body">
                  <div class="swse-npc-mode-grid">
                    {{#each npcConcept.modeCards as |mode|}}
                      <div class="swse-npc-mode-grid__item {{#if mode.active}}is-active{{/if}}">
                        <span class="swse-npc-mode-grid__label">{{mode.label}}</span>
                        <span class="swse-npc-mode-grid__value">{{mode.value}}</span>
                      </div>
                    {{/each}}
                  </div>
                  <div class="swse-npc-callout swse-npc-callout--statblock">
                    {{authorityDescription}}
                  </div>
                </div>
              </section>
              {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-profile-panel.hbs"}}
              {{#if showProgressionPanel}}
                {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-progression-panel.hbs"}}
              {{/if}}
            </aside>
          </div>
        {{/if}}
      {{/if}}
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="combat">
      <div class="swse-npc-col-stack">
        <section class="swse-npc-card swse-npc-card--action-economy">
          <header class="swse-npc-card__header">
            <div>
              <h3 class="swse-section-title">Action Economy</h3>
              <p class="swse-npc-card__subhead">Encounter telemetry appears when this NPC is in the combat tracker.</p>
            </div>
          </header>
          <div class="swse-npc-card__body">
            {{#if actionEconomy}}
              <div class="swse-npc-action-row">
                <span class="swse-npc-chip">Full {{actionEconomy.state.full}}</span>
                <span class="swse-npc-chip">Standard {{actionEconomy.state.standard}}</span>
                <span class="swse-npc-chip">Move {{actionEconomy.state.move}}</span>
                <span class="swse-npc-chip">Swift {{actionEconomy.state.swift}}</span>
              </div>
            {{else}}
              <p class="swse-npc-empty-state">Action economy tracking activates during active combat.</p>
            {{/if}}
          </div>
        </section>

        <section class="swse-npc-card swse-npc-card--attacks">
          <header class="swse-npc-card__header">
            <div>
              <h3 class="swse-section-title">Attacks</h3>
              <p class="swse-npc-card__subhead">Weapon, natural, and statblock attacks.</p>
            </div>
            <div class="swse-npc-badges"><span class="swse-npc-badge">BAB {{npcConcept.babDisplay}}</span></div>
          </header>
          <div class="swse-npc-card__body swse-npc-attack-list">
            {{#if npcConcept.hasAttacks}}
              {{#each npcConcept.attacks as |attack|}}
                <article class="swse-npc-attack-item">
                  <div class="swse-npc-attack-head">
                    <strong>{{attack.name}}</strong>
                    <span>{{attack.source}} · {{attack.mode}}</span>
                  </div>
                  <div class="swse-npc-attack-meta">
                    <span>Attack {{attack.attack}}</span>
                    <span>Damage {{attack.damage}}</span>
                  </div>
                  <div class="swse-npc-attack-actions">
                    {{#if attack.canRollAttack}}
                      <button type="button" class="swse-npc-action-button swse-npc-action-button--compact" data-action="roll-npc-statblock-attack" data-item-id="{{attack.itemId}}" data-attack-name="{{attack.name}}" data-attack-bonus="{{attack.attackBonus}}">Roll Attack</button>
                    {{/if}}
                    {{#if attack.canRollDamage}}
                      <button type="button" class="swse-npc-action-button swse-npc-action-button--compact swse-npc-action-button--secondary" data-action="roll-npc-statblock-damage" data-attack-name="{{attack.name}}" data-damage-formula="{{attack.damageFormula}}">Roll Damage</button>
                    {{/if}}
                    {{#if attack.canOpen}}
                      <button type="button" class="swse-npc-action-button swse-npc-action-button--compact swse-npc-action-button--secondary swse-v2-open-item" data-item-id="{{attack.itemId}}">Open Item</button>
                    {{/if}}
                  </div>
                  {{#if attack.notes}}<p class="swse-npc-attack-notes">{{attack.notes}}</p>{{/if}}
                </article>
              {{/each}}
            {{else}}
              <p class="swse-npc-empty-state">No itemized or statblock attacks were found.</p>
            {{/if}}
          </div>
        </section>

        <section class="swse-npc-card swse-npc-card--combat-actions">
          <header class="swse-npc-card__header">
            <div>
              <h3 class="swse-section-title">Combat Actions</h3>
              <p class="swse-npc-card__subhead">Executable SWSE action cards grouped by action economy.</p>
            </div>
          </header>
          <div class="swse-npc-card__body swse-npc-combat-action-groups">
            {{#if npcConcept.hasCombatActionGroups}}
              {{#each npcConcept.combatActionGroups as |group|}}
                <article class="swse-npc-combat-action-group" data-combat-action-group="{{group.key}}">
                  <header class="swse-npc-combat-action-group__header">
                    <strong>{{group.label}}</strong>
                    <span>{{group.count}} entries</span>
                  </header>
                  <div class="swse-npc-combat-action-list">
                    {{#each group.items as |item|}}
                      <article class="swse-npc-combat-action-row" data-action-key="{{item.key}}" data-action-type="{{item.actionType}}">
                        <div class="swse-npc-combat-action-row__copy">
                          <strong class="swse-npc-combat-action-row__title">{{item.name}}</strong>
                          {{#if item.description}}<small class="swse-npc-combat-action-row__description">{{item.description}}</small>{{/if}}
                          {{#if item.resources.length}}
                            <div class="swse-npc-action-row">
                              {{#each item.resources as |resource|}}<span class="swse-npc-chip">{{resource}}</span>{{/each}}
                            </div>
                          {{/if}}
                        </div>
                        <div class="swse-npc-combat-action-row__actions">
                          {{#if item.itemId}}<button type="button" class="swse-npc-mini-btn swse-v2-open-item" data-item-id="{{item.itemId}}">Inspect</button>{{/if}}
                          {{#if item.executable}}<button type="button" class="swse-npc-mini-btn swse-npc-mini-btn--primary" data-action="swse-v2-use-action" data-action-id="{{item.key}}" data-action-type="{{item.actionType}}">{{item.useLabel}}</button>{{/if}}
                        </div>
                      </article>
                    {{/each}}
                  </div>
                </article>
              {{/each}}
            {{else}}
              <p class="swse-npc-empty-state">No grouped combat actions were found for this NPC.</p>
            {{/if}}
          </div>
        </section>

        <div class="swse-npc-two-col-equal">
          <section class="swse-npc-card swse-npc-card--condition">
            <header class="swse-npc-card__header"><h3 class="swse-section-title">Condition Track</h3></header>
            <div class="swse-npc-card__body">
              <div class="swse-npc-combat-stat-row swse-npc-combat-stat-row--condition">
                {{#each npcConcept.conditionSteps as |step|}}
                  <button type="button" class="swse-npc-combat-stat swse-v2-condition-step {{#if step.active}}is-active{{/if}}" data-step="{{step.value}}">
                    <span class="swse-npc-combat-stat__label">{{step.label}}</span>
                    <strong class="swse-npc-combat-stat__value">{{#if step.active}}Active{{else}}{{step.value}}{{/if}}</strong>
                  </button>
                {{/each}}
              </div>
            </div>
          </section>

          <section class="swse-npc-card swse-npc-card--defenses">
            <header class="swse-npc-card__header"><h3 class="swse-section-title">Defenses</h3></header>
            <div class="swse-npc-card__body">
              <div class="swse-npc-combat-stat-row">
                {{#each npcConcept.defenseChips as |def|}}
                  <div class="swse-npc-combat-stat">
                    <span class="swse-npc-combat-stat__label">{{def.label}}</span>
                    <strong class="swse-npc-combat-stat__value">{{def.value}}</strong>
                  </div>
                {{/each}}
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="stats">
      <div class="swse-npc-col-stack">
        {{#if editable}}
        <section class="swse-npc-card swse-npc-card--edit-basics">
          <header class="swse-npc-card__header">
            <div>
              <h3 class="swse-section-title">Editable NPC Fields</h3>
              <p class="swse-npc-card__subhead">GM-safe direct fields. Changes save when the field loses focus or changes.</p>
            </div>
          </header>
          <div class="swse-npc-card__body swse-npc-edit-grid">
            <label><span>Species</span><input type="text" name="system.race" value="{{system.race}}"></label>
            <label><span>Class</span><input type="text" name="system.className" value="{{system.className}}"></label>
            <label><span>Level</span><input type="number" name="system.level" value="{{system.level}}" min="0" step="1"></label>
            <label><span>Challenge</span><input type="text" name="system.challengeLevel" value="{{system.challengeLevel}}"></label>
            <label><span>Size</span><input type="text" name="system.size" value="{{system.size}}"></label>
            <label><span>Speed</span><input type="text" name="system.speed" value="{{system.speed}}"></label>
            <label><span>HP</span><input type="number" name="system.hp.value" value="{{system.hp.value}}" min="0" step="1"></label>
            <label><span>Credits</span><input type="number" name="system.credits" value="{{system.credits}}" min="0" step="1"></label>
          </div>
        </section>
        {{/if}}
        <section class="swse-npc-card swse-npc-card--abilities">
          <header class="swse-npc-card__header">
            <div>
              <h3 class="swse-section-title">Ability Scores</h3>
              <p class="swse-npc-card__subhead">Edit base, species/template bonus, and temporary modifiers directly on NPCs you own.</p>
            </div>
          </header>
          <div class="swse-npc-card__body">
            {{#if npcConcept.hasAbilities}}
              <div class="swse-npc-abilities-grid swse-npc-abilities-grid--concept">
                {{#each npcConcept.abilities as |ability|}}
                  <div class="swse-npc-ability-card {{#if ability.isPrimary}}primary{{/if}} {{#if ability.isLowest}}lowest{{/if}}">
                    <span class="swse-npc-ability-label">{{ability.abbr}}</span>
                    <strong class="swse-npc-ability-score">{{ability.score}}</strong>
                    <span class="swse-npc-ability-mod {{ability.modifierClass}}">{{ability.mod}}</span>
                    {{#if ../editable}}
                      <div class="swse-npc-ability-edit-grid">
                        <label><span>Base</span><input class="swse-npc-ability-input" type="number" name="system.attributes.{{ability.key}}.base" value="{{ability.base}}" step="1"></label>
                        <label><span>Bonus</span><input class="swse-npc-ability-input" type="number" name="system.attributes.{{ability.key}}.racial" value="{{ability.racial}}" step="1"></label>
                        <label><span>Temp</span><input class="swse-npc-ability-input" type="number" name="system.attributes.{{ability.key}}.temp" value="{{ability.temp}}" step="1"></label>
                      </div>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="swse-npc-empty-state">No ability scores were found.</p>
            {{/if}}
          </div>
        </section>

        <section class="swse-npc-card swse-npc-card--skills">
          <header class="swse-npc-card__header">
            <div><h3 class="swse-section-title">Skills</h3></div>
            <div class="swse-npc-badges"><span class="swse-npc-badge">{{npcConcept.trainedSkillCount}} trained</span></div>
          </header>
          <div class="swse-npc-card__body">
            {{#if npcConcept.hasSkills}}
              <div class="swse-npc-skills-grid">
                {{#each npcConcept.skills as |skill|}}
                  <button type="button" class="swse-npc-skill-row {{#if skill.trained}}is-trained{{/if}}" data-action="roll-skill" data-skill="{{skill.key}}" data-mod-dialog="true">
                    <span class="swse-npc-skill-name">{{#if skill.trained}}● {{/if}}{{skill.label}}</span>
                    <strong class="swse-npc-skill-total">{{skill.total}}</strong>
                  </button>
                {{/each}}
              </div>
            {{else}}
              <p class="swse-npc-empty-state">No trained or notable skill rows were found.</p>
            {{/if}}
          </div>
        </section>
      </div>
    </section>

    <section class="tab flexcol" data-tab-group="primary" data-tab="features">
      <div class="swse-npc-two-col-equal swse-npc-features-layout">
        <section class="swse-npc-card swse-npc-card--features">
          <header class="swse-npc-card__header"><h3 class="swse-section-title">Feats</h3><div class="swse-npc-badges"><span class="swse-npc-badge">{{npcConcept.feats.length}}</span></div></header>
          <div class="swse-npc-card__body swse-npc-feature-list">
            {{#if npcConcept.hasFeats}}
              {{#each npcConcept.feats as |feat|}}
                <button type="button" class="swse-npc-feature-item {{#if feat.canOpen}}swse-v2-open-item{{/if}}" data-item-id="{{feat.id}}">
                  <span class="swse-npc-feature-name">{{feat.name}}</span>
                  <span class="swse-npc-feature-type">{{feat.typeLabel}}</span>
                </button>
              {{/each}}
            {{else}}
              <p class="swse-npc-empty-state">No feat items are recorded.</p>
            {{/if}}
          </div>
        </section>

        <section class="swse-npc-card swse-npc-card--features">
          <header class="swse-npc-card__header"><h3 class="swse-section-title">Talents</h3><div class="swse-npc-badges"><span class="swse-npc-badge">{{npcConcept.talents.length}}</span></div></header>
          <div class="swse-npc-card__body swse-npc-feature-list">
            {{#if npcConcept.hasTalents}}
              {{#each npcConcept.talents as |talent|}}
                <button type="button" class="swse-npc-feature-item {{#if talent.canOpen}}swse-v2-open-item{{/if}}" data-item-id="{{talent.id}}">
                  <span class="swse-npc-feature-name">{{talent.name}}</span>
                  <span class="swse-npc-feature-type">{{talent.typeLabel}}</span>
                </button>
              {{/each}}
            {{else}}
              <p class="swse-npc-empty-state">No talent items are recorded.</p>
            {{/if}}
          </div>
        </section>
      </div>

      <section class="swse-npc-card swse-npc-card--specials">
        <header class="swse-npc-card__header"><h3 class="swse-section-title">Special Traits / Notes</h3></header>
        <div class="swse-npc-card__body swse-npc-statblock-list">
          {{#if npcConcept.hasSpecials}}
            {{#each npcConcept.specials as |special|}}
              <article class="swse-npc-statblock-row">
                <div class="swse-npc-statblock-row__main"><strong>{{special.label}}</strong><span>{{special.source}}</span></div>
                <p>{{special.value}}</p>
              </article>
            {{/each}}
          {{else}}
            <p class="swse-npc-empty-state">No structured special trait notes were found.</p>
          {{/if}}
        </div>
      </section>
    </section>

    {{#if npcConcept.showGearTab}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="gear">
      <section class="swse-npc-card swse-npc-card--gear">
        <header class="swse-npc-card__header">
          <div><h3 class="swse-section-title">Inventory</h3></div>
          <div class="swse-npc-badges"><span class="swse-npc-badge swse-npc-badge--subtype">{{npcConcept.creditsDisplay}}</span></div>
        </header>
        <div class="swse-npc-card__body swse-npc-gear-stack">
          {{#if npcConcept.hasGear}}
            {{#each npcConcept.gear as |item|}}
              <div class="swse-npc-gear-row">
                <button type="button" class="swse-npc-gear-name {{#if item.canOpen}}swse-v2-open-item{{/if}}" data-item-id="{{item.id}}">{{item.name}}</button>
                <div class="swse-npc-gear-meta"><span>{{item.typeLabel}}</span><span>×{{item.quantity}}</span></div>
                {{#if item.canRollAttack}}
                  <button type="button" class="swse-npc-gear-roll" data-action="roll-npc-weapon" data-item-id="{{item.id}}">Roll Attack</button>
                {{/if}}
              </div>
            {{/each}}
          {{else}}
            <p class="swse-npc-empty-state">No itemized gear. Add items via the item browser.</p>
          {{/if}}
        </div>
      </section>
    </section>
    {{/if}}

    {{#if npcConcept.showRelationshipsTab}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="relationships">
      {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-relationships-panel.hbs"}}
    </section>
    {{/if}}

    {{#if npcConcept.showBeastTab}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="beast">
      <div class="swse-npc-two-col">
        <div class="swse-npc-col-stack">
          {{#if showBeastPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-beast-panel.hbs"}}
          {{/if}}
          {{#if showMountPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-mount-panel.hbs"}}
          {{/if}}
        </div>
        <aside class="swse-npc-col-stack">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-play-statblock-panel.hbs"}}
        </aside>
      </div>
    </section>
    {{/if}}

    {{#if npcConcept.showForceTab}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="force">
      {{#if system.forceSensitive}}
        {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/tabs/force-suite-tab.hbs"}}
      {{else}}
        <section class="swse-npc-card"><div class="swse-npc-card__body"><p class="swse-npc-empty-state">No Force suite is active for this NPC.</p></div></section>
      {{/if}}
    </section>
    {{/if}}

    {{#if npcConcept.showGmTab}}
    <section class="tab flexcol" data-tab-group="primary" data-tab="gm">
      <div class="swse-npc-gm-notice"><i class="fas fa-user-shield"></i><span>GM Utility Tab — hidden from players by default.</span></div>
      <div class="swse-npc-two-col">
        <div class="swse-npc-col-stack">
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-statblock-authority-panel.hbs"}}
          {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-legal-review-panel.hbs"}}
        </div>
        <aside class="swse-npc-col-stack">
          {{#if showProgressionPanel}}
            {{> "systems/foundryvtt-swse/templates/actors/npc/v2/partials/npc-progression-panel.hbs"}}
          {{else}}
            <section class="swse-npc-card">
              <header class="swse-npc-card__header"><h3 class="swse-section-title">Progression</h3><div class="swse-npc-badges"><span class="swse-npc-badge swse-npc-badge--mode">Not Active</span></div></header>
              <div class="swse-npc-card__body">
                <p class="swse-npc-empty-state">Progression panel is not active for this NPC mode.</p>
                <div class="swse-npc-action-row"><button type="button" class="swse-npc-action-button" data-action="open-npc-levelup">Open NPC Level-Up</button></div>
              </div>
            </section>
          {{/if}}
        </aside>
      </div>
    </section>
    {{/if}}
  </section>
</div>

  {{> "systems/foundryvtt-swse/templates/shell/shell-surface.hbs"}}
{{else}}
  <div class="swse-shell-screen-surface swse-shell-screen-surface--{{shellSurface}}">
    {{> "systems/foundryvtt-swse/templates/shell/shell-surface.hbs"}}
  </div>
{{/if}}
