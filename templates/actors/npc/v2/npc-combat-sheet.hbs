{{!-- DEPRECATED / ORPHANED (Phase 2.5): NPC actors now use SWSEV2CharacterSheet and the shared actor shell. --}}
<div class="swse swse-sheet swse-sheet-ui swse-ui-shell swse-npc-combat-sheet v2 flexcol">

  <!-- Header -->
  <header class="sheet-header holo-header npc-combat-header swse-ui-frame">
    <div class="header-left">
      <img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
      <div class="title-block">
        <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'SWSE.ActorUI.Name'}}"/></h1>
        <div class="subline muted">NPC Combat Mode — Level {{system.level}}</div>
      </div>
    </div>
    <div class="header-right npc-combat-header-stats">
      <div class="swse-stat"><div class="label">{{localize "SWSE.ActorUI.FORT"}}</div><div class="value">{{derived.defenses.fort}}</div></div>
      <div class="swse-stat"><div class="label">{{localize "SWSE.ActorUI.REF"}}</div><div class="value">{{derived.defenses.ref}}</div></div>
      <div class="swse-stat"><div class="label">{{localize "SWSE.ActorUI.WILL"}}</div><div class="value">{{derived.defenses.will}}</div></div>
      <div class="swse-stat"><div class="label">{{localize "SWSE.ActorUI.DT"}}</div><div class="value">{{derived.damage.threshold}}</div></div>
    </div>
  </header>

  <!-- Combat Grid -->
  <section class="sheet-body npc-combat-body flexcol swse-npc-combat-body-shell">

    <!-- Left Column: HP, Condition, Defenses -->
    <div class="npc-combat-left flexcol">
      {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/hp-condition-panel.hbs"}}
      {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/defenses-panel.hbs"}}
    </div>

    <!-- Right Column: Initiative, Attacks and Actions -->
    <div class="npc-combat-right flexcol">

      {{!-- Action Economy Display --}}
      {{#if actionEconomy}}
        {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/action-economy-indicator.hbs"
            actionState=actionEconomy.state
            actionBreakdown=actionEconomy.breakdown
            swiftMax=actionEconomy.state.swiftMax}}
      {{/if}}

      <!-- INITIATIVE DISPLAY -->
      <div class="holo-panel initiative-panel">
        <div class="section-bar">
          <h3 class="section-header">{{localize "SWSE.ActorUI.Initiative"}}</h3>
        </div>
        <div class="initiative-panel-body initiative-panel-compact">
          <div class="initiative-mod-value">{{system.skills.initiative.total}}</div>
          <div class="initiative-controls">
            <button type="button" class="initiative-btn roll-initiative">
              {{localize "SWSE.ActorUI.Roll"}}
            </button>
            <button type="button" class="initiative-btn take10-initiative">
              {{localize "SWSE.ActorUI.Take10"}}
            </button>
          </div>
        </div>
      </div>

      {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/attacks-panel.hbs"}}
      {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/actions-panel.hbs"}}
    </div>

  </section>

  <!-- Quick Actions Bar -->
  <footer class="npc-combat-footer swse-ui-frame">
    <div class="npc-combat-actions swse-control-cluster">
      <button type="button" class="action-btn" data-action="level-up">{{localize "SWSE.ActorUI.LevelUp"}}</button>
      <button type="button" class="action-btn" data-action="switch-full-mode">{{localize "SWSE.ActorUI.FullMode"}}</button>
    </div>
  </footer>

</div>
