{{!-- Deprecated/orphaned droid-only shell template. Droid actors now use the character actor shell via SWSEV2CharacterSheet. Do not register this as the droid actor sheet. --}}
{{!--
  Droid Sheet V2 — shared holopad concept shell.

  The outer tablet/screen frame is intentionally the same shared shell used by
  the actor concept V2 sheet. Droid-only content lives in droid partials below;
  generic shell routing stays in templates/shell/*.hbs and ShellHostMixin.
--}}
{{> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame.hbs"
  frameOuterClass="swse-droid-sheet-wrapper swse-droid-sheet-wrapper--concept swse-droid-sheet-form-root swse-sheet-ui swse-sheet swse-sheet--concept swse-droid-sheet--concept"
  frameDataSheetForm="droid"
  frameDataConceptSource="assets/Concept/droid-shipyard-customization-concept.html"
  shellSurface=shellSurface
  shellTheme=sheetTheme
  shellMotionStyle=sheetMotionStyle
  shellStyleInline=sheetSurfaceStyleInline
  topHomeAction="tablet-home"
  bottomHomeAction="tablet-home"
  tabletExtraClass="swse-droid-tablet"
  screenExtraClass="swse-droid-screen"
  showResize=true
}}
{{#if shellIsSheet}}
  <div class="swse-droid-concept-root {{cssClass}}" data-sheet-region="droid-sheet">
    {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/frame/title-strip.hbs"}}
    {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/frame/header-block.hbs"}}
    {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/frame/resource-strip.hbs"}}
    {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/frame/tabs-bar.hbs"}}

    <div class="swse-concept-body swse-droid-concept-body">
      <aside class="swse-concept-sidebar swse-droid-concept-sidebar">
        {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/frame/sidebar.hbs"}}
      </aside>

      <section class="swse-concept-main swse-droid-concept-main sheet-body sheet-content">
        <section class="tab active flexcol" data-group="primary" data-tab-group="primary" data-tab="overview">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/overview-tab.hbs"}}
        </section>

        <section class="tab flexcol" data-group="primary" data-tab-group="primary" data-tab="abilities">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/abilities-tab.hbs"}}
        </section>

        <section class="tab flexcol" data-group="primary" data-tab-group="primary" data-tab="skills">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/skills-tab.hbs"}}
        </section>

        <section class="tab flexcol" data-group="primary" data-tab-group="primary" data-tab="combat">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/combat-tab.hbs"}}
        </section>

        <section class="tab flexcol" data-group="primary" data-tab-group="primary" data-tab="talents">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/talents-tab.hbs"}}
        </section>

        <section class="tab flexcol" data-group="primary" data-tab-group="primary" data-tab="gear">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/gear-tab.hbs"}}
        </section>

        <section class="tab flexcol" data-group="primary" data-tab-group="primary" data-tab="systems">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/systems-tab.hbs"}}
        </section>

        <section class="tab flexcol" data-group="primary" data-tab-group="primary" data-tab="biography">
          {{> "systems/foundryvtt-swse/templates/actors/droid/v2/partials/tabs/biography-tab.hbs"}}
        </section>
      </section>
    </div>

    {{> "systems/foundryvtt-swse/templates/shell/shell-surface.hbs"}}
  </div>
{{else}}
  <div class="swse-shell-screen-surface swse-shell-screen-surface--{{shellSurface}}">
    {{> "systems/foundryvtt-swse/templates/shell/shell-surface.hbs"}}
  </div>
{{/if}}
{{> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame-close.hbs"
  bottomHomeAction="tablet-home"
  bottomHomeTitle="Return to holopad home"
  bottomHomeLabel="Return to holopad home"
  bottomEngraving="CEC ID 31 · DROID OPS · NO HOT OPEN"
  showResize=true
}}
