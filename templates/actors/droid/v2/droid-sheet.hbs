<form class="swse-recovery-sheet swse-character-sheet-form {{cssClass}}" autocomplete="off">
  <div class="swse-datapad-frame droid-mode">
    <div class="swse-datapad-header">
      <div class="swse-datapad-ident">TYPES.ACTOR.DROID: {{actor.name}}</div>
      <div class="swse-datapad-controls"><span></span><span></span><span></span></div>
    </div>
    <div class="swse-home-console compact">
      <div class="swse-console-topline"><span>DROID CONTROL</span><span>·</span><span>WORKBENCH</span><span class="swse-console-power">{{system.level}} LVL</span></div>
      <div class="swse-home-hero compact-hero">
        <div class="swse-home-left"><div class="swse-panel swse-profile-card"><img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}"/><div class="swse-status-line">[CHASSIS] droid systems nominal.</div></div></div>
        <div class="swse-home-center"><div class="swse-radial-shell droid-shell"><div class="swse-radial-ring swse-radial-ring--outer"></div><div class="swse-radial-ring swse-radial-ring--mid"></div><div class="swse-radial-core"><span>{{system.class}}</span></div><button type="button" class="swse-radial-app app-character">Overview</button><button type="button" class="swse-radial-app app-progress">Training</button><button type="button" class="swse-radial-app app-workbench">Systems</button><button type="button" class="swse-radial-app app-store">Store</button></div></div>
        <div class="swse-home-right"><div class="swse-panel swse-glance-card"><div class="swse-panel-title">QUICK GLANCE</div><div class="swse-glance-grid"><div><span>HP</span><strong>{{system.hp.value}}/{{system.hp.max}}</strong></div><div><span>SPEED</span><strong>{{system.speed.total}}</strong></div><div><span>REF</span><strong>{{system.defenses.reflex.total}}</strong></div><div><span>FORT</span><strong>{{system.defenses.fortitude.total}}</strong></div></div></div></div>
      </div>
    </div>
    <nav class="sheet-tabs swse-sheet-tabs tabs" data-group="primary">
      <a class="item active" data-tab="overview">Overview</a>
      <a class="item" data-tab="abilities">Abilities</a>
      <a class="item" data-tab="skills">Skills</a>
      <a class="item" data-tab="combat">Combat</a>
      <a class="item" data-tab="talents">Talents</a>
      <a class="item" data-tab="gear">Gear</a>
      <a class="item" data-tab="biography">Notes</a>
    </nav>
    <section class="sheet-body swse-sheet-body">
      <section class="tab active" data-group="primary" data-tab="overview"><div class="swse-content-grid swse-overview-grid"><div class="swse-panel"><div class="swse-panel-title">Identity</div><div class="swse-form-grid two-col"><label>Name<input name="name" type="text" value="{{actor.name}}"/></label><label>Model<input name="system.class" type="text" value="{{system.class}}"/></label><label>Level<input name="system.level" type="number" value="{{system.level}}" min="1"/></label><label>Credits<input name="system.credits" type="number" value="{{system.credits}}"/></label></div></div><div class="swse-panel"><div class="swse-panel-title">Defenses</div><div class="swse-defense-grid">{{#each defenseList as |def|}}<div class="swse-defense-chip"><span>{{def.label}}</span><strong>{{def.total}}</strong></div>{{/each}}</div></div></div></section>
      <section class="tab" data-group="primary" data-tab="abilities"><div class="swse-content-grid ability-grid">{{#each abilitiesList as |ability|}}<div class="swse-panel swse-ability-card"><div class="swse-panel-title">{{ability.label}}</div><input name="system.abilities.{{ability.key}}.base" type="number" value="{{ability.base}}"/><div class="swse-ability-total">{{ability.total}}</div><div class="swse-ability-mod">{{ability.mod}}</div></div>{{/each}}</div></section>
      <section class="tab" data-group="primary" data-tab="skills"><div class="swse-panel"><div class="swse-panel-title">Skills</div><div class="swse-list">{{#each skillsList as |skill|}}<div class="swse-list-row"><span>{{skill.label}}</span><span>{{skill.ability}}</span><strong>{{skill.value}}</strong></div>{{else}}<div class="swse-empty">No skills configured yet.</div>{{/each}}</div></div></section>
      <section class="tab" data-group="primary" data-tab="combat"><div class="swse-panel"><div class="swse-panel-title">Weapons</div><div class="swse-list">{{#each weaponsList as |weapon index|}}<div class="swse-list-row weapon-entry" data-index="{{index}}"><input type="text" name="system.weapons.{{index}}.name" value="{{weapon.name}}"/><input type="text" name="system.weapons.{{index}}.damage" value="{{weapon.damage}}"/><div class="swse-inline-actions"><button type="button" class="roll-weapon">Roll</button><button type="button" class="remove-weapon">Delete</button></div></div>{{else}}<div class="swse-empty">No weapons recorded.</div>{{/each}}</div><button type="button" class="header-btn add-weapon">Add Weapon</button></div></section>
      <section class="tab" data-group="primary" data-tab="talents"><div class="swse-content-grid two-up"><div class="swse-panel"><div class="swse-panel-title">Feats</div><div class="swse-list">{{#each system.feats as |feat index|}}<div class="swse-list-row list-entry" data-index="{{index}}"><input type="text" name="system.feats.{{index}}.name" value="{{feat.name}}"/><button type="button" class="remove-feat">Delete</button></div>{{else}}<div class="swse-empty">No feats yet.</div>{{/each}}</div><button type="button" class="header-btn add-feat">Add Feat</button></div><div class="swse-panel"><div class="swse-panel-title">Talents</div><div class="swse-list">{{#each system.talents as |talent index|}}<div class="swse-list-row list-entry" data-index="{{index}}"><input type="text" name="system.talents.{{index}}.name" value="{{talent.name}}"/><button type="button" class="remove-talent">Delete</button></div>{{else}}<div class="swse-empty">No talents yet.</div>{{/each}}</div><button type="button" class="header-btn add-talent">Add Talent</button></div></div></section>
      <section class="tab" data-group="primary" data-tab="gear"><div class="swse-panel"><div class="swse-panel-title">Inventory &amp; Workbench</div><div class="swse-list">{{#each inventoryItems as |item|}}<div class="swse-list-row"><span>{{item.name}}</span><span>{{item.type}}</span></div>{{else}}<div class="swse-empty">No inventory items found.</div>{{/each}}</div><div class="swse-inline-actions"><button type="button" class="header-btn app-store">Open Store</button><button type="button" class="header-btn app-progress">Open Progression</button></div></div></section>
      <section class="tab" data-group="primary" data-tab="biography"><div class="swse-content-grid two-up"><div class="swse-panel"><div class="swse-panel-title">Biography</div><textarea name="system.bio" rows="12">{{bio}}</textarea></div><div class="swse-panel"><div class="swse-panel-title">Notes</div><textarea name="system.notes" rows="12">{{notes}}</textarea></div></div></section>
    </section>
  </div>
</form>
