{{!--
  Build History Panel — Phase 1: Template Integration Pass

  Now consumes droidPanels.buildHistory instead of raw system.droidSystems.buildHistory.
  Preserves current timeline layout.

  Data contract:
    droidPanels.buildHistory.entries[] (id, timestamp, action, mode, costDelta, detail, summary, actor)
    droidPanels.buildHistory.hasEntries
    droidPanels.buildHistory.emptyMessage
--}}
<div class="holo-panel">
  <div class="section-bar">
    <h3 class="section-header">Build History</h3>
  </div>

  {{#if droidPanels.buildHistory.hasEntries}}
    <div class="build-history-timeline">
      {{#each droidPanels.buildHistory.entries as |entry index|}}
        <div class="history-entry">
          <div class="history-marker"></div>
          <div class="history-content">
            <div class="entry-header">
              <span class="action-badge {{entry.action}}">
                {{#if (eq entry.action 'created')}}Created{{/if}}
                {{#if (eq entry.action 'modified')}}Modified{{/if}}
                {{#if (eq entry.action 'approved_by_gm')}}Approved{{/if}}
                {{#if (eq entry.action 'rejected_by_gm')}}Rejected{{/if}}
              </span>
              <span class="timestamp">{{entry.timestamp}}</span>
            </div>

            {{#if entry.mode}}
              <div class="entry-detail">
                <small><strong>Mode:</strong> {{entry.mode}}</small>
              </div>
            {{/if}}

            {{#if entry.costDelta}}
              <div class="entry-detail cost-delta">
                <small><strong>Cost Delta:</strong> {{#if (gt entry.costDelta 0)}}+{{/if}}{{entry.costDelta}} credits</small>
              </div>
            {{/if}}

            {{#if entry.detail}}
              <div class="entry-detail">
                <small>{{entry.detail}}</small>
              </div>
            {{/if}}
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p><em>{{droidPanels.buildHistory.emptyMessage}}</em></p>
    </div>
  {{/if}}
</div>
