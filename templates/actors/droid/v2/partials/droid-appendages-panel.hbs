<section class="swse-panel holo-panel swse-ui-panel swse-droid-part-panel" data-region="appendages">
  <header class="section-bar">
    <h3 class="section-header">Appendages</h3>
    <span class="section-meta muted">{{droidPanels.appendages.totalCount}} installed</span>
  </header>

  <div class="swse-droid-unarmed-summary">
    <span class="swse-weapon-integrated-badge">UNARMED</span>
    <strong>{{droidPanels.appendages.unarmedAttack.damage}}</strong>
    <span class="muted">appendage strike damage before Strength modifier from roll pipeline</span>
    <button type="button" class="holo-btn tiny" data-action="roll-unarmed-attack">Roll</button>
  </div>

  <div class="appendages-list swse-droid-slot-list">
    {{#each droidPanels.appendages.slots as |slot|}}
      <div class="appendage-entry swse-droid-slot {{#if slot.isEmpty}}is-empty{{/if}}" data-slot-id="{{slot.id}}">
        <div class="entry-header">
          <span class="entry-name">{{slot.label}}</span>
          {{#if slot.canAdd}}<span class="swse-droid-chip">ADD LIMB</span>{{else if slot.canReplace}}<span class="swse-droid-chip">REPLACE OK</span>{{/if}}
        </div>
        {{#if slot.item}}
          <strong>{{slot.item.name}}</strong>
          {{#if slot.item.appendageType}}<span class="swse-weapon-meta">{{slot.item.appendageType}}</span>{{/if}}
          {{#if slot.item.description}}<div class="entry-description muted">{{slot.item.description}}</div>{{/if}}
          <div class="swse-droid-slot-actions">
            <button type="button" class="holo-btn tiny" data-action="use-droid-part" data-part-id="{{slot.item.id}}" data-part-name="{{slot.item.name}}">Use / Describe</button>
            <button type="button" class="holo-btn tiny" data-action="customize-droid" data-garage-region="appendage" data-garage-slot="{{slot.id}}" data-garage-mode="replace">Replace in Garage</button>
          </div>
        {{else}}
          <p class="swse-droid-default-hint">{{slot.defaultName}}</p>
          <button type="button" class="holo-btn tiny" data-action="customize-droid" data-garage-region="appendage" data-garage-slot="{{slot.id}}" data-garage-mode="add">Add Limb in Garage</button>
        {{/if}}
      </div>
    {{/each}}
  </div>
</section>
