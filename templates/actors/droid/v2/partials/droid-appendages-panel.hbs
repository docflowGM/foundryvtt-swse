{{!--
  Droid Appendages Panel

  Shows installed appendages (manipulators, limbs, graspers).

  Data consumed:
    droidPanels.appendages (entries[], hasEntries, totalCount, totalCost, emptyMessage)

  Phase 3B: Subsystem detail enrichment. Lists all appendages with cost breakdown.
--}}
<section class="swse-panel holo-panel swse-ui-panel">
  <header class="section-bar">
    <h3 class="section-header">Appendages</h3>
    {{#if droidPanels.appendages.totalCount}}
      <span class="section-meta muted" style="font-size: 0.85em;">({{droidPanels.appendages.totalCount}}) {{droidPanels.appendages.totalCost}} credits</span>
    {{/if}}
  </header>

  {{#if droidPanels.appendages.hasEntries}}
    <div class="appendages-list">
      {{#each droidPanels.appendages.entries as |appendage|}}
        <div class="appendage-entry" data-appendage-id="{{appendage.id}}">
          <div class="entry-header">
            <span class="entry-name">{{appendage.name}}</span>
            {{#if appendage.cost}}
              <span class="entry-cost muted" style="font-size: 0.85em;">{{appendage.cost}} cr</span>
            {{/if}}
          </div>
          {{#if appendage.description}}
            <div class="entry-description muted" style="font-size: 0.85em; margin-top: 4px;">
              {{appendage.description}}
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p><em>{{droidPanels.appendages.emptyMessage}}</em></p>
    </div>
  {{/if}}
</section>
