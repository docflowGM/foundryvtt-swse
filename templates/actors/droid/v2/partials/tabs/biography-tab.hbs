    <header class="swse-concept-panel__header"><h3 class="swse-concept-panel__title">{{localize "SWSE.ActorUI.Biography"}}</h3></header>
    <textarea name="system.notes" rows="12" {{#unless editable}}disabled{{/unless}}>{{biographyPanel.biography}}</textarea>
  </section>
  <section class="swse-concept-panel swse-droid-panel">
    <header class="swse-concept-panel__header"><h3 class="swse-concept-panel__title">{{localize "SWSE.ActorUI.Notes"}}</h3></header>
    <textarea name="system.bio" rows="12" {{#unless editable}}disabled{{/unless}}>{{system.bio}}</textarea>
  </section>
</div>
