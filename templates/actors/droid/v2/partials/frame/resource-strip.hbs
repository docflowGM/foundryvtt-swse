<section class="swse-concept-resource-strip swse-droid-resource-strip">
  <div class="swse-concept-resource-card swse-concept-resource-card--hp">
    <div class="swse-concept-resource-card__header">
      <span>{{localize "SWSE.ActorUI.HullHealth"}}</span>
      <strong>{{healthPanel.hp.value}} / {{healthPanel.hp.max}}</strong>
    </div>
    <div class="swse-concept-segment-bar" data-resource-visual="hp" data-hp-current="{{healthPanel.hp.value}}" data-hp-max="{{healthPanel.hp.max}}" data-hp-temp="{{healthPanel.hp.temp}}">
      {{#each headerHpSegments as |segment|}}
        <span class="swse-concept-segment {{segment.colorClass}} {{#if segment.filled}}is-filled{{/if}}"></span>
      {{/each}}
    </div>
    <div class="swse-concept-resource-card__meta">
      <span>Temp {{healthPanel.hp.temp}}</span>
      <span>{{healthPanel.stateLabel}}</span>
    </div>
  </div>

  <div class="swse-concept-resource-card swse-concept-resource-card--xp">
    <div class="swse-concept-resource-card__header">
      <span>{{localize "SWSE.ActorUI.Training"}}</span>
      <strong>{{xpData.total}} XP</strong>
    </div>
    <div class="swse-concept-segment-bar" data-resource-visual="xp" data-xp-total="{{xpData.total}}" data-xp-percent="{{xpData.percentRounded}}">
      {{#each headerXpSegments as |segment|}}
        <span class="swse-concept-segment {{#if segment.filled}}is-filled{{/if}}"></span>
      {{/each}}
    </div>
    <div class="swse-concept-resource-card__meta">
      <span>{{xpData.percentRounded}}% to next level</span>
      <span>{{#if xpLevelReady}}Ready{{else}}Advancing{{/if}}</span>
    </div>
  </div>

  <div class="swse-concept-resource-card swse-concept-resource-card--compact">
    <div class="swse-concept-compact-resource">
      <span>{{localize "SWSE.ActorUI.Ref"}}</span>
      <strong>{{quickGlance.reflex}}</strong>
    </div>
    <div class="swse-concept-compact-resource">
      <span>{{localize "SWSE.ActorUI.Fort"}}</span>
      <strong>{{quickGlance.fortitude}}</strong>
    </div>
    <div class="swse-concept-compact-resource">
      <span>{{localize "SWSE.ActorUI.Will"}}</span>
      <strong>{{quickGlance.will}}</strong>
    </div>
  </div>
</section>
