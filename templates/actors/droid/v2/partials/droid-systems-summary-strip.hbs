{{!--
  Droid Systems Summary Strip

  Compact top-level readout showing:
  - degree, size
  - current state
  - credit budget summary
  - edit affordance

  Data consumed:
    droidPanels.droidSummary (degree, size, stateMode, creditsSpent, creditsTotal)
    droid.flags (isStockDroid, hasConversionReport, isPendingApproval) — Phase 3
    droid.garage (canEdit, canCustomize, canConvert, hasConfiguration) — Phase 3
    editable (permission flag)

  This is the entry-level summary. Subsystem detail panels follow below.
--}}
<div class="holo-panel swse-ui-panel swse-droid-system-suite">
  <div class="section-bar">
    <h3 class="section-header">{{localize "SWSE.ActorUI.DroidSystems"}}</h3>
    {{#if editable}}
      {{#if droid.flags.isStockDroid}}
        <button type="button" class="convert-to-custom-droid holo-btn small" aria-label="{{localize 'SWSE.ActorUI.ConvertStockDroidToCustomSystemNativeDroid'}}">
          <i class="fa-solid fa-wand-magic-sparkles"></i> {{localize "SWSE.ActorUI.ConvertToCustom"}}
        </button>
      {{else}}
        <button type="button" class="edit-droid-systems holo-btn small" aria-label="{{localize 'SWSE.ActorUI.EditDroidConfiguration'}}">
          <i class="fa-solid fa-edit"></i> {{localize "SWSE.ActorUI.Edit"}}
        </button>
      {{/if}}
      {{#if droidPanels.droidSummary.degree}}
        <button type="button" data-action="customize-droid" class="holo-btn small" aria-label="{{localize 'SWSE.ActorUI.CustomizeDroidSystems'}}">
          <i class="fas fa-cog"></i> {{localize "SWSE.ActorUI.Customize"}}
        </button>
      {{/if}}
    {{/if}}
  </div>

  {{#if droidPanels.droidSummary.degree}}
    <div class="droid-config-summary swse-store-section">
      {{#if droidPanels.droidSummary.degree}}
        <div class="config-item swse-metric-chip">
          <span class="label">{{localize "SWSE.ActorUI.Degree2"}}</span>
          <span class="value">{{droidPanels.droidSummary.degree}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.droidSummary.size}}
        <div class="config-item swse-metric-chip">
          <span class="label">{{localize "SWSE.ActorUI.Size"}}</span>
          <span class="value">{{droidPanels.droidSummary.size}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.droidSummary.creditsTotal}}
        <div class="config-item swse-metric-chip">
          <span class="label">{{localize "SWSE.ActorUI.Budget"}}</span>
          <span class="value">{{droidPanels.droidSummary.creditsSpent}} / {{droidPanels.droidSummary.creditsTotal}}</span>
        </div>
        <div class="config-item swse-metric-chip">
          <span class="label">{{localize "SWSE.ActorUI.Remaining"}}</span>
          <span class="value {{#if droidPanels.droidSummary.isOverBudget}}over-budget{{else}}in-budget{{/if}}">
            {{droidPanels.droidSummary.creditsRemaining}}
          </span>
        </div>
      {{/if}}

      {{#if droidPanels.droidSummary.readinessStatus}}
        <div class="config-item swse-metric-chip">
          <span class="label">{{localize "SWSE.ActorUI.Status"}}</span>
          <span class="value readiness-{{droidPanels.droidSummary.readinessStatus}}">{{droidPanels.droidSummary.readinessStatus}}</span>
        </div>
      {{/if}}
    </div>
  {{else}}
    <div class="empty-state">
      <p><em>{{localize "SWSE.ActorUI.NoDroidConfigurationYet"}}</em></p>
      {{#if editable}}
        <button type="button" class="edit-droid-systems holo-btn" aria-label="{{localize 'SWSE.ActorUI.CreateDroidConfiguration'}}">
          <i class="fa-solid fa-robot"></i> {{localize "SWSE.ActorUI.CreateConfiguration"}}
        </button>
      {{/if}}
    </div>
  {{/if}}
</div>
