<section class="swse-panel holo-panel swse-ui-panel swse-droid-part-region swse-droid-armor-region">
  <header class="section-bar">
    <h3 class="section-header">Armor / Body</h3>
    {{#if droid.resolvedSystems.armor.items.length}}
      <span class="section-meta muted">{{droid.resolvedSystems.armor.items.length}} installed</span>
    {{/if}}
  </header>

  {{#if droid.resolvedSystems.armor.isConfigured}}
    <div class="swse-droid-part-list">
      {{#each droid.resolvedSystems.armor.items as |armor|}}
        <button type="button" class="swse-droid-part-card" data-action="use-droid-part" data-part-id="{{armor.id}}" data-item-id="{{armor.itemId}}">
          <span class="swse-droid-part-name">{{armor.name}}</span>
          {{#if armor.armorBonus}}
            <span class="swse-droid-slot-badge">Ref +{{armor.armorBonus}}</span>
          {{/if}}
          {{#if armor.description}}
            <span class="swse-droid-part-desc">{{armor.description}}</span>
          {{/if}}
        </button>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p><em>No built-in armor installed.</em></p>
    </div>
  {{/if}}
</section>
