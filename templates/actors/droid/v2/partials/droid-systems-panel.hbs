{{!--
  Droid Systems Panel — Phase 1: Template Integration Pass

  Now consumes droidPanels.* instead of raw system.droidSystems.
  Preserves current chip-summary layout and all affordances.

  Data contract:
    droidPanels.droidSummary (degree, size, credits, state)
    droidPanels.locomotion.name
    droidPanels.configurationMetrics (processor, armor, counts)
--}}
<div class="holo-panel swse-ui-panel swse-droid-system-suite">
  <div class="section-bar">
    <h3 class="section-header">Droid Systems</h3>
    {{#if editable}}
      <button type="button" class="edit-droid-systems holo-btn small" aria-label="Edit droid configuration">
        <i class="fa-solid fa-edit"></i> Edit
      </button>
    {{/if}}
  </div>

  {{#if droidPanels.droidSummary.degree}}
    <div class="droid-config-summary swse-store-section">
      {{#if droidPanels.droidSummary.degree}}
        <div class="config-item swse-metric-chip">
          <span class="label">Degree:</span>
          <span class="value">{{droidPanels.droidSummary.degree}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.droidSummary.size}}
        <div class="config-item swse-metric-chip">
          <span class="label">Size:</span>
          <span class="value">{{droidPanels.droidSummary.size}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.locomotion.name}}
        <div class="config-item swse-metric-chip">
          <span class="label">Locomotion:</span>
          <span class="value">{{droidPanels.locomotion.name}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.configurationMetrics.appendagesCount}}
        <div class="config-item swse-metric-chip">
          <span class="label">Appendages:</span>
          <span class="value">{{droidPanels.configurationMetrics.appendagesCount}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.configurationMetrics.sensorsCount}}
        <div class="config-item swse-metric-chip">
          <span class="label">Sensors:</span>
          <span class="value">{{droidPanels.configurationMetrics.sensorsCount}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.configurationMetrics.processorName}}
        <div class="config-item swse-metric-chip">
          <span class="label">Processor:</span>
          <span class="value">{{droidPanels.configurationMetrics.processorName}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.configurationMetrics.armorName}}
        <div class="config-item swse-metric-chip">
          <span class="label">Armor:</span>
          <span class="value">{{droidPanels.configurationMetrics.armorName}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.configurationMetrics.weaponsCount}}
        <div class="config-item swse-metric-chip">
          <span class="label">Weapons:</span>
          <span class="value">{{droidPanels.configurationMetrics.weaponsCount}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.configurationMetrics.accessoriesCount}}
        <div class="config-item swse-metric-chip">
          <span class="label">Accessories:</span>
          <span class="value">{{droidPanels.configurationMetrics.accessoriesCount}}</span>
        </div>
      {{/if}}

      {{#if droidPanels.droidSummary.creditsTotal}}
        <div class="config-item swse-metric-chip">
          <span class="label">Cost:</span>
          <span class="value">{{droidPanels.droidSummary.creditsSpent}} / {{droidPanels.droidSummary.creditsTotal}} credits</span>
        </div>
      {{/if}}

      {{#if droidPanels.droidSummary.stateMode}}
        <div class="config-item swse-metric-chip">
          <span class="label">State:</span>
          <span class="value state-{{droidPanels.droidSummary.stateMode}}">{{droidPanels.droidSummary.stateMode}}</span>
        </div>
      {{/if}}
    </div>
  {{else}}
    <div class="empty-state">
      <p><em>No droid configuration yet.</em></p>
      {{#if editable}}
        <button type="button" class="edit-droid-systems holo-btn" aria-label="Create droid configuration">
          <i class="fa-solid fa-robot"></i> Create Configuration
        </button>
      {{/if}}
    </div>
  {{/if}}
</div>
