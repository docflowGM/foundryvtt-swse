<section class="sheet-shell flexcol">

  {{!-- HEADER --}}
  <header class="sheet-header flexrow">
    <h2 class="char-name">{{actorName}}</h2>
  </header>

  {{!-- BODY WITH PROPER FLEX LAYOUT --}}
  <section class="sheet-body flexcol">

    {{!-- TABS (FIXED HEIGHT) --}}
    <nav class="sheet-tabs tabs flexrow" data-group="primary">
      <a class="item" data-tab="overview">Overview</a>
      <a class="item" data-tab="details">Details</a>
      <a class="item" data-tab="notes">Notes</a>
    </nav>

    {{!-- TAB CONTENT (FLEXIBLE HEIGHT) --}}
    <section class="sheet-content">
      <div class="tab" data-group="primary" data-tab="overview">
        <div class="swse-p-md">
          <h3>Overview</h3>
          <p>This is the overview tab content.</p>
          <p>The tab system should now render properly with flex layout.</p>
        </div>
      </div>

      <div class="tab" data-group="primary" data-tab="details">
        <div class="swse-p-md">
          <h3>Character Details</h3>
          <p>This is the details tab content.</p>
          <p>Tabs should expand to fill available space.</p>
        </div>
      </div>

      <div class="tab" data-group="primary" data-tab="notes">
        <div class="swse-p-md">
          <h3>Notes</h3>
          <p>This is the notes tab content.</p>
          <p>All panels should be visible and properly sized.</p>
        </div>
      </div>
    </section>

  </section>

</section>
