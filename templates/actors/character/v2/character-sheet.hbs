<form class="swse-recovery-sheet swse-character-sheet-form {{cssClass}}" autocomplete="off">
  <div class="swse-datapad-frame">
    <div class="swse-datapad-header">
      <div class="swse-datapad-ident">TYPES.ACTOR.CHARACTER: {{actor.name}}</div>
      <div class="swse-datapad-controls"><span></span><span></span><span></span></div>
    </div>

    <div class="swse-home-console">
      <div class="swse-console-topline">
        <span>ONLINE DATAPAD</span>
        <span>·</span>
        <span>HOME</span>
        <span>·</span>
        <span>ALERTS</span>
        <span class="swse-console-power">{{system.level}} LVL</span>
      </div>

      <div class="swse-home-hero">
        <div class="swse-home-left">
          <div class="swse-panel swse-profile-card">
            <img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}"/>
            <div class="swse-profile-lines">
              <div><span>HP</span><div class="swse-mini-bar"><i style="width: {{hpPercent}}%"></i></div></div>
              <div><span>FP</span><div class="swse-mini-bar"><i style="width: {{system.forcePoints.value}}0%"></i></div></div>
              <div><span>DT</span><div class="swse-mini-bar"><i style="width: 62%"></i></div></div>
              <div><span>XP</span><div class="swse-mini-bar gold"><i style="width: {{xpPercent}}%"></i></div></div>
            </div>
            <div class="swse-status-line">[STATUS] awaiting new instructions.</div>
          </div>
        </div>

        <div class="swse-home-center">
          <div class="swse-radial-shell">
            <div class="swse-radial-ring swse-radial-ring--outer"></div>
            <div class="swse-radial-ring swse-radial-ring--mid"></div>
            <div class="swse-radial-core">
              <span>{{system.class}}</span>
            </div>
            <button type="button" class="swse-radial-app app-character">Character</button>
            <button type="button" class="swse-radial-app app-progress">Training</button>
            <button type="button" class="swse-radial-app app-workbench">Workbench</button>
            <button type="button" class="swse-radial-app app-store">Store</button>
          </div>
        </div>

        <div class="swse-home-right">
          <div class="swse-panel swse-feed-card">
            <div class="swse-panel-title">COMM FEED</div>
            <div class="swse-panel-body">{{#if notes}}{{notes}}{{else}}No holonet traffic yet.{{/if}}</div>
          </div>
          <div class="swse-panel swse-glance-card">
            <div class="swse-panel-title">QUICK GLANCE</div>
            <div class="swse-glance-grid">
              <div><span>LEVEL</span><strong>{{system.level}}</strong></div>
              <div><span>XP</span><strong>{{system.xp.value}}/{{system.xp.required}}</strong></div>
              <div><span>FP</span><strong>{{system.forcePoints.value}}</strong></div>
              <div><span>ALERTS</span><strong>{{featureItems.length}}</strong></div>
            </div>
          </div>
          <div class="swse-panel swse-feed-card">
            <div class="swse-panel-title">LAST SESSION</div>
            <div class="swse-panel-body">{{#if bio}}{{bio}}{{else}}No recap has been published yet.{{/if}}</div>
          </div>
        </div>
      </div>

      <div class="swse-launch-row">
        <button type="button" class="swse-launch-button app-character">[1] Character</button>
        <button type="button" class="swse-launch-button app-progress">[2] Training</button>
        <button type="button" class="swse-launch-button app-workbench">[3] Workbench</button>
        <button type="button" class="swse-launch-button app-store">[4] Store</button>
      </div>
    </div>

    <nav class="sheet-tabs swse-sheet-tabs tabs" data-group="primary">
      <a class="item active" data-tab="overview">Overview</a>
      <a class="item" data-tab="abilities">Abilities</a>
      <a class="item" data-tab="skills">Skills</a>
      <a class="item" data-tab="combat">Combat</a>
      <a class="item" data-tab="talents">Talents &amp; Feats</a>
      <a class="item" data-tab="force">Force</a>
      <a class="item" data-tab="gear">Gear</a>
      <a class="item" data-tab="biography">Biography</a>
    </nav>

    <section class="sheet-body swse-sheet-body">
      <section class="tab active" data-group="primary" data-tab="overview">
        <div class="swse-content-grid swse-overview-grid">
          <div class="swse-panel">
            <div class="swse-panel-title">Identity</div>
            <div class="swse-form-grid two-col">
              <label>Name<input name="name" type="text" value="{{actor.name}}"/></label>
              <label>Player<input name="system.player" type="text" value="{{system.player}}"/></label>
              <label>Species<select name="system.race">{{#each races as |race key|}}<option value="{{key}}" {{#if (eq ../system.race key)}}selected{{/if}}>{{race.label}}</option>{{/each}}</select></label>
              <label>Class<input name="system.class" type="text" value="{{system.class}}"/></label>
              <label>Level<input name="system.level" type="number" value="{{system.level}}" min="1"/></label>
              <label>Credits<input name="system.credits" type="number" value="{{system.credits}}"/></label>
            </div>
          </div>
          <div class="swse-panel">
            <div class="swse-panel-title">Defenses</div>
            <div class="swse-defense-grid">{{#each defenseList as |def|}}<div class="swse-defense-chip"><span>{{def.label}}</span><strong>{{def.total}}</strong></div>{{/each}}</div>
            <div class="swse-resource-stack">
              <label>HP<div class="swse-meter"><i style="width: {{hpPercent}}%"></i></div><div class="swse-meter-value"><input name="system.hp.value" type="number" value="{{system.hp.value}}"/> / <input name="system.hp.max" type="number" value="{{system.hp.max}}"/></div></label>
              <label>XP<div class="swse-meter gold"><i style="width: {{xpPercent}}%"></i></div><div class="swse-meter-value"><input name="system.xp.value" type="number" value="{{system.xp.value}}"/> / <input name="system.xp.required" type="number" value="{{system.xp.required}}"/></div></label>
            </div>
          </div>
          <div class="swse-panel">
            <div class="swse-panel-title">Combat Snapshot</div>
            <div class="swse-stat-row"><span>BAB</span><strong>{{system.bab}}</strong></div>
            <div class="swse-stat-row"><span>Initiative</span><strong>{{system.initiative.total}}</strong></div>
            <div class="swse-stat-row"><span>Speed</span><strong>{{system.speed.total}}</strong></div>
            <div class="swse-stat-row"><span>Condition</span><strong>{{system.conditionTrack}}</strong></div>
            <button type="button" class="header-btn level-up">Level Up</button>
          </div>
        </div>
      </section>

      <section class="tab" data-group="primary" data-tab="abilities">
        <div class="swse-content-grid ability-grid">{{#each abilitiesList as |ability|}}<div class="swse-panel swse-ability-card"><div class="swse-panel-title">{{ability.label}}</div><input name="system.abilities.{{ability.key}}.base" type="number" value="{{ability.base}}"/><div class="swse-ability-total">{{ability.total}}</div><div class="swse-ability-mod">{{ability.mod}}</div></div>{{/each}}</div>
      </section>

      <section class="tab" data-group="primary" data-tab="skills">
        <div class="swse-panel"><div class="swse-panel-title">Skills</div><div class="swse-list">{{#each skillsList as |skill|}}<div class="swse-list-row"><span>{{skill.label}}</span><span>{{skill.ability}}</span><strong>{{skill.value}}</strong></div>{{else}}<div class="swse-empty">No skills configured yet.</div>{{/each}}</div></div>
      </section>

      <section class="tab" data-group="primary" data-tab="combat">
        <div class="swse-panel"><div class="swse-panel-title">Weapons</div><div class="swse-list"><div class="swse-list-row weapon-entry swse-unarmed-attack-row"><span class="weapon-name">{{unarmedAttack.name}}</span><span>{{unarmedAttack.damage}} {{unarmedAttack.damageType}}</span>{{#if unarmedAttack.martialArtsStep}}<span>Martial Arts {{unarmedAttack.martialArtsStep}}</span>{{/if}}{{#if unarmedAttack.noProvokeOpportunity}}<span>No AoO</span>{{/if}}<div class="swse-inline-actions"><button type="button" data-action="roll-unarmed-attack">Roll</button></div></div>{{#each weaponsList as |weapon index|}}<div class="swse-list-row weapon-entry" data-index="{{index}}"><input type="text" name="system.weapons.{{index}}.name" value="{{weapon.name}}"/><input type="text" name="system.weapons.{{index}}.damage" value="{{weapon.damage}}"/><div class="swse-inline-actions"><button type="button" class="roll-weapon">Roll</button><button type="button" class="remove-weapon">Delete</button></div></div>{{else}}<div class="swse-empty">No weapons recorded.</div>{{/each}}</div><button type="button" class="header-btn add-weapon">Add Weapon</button></div>
      </section>

      <section class="tab" data-group="primary" data-tab="talents">
        <div class="swse-content-grid two-up">
          <div class="swse-panel"><div class="swse-panel-title">Feats</div><div class="swse-list">{{#each system.feats as |feat index|}}<div class="swse-list-row list-entry" data-index="{{index}}"><input type="text" name="system.feats.{{index}}.name" value="{{feat.name}}"/><button type="button" class="remove-feat">Delete</button></div>{{else}}<div class="swse-empty">No feats yet.</div>{{/each}}</div><button type="button" class="header-btn add-feat">Add Feat</button></div>
          <div class="swse-panel"><div class="swse-panel-title">Talents</div><div class="swse-list">{{#each system.talents as |talent index|}}<div class="swse-list-row list-entry" data-index="{{index}}"><input type="text" name="system.talents.{{index}}.name" value="{{talent.name}}"/><button type="button" class="remove-talent">Delete</button></div>{{else}}<div class="swse-empty">No talents yet.</div>{{/each}}</div><button type="button" class="header-btn add-talent">Add Talent</button></div>
        </div>
      </section>

      <section class="tab" data-group="primary" data-tab="force">
        <div class="swse-panel"><div class="swse-panel-title">Force Powers</div><div class="swse-list">{{#each forcePowers as |power|}}<div class="swse-list-row forcepower-entry" data-item-id="{{power._id}}"><span>{{power.name}}</span><span>{{power.system.uses.current}} / {{power.system.uses.max}}</span><div class="swse-inline-actions"><button type="button" class="roll-forcepower">Use</button><button type="button" class="remove-forcepower">Delete</button></div></div>{{else}}<div class="swse-empty">No Force powers known.</div>{{/each}}</div><div class="swse-inline-actions"><button type="button" class="header-btn add-forcepower">Add Force Power</button><button type="button" class="header-btn refresh-forcepowers">Refresh</button></div></div>
      </section>

      <section class="tab" data-group="primary" data-tab="gear">
        <div class="swse-panel"><div class="swse-panel-title">Inventory &amp; Workbench</div><div class="swse-list">{{#each inventoryItems as |item|}}<div class="swse-list-row"><span>{{item.name}}</span><span>{{item.type}}</span></div>{{else}}<div class="swse-empty">No inventory items found.</div>{{/each}}</div><div class="swse-inline-actions"><button type="button" class="header-btn app-store">Open Store</button><button type="button" class="header-btn app-progress">Open Progression</button></div></div>
      </section>

      <section class="tab" data-group="primary" data-tab="biography">
        <div class="swse-content-grid two-up"><div class="swse-panel"><div class="swse-panel-title">Biography</div><textarea name="system.bio" rows="12">{{bio}}</textarea></div><div class="swse-panel"><div class="swse-panel-title">Notes</div><textarea name="system.notes" rows="12">{{notes}}</textarea></div></div>
      </section>
    </section>
  </div>

  {{> "systems/foundryvtt-swse/templates/shell/shell-surface.hbs"}}

</form>
