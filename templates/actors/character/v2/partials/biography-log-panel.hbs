<section class="biography-log-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">Character History & Profile</h3>
  </header>

  <!-- Biography Main -->
  <div class="bio-log-sections">

    <div class="bio-log-section">
      <label class="section-subheader">Background & History</label>
      <textarea name="flags.swse.character.biography" class="bio-textarea" placeholder="Character background, origin story, key life events...">{{flags.swse.character.biography}}</textarea>
    </div>

    <!-- Campaign Log / Journal -->
    <div class="bio-log-section">
      <label class="section-subheader">Campaign Log & Notable Events</label>
      <textarea name="flags.swse.character.campaignLog" class="bio-textarea" placeholder="Session notes, key story moments, in-character journal entries, character development...">{{flags.swse.character.campaignLog}}</textarea>
    </div>

    <!-- Profile Summary -->
    <div class="bio-log-section">
      <label class="section-subheader">Character Profile & Beliefs</label>
      <textarea name="flags.swse.character.profileSummary" class="bio-textarea" placeholder="Character goals, beliefs, code of honor, quirks, ambitions...">{{flags.swse.character.profileSummary}}</textarea>
    </div>

  </div>

</section>
