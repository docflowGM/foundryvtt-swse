<section class="equipment-ledger-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">Equipment Ledger</h3>
    <button type="button" class="btn-small" data-action="tab" data-tab="gear" data-group="primary" data-tab-group="primary" title="Open Gear tab to manage inventory">Edit in Gear →</button>
  </header>

  {{#if (gt equipmentLedgerPanel.allEquipment.length 0)}}
    <div class="equipment-ledger">
      <!-- Ledger Header -->
      <div class="ledger-header">
        <div class="col-name">Item</div>
        <div class="col-type">Type</div>
        <div class="col-qty">Qty</div>
        <div class="col-weight">Weight</div>
        <div class="col-cost">Cost</div>
      </div>

      <!-- Equipment Rows -->
      {{#each equipmentLedgerPanel.allEquipment}}
        <div class="ledger-row svg-row-backed {{#if this.equipped}}equipped{{/if}}" data-item-id="{{this.id}}">
          <div class="col-name">
            <span class="item-name">{{this.name}}</span>
            {{#if this.equipped}}<span class="equipped-marker">⚙</span>{{/if}}
          </div>
          <div class="col-type">{{this.category}}</div>
          <div class="col-qty">{{this.quantity}}</div>
          <div class="col-weight">{{this.weight}}</div>
          <div class="col-cost">{{this.cost}}</div>
        </div>
      {{/each}}

      {{#if equipmentLedgerPanel.totalEquipmentWeight}}
        <div class="ledger-footer">
          <span class="footer-label">Total Weight</span>
          <span class="footer-value">{{equipmentLedgerPanel.totalEquipmentWeight}}</span>
        </div>
      {{/if}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>No equipment recorded.</p>
      <p class="hint">Add weapons, armor, and gear in the <a data-action="tab" data-tab="gear" data-group="primary" data-tab-group="primary" style="cursor:pointer; color:inherit; text-decoration:underline;">Gear tab</a>.</p>
    </div>
  {{/if}}

</section>
