<section class="swse-panel swse-panel--relationships relationships-panel holo-panel svg-framed svg-panel-frame">

  <!-- Frame layer: SVG background -->
  <div class="swse-panel__frame" aria-hidden="true"></div>

  <!-- Content layer: normal flow content -->
  <div class="swse-panel__content">
    <header class="section-bar">
      <h3 class="section-header">Relationships & Connections</h3>
      {{#if relationshipsPanel.hasAvailableFollowerSlots}}
      <button class="build-follower-btn" data-action="build-follower" title="Create a new follower under your command">
        <i class="fas fa-user-plus"></i> Build Follower
      </button>
      {{/if}}
    </header>

    {{#if (gt relationshipsPanel.relationships.length 0)}}
      <div class="relationships-list">
      {{#each relationshipsPanel.relationships}}
        <div class="relationship-entry" data-uuid="{{this.uuid}}">
          <div class="relationship-header">
            <div class="relationship-name-block">
              <img class="relationship-portrait" src="{{this.img}}" alt="{{this.name}}" title="Click to open {{this.name}}" />
              <div class="relationship-info">
                <div class="relationship-name">{{this.name}}</div>
                <div class="relationship-type">{{this.type}}</div>
              </div>
            </div>
          </div>
          {{#if this.notes}}
            <div class="relationship-notes">{{this.notes}}</div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>No relationships recorded yet.</p>
      <p class="hint">Drop actors onto the sheet to add relationships.</p>
    </div>
  {{/if}}

  <!-- Relationship Notes Section -->
  <div class="relationships-notes-section">
    <label class="section-subheader">Relationship Notes & Context</label>
    <textarea name="flags.swse.character.relationshipNotes" class="bio-textarea" placeholder="Overall notes about alliances, rivalries, key contact information...">{{relationshipsPanel.relationshipNotes}}</textarea>
    </div>
  </div>

</section>
