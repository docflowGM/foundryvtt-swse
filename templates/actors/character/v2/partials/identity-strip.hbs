
<div class="identity-strip {{#if forceSensitive}}force-sensitive{{/if}}"
     style="--identity-glow: {{identityGlowColor}};">

  <div class="identity-main">
    <h2 class="identity-name">{{biographyPanel.identity.name}}</h2>

    <div class="identity-meta">
      {{!-- PHASE 5: Display custom species name if present (Near-Human variants) --}}
      {{#if system.speciesCustomName}}
        <span>Species: {{system.speciesCustomName}}</span>
      {{else}}
        <span>Species: {{biographyPanel.identity.species}}</span>
      {{/if}}
      {{!-- Character biography fields (only display for characters) --}}
      <span>Homeworld: {{biographyPanel.identity.homeworld}}</span>
      <span>Background: {{biographyPanel.identity.background}}</span>
    </div>
  </div>

  {{#if forceSensitive}}
    <div class="identity-force-indicator">
      <i class="fa-solid fa-bolt"></i>
    </div>
  {{/if}}

</div>
