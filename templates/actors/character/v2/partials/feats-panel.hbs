<section class="abilities-section feats-section v3-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.Feats"}}</h3>
    <button type="button"
            class="add-feat swse-btn"
            data-action="add-feat"
            {{#unless featPanel.canEdit}}disabled{{/unless}}>
      {{localize "SWSE.CharacterSheet.Actions.AddFeat"}}
    </button>
  </header>

  {{#if featPanel.hasEntries}}
    <div class="feat-grid swse-dense-grid">
      {{#each featPanel.entries as |feat|}}
        <div class="feat-card swse-dense-card swse-ui-panel swse-card-schema swse-card-schema--enumerated swse-card-schema--filled"
             data-item-id="{{feat.id}}"
             data-action="open-ability">

          <div class="card-header swse-card-header">
            <span class="card-title">{{feat.name}}</span>
            {{#if ../featPanel.canEdit}}
              <button type="button"
                      class="swse-btn swse-btn--tiny swse-card-remove"
                      data-action="delete-item"
                      data-item-id="{{feat.id}}"
                      title='{{localize "SWSE.CharacterSheet.Actions.RemoveNamed" name=feat.name}}'
                      aria-label='{{localize "SWSE.CharacterSheet.Actions.RemoveNamed" name=feat.name}}'>
                ×
              </button>
            {{/if}}
          </div>

          {{#if feat.description}}
            <div class="card-summary swse-card-summary">
              {{feat.description}}
            </div>
          {{/if}}

          {{#if feat.requiresChoice}}
            <div class="swse-feat-choice-status {{#if feat.choiceMissing}}is-missing{{/if}} {{#if feat.choiceLocked}}is-locked{{/if}}">
              {{#if feat.choiceLocked}}
                <span class="swse-choice-badge">{{localize "SWSE.CharacterSheet.Status.LockedClassGrant"}}</span>
              {{else if feat.choiceMissing}}
                <span class="swse-choice-badge warning">{{localize "SWSE.CharacterSheet.Status.ChoiceNeeded"}}</span>
              {{else if feat.choiceInvalid}}
                <span class="swse-choice-badge warning" title="{{feat.choiceInvalidReason}}">{{localize "SWSE.CharacterSheet.Status.InvalidChoice" choice=feat.choiceLabel}}</span>
              {{else}}
                <span class="swse-choice-badge">{{localize "SWSE.CharacterSheet.Status.ChoiceMade" choice=feat.choiceLabel}}</span>
              {{/if}}
              {{#if feat.choiceEditable}}
                <button type="button"
                        class="swse-btn swse-btn--tiny"
                        data-action="resolve-feat-choice"
                        data-item-id="{{feat.id}}">
                  {{#if feat.choiceMissing}}{{localize "SWSE.CharacterSheet.Actions.Choose"}}{{else}}{{localize "SWSE.CharacterSheet.Actions.Change"}}{{/if}}
                </button>
              {{/if}}
            </div>
          {{/if}}

        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="muted empty-state swse-card-schema swse-card-schema--choice swse-card-schema--placeholder">
      <span class="swse-card-schema__eyebrow">{{localize "SWSE.CharacterSheet.Labels.ChoiceSlot"}}</span>
      <span class="swse-card-schema__title">{{featPanel.emptyMessage}}</span>
      <span class="swse-card-schema__body">{{#if featPanel.canEdit}}{{localize "SWSE.CharacterSheet.Hints.AddFirstFeat"}}{{else}}{{localize "SWSE.CharacterSheet.Empty.NoFeats"}}{{/if}}</span>
    </div>
  {{/if}}

</section>
