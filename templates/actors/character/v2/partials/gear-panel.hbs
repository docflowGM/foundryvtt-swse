{{!-- ========================================= --}}
{{!-- SWSE V2 GEAR INVENTORY PANEL --}}
{{!-- ========================================= --}}

<div class="swse-gear-panel">

  {{!-- WEAPONS SECTION --}}
  {{#if inventory.weapons.length}}
  <div class="gear-section">
    <div class="gear-section-header">
      <h3 class="gear-section-title">Weapons</h3>
      <span class="gear-section-count">{{inventory.weapons.length}}</span>
    </div>

    <div class="gear-list">
      {{#each inventory.weapons as |weapon|}}
      <div class="gear-row" data-item-id="{{weapon.id}}" data-item-type="weapon">
        <div class="gear-row-left">
          <div class="gear-item-name">
            <a class="gear-item-link" data-action="open-item" data-item-id="{{weapon.id}}" title="Click to edit weapon">
              {{weapon.name}}
            </a>
          </div>
          {{#if weapon.system.equipped}}
          <div class="gear-equipped-badge">EQUIPPED</div>
          {{/if}}
          {{#if weapon.system.quantity}}
          <div class="gear-qty-badge">×{{weapon.system.quantity}}</div>
          {{/if}}
        </div>

        <div class="gear-row-stats">
          {{#if weapon.system.weight}}
          <span class="gear-stat" title="Weight">{{weapon.system.weight}} kg</span>
          {{/if}}
        </div>

        <div class="gear-row-actions">
          <button
            type="button"
            class="gear-btn gear-btn-equip"
            data-action="equip-item"
            data-item-id="{{weapon.id}}"
            title="{{#if weapon.system.equipped}}Unequip{{else}}Equip{{/if}}">
            {{#if weapon.system.equipped}}<i class="fas fa-check-circle"></i>{{else}}<i class="fas fa-circle"></i>{{/if}}
          </button>
          <button
            type="button"
            class="gear-btn gear-btn-edit"
            data-action="edit-item"
            data-item-id="{{weapon.id}}"
            title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button
            type="button"
            class="gear-btn gear-btn-delete"
            data-action="delete-item"
            data-item-id="{{weapon.id}}"
            title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- ARMOR SECTION --}}
  {{#if inventory.armor.length}}
  <div class="gear-section">
    <div class="gear-section-header">
      <h3 class="gear-section-title">Armor</h3>
      <span class="gear-section-count">{{inventory.armor.length}}</span>
    </div>

    <div class="gear-list">
      {{#each inventory.armor as |armor|}}
      <div class="gear-row" data-item-id="{{armor.id}}" data-item-type="armor">
        <div class="gear-row-left">
          <div class="gear-item-name">
            <a class="gear-item-link" data-action="open-item" data-item-id="{{armor.id}}" title="Click to edit armor">
              {{armor.name}}
            </a>
          </div>
          {{#if armor.system.equipped}}
          <div class="gear-equipped-badge">EQUIPPED</div>
          {{/if}}
        </div>

        <div class="gear-row-stats">
          {{#if armor.system.defense}}
          <span class="gear-stat" title="Defense Bonus">+{{armor.system.defense}}</span>
          {{/if}}
          {{#if armor.system.weight}}
          <span class="gear-stat" title="Weight">{{armor.system.weight}} kg</span>
          {{/if}}
        </div>

        <div class="gear-row-actions">
          <button
            type="button"
            class="gear-btn gear-btn-equip"
            data-action="equip-item"
            data-item-id="{{armor.id}}"
            title="{{#if armor.system.equipped}}Unequip{{else}}Equip{{/if}}">
            {{#if armor.system.equipped}}<i class="fas fa-check-circle"></i>{{else}}<i class="fas fa-circle"></i>{{/if}}
          </button>
          <button
            type="button"
            class="gear-btn gear-btn-edit"
            data-action="edit-item"
            data-item-id="{{armor.id}}"
            title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button
            type="button"
            class="gear-btn gear-btn-delete"
            data-action="delete-item"
            data-item-id="{{armor.id}}"
            title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- EQUIPMENT SECTION --}}
  {{#if inventory.equipment.length}}
  <div class="gear-section">
    <div class="gear-section-header">
      <h3 class="gear-section-title">Equipment</h3>
      <span class="gear-section-count">{{inventory.equipment.length}}</span>
    </div>

    <div class="gear-list">
      {{#each inventory.equipment as |equip|}}
      <div class="gear-row" data-item-id="{{equip.id}}" data-item-type="equipment">
        <div class="gear-row-left">
          <div class="gear-item-name">
            <a class="gear-item-link" data-action="open-item" data-item-id="{{equip.id}}" title="Click to edit equipment">
              {{equip.name}}
            </a>
          </div>
          {{#if equip.system.quantity}}
          <div class="gear-qty-badge">×{{equip.system.quantity}}</div>
          {{/if}}
        </div>

        <div class="gear-row-stats">
          {{#if equip.system.weight}}
          <span class="gear-stat" title="Weight">{{equip.system.weight}} kg</span>
          {{/if}}
        </div>

        <div class="gear-row-actions">
          <button
            type="button"
            class="gear-btn gear-btn-edit"
            data-action="edit-item"
            data-item-id="{{equip.id}}"
            title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button
            type="button"
            class="gear-btn gear-btn-delete"
            data-action="delete-item"
            data-item-id="{{equip.id}}"
            title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- CONSUMABLES SECTION --}}
  {{#if inventory.consumables.length}}
  <div class="gear-section">
    <div class="gear-section-header">
      <h3 class="gear-section-title">Consumables</h3>
      <span class="gear-section-count">{{inventory.consumables.length}}</span>
    </div>

    <div class="gear-list">
      {{#each inventory.consumables as |consumable|}}
      <div class="gear-row" data-item-id="{{consumable.id}}" data-item-type="consumable">
        <div class="gear-row-left">
          <div class="gear-item-name">
            <a class="gear-item-link" data-action="open-item" data-item-id="{{consumable.id}}" title="Click to edit consumable">
              {{consumable.name}}
            </a>
          </div>
          {{#if consumable.system.quantity}}
          <div class="gear-qty-badge">×{{consumable.system.quantity}}</div>
          {{/if}}
        </div>

        <div class="gear-row-actions">
          <button
            type="button"
            class="gear-btn gear-btn-edit"
            data-action="edit-item"
            data-item-id="{{consumable.id}}"
            title="Edit">
            <i class="fas fa-edit"></i>
          </button>
          <button
            type="button"
            class="gear-btn gear-btn-delete"
            data-action="delete-item"
            data-item-id="{{consumable.id}}"
            title="Delete">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- EMPTY STATE --}}
  {{#unless (or inventory.weapons inventory.armor inventory.equipment inventory.consumables)}}
  <div class="gear-empty-state">
    <i class="fas fa-box-open"></i>
    <p>No gear yet. Add items to your inventory!</p>
  </div>
  {{/unless}}

</div>

<style>
.swse-gear-panel {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 16px;
  height: 100%;
  overflow-y: auto;
}

.gear-section {
  border: 1px solid rgba(0, 255, 255, 0.2);
  border-radius: 6px;
  background: rgba(10, 34, 56, 0.3);
  overflow: hidden;
}

.gear-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  background: rgba(0, 255, 255, 0.05);
  border-bottom: 1px solid rgba(0, 255, 255, 0.1);
}

.gear-section-title {
  margin: 0;
  font-size: 0.95rem;
  font-weight: 600;
  color: #4a9eff;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.gear-section-count {
  font-size: 0.8rem;
  color: #888;
  background: rgba(0, 0, 0, 0.3);
  padding: 2px 8px;
  border-radius: 3px;
}

.gear-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  padding: 0;
}

.gear-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 14px;
  background: rgba(0, 0, 0, 0.2);
  border-bottom: 1px solid rgba(0, 255, 255, 0.05);
  gap: 12px;
}

.gear-row:last-child {
  border-bottom: none;
}

.gear-row:hover {
  background: rgba(0, 0, 0, 0.4);
}

.gear-row-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  min-width: 0;
}

.gear-item-name {
  flex: 1;
  min-width: 0;
}

.gear-item-link {
  color: #4a9eff;
  text-decoration: none;
  cursor: pointer;
  word-break: break-word;
  padding-bottom: 2px;
  border-bottom: 1px solid transparent;
  transition: all 0.2s ease;
}

.gear-item-link:hover {
  color: #6bb5ff;
  border-bottom-color: #4a9eff;
}

.gear-equipped-badge {
  display: inline-block;
  padding: 3px 8px;
  background: rgba(74, 158, 255, 0.2);
  border: 1px solid rgba(74, 158, 255, 0.4);
  border-radius: 3px;
  font-size: 0.7rem;
  font-weight: 600;
  color: #4a9eff;
  text-transform: uppercase;
  letter-spacing: 0.2px;
  white-space: nowrap;
  flex-shrink: 0;
}

.gear-qty-badge {
  display: inline-block;
  padding: 3px 8px;
  background: rgba(255, 153, 0, 0.15);
  border: 1px solid rgba(255, 153, 0, 0.3);
  border-radius: 3px;
  font-size: 0.75rem;
  color: #ffaa00;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}

.gear-row-stats {
  display: flex;
  gap: 12px;
  align-items: center;
  flex-shrink: 0;
}

.gear-stat {
  font-size: 0.8rem;
  color: #888;
  white-space: nowrap;
}

.gear-row-actions {
  display: flex;
  gap: 4px;
  flex-shrink: 0;
}

.gear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  padding: 0;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 4px;
  color: #888;
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 0.85rem;
}

.gear-btn:hover {
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
}

.gear-btn-equip:hover {
  border-color: #4a9eff;
  background: rgba(74, 158, 255, 0.1);
  color: #4a9eff;
}

.gear-btn-edit:hover {
  border-color: #ffaa00;
  background: rgba(255, 170, 0, 0.1);
  color: #ffaa00;
}

.gear-btn-delete:hover {
  border-color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.gear-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  text-align: center;
  opacity: 0.6;
}

.gear-empty-state i {
  font-size: 3rem;
  margin-bottom: 16px;
  opacity: 0.4;
}

.gear-empty-state p {
  margin: 0;
  color: #888;
  font-size: 0.95rem;
}
</style>
