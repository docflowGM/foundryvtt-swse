<section class="skills-panel v2-skills-grid swse-ui-panel">

  <header class="section-header swse-ui-titlebar">
    <h3>Skills</h3>
  </header>

  <div class="skills-tools-row">
    <div class="skills-tool skills-tool--filter">
      <label for="skills-filter-select">Filter</label>
      <select id="skills-filter-select" data-action="filter-skills">
        <option value="all">All Skills</option>
        <option value="trained">Trained</option>
        <option value="favorited">Favorited</option>
        <option value="focused">Focused</option>
      </select>
    </div>
    <div class="skills-tool skills-tool--sort">
      <label for="skills-sort-select">Sort</label>
      <select id="skills-sort-select" data-action="sort-skills">
        <option value="name">Name A→Z</option>
        <option value="ability">Ability</option>
        <option value="total-desc">Highest Total</option>
        <option value="total-asc">Lowest Total</option>
      </select>
    </div>
    <button type="button" class="skills-tool-reset" data-action="reset-skills-tools">Reset Filters</button>
  </div>

  <!-- Skills Grid Header (Sticky) -->
  <div class="skills-grid-header swse-grid-header">
    <div class="col-favorite">★</div>
    <div class="col-skill-name">Skill</div>
    <div class="col-equals">=</div>
    <div class="col-ability-mod">Ability</div>
    <div class="col-half-level">½ Lvl</div>
    <div class="col-trained">Trained</div>
    <div class="col-focus">Focus</div>
    <div class="col-misc">Misc</div>
    <div class="col-total">Total</div>
    <div class="col-roll">Roll</div>
  </div>

  <!-- Skills Grid Body -->
  <div class="skills-grid-body skills-list">

    {{#each derived.skills as |skill|}}

      <div class="skills-grid-row swse-row-surface skill-row-container" data-skill="{{skill.key}}"
           data-skill-extra-uses="{{skill.extraUses.length}}"
           data-swse-tooltip="{{skill.label}}"
           data-name="{{skill.key}}"
           data-label="{{skill.label}}"
           data-total="{{skill.total}}"
           data-trained="{{#if skill.trained}}true{{else}}false{{/if}}"
           data-favorite="{{#if skill.favorite}}true{{else}}false{{/if}}"
           data-focused="{{#if skill.focused}}true{{else}}false{{/if}}"
           data-ability="{{skill.selectedAbility}}">

        <!-- Favorite Star (with expand/collapse affordance if extra uses available) -->
        <div class="col-favorite">
          <button type="button"
                  class="favorite-btn {{#if skill.favorite}}favorited{{/if}}"
                  data-action="toggle-favorite"
                  data-skill="{{skill.key}}"
                  title="Mark as favorite">
            ★
          </button>
        </div>

        <!-- Skill Name with Conditional Expand Affordance -->
        <div class="col-skill-name">
          {{#if skill.hasExtraUses}}
            {{#if (gte skill.extraUsesCount 3)}}
              <!-- Many uses: Show badge count -->
              <button type="button"
                      class="skill-expand-toggle skill-expand-toggle--many"
                      data-action="toggle-skill-expand"
                      data-skill="{{skill.key}}"
                      title="{{skill.extraUsesCount}} skill uses available"
                      aria-expanded="false">
                <span class="expand-count">{{skill.extraUsesCount}}</span>
              </button>
            {{else}}
              <!-- Few uses: Simple chevron -->
              <button type="button"
                      class="skill-expand-toggle"
                      data-action="toggle-skill-expand"
                      data-skill="{{skill.key}}"
                      title="{{skill.extraUsesCount}} skill {{#if (eq skill.extraUsesCount 1)}}use{{else}}uses{{/if}} available"
                      aria-expanded="false">
                ▶
              </button>
            {{/if}}
          {{/if}}
          <button type="button"
                  class="skill-name-btn rollable"
                  data-skill="{{skill.key}}"
                  data-mod-dialog="true"
                  title="Click to roll {{skill.label}}">
            {{skill.label}}
          </button>
        </div>

        <!-- Equals Operator -->
        <div class="col-equals">=</div>

        <!-- Ability Modifier (selected ability) -->
        <div class="col-ability-mod">
          <select name="system.skills.{{skill.key}}.selectedAbility"
                  class="ability-select ability-select--{{skill.selectedAbility}}"
                  data-ability-select="{{skill.selectedAbility}}"
                  title="Select ability modifier for {{skill.label}}">
            {{#each @root.derived.identity.abilities as |ab|}}
              <option value="{{ab.key}}"
                class="ability-option ability-option--{{ab.key}}"
                data-ability="{{ab.key}}"
                {{#if (eq ab.key skill.selectedAbility)}}selected{{/if}}>
                {{ab.label}}
              </option>
            {{/each}}
          </select>
          <span class="number-display {{#if (gt skill.abilityMod 0)}}positive{{else if (lt skill.abilityMod 0)}}negative{{else}}zero{{/if}}">
            {{numberFormat skill.abilityMod decimals=0 sign=true}}
          </span>
        </div>

        <!-- Half-Level Bonus (non-editable) -->
        <div class="col-half-level">
          <span class="number-display {{#if (gt skill.halfLevel 0)}}positive{{else if (lt skill.halfLevel 0)}}negative{{else}}zero{{/if}}"
                title="Half your character level">
            {{numberFormat skill.halfLevel decimals=0 sign=true}}
          </span>
        </div>

        <!-- Trained Checkbox -->
        <div class="col-trained">
          <input type="checkbox"
                 class="skill-checkbox"
                 name="system.skills.{{skill.key}}.trained"
                 {{checked skill.trained}}
                 title="Trained: You have ranks in this skill (+5)">
        </div>

        <!-- Focus Checkbox -->
        <div class="col-focus">
          <input type="checkbox"
                 class="skill-checkbox"
                 name="system.skills.{{skill.key}}.focused"
                 {{checked skill.focused}}
                 title="Focus: Focused skill (+5 bonus)">
        </div>

        <!-- Miscellaneous Modifier -->
        <div class="col-misc">
          <input type="number"
                 class="misc-input number-display {{#if (gt skill.miscMod 0)}}positive{{else if (lt skill.miscMod 0)}}negative{{else}}zero{{/if}}"
                 name="system.skills.{{skill.key}}.miscMod"
                 value="{{skill.miscMod}}"
                 placeholder="0"
                 title="Miscellaneous modifier (feats, conditions, etc.)">
        </div>

        <!-- Skill Total Display -->
        <div class="col-total">
          <span class="number-display {{#if (gt skill.total 0)}}positive{{else if (lt skill.total 0)}}negative{{else}}zero{{/if}}"
                title="Total skill bonus">
            {{numberFormat skill.total decimals=0 sign=true}}
          </span>
        </div>

        <!-- PHASE 6: Mobile Tap-to-Play Roll Button -->
        <div class="col-roll">
          <button type="button"
                  class="skill-roll-btn"
                  data-skill="{{skill.key}}"
                  data-mod-dialog="true"
                  aria-label="Roll {{skill.label}}"
                  title="Roll {{skill.label}}">
            🎲
          </button>
        </div>

      </div>

      <!-- PHASE 10+: Extra Skill Uses (grouped, filtered, status-aware) -->
      {{#if skill.hasExtraUses}}
      <div class="skill-extra-uses skill-extra-uses--collapsed swse-ui-frame" data-skill="{{skill.key}}">
        <!-- COMPACT FILTER TOGGLE (visible only when expanded) -->
        <div class="extra-uses-filter-bar skill-extra-uses-hidden">
          <div class="filter-buttons">
            <button class="filter-btn filter-btn--active" data-filter="all" title="Show all skill uses">All</button>
            <button class="filter-btn" data-filter="available" title="Show only usable actions">Available</button>
            <button class="filter-btn" data-filter="combat" title="Show combat-relevant uses">Combat</button>
          </div>
        </div>

        <!-- GROUPED DISPLAY -->
        {{#each skill.extraUsesGrouped as |group groupName|}}
          {{#if group.length}}
          <div class="extra-use-group" data-group="{{groupName}}">
            <div class="group-header">{{groupName}}</div>
            {{#each group as |use|}}
              <div class="extra-use-row swse-row-surface {{#if use.isBlocked}}use-blocked{{/if}}" data-use-key="{{use.key}}" data-category="{{use.category}}">
                <!-- Left: Label & Status -->
                <div class="extra-use-copy">
                  <div class="use-label-line">
                    <span class="extra-use-label">{{use.label}}</span>
                    {{#if use.isBlocked}}
                      <span class="use-status use-status--blocked" title="">🔒</span>
                    {{else if (and use.requiresTrained use.skillTrained)}}
                      <span class="use-status use-status--trained" title="Trained use">⭐</span>
                    {{/if}}
                  </div>
                  {{#if use.description}}
                    <span class="extra-use-description" title="{{use.description}}">{{truncate use.description 60}}</span>
                  {{/if}}
                </div>

                <!-- Center: DC & Type -->
                <div class="extra-use-meta">
                  {{#if use.dc}}
                    <span class="extra-use-dc" title="Difficulty Class">{{use.dc}}</span>
                  {{/if}}
                  {{#if use.actionTypeLabel.label}}
                    <span class="action-type-tag {{use.actionType}}" title="{{use.actionTypeLabel.label}} action">
                      {{use.actionTypeLabel.icon}}
                    </span>
                  {{/if}}
                </div>

                <!-- Right: Economy & Action -->
                <div class="extra-use-action-right">
                  {{#if use.timeLabel}}
                    <span class="extra-use-time {{use.timeClass}}" title="Action economy: {{use.timeLabel}}">
                      {{use.timeLabel}}
                    </span>
                  {{/if}}
                  <button type="button"
                          class="extra-use-btn {{#if use.isBlocked}}btn-disabled{{/if}}"
                          data-action="execute-extra-skill-use"
                          data-skill="{{../../key}}"
                          data-use="{{use.key}}"
                          data-use-key="{{use.useKey}}"
                          data-blocked="{{#if use.isBlocked}}true{{else}}false{{/if}}"
                          data-action-type="{{use.actionType}}"
                          data-source-type="{{use.sourceType}}"
                          data-source-label="{{use.sourceLabel}}"
                          {{#if use.isBlocked}}disabled title="{{use.blockedReason}}"{{else}}title="Use {{use.label}}"{{/if}}>
                    {{use.actionTypeLabel.action}}
                  </button>
                </div>
              </div>
            {{/each}}
          </div>
          {{/if}}
        {{/each}}
      </div>
      {{/if}}

    {{/each}}

  </div>

  <!-- Custom Skills Section (separate from built-in skills) -->
  {{#if (or system.customSkills customSkillsEditable)}}
  <div class="custom-skills-section swse-ui-frame">

    <div class="custom-skills-header swse-ui-titlebar">
      <h4>Custom Skills</h4>
      {{#if customSkillsEditable}}
      <button type="button"
              class="custom-skill-add-btn"
              data-action="add-custom-skill"
              title="Add a new custom skill">
        + Add
      </button>
      {{/if}}
    </div>

    {{#if system.customSkills}}
      <div class="custom-skills-list">

        {{#each system.customSkills as |customSkill|}}
        <div class="custom-skill-row swse-row-surface" data-custom-skill-id="{{customSkill.id}}">

          <!-- Favorite Placeholder -->
          <div class="col-favorite"></div>

          <!-- Skill Name (Editable) -->
          <div class="col-skill-name">
            <input type="text"
                   class="custom-skill-label-input"
                   name="system.customSkills.{{@index}}.label"
                   value="{{customSkill.label}}"
                   placeholder="Skill name"
                   title="Custom skill name">
          </div>

          <!-- Equals Operator -->
          <div class="col-equals">=</div>

          <!-- Ability Modifier Selector -->
          <div class="col-ability-mod">
            <select name="system.customSkills.{{@index}}.ability"
                    class="ability-select ability-select--{{customSkill.ability}}"
                    data-ability-select="{{customSkill.ability}}"
                    title="Select governing ability">
              {{#each @root.derived.identity.abilities as |ab|}}
                <option value="{{ab.key}}"
                  class="ability-option ability-option--{{ab.key}}"
                  data-ability="{{ab.key}}"
                  {{#if (eq ab.key customSkill.ability)}}selected{{/if}}>
                  {{ab.label}}
                </option>
              {{/each}}
            </select>
            {{#if @root.actor}}
            <span class="number-display {{#if (gt (getAbilityMod @root.actor customSkill.ability) 0)}}positive{{else if (lt (getAbilityMod @root.actor customSkill.ability) 0)}}negative{{else}}zero{{/if}}">
              {{numberFormat (getAbilityMod @root.actor customSkill.ability) decimals=0 sign=true}}
            </span>
            {{else}}
            <span class="number-display zero">{{numberFormat 0 decimals=0 sign=true}}</span>
            {{/if}}
          </div>

          <!-- Half-Level Bonus -->
          <div class="col-half-level">
            <span class="number-display {{#if (gt @root.derived.identity.level 0)}}positive{{else}}zero{{/if}}"
                  title="Half your character level">
              {{#if @root.system.level}}
                {{numberFormat (halfLevel @root.system.level) decimals=0 sign=true}}
              {{else}}
                {{numberFormat 0 decimals=0 sign=true}}
              {{/if}}
            </span>
          </div>

          <!-- Trained Checkbox -->
          <div class="col-trained">
            <input type="checkbox"
                   class="skill-checkbox"
                   name="system.customSkills.{{@index}}.trained"
                   {{checked customSkill.trained}}
                   title="Trained: +5 bonus">
          </div>

          <!-- Focus Checkbox -->
          <div class="col-focus">
            <input type="checkbox"
                   class="skill-checkbox"
                   name="system.customSkills.{{@index}}.focused"
                   {{checked customSkill.focused}}
                   title="Focus: +5 bonus">
          </div>

          <!-- Miscellaneous Modifier -->
          <div class="col-misc">
            <input type="number"
                   class="misc-input number-display {{#if (gt customSkill.miscMod 0)}}positive{{else if (lt customSkill.miscMod 0)}}negative{{else}}zero{{/if}}"
                   name="system.customSkills.{{@index}}.miscMod"
                   value="{{customSkill.miscMod}}"
                   placeholder="0"
                   title="Miscellaneous modifier">
          </div>

          <!-- Total Bonus Display -->
          <div class="col-total">
            {{#if @root.actor}}
            <span class="number-display {{#if (gt (customSkillTotal @root.actor customSkill) 0)}}positive{{else if (lt (customSkillTotal @root.actor customSkill) 0)}}negative{{else}}zero{{/if}}">
              {{numberFormat (customSkillTotal @root.actor customSkill) decimals=0 sign=true}}
            </span>
            {{else}}
            <span class="number-display zero">{{numberFormat 0 decimals=0 sign=true}}</span>
            {{/if}}
          </div>

          <!-- Roll Button -->
          <div class="col-roll">
            <button type="button"
                    class="custom-skill-roll-btn"
                    data-action="roll-custom-skill"
                    data-custom-skill-id="{{customSkill.id}}"
                    title="Roll this custom skill">
              🎲
            </button>
          </div>

          <!-- Delete Button -->
          <div class="col-delete">
            <button type="button"
                    class="custom-skill-delete-btn"
                    data-action="delete-custom-skill"
                    data-custom-skill-id="{{customSkill.id}}"
                    title="Delete this custom skill">
              ✕
            </button>
          </div>

        </div>

        {{#if customSkill.notes}}
        <div class="custom-skill-notes" data-custom-skill-id="{{customSkill.id}}">
          <textarea name="system.customSkills.{{@index}}.notes"
                    class="custom-skill-notes-input"
                    placeholder="Notes"
                    title="Notes for this skill">{{customSkill.notes}}</textarea>
        </div>
        {{/if}}

        {{/each}}

      </div>
    {{else}}
      {{#if customSkillsEditable}}
      <div class="custom-skills-empty">
        <p>No custom skills yet. Click "Add" to create one.</p>
      </div>
      {{/if}}
    {{/if}}

  </div>
  {{/if}}

  <style>
  .custom-skills-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 12px;
    margin-top: 12px;
    border-top: 2px solid rgba(255, 140, 0, 0.3);
  }

  .custom-skills-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0;
    padding: 0;
  }

  .custom-skills-header h4 {
    font-size: 1rem;
    font-weight: 700;
    opacity: 0.85;
    margin: 0;
  }

  .custom-skill-add-btn {
    padding: 4px 12px;
    border-radius: 4px;
    border: 1px solid rgba(255, 140, 0, 0.3);
    background: rgba(255, 140, 0, 0.1);
    color: rgba(255, 140, 0, 0.9);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .custom-skill-add-btn:hover {
    background: rgba(255, 140, 0, 0.2);
    border-color: rgba(255, 140, 0, 0.5);
    color: #ff8c00;
  }

  .custom-skills-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .custom-skill-row {
    display: grid;
    grid-template-columns: 0.5fr 2fr 0.3fr 1fr 0.8fr 0.8fr 0.8fr 1fr 1fr 0.6fr 0.4fr;
    gap: 8px;
    align-items: center;
    padding: 6px 8px;
    border-radius: 4px;
    border: 1px solid rgba(255, 140, 0, 0.15);
    background: rgba(255, 140, 0, 0.03);
    transition: background 0.15s ease;
  }

  .custom-skill-row:hover {
    background: rgba(255, 140, 0, 0.08);
    border-color: rgba(255, 140, 0, 0.25);
  }

  .custom-skill-label-input {
    padding: 4px 8px;
    border-radius: 3px;
    border: 1px solid rgba(255, 140, 0, 0.2);
    background: rgba(0, 20, 30, 0.5);
    color: inherit;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .custom-skill-label-input:focus {
    border-color: rgba(255, 140, 0, 0.5);
    outline: none;
  }

  .col-delete {
    display: flex;
    justify-content: center;
  }

  .custom-skill-delete-btn {
    background: none;
    border: none;
    padding: 2px 4px;
    color: rgba(255, 100, 100, 0.6);
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s ease;
    opacity: 0.5;
  }

  .custom-skill-delete-btn:hover {
    opacity: 1;
    color: #ff6464;
    transform: scale(1.2);
  }

  .custom-skill-roll-btn {
    background: none;
    border: none;
    padding: 4px;
    font-size: 1.2rem;
    cursor: pointer;
    opacity: 0.5;
    transition: all 0.15s ease;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    min-height: 32px;
  }

  .custom-skill-roll-btn:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .custom-skill-roll-btn:active {
    transform: scale(0.95);
  }

  .custom-skill-notes {
    padding: 4px 8px 0 24px;
    margin-top: -2px;
  }

  .custom-skill-notes-input {
    width: 100%;
    padding: 4px 8px;
    border-radius: 3px;
    border: 1px solid rgba(255, 140, 0, 0.15);
    background: rgba(255, 140, 0, 0.03);
    color: inherit;
    font-size: 0.85rem;
    font-style: italic;
    resize: vertical;
    min-height: 32px;
  }

  .custom-skill-notes-input:focus {
    border-color: rgba(255, 140, 0, 0.4);
    outline: none;
  }

  .custom-skills-empty {
    padding: 12px;
    text-align: center;
    color: rgba(255, 140, 0, 0.6);
    font-style: italic;
    opacity: 0.7;
  }
  </style>

</section>

<style>
.skills-tools-row { display:flex; flex-wrap:wrap; align-items:end; gap:12px; margin-bottom:10px; }
.skills-tool { display:flex; flex-direction:column; gap:4px; }
.skills-tool label { font-size:0.75rem; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; opacity:0.8; }
.skills-tool select, .skills-tool-reset { min-height:34px; border-radius:8px; }
.skills-tool-reset { border:1px solid rgba(0, 234, 255, 0.24); background:rgba(7, 17, 30, 0.9); color:#d9f8ff; font-weight:700; padding:0 12px; }
.skills-tool-reset:hover { border-color:rgba(0, 234, 255, 0.55); }
</style>

<!-- CSS for Traditional Grid Layout & Color Coding -->
<style>
.v2-skills-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 12px;
}

.v2-skills-grid .section-header {
  margin: 0;
  padding: 0;
  font-size: 1.1rem;
  font-weight: 800;
  opacity: 0.9;
}

.skills-grid-header {
  display: grid;
  grid-template-columns: 0.5fr 2fr 0.3fr 1fr 0.8fr 0.8fr 0.8fr 1fr 1fr 0.6fr;
  gap: 8px;
  padding: 8px 0;
  border-bottom: 2px solid rgba(0, 234, 255, 0.3);
  font-weight: 700;
  font-size: 0.85rem;
  opacity: 0.8;
  text-align: center;
  position: sticky;
  top: 0;
  background: rgba(0, 20, 40, 0.95);
  z-index: 10;
}

.skills-grid-header .col-favorite,
.skills-grid-header .col-skill-name {
  text-align: left;
}

/* Phase 5: Removed max-height to let tab expand */
.skills-grid-body {
  display: flex;
  flex-direction: column;
  gap: 2px;
  /* max-height removed — tab now owns scrolling */
  overflow-x: hidden;
}

.skills-grid-row {
  display: grid;
  grid-template-columns: 0.5fr 2fr 0.3fr 1fr 0.8fr 0.8fr 0.8fr 1fr 1fr 0.6fr;
  gap: 8px;
  align-items: center;
  padding: 6px 8px;
  border-radius: 4px;
  border: 1px solid rgba(0, 234, 255, 0.15);
  background: rgba(0, 234, 255, 0.03);
  transition: background 0.15s ease;
}

.skills-grid-row:hover {
  background: rgba(0, 234, 255, 0.08);
  border-color: rgba(0, 234, 255, 0.25);
}

.skills-grid-row .col-skill-name {
  text-align: left;
}

.favorite-btn {
  background: none;
  border: none;
  padding: 2px 4px;
  color: rgba(255, 215, 0, 0.3);
  font-size: 1.1rem;
  cursor: pointer;
  transition: all 0.2s ease;
  text-align: center;
}

.favorite-btn:hover {
  color: rgba(255, 215, 0, 0.8);
  transform: scale(1.2);
}

.favorite-btn.favorited {
  color: #ffd700;
  text-shadow: 0 0 8px rgba(255, 215, 0, 0.5);
}

.skill-name-btn,
.skill-bonus-btn {
  background: none;
  border: none;
  padding: 0;
  color: inherit;
  font-size: inherit;
  font-weight: 600;
  cursor: pointer;
  text-align: left;
  transition: color 0.1s ease;
}

.skill-name-btn:hover,
.skill-bonus-btn:hover {
  color: #00f0ff;
}

.skill-bonus-btn {
  text-align: center;
  width: 100%;
  cursor: pointer;
  border-radius: 3px;
  padding: 2px 4px;
  transition: all 0.15s ease;
}

.skill-bonus-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 0 8px rgba(0, 234, 255, 0.4);
}

/* ========== NUMBER COLOR CODING ========== */

.number-display {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.95rem;
  padding: 2px 4px;
  border-radius: 3px;
  min-width: 32px;
}

.number-display.positive {
  color: #00ff88;
  background: rgba(0, 255, 136, 0.15);
  border: 1px solid rgba(0, 255, 136, 0.4);
}

