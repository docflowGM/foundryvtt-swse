{{!--
  Talents Known Ledger (Record-Sheet Style)

  This is a compact reference surface showing all known talents in a scannable ledger.
  It is NOT a replacement for talents-panel.hbs; it is a presentation layer for
  quick reference during play.

  Reads: talentPanel.* (from panel context)
--}}

<section class="talents-known-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.TalentsKnown"}}</h3>
    <button type="button" class="btn-small" data-action="tab" data-tab="talents" data-group="primary" data-tab-group="primary" title='{{localize "SWSE.CharacterSheet.Tooltips.OpenTalentsTab"}}'>{{localize "SWSE.CharacterSheet.Actions.ManageArrow"}}</button>
  </header>

  {{#if talentPanel.hasEntries}}
    <div class="talents-ledger">
      {{#each (objectEntries talentPanel.grouped) as |groupEntry|}}
        {{#if groupEntry.value.length}}
          <div class="talent-group">
            <div class="group-header">{{groupEntry.key}}</div>
            {{#each groupEntry.value}}
              <div class="talent-row svg-row-backed" data-item-id="{{this.id}}">
                <div class="talent-name">{{this.name}}</div>
                {{#if this.source}}
                  <div class="talent-source">{{this.source}}</div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{/if}}
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>{{localize "SWSE.CharacterSheet.Empty.NoTalentsKnown"}}</p>
      <p class="hint">{{localize "SWSE.CharacterSheet.Hints.AddTalentsOnTab"}}</p>
    </div>
  {{/if}}

</section>
