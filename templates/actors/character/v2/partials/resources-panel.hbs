<section class="v3-panel holo-panel swse-resources-panel">
  <header class="section-bar">
    <h3 class="section-header">Combat Metrics & Resources</h3>
  </header>

  <!-- COMBAT METRICS SECTION -->
  <div class="resources-group">
    <div class="resources-group-header">Combat Metrics</div>
    <div class="resources-subgrid">
      <div class="resource">
        <div class="label">Speed</div>
        <input type="number" name="system.speed" value="{{speed}}" min="0" step="1" class="small-input"/>
      </div>

      <div class="resource" data-swse-tooltip="Initiative">
        <div class="label">Initiative</div>
        <div class="value-row">
          <span class="value">{{initiativeTotal}}</span>
          <button type="button" class="mini-btn" data-action="roll-initiative" title="Roll initiative">
            <i class="fa-solid fa-dice-d20"></i>
          </button>
          <button type="button" class="mini-btn" data-action="take10-initiative" title="Take 10 initiative">
            10
          </button>
        </div>
      </div>

      <div class="resource">
        <div class="label">Perception</div>
        <div class="value-row">
          <span class="value">{{perceptionTotal}}</span>
          <button type="button" class="mini-btn" data-action="roll-skill" data-skill="perception" title="Roll Perception">
            <i class="fa-solid fa-dice-d20"></i>
          </button>
        </div>
      </div>

      <div class="resource" data-swse-tooltip="BaseAttackBonus">
        <div class="label">Base Attack</div>
        <div class="value-row">
          <span class="value">{{bab}}</span>
        </div>
      </div>

      <div class="resource" data-swse-tooltip="Grapple">
        <div class="label">Grapple Bonus</div>
        <div class="value-row">
          <span class="value">{{grappleBonus}}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- HEROIC RESOURCES SECTION -->
  <div class="resources-group">
    <div class="resources-group-header">Heroic Resources</div>
    <div class="resources-subgrid">
      <div class="resource" data-swse-tooltip="ForcePoints">
        <div class="label">Force Points <span class="resource-subtle">({{forcePointDie}})</span></div>
        <div class="value-row">
          <input type="number" name="system.forcePoints.value" value="{{forcePointsValue}}" min="0" class="tiny-input"/>
          <span>/</span>
          <input type="number" name="system.forcePoints.max" value="{{forcePointsMax}}" min="0" class="tiny-input"/>
        </div>
        <div class="value-row">
          <button type="button" class="mini-btn" data-action="spend-force-point" title="Spend 1 Force Point">-1</button>
          <button type="button" class="mini-btn" data-action="gain-force-point" title="Restore 1 Force Point">+1</button>
        </div>
      </div>

      <div class="resource" data-swse-tooltip="DestinyPoints">
        <div class="label">Destiny Points</div>
        <div class="value-row">
          <input type="number" name="system.destinyPoints.value" value="{{destinyPointsValue}}" min="0" class="tiny-input"/>
          <span>/</span>
          <input type="number" name="system.destinyPoints.max" value="{{destinyPointsMax}}" min="0" class="tiny-input"/>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.swse-resources-panel .resource {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.swse-resources-panel .label {
  font-size: 0.75rem;
  opacity: 0.85;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.swse-resources-panel .value-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.swse-resources-panel .value {
  font-weight: 800;
  font-size: 1.05rem;
  min-width: 2ch;
}
.swse-resources-panel .small-input,
.swse-resources-panel .tiny-input {
  background: rgba(0,0,0,0.35);
  border: 1px solid rgba(0,255,255,0.25);
  color: inherit;
  border-radius: 6px;
  padding: 2px 6px;
}
.swse-resources-panel .small-input { width: 72px; }
.swse-resources-panel .tiny-input { width: 52px; }
.swse-resources-panel .mini-btn {
  border: 1px solid rgba(0,255,255,0.25);
  background: rgba(0,0,0,0.25);
  border-radius: 6px;
  padding: 2px 6px;
}
.swse-resources-panel .resource-subtle { opacity: 0.75; font-size: 0.7rem; }
</style>
