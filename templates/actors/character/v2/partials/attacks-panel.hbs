{{!-- SWSE V2 Attack Cards — visual shell only; rolls stay on the canonical attack path. --}}

<section class="swse-attacks-panel v3-panel holo-panel {{#if combatStatus.attackLocked}}is-attack-locked{{/if}}">
  <header class="section-bar swse-attacks-header">
    <div>
      <h3 class="section-header">Attacks</h3>
      <span class="swse-attacks-subtitle">Weapon cards use the canonical preroller and attack resolver.</span>
    </div>
    {{#if combatStatus.attackLocked}}
      <span class="swse-attack-lock-chip">Full Defense</span>
    {{/if}}
  </header>

  {{#if combatStatus.attackLocked}}
    <div class="swse-combat-lock-notice">{{combatStatus.attackLockLabel}}</div>
  {{/if}}

  {{#if combat.attacks.length}}
    <div class="swse-attacks-grid">
      {{#each combat.attacks as |attack|}}
      <div class="swse-attack-block swse-attack-card {{#if ../combatStatus.attackLocked}}is-disabled{{/if}}" data-attack-id="{{attack.id}}">
        <div class="swse-attack-card-icon" aria-hidden="true">{{#if attack.isMelee}}◇{{else}}⌁{{/if}}</div>
        <div class="swse-attack-card-main">
          <div class="swse-attack-card-name">{{attack.name}}</div>
          <div class="swse-attack-card-meta">
            {{#if attack.weaponType}}<span>{{attack.weaponType}}</span>{{/if}}
            {{#if attack.weaponName}}<span>{{attack.weaponName}}</span>{{/if}}
            {{#if attack.tags}}{{#each attack.tags}}<span>{{this}}</span>{{/each}}{{/if}}
          </div>
        </div>

        <div class="swse-attack-stat attack-bonus" data-weapon-id="{{attack.weaponId}}" data-attack-breakdown title="Click for breakdown">
          <strong>{{attack.attackTotal}}</strong>
          <span>To Hit</span>
        </div>

        <div class="swse-attack-stat attack-damage" data-weapon-id="{{attack.weaponId}}" data-damage-breakdown title="Click for breakdown">
          <strong>{{attack.damageFormula}}</strong>
          <span>Damage</span>
        </div>

        <div class="swse-attack-stat attack-crit">
          <strong>{{attack.critRange}}×{{attack.critMult}}</strong>
          <span>Crit</span>
        </div>

        <div class="swse-attack-card-actions">
          <button type="button"
                  class="attack-roll-btn primary"
                  data-action="roll-attack"
                  data-weapon-id="{{attack.weaponId}}"
                  {{#if ../combatStatus.attackLocked}}disabled{{/if}}
                  {{#unless ../combatStatus.canEdit}}disabled{{/unless}}
                  aria-label="Roll {{attack.name}} attack">
            Roll Attack
          </button>
          <button type="button"
                  class="attack-details-btn secondary"
                  data-action="toggle-attack-details"
                  data-attack-id="{{attack.id}}"
                  title="Show attack and damage breakdown"
                  aria-label="Show details for {{attack.name}}"
                  aria-expanded="false">
            Details
          </button>
        </div>

        <div class="attack-breakdown" style="display: none;">
          <div class="breakdown-section">
            <div class="section-title">Attack Modifier</div>
            <div class="pill-row swse-pill-row">
              {{#each attack.breakdown.attack}}<span class="pill swse-info-pill">{{label}} {{value}}</span>{{/each}}
            </div>
          </div>

          <div class="breakdown-section">
            <div class="section-title">Damage Modifier</div>
            <div class="pill-row swse-pill-row">
              {{#each attack.breakdown.damage}}<span class="pill swse-info-pill">{{label}} {{value}}</span>{{/each}}
            </div>
          </div>

          {{#if attack.breakdown.conditional.length}}
          <div class="breakdown-section">
            <div class="section-title">Conditional Modifiers</div>
            <div class="pill-row swse-pill-row">
              {{#each attack.breakdown.conditional}}<span class="pill conditional swse-info-pill">{{label}} {{value}}</span>{{/each}}
            </div>
          </div>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
  {{else}}
    <div class="swse-ui-empty swse-card-schema swse-card-schema--choice swse-card-schema--placeholder">
      <span class="swse-card-schema__eyebrow">No Attacks</span>
      <span class="swse-card-schema__title">No attacks available</span>
      <span class="swse-card-schema__body">Equip a weapon in the Gear tab to populate attack blocks here.</span>
    </div>
  {{/if}}
</section>
