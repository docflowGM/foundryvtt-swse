{{!-- ========================================= --}}
{{!-- SWSE V2 ATTACK CARDS (Flip Architecture) --}}
{{!-- ========================================= --}}

<div class="swse-attacks-panel swse-card-schema-grid">
  {{#if combat.attacks.length}}
    {{#each combat.attacks as |attack|}}
    <div class="swse-attack-card swse-ui-panel swse-card-schema swse-card-schema--enumerated swse-card-schema--filled" data-attack-id="{{attack.id}}">
      <div class="card-inner">
        <div class="card-front swse-card-face">
          <div class="attack-name">{{attack.name}}</div>

          {{#if attack.weaponId}}
          <div class="attack-weapon-info">
            <span class="weapon-name" title="{{attack.weaponName}}">{{attack.weaponName}}</span>
            {{#if attack.weaponType}}<span class="weapon-type">({{attack.weaponType}})</span>{{/if}}
          </div>
          {{/if}}

          <div class="attack-primary">
            <div class="attack-bonus" data-weapon-id="{{attack.weaponId}}" data-attack-breakdown title="Click for breakdown">{{attack.attackTotal}}</div>
            <div class="attack-damage" data-weapon-id="{{attack.weaponId}}" data-damage-breakdown title="Click for breakdown">{{attack.damageFormula}}</div>
          </div>

          <div class="attack-crit">
            Crit {{attack.critRange}}×{{attack.critMult}}
            {{#if attack.weaponProperties}}
              {{#if attack.weaponProperties.keen}}<span class="property-indicator" title="Keen: range +1">⚔</span>{{/if}}
            {{/if}}
          </div>

          <div class="attack-tags">
            {{#each attack.tags}}<span class="tag">{{this}}</span>{{/each}}
            {{#if attack.weaponProperties}}
              {{#if attack.weaponProperties.flaming}}<span class="tag property-tag">Flaming</span>{{/if}}
              {{#if attack.weaponProperties.frost}}<span class="tag property-tag">Frost</span>{{/if}}
              {{#if attack.weaponProperties.shock}}<span class="tag property-tag">Shock</span>{{/if}}
              {{#if attack.weaponProperties.vorpal}}<span class="tag property-tag">Vorpal</span>{{/if}}
            {{/if}}
          </div>

          <button type="button" class="attack-roll-btn" data-action="roll-weapon-attack" data-weapon-id="{{attack.weaponId}}">ROLL</button>
        </div>

        <div class="card-back swse-card-face">
          <div class="breakdown-section">
            <div class="section-title">Attack Breakdown</div>
            <div class="pill-row swse-pill-row">
              {{#each attack.breakdown.attack}}<span class="pill swse-info-pill">{{label}} {{value}}</span>{{/each}}
            </div>
          </div>

          <div class="breakdown-section">
            <div class="section-title">Damage Breakdown</div>
            <div class="pill-row swse-pill-row">
              {{#each attack.breakdown.damage}}<span class="pill swse-info-pill">{{label}} {{value}}</span>{{/each}}
            </div>
          </div>

          {{#if attack.breakdown.conditional.length}}
          <div class="breakdown-section">
            <div class="section-title">Conditional</div>
            <div class="pill-row swse-pill-row">
              {{#each attack.breakdown.conditional}}<span class="pill conditional swse-info-pill">{{label}} {{value}}</span>{{/each}}
            </div>
          </div>
          {{/if}}
        </div>
      </div>
    </div>
    {{/each}}
  {{else}}
    <div class="swse-ui-empty swse-card-schema swse-card-schema--choice swse-card-schema--placeholder">
      <span class="swse-card-schema__eyebrow">Enumerated Slot</span>
      <span class="swse-card-schema__title">No attacks available</span>
      <span class="swse-card-schema__body">Equip a weapon or add a combat-ready profile to populate standardized attack cards here.</span>
    </div>
  {{/if}}
</div>
