<section class="force-secrets-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">Force Secrets ({{derived.forceSecrets.count}})</h3>
  </header>

  {{#if derived.forceSecrets.list.length}}
    <div class="force-secrets-ledger">
      {{#each derived.forceSecrets.list}}
        <div class="secret-row svg-row-backed" data-item-id="{{this.id}}">
          <div class="secret-name">{{this.name}}</div>
          {{#if this.prerequisite}}
            <div class="secret-prereq muted">Requires: {{this.prerequisite}}</div>
          {{/if}}
          {{#if this.summary}}
            <div class="secret-summary muted">{{this.summary}}</div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>No Force secrets known.</p>
    </div>
  {{/if}}

</section>
