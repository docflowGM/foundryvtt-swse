<section class="force-secrets-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.ForceSecrets"}} ({{forcePowersPanel.secrets.length}})</h3>
  </header>

  {{#if forcePowersPanel.hasSecrets}}
    <div class="force-secrets-ledger">
      {{#each forcePowersPanel.secrets}}
        <div class="secret-row svg-row-backed" data-item-id="{{this.id}}">
          <div class="secret-name">{{this.name}}</div>
          {{#if this.system.prerequisite}}
            <div class="secret-prereq muted">{{localize "SWSE.CharacterSheet.Labels.Requires"}}: {{this.system.prerequisite}}</div>
          {{/if}}
          {{#if this.system.summary}}
            <div class="secret-summary muted">{{this.system.summary}}</div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>{{localize "SWSE.CharacterSheet.Empty.NoForceSecrets"}}</p>
    </div>
  {{/if}}

</section>
