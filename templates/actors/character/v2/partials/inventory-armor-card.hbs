{{!-- Armor Item Card for Inventory Display --}}
<div class="inventory-armor-card {{#if equipped}}is-equipped{{/if}}" data-item-id="{{id}}">

  {{!-- CARD HEADER: Name + Quick Status --}}
  <div class="card-header armor-header">
    <div class="armor-title-section">
      <div class="armor-name">{{name}}</div>
      <div class="armor-type-badge">{{system.armorType}}</div>
    </div>
    <div class="armor-status">
      {{#if equipped}}
        <span class="equipped-badge" title="Equipped">⚙</span>
      {{/if}}
    </div>
  </div>

  {{!-- CARD BODY: Stats + Modifiers --}}
  <div class="card-body armor-body">

    {{!-- Defense Bonuses Row --}}
    <div class="stat-row defense-stats">
      <div class="stat-item">
        <span class="stat-label">Reflex</span>
        <span class="stat-value {{#if system.reflexBonus}}positive{{/if}}">
          {{#if system.reflexBonus}}+{{system.reflexBonus}}{{else}}—{{/if}}
        </span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Fort</span>
        <span class="stat-value {{#if system.fortBonus}}positive{{/if}}">
          {{#if system.fortBonus}}+{{system.fortBonus}}{{else}}—{{/if}}
        </span>
      </div>
    </div>

    {{!-- Penalties Row --}}
    <div class="stat-row penalty-stats">
      {{#if system.armorCheckPenalty}}
        <div class="stat-item penalty">
          <span class="stat-label">ACP</span>
          <span class="stat-value negative">{{system.armorCheckPenalty}}</span>
        </div>
      {{/if}}
      {{#if system.maxDexBonus}}
        <div class="stat-item penalty">
          <span class="stat-label">Max Dex</span>
          <span class="stat-value">+{{system.maxDexBonus}}</span>
        </div>
      {{/if}}
      {{#if system.speedPenalty}}
        <div class="stat-item penalty">
          <span class="stat-label">Speed</span>
          <span class="stat-value negative">{{system.speedPenalty}}</span>
        </div>
      {{/if}}
    </div>

    {{!-- Weight & Properties --}}
    <div class="armor-meta">
      {{#if system.weight}}
        <span class="meta-item">⚖ {{system.weight}} lbs</span>
      {{/if}}
      {{#if system.isPowered}}
        <span class="meta-item powered">⚡ Powered</span>
      {{/if}}
      {{#if system.upgradeSlots}}
        <span class="meta-item">🔧 {{system.upgradeSlots}} slots</span>
      {{/if}}
    </div>

  </div>

  {{!-- CARD FOOTER: Actions --}}
  <div class="card-footer armor-footer">
    <div class="item-actions">
      <button class="item-action-btn customize-btn" data-action="customize-item" data-item-id="{{id}}" title="Customize Armor">
        <span class="icon">✎</span>
        <span class="label">Customize</span>
      </button>
      <button class="item-action-btn menu-btn" data-action="open-item-menu" data-item-id="{{id}}" title="More Actions">
        <span class="icon">⋯</span>
        <span class="label">More</span>
      </button>
    </div>
    <div class="item-actions-legacy">
      <button type="button" class="btn btn-equip" title="Equip/Unequip" data-action="equip" data-item-id="{{id}}">
        {{#if equipped}}Unequip{{else}}Equip{{/if}}
      </button>
      <button type="button" class="btn btn-config" title="Customize Armor" data-action="configure" data-item-id="{{id}}">⚙</button>
      <button type="button" class="btn btn-edit" title="Edit Item" data-action="edit" data-item-id="{{id}}">Edit</button>
      <button type="button" class="btn btn-sell" title="Sell Item" data-action="sell-item" data-item-id="{{id}}">Sell</button>
      <button type="button" class="btn btn-delete" title="Remove Item" data-action="delete" data-item-id="{{id}}">Delete</button>
    </div>
  </div>

</div>

