{{!-- Starship Maneuvers Panel
     Pure display — no logic, no mutations
     Reads: starshipManeuversPanel.* (from panel context)
--}}

<section class="starship-maneuvers-known-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.StarshipManeuvers"}} ({{starshipManeuversPanel.totalCount}})</h3>
  </header>

  {{#if starshipManeuversPanel.hasEntries}}
    <div class="starship-maneuvers-ledger">
      {{#each starshipManeuversPanel.entries}}
        <div class="maneuver-row svg-row-backed" data-item-id="{{this.id}}">
          <div class="maneuver-name">{{this.name}}</div>
          {{#if this.summary}}
            <div class="maneuver-summary muted">{{this.summary}}</div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>{{localize "SWSE.CharacterSheet.Empty.NoStarshipManeuvers"}}</p>
      <p class="hint">{{localize "SWSE.CharacterSheet.Hints.TakeStarshipTactics"}}</p>
    </div>
  {{/if}}

</section>
