<div class="holo-panel swse-ui-panel swse-card-schema swse-card-schema--enumerated swse-card-schema--filled">
  <div class="section-bar">
    <h3 class="section-header">Actions</h3>
    <div class="muted swse-card-schema__eyebrow" style="opacity:0.85; font-size:0.85rem;">Read-only — click an item-linked action to inspect</div>
  </div>

  {{#if combatActions.groups.length}}
    <div class="swse-v2-actions swse-card-schema-grid">
      {{#each combatActions.groups}}
        <div class="swse-v2-action-group swse-ui-panel swse-card-schema swse-card-schema--enumerated swse-card-schema--filled">
          <div class="swse-v2-action-group-header swse-card-header">
            <span class="label">{{this.label}}</span>
            <span class="count">{{this.count}}</span>
          </div>

          {{#each this.subgroups}}
            <div class="swse-v2-action-subgroup swse-ui-frame swse-card-schema swse-card-schema--enumerated swse-card-schema--filled">
              <div class="swse-v2-action-subheader swse-card-header">
                <span class="label">{{this.label}}</span>
                <span class="count">{{this.count}}</span>
              </div>

              <div class="swse-v2-action-list">
                {{#each this.items}}
                  <div class="swse-v2-action-row swse-row-surface swse-card-schema swse-card-schema--enumerated swse-card-schema--filled">
                    <div class="swse-v2-action-row-top">
                      <div class="left">
                        {{#if this.itemId}}
                          <a class="name swse-v2-open-item" data-action="open-item" data-item-id="{{this.itemId}}">{{this.name}}</a>
                        {{else}}
                          <span class="name">{{this.name}}</span>
                        {{/if}}
                        {{#if this.sourceName}}
                          <span class="tag">{{this.sourceName}}</span>
                        {{/if}}
                        {{#if this.active}}
                          <span class="tag">Active</span>
                        {{/if}}
                      </div>
                      <div class="right">
                        {{#if this.executable}}
                          <button type="button" class="swse-v2-btn swse-v2-use-action" data-action="swse-v2-use-action" data-action-id="{{this.key}}">{{#if this.useLabel}}{{this.useLabel}}{{else}}Use{{/if}}</button>
                        {{/if}}
                      </div>
                    </div>

                    {{#if this.resources.length}}
                      <div class="swse-v2-resources" style="margin-top:4px;">
                        {{#each this.resources as |r|}}
                          <div class="swse-v2-resource" data-kind="{{r.kind}}">
                            <span class="ticks {{r.sizeClass}}">
                              {{#each r.ticks as |t|}}
                                <span class="tick {{#if t.filled}}filled{{/if}}"></span>
                              {{/each}}
                            </span>
                            <span class="count">{{r.labelText}}</span>
                          </div>
                        {{/each}}
                      </div>
                    {{/if}}

                    {{#if this.description}}
                      <div class="muted swse-card-schema__body" style="opacity:0.85; margin-top:4px;">{{this.description}}</div>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/each}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="muted empty-state swse-ui-empty swse-card-schema swse-card-schema--choice swse-card-schema--placeholder" style="opacity:0.8;">
      <span class="swse-card-schema__eyebrow">Enumerated Slot</span>
      <span class="swse-card-schema__title">No actions available</span>
      <span class="swse-card-schema__body">This actor does not currently expose any item-linked or condition-linked action cards.</span>
    </div>
  {{/if}}
</div>
