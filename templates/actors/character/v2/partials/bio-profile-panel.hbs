<section class="bio-profile-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">Biography & Profile</h3>
  </header>

  <div class="bio-profile-content">
    <div class="bio-profile-grid">
      <!-- Appearance -->
      <div class="bio-field">
        <label class="field-label">Appearance</label>
        <textarea name="flags.swse.character.appearance" class="bio-textarea" placeholder="Physical description, distinguishing features, etc.">{{flags.swse.character.appearance}}</textarea>
      </div>

      <!-- Personality -->
      <div class="bio-field">
        <label class="field-label">Personality & Motivations</label>
        <textarea name="flags.swse.character.personality" class="bio-textarea" placeholder="Personality traits, motivations, quirks, etc.">{{flags.swse.character.personality}}</textarea>
      </div>
    </div>
  </div>

</section>
