<!-- Custom Skills Section -->
{{#if (or system.customSkills (hasPermission "items" "create"))}}
<div class="custom-skills-section swse-ui-frame">

  <div class="custom-skills-header swse-ui-titlebar">
    <h4>Custom Skills</h4>
    {{#if (hasPermission "items" "create")}}
    <button type="button"
            class="custom-skill-add-btn"
            data-action="add-custom-skill"
            title="Add a new custom skill">
      + Add
    </button>
    {{/if}}
  </div>

  {{#if system.customSkills}}
    <div class="custom-skills-list">

      {{#each system.customSkills as |customSkill|}}
      <div class="custom-skill-row swse-row-surface" data-custom-skill-id="{{customSkill.id}}">

        <!-- Favorite Placeholder -->
        <div class="col-favorite"></div>

        <!-- Skill Name (Editable) -->
        <div class="col-skill-name">
          <input type="text"
                 class="custom-skill-label-input"
                 name="system.customSkills.{{@index}}.label"
                 value="{{customSkill.label}}"
                 placeholder="Skill name"
                 title="Custom skill name">
        </div>

        <!-- Equals Operator -->
        <div class="col-equals">=</div>

        <!-- Ability Modifier Selector -->
        <div class="col-ability-mod">
          <select name="system.customSkills.{{@index}}.ability"
                  class="ability-select"
                  title="Select governing ability">
            {{#each @root.derived.identity.abilities as |ab|}}
              <option value="{{ab.key}}"
                {{#if (eq ab.key customSkill.ability)}}selected{{/if}}>
                {{ab.label}}
              </option>
            {{/each}}
          </select>
          <span class="number-display {{#if (gt (getAbilityMod @root.actor customSkill.ability) 0)}}positive{{else if (lt (getAbilityMod @root.actor customSkill.ability) 0)}}negative{{else}}zero{{/if}}">
            {{numberFormat (getAbilityMod @root.actor customSkill.ability) decimals=0 sign=true}}
          </span>
        </div>

        <!-- Half-Level Bonus -->
        <div class="col-half-level">
          <span class="number-display {{#if (gt @root.derived.identity.level 0)}}positive{{else}}zero{{/if}}"
                title="Half your character level">
            {{numberFormat (halfLevel @root.system.level) decimals=0 sign=true}}
          </span>
        </div>

        <!-- Trained Checkbox -->
        <div class="col-trained">
          <input type="checkbox"
                 class="skill-checkbox"
                 name="system.customSkills.{{@index}}.trained"
                 {{checked customSkill.trained}}
                 title="Trained: +5 bonus">
        </div>

        <!-- Focus Checkbox -->
        <div class="col-focus">
          <input type="checkbox"
                 class="skill-checkbox"
                 name="system.customSkills.{{@index}}.focused"
                 {{checked customSkill.focused}}
                 title="Focus: +5 bonus">
        </div>

        <!-- Miscellaneous Modifier -->
        <div class="col-misc">
          <input type="number"
                 class="misc-input number-display {{#if (gt customSkill.miscMod 0)}}positive{{else if (lt customSkill.miscMod 0)}}negative{{else}}zero{{/if}}"
                 name="system.customSkills.{{@index}}.miscMod"
                 value="{{customSkill.miscMod}}"
                 placeholder="0"
                 title="Miscellaneous modifier">
        </div>

        <!-- Total Bonus Display -->
        <div class="col-total">
          <span class="number-display {{#if (gt (customSkillTotal @root.actor customSkill) 0)}}positive{{else if (lt (customSkillTotal @root.actor customSkill) 0)}}negative{{else}}zero{{/if}}">
            {{numberFormat (customSkillTotal @root.actor customSkill) decimals=0 sign=true}}
          </span>
        </div>

        <!-- Roll Button -->
        <div class="col-roll">
          <button type="button"
                  class="custom-skill-roll-btn"
                  data-action="roll-custom-skill"
                  data-custom-skill-id="{{customSkill.id}}"
                  title="Roll this custom skill">
            🎲
          </button>
        </div>

        <!-- Delete Button -->
        <div class="col-delete">
          <button type="button"
                  class="custom-skill-delete-btn"
                  data-action="delete-custom-skill"
                  data-custom-skill-id="{{customSkill.id}}"
                  title="Delete this custom skill">
            ✕
          </button>
        </div>

      </div>

      {{#if customSkill.notes}}
      <div class="custom-skill-notes" data-custom-skill-id="{{customSkill.id}}">
        <textarea name="system.customSkills.{{@index}}.notes"
                  class="custom-skill-notes-input"
                  placeholder="Notes"
                  title="Notes for this skill">{{customSkill.notes}}</textarea>
      </div>
      {{/if}}

      {{/each}}

    </div>
  {{else}}
    {{#if (hasPermission "items" "create")}}
    <div class="custom-skills-empty">
      <p>No custom skills yet. Click "Add" to create one.</p>
    </div>
    {{/if}}
  {{/if}}

</div>
{{/if}}

<style>
.custom-skills-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 12px;
  margin-top: 12px;
  border-top: 2px solid rgba(255, 140, 0, 0.3);
}

.custom-skills-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0;
  padding: 0;
}

.custom-skills-header h4 {
  font-size: 1rem;
  font-weight: 700;
  opacity: 0.85;
  margin: 0;
}

.custom-skill-add-btn {
  padding: 4px 12px;
  border-radius: 4px;
  border: 1px solid rgba(255, 140, 0, 0.3);
  background: rgba(255, 140, 0, 0.1);
  color: rgba(255, 140, 0, 0.9);
  font-weight: 600;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.2s ease;
}

.custom-skill-add-btn:hover {
  background: rgba(255, 140, 0, 0.2);
  border-color: rgba(255, 140, 0, 0.5);
  color: #ff8c00;
}

.custom-skills-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.custom-skill-row {
  display: grid;
  grid-template-columns: 0.5fr 2fr 0.3fr 1fr 0.8fr 0.8fr 0.8fr 1fr 1fr 0.6fr 0.4fr;
  gap: 8px;
  align-items: center;
  padding: 6px 8px;
  border-radius: 4px;
  border: 1px solid rgba(255, 140, 0, 0.15);
  background: rgba(255, 140, 0, 0.03);
  transition: background 0.15s ease;
}

.custom-skill-row:hover {
  background: rgba(255, 140, 0, 0.08);
  border-color: rgba(255, 140, 0, 0.25);
}

.custom-skill-label-input {
  padding: 4px 8px;
  border-radius: 3px;
  border: 1px solid rgba(255, 140, 0, 0.2);
  background: rgba(0, 20, 30, 0.5);
  color: inherit;
  font-weight: 600;
  font-size: 0.9rem;
}

.custom-skill-label-input:focus {
  border-color: rgba(255, 140, 0, 0.5);
  outline: none;
}

.col-delete {
  display: flex;
  justify-content: center;
}

.custom-skill-delete-btn {
  background: none;
  border: none;
  padding: 2px 4px;
  color: rgba(255, 100, 100, 0.6);
  font-size: 1rem;
  cursor: pointer;
  transition: all 0.2s ease;
  opacity: 0.5;
}

.custom-skill-delete-btn:hover {
  opacity: 1;
  color: #ff6464;
  transform: scale(1.2);
}

.custom-skill-roll-btn {
  background: none;
  border: none;
  padding: 4px;
  font-size: 1.2rem;
  cursor: pointer;
  opacity: 0.5;
  transition: all 0.15s ease;
  border-radius: 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 32px;
  min-height: 32px;
}

.custom-skill-roll-btn:hover {
  opacity: 1;
  transform: scale(1.1);
}

.custom-skill-roll-btn:active {
  transform: scale(0.95);
}

.custom-skill-notes {
  padding: 4px 8px 0 24px;
  margin-top: -2px;
}

.custom-skill-notes-input {
  width: 100%;
  padding: 4px 8px;
  border-radius: 3px;
  border: 1px solid rgba(255, 140, 0, 0.15);
  background: rgba(255, 140, 0, 0.03);
  color: inherit;
  font-size: 0.85rem;
  font-style: italic;
  resize: vertical;
  min-height: 32px;
}

.custom-skill-notes-input:focus {
  border-color: rgba(255, 140, 0, 0.4);
  outline: none;
}

.custom-skills-empty {
  padding: 12px;
  text-align: center;
  color: rgba(255, 140, 0, 0.6);
  font-style: italic;
  opacity: 0.7;
}
</style>
