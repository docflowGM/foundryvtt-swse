{{!--
  ARMOR DISPLAY RULE: Deterministic Single-Armor Display
  -------------------------------------------------------
  Because equipped armor uniqueness is NOT enforced at the schema level,
  this panel uses a deterministic rule to display a single armor:

  RULE: First equipped armor by document storage order (first .find() match)
  RATIONALE: Matches ModifierEngine behavior (ModifierEngine.js)
  PRECEDENT: No validation in inventory-handlers.js to prevent multi-equip
  WORKAROUND: UI convention (toggle buttons) prevents accidental multi-equip

  If multiple armors are accidentally marked equipped, only the first one
  (by Foundry storage order) will display here and affect calculations.
  This is intentional, stable, and prevents silent failures.

  TODO (Phase 5): Consider adding UI validation or schema enforcement if
  multi-slot armor becomes a real requirement.
--}}

<section class="armor-summary-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">Equipped Armor Summary</h3>
    <button type="button" class="btn-small" data-action="tab" data-tab="gear" data-group="primary" data-tab-group="primary" title="Open Gear tab to manage armor">Manage →</button>
  </header>

  {{#if equippedArmor}}
    <div class="armor-summary">
      <!-- Armor Name & Type -->
      <div class="armor-name-block">
        <div class="armor-name">{{equippedArmor.name}}</div>
        {{#if equippedArmor.armorType}}
          <div class="armor-type">{{equippedArmor.armorType}}</div>
        {{/if}}
      </div>

      <!-- Defense Contributions -->
      <div class="armor-defenses">
        <div class="defense-item">
          <span class="defense-label">Reflex</span>
          <span class="defense-value {{#if equippedArmor.reflexBonus}}positive{{/if}}">
            {{#if equippedArmor.reflexBonus}}+{{equippedArmor.reflexBonus}}{{else}}—{{/if}}
          </span>
        </div>
        <div class="defense-item">
          <span class="defense-label">Fortitude</span>
          <span class="defense-value {{#if equippedArmor.fortBonus}}positive{{/if}}">
            {{#if equippedArmor.fortBonus}}+{{equippedArmor.fortBonus}}{{else}}—{{/if}}
          </span>
        </div>
      </div>

      <!-- Penalties & Modifiers -->
      <div class="armor-modifiers">
        {{#if equippedArmor.maxDexBonus}}
          <div class="modifier-item">
            <span class="mod-label">Max Dex Bonus</span>
            <span class="mod-value">+{{equippedArmor.maxDexBonus}}</span>
          </div>
        {{/if}}
        {{#if equippedArmor.armorCheckPenalty}}
          <div class="modifier-item penalty">
            <span class="mod-label">Armor Check Penalty</span>
            <span class="mod-value">{{equippedArmor.armorCheckPenalty}}</span>
          </div>
        {{/if}}
        {{#if equippedArmor.speedPenalty}}
          <div class="modifier-item penalty">
            <span class="mod-label">Speed Penalty</span>
            <span class="mod-value">{{equippedArmor.speedPenalty}}</span>
          </div>
        {{/if}}
      </div>

      <!-- Weight & Properties -->
      {{#if (or equippedArmor.weight equippedArmor.isPowered equippedArmor.upgradeSlots)}}
        <div class="armor-properties">
          {{#if equippedArmor.weight}}
            <span class="property">⚖ {{equippedArmor.weight}} lbs</span>
          {{/if}}
          {{#if equippedArmor.isPowered}}
            <span class="property powered">⚡ Powered</span>
          {{/if}}
          {{#if equippedArmor.upgradeSlots}}
            <span class="property">🔧 {{equippedArmor.upgradeSlots}} slots</span>
          {{/if}}
        </div>
      {{/if}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>No armor equipped.</p>
      <p class="hint">Equip armor from the <a data-action="tab" data-tab="gear" data-group="primary" data-tab-group="primary" style="cursor:pointer; color:inherit; text-decoration:underline;">Gear tab</a> to see summary here.</p>
    </div>
  {{/if}}

</section>
