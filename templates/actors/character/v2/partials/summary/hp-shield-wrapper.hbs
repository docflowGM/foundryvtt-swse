{{!-- HP + Shield Rating Visual Wrapper
     SR creates a glowing ring around HP
     Pure display — no logic, no mutations
     Reads: healthPanel.hp.value/max, healthPanel.shield.current/max
--}}

<div class="hp-shield-wrapper {{#if (eq healthPanel.shield.current 0)}}sr-empty{{/if}}"
     style="--sr-percent: {{percentage healthPanel.shield.current healthPanel.shield.max}}%;">

  {{!-- SR Ring Overlay --}}
  {{#if healthPanel.shield.max}}
    <div class="sr-ring"></div>
  {{/if}}

  {{!-- HP Container --}}
  <div class="hp-container">
    <div class="hp-bar">
      <div class="hp-fill"
           style="width: {{percentage healthPanel.hp.value healthPanel.hp.max}}%;"></div>
    </div>

    <div class="hp-values">
      {{healthPanel.hp.value}} / {{healthPanel.hp.max}}
    </div>
  </div>
</div>
