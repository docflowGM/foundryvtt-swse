{{!-- Shield Rating Display Partial
     Pure display — no logic, no mutations
     Reads: healthPanel.shield.* (from panel context)
--}}

<section class="summary-block sr-block {{#unless healthPanel.shield.active}}inactive{{/unless}}">
  <header class="summary-header">
    <span class="header-label">Shield Rating</span>
  </header>

  {{#if healthPanel.shield.max}}
    <div class="sr-content">
      <div class="sr-bar">
        <div class="sr-fill"
             style="width: {{healthPanel.shield.percent}}%;"></div>
      </div>

      <div class="sr-values">
        <span class="sr-current">SR {{healthPanel.shield.current}}</span>
        <span class="sr-separator">/</span>
        <span class="sr-max">{{healthPanel.shield.max}}</span>
      </div>

      {{#if healthPanel.shield.source}}
        <div class="sr-source">
          {{healthPanel.shield.source}}
        </div>
      {{/if}}
    </div>
  {{else}}
    <div class="sr-none">
      <em>None</em>
    </div>
  {{/if}}
</section>
