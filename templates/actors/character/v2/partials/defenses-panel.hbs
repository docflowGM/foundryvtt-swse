<section class="swse-panel swse-panel--defenses defenses-panel v3-panel holo-panel">
  <div class="swse-panel__content">
    <header class="section-bar">
      <h3 class="section-header">Defenses</h3>
      <div class="section-bar__actions">
        <button type="button"
                data-action="toggle-defenses"
                class="swse-btn">
          Expand
        </button>
      </div>
    </header>


    {{#if defensePanel.hasActiveImplant}}
      <div class="defense-implant-summary {{#unless defensePanel.implantTraining}}is-penalized{{/unless}}" title="Implant rules summary">
        {{defensePanel.implantSummary}}
      </div>
    {{/if}}

    <div class="defenses-container defenses-container--rows">
      {{#each defensePanel.defenses as |def|}}
        <div class="defense-row defense-{{def.key}}">
          <div class="defense-collapsed">
            <div class="defense-label-group">
              <div class="defense-label">{{def.label}}</div>
              <div class="defense-summary">
                10 + Heroic/Armor {{def.levelContribution}} + {{def.abilityLabel}} {{def.abilityMod}} + Class {{def.classDef}} + Species {{def.speciesBonus}} + Misc {{def.miscMod}}
              </div>
            </div>

            <div class="defense-total-group">
              <div class="defense-total">{{def.total}}</div>
              <div class="defense-total-label">Total</div>
            </div>
          </div>

          <div class="defense-expanded">
            <div class="defense-expanded__breakdown">
              <div class="defense-breakdown-row">
                <span class="defense-breakdown-label">Base</span>
                <span class="defense-breakdown-value">10</span>
              </div>
              <div class="defense-breakdown-row">
                <span class="defense-breakdown-label">Heroic/Armor</span>
                <span class="defense-breakdown-value">{{numberFormat def.levelContribution decimals=0 sign=true}}</span>
              </div>
              <div class="defense-breakdown-row">
                <span class="defense-breakdown-label">Armor Bonus</span>
                {{#if def.armorEditable}}
                  <input type="number" name="{{def.armorPath}}" value="{{def.armorBonus}}" class="misc-input" {{#unless def.canEdit}}disabled{{/unless}} />
                {{else}}
                  <span class="defense-breakdown-value">{{numberFormat def.armorBonus decimals=0 sign=true}}</span>
                {{/if}}
              </div>
              <div class="defense-breakdown-row">
                <span class="defense-breakdown-label">{{def.abilityLabel}} Modifier</span>
                <span class="defense-breakdown-value">{{numberFormat def.abilityMod decimals=0 sign=true}}</span>
              </div>
              <div class="defense-breakdown-row">
                <span class="defense-breakdown-label">Class Bonus</span>
                <input type="number" name="{{def.classBonusPath}}" value="{{def.classDef}}" class="misc-input" {{#unless def.canEdit}}disabled{{/unless}} />
              </div>
              {{#if def.speciesBonus}}
                <div class="defense-breakdown-row">
                  <span class="defense-breakdown-label">Species</span>
                  <span class="defense-breakdown-value {{def.speciesBonusClass}}">{{numberFormat def.speciesBonus decimals=0 sign=true}}</span>
                </div>
              {{/if}}
              {{#if def.rulesBonus}}
                <div class="defense-breakdown-row">
                  <span class="defense-breakdown-label">Rules</span>
                  <span class="defense-breakdown-value {{def.rulesBonusClass}}">{{numberFormat def.rulesBonus decimals=0 sign=true}}</span>
                </div>
              {{/if}}

              {{#if def.hasImplantWillPenalty}}
                <div class="defense-breakdown-row">
                  <span class="defense-breakdown-label">Implant Penalty</span>
                  <span class="defense-breakdown-value {{def.implantWillPenaltyClass}}">{{numberFormat def.implantWillPenalty decimals=0 sign=true}}</span>
                </div>
              {{/if}}

              <div class="defense-breakdown-row defense-breakdown-row--editable">
                <label class="defense-breakdown-label" for="defense-misc-{{def.key}}">Misc Modifier</label>
                <input id="defense-misc-{{def.key}}"
                       type="number"
                       name="{{def.miscPath}}"
                       value="{{def.miscMod}}"
                       class="misc-input {{def.miscModClass}}"
                       {{#unless def.canEdit}}disabled{{/unless}} />
              </div>
            </div>

            <div class="defense-expanded__total">
              <div class="defense-total">{{def.total}}</div>
              <div class="defense-total-label">{{def.label}}</div>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  </div>
</section>

<style>
.defense-implant-summary {
  margin: 0 0 8px;
  padding: 6px 8px;
  border: 1px solid rgba(123, 104, 238, 0.45);
  border-radius: 4px;
  color: #d6d0ff;
  background: rgba(123, 104, 238, 0.10);
  font-size: 12px;
}
.defense-implant-summary.is-penalized {
  border-color: rgba(255, 204, 102, 0.5);
  color: #ffe4a3;
  background: rgba(255, 204, 102, 0.10);
}
</style>
