
<section class="defenses-panel v3-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">Defenses</h3>
    <button type="button"
            data-action="toggle-defenses"
            class="swse-btn defenses-toggle">
      More
    </button>
  </header>

  <div class="defenses-container">

    {{#each headerDefenses as |def|}}

      <div class="defense-row defense-{{def.key}}">

        <!-- COLLAPSED -->
        <div class="defense-collapsed">

          <div class="defense-label">
            {{def.label}}
          </div>

          <div class="defense-total" data-defense-breakdown="{{def.key}}" title="Hover for modifier breakdown">
            {{def.total}}
          </div>

        </div>

        <!-- EXPANDED -->
        <div class="defense-expanded">

          <!-- Base (10) -->
          <div class="math-pill derived base-pill">
            <div class="pill-value">10</div>
          </div>

          <div class="math-operator">+</div>

          <!-- Level or Armor (Derived) -->
          <div class="math-pill derived">
            <label>Armor</label>
            <div class="pill-value">
              {{def.armorBonus}}
            </div>
          </div>

          <div class="math-operator">+</div>

          <!-- Ability (Derived) -->
          <div class="math-pill derived {{def.abilityModClass}}">
            <label>Ability</label>
            <div class="pill-value">
              <span class="mod-value">{{def.abilityMod}}</span>
            </div>
          </div>

          <div class="math-operator">+</div>

          <!-- Class (Derived if used) -->
          <div class="math-pill derived">
            <label>Class</label>
            <div class="pill-value">
              {{def.classDef}}
            </div>
          </div>

          <div class="math-operator">+</div>

          <!-- Misc (Editable) -->
          <div class="math-pill editable {{def.miscModClass}}">
            <label>Misc</label>
            <input type="number"
                   data-field="misc"
                   name="system.defenses.{{def.key}}.miscMod"
                   value="{{def.miscMod}}"
                   class="misc-input {{def.miscModClass}}">
          </div>

          <div class="math-equals">
            =
          </div>

          <div class="math-result">
            {{def.total}}
          </div>

        </div>

      </div>

    {{/each}}

  </div>

</section>
