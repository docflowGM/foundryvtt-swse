<section class="swse-panel swse-panel--defenses defenses-panel v3-panel holo-panel defenses-panel--open">
  <div class="swse-panel__content">
    <header class="section-bar">
      <h3 class="section-header">Defenses</h3>
    </header>

    <div class="defenses-container defenses-container--cards">
      {{#each defensePanel.defenses as |def|}}
        <div class="defense-card defense-{{def.key}}">
          <div class="defense-card__header">
            <div class="defense-card__label">{{def.label}}</div>
            <div class="defense-card__total">{{def.total}}</div>
          </div>

          <div class="defense-card__body">
            <div class="defense-card__formula">
              <span class="defense-token">10</span>
              <span class="defense-op">+</span>
              <span class="defense-token">A {{def.armorBonus}}</span>
              <span class="defense-op">+</span>
              <span class="defense-token">Ab {{def.abilityMod}}</span>
              <span class="defense-op">+</span>
              <span class="defense-token">C {{def.classDef}}</span>
              <span class="defense-op">+</span>
              <span class="defense-token defense-token--editable">M</span>
            </div>

            <div class="defense-card__misc">
              <label>Misc Modifier</label>
              <input type="number"
                     name="system.defenses.{{def.key}}.miscMod"
                     value="{{def.miscMod}}"
                     class="misc-input {{def.miscModClass}}"
                     {{#unless def.canEdit}}disabled{{/unless}} />
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  </div>
</section>
