{!-- DEPRECATED V2 SURFACE: retained only as reference. Canonical mounted surface is attacks-panel.hbs. Do not mount this partial in parallel unless replacing the canonical view intentionally. --}
{{!-- ========================================= --}}
{{!-- SWSE V2 COMBAT ATTACKS PANEL (SIMPLIFIED) --}}
{{!-- ========================================= --}}

<div class="swse-combat-attacks-panel">

  {{#if combat.attacks.length}}

    <div class="attacks-list">
      {{#each combat.attacks as |attack|}}
      <div class="attack-card" data-attack-id="{{attack.id}}" data-action-key="item:{{attack.id}}:attack">

        <div class="attack-card-header">
          <div class="attack-name">{{attack.name}}</div>
          {{#if attack.type}}
          <div class="attack-type-badge">{{attack.type}}</div>
          {{/if}}
        </div>

        <div class="attack-card-stats">
          <div class="stat-row">
            <span class="stat-label">Damage:</span>
            <span class="stat-value">{{attack.damage}}</span>
          </div>

          <div class="stat-row">
            <span class="stat-label">Range:</span>
            <span class="stat-value">{{attack.range}}</span>
          </div>

          {{#if attack.notes}}
          <div class="stat-row attack-notes">
            <span class="stat-value">{{attack.notes}}</span>
          </div>
          {{/if}}
        </div>

        <button
          type="button"
          class="attack-roll-btn"
          data-action="roll-weapon-attack"
          data-action-id="{{attack.actionId}}"
          data-weapon-id="{{attack.id}}"
          title="Roll attack with {{attack.name}}">
          <i class="fas fa-dice-d20"></i> Roll Attack
        </button>

      </div>
      {{/each}}
    </div>

  {{else}}

    <div class="attacks-empty-state">
      <i class="fas fa-shield-alt"></i>
      <p>No equipped weapons. Equip a weapon to make attacks.</p>
    </div>

  {{/if}}

</div>

<style>
.swse-combat-attacks-panel {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 16px;
  height: 100%;
  overflow-y: auto;
}

.attacks-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.attack-card {
  border: 1px solid rgba(74, 158, 255, 0.3);
  border-radius: 6px;
  padding: 12px;
  background: linear-gradient(135deg, rgba(10, 34, 56, 0.4) 0%, rgba(20, 50, 80, 0.3) 100%);
  transition: all 0.2s ease;
  cursor: pointer;
}

.attack-card:hover {
  background: linear-gradient(135deg, rgba(10, 34, 56, 0.6) 0%, rgba(20, 50, 80, 0.5) 100%);
  border-color: rgba(74, 158, 255, 0.6);
  box-shadow: 0 0 12px rgba(74, 158, 255, 0.2);
}

.attack-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
  gap: 10px;
}

.attack-name {
  font-size: 1rem;
  font-weight: 600;
  color: #fff;
  flex: 1;
}

.attack-type-badge {
  display: inline-block;
  padding: 3px 8px;
  background: rgba(255, 170, 0, 0.15);
  border: 1px solid rgba(255, 170, 0, 0.3);
  border-radius: 3px;
  font-size: 0.7rem;
  font-weight: 600;
  color: #ffaa00;
  text-transform: uppercase;
  letter-spacing: 0.2px;
  white-space: nowrap;
}

.attack-card-stats {
  margin-bottom: 12px;
  padding: 8px;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 4px;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.85rem;
  padding: 4px 0;
  gap: 8px;
}

.stat-row:not(:last-child) {
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  padding-bottom: 6px;
  margin-bottom: 6px;
}

.stat-label {
  color: #888;
  font-weight: 500;
  min-width: 70px;
}

.stat-value {
  color: #aaa;
  flex: 1;
  text-align: right;
}

.attack-notes {
  color: #666;
  font-size: 0.75rem;
  font-style: italic;
}

.attack-roll-btn {
  width: 100%;
  padding: 10px;
  background: linear-gradient(135deg, #4a9eff 0%, #2976cc 100%);
  border: none;
  border-radius: 4px;
  color: #fff;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.attack-roll-btn:hover {
  background: linear-gradient(135deg, #6bb5ff 0%, #3a88dd 100%);
  box-shadow: 0 0 16px rgba(74, 158, 255, 0.4);
  transform: translateY(-1px);
}

.attack-roll-btn:active {
  transform: translateY(0);
}

.attacks-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  text-align: center;
  opacity: 0.6;
}

.attacks-empty-state i {
  font-size: 3rem;
  margin-bottom: 16px;
  opacity: 0.4;
}

.attacks-empty-state p {
  margin: 0;
  color: #888;
  font-size: 0.95rem;
}
</style>
