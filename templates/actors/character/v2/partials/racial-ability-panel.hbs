{{!-- Racial Abilities Panel
     Pure display — no logic, no mutations
     Reads: racialAbilitiesPanel.* (from panel context)
--}}

<section class="abilities-section racial-section v3-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.RacialAbilities"}}</h3>
    <div class="muted">{{localize "SWSE.CharacterSheet.Labels.Passive"}}</div>
  </header>

  {{#if racialAbilitiesPanel.hasEntries}}
    <div class="racial-list">
      {{#each racialAbilitiesPanel.entries as |ability|}}
        <div class="racial-card"
             data-item-id="{{ability.id}}"
             data-action="open-ability">

          <div class="card-header">
            <span class="card-title">{{ability.name}}</span>
          </div>

          {{#if ability.summary}}
            <div class="card-summary">
              {{ability.summary}}
            </div>
          {{/if}}

        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="muted empty-state">
      {{localize "SWSE.CharacterSheet.Empty.NoRacialAbilities"}}
    </div>
  {{/if}}

</section>
