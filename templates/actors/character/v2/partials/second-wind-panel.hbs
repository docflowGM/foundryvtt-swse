<section class="swse-second-wind-panel v3-panel holo-panel swse-ui-panel">
  <header class="section-bar">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.SecondWind"}}</h3>
  </header>

  <div class="sw-content sw-content--detailed">
    <div class="sw-readout-row">
      <div class="sw-readout-chip">
        <span class="sw-readout-chip__label">{{localize "SWSE.CharacterSheet.Labels.BaseHealing"}}</span>
        <span class="sw-readout-chip__value">{{secondWindPanel.baseHealing}} {{localize "SWSE.CharacterSheet.Labels.HP"}}</span>
      </div>    </div>

    <div class="sw-edit-grid">
      <div class="sw-field">
        <label>{{localize "SWSE.CharacterSheet.Labels.ModifiedHealing"}}</label>
        <input type="number"
               name="system.secondWind.healing"
               value="{{secondWindPanel.healing}}"
               min="0"
               {{#unless secondWindPanel.canEdit}}disabled{{/unless}} />
      </div>
      <div class="sw-field">
        <label>{{localize "SWSE.CharacterSheet.Labels.UsesRemaining"}}</label>
        <input type="number"
               name="system.secondWind.uses"
               value="{{secondWindPanel.uses}}"
               min="0"
               {{#unless secondWindPanel.canEdit}}disabled{{/unless}} />
      </div>
      <div class="sw-field">
        <label>{{localize "SWSE.CharacterSheet.Labels.MaxUses"}}</label>
        <input type="number"
               name="system.secondWind.max"
               value="{{secondWindPanel.max}}"
               min="0"
               {{#unless secondWindPanel.canEdit}}disabled{{/unless}} />
      </div>
    </div>

    <div class="sw-uses-tracker">
      {{#each secondWindPanel.pips as |pip|}}
        <div class="sw-charge {{#if pip.active}}active{{/if}}" title="{{pip.label}}"></div>
      {{/each}}
    </div>

    <div class="sw-actions">
      <button type="button"
              class="sw-recover-btn"
              data-action="use-second-wind"
              {{#unless secondWindPanel.hasUses}}disabled{{/unless}}>
        {{localize "SWSE.CharacterSheet.Actions.UseSecondWind"}}
      </button>

      <button type="button"
              class="sw-rest-btn"
              data-action="rest-second-wind"
              {{#unless secondWindPanel.canEdit}}disabled{{/unless}}>
        {{localize "SWSE.CharacterSheet.Actions.ResetUses"}}
      </button>
    </div>
  </div>
</section>
