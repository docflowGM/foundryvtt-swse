<section class="swse-second-wind-panel v3-panel holo-panel swse-ui-panel">
  <header class="section-bar">
    <h3 class="section-header">Second Wind</h3>
  </header>

  <div class="sw-content sw-content--detailed">
    <div class="sw-readout-row">
      <div class="sw-readout-chip">
        <span class="sw-readout-chip__label">Base Healing</span>
        <span class="sw-readout-chip__value">{{secondWindPanel.baseHealing}} HP</span>
      </div>
      <div class="sw-readout-chip sw-readout-chip--accent">
        <span class="sw-readout-chip__label">Header Healing</span>
        <span class="sw-readout-chip__value">{{secondWindPanel.healing}} HP</span>
      </div>
    </div>

    <div class="sw-edit-grid">
      <div class="sw-field">
        <label>Modified Healing</label>
        <input type="number"
               name="system.secondWind.healing"
               value="{{secondWindPanel.healing}}"
               min="0"
               {{#unless secondWindPanel.canEdit}}disabled{{/unless}} />
      </div>
      <div class="sw-field">
        <label>Uses Remaining</label>
        <input type="number"
               name="system.secondWind.uses"
               value="{{secondWindPanel.uses}}"
               min="0"
               {{#unless secondWindPanel.canEdit}}disabled{{/unless}} />
      </div>
      <div class="sw-field">
        <label>Max Uses</label>
        <input type="number"
               name="system.secondWind.max"
               value="{{secondWindPanel.max}}"
               min="0"
               {{#unless secondWindPanel.canEdit}}disabled{{/unless}} />
      </div>
    </div>

    <div class="sw-uses-tracker">
      {{#each (range 0 secondWindPanel.max) as |i|}}
        <div class="sw-charge {{#if (lt i ../secondWindPanel.uses)}}active{{/if}}"></div>
      {{/each}}
    </div>

    <div class="sw-actions">
      <button type="button"
              class="sw-recover-btn"
              data-action="use-second-wind"
              {{#unless secondWindPanel.hasUses}}disabled{{/unless}}>
        Use Second Wind
      </button>

      <button type="button"
              class="sw-rest-btn"
              data-action="rest-second-wind"
              {{#unless secondWindPanel.canEdit}}disabled{{/unless}}>
        Reset Uses
      </button>
    </div>
  </div>
</section>
