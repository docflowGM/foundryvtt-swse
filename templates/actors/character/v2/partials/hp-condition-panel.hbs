<section class="swse-panel swse-panel--health hp-condition-panel v3-panel holo-panel {{healthPanel.stateClass}}">
  <div class="swse-panel__content">
    <header class="section-bar">
      <h3 class="section-header">Health &amp; Conditions</h3>
      <span class="hp-state-label {{healthPanel.stateClass}}">{{healthPanel.stateLabel}}</span>
    </header>

    <div class="hp-input-grid" data-swse-tooltip="HitPoints">
      <div class="hp-input-group">
        <label>Current HP</label>
        <input type="number"
               name="system.hp.value"
               value="{{healthPanel.hp.value}}"
               class="hp-current-input"
               data-resource-number="hp-current"
               min="0"
               {{#unless healthPanel.hp.canEdit}}disabled{{/unless}} />
      </div>

      <div class="hp-input-group">
        <label>Max HP</label>
        <input type="number"
               name="system.hp.max"
               value="{{healthPanel.hp.max}}"
               class="hp-max-input"
               min="1"
               {{#unless healthPanel.hp.canEdit}}disabled{{/unless}} />
      </div>

      <div class="hp-input-group">
        <label>Temporary HP</label>
        <input type="number"
               name="system.hp.temp"
               value="{{healthPanel.hp.temp}}"
               class="hp-temp-input"
               data-resource-number="hp-temp"
               min="0"
               {{#unless healthPanel.hp.canEdit}}disabled{{/unless}} />
      </div>

      <div class="hp-input-group hp-input-group--readonly" title="Shield Rating">
        <label>SR</label>
        <input type="number"
               value="{{healthPanel.shield.current}}"
               class="hp-sr-input"
               data-resource-number="shield-current"
               readonly
               disabled />
        <div class="hp-input-hint">{{healthPanel.shield.current}} / {{healthPanel.shield.max}}</div>
      </div>

      <div class="hp-input-group">
        <label>DR</label>
        <input type="number"
               name="system.damageReduction"
               value="{{healthPanel.damageReductionValue}}"
               class="hp-dr-input"
               min="0"
               {{#unless healthPanel.hp.canEdit}}disabled{{/unless}} />
      </div>
    </div>

    {{#if healthPanel.bonusHp.hasBonus}}
      <div class="bonus-hp-info">
        <span class="bonus-hp-label">Bonus HP: +{{healthPanel.bonusHp.value}}</span>
      </div>
    {{/if}}

    <div class="condition-standard-track" data-swse-tooltip="ConditionTrack">
      <div class="condition-standard-track__header">
        <span class="condition-standard-track__title">Condition Track</span>
        <span class="condition-standard-track__summary">Current: {{healthPanel.currentConditionPenalty.label}}</span>
      </div>

      <div class="condition-standard-track__rows">
        {{#each healthPanel.conditionSlots as |slot|}}
          <button type="button"
                  class="condition-track-row {{slot.severityClass}} {{#if slot.active}}active{{/if}}"
                  data-action="set-condition-step"
                  data-step="{{slot.step}}"
                  title="Set condition: {{slot.label}}"
                  {{#unless slot.canEdit}}disabled{{/unless}}>
            <span class="condition-track-row__badge">{{slot.label}}</span>
            <span class="condition-track-row__text">{{slot.description}}</span>
          </button>
        {{/each}}
      </div>
    </div>
  </div>
</section>
