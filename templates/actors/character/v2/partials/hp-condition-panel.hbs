
<section class="swse-panel swse-panel--health hp-condition-panel v3-panel holo-panel svg-framed svg-panel-frame {{healthPanel.stateClass}}">

  <!-- Frame layer: SVG background -->
  <div class="swse-panel__frame" aria-hidden="true"></div>

  <!-- Content layer: normal flow content -->
  <div class="swse-panel__content">
    <header class="section-bar">
      <h3 class="section-header">Health & Conditions</h3>
      <span class="hp-state-label {{healthPanel.stateClass}}">
        {{healthPanel.stateLabel}}
      </span>
    </header>

    <!-- HP BLOCK -->
    <div class="hp-section" data-swse-tooltip="HitPoints">
      <div class="hp-bar-wrapper {{healthPanel.hp.stateClass}}">
        <div class="hp-bar {{healthPanel.hp.stateClass}}">
          <div class="hp-bar__fill {{healthPanel.hp.stateClass}}" style="width: {{healthPanel.hp.percent}}%;"></div>
          <div class="hp-bar__label">
            <input type="number"
                   name="system.hp.value"
                   value="{{healthPanel.hp.value}}"
                   class="hp-current-input"
                   min="0"
                   placeholder="0"
                   {{#unless healthPanel.hp.canEdit}}disabled{{/unless}} />
            <span class="hp-separator">/</span>
            <input type="number"
                   name="system.hp.max"
                   value="{{healthPanel.hp.max}}"
                   class="hp-max-input"
                   min="1"
                   placeholder="1"
                   {{#unless healthPanel.hp.canEdit}}disabled{{/unless}} />
          </div>
        </div>
      </div>
      {{#if healthPanel.bonusHp.hasBonus}}
        <div class="bonus-hp-info">
          <span class="bonus-hp-label">+{{healthPanel.bonusHp.value}} bonus</span>
        </div>
      {{/if}}
    </div>

    {{!-- Shield Display --}}
    {{#if healthPanel.showShield}}
      <div class="survivability-stat" title="Shield Rating">
        <div class="stat-label">Shield</div>
        <div class="stat-value">{{healthPanel.shield.rating}}</div>
      </div>
    {{/if}}

    {{!-- Damage Reduction Display --}}
    {{#if healthPanel.showDamageReduction}}
      <div class="survivability-stat" title="Damage Reduction reduces incoming damage before other defenses">
        <div class="stat-label">DR</div>
        <div class="stat-value">{{healthPanel.damageReduction}}</div>
      </div>
    {{/if}}

    <!-- CONDITION TRACK BLOCK (with overlay for positioned sockets) -->
    {{#if healthPanel.showConditionTrack}}
    <div class="condition-section" data-swse-tooltip="ConditionTrack">
      <div class="swse-panel swse-panel--condition-track condition-track-panel">
        <div class="swse-panel__frame condition-track-frame" aria-hidden="true"></div>
        <div class="swse-panel__overlay condition-track-overlay">
          {{#each healthPanel.conditionSlots as |slot|}}
            <button type="button"
                    class="condition-slot condition-slot-{{slot.step}} {{#if slot.active}}active{{/if}}"
                    data-action="set-condition-step"
                    data-step="{{slot.step}}"
                    title="Set condition: {{slot.label}}"
                    aria-label="Condition level {{slot.step}}: {{slot.label}}"
                    {{#unless slot.canEdit}}disabled{{/unless}}>
              <span class="condition-level">{{slot.step}}</span>
            </button>
          {{/each}}
        </div>
      </div>
      <div class="condition-status-row">
        <span class="condition-status-label">Condition Track:</span>
        <span class="condition-status-value">{{healthPanel.conditionTrack.current}} / {{healthPanel.conditionTrack.max}}</span>
      </div>
    </div>
    {{/if}}
  </div>

</section>
