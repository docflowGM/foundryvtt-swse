
<section class="force-panel v3-panel holo-panel swse-ui-panel swse-force-suite">

  <header class="section-bar force-controls">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.ForceSuite"}}</h3>

    <div class="force-filter-bar swse-control-cluster">
      {{#if lightsaberConstructionAvailable}}
        <button type="button" class="force-tag-filter construct-lightsaber-btn" data-action="construct-lightsaber">
          {{#if lightsaberConstructionDeferred}}{{localize "SWSE.CharacterSheet.Actions.ConstructLightsaber"}}{{else}}{{localize "SWSE.CharacterSheet.Status.LightsaberConstructionAvailable"}}{{/if}}
        </button>
      {{/if}}
      <select data-action="force-sort">
        <option value="name">{{localize "SWSE.CharacterSheet.Labels.SortName"}}</option>
        <option value="tag">{{localize "SWSE.CharacterSheet.Labels.SortTag"}}</option>
      </select>

      <div class="force-tag-filters">
        {{#each forceTags as |tag|}}
          <button type="button"
                  class="force-tag-filter" data-action="force-tag-filter" data-tag="{{tag}}">
            {{tag}}
          </button>
        {{/each}}
      </div>
    </div>
  </header>

  <div class="force-zone swse-ui-panel hand-zone {{#if lowHand}}low-hand{{/if}}">
    <div class="zone-label">
      {{localize "SWSE.CharacterSheet.Labels.Hand"}} ({{forceSuite.hand.length}})
    </div>

    <div class="force-card-grid swse-dense-grid">
      {{#each forceSuite.hand as |power|}}
        <div class="force-card swse-dense-card swse-ui-panel"
             data-item-id="{{power.id}}"
             data-tags="{{power.tagString}}">

          <div class="force-card-inner">

            <div class="force-card-face front swse-card-face">
              <div class="force-card-header">
                <span class="force-name">{{power.name}}</span>
              </div>

              <div class="force-tags">
                {{#if power.tags}}
                  {{#each power.tags}}
                    <span class="tag">{{this}}</span>
                  {{/each}}
                {{/if}}
              </div>

              <div class="flip-indicator">
                {{localize "SWSE.CharacterSheet.Actions.FlipForMore"}} ⟳
              </div>
            </div>

            <div class="force-card-face back swse-card-face">

              <div class="force-back-content">
                {{#if power.system}}
                  {{{power.system.description}}}
                {{/if}}
              </div>

              <div class="force-back-actions">
                <button type="button" data-action="activate-force"
                        data-item-id="{{power.id}}"
>
                  {{localize "SWSE.CharacterSheet.Actions.Activate"}}
                </button>
                <button type="button" class="flip-back">
                  ↺ {{localize "SWSE.CharacterSheet.Actions.Back"}}
                </button>
              </div>

            </div>

          </div>
        </div>
      {{/each}}
    </div>
  </div>

  <div class="force-zone swse-ui-panel discard-zone">
    <div class="zone-label">
      {{localize "SWSE.CharacterSheet.Labels.Discard"}} ({{forceSuite.discard.length}})
    </div>

    <div class="force-card-grid discard swse-dense-grid">
      {{#each forceSuite.discard as |power|}}
        <div class="force-card discarded">
          <div class="force-card-face front swse-card-face">
            <span>{{power.name}}</span>
          </div>
        </div>
      {{/each}}
    </div>
  </div>

</section>
