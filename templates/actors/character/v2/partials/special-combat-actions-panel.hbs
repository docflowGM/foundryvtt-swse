<section class="swse-panel swse-panel--combat-actions special-combat-actions-panel holo-panel svg-framed svg-panel-frame">

  <!-- Frame layer: SVG background -->
  <div class="swse-panel__frame" aria-hidden="true"></div>

  <!-- Content layer: normal flow content -->
  <div class="swse-panel__content">
    <header class="section-bar">
      <h3 class="section-header">Special Combat Actions & Notes</h3>
      <div class="muted section-eyebrow" style="opacity:0.75; font-size:0.8rem;">Tactical reminders, house rules, and special procedures</div>
    </header>

    <div class="combat-notes-container">
      <label for="combat-notes-textarea" class="sr-only">Special Combat Actions and Notes</label>
      <textarea
        id="combat-notes-textarea"
        name="flags.swse.sheetNotes.specialCombatActions"
        class="combat-notes-textarea"
        placeholder="Examples: conditions, special maneuvers, house rules, action economy notes, target priorities...">{{combatNotesPanel.combatNotes}}</textarea>
    </div>

    <div class="combat-notes-hint" style="opacity:0.65; font-size:0.75rem; padding:6px 0; margin-top:4px; border-top:1px solid rgba(0,255,136,0.1);">
      💡 Use for: condition reminders, special maneuver notes, house rules, tactics, action economy rules, cover rules, action sequences
    </div>
  </div>

</section>
