{{!--
  Force Powers Known Ledger (Record-Sheet Style)

  This is a compact reference surface for known Force powers in a scannable ledger.
  It is NOT a replacement for force-panel.hbs; it is a presentation layer for
  quick reference during play.

  CLARITY NOTE:
  - "Hand" = currently available/known powers
  - "Discard" = powers in discard (house-rule dependent mechanic)
  Both are shown separately for clarity about game state.

  Source: forceSuite.hand (all known available powers) + forceSuite.discard
--}}

<section class="force-powers-known-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">{{localize "SWSE.CharacterSheet.Sections.ForcePowersKnown"}}</h3>
    <button type="button" class="btn-small" data-action="tab" data-tab="force" data-group="primary" data-tab-group="primary" title='{{localize "SWSE.CharacterSheet.Tooltips.OpenForceTab"}}'>{{localize "SWSE.CharacterSheet.Actions.ManageArrow"}}</button>
  </header>

  {{#if (or forcePowersPanel.hasHand forcePowersPanel.hasDiscard)}}
    <div class="force-powers-ledger">

      {{#if forcePowersPanel.hasHand}}
      <div class="powers-group">
        <div class="group-header">{{localize "SWSE.CharacterSheet.Labels.Available"}} ({{forcePowersPanel.hand.length}})</div>
        {{#each forcePowersPanel.hand}}
          <div class="power-row svg-row-backed" data-item-id="{{this.id}}">
            <div class="power-name">{{this.name}}</div>
            {{#if this.system.tags}}
              <div class="power-tags">
                {{#each this.system.tags}}<span class="tag">{{this}}</span>{{/each}}
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
      {{/if}}

      {{#if forcePowersPanel.hasDiscard}}
      <div class="powers-group">
        <div class="group-header">{{localize "SWSE.CharacterSheet.Labels.Discarded"}} ({{forcePowersPanel.discard.length}})</div>
        {{#each forcePowersPanel.discard}}
          <div class="power-row discarded svg-row-backed" data-item-id="{{this.id}}">
            <div class="power-name">{{this.name}}</div>
            {{#if this.system.tags}}
              <div class="power-tags">
                {{#each this.system.tags}}<span class="tag">{{this}}</span>{{/each}}
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
      {{/if}}

    </div>
  {{else}}
    <div class="empty-state">
      <p>{{localize "SWSE.CharacterSheet.Empty.NoForcePowers"}}</p>
      <p class="hint">{{localize "SWSE.CharacterSheet.Hints.ManageForcePowers"}}</p>
    </div>
  {{/if}}

</section>
