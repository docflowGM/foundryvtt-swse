{{!-- SWSE V2 Combat Actions Panel — grouped by action economy, display-only availability from ActionEngine. --}}

<section class="swse-combat-actions-panel v3-panel holo-panel">
  <header class="section-bar swse-combat-actions-header">
    <div>
      <h3 class="section-header">Combat Actions</h3>
      <span class="swse-combat-actions-subtitle">Grouped by action cost. Spending still routes through the canonical action executor.</span>
    </div>
    <div class="combat-actions-controls">
      <input type="text"
             class="combat-actions-search"
             placeholder="Search actions..."
             aria-label="Filter combat actions"
             data-action="filter-combat-actions" />
      <select class="combat-actions-sort"
              data-action="sort-combat-actions"
              aria-label="Sort combat actions">
        <option value="economy">Economy</option>
        <option value="name">Name</option>
      </select>
    </div>
  </header>

  <div class="combat-actions-content">
    {{#if combatActions.groups.length}}
      {{#each combatActions.groups as |group|}}
        <div class="combat-action-group {{group.cssClass}}" data-economy="{{group.economy}}">
          <div class="combat-action-group-header">
            <span class="group-label">
              {{#if (eq group.economy "full-round")}}⟲ Full-Round{{/if}}
              {{#if (eq group.economy "standard")}}⬤ Standard{{/if}}
              {{#if (eq group.economy "move")}}▶ Move{{/if}}
              {{#if (eq group.economy "swift")}}⚡ Swift{{/if}}
              {{#if (eq group.economy "free")}}∞ Free{{/if}}
              {{#if (eq group.economy "reaction")}}↩ Reaction{{/if}}
            </span>
            <span class="group-meta"><span>{{group.count}}</span><span>{{group.availabilityLabel}}</span></span>
          </div>

          <div class="combat-action-list">
            {{#each group.actions as |action|}}
              <div class="combat-action-row {{#if action.disabled}}is-disabled{{/if}}" data-action-id="{{action.id}}" data-action-key="{{action.key}}">
                <div class="action-main">
                  <div class="action-name-section">
                    <span class="action-name">{{action.name}}</span>
                    <span class="action-cost-badge">{{action.type}}</span>
                    {{#if action.disabled}}<span class="action-state-badge">{{action.availabilityLabel}}</span>{{/if}}
                  </div>
                  {{#if action.notes}}
                    <div class="action-notes">{{action.notes}}</div>
                  {{/if}}
                </div>

                <div class="action-affordance">
                  {{#if action.executable}}
                    <button type="button"
                            class="combat-action-roll-btn"
                            data-action="swse-v2-use-action"
                            data-action-id="{{action.id}}"
                            {{#if action.disabled}}disabled{{/if}}
                            title="{{action.useLabel}}">
                      {{action.useLabel}}
                    </button>
                  {{else}}
                    <span class="combat-action-reference" title="Reference action">Ref</span>
                  {{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      {{/each}}
    {{else}}
      <div class="swse-ui-empty">
        <span class="swse-card-schema__title">No Combat Actions</span>
        <span class="swse-card-schema__body">Combat action data not loaded.</span>
      </div>
    {{/if}}
  </div>
</section>
