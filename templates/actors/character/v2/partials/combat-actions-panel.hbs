{{!-- =========================================== --}}
{{!-- SWSE V2 COMBAT ACTIONS PANEL --}}
{{!-- Displays action-economy-categorized combat actions --}}
{{!-- =========================================== --}}

<section class="swse-combat-actions-panel v3-panel holo-panel">
  <header class="section-bar">
    <h3 class="section-header">Combat Actions</h3>
    <div class="combat-actions-controls">
      <input type="text"
             class="combat-actions-search"
             placeholder="Search actions..."
             aria-label="Filter combat actions"
             data-action="filter-combat-actions" />
      <select class="combat-actions-sort"
              data-action="sort-combat-actions"
              aria-label="Sort combat actions">
        <option value="economy">Sort: By Economy</option>
        <option value="name">Sort: By Name</option>
      </select>
    </div>
  </header>

  <div class="combat-actions-content">
    {{#if combatActions.groups.length}}
      {{#each combatActions.groups as |group|}}
        <div class="combat-action-group" data-economy="{{group.economy}}">
          <div class="combat-action-group-header">
            <span class="group-label">
              {{#if (eq group.economy "full-round")}}⟲ Full Round{{/if}}
              {{#if (eq group.economy "standard")}}⬤ Standard{{/if}}
              {{#if (eq group.economy "move")}}▶ Move{{/if}}
              {{#if (eq group.economy "swift")}}⚡ Swift{{/if}}
              {{#if (eq group.economy "free")}}∞ Free{{/if}}
              {{#if (eq group.economy "reaction")}}↩ Reaction{{/if}}
            </span>
            <span class="group-count">{{group.count}}</span>
          </div>

          <div class="combat-action-list">
            {{#each group.actions as |action|}}
              <div class="combat-action-row" data-action-id="{{action.id}}">
                <div class="action-main">
                  <div class="action-name-section">
                    <span class="action-name">{{action.name}}</span>
                    {{#if action.cost}}
                      <span class="action-cost-badge">
                        {{#if (eq action.type "swift")}}
                          {{action.cost}}/turn
                        {{else}}
                          {{action.cost}}
                        {{/if}}
                      </span>
                    {{/if}}
                  </div>
                  {{#if action.notes}}
                    <div class="action-notes">{{action.notes}}</div>
                  {{/if}}
                </div>

                <div class="action-affordance">
                  {{#if action.hasRelatedSkills}}
                    <button type="button"
                            class="combat-action-roll-btn"
                            data-action="roll-combat-action"
                            data-action-id="{{action.id}}"
                            title="Roll related skill check">
                      Roll
                    </button>
                  {{else}}
                    <span class="combat-action-reference" title="Reference action">Ref</span>
                  {{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      {{/each}}
    {{else}}
      <div class="swse-ui-empty">
        <span class="swse-card-schema__title">No Combat Actions</span>
        <span class="swse-card-schema__body">Combat action data not loaded</span>
      </div>
    {{/if}}
  </div>
</section>

<style>
.swse-combat-actions-panel {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.combat-actions-controls {
  display: flex;
  gap: 6px;
  align-items: center;
}

.combat-actions-search {
  flex: 1;
  padding: 6px 10px;
  font-size: 0.9rem;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(124, 232, 255, 0.3);
  color: #f0faff;
  border-radius: 3px;
}

.combat-actions-search::placeholder {
  color: rgba(240, 250, 255, 0.5);
}

.combat-actions-sort {
  padding: 6px 8px;
  font-size: 0.9rem;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(124, 232, 255, 0.3);
  color: #f0faff;
  border-radius: 3px;
  cursor: pointer;
}

.combat-actions-content {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-height: 500px;
  overflow-y: auto;
  padding: 8px;
}

.combat-action-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 8px;
  background: rgba(0, 0, 0, 0.2);
  border-left: 3px solid rgba(124, 232, 255, 0.4);
  border-radius: 3px;
}

.combat-action-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: 700;
  font-size: 0.95rem;
  color: #7ce8ff;
  padding-bottom: 4px;
  border-bottom: 1px solid rgba(124, 232, 255, 0.2);
}

.group-label {
  display: flex;
  align-items: center;
  gap: 6px;
}

.group-count {
  font-size: 0.85rem;
  opacity: 0.7;
}

.combat-action-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.combat-action-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
  padding: 6px 8px;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 3px;
  border-left: 2px solid rgba(124, 232, 255, 0.3);
}

.action-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.action-name-section {
  display: flex;
  align-items: center;
  gap: 8px;
}

.action-name {
  font-weight: 600;
  color: #fff;
  font-size: 0.95rem;
}

.action-cost-badge {
  display: inline-block;
  padding: 2px 6px;
  background: rgba(124, 232, 255, 0.15);
  border: 1px solid rgba(124, 232, 255, 0.4);
  border-radius: 2px;
  font-size: 0.75rem;
  color: #b7f4ff;
  font-weight: 500;
}

.action-notes {
  font-size: 0.85rem;
  color: rgba(240, 250, 255, 0.7);
  line-height: 1.3;
  padding: 4px 0;
}

.action-affordance {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.combat-action-roll-btn {
  padding: 4px 10px;
  background: rgba(124, 232, 255, 0.2);
  border: 1px solid rgba(124, 232, 255, 0.4);
  color: #b7f4ff;
  font-size: 0.85rem;
  font-weight: 600;
  border-radius: 3px;
  cursor: pointer;
  transition: all 0.15s ease;
}

.combat-action-roll-btn:hover {
  background: rgba(124, 232, 255, 0.35);
  border-color: rgba(124, 232, 255, 0.6);
  box-shadow: 0 0 8px rgba(124, 232, 255, 0.2);
}

.combat-action-reference {
  padding: 4px 8px;
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(124, 232, 255, 0.2);
  color: rgba(240, 250, 255, 0.5);
  font-size: 0.8rem;
  border-radius: 2px;
}

.swse-ui-empty {
  padding: 16px;
  text-align: center;
  color: rgba(240, 250, 255, 0.5);
}
</style>
