<div class="swse-inventory inventory-card-layout">

  {{#if inventoryPanel.hasEntries}}

    {{#each inventoryPanel.grouped as |items group|}}

      <div class="inventory-group">

        <div class="inventory-group-header">
          <span class="inventory-group-title">{{group}}</span>
          <div class="inventory-group-actions">
            {{#if (eq (lowercase group) "weapons")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="weapon">Add Weapon</button>{{/if}}
            {{#if (eq (lowercase group) "armor")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="armor">Add Armor</button><button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="shield">Add Shield</button>{{/if}}
            {{#if (eq (lowercase group) "equipment")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="equipment">Add Gear</button>{{/if}}
            {{#if (eq (lowercase group) "consumables")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="equipment">Add Consumable</button>{{/if}}
          </div>
        </div>

        {{#if items.length}}
        <div class="inventory-group-body inventory-rows">

          {{#each items}}
            {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/inventory-item-row.hbs" this}}
          {{/each}}

        </div>
        {{/if}}

      </div>

    {{/each}}

  {{else}}

    <div class="inventory-empty-state">
      <p>{{inventoryPanel.emptyMessage}}</p>
      <div class="inventory-empty-actions">
        <button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="weapon">Add Weapon</button>
        <button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="armor">Add Armor</button>
        <button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="equipment">Add Gear</button>
      </div>
    </div>

  {{/if}}

</div>

<style>
.swse-inventory.inventory-card-layout {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.inventory-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.inventory-group-header {
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:8px;
  font-weight: bold;
  font-size: 13px;
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 8px 0;
  border-bottom: 2px solid #444;
}

.inventory-group-actions { display:flex; flex-wrap:wrap; gap:6px; }
.inventory-add-btn { font-size:11px; padding:4px 8px; }
.inventory-empty-actions { display:flex; flex-wrap:wrap; gap:8px; margin-top:10px; }
.inventory-rows {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
</style>
