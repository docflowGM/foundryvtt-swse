<div class="swse-inventory inventory-card-layout">

  {{!-- Credits Box --}}
  <div class="credits-box">
    <label class="credits-label" for="swse-sheet-credits-input">Credits</label>
    <div class="credits-value credits-value--editable">
      <input
        id="swse-sheet-credits-input"
        class="credits-input"
        type="number"
        name="system.credits"
        value="{{actor.system.credits}}"
        min="0"
        step="1"
        inputmode="numeric"
      >
      <span class="credits-symbol">$</span>
    </div>
    {{#if inventoryPanel.hasUpgradeableItems}}
    <button type="button"
            class="upgrade-workshop-launch"
            data-action="open-upgrade-workshop"
            title="Open Upgrade Workshop">
      <i class="fas fa-tools"></i> Upgrade Workshop
    </button>
    {{else}}
    <button type="button"
            class="upgrade-workshop-launch"
            data-action="open-upgrade-workshop"
            disabled
            title="No upgradeable items">
      <i class="fas fa-tools"></i> Upgrades
    </button>
    {{/if}}
  </div>

  {{#if inventoryPanel.hasEntries}}

    {{#each inventoryPanel.grouped as |items group|}}

      <div class="inventory-group">

        <div class="inventory-group-header">
          <span class="inventory-group-title">{{group}}</span>
          <div class="inventory-group-actions">
            {{#if (eq (lowercase group) "weapons")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="weapon">Add Weapon</button>{{/if}}
            {{#if (eq (lowercase group) "armor")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="armor">Add Armor</button><button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="shield">Add Shield</button>{{/if}}
            {{#if (eq (lowercase group) "equipment")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="equipment">Add Gear</button>{{/if}}
            {{#if (eq (lowercase group) "consumables")}}<button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="equipment">Add Consumable</button>{{/if}}
          </div>
        </div>

        {{#if items.length}}
        <div class="inventory-group-body inventory-rows v2-gear-list">

          {{#each items}}
            {{> "systems/foundryvtt-swse/templates/actors/character/v2/partials/inventory-item-row.hbs" this}}
          {{/each}}

        </div>
        {{/if}}

      </div>

    {{/each}}

  {{else}}

    <div class="inventory-empty-state">
      <p>{{inventoryPanel.emptyMessage}}</p>
      <div class="inventory-empty-actions">
        <button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="weapon">Add Weapon</button>
        <button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="armor">Add Armor</button>
        <button type="button" class="inventory-add-btn" data-action="add-item" data-item-type="equipment">Add Gear</button>
      </div>
    </div>

  {{/if}}

</div>

<style>
.swse-inventory.inventory-card-layout {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.inventory-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.inventory-group-header {
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:8px;
  font-weight: bold;
  font-size: 13px;
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 8px 0;
  border-bottom: 2px solid #444;
}

.inventory-group-actions { display:flex; flex-wrap:wrap; gap:6px; }
.inventory-add-btn { font-size:11px; padding:4px 8px; }
.inventory-empty-actions { display:flex; flex-wrap:wrap; gap:8px; margin-top:10px; }
.inventory-rows {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.credits-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(20, 50, 80, 0.6), rgba(10, 30, 50, 0.6));
  border: 2px solid #0cf;
  border-radius: 6px;
  padding: 12px 16px;
  margin-bottom: 16px;
  box-shadow: inset 0 0 8px rgba(0, 204, 255, 0.1);
}

.credits-label {
  font-size: 12px;
  font-weight: bold;
  text-transform: uppercase;
  color: #0cf;
  letter-spacing: 1px;
}

.credits-value {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 20px;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 0 8px rgba(0, 204, 255, 0.5);
}

.credits-value--editable {
  justify-content: flex-end;
}

.credits-input {
  width: 120px;
  padding: 6px 8px;
  border: 1px solid rgba(0, 204, 255, 0.45);
  border-radius: 4px;
  background: rgba(3, 16, 28, 0.9);
  color: #fff;
  font-size: 18px;
  font-weight: bold;
  text-align: right;
  box-shadow: inset 0 0 6px rgba(0, 204, 255, 0.12);
}

.credits-input:focus {
  outline: none;
  border-color: #0cf;
  box-shadow: 0 0 0 1px rgba(0, 204, 255, 0.45), inset 0 0 6px rgba(0, 204, 255, 0.16);
}

.credits-symbol {
  font-family: "Aurabesh";
  font-size: 24px;
  color: #0f0;
  text-shadow: 0 0 10px rgba(0, 255, 0, 0.6);
}
</style>
