<section class="force-techniques-panel holo-panel">

  <header class="section-bar">
    <h3 class="section-header">Force Techniques ({{forcePowersPanel.techniques.length}})</h3>
  </header>

  {{#if forcePowersPanel.hasTechniques}}
    <div class="force-techniques-ledger">
      {{#each forcePowersPanel.techniques}}
        <div class="technique-row svg-row-backed" data-item-id="{{this.id}}">
          <div class="technique-name">{{this.name}}</div>
          {{#if this.system.prerequisite}}
            <div class="technique-prereq muted">Requires: {{this.system.prerequisite}}</div>
          {{/if}}
          {{#if this.system.summary}}
            <div class="technique-summary muted">{{this.system.summary}}</div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>No Force techniques known.</p>
    </div>
  {{/if}}

</section>
