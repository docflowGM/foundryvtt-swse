<div class="swse-concept-dashboard">
  <div class="swse-concept-card-grid swse-concept-card-grid--skills-top">
    {{#each conceptLayout.skills.summaryCards as |card|}}
      <article class="swse-concept-info-card swse-concept-info-card--stat">
        <span>{{card.label}}</span>
        <strong>{{card.value}}</strong>
      </article>
    {{/each}}
  </div>

  <section class="swse-concept-panel swse-concept-panel--ledger skills-panel">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Skill Ledger</h3>
        <p class="swse-concept-panel__hint">Full skill matrix with sorting, favorites, training state, and expandable special uses.</p>
      </div>
    </header>

    <div class="swse-concept-segmented swse-concept-segmented--skills" role="group" aria-label="Skill quick filters">
      <button type="button" class="swse-concept-segmented__button is-active" data-action="set-skills-filter" data-filter="all">All</button>
      <button type="button" class="swse-concept-segmented__button" data-action="set-skills-filter" data-filter="trained">Trained</button>
      <button type="button" class="swse-concept-segmented__button" data-action="set-skills-filter" data-filter="custom">Custom</button>
    </div>

    <div class="skills-tools-row swse-concept-skills-tools">
      <div class="swse-concept-toolfield">
        <label for="concept-skills-filter-select">Filter</label>
        <select id="concept-skills-filter-select" data-action="filter-skills">
          <option value="all">All Skills</option>
          <option value="trained">Trained</option>
          <option value="favorited">Favorited</option>
          <option value="focused">Focused</option>
          <option value="custom">Custom</option>
        </select>
      </div>
      <div class="swse-concept-toolfield">
        <label for="concept-skills-sort-select">Sort</label>
        <select id="concept-skills-sort-select" data-action="sort-skills">
          <option value="name">Name A→Z</option>
          <option value="ability">Ability</option>
          <option value="total-desc">Highest Total</option>
          <option value="total-asc">Lowest Total</option>
        </select>
      </div>
      <button type="button" class="swse-concept-btn" data-action="reset-skills-tools">Reset Filters</button>
    </div>

    <div class="swse-concept-chip-row swse-concept-chip-row--skills">
      {{#each conceptLayout.skills.highlights as |skill|}}
        <span class="swse-concept-chip swse-concept-chip--neutral">{{skill.label}} {{numberFormat skill.total decimals=0 sign=true}}</span>
      {{/each}}
    </div>

    <div class="skills-list swse-concept-skills-list">
      {{#each conceptLayout.skills.entries as |skill|}}
        <article class="skill-row-container swse-concept-skill-row {{skill.abilityAccentClass}} swse-concept-skill-row--{{skill.selectedAbility}}"
                 data-skill="{{skill.key}}"
                 data-label="{{skill.label}}"
                 data-name="{{skill.key}}"
                 data-total="{{skill.total}}"
                 data-trained="{{#if skill.trained}}true{{else}}false{{/if}}"
                 data-favorite="{{#if skill.favorite}}true{{else}}false{{/if}}"
                 data-focused="{{#if skill.focused}}true{{else}}false{{/if}}"
                 data-ability="{{skill.selectedAbility}}"
                 data-swse-tooltip="{{skill.tooltipKey}}">
          <div class="swse-concept-skill-row__identity">
            <button type="button"
                    class="favorite-btn swse-concept-favorite {{#if skill.favorite}}favorited{{/if}}"
                    data-action="toggle-favorite"
                    data-skill="{{skill.key}}"
                    title="Toggle favorite">
              ★
            </button>

            <div class="swse-concept-skill-row__copy">
              <div class="swse-concept-skill-row__titleline">
                {{#if skill.hasExtraUses}}
                  <button type="button"
                          class="skill-expand-toggle swse-concept-expand-toggle {{#if (gte skill.extraUsesCount 3)}}skill-expand-toggle--many{{/if}}"
                          data-action="toggle-skill-expand"
                          data-skill="{{skill.key}}"
                          aria-expanded="false"
                          title="Expand extra uses">
                    {{#if (gte skill.extraUsesCount 3)}}
                      <span class="expand-count">{{skill.extraUsesCount}}</span>
                    {{else}}
                      ▶
                    {{/if}}
                  </button>
                {{/if}}

                <button type="button"
                        class="skill-name-btn rollable swse-concept-skill-name"
                        data-skill="{{skill.key}}"
                        data-mod-dialog="true"
                        title="Roll {{skill.label}}">
                  {{skill.label}}
                </button>
              </div>

              <div class="swse-concept-ledger-row__meta">
                <span class="swse-concept-skill-ability-chip {{skill.abilityAccentClass}}">{{skill.selectedAbilityLabel}}</span>
                {{#if skill.trained}}<span>Trained</span>{{/if}}
                {{#if skill.focused}}<span>Focused</span>{{/if}}
                {{#if skill.favorite}}<span>Favorite</span>{{/if}}
                {{#if skill.hasExtraUses}}<span>{{skill.extraUsesCount}} uses</span>{{/if}}
              </div>
            </div>
          </div>

          <div class="swse-concept-skill-row__math swse-edit-reveal">
            <label class="swse-concept-toolfield swse-concept-toolfield--compact">
              <span>Ability</span>
              <select name="system.skills.{{skill.key}}.selectedAbility" class="ability-select ability-select--{{skill.selectedAbility}} {{skill.abilityAccentClass}}">
                {{#each skill.abilityChoices as |ab|}}
                  <option value="{{ab.key}}" {{#if (eq ab.key skill.selectedAbility)}}selected{{/if}}>{{ab.label}}</option>
                {{/each}}
              </select>
            </label>

            <div class="swse-concept-skill-stat">
              <span>Ability Mod</span>
              <strong class="{{skill.abilityModClass}}" title="{{skill.selectedAbilityLabel}} modifier">{{numberFormat skill.abilityMod decimals=0 sign=true}}</strong>
            </div>

            <div class="swse-concept-skill-stat">
              <span>½ Lvl</span>
              <strong class="{{skill.halfLevelClass}}" title="Half level contribution">{{numberFormat skill.halfLevel decimals=0 sign=true}}</strong>
            </div>

            <label class="swse-concept-checkpill">
              <input type="checkbox" name="system.skills.{{skill.key}}.trained" {{checked skill.trained}}>
              <span>Trained</span>
            </label>

            <label class="swse-concept-checkpill">
              <input type="checkbox" name="system.skills.{{skill.key}}.focused" {{checked skill.focused}}>
              <span>Focus</span>
            </label>

            <label class="swse-concept-toolfield swse-concept-toolfield--compact swse-concept-toolfield--number">
              <span>Misc</span>
              <input type="number"
                     class="misc-input {{skill.miscModClass}}"
                     name="system.skills.{{skill.key}}.miscMod"
                     value="{{skill.miscMod}}">
            </label>

            <div class="swse-concept-skill-stat swse-concept-skill-stat--total" title="{{skill.selectedAbilityLabel}} {{numberFormat skill.breakdown.abilityMod decimals=0 sign=true}} + ½ level {{numberFormat skill.breakdown.halfLevel decimals=0 sign=true}} + trained {{numberFormat skill.breakdown.trained decimals=0 sign=true}} + focus {{numberFormat skill.breakdown.focus decimals=0 sign=true}} + misc {{numberFormat skill.breakdown.misc decimals=0 sign=true}} + armor {{numberFormat skill.breakdown.armor decimals=0 sign=true}}">
              <span>Total</span>
              <strong class="{{skill.totalClass}}">{{numberFormat skill.total decimals=0 sign=true}}</strong>
            </div>

            <button type="button" class="swse-concept-btn skill-roll-btn" data-action="roll-skill" data-skill="{{skill.key}}">Roll</button>

            <div class="swse-concept-skill-breakdown" aria-label="{{skill.label}} breakdown">
              <span>{{skill.selectedAbilityLabel}} {{numberFormat skill.breakdown.abilityMod decimals=0 sign=true}}</span>
              <span>½ Lvl {{numberFormat skill.breakdown.halfLevel decimals=0 sign=true}}</span>
              {{#if skill.trained}}<span>Trained +5</span>{{/if}}
              {{#if skill.focused}}<span>Focus +5</span>{{/if}}
              <span>Misc {{numberFormat skill.breakdown.misc decimals=0 sign=true}}</span>
              {{#if skill.armorPenalty}}<span>Armor {{numberFormat skill.breakdown.armor decimals=0 sign=true}}</span>{{/if}}
            </div>
          </div>
        </article>

        {{#if skill.hasExtraUses}}
          <div class="skill-extra-uses skill-extra-uses--collapsed swse-concept-panel swse-concept-panel--subledger" data-skill="{{skill.key}}">
            <div class="extra-uses-filter-bar skill-extra-uses-hidden">
              <div class="filter-buttons">
                <button type="button" class="filter-btn filter-btn--active" data-filter="all">All</button>
                <button type="button" class="filter-btn" data-filter="available">Available</button>
                <button type="button" class="filter-btn" data-filter="combat">Combat</button>
              </div>
            </div>

            {{#each skill.extraUsesGrouped as |group|}}
              <section class="extra-use-group" data-group="{{group.label}}">
                <div class="group-header">{{group.label}}</div>
                {{#each group.entries as |use|}}
                  <article class="extra-use-row {{#if use.isBlocked}}use-blocked{{/if}}" data-use-key="{{use.key}}" data-category="{{use.category}}">
                    <div class="extra-use-copy">
                      <div class="use-label-line">
                        <span class="extra-use-label">{{use.label}}</span>
                        {{#if use.isBlocked}}
                          <span class="use-status use-status--blocked">Locked</span>
                        {{else if (and use.requiresTrained use.skillTrained)}}
                          <span class="use-status use-status--trained">Trained</span>
                        {{/if}}
                      </div>
                      {{#if use.description}}
                        <span class="extra-use-description">{{use.description}}</span>
                      {{/if}}
                    </div>

                    <div class="extra-use-meta">
                      {{#if use.dc}}<span class="extra-use-dc">DC {{use.dc}}</span>{{/if}}
                      {{#if use.actionTypeLabel.label}}<span class="action-type-tag {{use.actionType}}">{{use.actionTypeLabel.icon}} {{use.actionTypeLabel.label}}</span>{{/if}}
                      {{#if use.timeLabel}}<span class="extra-use-time {{use.timeClass}}">{{use.timeLabel}}</span>{{/if}}
                    </div>

                    <div class="extra-use-action-right">
                      <button type="button"
                              class="swse-concept-btn {{#if use.isBlocked}}btn-disabled{{else}}swse-concept-btn--primary{{/if}}"
                              data-action="execute-extra-skill-use"
                              data-skill="{{../../key}}"
                              data-use="{{use.key}}"
                              data-key="{{use.key}}"
                              data-use-key="{{use.useKey}}"
                              data-blocked="{{#if use.isBlocked}}true{{else}}false{{/if}}"
                              data-action-type="{{use.actionType}}"
                              data-source-type="{{use.sourceType}}"
                              data-source-label="{{use.sourceLabel}}"
                              {{#if use.isBlocked}}disabled title="{{use.blockedReason}}"{{/if}}>
                        {{use.actionTypeLabel.action}}
                      </button>
                    </div>
                  </article>
                {{/each}}
              </section>
            {{/each}}
          </div>
        {{/if}}
      {{/each}}
    </div>
  </section>

  <section class="swse-concept-panel swse-concept-panel--ledger swse-concept-custom-skills">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Custom Skills</h3>
        <p class="swse-concept-panel__hint">Actor-local skills for house rules, backgrounds, professions, and narrative specialties.</p>
      </div>
      <button type="button" class="swse-concept-btn swse-concept-btn--primary swse-edit-only" data-action="add-custom-skill" title="Add a custom skill">Add Custom Skill</button>
    </header>

    {{#if conceptLayout.skills.customEntries.length}}
      <div class="swse-concept-ledger swse-concept-custom-skills__list">
        {{#each conceptLayout.skills.customEntries as |skill|}}
          <article class="swse-concept-ledger-row swse-concept-custom-skill-row {{skill.abilityAccentClass}}" data-custom-skill-id="{{skill.id}}">
            <div class="swse-concept-ledger-row__main">
              <label class="swse-concept-toolfield swse-concept-custom-skill-row__name">
                <span>Name</span>
                <input type="text" name="system.customSkills.{{skill.index}}.label" value="{{skill.label}}" placeholder="Custom skill name">
              </label>
              <div class="swse-concept-ledger-row__meta">
                <span class="swse-concept-skill-ability-chip {{skill.abilityAccentClass}}">{{skill.abilityLabel}}</span>
                {{#if skill.trained}}<span>Trained</span>{{/if}}
                {{#if skill.focused}}<span>Focused</span>{{/if}}
              </div>
            </div>

            <div class="swse-concept-custom-skill-row__controls swse-edit-reveal">
              <label class="swse-concept-toolfield swse-concept-toolfield--compact">
                <span>Ability</span>
                <select name="system.customSkills.{{skill.index}}.ability" class="ability-select ability-select--{{skill.ability}} {{skill.abilityAccentClass}}">
                  {{#each skill.abilityChoices as |ab|}}
                    <option value="{{ab.key}}" {{#if (eq ab.key skill.ability)}}selected{{/if}}>{{ab.label}}</option>
                  {{/each}}
                </select>
              </label>

              <label class="swse-concept-checkpill">
                <input type="checkbox" name="system.customSkills.{{skill.index}}.trained" {{checked skill.trained}}>
                <span>Trained</span>
              </label>

              <label class="swse-concept-checkpill">
                <input type="checkbox" name="system.customSkills.{{skill.index}}.focused" {{checked skill.focused}}>
                <span>Focus</span>
              </label>

              <label class="swse-concept-toolfield swse-concept-toolfield--compact swse-concept-toolfield--number">
                <span>Misc</span>
                <input type="number" name="system.customSkills.{{skill.index}}.miscMod" value="{{skill.miscMod}}">
              </label>
            </div>

            <div class="swse-concept-ledger-row__stats">
              <div>
                <span>Ability</span>
                <strong>{{numberFormat skill.abilityMod decimals=0 sign=true}}</strong>
              </div>
              <div>
                <span>½ Lvl</span>
                <strong>{{numberFormat skill.halfLevel decimals=0 sign=true}}</strong>
              </div>
              <div>
                <span>Total</span>
                <strong class="{{skill.totalClass}}">{{numberFormat skill.total decimals=0 sign=true}}</strong>
              </div>
            </div>

            <div class="swse-concept-custom-skill-row__notes swse-edit-reveal">
              <label class="swse-concept-toolfield">
                <span>Notes</span>
                <textarea name="system.customSkills.{{skill.index}}.notes" placeholder="Optional notes">{{skill.notes}}</textarea>
              </label>
            </div>

            <div class="swse-concept-ledger-row__actions">
              <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-custom-skill" data-custom-skill-id="{{skill.id}}">Roll</button>
              <button type="button" class="swse-concept-btn swse-concept-btn--danger swse-edit-only" data-action="delete-custom-skill" data-custom-skill-id="{{skill.id}}">Delete</button>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="swse-concept-empty-state swse-concept-empty-state--guided">
        <span class="swse-concept-empty-state__eyebrow">No custom skills yet</span>
        <strong>Custom skills are useful for campaign-specific checks, professions, and house rules.</strong>
        <button type="button" class="swse-concept-btn swse-concept-btn--primary swse-edit-only" data-action="add-custom-skill">Add Custom Skill</button>
      </div>
    {{/if}}
  </section>
</div>
