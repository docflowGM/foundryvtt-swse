<div class="swse-concept-dashboard">
  <section class="swse-concept-panel swse-concept-panel--hero">
    <div class="swse-concept-hero">
      <div class="swse-concept-hero__copy">
        <span class="swse-concept-empty-state__eyebrow">Mission Profile</span>
        <h3 class="swse-concept-hero__title">Live Dossier Brief</h3>
        <p class="swse-concept-hero__body">{{conceptLayout.summary.missionBrief}}</p>

        <div class="swse-concept-chip-row">
          {{#each conceptLayout.summary.dossierTags as |tag|}}
            <span class="swse-concept-chip swse-concept-chip--{{tag.tone}}">{{tag.label}}</span>
          {{/each}}
        </div>
      </div>

      <div class="swse-concept-hero__rail">
        <div class="swse-concept-hero-status">
          <span>Status</span>
          <strong class="{{conceptLayout.summary.readinessClass}}">{{conceptLayout.summary.readinessLabel}}</strong>
          <p>{{conceptLayout.summary.readinessNote}}</p>
        </div>

        <div class="swse-concept-card-grid swse-concept-card-grid--summary-hero">
          {{#each conceptLayout.summary.heroMetrics as |metric|}}
            <article class="swse-concept-info-card swse-concept-info-card--stat">
              <span>{{metric.label}}</span>
              <strong class="{{metric.valueClass}}">{{metric.value}}</strong>
            </article>
          {{/each}}
        </div>
      </div>
    </div>
  </section>

  <section class="swse-concept-panel swse-concept-panel--summary">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Dossier Summary</h3>
        <p class="swse-concept-panel__hint">At-a-glance operator profile and current status.</p>
      </div>
    </header>

    <div class="swse-concept-card-grid swse-concept-card-grid--summary">
      {{#each conceptLayout.summary.cards as |card|}}
        <article class="swse-concept-info-card">
          <span>{{card.label}}</span>
          <strong>{{card.value}}</strong>
        </article>
      {{/each}}
    </div>
  </section>

  <div class="swse-concept-grid swse-concept-grid--two">
    {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/xp-panel.hbs"}}

    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Credits Ledger</h3>
          <p class="swse-concept-panel__hint">Current credits and quick credit adjustments.</p>
        </div>
        <div class="swse-concept-ledger-row__actions">
          <span class="swse-concept-chip swse-concept-chip--neutral">{{numberFormat conceptLayout.gear.credits decimals=0}} cr</span>
        </div>
      </header>

      <div class="swse-concept-inline-adjuster swse-concept-inline-adjuster--credits">
        <label>
          <span>Set Credits</span>
          <input type="number" name="system.credits" value="{{conceptLayout.gear.credits}}" min="0" step="1" />
        </label>
        <label>
          <span>Add Credits</span>
          <input type="number" data-role="credits-add-amount" step="1" placeholder="0" />
        </label>
        <button type="button" class="swse-concept-btn" data-action="add-credits-to-actor">Add Credits</button>
      </div>
    </section>
  </div>



  <div class="swse-concept-grid swse-concept-grid--two swse-concept-summary-state-grid">
    <section class="swse-concept-panel swse-concept-panel--summary-effects">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Current Conditions &amp; Effects</h3>
          <p class="swse-concept-panel__hint">Full active-effect feed moved here from Combat so the Summary tab acts as the live status dossier.</p>
        </div>
        <span class="swse-concept-panel__eyebrow">Live Status</span>
      </header>

      {{#if healthPanel.currentConditions.hasCards}}
        {{> "systems/foundryvtt-swse/templates/actors/shared/partials/current-conditions-panel.hbs" currentConditions=healthPanel.currentConditions}}
      {{else}}
        <div class="swse-concept-empty-state swse-concept-empty-state--compact">
          <span class="swse-concept-empty-state__eyebrow">Clear</span>
          <strong>No active conditions or mechanical effects are currently impacting this actor.</strong>
        </div>
      {{/if}}


      <div class="swse-concept-subsection swse-concept-condition-track swse-concept-condition-track--summary" data-swse-tooltip="ConditionTrack">
        <div class="swse-concept-condition-track__header">
          <span class="swse-concept-subsection__label">Condition Track</span>
          <span class="swse-concept-condition-track__summary">Current: {{healthPanel.currentConditionPenalty.label}}</span>
        </div>
        <div class="swse-concept-chip-row swse-concept-chip-row--wrap">
          {{#each healthPanel.conditionSlots as |slot|}}
            <button type="button"
                    class="swse-concept-chip swse-concept-condition-chip {{slot.severityClass}} {{#if slot.active}}swse-concept-chip--warn is-current{{else}}swse-concept-chip--neutral{{/if}}"
                    data-action="set-condition-step"
                    data-step="{{slot.step}}"
                    title="{{slot.description}}"
                    {{#unless slot.canEdit}}disabled{{/unless}}>
              {{slot.label}}
            </button>
          {{/each}}
        </div>
        <label class="swse-concept-checkpill">
          <input type="checkbox"
                 name="system.conditionTrack.persistent"
                 data-action="toggle-condition-persistent"
                 {{#if healthPanel.conditionTrack.persistent}}checked{{/if}}
                 {{#unless healthPanel.conditionTrack.canEdit}}disabled{{/unless}}>
          <span>Persistent Condition</span>
        </label>
      </div>
    </section>

    {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/second-wind-panel.hbs"}}
  </div>

  <section class="swse-concept-panel">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Status Feed</h3>
        <p class="swse-concept-panel__hint">Persistent conditions, shields, XP awards, credit adjustments, and readiness markers.</p>
      </div>
    </header>

    <div class="swse-concept-chip-row">
      {{#each conceptLayout.summary.statusChips as |chip|}}
        <span class="swse-concept-chip swse-concept-chip--{{chip.tone}}">{{chip.label}}</span>
      {{/each}}
    </div>

    <div class="swse-concept-metric-row">
      {{#each conceptLayout.summary.quickReadouts as |metric|}}
        <div class="swse-concept-metric-card">
          <span>{{metric.label}}</span>
          <strong>{{metric.value}}</strong>
        </div>
      {{/each}}
    </div>

    {{#if conceptLayout.summary.statusFeedEntries.length}}
      <div class="swse-concept-status-feed">
        {{#each conceptLayout.summary.statusFeedEntries as |entry|}}
          <article class="swse-concept-status-feed__entry swse-concept-status-feed__entry--{{entry.tone}}">
            <strong>{{entry.label}}</strong>
            {{#if entry.detail}}<span>{{entry.detail}}</span>{{/if}}
            {{#if entry.value}}<em>{{entry.value}}</em>{{/if}}
          </article>
        {{/each}}
      </div>
    {{/if}}
  </section>

  <section class="swse-concept-panel swse-concept-panel--summary-audit" data-sheet-anchor="progression-audit">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Training &amp; Progression Audit</h3>
        <p class="swse-concept-panel__hint">Expected feats, talents, ability increases, HP, BAB, and class defenses from the class progression SSOT.</p>
      </div>
      <span class="swse-concept-chip swse-concept-chip--neutral">Level {{conceptLayout.progressionAudit.totalHeroicLevel}}</span>
    </header>

    {{#if conceptLayout.progressionAudit.diagnostics.error}}
      <div class="swse-concept-empty-state swse-concept-empty-state--warning" data-sheet-anchor="progression-audit-diagnostics">
        <span class="swse-concept-empty-state__eyebrow">Audit Safe Mode</span>
        <strong>The progression audit could not fully complete, so the sheet is showing safe fallback data.</strong>
        {{#if conceptLayout.progressionAudit.diagnostics.message}}<p>{{conceptLayout.progressionAudit.diagnostics.message}}</p>{{/if}}
      </div>
    {{/if}}

    {{#if conceptLayout.progressionAudit.hasRepairSuggestions}}
      <div class="swse-concept-subsection" data-sheet-anchor="progression-repair-suggestions">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Repair Suggestions</h3>
            <p class="swse-concept-panel__hint">The audit found actor data that may need GM/player review. These suggestions do not automatically rewrite the actor.</p>
          </div>
          <span class="swse-concept-chip swse-concept-chip--neutral">{{conceptLayout.progressionAudit.repairSuggestions.length}} suggested</span>
        </header>
        <div class="swse-concept-ledger">
          {{#each conceptLayout.progressionAudit.repairSuggestions as |suggestion|}}
            <article class="swse-concept-ledger-row">
              <div class="swse-concept-ledger-row__main">
                <div class="swse-concept-ledger-row__title">{{suggestion.label}}</div>
                <div class="swse-concept-ledger-row__meta">
                  {{#if suggestion.detail}}<span>{{suggestion.detail}}</span>{{/if}}
                  {{#if suggestion.repairKey}}<span>{{suggestion.repairKey}}</span>{{/if}}
                </div>
              </div>
              <div class="swse-concept-ledger-row__actions">
                <span class="swse-concept-chip swse-concept-chip--neutral">Review</span>
              </div>
            </article>
          {{/each}}
        </div>
      </div>
    {{/if}}

    {{#if conceptLayout.progressionAudit.trainingLedgers.length}}
      <div class="swse-concept-subsection" data-sheet-anchor="progression-ledger">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Progression Choices</h3>
            <p class="swse-concept-panel__hint">General feats, class feats, heroic talents, class talents, and ability increases compared against current actor items.</p>
          </div>
        </header>

        <div class="swse-concept-card-grid">
          {{#each conceptLayout.progressionAudit.trainingLedgers as |ledger|}}
            <article class="swse-concept-info-card swse-concept-info-card--stat">
              <span>{{ledger.label}}</span>
              <strong>{{ledger.filled}}/{{ledger.expected}}</strong>
              <small>{{ledger.statusLabel}}</small>
              {{#if ledger.ambiguous}}<small>{{ledger.ambiguous}} unclassified</small>{{/if}}
            </article>
          {{/each}}
        </div>

        {{#if conceptLayout.progressionAudit.hasTrainingProgression}}
          <div class="swse-concept-ledger">
            {{#each conceptLayout.progressionAudit.trainingLedgers as |ledger|}}
              {{#if ledger.openSlots.length}}
                {{#each ledger.openSlots as |slot|}}
                  <article class="swse-concept-ledger-row swse-concept-ledger-row--actionable"
                           role="button"
                           tabindex="0"
                           data-action="resolve-progression-slot"
                           data-step-id="{{slot.primaryAction.stepId}}"
                           data-slot-id="{{slot.id}}"
                           data-slot-type="{{slot.type}}"
                           data-class-id="{{slot.classId}}"
                           data-class-name="{{slot.className}}"
                           data-class-level="{{slot.classLevel}}"
                           data-character-level="{{slot.characterLevel}}">
                    <div class="swse-concept-ledger-row__main">
                      <div class="swse-concept-ledger-row__title">{{slot.label}}</div>
                      <div class="swse-concept-ledger-row__meta">
                        {{#if slot.source}}<span>{{slot.source}}</span>{{/if}}
                        {{#if slot.featureName}}<span>{{slot.featureName}}</span>{{/if}}
                      </div>
                    </div>
                    <div class="swse-concept-ledger-row__actions">
                      <span class="swse-concept-chip swse-concept-chip--warn">Missing {{ledger.label}}</span>
                      <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="resolve-progression-slot" data-step-id="{{slot.primaryAction.stepId}}" data-slot-id="{{slot.id}}" data-slot-type="{{slot.type}}" data-class-id="{{slot.classId}}" data-class-name="{{slot.className}}" data-class-level="{{slot.classLevel}}" data-character-level="{{slot.characterLevel}}">{{slot.primaryAction.label}}</button>
                    </div>
                  </article>
                {{/each}}
              {{/if}}
              {{#if ledger.ambiguousSlots.length}}
                {{#each ledger.ambiguousSlots as |slot|}}
                  <article class="swse-concept-ledger-row swse-concept-ledger-row--actionable"
                           role="button"
                           tabindex="0"
                           data-action="classify-progression-slot"
                           data-step-id="{{slot.primaryAction.stepId}}"
                           data-slot-id="{{slot.id}}"
                           data-slot-type="{{slot.type}}"
                           data-class-id="{{slot.classId}}"
                           data-class-name="{{slot.className}}"
                           data-class-level="{{slot.classLevel}}"
                           data-character-level="{{slot.characterLevel}}"
                           data-item-id="{{slot.primaryCandidateId}}">
                    <div class="swse-concept-ledger-row__main">
                      <div class="swse-concept-ledger-row__title">{{slot.label}}</div>
                      <div class="swse-concept-ledger-row__meta">
                        {{#if slot.source}}<span>{{slot.source}}</span>{{/if}}
                        {{#if slot.candidateNames.length}}<span>Candidate: {{#each slot.candidateNames as |candidateName|}}{{candidateName}}{{#unless @last}}, {{/unless}}{{/each}}</span>{{/if}}
                        {{#if slot.classificationReason}}<span>{{slot.classificationReason}}</span>{{/if}}
                      </div>
                    </div>
                    <div class="swse-concept-ledger-row__actions">
                      <span class="swse-concept-chip swse-concept-chip--neutral">Needs Classification</span>
                      <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="classify-progression-slot" data-step-id="{{slot.primaryAction.stepId}}" data-slot-id="{{slot.id}}" data-slot-type="{{slot.type}}" data-class-id="{{slot.classId}}" data-class-name="{{slot.className}}" data-class-level="{{slot.classLevel}}" data-character-level="{{slot.characterLevel}}" data-item-id="{{slot.primaryCandidateId}}">{{slot.primaryAction.label}}</button>
                    </div>
                  </article>
                {{/each}}
              {{/if}}
              {{#if ledger.overfilledSlots.length}}
                {{#each ledger.overfilledSlots as |slot|}}
                  <article class="swse-concept-ledger-row swse-concept-ledger-row--actionable"
                           role="button"
                           tabindex="0"
                           data-action="review-progression-slot"
                           data-slot-id="{{slot.id}}"
                           data-slot-type="{{slot.type}}"
                           data-item-id="{{slot.filledBy}}">
                    <div class="swse-concept-ledger-row__main">
                      <div class="swse-concept-ledger-row__title">{{slot.filledByName}}</div>
                      <div class="swse-concept-ledger-row__meta">
                        <span>{{slot.label}}</span>
                        {{#if slot.source}}<span>{{slot.source}}</span>{{/if}}
                      </div>
                    </div>
                    <div class="swse-concept-ledger-row__actions">
                      <span class="swse-concept-chip swse-concept-chip--neutral">Extra</span>
                      <button type="button" class="swse-concept-btn" data-action="review-progression-slot" data-slot-id="{{slot.id}}" data-slot-type="{{slot.type}}" data-item-id="{{slot.filledBy}}">Review</button>
                    </div>
                  </article>
                {{/each}}
              {{/if}}
            {{/each}}
          </div>
        {{else}}
          <div class="swse-concept-empty-state">
            <span class="swse-concept-empty-state__eyebrow">Training ledger reconciled</span>
            <strong>General feats, class feats, heroic talents, class talents, and ability increases match recorded progression, with no unclassified items waiting for review.</strong>
          </div>
        {{/if}}
      </div>
    {{/if}}

    {{#if conceptLayout.progressionAudit.derivedStats.rows.length}}
      <div class="swse-concept-subsection" data-sheet-anchor="derived-class-stats">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Derived Class Stats</h3>
            <p class="swse-concept-panel__hint">HP, BAB, and class defense bonuses compared against the merged class ledger and class progression SSOT.</p>
          </div>
          {{#if conceptLayout.progressionAudit.derivedStats.hasIssues}}
            <span class="swse-concept-chip swse-concept-chip--warn">{{conceptLayout.progressionAudit.derivedStats.issueCount}} review</span>
          {{else}}
            <span class="swse-concept-chip swse-concept-chip--ok">Reconciled</span>
          {{/if}}
        </header>

        <div class="swse-concept-card-grid">
          {{#each conceptLayout.progressionAudit.derivedStats.rows as |row|}}
            <article class="swse-concept-info-card swse-concept-info-card--stat">
              <span>{{row.label}}</span>
              <strong>{{row.currentLabel}}</strong>
              <small>Expected {{row.expectedLabel}}</small>
            </article>
          {{/each}}
        </div>

        {{#if conceptLayout.progressionAudit.derivedStats.hasIssues}}
          <div class="swse-concept-ledger">
            {{#each conceptLayout.progressionAudit.derivedStats.rows as |row|}}
              {{#if row.needsAttention}}
                <article class="swse-concept-ledger-row swse-concept-ledger-row--actionable"
                         role="button"
                         tabindex="0"
                         data-action="open-audit-target"
                         data-tab-target="{{row.targetTab}}"
                         data-sheet-anchor="{{row.sheetAnchor}}"
                         data-row-id="{{row.id}}">
                  <div class="swse-concept-ledger-row__main">
                    <div class="swse-concept-ledger-row__title">{{row.label}}</div>
                    <div class="swse-concept-ledger-row__meta">
                      <span>Current {{row.currentLabel}}</span>
                      <span>Expected {{row.expectedLabel}}</span>
                      {{#if row.detail}}<span>{{row.detail}}</span>{{/if}}
                    </div>
                  </div>
                  <div class="swse-concept-ledger-row__actions">
                    <span class="swse-concept-chip swse-concept-chip--{{row.tone}}">{{row.statusLabel}}</span>
                    <button type="button" class="swse-concept-btn" data-action="open-audit-target" data-tab-target="{{row.targetTab}}" data-sheet-anchor="{{row.sheetAnchor}}" data-row-id="{{row.id}}">{{row.primaryAction.label}}</button>
                  </div>
                </article>
              {{/if}}
            {{/each}}
          </div>
        {{/if}}
      </div>
    {{/if}}

    {{#if conceptLayout.progressionAudit.byClass.length}}
      <div class="swse-concept-subsection" data-sheet-anchor="class-progression-ledger">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Class Progression Ledger</h3>
            <p class="swse-concept-panel__hint">Per-class feat and talent accounting from each owned class level.</p>
          </div>
        </header>
        <div class="swse-concept-ledger">
          {{#each conceptLayout.progressionAudit.byClass as |row|}}
            <article class="swse-concept-ledger-row">
              <div class="swse-concept-ledger-row__main">
                <div class="swse-concept-ledger-row__title">{{row.className}}</div>
                <div class="swse-concept-ledger-row__meta">
                  <span>Class feats {{row.classFeats.filled}}/{{row.classFeats.expected}}{{#if row.classFeats.ambiguous}} · {{row.classFeats.ambiguous}} unclassified{{/if}}</span>
                  <span>Class talents {{row.classTalents.filled}}/{{row.classTalents.expected}}{{#if row.classTalents.ambiguous}} · {{row.classTalents.ambiguous}} unclassified{{/if}}</span>
                </div>
              </div>
              <div class="swse-concept-ledger-row__actions">
                {{#if row.classFeats.open}}<span class="swse-concept-chip swse-concept-chip--warn">{{row.classFeats.open}} feat open</span>{{/if}}
                {{#if row.classFeats.ambiguous}}<span class="swse-concept-chip swse-concept-chip--neutral">{{row.classFeats.ambiguous}} feat classify</span>{{/if}}
                {{#if row.classTalents.open}}<span class="swse-concept-chip swse-concept-chip--warn">{{row.classTalents.open}} talent open</span>{{/if}}
                {{#if row.classTalents.ambiguous}}<span class="swse-concept-chip swse-concept-chip--neutral">{{row.classTalents.ambiguous}} talent classify</span>{{/if}}
              </div>
            </article>
          {{/each}}
        </div>
      </div>
    {{/if}}
  </section>

</div>
