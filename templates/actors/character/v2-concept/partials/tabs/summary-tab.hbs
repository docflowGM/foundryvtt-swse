<div class="swse-concept-dashboard">
  <section class="swse-concept-panel swse-concept-panel--hero">
    <div class="swse-concept-hero">
      <div class="swse-concept-hero__copy">
        <span class="swse-concept-empty-state__eyebrow">Mission Profile</span>
        <h3 class="swse-concept-hero__title">Live Dossier Brief</h3>
        <p class="swse-concept-hero__body">{{conceptLayout.summary.missionBrief}}</p>

        <div class="swse-concept-chip-row">
          {{#each conceptLayout.summary.dossierTags as |tag|}}
            <span class="swse-concept-chip swse-concept-chip--{{tag.tone}}">{{tag.label}}</span>
          {{/each}}
        </div>
      </div>

      <div class="swse-concept-hero__rail">
        <div class="swse-concept-hero-status">
          <span>Status</span>
          <strong class="{{conceptLayout.summary.readinessClass}}">{{conceptLayout.summary.readinessLabel}}</strong>
          <p>{{conceptLayout.summary.readinessNote}}</p>
        </div>

        <div class="swse-concept-card-grid swse-concept-card-grid--summary-hero">
          {{#each conceptLayout.summary.heroMetrics as |metric|}}
            <article class="swse-concept-info-card swse-concept-info-card--stat">
              <span>{{metric.label}}</span>
              <strong class="{{metric.valueClass}}">{{metric.value}}</strong>
            </article>
          {{/each}}
        </div>
      </div>
    </div>
  </section>

  <section class="swse-concept-panel swse-concept-panel--summary">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Dossier Summary</h3>
        <p class="swse-concept-panel__hint">At-a-glance operator profile and current status.</p>
      </div>
    </header>

    <div class="swse-concept-card-grid swse-concept-card-grid--summary">
      {{#each conceptLayout.summary.cards as |card|}}
        <article class="swse-concept-info-card">
          <span>{{card.label}}</span>
          <strong>{{card.value}}</strong>
        </article>
      {{/each}}
    </div>
  </section>

  <div class="swse-concept-grid swse-concept-grid--two">
    {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/xp-panel.hbs"}}

    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Credits Ledger</h3>
          <p class="swse-concept-panel__hint">Current credits and quick credit adjustments.</p>
        </div>
        <div class="swse-concept-ledger-row__actions">
          <span class="swse-concept-chip swse-concept-chip--neutral">{{numberFormat conceptLayout.gear.credits decimals=0}} cr</span>
        </div>
      </header>

      <div class="swse-concept-inline-adjuster swse-concept-inline-adjuster--credits">
        <label>
          <span>Set Credits</span>
          <input type="number" name="system.credits" value="{{conceptLayout.gear.credits}}" min="0" step="1" />
        </label>
        <label>
          <span>Add Credits</span>
          <input type="number" data-role="credits-add-amount" step="1" placeholder="0" />
        </label>
        <button type="button" class="swse-concept-btn" data-action="add-credits-to-actor">Add Credits</button>
      </div>
    </section>
  </div>



  <div class="swse-concept-grid swse-concept-grid--two swse-concept-summary-state-grid">
    <section class="swse-concept-panel swse-concept-panel--summary-effects">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Current Conditions &amp; Effects</h3>
          <p class="swse-concept-panel__hint">Full active-effect feed moved here from Combat so the Summary tab acts as the live status dossier.</p>
        </div>
        <span class="swse-concept-panel__eyebrow">Live Status</span>
      </header>

      {{#if healthPanel.currentConditions.hasCards}}
        {{> "systems/foundryvtt-swse/templates/actors/shared/partials/current-conditions-panel.hbs" currentConditions=healthPanel.currentConditions}}
      {{else}}
        <div class="swse-concept-empty-state swse-concept-empty-state--compact">
          <span class="swse-concept-empty-state__eyebrow">Clear</span>
          <strong>No active conditions or mechanical effects are currently impacting this actor.</strong>
        </div>
      {{/if}}
    </section>

    {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/second-wind-panel.hbs"}}
  </div>

  <section class="swse-concept-panel">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Status Feed</h3>
        <p class="swse-concept-panel__hint">Persistent conditions, shields, XP awards, credit adjustments, and readiness markers.</p>
      </div>
    </header>

    <div class="swse-concept-chip-row">
      {{#each conceptLayout.summary.statusChips as |chip|}}
        <span class="swse-concept-chip swse-concept-chip--{{chip.tone}}">{{chip.label}}</span>
      {{/each}}
    </div>

    <div class="swse-concept-metric-row">
      {{#each conceptLayout.summary.quickReadouts as |metric|}}
        <div class="swse-concept-metric-card">
          <span>{{metric.label}}</span>
          <strong>{{metric.value}}</strong>
        </div>
      {{/each}}
    </div>

    {{#if conceptLayout.summary.statusFeedEntries.length}}
      <div class="swse-concept-status-feed">
        {{#each conceptLayout.summary.statusFeedEntries as |entry|}}
          <article class="swse-concept-status-feed__entry swse-concept-status-feed__entry--{{entry.tone}}">
            <strong>{{entry.label}}</strong>
            {{#if entry.detail}}<span>{{entry.detail}}</span>{{/if}}
            {{#if entry.value}}<em>{{entry.value}}</em>{{/if}}
          </article>
        {{/each}}
      </div>
    {{/if}}
  </section>
</div>
