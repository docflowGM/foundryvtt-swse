<div class="swse-concept-dashboard">
  <section class="swse-concept-panel swse-concept-panel--gear-actions swse-edit-reveal">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Inventory Controls</h3>
        <p class="swse-concept-panel__hint">Create blank actor-local items, then inspect them to fill in details.</p>
      </div>
    </header>
    <div class="swse-concept-action-rail swse-concept-action-rail--gear">
      <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="weapon">Add Weapon</button>
      <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="armor">Add Armor</button>
      <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="equipment">Add Gear</button>
    </div>
  </section>

  <div class="swse-concept-card-grid swse-concept-card-grid--gear-top">
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Credits</span>
      <strong>{{numberFormat conceptLayout.gear.credits decimals=0}}</strong>
    </article>
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Inventory Items</span>
      <strong>{{conceptLayout.gear.totalItems}}</strong>
    </article>
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Total Weight</span>
      <strong>{{#if conceptLayout.gear.ledgerWeight}}{{conceptLayout.gear.ledgerWeight}}{{else}}{{numberFormat conceptLayout.gear.totalWeight decimals=1}} kg{{/if}}</strong>
    </article>
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Workshop</span>
      <strong>{{#if conceptLayout.gear.hasUpgradeableItems}}Upgrade Ready{{else}}No Eligible Mods{{/if}}</strong>
    </article>
  </div>

  <div class="swse-concept-grid swse-concept-grid--gear-top">
    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Equipped Loadout</h3>
          <p class="swse-concept-panel__hint">Currently active weapons, armor, and field gear.</p>
        </div>
      </header>

      {{#if conceptLayout.gear.equippedEntries.length}}
        <div class="swse-concept-list-stack">
          {{#each conceptLayout.gear.equippedEntries as |entry|}}
            <article class="swse-concept-simple-row">
              <div class="swse-concept-simple-row__copy">
                <strong>{{entry.name}}</strong>
                <small>{{entry.typeLabel}} · Qty {{entry.quantity}}</small>
              </div>
              <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{entry.id}}">Inspect</button>
            </article>
          {{/each}}
        </div>
      {{else}}
        <div class="swse-concept-empty-state swse-concept-empty-state--guided">
          <span class="swse-concept-empty-state__eyebrow">Nothing equipped</span>
          <strong>Equip weapons, armor, or field gear from the ledger below to populate the active loadout.</strong>
          <div class="swse-concept-empty-state__actions swse-edit-only">
            <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="weapon">Add Weapon</button>
            <button type="button" class="swse-concept-btn" data-action="add-item" data-item-type="equipment">Add Gear</button>
          </div>
        </div>
      {{/if}}
    </section>

    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Armor Profile</h3>
          <p class="swse-concept-panel__hint">Current equipped armor summary and modifiers.</p>
        </div>
      </header>

      {{#if conceptLayout.gear.equippedArmor}}
        <div class="swse-concept-card-grid swse-concept-card-grid--armor">
          <article class="swse-concept-info-card swse-concept-info-card--wide">
            <span>Equipped Armor</span>
            <strong>{{conceptLayout.gear.equippedArmor.name}}</strong>
          </article>
          <article class="swse-concept-info-card">
            <span>Type</span>
            <strong>{{conceptLayout.gear.equippedArmor.armorType}}</strong>
          </article>
          <article class="swse-concept-info-card">
            <span>Reflex</span>
            <strong>{{numberFormat conceptLayout.gear.equippedArmor.reflexBonus decimals=0 sign=true}}</strong>
          </article>
          <article class="swse-concept-info-card">
            <span>Fort</span>
            <strong>{{numberFormat conceptLayout.gear.equippedArmor.fortBonus decimals=0 sign=true}}</strong>
          </article>
          <article class="swse-concept-info-card">
            <span>Max Dex</span>
            <strong>{{conceptLayout.gear.equippedArmor.maxDexBonus}}</strong>
          </article>
          <article class="swse-concept-info-card">
            <span>ACP</span>
            <strong>{{conceptLayout.gear.equippedArmor.armorCheckPenalty}}</strong>
          </article>
        </div>
      {{else}}
        <div class="swse-concept-empty-state swse-concept-empty-state--guided">
          <span class="swse-concept-empty-state__eyebrow">No armor equipped</span>
          <strong>Armor can modify Reflex Defense, Fortitude Defense, Max Dex, and armor check penalties.</strong>
          <div class="swse-concept-empty-state__actions swse-edit-only">
            <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="armor">Add Armor</button>
          </div>
        </div>
      {{/if}}
    </section>
  </div>

  {{#unless conceptLayout.gear.groups.length}}
    <section class="swse-concept-panel swse-concept-panel--ledger swse-concept-gear-ledger-empty">
      <div class="swse-concept-empty-state swse-concept-empty-state--guided">
        <span class="swse-concept-empty-state__eyebrow">No gear logged</span>
        <strong>Create actor-local weapons, armor, or equipment to begin the inventory ledger.</strong>
        <div class="swse-concept-empty-state__actions swse-edit-only">
          <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="weapon">Add Weapon</button>
          <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="armor">Add Armor</button>
          <button type="button" class="swse-concept-btn" data-action="add-item" data-item-type="equipment">Add Gear</button>
        </div>
      </div>
    </section>
  {{/unless}}

  {{#each conceptLayout.gear.groups as |group|}}
    <section class="swse-concept-panel swse-concept-panel--ledger">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">{{group.label}}</h3>
          <p class="swse-concept-panel__hint">{{group.count}} entries in this category.</p>
        </div>
      </header>

      <div class="swse-concept-ledger">
        {{#each group.entries as |entry|}}
          <article class="swse-concept-ledger-row">
            <div class="swse-concept-ledger-row__main">
              <div class="swse-concept-ledger-row__title">{{entry.name}}</div>
              <div class="swse-concept-ledger-row__meta">
                <span>{{entry.typeLabel}}</span>
                {{#if entry.equipped}}<span>Equipped</span>{{/if}}
                {{#if entry.isNaturalWeapon}}<span>Natural</span>{{/if}}
                {{#each entry.tags as |tag|}}<span>{{tag}}</span>{{/each}}
              </div>
            </div>

            <div class="swse-concept-ledger-row__stats">
              <div>
                <span>Qty</span>
                <strong>{{entry.quantity}}</strong>
              </div>
              <div>
                <span>Weight</span>
                <strong>{{#if entry.weight}}{{numberFormat entry.weight decimals=1}} kg{{else}}-{{/if}}</strong>
              </div>
              <div>
                <span>Value</span>
                <strong>{{numberFormat entry.value decimals=0}}</strong>
              </div>
            </div>

            <div class="swse-concept-ledger-row__actions">
              <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{entry.id}}">Inspect</button>
            </div>
          </article>
        {{/each}}
      </div>
    </section>
  {{/each}}
</div>
