<div class="swse-concept-dashboard">
  <div class="swse-concept-card-grid swse-concept-card-grid--talents-top">
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Feats</span>
      <strong>{{conceptLayout.talents.featCount}}</strong>
    </article>
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Talents</span>
      <strong>{{conceptLayout.talents.talentCount}}</strong>
    </article>
    {{#unless isDroidActor}}
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Species Abilities</span>
      <strong>{{conceptLayout.talents.speciesAbilityCount}}</strong>
    </article>
    {{/unless}}
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Class Features</span>
      <strong>{{conceptLayout.talents.classFeatureCount}}</strong>
    </article>
    <article class="swse-concept-info-card swse-concept-info-card--stat">
      <span>Total Abilities</span>
      <strong>{{conceptLayout.talents.abilityCount}}</strong>
    </article>
  </div>

  {{#if conceptLayout.progressionAudit.trainingLedgers.length}}
  <section class="swse-concept-panel swse-concept-panel--ledger" data-sheet-anchor="progression-ledger">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Progression Audit</h3>
        <p class="swse-concept-panel__hint">Expected training slots from total heroic level and class levels compared against current actor items.</p>
      </div>
      <span class="swse-concept-chip swse-concept-chip--neutral">Level {{conceptLayout.progressionAudit.totalHeroicLevel}}</span>
    </header>

    <div class="swse-concept-card-grid">
      {{#each conceptLayout.progressionAudit.trainingLedgers as |ledger|}}
        <article class="swse-concept-info-card swse-concept-info-card--stat">
          <span>{{ledger.label}}</span>
          <strong>{{ledger.filled}}/{{ledger.expected}}</strong>
          <small>{{ledger.statusLabel}}</small>
          {{#if ledger.ambiguous}}<small>{{ledger.ambiguous}} unclassified</small>{{/if}}
        </article>
      {{/each}}
    </div>

    {{#if conceptLayout.progressionAudit.hasOpenProgression}}
      <div class="swse-concept-ledger">
        {{#each conceptLayout.progressionAudit.trainingLedgers as |ledger|}}
          {{#if ledger.openSlots.length}}
            {{#each ledger.openSlots as |slot|}}
              <article class="swse-concept-ledger-row">
                <div class="swse-concept-ledger-row__main">
                  <div class="swse-concept-ledger-row__title">{{slot.label}}</div>
                  <div class="swse-concept-ledger-row__meta">
                    {{#if slot.source}}<span>{{slot.source}}</span>{{/if}}
                    {{#if slot.featureName}}<span>{{slot.featureName}}</span>{{/if}}
                  </div>
                </div>
                <div class="swse-concept-ledger-row__actions">
                  <span class="swse-concept-chip swse-concept-chip--warn">Missing {{ledger.label}}</span>
                  <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="resolve-progression-slot" data-step-id="{{slot.primaryAction.stepId}}" data-slot-id="{{slot.id}}" data-slot-type="{{slot.type}}" data-class-id="{{slot.classId}}" data-class-name="{{slot.className}}" data-class-level="{{slot.classLevel}}" data-character-level="{{slot.characterLevel}}">{{slot.primaryAction.label}}</button>
                </div>
              </article>
            {{/each}}
          {{/if}}
          {{#if ledger.ambiguousSlots.length}}
            {{#each ledger.ambiguousSlots as |slot|}}
              <article class="swse-concept-ledger-row">
                <div class="swse-concept-ledger-row__main">
                  <div class="swse-concept-ledger-row__title">{{slot.label}}</div>
                  <div class="swse-concept-ledger-row__meta">
                    {{#if slot.source}}<span>{{slot.source}}</span>{{/if}}
                    {{#if slot.candidateNames.length}}<span>Candidate: {{#each slot.candidateNames as |candidateName|}}{{candidateName}}{{#unless @last}}, {{/unless}}{{/each}}</span>{{/if}}
                    {{#if slot.classificationReason}}<span>{{slot.classificationReason}}</span>{{/if}}
                  </div>
                </div>
                <div class="swse-concept-ledger-row__actions">
                  <span class="swse-concept-chip swse-concept-chip--neutral">Needs Classification</span>
                  <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="classify-progression-slot" data-step-id="{{slot.primaryAction.stepId}}" data-slot-id="{{slot.id}}" data-slot-type="{{slot.type}}" data-class-id="{{slot.classId}}" data-class-name="{{slot.className}}" data-class-level="{{slot.classLevel}}" data-character-level="{{slot.characterLevel}}" data-item-id="{{slot.primaryCandidateId}}">{{slot.primaryAction.label}}</button>
                </div>
              </article>
            {{/each}}
          {{/if}}
          {{#if ledger.overfilledSlots.length}}
            {{#each ledger.overfilledSlots as |slot|}}
              <article class="swse-concept-ledger-row">
                <div class="swse-concept-ledger-row__main">
                  <div class="swse-concept-ledger-row__title">{{slot.filledByName}}</div>
                  <div class="swse-concept-ledger-row__meta">
                    <span>{{slot.label}}</span>
                    {{#if slot.source}}<span>{{slot.source}}</span>{{/if}}
                  </div>
                </div>
                <div class="swse-concept-ledger-row__actions">
                  <span class="swse-concept-chip swse-concept-chip--neutral">Extra</span>
                  <button type="button" class="swse-concept-btn" data-action="review-progression-slot" data-slot-id="{{slot.id}}" data-slot-type="{{slot.type}}" data-item-id="{{slot.filledBy}}">Review</button>
                </div>
              </article>
            {{/each}}
          {{/if}}
        {{/each}}
      </div>
    {{else}}
      <div class="swse-concept-empty-state">
        <span class="swse-concept-empty-state__eyebrow">Training ledger reconciled</span>
        <strong>General feats, class feats, heroic talents, class talents, and ability increases match recorded progression, with no unclassified items waiting for review.</strong>
      </div>
    {{/if}}
  </section>
  {{/if}}

  {{#if conceptLayout.progressionAudit.byClass.length}}
  <section class="swse-concept-panel swse-concept-panel--ledger" data-sheet-anchor="class-progression-ledger">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Class Progression Ledger</h3>
        <p class="swse-concept-panel__hint">Per-class feat and talent accounting from each owned class level.</p>
      </div>
    </header>
    <div class="swse-concept-ledger">
      {{#each conceptLayout.progressionAudit.byClass as |row|}}
        <article class="swse-concept-ledger-row">
          <div class="swse-concept-ledger-row__main">
            <div class="swse-concept-ledger-row__title">{{row.className}}</div>
            <div class="swse-concept-ledger-row__meta">
              <span>Class feats {{row.classFeats.filled}}/{{row.classFeats.expected}}{{#if row.classFeats.ambiguous}} · {{row.classFeats.ambiguous}} unclassified{{/if}}</span>
              <span>Class talents {{row.classTalents.filled}}/{{row.classTalents.expected}}{{#if row.classTalents.ambiguous}} · {{row.classTalents.ambiguous}} unclassified{{/if}}</span>
            </div>
          </div>
          <div class="swse-concept-ledger-row__actions">
            {{#if row.classFeats.open}}<span class="swse-concept-chip swse-concept-chip--warn">{{row.classFeats.open}} feat open</span>{{/if}}
            {{#if row.classFeats.ambiguous}}<span class="swse-concept-chip swse-concept-chip--neutral">{{row.classFeats.ambiguous}} feat classify</span>{{/if}}
            {{#if row.classTalents.open}}<span class="swse-concept-chip swse-concept-chip--warn">{{row.classTalents.open}} talent open</span>{{/if}}
            {{#if row.classTalents.ambiguous}}<span class="swse-concept-chip swse-concept-chip--neutral">{{row.classTalents.ambiguous}} talent classify</span>{{/if}}
          </div>
        </article>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#unless isDroidActor}}
  <section class="swse-concept-panel swse-concept-panel--ledger racial-section">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Species Abilities</h3>
        <p class="swse-concept-panel__hint">Innate traits and species features loaded from the character record.</p>
      </div>
    </header>

    {{#if conceptLayout.talents.speciesAbilityEntries.length}}
      <div class="swse-concept-ledger">
        {{#each conceptLayout.talents.speciesAbilityEntries as |ability|}}
          <article class="swse-concept-ledger-row racial-card">
            <div class="swse-concept-ledger-row__main">
              <div class="swse-concept-ledger-row__title">{{ability.name}}</div>
              <div class="swse-concept-ledger-row__meta">
                {{#if ability.source}}<span>{{ability.source}}</span>{{/if}}
                {{#if ability.description}}<span>{{ability.description}}</span>{{/if}}
              </div>
            </div>
            <div class="swse-concept-ledger-row__actions">
              <span class="swse-concept-chip swse-concept-chip--neutral">Species</span>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="swse-concept-empty-state">
        <span class="swse-concept-empty-state__eyebrow">No species abilities recorded</span>
        <strong>Species traits will appear here once the actor record exposes them.</strong>
      </div>
    {{/if}}
  </section>
  {{/unless}}

  <div class="swse-concept-grid swse-concept-grid--two">
    <section class="swse-concept-panel swse-concept-panel--ledger" data-sheet-anchor="feat-ledger">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Feat Ledger</h3>
          <p class="swse-concept-panel__hint">Standard feats currently loaded on the actor.</p>
        </div>
        <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-feat">Add Feat</button>
      </header>

      {{#if conceptLayout.talents.featEntries.length}}
        <div class="swse-concept-ledger">
          {{#each conceptLayout.talents.featEntries as |feat|}}
            <article class="swse-concept-ledger-row">
              <div class="swse-concept-ledger-row__main">
                <div class="swse-concept-ledger-row__title">{{feat.name}}</div>
                <div class="swse-concept-ledger-row__meta">
                  {{#if feat.source}}<span>{{feat.source}}</span>{{/if}}
                  {{#if feat.description}}<span>{{feat.description}}</span>{{/if}}
                </div>
              </div>
              <div class="swse-concept-ledger-row__actions">
                {{#if feat.virtual}}
                  <span class="swse-concept-chip swse-concept-chip--neutral">Build Plan</span>
                {{else}}
                  <button type="button" class="swse-concept-btn" data-action="open-ability" data-item-id="{{feat.id}}">Inspect</button>
                  <button type="button" class="swse-concept-btn swse-concept-btn--danger" data-action="delete-feat" data-item-id="{{feat.id}}" title="Remove feat">✕</button>
                {{/if}}
              </div>
            </article>
          {{/each}}
        </div>
      {{else}}
        <div class="swse-concept-empty-state">
          <span class="swse-concept-empty-state__eyebrow">No feats recorded</span>
          <strong>Use Add Feat to create the first feat entry for this dossier.</strong>
        </div>
      {{/if}}
    </section>

    <section class="swse-concept-panel swse-concept-panel--ledger" data-sheet-anchor="talent-ledger">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Talent Trees</h3>
          <p class="swse-concept-panel__hint">Grouped by originating tree so the progression path stays readable.</p>
        </div>
        <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-talent">Add Talent</button>
      </header>

      {{#if conceptLayout.talents.talentGroups.length}}
        <div class="swse-concept-tree-stack">
          {{#each conceptLayout.talents.talentGroups as |group|}}
            <article class="swse-concept-action-group swse-concept-action-group--tree">
              <div class="swse-concept-action-group__header">
                <strong>{{group.label}}</strong>
                <span>{{group.count}}</span>
              </div>

              <div class="swse-concept-action-list">
                {{#each group.entries as |talent|}}
                  <div class="swse-concept-action-row swse-concept-action-row--talent">
                    <div class="swse-concept-action-row__copy">
                      <strong>{{talent.name}}</strong>
                      <small>{{talent.description}}</small>
                    </div>
                    <div class="swse-concept-action-row__actions">
                      {{#if talent.source}}<span class="swse-concept-chip swse-concept-chip--neutral">{{talent.source}}</span>{{/if}}
                      {{#if talent.virtual}}
                        <span class="swse-concept-chip swse-concept-chip--neutral">Build Plan</span>
                      {{else}}
                        <button type="button" class="swse-concept-btn" data-action="open-ability" data-item-id="{{talent.id}}">Inspect</button>
                        <button type="button" class="swse-concept-btn swse-concept-btn--danger" data-action="delete-talent" data-item-id="{{talent.id}}" title="Remove talent">✕</button>
                      {{/if}}
                    </div>
                  </div>
                {{/each}}
              </div>
            </article>
          {{/each}}
        </div>
      {{else}}
        <div class="swse-concept-empty-state">
          <span class="swse-concept-empty-state__eyebrow">No talent trees recorded</span>
          <strong>Use Add Talent to begin building out talent tree progression.</strong>
        </div>
      {{/if}}
    </section>
  </div>

  {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/class-features-panel.hbs"}}
</div>
