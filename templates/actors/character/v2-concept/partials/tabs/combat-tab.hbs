<div class="swse-concept-dashboard">
  <div class="swse-concept-metric-row swse-concept-metric-row--combat">
    {{#each conceptLayout.combat.telemetry as |metric|}}
      <div class="swse-concept-metric-card swse-concept-metric-card--combat">
        <span>{{metric.label}}</span>
        <strong class="{{metric.valueClass}}">{{numberFormat metric.value decimals=0 sign=true}}{{metric.suffix}}</strong>
      </div>
    {{/each}}
  </div>

  <div class="swse-concept-grid swse-concept-grid--combat">
    <section class="swse-concept-panel swse-concept-panel--ledger">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Attack Ledger</h3>
          <p class="swse-concept-panel__hint">Use current attacks without leaving the dossier shell.</p>
        </div>
      </header>

      {{#if conceptLayout.combat.attacks.length}}
        <div class="swse-concept-ledger">
          {{#each conceptLayout.combat.attacks as |attack|}}
            <article class="swse-concept-ledger-row swse-concept-ledger-row--attack" data-attack-id="{{attack.id}}">
              <div class="swse-concept-ledger-row__main">
                <div class="swse-concept-ledger-row__title">{{attack.name}}</div>
                <div class="swse-concept-ledger-row__meta">
                  {{#if attack.weaponName}}<span>{{attack.weaponName}}</span>{{/if}}
                  {{#if attack.weaponType}}<span>{{attack.weaponType}}</span>{{/if}}
                  {{#each attack.tags as |tag|}}<span>{{tag}}</span>{{/each}}
                </div>
              </div>

              <div class="swse-concept-ledger-row__stats">
                <div>
                  <span>To Hit</span>
                  <strong class="{{attack.attackTotalClass}}">{{numberFormat attack.attackTotal decimals=0 sign=true}}</strong>
                </div>
                <div>
                  <span>Damage</span>
                  <strong>{{attack.damageFormula}}</strong>
                </div>
                <div>
                  <span>Crit</span>
                  <strong>{{attack.critRange}}x{{attack.critMult}}</strong>
                </div>
              </div>

              <div class="swse-concept-ledger-row__actions">
                <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-attack" data-weapon-id="{{attack.weaponId}}">Roll</button>
                {{#if attack.weaponId}}
                  <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{attack.weaponId}}">Inspect</button>
                {{/if}}
              </div>
            </article>
          {{/each}}
        </div>
      {{else}}
        <div class="swse-concept-empty-state">
          <span class="swse-concept-empty-state__eyebrow">No attacks available</span>
          <strong>Equip a weapon in Gear to populate attack telemetry here.</strong>
        </div>
      {{/if}}
    </section>

    <div class="swse-concept-tab-stack">
      <section class="swse-concept-panel">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Action Economy</h3>
            <p class="swse-concept-panel__hint">Condensed action browser grouped by economy bucket.</p>
          </div>
        </header>

        {{#if conceptLayout.combat.actionGroups.length}}
          <div class="swse-concept-action-groups">
            {{#each conceptLayout.combat.actionGroups as |group|}}
              <article class="swse-concept-action-group">
                <div class="swse-concept-action-group__header">
                  <strong>{{group.label}}</strong>
                  <span>{{group.count}}</span>
                </div>

                {{#each group.subgroups as |subgroup|}}
                  <div class="swse-concept-action-subgroup">
                    <div class="swse-concept-action-subgroup__header">
                      <span>{{subgroup.label}}</span>
                      <span>{{subgroup.count}}</span>
                    </div>
                    <div class="swse-concept-action-list">
                      {{#each subgroup.items as |item|}}
                        <div class="swse-concept-action-row">
                          <div class="swse-concept-action-row__copy">
                            <strong>{{item.name}}</strong>
                            <small>{{item.sourceName}}</small>
                          </div>
                          <div class="swse-concept-action-row__actions">
                            {{#if item.itemId}}
                              <button type="button" class="swse-concept-iconbtn" data-action="open-item" data-item-id="{{item.itemId}}" title="Inspect source item">
                                <i class="fa-solid fa-up-right-from-square"></i>
                              </button>
                            {{/if}}
                            {{#if item.executable}}
                              <button type="button" class="swse-concept-btn" data-action="swse-v2-use-action" data-action-id="{{item.key}}">{{item.useLabel}}</button>
                            {{/if}}
                          </div>
                        </div>
                      {{/each}}
                    </div>
                  </div>
                {{/each}}
              </article>
            {{/each}}
          </div>
        {{else}}
          <div class="swse-concept-empty-state">
            <span class="swse-concept-empty-state__eyebrow">No action cards</span>
            <strong>This actor does not currently expose any executable action groups.</strong>
          </div>
        {{/if}}
      </section>

      <section class="swse-concept-panel">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Tactical Notes</h3>
            <p class="swse-concept-panel__hint">House rules, sequences, reminders, and combat procedures.</p>
          </div>
        </header>

        <textarea name="flags.swse.sheetNotes.specialCombatActions"
                  class="swse-concept-textarea"
                  placeholder="Examples: cover rules, condition reminders, action sequences, special maneuvers...">{{combatNotesPanel.combatNotes}}</textarea>
      </section>
    </div>
  </div>
</div>
