<div class="swse-concept-combat-redesign" data-combat-tab-root>
  {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/action-economy-indicator.hbs"}}

  <div class="swse-concept-combat-row swse-concept-combat-row--split">
    <section class="swse-concept-panel swse-concept-combat-init-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Initiative</h3>
          <p class="swse-concept-panel__hint">Dex + half level + misc.</p>
        </div>
        <span class="swse-concept-panel__eyebrow">Roll</span>
      </header>
      <div class="swse-concept-initiative-command">
        <div class="swse-concept-initiative-command__total">
          {{numberFormat initiativeTotal decimals=0 sign=true}}
        </div>
        <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-initiative">Roll d20</button>
      </div>
    </section>

    <section class="swse-concept-panel swse-concept-combat-vitals-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Combat Vitals</h3>
          <p class="swse-concept-panel__hint">Derived values used every round.</p>
        </div>
        <span class="swse-concept-panel__eyebrow">Derived</span>
      </header>
      <div class="swse-concept-vital-grid">
        <div class="swse-concept-vital"><span>BAB</span><strong>{{numberFormat bab decimals=0 sign=true}}</strong></div>
        <div class="swse-concept-vital"><span>Speed</span><strong>{{speed}}</strong></div>
        <div class="swse-concept-vital"><span>DT</span><strong>{{derived.damageThreshold}}</strong></div>
        <div class="swse-concept-vital"><span>Grapple</span><strong>{{numberFormat grappleBonus decimals=0 sign=true}}</strong></div>
        <div class="swse-concept-vital"><span>Perception</span><strong>{{numberFormat perceptionTotal decimals=0 sign=true}}</strong></div>
        <div class="swse-concept-vital swse-concept-vital--second-wind"><span>Second Wind</span><strong>{{secondWindPanel.uses}}/{{secondWindPanel.max}}</strong><small>{{secondWindPanel.healing}} HP</small></div>
      </div>
      <div class="swse-concept-combat-vitals-actions">
        <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="use-second-wind" {{#unless secondWindPanel.hasUses}}disabled{{/unless}}>Use Second Wind</button>
        <button type="button" class="swse-concept-btn" data-action="rest-second-wind" {{#unless secondWindPanel.canEdit}}disabled{{/unless}}>Reset</button>
      </div>
    </section>
  </div>

  <div class="swse-concept-combat-row swse-concept-combat-row--split swse-concept-combat-row--status">
    {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/combat-status-panel.hbs"}}
    {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/effective-defenses-panel.hbs"}}
  </div>

  {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/combat-actions-panel.hbs"}}

  <section class="swse-concept-panel swse-concept-panel--attacks swse-concept-combat-attacks-panel">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Attacks</h3>
        <p class="swse-concept-panel__hint">Click a weapon row to roll from the live combat profile.</p>
      </div>
      <span class="swse-concept-panel__eyebrow">Click to roll</span>
    </header>

    {{#if combatStatus.attackLocked}}
      <div class="swse-concept-combat-lock-notice">{{combatStatus.attackLockLabel}}</div>
    {{/if}}

    {{#if conceptLayout.combat.hasAnyAttacks}}
      <div class="swse-concept-attack-board">
        {{#if conceptLayout.combat.unarmedAttack}}
          {{#with conceptLayout.combat.unarmedAttack as |attack|}}
            <article class="swse-concept-attack-card swse-concept-attack-card--unarmed" data-attack-id="{{attack.id}}" style="{{attack.weaponRailStyle}}">
              <div class="swse-concept-attack-card__rail"><i class="fas fa-hand-fist" aria-hidden="true"></i></div>
              <div class="swse-concept-attack-card__main">
                <h4>{{attack.name}}</h4>
                <p>Default · {{attack.weaponType}} · {{attack.rangeLabel}}</p>
                {{#if attack.tags.length}}
                  <div class="swse-concept-attack-card__tags">
                    {{#each attack.tags as |tag|}}<span>{{tag}}</span>{{/each}}
                  </div>
                {{/if}}
                <div class="swse-concept-attack-card__microline">
                  {{#if attack.damageType}}<span>{{attack.damageType}}</span>{{/if}}
                  {{#if attack.ammoLabel}}<span>Ammo {{attack.ammoLabel}}</span>{{/if}}
                </div>
              </div>
              <div class="swse-concept-attack-card__stat">
                <span>To Hit</span>
                <strong class="{{attack.attackTotalClass}}">{{numberFormat attack.attackTotal decimals=0 sign=true}}</strong>
                <small>Crit {{attack.critRange}}</small>
              </div>
              <div class="swse-concept-attack-card__stat">
                <span>Damage</span>
                <strong>{{attack.damageFormula}}</strong>
                <small>{{attack.critMult}}</small>
              </div>
              <div class="swse-concept-attack-card__actions">
                <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-unarmed-attack" {{#if ../combatStatus.attackLocked}}disabled{{/if}}>Roll</button>
              </div>
            </article>
          {{/with}}
        {{/if}}

        {{#each conceptLayout.combat.attacks as |attack|}}
          <article class="swse-concept-attack-card" data-attack-id="{{attack.id}}" style="{{attack.weaponRailStyle}}">
            <div class="swse-concept-attack-card__rail"><i class="fas fa-crosshairs" aria-hidden="true"></i></div>
            <div class="swse-concept-attack-card__main">
              <h4>{{attack.name}}</h4>
              <p>{{attack.weaponName}} · {{attack.weaponType}} · {{attack.rangeLabel}}</p>
              {{#if attack.tags.length}}
                <div class="swse-concept-attack-card__tags">
                  {{#each attack.tags as |tag|}}<span>{{tag}}</span>{{/each}}
                </div>
              {{/if}}
              <div class="swse-concept-attack-card__microline">
                {{#if attack.damageType}}<span>{{attack.damageType}}</span>{{/if}}
                {{#if attack.ammoLabel}}<span>Ammo {{attack.ammoLabel}}</span>{{/if}}
              </div>
            </div>
            <div class="swse-concept-attack-card__stat">
              <span>To Hit</span>
              <strong class="{{attack.attackTotalClass}}">{{numberFormat attack.attackTotal decimals=0 sign=true}}</strong>
              <small>Crit {{attack.critRange}}</small>
            </div>
            <div class="swse-concept-attack-card__stat">
              <span>Damage</span>
              <strong>{{attack.damageFormula}}</strong>
              <small>{{attack.critMult}}</small>
            </div>
            <div class="swse-concept-attack-card__actions">
              <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-attack" data-weapon-id="{{attack.weaponId}}" {{#if ../combatStatus.attackLocked}}disabled{{/if}}>Roll</button>
              {{#if attack.weaponId}}
                <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{attack.weaponId}}">Inspect</button>
              {{/if}}
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="swse-concept-empty-state swse-concept-empty-state--guided">
        <span class="swse-concept-empty-state__eyebrow">No attacks available</span>
        <strong>No equipped weapons detected. Unarmed Attack should be available by default; add or equip a weapon in Gear for a full attack ledger.</strong>
        <div class="swse-concept-empty-state__actions swse-edit-only">
          <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="weapon">Add Weapon</button>
          <button type="button" class="swse-concept-btn" data-action="sheet-tab" data-sheet-tab="gear" data-tab="gear">Open Gear</button>
        </div>
      </div>
    {{/if}}
  </section>

  <nav class="swse-concept-combat-command-rail" aria-label="Combat quick commands">
    <button type="button" class="swse-concept-command-link" data-action="roll-initiative">Roll Initiative</button>
    <button type="button" class="swse-concept-command-link" data-action="use-second-wind" {{#unless secondWindPanel.hasUses}}disabled{{/unless}}>Second Wind</button>
    <button type="button" class="swse-concept-command-link" data-action="spend-force-point" {{#unless forcePointsValue}}disabled{{/unless}}>Spend Force</button>
    <button type="button" class="swse-concept-command-link" data-action="sheet-tab" data-sheet-tab="gear" data-tab="gear">Gear</button>
    <button type="button" class="swse-concept-command-link" data-action="cmd-levelup">Level Up</button>
  </nav>

</div>
