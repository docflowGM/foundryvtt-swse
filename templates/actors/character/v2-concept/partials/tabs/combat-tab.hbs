<div class="swse-concept-dashboard">
  <div class="swse-concept-metric-row swse-concept-metric-row--combat">
    {{#each conceptLayout.combat.telemetry as |metric|}}
      <div class="swse-concept-metric-card swse-concept-metric-card--combat" data-swse-tooltip="{{metric.tooltip}}">
        <span>{{metric.label}}</span>
        <strong class="{{metric.valueClass}}">{{numberFormat metric.value decimals=0 sign=true}}{{metric.suffix}}</strong>
      </div>
    {{/each}}
  </div>

  <div class="swse-concept-combat-status-strip" aria-label="Combat status">
    {{#each conceptLayout.combat.statusStrip as |chip|}}
      <span class="swse-concept-status-chip swse-concept-status-chip--{{chip.tone}}" data-swse-tooltip="{{chip.tooltip}}">{{chip.label}}</span>
    {{/each}}
  </div>

  <div class="swse-concept-grid swse-concept-grid--combat">
    <div class="swse-concept-combat-main">
      <section class="swse-concept-panel swse-concept-panel--ledger">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Attack Ledger</h3>
            <p class="swse-concept-panel__hint">Use current attacks without leaving the dossier shell.</p>
          </div>
        </header>

        {{#if conceptLayout.combat.hasAnyAttacks}}
          <div class="swse-concept-ledger">
          {{#if conceptLayout.combat.unarmedAttack}}
            {{#with conceptLayout.combat.unarmedAttack as |attack|}}
              <article class="swse-concept-ledger-row swse-concept-ledger-row--attack swse-concept-ledger-row--unarmed" data-attack-id="{{attack.id}}">
                <div class="swse-concept-ledger-row__main">
                  <div class="swse-concept-ledger-row__title">{{attack.name}}</div>
                  <div class="swse-concept-ledger-row__meta">
                    <span>Default</span>
                    {{#if attack.weaponType}}<span>{{attack.weaponType}}</span>{{/if}}
                    {{#each attack.tags as |tag|}}<span>{{tag}}</span>{{/each}}
                  </div>
                </div>

                <div class="swse-concept-ledger-row__stats">
                  <div>
                    <span>To Hit</span>
                    <strong class="{{attack.attackTotalClass}}">{{numberFormat attack.attackTotal decimals=0 sign=true}}</strong>
                  </div>
                  <div>
                    <span>Damage</span>
                    <strong>{{attack.damageFormula}}</strong>
                  </div>
                  <div>
                    <span>Crit</span>
                    <strong>{{attack.critRange}}x{{attack.critMult}}</strong>
                  </div>
                </div>

                <div class="swse-concept-ledger-row__actions">
                  <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-unarmed-attack">Roll</button>
                </div>
              </article>
            {{/with}}
          {{/if}}
          {{#each conceptLayout.combat.attacks as |attack|}}
            <article class="swse-concept-ledger-row swse-concept-ledger-row--attack" data-attack-id="{{attack.id}}">
              <div class="swse-concept-ledger-row__main">
                <div class="swse-concept-ledger-row__title">{{attack.name}}</div>
                <div class="swse-concept-ledger-row__meta">
                  {{#if attack.weaponName}}<span>{{attack.weaponName}}</span>{{/if}}
                  {{#if attack.weaponType}}<span>{{attack.weaponType}}</span>{{/if}}
                  {{#each attack.tags as |tag|}}<span>{{tag}}</span>{{/each}}
                </div>
              </div>

              <div class="swse-concept-ledger-row__stats">
                <div>
                  <span>To Hit</span>
                  <strong class="{{attack.attackTotalClass}}">{{numberFormat attack.attackTotal decimals=0 sign=true}}</strong>
                </div>
                <div>
                  <span>Damage</span>
                  <strong>{{attack.damageFormula}}</strong>
                </div>
                <div>
                  <span>Crit</span>
                  <strong>{{attack.critRange}}x{{attack.critMult}}</strong>
                </div>
              </div>

              <div class="swse-concept-ledger-row__actions">
                <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-attack" data-weapon-id="{{attack.weaponId}}">Roll</button>
                {{#if attack.weaponId}}
                  <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{attack.weaponId}}">Inspect</button>
                {{/if}}
              </div>
            </article>
          {{/each}}
        </div>
      {{else}}
        <div class="swse-concept-empty-state swse-concept-empty-state--guided">
          <span class="swse-concept-empty-state__eyebrow">No attacks available</span>
          <strong>No equipped weapons detected. Unarmed Attack should be available by default; add or equip a weapon in Gear for a full attack ledger.</strong>
          <div class="swse-concept-empty-state__actions swse-edit-only">
            <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="add-item" data-item-type="weapon">Add Weapon</button>
            <button type="button" class="swse-concept-btn" data-action="sheet-tab" data-sheet-tab="gear" data-tab="gear">Open Gear</button>
          </div>
        </div>
        {{/if}}
      </section>

      {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/combat-actions-panel.hbs"}}
    </div>

    <div class="swse-concept-tab-stack">
      {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/hp-condition-panel.hbs"}}

      {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/second-wind-panel.hbs"}}

      {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/defenses-panel.hbs"}}


      {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/action-economy-indicator.hbs"}}

      <section class="swse-concept-panel">
        <header class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">Tactical Notes</h3>
            <p class="swse-concept-panel__hint">House rules, sequences, reminders, and combat procedures.</p>
          </div>
        </header>

        <textarea name="flags.swse.sheetNotes.specialCombatActions"
                  class="swse-concept-textarea"
                  placeholder="Examples: cover rules, condition reminders, action sequences, special maneuvers...">{{combatNotesPanel.combatNotes}}</textarea>
      </section>
    </div>
  </div>
</div>
