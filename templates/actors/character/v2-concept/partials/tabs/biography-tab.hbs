<div class="swse-concept-dashboard">
  <section class="swse-concept-panel">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Identity Record</h3>
        <p class="swse-concept-panel__hint">Reference metadata for the actor dossier. Origin, chassis/species, and class are progression-owned; personal metadata is editable here.</p>
      </div>
    </header>

    <div class="swse-concept-card-grid swse-concept-card-grid--bio">
      <article class="swse-concept-info-card">
        <span>Player</span>
        <input type="text" name="flags.swse.character.player" value="{{conceptLayout.identity.player}}" placeholder="Player" />
      </article>
      <article class="swse-concept-info-card">
        <span>Age</span>
        <input type="text" name="flags.swse.character.age" value="{{conceptLayout.identity.age}}" placeholder="Age" />
      </article>
      <article class="swse-concept-info-card">
        <span>Gender</span>
        <input type="text" name="flags.swse.character.gender" value="{{conceptLayout.identity.gender}}" placeholder="Gender" />
      </article>
      <article class="swse-concept-info-card">
        <span>Height</span>
        <input type="text" name="flags.swse.character.height" value="{{conceptLayout.identity.height}}" placeholder="Height" />
      </article>
      <article class="swse-concept-info-card">
        <span>Weight</span>
        <input type="text" name="flags.swse.character.weight" value="{{conceptLayout.identity.weight}}" placeholder="Weight" />
      </article>
      <article class="swse-concept-info-card">
        <span>{{conceptLayout.identity.identityLabel}}</span>
        <strong>{{conceptLayout.identity.identityValue}}</strong>
      </article>
      <article class="swse-concept-info-card">
        <span>{{conceptLayout.identity.originLabel}}</span>
        <strong>{{conceptLayout.identity.originValue}}</strong>
      </article>
      <article class="swse-concept-info-card">
        <span>{{#if conceptLayout.isDroidActor}}Function{{else}}Background{{/if}}</span>
        <strong>{{conceptLayout.identity.background}}</strong>
      </article>
      <article class="swse-concept-info-card">
        <span>{{#if conceptLayout.isDroidActor}}Chassis{{else}}Profession{{/if}}</span>
        <strong>{{conceptLayout.identity.profession}}</strong>
      </article>
    </div>

    <div class="swse-concept-subsection">
      <span class="swse-concept-subsection__label">Known Languages</span>
      <div class="swse-concept-chip-row">
        {{#if conceptLayout.biography.languages.length}}
          {{#each conceptLayout.biography.languages as |language|}}
            <span class="swse-concept-chip swse-concept-chip--neutral">{{language}}</span>
          {{/each}}
        {{else}}
          <span class="swse-concept-chip swse-concept-chip--neutral">No languages recorded</span>
        {{/if}}
      </div>
    </div>
  </section>

  {{#if darkSidePanel}}
    {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/dark-side-panel.hbs"}}
  {{/if}}

  <div class="swse-concept-grid swse-concept-grid--two">
    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Background & History</h3>
          <p class="swse-concept-panel__hint">Origin story, formative events, and biography text.</p>
        </div>
      </header>
      <textarea name="flags.swse.character.biography"
                class="swse-concept-textarea swse-concept-textarea--lg"
                placeholder="Character background, origin story, key life events...">{{flags.swse.character.biography}}</textarea>
    </section>

    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Campaign Log</h3>
          <p class="swse-concept-panel__hint">Session notes, key story beats, and in-character journal entries.</p>
        </div>
      </header>
      <textarea name="flags.swse.character.campaignLog"
                class="swse-concept-textarea swse-concept-textarea--lg"
                placeholder="Session notes, key story moments, in-character journal entries...">{{flags.swse.character.campaignLog}}</textarea>
    </section>
  </div>

  <div class="swse-concept-grid swse-concept-grid--two">
    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">Profile & Beliefs</h3>
          <p class="swse-concept-panel__hint">Goals, code of honor, quirks, ambitions, and roleplaying notes.</p>
        </div>
      </header>
      <textarea name="flags.swse.character.profileSummary"
                class="swse-concept-textarea swse-concept-textarea--lg"
                placeholder="Character goals, beliefs, code of honor, quirks, ambitions...">{{flags.swse.character.profileSummary}}</textarea>
    </section>

    <section class="swse-concept-panel">
      <header class="swse-concept-panel__header">
        <div>
          <h3 class="swse-concept-panel__title">General Notes</h3>
          <p class="swse-concept-panel__hint">Table-facing notes and reminders that used to live on the Summary tab.</p>
        </div>
      </header>
      <textarea name="system.notes"
                class="swse-concept-textarea swse-concept-textarea--lg"
                placeholder="Add character notes here...">{{biographyPanel.biography}}</textarea>
    </section>
  </div>
</div>
