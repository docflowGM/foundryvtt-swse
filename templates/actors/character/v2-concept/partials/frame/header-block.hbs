<header class="swse-concept-header">
  <div class="swse-concept-portrait-card">
    <div class="swse-concept-portrait-frame" data-role="actor-portrait-dropzone">
      <span class="swse-concept-portrait-cert">Verified</span>
      <img class="swse-concept-portrait"
           src="{{portraitPanel.img}}"
           data-edit="img"
           data-role="actor-portrait-image"
           title="Click or drop image to update portrait"
           alt="{{portraitPanel.name}} portrait" />
    </div>
    <div class="swse-concept-portrait-caption">
      <span>{{conceptLayout.identity.identityValue}}</span>
      <span>{{conceptLayout.identity.size}}</span>
    </div>
  </div>

  <div class="swse-concept-identity-card">
    <div class="swse-concept-identity-topline">{{actorSheetMode.title}}</div>
    <h1 class="swse-concept-name">
      <input name="name" type="text" value="{{biographyPanel.identity.name}}" placeholder="Name" {{#unless biographyPanel.identity.canEdit}}disabled{{/unless}} />
    </h1>

    <div class="swse-concept-identity-subline">
      <span>{{conceptLayout.identity.classDisplay}}</span>
      <span class="sep">•</span>
      <span>{{conceptLayout.identity.identityValue}}</span>
      <span class="sep">•</span>
      <span>{{conceptLayout.identity.player}}</span>
      <span class="sep">•</span>
      <span>{{conceptLayout.identity.homeworld}}</span>
    </div>

    <div class="swse-concept-badges">
      <span class="swse-concept-badge swse-concept-badge--accent">{{conceptLayout.identity.classDisplay}}</span>
      <span class="swse-concept-badge">Lvl {{conceptLayout.identity.level}}</span>
      <span class="swse-concept-badge">{{conceptLayout.identity.background}}</span>
      {{#if forceSensitive}}<span class="swse-concept-badge swse-concept-badge--force">Force-Sensitive</span>{{/if}}
    </div>

    <div class="swse-concept-identity-grid">
      <label class="swse-concept-field">
        <span>Player</span>
        <input name="flags.swse.character.player" type="text" value="{{biographyPanel.identity.player}}" placeholder="Player Name" {{#unless biographyPanel.identity.canEdit}}disabled{{/unless}} />
      </label>
      <div class="swse-concept-readout">
        <span>{{conceptLayout.identity.originLabel}}</span>
        <strong>{{conceptLayout.identity.originValue}}</strong>
      </div>
      <div class="swse-concept-readout">
        <span>{{#if conceptLayout.isDroidActor}}Function{{else}}Background{{/if}}</span>
        <strong>{{conceptLayout.identity.background}}</strong>
      </div>
      <div class="swse-concept-readout">
        <span>{{#if conceptLayout.isDroidActor}}Chassis{{else}}Profession{{/if}}</span>
        <strong>{{conceptLayout.identity.profession}}</strong>
      </div>
    </div>

    <div class="swse-concept-operator-line">
      <span class="swse-concept-operator-line__label">Operator Status</span>
      <span class="swse-concept-operator-line__value">{{conceptLayout.summary.readinessLabel}}</span>
      <span class="swse-concept-operator-line__sep">//</span>
      <span class="swse-concept-operator-line__value">{{conceptLayout.identity.alignment}}</span>
      <span class="swse-concept-operator-line__sep">//</span>
      <span class="swse-concept-operator-line__value">{{conceptLayout.identity.destiny}}</span>
    </div>

    <div class="swse-concept-action-row">
      {{#if isLevel0}}
        <button type="button" data-action="cmd-chargen" class="swse-concept-btn swse-concept-btn--primary">Chargen</button>
      {{else}}
        <button type="button" data-action="cmd-levelup" class="swse-concept-btn swse-concept-btn--primary {{#if xpLevelReady}}ready{{/if}}">Level Up</button>
        {{#if chargenCompleted}}
          <button type="button" data-action="open-mentor" class="swse-concept-btn swse-concept-btn--mentor">Talk to Mentor</button>
        {{/if}}
      {{/if}}
      <button type="button" data-action="cmd-store" class="swse-concept-btn">Store</button>
      <button type="button" data-action="refresh-sheet" class="swse-concept-btn" title="Recalculate and reload this sheet">Refresh</button>
      {{#unless chargenCompleted}}
        <button type="button" data-action="cmd-select-class" class="swse-concept-btn">Class</button>
        {{#unless actorSheetMode.hideSpeciesSection}}<button type="button" data-action="cmd-select-species" class="swse-concept-btn">Species</button>{{/unless}}
      {{/unless}}
      <button type="button" data-action="open-settings-app" class="swse-concept-btn">Settings</button>
      <button type="button" data-action="toggle-help-mode" class="swse-concept-btn swse-concept-btn--help" title="{{helpLevelDescription}}">{{helpLevelLabel}}</button>
      {{#if biographyPanel.identity.canEdit}}
        <button type="button" data-action="reset-character" class="swse-concept-btn swse-concept-btn--danger" title="Reset this character to a blank slate">⟳ Reset</button>
      {{/if}}
    </div>
  </div>

  <div class="swse-concept-readouts-card">
    <div class="swse-concept-level-block">
      <div class="swse-concept-level-row">
        <strong class="swse-concept-level-num">{{conceptLayout.identity.level}}</strong>
        <div class="swse-concept-level-stack">
          <span class="lbl">Class Track</span>
          <span class="class">{{conceptLayout.identity.classDisplay}}</span>
          <span class="half">Half Level {{derived.identity.halfLevel}}</span>
        </div>
      </div>
      <div class="swse-concept-xp-bar">
        <span class="swse-concept-xp-fill" style="width: {{xpData.percentRounded}}%;"></span>
      </div>
      <div class="swse-concept-xp-text">
        <span>{{xpData.total}} XP</span>
        <span>{{#if xpLevelReady}}Promotion Ready{{else}}{{xpData.percentRounded}}% to next level{{/if}}</span>
      </div>
    </div>

    <div class="swse-concept-stat-stack">
      <div class="swse-concept-stat-card">
        <span class="swse-concept-stat-card__label">Damage Threshold</span>
        <strong>{{derived.damageThreshold}}</strong>
      </div>
      <div class="swse-concept-stat-card">
        <span class="swse-concept-stat-card__label">Credits</span>
        <strong>{{numberFormat conceptLayout.gear.credits decimals=0}}</strong>
      </div>
      <div class="swse-concept-stat-card swse-concept-stat-card--force-points">
        <span class="swse-concept-stat-card__label">Force Points</span>
        <strong>{{forcePointsValue}} / {{forcePointsMax}}</strong>
        <div class="swse-concept-stat-card__actions">
          <button type="button" class="swse-concept-mini-btn" data-action="spend-force-point" {{#unless forcePointsValue}}disabled{{/unless}} title="Spend 1 Force Point">Spend</button>
          <button type="button" class="swse-concept-mini-btn" data-action="gain-force-point" {{#if (gte forcePointsValue forcePointsMax)}}disabled{{/if}} title="Restore 1 Force Point">+1</button>
        </div>
      </div>
      <div class="swse-concept-stat-card">
        <span class="swse-concept-stat-card__label">Destiny</span>
        <strong>{{destinyPointsValue}} / {{destinyPointsMax}}</strong>
      </div>
    </div>

    <div class="swse-concept-command-strip">
      <div class="swse-concept-command-chip">HP {{conceptLayout.vitals.hpValue}} / {{conceptLayout.vitals.hpMax}}</div>
      <div class="swse-concept-command-chip">CT {{conceptLayout.vitals.conditionLabel}}</div>
      <div class="swse-concept-command-chip">Init {{numberFormat initiativeTotal decimals=0 sign=true}}</div>
      <div class="swse-concept-command-chip">Speed {{conceptLayout.vitals.speed}}sq</div>
    </div>

    <div class="swse-concept-defense-strip">
      {{#each conceptLayout.defenses as |def|}}
        <div class="swse-concept-defense-pill">
          <span>{{def.label}}</span>
          <strong class="{{def.totalClass}}">{{def.total}}</strong>
        </div>
      {{/each}}
    </div>
  </div>
</header>
