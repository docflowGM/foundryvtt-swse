<div class="swse-concept-grid swse-concept-grid--two">
  <section class="swse-concept-panel">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Background &amp; History</h3>
        <p class="swse-concept-panel__hint">Origin story, formative events, and biography text.</p>
      </div>
    </header>
    <textarea name="flags.swse.character.biography"
              class="swse-concept-textarea swse-concept-textarea--lg"
              placeholder="Character background, origin story, key life events...">{{flags.swse.character.biography}}</textarea>
  </section>

  <section class="swse-concept-panel">
    <header class="swse-concept-panel__header">
      <div>
        <h3 class="swse-concept-panel__title">Campaign Log</h3>
        <p class="swse-concept-panel__hint">Session notes, key story beats, and in-character journal entries.</p>
      </div>
    </header>
    <textarea name="flags.swse.character.campaignLog"
              class="swse-concept-textarea swse-concept-textarea--lg"
              placeholder="Session notes, key story moments, in-character journal entries...">{{flags.swse.character.campaignLog}}</textarea>
  </section>
</div>
