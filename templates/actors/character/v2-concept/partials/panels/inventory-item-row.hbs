<article class="swse-concept-ledger-row swse-concept-ledger-row--inventory {{entry.cssClass}}" data-item-id="{{entry.id}}">
  <div class="swse-concept-ledger-row__main">
    <div class="swse-concept-ledger-row__title">{{entry.name}}</div>
    <div class="swse-concept-ledger-row__meta">
      <span>{{entry.typeLabel}}</span>
      {{#if entry.equipped}}<span>Equipped</span>{{/if}}
      {{#if entry.isNaturalWeapon}}<span>Natural</span>{{/if}}
      {{#each entry.tags as |tag|}}<span>{{tag}}</span>{{/each}}
    </div>
  </div>

  <div class="swse-concept-ledger-row__stats">
    <div>
      <span>Qty</span>
      <strong>{{entry.quantity}}</strong>
    </div>
    <div>
      <span>Weight</span>
      <strong>{{#if entry.weight}}{{numberFormat entry.weight decimals=1}} kg{{else}}-{{/if}}</strong>
    </div>
    <div>
      <span>Value</span>
      <strong>{{numberFormat entry.value decimals=0}}</strong>
    </div>
  </div>

  <div class="swse-concept-ledger-row__actions">
    <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{entry.id}}">Inspect</button>
    {{#if entry.isLightsaber}}
      <button type="button" class="swse-concept-btn" data-action="toggle-activated" data-item-id="{{entry.id}}">{{entry.activationLabel}}</button>
    {{/if}}
    {{#unless entry.isNaturalWeapon}}
      <button type="button" class="swse-concept-btn" data-action="equip" data-item-id="{{entry.id}}">{{#if entry.equipped}}Unequip{{else}}Equip{{/if}}</button>
    {{/unless}}
    {{#if entry.canEdit}}
      <button type="button" class="swse-concept-btn swse-edit-only" data-action="edit" data-item-id="{{entry.id}}">Edit</button>
      <button type="button" class="swse-concept-btn swse-edit-only" data-action="configure" data-item-id="{{entry.id}}">Customize</button>
      {{#if entry.canOpenForceAlchemy}}<button type="button" class="swse-concept-btn swse-concept-btn--alchemy" data-action="force-alchemy" data-item-id="{{entry.id}}">Alchemy</button>{{/if}}
      <button type="button" class="swse-concept-btn swse-edit-only" data-action="sell-item" data-item-id="{{entry.id}}">Sell</button>
    {{/if}}
    {{#if entry.canDelete}}
      <button type="button" class="swse-concept-btn swse-concept-btn--danger swse-edit-only" data-action="delete" data-item-id="{{entry.id}}">Delete</button>
    {{/if}}
  </div>
</article>
