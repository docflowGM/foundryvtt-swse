<section class="swse-concept-panel swse-concept-panel--ledger">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Force Secrets</h3>
      <p class="swse-concept-panel__hint">High-tier Force knowledge and secret disciplines.</p>
    </div>
  </header>

  {{#if conceptLayout.force.secrets.length}}
    <div class="swse-concept-ledger">
      {{#each conceptLayout.force.secrets as |entry|}}
        <article class="swse-concept-ledger-row">
          <div class="swse-concept-ledger-row__main">
            <div class="swse-concept-ledger-row__title">{{entry.name}}</div>
            <div class="swse-concept-ledger-row__meta">
              {{#if entry.prerequisite}}<span>Requires {{entry.prerequisite}}</span>{{/if}}
              {{#if entry.summary}}<span>{{entry.summary}}</span>{{/if}}
            </div>
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="swse-concept-empty-state">
      <span class="swse-concept-empty-state__eyebrow">No secrets known</span>
      <strong>No Force secrets are currently present on the actor record.</strong>
    </div>
  {{/if}}
</section>
