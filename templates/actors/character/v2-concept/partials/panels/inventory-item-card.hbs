<article class="swse-concept-loadout-card swse-concept-loadout-card--generic" data-item-id="{{entry.id}}">
  <div class="swse-concept-loadout-card__header">
    <div>
      <strong>{{entry.name}}</strong>
      <small>{{entry.typeLabel}}</small>
    </div>
    {{#if entry.equipped}}
      <span class="swse-concept-chip swse-concept-chip--ok">Equipped</span>
    {{/if}}
  </div>
  <div class="swse-concept-loadout-card__meta">
    <span>Qty {{entry.quantity}}</span>
    <span>{{#if entry.weight}}{{numberFormat entry.weight decimals=1}} kg{{else}}No weight{{/if}}</span>
    <span>{{numberFormat entry.value decimals=0}} cr</span>
  </div>
  {{#if entry.tags.length}}
    <div class="swse-concept-chip-row">
      {{#each entry.tags as |tag|}}
        <span class="swse-concept-chip swse-concept-chip--neutral">{{tag}}</span>
      {{/each}}
    </div>
  {{/if}}

  {{#if entry.alchemy.hasAlchemy}}
    <div class="swse-alchemy-badge-row" title="Alchemical modifications tracked on this item">
      {{#each entry.alchemy.badges as |badge|}}
        <span class="swse-concept-chip swse-concept-chip--alchemy {{badge.tone}}">&#9959; {{badge.label}}</span>
      {{/each}}
    </div>
  {{/if}}
  <div class="swse-concept-ledger-row__actions">
    {{#if entry.canEdit}}<button type="button" class="swse-concept-btn swse-edit-only" data-action="edit" data-item-id="{{entry.id}}">Edit</button>{{else}}<button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{entry.id}}">Inspect</button>{{/if}}
    {{#if entry.canOpenForceAlchemy}}<button type="button" class="swse-concept-btn swse-concept-btn--alchemy" data-action="force-alchemy" data-item-id="{{entry.id}}">Alchemy</button>{{/if}}
  </div>
</article>
