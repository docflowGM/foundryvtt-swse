<section class="swse-concept-panel">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Known Languages</h3>
      <p class="swse-concept-panel__hint">Languages recorded on the actor profile and surfaced to the sheet context.</p>
    </div>
  </header>

  <div class="swse-concept-chip-row">
    {{#if languagesPanel.entries.length}}
      {{#each languagesPanel.entries as |language|}}
        <span class="swse-concept-chip swse-concept-chip--neutral">{{language}}</span>
      {{/each}}
    {{else}}
      <span class="swse-concept-chip swse-concept-chip--neutral">No languages recorded</span>
    {{/if}}
  </div>
</section>
