<section class="swse-concept-panel swse-concept-effective-defenses-panel">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Effective Defenses</h3>
      <p class="swse-concept-panel__hint">Editable formula + live combat status modifiers.</p>
    </div>
    <span class="swse-concept-panel__eyebrow">Base + Lvl/Armor + Mod</span>
  </header>

  {{#if effectiveDefenses.hasRows}}
    <div class="swse-concept-effective-defense-list">
      {{#each effectiveDefenses.rows as |row|}}
        <article class="swse-concept-effective-defense-row {{#if row.boosted}}is-boosted{{/if}} {{#if row.blocked}}is-blocked{{/if}}">
          <div class="swse-concept-effective-defense-row__title">
            <h4>{{row.abbrev}}</h4>
            <span>Base {{row.base}}</span>
          </div>

          <div class="swse-concept-defense-formula-strip">
            {{#each row.parts as |part|}}
              {{#if part.isSelect}}
                <label class="swse-concept-defense-formula-input swse-concept-defense-formula-input--select">
                  <small>{{part.label}}</small>
                  <select name="{{part.path}}" {{#unless ../canEdit}}disabled{{/unless}}>
                    {{#each part.options as |opt|}}
                      <option value="{{opt.value}}" {{#if opt.selected}}selected{{/if}}>{{opt.label}}</option>
                    {{/each}}
                  </select>
                  <strong>{{numberFormat part.value decimals=0 sign=true}}</strong>
                </label>
              {{else}}
                {{#if part.readonly}}
                  <span class="swse-concept-defense-formula-chip">
                    <small>{{part.label}}</small>
                    <strong>{{numberFormat part.value decimals=0 sign=true}}</strong>
                  </span>
                {{else}}
                  <label class="swse-concept-defense-formula-input">
                    <span>{{part.label}}</span>
                    <input type="number" name="{{part.path}}" value="{{part.value}}" {{#unless ../canEdit}}disabled{{/unless}}>
                  </label>
                {{/if}}
              {{/if}}
            {{/each}}
          </div>

          <div class="swse-concept-effective-defense-row__mods">
            {{#if row.chips.length}}
              {{#each row.chips as |chip|}}
                <span class="swse-concept-defense-mod-chip swse-concept-defense-mod-chip--{{chip.tone}}">
                  {{chip.label}} {{chip.valueLabel}}
                </span>
              {{/each}}
            {{else}}
              <span class="swse-concept-defense-mod-chip swse-concept-defense-mod-chip--neutral">No combat status mods</span>
            {{/if}}
          </div>

          <div class="swse-concept-effective-defense-row__total">
            <span>Effective</span>
            {{#if row.blocked}}
              <strong>BLOCK</strong>
            {{else}}
              <strong>{{row.effective}}</strong>
            {{/if}}
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="swse-concept-empty-state">
      <span class="swse-concept-empty-state__eyebrow">No defenses</span>
      <strong>Defense context was unavailable for this actor.</strong>
    </div>
  {{/if}}
</section>
