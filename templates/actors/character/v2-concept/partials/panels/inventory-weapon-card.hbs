<article class="swse-concept-loadout-card swse-concept-loadout-card--weapon" data-item-id="{{entry.id}}">
  <div class="swse-concept-loadout-card__header">
    <div>
      <strong>{{entry.name}}</strong>
      <small>Weapon</small>
    </div>
    <span class="swse-concept-chip swse-concept-chip--accent">{{#if entry.isNaturalWeapon}}Natural{{else}}Equipped{{/if}}</span>
  </div>

  <div class="swse-concept-loadout-card__stats">
    <div>
      <span>Attack</span>
      <strong class="{{entry.attackTotalClass}}">{{#if entry.hasAttackProfile}}{{numberFormat entry.attackTotal decimals=0 sign=true}}{{else}}—{{/if}}</strong>
    </div>
    <div>
      <span>Damage</span>
      <strong>{{#if entry.damageFormula}}{{entry.damageFormula}}{{else}}—{{/if}}</strong>
    </div>
    <div>
      <span>Crit</span>
      <strong>{{#if entry.critRange}}{{entry.critRange}}x{{entry.critMult}}{{else}}—{{/if}}</strong>
    </div>
  </div>

  <div class="swse-concept-loadout-card__meta">
    <span>Qty {{entry.quantity}}</span>
    <span>{{#if entry.weight}}{{numberFormat entry.weight decimals=1}} kg{{else}}No weight{{/if}}</span>
    <span>{{numberFormat entry.value decimals=0}} cr</span>
  </div>

  <div class="swse-concept-ledger-row__actions">
    <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="roll-attack" data-weapon-id="{{entry.id}}">Roll</button>
    <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{entry.id}}">Inspect</button>
  </div>
</article>
