<section class="swse-concept-panel swse-concept-panel--action-economy-star" data-action-economy-star>
  <header class="swse-concept-panel__header swse-concept-ae-star__header">
    <div>
      <h3 class="swse-concept-panel__title">Action Economy</h3>
      <p class="swse-concept-panel__hint">Turn economy first: available actions unlock the compact combat console below.</p>
    </div>
    <div class="swse-concept-ae-star__mode">
      <span>{{actionEconomy.enforcementModeLabel}}</span>
      <small>{{#if actionEconomy.active}}Live Turn{{else}}Reference{{/if}}</small>
    </div>
  </header>

  <div class="swse-concept-ae-ladder" aria-label="Action economy availability">
    <div class="swse-concept-ae-ladder__spine" aria-hidden="true"></div>
    {{#each actionEconomy.steps as |step|}}
      <div class="swse-concept-ae-step {{step.cssClass}}" data-ae-step="{{step.key}}" title="{{step.tooltip}}">
        <span class="swse-concept-ae-step__diamond" aria-hidden="true"></span>
        <strong>{{step.label}}</strong>
        <div class="swse-concept-ae-step__pips">
          {{#if step.infinite}}
            <span class="swse-concept-ae-step__infinite">∞</span>
          {{else}}
            {{#each step.pips as |pip|}}
              <i class="{{#if pip.on}}is-on{{/if}}" aria-hidden="true"></i>
            {{/each}}
          {{/if}}
        </div>
        <small>{{step.stateLabel}}</small>
      </div>
    {{/each}}
  </div>

  <footer class="swse-concept-ae-star__footer">
    <div class="swse-concept-ae-star__remaining">
      <span>Remaining:</span>
      <strong>{{actionEconomy.summary}}</strong>
    </div>
    {{#if actionEconomy.readOnlyReason}}
      <p>{{actionEconomy.readOnlyReason}}</p>
    {{/if}}
    <div class="swse-concept-ae-star__controls">
      <button type="button" class="swse-concept-btn" data-action="swse-action-economy-undo" {{#unless actionEconomy.canUndo}}disabled{{/unless}}>Undo</button>
      <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="new-round" {{#unless actionEconomy.canReset}}disabled{{/unless}}>End Turn / Reset</button>
    </div>
  </footer>
</section>
