<section class="swse-concept-panel">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Identity Record</h3>
      <p class="swse-concept-panel__hint">Reference metadata for the character dossier.</p>
    </div>
  </header>

  <div class="swse-concept-card-grid swse-concept-card-grid--bio">
    {{#each conceptLayout.biography.profileCards as |card|}}
      <article class="swse-concept-info-card">
        <span>{{card.label}}</span>
        <strong>{{card.value}}</strong>
      </article>
    {{/each}}
  </div>

  <div class="swse-concept-subsection">
    <span class="swse-concept-subsection__label">Known Languages</span>
    <div class="swse-concept-chip-row">
      {{#if conceptLayout.biography.languages.length}}
        {{#each conceptLayout.biography.languages as |language|}}
          <span class="swse-concept-chip swse-concept-chip--neutral">{{language}}</span>
        {{/each}}
      {{else}}
        <span class="swse-concept-chip swse-concept-chip--neutral">No languages recorded</span>
      {{/if}}
    </div>
  </div>
</section>
