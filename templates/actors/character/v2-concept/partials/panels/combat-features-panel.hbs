<section class="swse-concept-panel swse-concept-panel--combat-features swse-combat-features-panel{{#if combatFeatures.preferences.compactMode}} is-compact{{/if}}" data-combat-features-panel data-swse-actor-id="{{actor.id}}">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Combat Features</h3>
      <p class="swse-concept-panel__hint">Feature console grouped by favorites, state, action economy, triggers, and passive riders.</p>
    </div>
    <span class="swse-concept-panel__eyebrow">Phase 10 Preview</span>
  </header>

  <div class="swse-combat-feature-toolbar">
    <button type="button" data-action="toggle-combat-features-compact">
      {{#if combatFeatures.preferences.compactMode}}Expanded View{{else}}Compact View{{/if}}
    </button>
  </div>

  <div class="swse-concept-command-strip swse-combat-feature-badges">
    <div class="swse-concept-command-chip"><strong>{{combatFeatures.badges.favoriteCount}}</strong><span>Favorites</span></div>
    <div class="swse-concept-command-chip"><strong>{{combatFeatures.badges.activeStateCount}}</strong><span>Active</span></div>
    <div class="swse-concept-command-chip"><strong>{{combatFeatures.badges.readyActionCount}}</strong><span>Actions</span></div>
    <div class="swse-concept-command-chip"><strong>{{combatFeatures.triggeredFeatures.length}}</strong><span>Triggers</span></div>
    <div class="swse-concept-command-chip"><strong>{{combatFeatures.badges.passiveAutomatedCount}}/{{combatFeatures.badges.passiveRiderCount}}</strong><span>Auto Riders</span></div>
    <div class="swse-concept-command-chip"><strong>{{combatFeatures.badges.rageLabel}}</strong><span>Rage</span></div>
  </div>

  {{#if combatFeatures.favoriteFeatures.length}}
    <div class="swse-concept-action-board swse-combat-feature-section swse-combat-feature-section--favorites" data-combat-feature-section="favorites">
      <article class="swse-concept-action-lane swse-action-lane--favorites">
        <header class="swse-concept-action-lane__header">
          <strong>Favorites</strong>
          <span>{{combatFeatures.badges.favoriteCount}}</span>
        </header>
        <div class="swse-concept-action-lane__rows">
          {{#each combatFeatures.favoriteFeatures as |feature|}}
            <div class="swse-combat-feature-row">
              <button type="button" class="swse-combat-feature-star is-favorite" data-action="toggle-combat-feature-favorite" data-feature-id="{{feature.id}}" title="Remove from favorites">★</button>
              <button type="button"
                      class="swse-concept-action-button swse-combat-feature-button swse-combat-feature-main swse-combat-feature-button--{{feature.automationStatus}}"
                      data-action="{{#if feature.executeAction}}{{feature.executeAction}}{{else}}view-combat-feature-details{{/if}}"
                      data-feature-id="{{feature.id}}"
                      data-feature-label="{{feature.name}}"
                      data-feature-summary="{{feature.summary}}"
                      data-source-name="{{feature.sourceName}}"
                      data-source-item-id="{{feature.sourceItemId}}"
                      data-automation-status="{{feature.automationStatus}}"
                      data-readiness="{{feature.readiness}}"
                      data-action-cost="{{feature.actionCost}}"
                      title="{{feature.summary}}">
                <span class="swse-concept-action-button__icon" aria-hidden="true">★</span>
                <span class="swse-concept-action-button__copy">
                  <strong>{{feature.name}}</strong>
                  <small>{{feature.favoriteSection}}</small>
                </span>
                <span class="swse-concept-action-button__cost">{{#if feature.actionCost}}{{feature.actionCost}}{{else}}{{feature.automationStatus}}{{/if}}</span>
              </button>
            </div>
          {{/each}}
        </div>
      </article>
    </div>
  {{/if}}

  {{#if combatFeatures.activeStates.length}}
    <div class="swse-concept-action-board swse-combat-feature-section swse-combat-feature-section--active" data-combat-feature-section="activeStates">
      <article class="swse-concept-action-lane swse-action-lane--active">
        <header class="swse-concept-action-lane__header">
          <strong>Active Combat States</strong>
          <span>{{combatFeatures.badges.activeStateCount}}</span>
        </header>
        <div class="swse-concept-action-lane__rows">
          {{#each combatFeatures.activeStates as |feature|}}
            <div class="swse-combat-feature-row">
              <button type="button" class="swse-combat-feature-star {{#if feature.isFavorite}}is-favorite{{/if}}" data-action="toggle-combat-feature-favorite" data-feature-id="{{feature.id}}" title="Toggle favorite">{{#if feature.isFavorite}}★{{else}}☆{{/if}}</button>
              <button type="button"
                      class="swse-concept-action-button swse-combat-feature-button swse-combat-feature-main swse-combat-feature-button--{{feature.automationStatus}}"
                      data-action="{{#if feature.deactivateAction}}{{feature.deactivateAction}}{{else}}view-combat-feature-details{{/if}}"
                      data-feature-id="{{feature.id}}"
                      data-feature-label="{{feature.name}}"
                      data-feature-summary="{{feature.summary}}"
                      data-source-name="{{feature.sourceName}}"
                      data-source-item-id="{{feature.sourceItemId}}"
                      data-effect-id="{{feature.effectId}}"
                      data-automation-status="{{feature.automationStatus}}"
                      data-readiness="{{feature.readiness}}"
                      data-action-cost="{{feature.actionCost}}"
                      title="{{feature.summary}}">
                <span class="swse-concept-action-button__icon" aria-hidden="true">●</span>
                <span class="swse-concept-action-button__copy">
                  <strong>{{feature.name}}</strong>
                  {{#if feature.durationLabel}}<small>{{feature.durationLabel}}</small>{{else}}{{#if feature.summary}}<small>{{feature.summary}}</small>{{/if}}{{/if}}
                </span>
                <span class="swse-concept-action-button__cost">{{feature.readiness}}</span>
              </button>
            </div>
          {{/each}}
        </div>
      </article>
    </div>
  {{/if}}

  {{#if combatFeatures.availableActionGroups.length}}
    <div class="swse-concept-action-board swse-combat-feature-section swse-combat-feature-section--actions" data-combat-feature-section="availableActions">
      {{#each combatFeatures.availableActionGroups as |group|}}
        <article class="swse-concept-action-lane swse-action-lane--{{group.id}}" data-combat-feature-action-group="{{group.id}}" title="{{group.hint}}">
          <header class="swse-concept-action-lane__header">
            <strong>{{group.label}}</strong>
            <span>{{group.count}}</span>
          </header>
          <div class="swse-concept-action-lane__rows">
            {{#each group.actions as |feature|}}
              <div class="swse-combat-feature-row">
                <button type="button" class="swse-combat-feature-star {{#if feature.isFavorite}}is-favorite{{/if}}" data-action="toggle-combat-feature-favorite" data-feature-id="{{feature.id}}" title="Toggle favorite">{{#if feature.isFavorite}}★{{else}}☆{{/if}}</button>
                <button type="button"
                        class="swse-concept-action-button swse-combat-feature-button swse-combat-feature-main swse-combat-feature-button--{{feature.automationStatus}} {{#if feature.canExecute}}{{else}}is-reference-only{{/if}}"
                        data-action="{{feature.executeAction}}"
                        data-feature-id="{{feature.id}}"
                        data-feature-label="{{feature.name}}"
                        data-feature-summary="{{feature.summary}}"
                        data-source-name="{{feature.sourceName}}"
                        data-source-item-id="{{feature.sourceItemId}}"
                        data-action-group="{{feature.actionGroupId}}"
                        data-automation-status="{{feature.automationStatus}}"
                        data-readiness="{{feature.readiness}}"
                        data-action-cost="{{feature.actionCost}}"
                        title="{{#if feature.readinessNote}}{{feature.readinessNote}}{{else}}{{feature.summary}}{{/if}}">
                  <span class="swse-concept-action-button__icon" aria-hidden="true">◆</span>
                  <span class="swse-concept-action-button__copy">
                    <strong>{{feature.name}}</strong>
                    {{#if feature.summary}}<small>{{feature.summary}}</small>{{/if}}
                  </span>
                  <span class="swse-concept-action-button__cost">{{#if feature.actionCost}}{{feature.actionCost}}{{else}}{{group.id}}{{/if}}</span>
                </button>
              </div>
            {{/each}}
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="swse-concept-empty-state">
      <span class="swse-concept-empty-state__eyebrow">No combat feature actions</span>
      <strong>No available action-style combat features were classified for this actor.</strong>
    </div>
  {{/if}}

  {{#if combatFeatures.triggeredFeatureGroups.length}}
    <div class="swse-concept-action-board swse-combat-feature-section swse-combat-feature-section--triggered" data-combat-feature-section="triggeredFeatures">
      {{#each combatFeatures.triggeredFeatureGroups as |group|}}
        <article class="swse-concept-action-lane swse-action-lane--{{group.id}}" data-combat-feature-trigger-group="{{group.id}}" title="{{group.hint}}">
          <header class="swse-concept-action-lane__header">
            <strong>{{group.label}}</strong>
            <span>{{group.count}}</span>
          </header>
          <div class="swse-concept-action-lane__rows">
            {{#each group.features as |feature|}}
              <div class="swse-combat-feature-row">
                <button type="button" class="swse-combat-feature-star {{#if feature.isFavorite}}is-favorite{{/if}}" data-action="toggle-combat-feature-favorite" data-feature-id="{{feature.id}}" title="Toggle favorite">{{#if feature.isFavorite}}★{{else}}☆{{/if}}</button>
                <button type="button"
                        class="swse-concept-action-button swse-combat-feature-button swse-combat-feature-main swse-combat-feature-button--{{feature.automationStatus}} swse-combat-feature-button--{{feature.readiness}} is-reference-only"
                        data-action="view-combat-feature-details"
                        data-feature-id="{{feature.id}}"
                        data-feature-label="{{feature.name}}"
                        data-feature-summary="{{feature.result}}"
                        data-source-name="{{feature.sourceName}}"
                        data-source-item-id="{{feature.sourceItemId}}"
                        data-trigger-id="{{feature.triggerId}}"
                        data-trigger-group="{{feature.triggerGroupId}}"
                        data-trigger-label="{{feature.triggerLabel}}"
                        data-response-window="{{feature.responseWindow}}"
                        data-automation-status="{{feature.automationStatus}}"
                        data-readiness="{{feature.readiness}}"
                        title="{{feature.trigger}} {{feature.result}}">
                  <span class="swse-concept-action-button__icon" aria-hidden="true">◇</span>
                  <span class="swse-concept-action-button__copy">
                    <strong>{{feature.name}}</strong>
                    {{#if feature.triggerLabel}}<small>{{feature.triggerLabel}} — {{feature.responseWindow}}</small>{{else}}{{#if feature.trigger}}<small>{{feature.trigger}}</small>{{/if}}{{/if}}
                  </span>
                  <span class="swse-concept-action-button__cost">{{feature.readiness}}</span>
                </button>
              </div>
            {{/each}}
          </div>
        </article>
      {{/each}}
    </div>
  {{/if}}

  {{#if combatFeatures.passiveRiderGroups.length}}
    <div class="swse-concept-action-board swse-combat-feature-section swse-combat-feature-section--passive" data-combat-feature-section="passiveRiders">
      {{#each combatFeatures.passiveRiderGroups as |group|}}
        <article class="swse-concept-action-lane swse-action-lane--{{group.id}}" data-combat-feature-passive-group="{{group.id}}" title="{{group.hint}}">
          <header class="swse-concept-action-lane__header">
            <strong>{{group.label}}</strong>
            <span>{{group.automatedCount}} auto · {{group.partialCount}} partial · {{group.manualCount}} manual</span>
          </header>
          <div class="swse-concept-action-lane__rows">
            {{#each group.riders as |feature|}}
              <div class="swse-combat-feature-row">
                <button type="button" class="swse-combat-feature-star {{#if feature.isFavorite}}is-favorite{{/if}}" data-action="toggle-combat-feature-favorite" data-feature-id="{{feature.id}}" title="Toggle favorite">{{#if feature.isFavorite}}★{{else}}☆{{/if}}</button>
                <button type="button"
                        class="swse-concept-action-button swse-combat-feature-button swse-combat-feature-main swse-combat-feature-button--{{feature.automationStatus}} is-reference-only"
                        data-action="view-combat-feature-details"
                        data-feature-id="{{feature.id}}"
                        data-feature-label="{{feature.name}}"
                        data-feature-summary="{{feature.summary}}"
                        data-source-name="{{feature.sourceName}}"
                        data-source-item-id="{{feature.sourceItemId}}"
                        data-passive-group="{{feature.riderGroupId}}"
                        data-applies-to="{{feature.appliesTo}}"
                        data-automation-status="{{feature.automationStatus}}"
                        data-automation-hint="{{feature.automationHint}}"
                        title="{{feature.automationHint}} {{feature.summary}}">
                  <span class="swse-concept-action-button__icon" aria-hidden="true">▣</span>
                  <span class="swse-concept-action-button__copy">
                    <strong>{{feature.name}}</strong>
                    {{#if feature.summary}}<small>{{feature.summary}}</small>{{/if}}
                  </span>
                  <span class="swse-concept-action-button__cost">{{feature.automationLabel}} · {{feature.appliesTo}}</span>
                </button>
              </div>
            {{/each}}
          </div>
        </article>
      {{/each}}
    </div>
  {{/if}}
</section>
