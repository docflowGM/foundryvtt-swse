<section class="swse-concept-panel">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Defense Matrix</h3>
      <p class="swse-concept-panel__hint">Fortitude, Reflex, and Will totals with canonical breakdown lanes.</p>
    </div>
  </header>

  <div class="swse-concept-defense-matrix">
    {{#each conceptLayout.defenses as |def|}}
      <article class="swse-concept-panel swse-concept-panel--subledger swse-concept-defense-card">
        <div class="swse-concept-panel__header">
          <div>
            <h3 class="swse-concept-panel__title">{{def.label}}</h3>
            <p class="swse-concept-panel__hint">10 + ability + class + armor + misc + condition.</p>
          </div>
          <div class="swse-concept-ledger-row__actions">
            <span class="swse-concept-chip swse-concept-chip--neutral">{{def.abilityLabel}}</span>
            <strong class="swse-concept-defense-card__total {{def.totalClass}}">{{def.total}}</strong>
          </div>
        </div>

        {{> "systems/foundryvtt-swse/templates/actors/character/v2-concept/partials/panels/defense-breakdown-tooltip.hbs" defense=def}}
      </article>
    {{/each}}
  </div>
</section>
