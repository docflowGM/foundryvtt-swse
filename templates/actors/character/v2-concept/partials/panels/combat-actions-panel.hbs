<section class="swse-concept-panel swse-concept-panel--combat-actions-compact">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Combat Actions</h3>
      <p class="swse-concept-panel__hint">Compact action console grouped by economy lane.</p>
    </div>
    <span class="swse-concept-panel__eyebrow">Click to spend</span>
  </header>

  {{#if conceptLayout.combat.actionGroups.length}}
    <div class="swse-concept-action-board" data-combat-actions-board>
      {{#each conceptLayout.combat.actionGroups as |group|}}
        <article class="swse-concept-action-lane swse-action-lane--{{group.key}} {{group.availabilityClass}}" data-combat-action-group="{{group.key}}" title="{{group.availabilityTooltip}}">
          <header class="swse-concept-action-lane__header">
            <strong>{{group.label}}</strong>
            <span>{{group.availabilityLabel}}</span>
          </header>
          <div class="swse-concept-action-lane__rows">
            {{#each group.items as |item|}}
              <button type="button"
                      class="swse-concept-action-button {{#unless item.canUseNow}}is-disabled{{/unless}}"
                      data-action="swse-v2-use-action"
                      data-action-id="{{item.key}}"
                      data-action-type="{{item.actionType}}"
                      title="{{#if item.unavailableReason}}{{item.unavailableReason}}{{else}}{{item.description}}{{/if}}"
                      {{#unless item.canUseNow}}disabled{{/unless}}>
                <span class="swse-concept-action-button__icon" aria-hidden="true">◆</span>
                <span class="swse-concept-action-button__copy">
                  <strong>{{item.name}}</strong>
                  {{#if item.description}}<small>{{item.description}}</small>{{/if}}
                </span>
                <span class="swse-concept-action-button__cost">{{#if item.actionType}}{{item.actionType}}{{else}}{{group.key}}{{/if}}</span>
              </button>
            {{/each}}
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="swse-concept-empty-state">
      <span class="swse-concept-empty-state__eyebrow">No action cards</span>
      <strong>The actor currently has no grouped combat actions to surface here.</strong>
    </div>
  {{/if}}
</section>
