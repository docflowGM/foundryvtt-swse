<section class="swse-concept-panel swse-concept-panel--ledger swse-concept-panel--combat-actions">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Combat Actions</h3>
      <p class="swse-concept-panel__hint">Executable combat actions organized by economy lane.</p>
    </div>
  </header>

  {{#if conceptLayout.combat.actionGroups.length}}
    <div class="swse-concept-action-groups swse-concept-action-groups--combat" data-combat-actions-scroll>
      {{#each conceptLayout.combat.actionGroups as |group|}}
        <article class="swse-concept-action-group swse-concept-action-group--combat is-expanded" data-combat-action-group="{{group.key}}">
          <button type="button"
                  class="swse-concept-action-group__header swse-concept-action-group__toggle"
                  data-action="toggle-combat-action-group"
                  data-group="{{group.key}}"
                  aria-expanded="true">
            <strong>{{group.label}}</strong>
            <span>{{group.count}} entries</span>
            <i class="fas fa-chevron-down" aria-hidden="true"></i>
          </button>

          <div class="swse-concept-action-group__body">
            <div class="swse-concept-action-list">
              {{#each group.items as |item|}}
                <article class="swse-concept-action-row swse-concept-action-row--combat" data-action-key="{{item.key}}" data-action-type="{{item.actionType}}">
                  <div class="swse-concept-action-row__copy">
                    <strong>{{item.name}}</strong>
                    {{#if item.descriptionHtml}}
                      <small>{{{item.descriptionHtml}}}</small>
                    {{else if item.description}}
                      <small>{{item.description}}</small>
                    {{/if}}
                    {{#if item.resources.length}}
                      <div class="swse-concept-ledger-row__meta">
                        {{#each item.resources as |resource|}}
                          <span>{{resource}}</span>
                        {{/each}}
                      </div>
                    {{/if}}
                  </div>

                  <div class="swse-concept-action-row__actions">
                    {{#if item.itemId}}
                      <button type="button" class="swse-concept-btn" data-action="open-item" data-item-id="{{item.itemId}}">Inspect</button>
                    {{/if}}
                    {{#if item.executable}}
                      <button type="button" class="swse-concept-btn swse-concept-btn--primary" data-action="swse-v2-use-action" data-action-id="{{item.key}}" data-action-type="{{item.actionType}}">{{item.useLabel}}</button>
                    {{/if}}
                  </div>
                </article>
              {{/each}}
            </div>
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="swse-concept-empty-state">
      <span class="swse-concept-empty-state__eyebrow">No action cards</span>
      <strong>The actor currently has no grouped combat actions to surface here.</strong>
    </div>
  {{/if}}
</section>
