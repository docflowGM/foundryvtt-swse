<section class="swse-concept-panel swse-concept-panel--ledger swse-concept-panel--class-features">
  <header class="swse-concept-panel__header">
    <div>
      <h3 class="swse-concept-panel__title">Class Features</h3>
      <p class="swse-concept-panel__hint">Non-feat, non-talent class features granted by class progression.</p>
    </div>
    <div class="swse-concept-ledger-row__actions">
      <span class="swse-concept-chip swse-concept-chip--neutral">{{conceptLayout.talents.classFeatureCount}} Features</span>
    </div>
  </header>

  {{#if conceptLayout.talents.classFeatureGroups.length}}
    <div class="swse-concept-tree-stack">
      {{#each conceptLayout.talents.classFeatureGroups as |group|}}
        <article class="swse-concept-action-group swse-concept-action-group--class-feature">
          <div class="swse-concept-action-group__header">
            <strong>{{group.label}}</strong>
            <span>{{group.count}}</span>
          </div>

          <div class="swse-concept-action-list">
            {{#each group.entries as |feature|}}
              <div class="swse-concept-action-row swse-concept-action-row--class-feature">
                <div class="swse-concept-action-row__copy">
                  <strong>{{feature.name}}</strong>
                  <small>{{feature.description}}</small>
                </div>
                <div class="swse-concept-action-row__actions">
                  {{#if feature.levelLabel}}<span class="swse-concept-chip swse-concept-chip--neutral">{{feature.levelLabel}}</span>{{/if}}
                  {{#if feature.typeLabel}}<span class="swse-concept-chip swse-concept-chip--neutral">{{feature.typeLabel}}</span>{{/if}}
                  {{#if feature.itemId}}
                    <button type="button" class="swse-concept-btn" data-action="open-ability" data-item-id="{{feature.itemId}}">Inspect</button>
                  {{else}}
                    <span class="swse-concept-chip swse-concept-chip--neutral">Class Ledger</span>
                  {{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="swse-concept-empty-state">
      <span class="swse-concept-empty-state__eyebrow">No class features recorded</span>
      <strong>Class progression features such as Mark, Defense Bonuses, or other automatic class abilities will appear here.</strong>
    </div>
  {{/if}}
</section>
