{{!--
  Shared holopad/tablet frame opening.
  Pair with templates/shell/partials/holopad-frame-close.hbs.
  Player actor shell and GM Datapad both consume this same physical chrome.
--}}
<div class="{{frameOuterClass}}"{{#if frameDataSheetForm}} data-sheet-form="{{frameDataSheetForm}}"{{/if}}{{#if frameDataConceptSource}} data-concept-source="{{frameDataConceptSource}}"{{/if}}{{#if frameDataApp}} data-app="{{frameDataApp}}"{{/if}} data-theme="{{shellTheme}}" data-motion-style="{{shellMotionStyle}}" style="{{{frameStyleInline}}}; {{{frameStyleInlineExtra}}};">
  <div class="swse-sheet-v2-shell swse-sheet-v2-shell--concept sheet-shell swse-sheet-v2-shell--surface-{{shellSurface}} {{shellExtraClass}}" data-shell-surface="{{shellSurface}}" data-theme="{{shellTheme}}" data-motion-style="{{shellMotionStyle}}" style="{{{shellStyleInline}}}; {{{shellStyleInlineExtra}}};">
    <div class="swse-v2-tablet swse-v2-tablet--concept {{tabletExtraClass}}">
      <div class="swse-tablet-rivet swse-tablet-rivet--tl" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--tr" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--bl" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--br" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--ml" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--mr" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--top-a" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--top-b" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--right-a" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--right-b" aria-hidden="true"></div>
      <div class="swse-tablet-camera" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--a" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--b" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--c" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--d" aria-hidden="true"></div>

      <div class="swse-tablet-top-bezel" data-action="tablet-drag" title="{{#if dragTitle}}{{dragTitle}}{{else}}Drag datapad. Double-click to minimize.{{/if}}" data-shell-chrome="top" aria-label="{{#if dragLabel}}{{dragLabel}}{{else}}Datapad drag rail. Double-click to minimize.{{/if}}">
        <div class="swse-tablet-drag-handle" data-action="tablet-drag" aria-hidden="true"></div>
      </div>

      <div class="swse-tablet-hardware-rail swse-tablet-top-right-rail swse-tablet-window-controls swse-tablet-no-drag" data-shell-window-control="true" data-no-drag="true" draggable="false" aria-label="{{#if controlsLabel}}{{controlsLabel}}{{else}}Tablet identity and window controls{{/if}}">
        <span class="swse-tablet-serial swse-tablet-serial--aurebesh" aria-label="{{#if serialAria}}{{serialAria}}{{else}}SN 4471-0EA-00827{{/if}}">{{#if serialLabel}}{{serialLabel}}{{else}}SN4471-0EA-00827{{/if}}</span>
        <span class="swse-tablet-status-lights" aria-hidden="true"><span></span><span></span><span></span></span>
        <button type="button" class="swse-tablet-control swse-tablet-control--home swse-tablet-no-drag" data-shell-window-control="true" data-no-drag="true" draggable="false" data-action="{{#if topHomeAction}}{{topHomeAction}}{{else}}tablet-home{{/if}}"{{#if topHomeNavTo}} data-nav-to="{{topHomeNavTo}}"{{/if}} title="Home" aria-label="Home"><span class="swse-tablet-control__home-glyph" aria-hidden="true"></span></button>
        <button type="button" class="swse-tablet-control swse-tablet-control--minimize swse-tablet-no-drag" data-shell-window-control="true" data-no-drag="true" draggable="false" data-action="{{#if minimizeAction}}{{minimizeAction}}{{else}}tablet-minimize{{/if}}" title="Minimize" aria-label="Minimize">−</button>
        <button type="button" class="swse-tablet-control swse-tablet-control--expand swse-tablet-no-drag" data-shell-window-control="true" data-no-drag="true" draggable="false" data-action="{{#if expandAction}}{{expandAction}}{{else}}tablet-expand{{/if}}" title="Expand" aria-label="Expand">⛶</button>
        <button type="button" class="swse-tablet-control swse-tablet-control--close swse-tablet-no-drag" data-shell-window-control="true" data-no-drag="true" draggable="false" data-action="{{#if closeAction}}{{closeAction}}{{else}}tablet-close{{/if}}" title="Close" aria-label="Close">×</button>
      </div>

      <div class="swse-tablet-vent swse-tablet-vent--top" aria-hidden="true"><span></span><span></span><span></span><span></span></div>

      <div class="swse-v2-screen swse-v2-screen--concept {{screenExtraClass}}">
        <div class="scan-v" aria-hidden="true"></div>
        <div class="corner tl" aria-hidden="true"></div>
        <div class="corner tr" aria-hidden="true"></div>
        <div class="corner bl" aria-hidden="true"></div>
        <div class="corner br" aria-hidden="true"></div>
