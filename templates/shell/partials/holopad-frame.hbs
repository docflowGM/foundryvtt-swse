{{!--
  holopad-frame.hbs

  Unified metallic holopad shell frame for all SWSE player-facing applications.

  This partial renders the complete holopad device chrome:
  - Metallic outer tablet body
  - Flush display area (zero gap to metal)
  - Hardware controls (close, expand, home buttons)
  - Bezel accoutrements (rivets, LEDs, labels, vents)
  - Viewport scaling for responsive display
  - Theme and motion style inheritance

  Parameters:
  - theme (string): CSS theme class, e.g. "holo-cyan", "imperial", "rebel"
  - motionStyle (string): Animation setting: "standard", "reduced", "off"
  - showHome (boolean): Whether to render home button (default: true)
  - homeRoute (string): data-action for home button (default: "tablet-home")

  Content:
  - {{@partial-block}}: Application-specific content rendered inside the flush display area

  Usage:
  {{#> "systems/foundryvtt-swse/templates/shell/partials/holopad-frame.hbs"
        theme=sheetTheme
        motionStyle=sheetMotionStyle}}
    {{!-- app content here --}}
  {{/> }}
--}}

<form class="swse-character-sheet-form swse-character-sheet-form-root swse-sheet-ui swse-sheet swse-sheet--concept" autocomplete="off">
  <div class="window-content">
    <div class="swse-tablet-scale-host">
      <div class="swse-tablet-scale-stage">
        <div class="swse-sheet-v2-shell swse-sheet-v2-shell--concept sheet-shell" data-theme="{{theme}}" data-motion-style="{{motionStyle}}">

          {{!-- TABLET HARDWARE CONTROLS — functional buttons on the metallic body --}}
          <div class="swse-tablet-hardware swse-tablet-hardware--top" aria-label="Tablet window controls">
            <button type="button" class="swse-tablet-control swse-tablet-control--close" data-action="tablet-close" title="Close" aria-label="Close">×</button>
            <button type="button" class="swse-tablet-control swse-tablet-control--expand" data-action="tablet-expand" title="Expand" aria-label="Expand">⛶</button>
          </div>

          {{!-- TABLET BEZEL DETAILS — subtle decorative hardware texture on the body --}}
          <div class="swse-tablet-bezel-detail swse-tablet-bezel-detail--top-left" aria-hidden="true">
            <span class="swse-tablet-rivet"></span>
            <span class="swse-tablet-micro-led"></span>
          </div>

          <div class="swse-tablet-bezel-detail swse-tablet-bezel-detail--top-right" aria-hidden="true">
            <span class="swse-tablet-serial">SN 4471-0EA-00827</span>
            <span class="swse-tablet-rivet"></span>
          </div>

          <div class="swse-tablet-micro-label swse-tablet-micro-label--lower-left" aria-hidden="true">
            SWSE-HOLOPAD // MK-VII
          </div>

          <div class="swse-tablet-vent" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>

          {{!-- FLUSH SCREEN DISPLAY — content viewport with zero gap to metal shell --}}
          <div class="swse-v2-tablet swse-v2-tablet--concept">
            <div class="swse-v2-screen swse-v2-screen--concept">
              <div class="scan-v" aria-hidden="true"></div>
              <div class="corner tl" aria-hidden="true"></div>
              <div class="corner tr" aria-hidden="true"></div>
              <div class="corner bl" aria-hidden="true"></div>
              <div class="corner br" aria-hidden="true"></div>

              {{!-- APPLICATION CONTENT SLOT --}}
              {{#if @partial-block}}
                {{@partial-block}}
              {{else}}
                <div class="swse-concept-main sheet-body sheet-content" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; color: var(--swse-concept-text-dim, #8fd7ef); font-size: 14px;">
                  <p>No application loaded</p>
                </div>
              {{/if}}
            </div>{{!-- /swse-v2-screen --}}

            {{!-- Physical Home button — bottom center of tablet body --}}
            {{#if (ne showHome false)}}
            <button type="button" class="swse-tablet-home-button" data-action="{{homeRoute}}" title="Home" aria-label="Home">
              <span class="swse-tablet-home-button__glyph"></span>
            </button>
            {{/if}}

            <div class="swse-tablet-vent" aria-hidden="true">
              <span></span><span></span><span></span><span></span>
            </div>
          </div>{{!-- /swse-v2-tablet --}}

        </div>{{!-- /swse-sheet-v2-shell --}}
      </div>{{!-- /swse-tablet-scale-stage --}}
    </div>{{!-- /swse-tablet-scale-host --}}
  </div>{{!-- /window-content --}}
</form>
