{{!--
  surface-store.hbs
  Shell-native store surface. Concept-aligned layout, live store data.
  Phase 3: Datapad chrome and hierarchical layout with browse grid + side rail.
--}}

<div class="swse-shell-surface swse-shell-surface--store"
     data-shell-region="surface-store"
     data-surface-id="{{vm.id}}">

  {{#if vm.error}}
  <div class="swse-store-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>{{vm.error}}</span>
  </div>
  {{else if vm.storeContext}}

  {{!-- Store splash is intentionally bypassed for stability. Deprecated path retained in templates/apps/store/store-splash.hbs. --}}
  <section class="swse-store-surface"
           data-theme="{{vm.sheetTheme}}"
           data-motion-style="{{vm.sheetMotionStyle}}"
           style="{{vm.surfaceStyleInline}}">
    <form class="swse-store-surface__tablet" autocomplete="off">
      <div class="swse-store-surface__scan-v" aria-hidden="true"></div>
      <span class="swse-store-surface__corner swse-store-surface__corner--tl" aria-hidden="true"></span>
      <span class="swse-store-surface__corner swse-store-surface__corner--tr" aria-hidden="true"></span>
      <span class="swse-store-surface__corner swse-store-surface__corner--bl" aria-hidden="true"></span>
      <span class="swse-store-surface__corner swse-store-surface__corner--br" aria-hidden="true"></span>

      <header class="swse-store-surface__hud">
        <button class="swse-store-surface__hud-back" data-shell-action="return-to-home" type="button" title="Return to Home">
          <i class="fas fa-arrow-left"></i> HOME
        </button>
        <div class="swse-store-surface__hud-center">
          <span class="swse-store-surface__signal"><span></span><span></span><span></span><span></span></span>
          <span class="swse-store-surface__hud-title">RENDARR'S EXCHANGE</span>
          <span class="swse-store-surface__hud-dot {{#if vm.storeContext.cartCount}}warn{{/if}}"></span>
        </div>
        <div class="swse-store-surface__hud-right">
          <span class="swse-store-surface__hud-lbl">RESERVE</span>
          <span class="swse-store-surface__hud-credits">{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
        </div>
      </header>

      <header class="swse-store-surface__hero">
        <div class="swse-store-surface__rendarr-portrait">
          {{#if vm.storeContext.rendarrImage}}
          <img src="{{vm.storeContext.rendarrImage}}" alt="Rendarr" class="swse-store-surface__rendarr-img"/>
          {{else}}
          <svg viewBox="0 0 64 64" class="swse-store-surface__rendarr-svg"><circle cx="32" cy="24" r="14" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 60 Q32 38 56 60" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
          {{/if}}
        </div>
        <div class="swse-store-surface__rendarr-meta">
          <div class="swse-store-surface__rendarr-name"><span class="swse-store-surface__rendarr-mark">⚡</span>RENDARR'S EXCHANGE</div>
          <div class="swse-store-surface__rendarr-sub">Quartermaster · Galactic Trade Network</div>
          <div class="swse-store-surface__rendarr-quote">
            {{#if vm.storeContext.rendarrWelcome}}"{{vm.storeContext.rendarrWelcome}}"{{else}}"What can I do for you today?"{{/if}}
          </div>
        </div>
        <div class="swse-store-surface__credits-block">
          <span class="swse-store-surface__credits-lbl">ACCOUNT</span>
          <span class="swse-store-surface__credits-val">{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
          {{#if vm.storeContext.cartCount}}
          <span class="swse-store-surface__credits-delta neg">−{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span> staged</span>
          <span class="swse-store-surface__credits-reserve">{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span> after</span>
          {{/if}}
        </div>
      </header>

      <nav class="swse-store-surface__tabs">
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'browse')}}active{{/if}} {{#if vm.storeContext.selectedProduct}}active{{/if}}" data-ss-tab="browse">
          <span class="swse-store-surface__tab-glyph">⊞</span> BROWSE
        </button>
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'cart')}}active{{/if}}" data-ss-tab="cart">
          <span class="swse-store-surface__tab-glyph">◳</span> CART
          {{#if vm.storeContext.cartCount}}<span class="swse-store-surface__tab-count">{{vm.storeContext.cartCount}}</span>{{/if}}
        </button>
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'checkout')}}active{{/if}}" data-ss-tab="checkout">
          <span class="swse-store-surface__tab-glyph">◈</span> CHECKOUT
        </button>
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'history')}}active{{/if}}" data-ss-tab="history">
          <span class="swse-store-surface__tab-glyph">◎</span> HISTORY
        </button>
      </nav>

      <main class="swse-store-surface__screen">

        {{#if vm.storeContext.isBrowseOrDetail}}
        <section class="swse-store-surface__filters">
          <div class="swse-store-surface__filter-search">
            <i class="fas fa-search swse-store-surface__filter-ico"></i>
            <input type="text" id="ss-search" class="swse-store-surface__search-input" placeholder="SEARCH LISTINGS…" aria-label="Search store" value="{{vm.storeContext.filters.search}}"/>
          </div>
          <div class="swse-store-surface__filter-group">
            <span class="swse-store-surface__filter-lbl">AVAIL</span>
            <select id="ss-avail" class="swse-store-surface__select">
              <option value="all">All</option>
              <option value="standard">Standard</option>
              <option value="licensed">Licensed</option>
              <option value="restricted">Restricted</option>
              <option value="military">Military</option>
              <option value="illegal">Illegal</option>
              <option value="rare">Rare</option>
            </select>
          </div>
          <div class="swse-store-surface__filter-group">
            <span class="swse-store-surface__filter-lbl">SORT</span>
            <select id="ss-sort" class="swse-store-surface__select">
              <option value="default">Best Match</option>
              <option value="price-asc">Price ↑</option>
              <option value="price-desc">Price ↓</option>
              <option value="name-asc">Name A–Z</option>
            </select>
          </div>
          <div class="swse-store-surface__filter-count">
            <span data-results-count>{{vm.storeContext.renderedItemCount}}</span>/<span>{{vm.storeContext.visibleItemCount}}</span> listings
          </div>
          <button type="button" class="swse-store-surface__filter-clear" data-action="clear-filters">✕ CLEAR</button>
        </section>

        <nav class="swse-store-surface__category-tabs">
          <button type="button" class="swse-store-surface__category-chip {{#unless vm.storeContext.currentCategory}}active{{/unless}}" data-action="category-nav" data-category="">ALL</button>
          {{#each vm.storeContext.categorySummary}}
          <button type="button" class="swse-store-surface__category-chip {{#if (eq ../vm.storeContext.currentCategory key)}}active{{/if}}" data-action="category-nav" data-category="{{key}}">
            {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
          </button>
          {{/each}}
        </nav>

        {{!-- Phase 2: Secondary navigation for subcategories --}}
        {{#if vm.storeContext.navigationModel.topCategories}}
        {{#each vm.storeContext.navigationModel.topCategories}}
        {{#if (eq key ../vm.storeContext.currentCategory)}}
        {{#if children}}
        <nav class="swse-store-surface__subnav">
          {{!-- "All [Category]" reset chip --}}
          <button type="button" class="swse-store-surface__subcat-chip {{#unless ../../../vm.storeContext.currentSubcategory}}active{{/unless}}" data-action="subcategory-nav" data-subcategory="" data-family="">
            All {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
          </button>

          {{#if (eq key 'weapons')}}
          {{!-- WEAPONS: Group by family (Melee/Ranged) --}}
          {{#if familyGroups.melee}}
          <div class="swse-store-surface__family-group">
            <div class="swse-store-surface__family-label">Melee</div>
            <div class="swse-store-surface__family-chips">
              {{#each familyGroups.melee}}
              <button type="button" class="swse-store-surface__subcat-chip {{#if (eq label ../../../../vm.storeContext.currentSubcategory)}}active{{/if}}"
                      data-action="subcategory-nav" data-subcategory="{{label}}" data-family="{{family}}">
                {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
              </button>
              {{/each}}
            </div>
          </div>
          {{/if}}

          {{#if familyGroups.ranged}}
          <div class="swse-store-surface__family-group">
            <div class="swse-store-surface__family-label">Ranged</div>
            <div class="swse-store-surface__family-chips">
              {{#each familyGroups.ranged}}
              <button type="button" class="swse-store-surface__subcat-chip {{#if (eq label ../../../../vm.storeContext.currentSubcategory)}}active{{/if}}"
                      data-action="subcategory-nav" data-subcategory="{{label}}" data-family="{{family}}">
                {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
              </button>
              {{/each}}
            </div>
          </div>
          {{/if}}

          {{else}}
          {{!-- OTHER CATEGORIES: List all subcategories --}}
          {{#each children}}
          <button type="button" class="swse-store-surface__subcat-chip {{#if (eq label ../../../vm.storeContext.currentSubcategory)}}active{{/if}}"
                  data-action="subcategory-nav" data-subcategory="{{label}}" data-family="{{family}}">
            {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
          </button>
          {{/each}}
          {{/if}}
        </nav>
        {{/if}}
        {{/if}}
        {{/each}}
        {{/if}}

        <section class="swse-store-surface__browse swse-store-surface__browse-layout">
          <div class="swse-store-surface__grid swse-store-surface__cards-grid">

            {{#each vm.storeContext.allItems}}
            <div class="swse-store-surface__card swse-store-surface__card--rar-{{this.rarityClass}} {{#if (eq ../vm.storeContext.selectedProductId this.id)}}is-selected{{/if}}"
                 data-item-id="{{this.id}}"
                 data-item-type="{{this.type}}"
                 data-name="{{this.name}}"
                 data-category="{{this.category}}"
                 data-category-key="{{this.categoryKey}}"
                 data-subcategory="{{this.subcategory}}"
                 data-subcategory-key="{{this.subcategoryKey}}"
                 data-availability="{{this.availability}}"
                 data-price="{{#if this.cost}}{{this.cost}}{{else}}{{this.finalCost}}{{/if}}"
                 data-score="{{#if this.suggestion}}{{this.suggestion.score}}{{else}}0{{/if}}">
              <span class="swse-store-surface__card-rar-tag">{{this.rarityLabel}}</span>
              <div class="swse-store-surface__card-hero" aria-hidden="true">
                <div class="swse-store-surface__card-glyph-panel">
                  <span class="swse-store-surface__card-glyph">{{#if this.cardLetter}}{{this.cardLetter}}{{else}}{{this.glyph}}{{/if}}</span>
                </div>
                <span class="swse-store-surface__card-glyph-label">{{#if this.glyphLabel}}{{this.glyphLabel}}{{else}}{{this.typeLabel}}{{/if}}</span>
              </div>
              <div class="swse-store-surface__card-body">
                <div class="swse-store-surface__card-name">{{this.name}}</div>
                <div class="swse-store-surface__card-cat">{{this.typeLabel}} · {{this.category}}{{#if this.subcategory}} · {{this.subcategory}}{{/if}}</div>
                <div class="swse-store-surface__card-meta-row">
                  <span class="swse-store-surface__card-meta-pill">{{this.availability}}</span>
                  {{#if this.suggestion.tierLabel}}<span class="swse-store-surface__card-tier swse-store-surface__card-tier--{{this.suggestion.tier}}">{{this.suggestion.tierLabel}}</span>{{/if}}
                </div>
              </div>
              <div class="swse-store-surface__card-foot">
                {{#if this.costUsed}}
                <span class="swse-store-surface__card-price">NEW {{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span> · USED {{this.costUsed}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
                {{else}}
                <span class="swse-store-surface__card-price">{{this.finalCost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
                {{/if}}
                <div class="swse-store-surface__card-actions">
                  <button type="button" class="swse-store-surface__card-btn" data-action="expand-product" data-item-id="{{this.id}}">{{#if (eq ../vm.storeContext.selectedProductId this.id)}}COLLAPSE{{else}}DETAILS{{/if}}</button>
                  {{#if (eq this.type 'vehicle')}}
                  <button type="button" class="swse-store-surface__card-btn" data-action="add-to-cart" data-item-id="{{this.id}}" data-item-type="vehicle" data-condition="used">USED</button>
                  <button type="button" class="swse-store-surface__card-btn swse-store-surface__card-btn--primary" data-action="add-to-cart" data-item-id="{{this.id}}" data-item-type="vehicle" data-condition="new">NEW</button>
                  {{else}}
                  <button type="button" class="swse-store-surface__card-btn swse-store-surface__card-btn--primary" data-action="add-to-cart" data-item-id="{{this.id}}" data-item-type="{{this.type}}">+ ADD</button>
                  {{/if}}
                </div>
              </div>
              {{#if (eq ../vm.storeContext.selectedProductId this.id)}}
              <div class="swse-store-surface__card-selected-note">
                <span>LISTING ROUTED TO DETAIL RAIL</span>
              </div>
              {{/if}}
            </div>
            {{/each}}
            {{#if vm.storeContext.hasMoreItems}}
            <div class="swse-store-surface__load-more-row">
              <button type="button" class="swse-store-surface__load-more" data-action="store-load-more" data-next-limit="{{vm.storeContext.nextRenderLimit}}">
                LOAD MORE STOCK → <span>{{vm.storeContext.renderedItemCount}}/{{vm.storeContext.visibleItemCount}}</span>
              </button>
            </div>
            {{/if}}
          </div>

          {{!-- Side rail: listing inspection + commerce rail. --}}
          <aside class="swse-store-surface__rail">
            <section class="swse-store-surface__side-card swse-store-surface__detail-card {{#if vm.storeContext.selectedProduct}}is-active{{else}}is-empty{{/if}}">
              <div class="swse-store-surface__side-head">
                <span>◇ Listing Inspect</span>
                <span class="hint">{{#if vm.storeContext.selectedProduct}}selected{{else}}idle{{/if}}</span>
              </div>
              {{#if vm.storeContext.selectedProduct}}
              <div class="swse-store-surface__detail-shell">
                <div class="swse-store-surface__detail-topline">
                  <div class="swse-store-surface__detail-glyph">
                    <span>{{#if vm.storeContext.selectedProduct.cardLetter}}{{vm.storeContext.selectedProduct.cardLetter}}{{else}}{{vm.storeContext.selectedProduct.glyph}}{{/if}}</span>
                    <small>{{#if vm.storeContext.selectedProduct.glyphLabel}}{{vm.storeContext.selectedProduct.glyphLabel}}{{else}}{{vm.storeContext.selectedProduct.typeLabel}}{{/if}}</small>
                  </div>
                  <div class="swse-store-surface__detail-title-block">
                    <div class="swse-store-surface__detail-name">{{vm.storeContext.selectedProduct.name}}</div>
                    <div class="swse-store-surface__detail-subtitle">{{vm.storeContext.selectedProduct.typeLabel}} · {{vm.storeContext.selectedProduct.category}}{{#if vm.storeContext.selectedProduct.subcategory}} · {{vm.storeContext.selectedProduct.subcategory}}{{/if}}</div>
                    <div class="swse-store-surface__detail-tags">
                      <span>{{vm.storeContext.selectedProduct.rarityLabel}}</span>
                      <span>{{vm.storeContext.selectedProduct.availability}}</span>
                      {{#if vm.storeContext.selectedProduct.suggestionTierLabel}}<span>{{vm.storeContext.selectedProduct.suggestionTierLabel}}</span>{{/if}}
                    </div>
                  </div>
                  <button type="button" class="swse-store-surface__detail-close" data-action="detail-back" title="Clear selected listing">×</button>
                </div>

                <div class="swse-store-surface__detail-price-strip">
                  {{#each vm.storeContext.selectedProductDetail.priceOptions}}
                  <div class="swse-store-surface__detail-price-option">
                    <span>{{label}}</span>
                    <strong>{{valueLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></strong>
                  </div>
                  {{/each}}
                </div>

                <div class="swse-store-surface__detail-summary">{{vm.storeContext.selectedProductDetail.summary}}</div>

                {{#if vm.storeContext.selectedProductDetail.rows.length}}
                <div class="swse-store-surface__detail-specs">
                  {{#each vm.storeContext.selectedProductDetail.rows}}
                  <div class="swse-store-surface__detail-spec-row"><span>{{label}}</span><strong>{{value}}</strong></div>
                  {{/each}}
                </div>
                {{/if}}

                {{#if vm.storeContext.selectedProduct.suggestionBullets.length}}
                <div class="swse-store-surface__detail-section">
                  <div class="swse-store-surface__detail-section-title">Fit Notes</div>
                  <ul class="swse-store-surface__detail-bullets">
                    {{#each vm.storeContext.selectedProduct.suggestionBullets}}<li>{{this}}</li>{{/each}}
                  </ul>
                </div>
                {{/if}}

                {{#if vm.storeContext.selectedProduct.techDetailsHtml}}
                <div class="swse-store-surface__detail-section swse-store-surface__detail-section--scroll">
                  <div class="swse-store-surface__detail-section-title">Technical Readout</div>
                  {{{vm.storeContext.selectedProduct.techDetailsHtml}}}
                </div>
                {{/if}}

                {{#if vm.storeContext.selectedProduct.flavorReviewsHtml}}
                <div class="swse-store-surface__detail-section swse-store-surface__detail-section--scroll">
                  <div class="swse-store-surface__detail-section-title">Marketplace Reviews</div>
                  {{{vm.storeContext.selectedProduct.flavorReviewsHtml}}}
                </div>
                {{/if}}

                <div class="swse-store-surface__detail-actions">
                  {{#if (eq vm.storeContext.selectedProduct.type 'vehicle')}}
                  <button type="button" class="swse-store-surface__rail-btn" data-action="add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="vehicle" data-condition="used">USED MODEL</button>
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="vehicle" data-condition="new">NEW MODEL</button>
                  <button type="button" class="swse-store-surface__rail-btn" data-action="store-build-from-scratch" data-builder-kind="vehicle">BUILD FROM SCRATCH</button>
                  {{else}}
                  {{#if (eq vm.storeContext.selectedProduct.type 'droid')}}
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="detail-add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="droid">ADD DROID</button>
                  <button type="button" class="swse-store-surface__rail-btn" data-action="store-build-from-scratch" data-builder-kind="droid">BUILD FROM SCRATCH</button>
                  {{else}}
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="detail-add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="{{vm.storeContext.selectedProduct.type}}">ADD TO CART</button>
                  {{/if}}
                  {{/if}}
                </div>
              </div>
              {{else}}
              <div class="swse-store-surface__detail-empty">
                <div class="swse-store-surface__detail-empty-glyph">⌁</div>
                <div class="swse-store-surface__detail-empty-title">No listing selected</div>
                <div class="swse-store-surface__detail-empty-copy">Click any market card to route its stats, pricing, and notes into this rail.</div>
              </div>
              {{/if}}
            </section>
            {{#if vm.storeContext.hasBuilderActions}}
            <section class="swse-store-surface__side-card swse-store-surface__builder-card">
              <div class="swse-store-surface__side-head">
                <span>Custom Build</span>
                <span class="hint">Scratch</span>
              </div>
              <div class="swse-store-surface__builder-actions">
                {{#each vm.storeContext.builderActions}}
                <button type="button"
                        class="swse-store-surface__builder-btn swse-store-surface__builder-btn--{{tone}}"
                        data-action="store-build-from-scratch"
                        data-builder-kind="{{key}}">
                  <span class="swse-store-surface__builder-icon">{{icon}}</span>
                  <span class="swse-store-surface__builder-copy">
                    <strong>{{label}}</strong>
                    <small>{{sublabel}}</small>
                  </span>
                </button>
                {{/each}}
              </div>
            </section>
            {{/if}}

            <section class="swse-store-surface__side-card swse-store-surface__cart-card">
              <div class="swse-store-surface__side-head">
                <span>◇ Cart</span>
                <span class="hint">{{#if vm.storeContext.cartCount}}{{vm.storeContext.cartCount}} staged{{else}}empty{{/if}}</span>
              </div>
              <div class="swse-store-surface__mini-cart">
                {{#if vm.storeContext.cartEntries.length}}
                <div class="swse-store-surface__mini-cart-list">
                  {{#each vm.storeContext.cartEntries}}
                  <div class="swse-store-surface__mini-cart-item">
                    <div class="swse-store-surface__mini-cart-name">{{this.name}}</div>
                    <div class="swse-store-surface__mini-cart-qty">×{{this.qty}}</div>
                    <div class="swse-store-surface__mini-cart-price">{{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></div>
                  </div>
                  {{/each}}
                </div>
                <div class="swse-store-surface__mini-cart-summary">
                  <div class="swse-store-surface__mini-cart-row"><span>SUBTOTAL</span><strong>{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></strong></div>
                  <div class="swse-store-surface__mini-cart-row"><span>AFTER HAUL</span><strong>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></strong></div>
                </div>
                <div class="swse-store-surface__rail-actions">
                  <button type="button" class="swse-store-surface__rail-btn" data-ss-tab="cart">▸ OPEN CART</button>
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="proceed-checkout" {{#if vm.storeContext.checkoutBlocked}}disabled aria-disabled="true" title="{{vm.storeContext.checkoutBlockedReason}}"{{/if}}>SETTLE</button>
                </div>
                {{else}}
                <div class="swse-store-surface__mini-cart-empty">
                  <div class="swse-store-surface__mini-cart-empty-glyph">◳</div>
                  <div class="swse-store-surface__mini-cart-empty-msg">No items staged</div>
                  <div class="swse-store-surface__mini-cart-empty-sub">Click a card's <span>+ ADD</span> to start a haul.</div>
                </div>
                <div class="swse-store-surface__rail-actions">
                  <button type="button" class="swse-store-surface__rail-btn" data-ss-tab="browse">▸ BROWSE FLOOR</button>
                </div>
                {{/if}}
              </div>
            </section>

            <section class="swse-store-surface__side-card swse-store-surface__wallet-card">
              <div class="swse-store-surface__side-head">
                <span>◇ Wallet</span>
                <span class="hint">SAGA std.</span>
              </div>
              <div class="swse-store-surface__wallet-grid">
                <div class="swse-store-surface__wallet-cell">
                  <span>Balance</span>
                  <strong>{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></strong>
                </div>
                <div class="swse-store-surface__wallet-cell {{#if vm.storeContext.cartRemainingNeg}}neg{{else}}pos{{/if}}">
                  <span>After Haul</span>
                  <strong>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></strong>
                </div>
              </div>
            </section>

            <section class="swse-store-surface__side-card swse-store-surface__market-card">
              <div class="swse-store-surface__side-head">
                <span>◇ Market Feed</span>
                <span class="hint">Live</span>
              </div>
              <div class="swse-store-surface__market-line"><span>Category</span><strong>{{vm.storeContext.currentCategoryLabel}}</strong></div>
              <div class="swse-store-surface__market-line"><span>Listings</span><strong>{{vm.storeContext.visibleItemCount}}</strong></div>
              <div class="swse-store-surface__market-line"><span>Rendered</span><strong>{{vm.storeContext.renderedItemCount}}</strong></div>
            </section>

            <section class="swse-store-surface__side-card swse-store-surface__chatter-card">
              <div class="swse-store-surface__side-head">
                <span>◇ Floor Chatter</span>
                <span class="hint">live</span>
              </div>
              <div class="swse-store-surface__ticker" aria-label="Store chatter feed">
                <div class="swse-store-surface__ticker-track">
                  <span>Rendarr: No refunds on thermal detonators.</span>
                  <span>Outer Rim surplus just cleared customs.</span>
                  <span>Licensed stock may need GM approval.</span>
                  <span>Used vehicles are inspected, not blessed.</span>
                </div>
              </div>
            </section>

          </aside>
        </section>

        <div class="swse-store-surface__empty" style="display:none">
          <div class="swse-store-surface__empty-glyph">◌</div>
          <div class="swse-store-surface__empty-msg">No listings match the current filters.</div>
          <div class="swse-store-surface__empty-sub">Try another category or clear the search parameters.</div>
        </div>
        {{/if}}

        {{#if (eq vm.storeContext.currentView 'cart')}}
        <section class="swse-store-surface__pane swse-store-surface__pane-cart">
          {{#if vm.storeContext.cartEntries.length}}
          <div class="swse-store-surface__cart-list">
            {{#each vm.storeContext.cartEntries}}
            <div class="swse-store-surface__cart-row">
              {{#if this.img}}<img class="swse-store-surface__cart-img" src="{{this.img}}" alt="{{this.name}}"/>{{else}}<div class="swse-store-surface__cart-glyph">{{this.glyph}}</div>{{/if}}
              <div class="swse-store-surface__cart-meta">
                <div class="swse-store-surface__cart-name">{{this.name}}</div>
                <div class="swse-store-surface__cart-type">{{this.summary}}</div>
              </div>
              <div class="swse-store-surface__cart-qty">×{{this.qty}}</div>
              <div class="swse-store-surface__cart-linecost">{{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></div>
              <button type="button" class="swse-store-surface__btn swse-store-surface__btn--ghost" data-action="remove-from-cart" data-item-id="{{this.id}}" data-item-type="{{this.itemType}}" data-condition="{{this.condition}}">REMOVE</button>
            </div>
            {{/each}}
          </div>
          <div class="swse-store-surface__cart-summary">
            <div class="swse-store-surface__cart-summary-row">
              <span>TOTAL</span>
              <span class="swse-store-surface__cart-total">{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
            </div>
            <div class="swse-store-surface__cart-summary-row dim">
              <span>AVAILABLE</span>
              <span>{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
            </div>
            <div class="swse-store-surface__cart-summary-row {{#if vm.storeContext.cartRemainingNeg}}neg{{else}}pos{{/if}}">
              <span>RESERVE AFTER TRADE</span>
              <span>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
            </div>
            {{#if vm.storeContext.hasCheckoutWarnings}}
            <div class="swse-store-surface__checkout-status {{#if vm.storeContext.cartRemainingNeg}}warn{{/if}}">
              {{#each vm.storeContext.checkoutWarnings}}
              <div class="swse-store-surface__checkout-status-line">{{this}}</div>
              {{/each}}
            </div>
            {{/if}}
            <div class="swse-store-surface__cart-actions">
              <button type="button" class="swse-store-surface__btn" data-action="clear-cart">CLEAR CART</button>
              <button type="button" class="swse-store-surface__btn swse-store-surface__btn--primary" data-action="proceed-checkout" {{#if vm.storeContext.checkoutBlocked}}disabled aria-disabled="true" title="{{vm.storeContext.checkoutBlockedReason}}"{{/if}}>PROCEED TO CHECKOUT →</button>
            </div>
          </div>
          {{else}}
          <div class="swse-store-surface__empty">
            <div class="swse-store-surface__empty-glyph">◳</div>
            <div class="swse-store-surface__empty-msg">Your cart is empty.</div>
            <div class="swse-store-surface__empty-sub">Browse listings and stage gear before checkout.</div>
            <button type="button" class="swse-store-surface__btn swse-store-surface__btn--primary" data-ss-tab="browse">→ BROWSE LISTINGS</button>
          </div>
          {{/if}}
        </section>
        {{/if}}

        {{#if (eq vm.storeContext.currentView 'checkout')}}
        <section class="swse-store-surface__pane swse-store-surface__pane-checkout">
          <div class="swse-store-surface__checkout-header">
            <span class="swse-store-surface__checkout-title">◈ SETTLEMENT WINDOW</span>
            <span class="swse-store-surface__checkout-sub">Review the locked manifest before confirming the trade.</span>
          </div>
          {{#if vm.storeContext.cartEntries.length}}
          <div class="swse-store-surface__checkout-manifest">
            {{#each vm.storeContext.cartEntries}}
            <div class="swse-store-surface__checkout-row">
              <span class="swse-store-surface__checkout-row-name">{{this.name}}</span>
              <span class="swse-store-surface__checkout-row-type">{{this.summary}} · ×{{this.qty}}</span>
              <span class="swse-store-surface__checkout-row-cost">{{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
            </div>
            {{/each}}
          </div>
          <div class="swse-store-surface__checkout-ledger">
            <div class="swse-store-surface__checkout-ledger-row"><span>AVAILABLE CREDITS</span><span>{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span></div>
            <div class="swse-store-surface__checkout-ledger-row debit"><span>TRADE DEBIT</span><span>−{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span></div>
            <div class="swse-store-surface__checkout-ledger-row {{#if vm.storeContext.cartRemainingNeg}}neg{{else}}pos{{/if}} total"><span>REMAINING RESERVE</span><span>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span></div>
          </div>
          {{#if vm.storeContext.hasCheckoutWarnings}}
          <div class="swse-store-surface__checkout-status {{#if vm.storeContext.cartRemainingNeg}}warn{{/if}}">
            {{#each vm.storeContext.checkoutWarnings}}
            <div class="swse-store-surface__checkout-status-line">{{this}}</div>
            {{/each}}
          </div>
          {{/if}}
          <div class="swse-store-surface__checkout-actions">
            <button type="button" class="swse-store-surface__btn" data-action="return-to-cart">← RETURN TO CART</button>
            <button type="button" class="swse-store-surface__btn swse-store-surface__btn--confirm" data-action="confirm-checkout" {{#if vm.storeContext.checkoutBlocked}}disabled aria-disabled="true" title="{{vm.storeContext.checkoutBlockedReason}}"{{/if}}>◈ CONFIRM TRADE</button>
          </div>
          {{else}}
          <div class="swse-store-surface__empty">
            <div class="swse-store-surface__empty-msg">Nothing to settle — cart is empty.</div>
            <button type="button" class="swse-store-surface__btn" data-action="return-to-cart">← RETURN TO CART</button>
          </div>
          {{/if}}
        </section>
        {{/if}}

        {{#if (eq vm.storeContext.currentView 'history')}}
        <section class="swse-store-surface__pane swse-store-surface__pane-history">
          {{#if vm.storeContext.purchaseHistoryEntries.length}}
          <div class="swse-store-surface__history-list">
            {{#each vm.storeContext.purchaseHistoryEntries}}
            <div class="swse-store-surface__history-entry">
              <div class="swse-store-surface__history-entry-header">
                <span class="swse-store-surface__history-date">{{this.timestamp}}</span>
                <span class="swse-store-surface__history-total">{{this.total}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span></span>
              </div>
              <div class="swse-store-surface__history-items">
                {{#each this.items}}
                <span class="swse-store-surface__history-item">{{this.name}} ×{{this.qty}} ({{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="credits"></span>)</span>
                {{/each}}
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="swse-store-surface__empty">
            <div class="swse-store-surface__empty-glyph">◎</div>
            <div class="swse-store-surface__empty-msg">No purchase history.</div>
            <div class="swse-store-surface__empty-sub">Previous exchange logs will appear here.</div>
          </div>
          {{/if}}
        </section>
        {{/if}}

      </main>
    </form>
  </section>

  {{else}}
  <div class="swse-store-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>Unable to load store.</span>
  </div>
  {{/if}}

</div>
