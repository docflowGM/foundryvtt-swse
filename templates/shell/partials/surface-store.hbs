{{!--
  surface-store.hbs
  Shell-native store surface. Concept-aligned layout, live store data.
  Phase 3: Datapad chrome and hierarchical layout with browse grid + side rail.
--}}

<div class="swse-shell-surface swse-shell-surface--store"
     data-shell-region="surface-store"
     data-surface-id="{{vm.id}}">

  {{#if vm.error}}
  <div class="swse-store-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>{{vm.error}}</span>
  </div>
  {{else if vm.storeContext}}

  {{!-- Store splash is intentionally bypassed for stability. Deprecated path retained in templates/apps/store/store-splash.hbs. --}}
  <section class="swse-store-surface"
           data-theme="{{vm.sheetTheme}}"
           data-motion-style="{{vm.sheetMotionStyle}}"
           style="{{vm.surfaceStyleInline}}">
    <form class="swse-store-surface__tablet" autocomplete="off">
      <div class="swse-store-surface__scan-v" aria-hidden="true"></div>
      <span class="swse-store-surface__corner swse-store-surface__corner--tl" aria-hidden="true"></span>
      <span class="swse-store-surface__corner swse-store-surface__corner--tr" aria-hidden="true"></span>
      <span class="swse-store-surface__corner swse-store-surface__corner--bl" aria-hidden="true"></span>
      <span class="swse-store-surface__corner swse-store-surface__corner--br" aria-hidden="true"></span>

      <header class="swse-store-surface__hud">
        <button class="swse-store-surface__hud-back" data-shell-action="return-to-home" type="button" title="{{localize 'SWSE.ShellUI.ReturnToHome'}}">
          <i class="fas fa-arrow-left"></i> {{localize "SWSE.ShellUI.HOME"}}
        </button>
        <div class="swse-store-surface__hud-center">
          <span class="swse-store-surface__signal"><span></span><span></span><span></span><span></span></span>
          <span class="swse-store-surface__hud-title">{{localize "SWSE.ShellUI.RENDARRSEXCHANGE"}}</span>
          <span class="swse-store-surface__hud-dot {{#if vm.storeContext.cartCount}}warn{{/if}}"></span>
        </div>
        <div class="swse-store-surface__hud-right">
          <span class="swse-store-surface__hud-lbl">{{localize "SWSE.ShellUI.RESERVE"}}</span>
          <span class="swse-store-surface__hud-credits">{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
        </div>
      </header>

      <header class="swse-store-surface__hero">
        <div class="swse-store-surface__rendarr-portrait">
          {{#if vm.storeContext.rendarrImage}}
          <img src="{{vm.storeContext.rendarrImage}}" alt="{{localize 'SWSE.ShellUI.Rendarr'}}" class="swse-store-surface__rendarr-img"/>
          {{else}}
          <svg viewBox="0 0 64 64" class="swse-store-surface__rendarr-svg"><circle cx="32" cy="24" r="14" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 60 Q32 38 56 60" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
          {{/if}}
        </div>
        <div class="swse-store-surface__rendarr-meta">
          <div class="swse-store-surface__rendarr-name"><span class="swse-store-surface__rendarr-mark">⚡</span>{{localize "SWSE.ShellUI.RENDARRSEXCHANGE"}}</div>
          <div class="swse-store-surface__rendarr-sub">{{localize "SWSE.ShellUI.QuartermasterGalacticTradeNetwork"}}</div>
          <div class="swse-store-surface__rendarr-quote">
            {{#if vm.storeContext.rendarrWelcome}}"{{vm.storeContext.rendarrWelcome}}"{{else}}"What can I do for you today?"{{/if}}
          </div>
        </div>
        <div class="swse-store-surface__credits-block">
          <span class="swse-store-surface__credits-lbl">{{localize "SWSE.ShellUI.ACCOUNT"}}</span>
          <span class="swse-store-surface__credits-val">{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
          {{#if vm.storeContext.cartCount}}
          <span class="swse-store-surface__credits-delta neg">−{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span> {{localize "SWSE.ShellUI.Staged"}}</span>
          <span class="swse-store-surface__credits-reserve">{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span> {{localize "SWSE.ShellUI.After"}}</span>
          {{/if}}
        </div>
      </header>

      <nav class="swse-store-surface__tabs">
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'browse')}}active{{/if}} {{#if vm.storeContext.selectedProduct}}active{{/if}}" data-ss-tab="browse">
          <span class="swse-store-surface__tab-glyph">⊞</span> {{localize "SWSE.ShellUI.BROWSE"}}
        </button>
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'cart')}}active{{/if}}" data-ss-tab="cart">
          <span class="swse-store-surface__tab-glyph">◳</span> CART
          {{#if vm.storeContext.cartCount}}<span class="swse-store-surface__tab-count">{{vm.storeContext.cartCount}}</span>{{/if}}
        </button>
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'checkout')}}active{{/if}}" data-ss-tab="checkout">
          <span class="swse-store-surface__tab-glyph">◈</span> {{localize "SWSE.ShellUI.CHECKOUT"}}
        </button>
        <button type="button" class="swse-store-surface__tab {{#if (eq vm.storeContext.currentView 'history')}}active{{/if}}" data-ss-tab="history">
          <span class="swse-store-surface__tab-glyph">◎</span> {{localize "SWSE.ShellUI.HISTORY"}}
        </button>
      </nav>

      <main class="swse-store-surface__screen">

        {{#if vm.storeContext.isBrowseOrDetail}}
        <section class="swse-store-surface__filters">
          <div class="swse-store-surface__filter-search">
            <i class="fas fa-search swse-store-surface__filter-ico"></i>
            <input type="text" id="ss-search" class="swse-store-surface__search-input" placeholder="{{localize 'SWSE.ShellUI.SEARCHLISTINGS'}}" aria-label="{{localize 'SWSE.ShellUI.SearchStore'}}" value="{{vm.storeContext.filters.search}}"/>
          </div>
          <div class="swse-store-surface__filter-group">
            <span class="swse-store-surface__filter-lbl">{{localize "SWSE.ShellUI.AVAIL"}}</span>
            <select id="ss-avail" class="swse-store-surface__select">
              <option value="all">{{localize "SWSE.ShellUI.All"}}</option>
              <option value="standard">{{localize "SWSE.ShellUI.Standard"}}</option>
              <option value="licensed">{{localize "SWSE.ShellUI.Licensed"}}</option>
              <option value="restricted">{{localize "SWSE.ShellUI.Restricted"}}</option>
              <option value="military">{{localize "SWSE.ShellUI.Military"}}</option>
              <option value="illegal">{{localize "SWSE.ShellUI.Illegal"}}</option>
              <option value="rare">{{localize "SWSE.ShellUI.Rare"}}</option>
            </select>
          </div>
          <div class="swse-store-surface__filter-group">
            <span class="swse-store-surface__filter-lbl">{{localize "SWSE.ShellUI.SORT"}}</span>
            <select id="ss-sort" class="swse-store-surface__select">
              <option value="default">{{localize "SWSE.ShellUI.BestMatch"}}</option>
              <option value="price-asc">{{localize "SWSE.ShellUI.Price"}}</option>
              <option value="price-desc">{{localize "SWSE.ShellUI.Price2"}}</option>
              <option value="name-asc">{{localize "SWSE.ShellUI.NameAZ"}}</option>
            </select>
          </div>
          {{#if (eq vm.storeContext.currentCategory 'vehicles')}}
          <div class="swse-store-surface__filter-group swse-store-surface__filter-group--vehicle">
            <span class="swse-store-surface__filter-lbl">SIZE</span>
            <select id="ss-vehicle-size" class="swse-store-surface__select">
              <option value="">All Sizes</option>
              {{#each vm.storeContext.vehicleSizeOptions}}
              <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </div>
          <div class="swse-store-surface__filter-group swse-store-surface__filter-group--vehicle">
            <span class="swse-store-surface__filter-lbl">CL</span>
            <select id="ss-vehicle-cl" class="swse-store-surface__select" {{#unless vm.storeContext.vehicleClOptions.length}}disabled{{/unless}}>
              <option value="">{{#if vm.storeContext.vehicleClOptions.length}}All CL{{else}}Unavailable{{/if}}</option>
              {{#each vm.storeContext.vehicleClOptions}}
              <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}} ({{count}})</option>
              {{/each}}
            </select>
          </div>
          {{/if}}
          <div class="swse-store-surface__filter-count">
            <span data-results-count>{{vm.storeContext.renderedItemCount}}</span>/<span>{{vm.storeContext.visibleItemCount}}</span> {{localize "SWSE.ShellUI.Listings"}}
          </div>
          <button type="button" class="swse-store-surface__filter-clear" data-action="clear-filters">{{localize "SWSE.ShellUI.CLEAR"}}</button>
        </section>

        <nav class="swse-store-surface__category-tabs" aria-label="{{localize 'SWSE.ShellUI.StoreDepartments'}}">
          {{#each vm.storeContext.categorySummary}}
          <button type="button" class="swse-store-surface__category-chip {{#if (eq ../vm.storeContext.currentCategory key)}}active{{/if}}" data-action="category-nav" data-category="{{key}}">
            {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
          </button>
          {{/each}}
        </nav>

        {{!-- Secondary navigation for subcategories/folders --}}
        {{#if vm.storeContext.navigationModel.topCategories}}
        {{#each vm.storeContext.navigationModel.topCategories}}
        {{#if (eq key ../vm.storeContext.currentCategory)}}
        {{#if children}}
        <nav class="swse-store-surface__subnav" aria-label="{{localize 'SWSE.ShellUI.StoreDepartmentSubcategories'}}">
          {{#if familyTabs}}
          {{#unless (eq key 'vehicles')}}
          <div class="swse-store-surface__family-tabs" aria-label="{{label}} folders">
            <button type="button" class="swse-store-surface__family-chip {{#unless ../vm.storeContext.currentFamily}}active{{/unless}}"
                    data-action="family-nav" data-family="">
              {{#if allLabel}}{{allLabel}}{{else}}{{label}}{{/if}}<span class="swse-store-surface__chip-count">{{count}}</span>
            </button>
            {{#each familyTabs}}
            <button type="button" class="swse-store-surface__family-chip {{#if active}}active{{/if}}"
                    data-action="family-nav" data-family="{{family}}">
              {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
            </button>
            {{/each}}
          </div>
          {{/unless}}
          {{/if}}

          {{#unless (eq key 'droids')}}
          <div class="swse-store-surface__subcategory-strip" aria-label="{{label}} subfolders">
            {{#each children}}
            <button type="button" class="swse-store-surface__subcat-chip swse-store-surface__subcat-chip--{{family}} {{#if active}}active{{/if}}"
                    data-action="subcategory-nav" data-subcategory="{{label}}" data-family="{{family}}">
              {{label}}<span class="swse-store-surface__chip-count">{{count}}</span>
            </button>
            {{/each}}
          </div>
          {{/unless}}
          {{#if (eq key 'vehicles')}}
          <button type="button" class="swse-store-surface__subcat-chip swse-store-surface__subcat-chip--builder"
                  data-action="store-build-from-scratch" data-builder-kind="vehicle">
            {{localize "SWSE.ShellUI.CreateCustomShip"}}
          </button>
          {{/if}}
          {{#if (eq key 'droids')}}
          <button type="button" class="swse-store-surface__subcat-chip swse-store-surface__subcat-chip--builder"
                  data-action="store-build-from-scratch" data-builder-kind="droid">
            {{localize "SWSE.ShellUI.CreateCustomDroid"}}
          </button>
          {{/if}}
        </nav>
        {{/if}}
        {{/if}}
        {{/each}}
        {{/if}}

        <section class="swse-store-surface__browse swse-store-surface__browse-layout">
          <div class="swse-store-surface__grid swse-store-surface__cards-grid">

            {{#each vm.storeContext.allItems}}
            <div class="swse-store-surface__card swse-store-surface__card--rar-{{this.rarityClass}} {{#if (eq ../vm.storeContext.selectedProductId this.id)}}is-selected{{/if}}"
                 data-item-id="{{this.id}}"
                 data-item-type="{{this.type}}"
                 data-name="{{this.name}}"
                 data-category="{{this.category}}"
                 data-category-key="{{this.categoryKey}}"
                 data-subcategory="{{this.subcategory}}"
                 data-subcategory-key="{{this.subcategoryKey}}"
                 data-family="{{#if this.navigationFamily}}{{this.navigationFamily}}{{else}}{{this.weaponFamily}}{{/if}}"
                 data-vehicle-size="{{this.vehicleSizeKey}}"
                 data-vehicle-cl="{{this.vehicleChallengeBand}}"
                 data-availability="{{this.availability}}"
                 data-price="{{#if this.cost}}{{this.cost}}{{else}}{{this.finalCost}}{{/if}}"
                 data-score="{{#if this.suggestion}}{{this.suggestion.score}}{{else}}0{{/if}}">
              <span class="swse-store-surface__card-rar-tag">{{this.rarityLabel}}</span>
              <div class="swse-store-surface__card-hero" aria-hidden="true">
                <div class="swse-store-surface__card-glyph-panel">
                  <span class="swse-store-surface__card-glyph">{{#if this.cardLetter}}{{this.cardLetter}}{{else}}{{this.glyph}}{{/if}}</span>
                </div>
                <span class="swse-store-surface__card-glyph-label">{{#if this.glyphLabel}}{{this.glyphLabel}}{{else}}{{this.typeLabel}}{{/if}}</span>
              </div>
              <div class="swse-store-surface__card-body">
                <div class="swse-store-surface__card-name">{{this.name}}</div>
                <div class="swse-store-surface__card-cat">{{this.typeLabel}} · {{this.category}}{{#if this.subcategory}} · {{this.subcategory}}{{/if}}</div>
                <div class="swse-store-surface__card-meta-row">
                  {{#if this.vehicleSizeLabel}}<span class="swse-store-surface__card-meta-pill">{{this.vehicleSizeLabel}}</span>{{/if}}
                  {{#if this.vehicleChallengeLabel}}<span class="swse-store-surface__card-meta-pill">{{this.vehicleChallengeLabel}}</span>{{/if}}
                  <span class="swse-store-surface__card-meta-pill">{{this.availability}}</span>
                  {{#if this.suggestion.tierLabel}}<span class="swse-store-surface__card-tier swse-store-surface__card-tier--{{this.suggestion.tier}}">{{this.suggestion.tierLabel}}</span>{{/if}}
                </div>
              </div>
              <div class="swse-store-surface__card-foot">
                {{#if this.costUsed}}
                <span class="swse-store-surface__card-price">NEW {{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span> · USED {{this.costUsed}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
                {{else}}
                <span class="swse-store-surface__card-price">{{this.finalCost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
                {{/if}}
                <div class="swse-store-surface__card-actions">
                  <button type="button" class="swse-store-surface__card-btn" data-action="expand-product" data-item-id="{{this.id}}">{{#if (eq ../vm.storeContext.selectedProductId this.id)}}COLLAPSE{{else}}DETAILS{{/if}}</button>
                  {{#if (eq this.type 'vehicle')}}
                  <button type="button" class="swse-store-surface__card-btn" data-action="add-to-cart" data-item-id="{{this.id}}" data-item-type="vehicle" data-condition="used">{{localize "SWSE.ShellUI.USED"}}</button>
                  <button type="button" class="swse-store-surface__card-btn swse-store-surface__card-btn--primary" data-action="add-to-cart" data-item-id="{{this.id}}" data-item-type="vehicle" data-condition="new">{{localize "SWSE.ShellUI.NEW"}}</button>
                  {{else}}
                  <button type="button" class="swse-store-surface__card-btn swse-store-surface__card-btn--primary" data-action="add-to-cart" data-item-id="{{this.id}}" data-item-type="{{this.type}}">{{localize "SWSE.ShellUI.ADD"}}</button>
                  {{/if}}
                </div>
              </div>
              {{#if (eq ../vm.storeContext.selectedProductId this.id)}}
              <div class="swse-store-surface__card-selected-note">
                <span>{{localize "SWSE.ShellUI.LISTINGROUTEDTODETAILRAIL"}}</span>
              </div>
              {{/if}}
            </div>
            {{/each}}
            {{#if vm.storeContext.hasMoreItems}}
            <div class="swse-store-surface__load-more-row">
              <button type="button" class="swse-store-surface__load-more" data-action="store-load-more" data-next-limit="{{vm.storeContext.nextRenderLimit}}">
                {{localize "SWSE.ShellUI.LOADMORESTOCK"}} <span>{{vm.storeContext.renderedItemCount}}/{{vm.storeContext.visibleItemCount}}</span>
              </button>
            </div>
            {{/if}}
          </div>

          {{!-- Side rail: listing inspection + commerce rail. --}}
          <aside class="swse-store-surface__rail">
            <section class="swse-store-surface__side-card swse-store-surface__detail-card {{#if vm.storeContext.selectedProduct}}is-active{{else}}is-empty{{/if}}">
              <div class="swse-store-surface__side-head">
                <span>{{localize "SWSE.ShellUI.ListingInspect"}}</span>
                <span class="hint">{{#if vm.storeContext.selectedProduct}}selected{{else}}idle{{/if}}</span>
              </div>
              {{#if vm.storeContext.selectedProduct}}
              <div class="swse-store-surface__detail-shell">
                <div class="swse-store-surface__detail-topline">
                  <div class="swse-store-surface__detail-glyph">
                    <span>{{#if vm.storeContext.selectedProduct.cardLetter}}{{vm.storeContext.selectedProduct.cardLetter}}{{else}}{{vm.storeContext.selectedProduct.glyph}}{{/if}}</span>
                    <small>{{#if vm.storeContext.selectedProduct.glyphLabel}}{{vm.storeContext.selectedProduct.glyphLabel}}{{else}}{{vm.storeContext.selectedProduct.typeLabel}}{{/if}}</small>
                  </div>
                  <div class="swse-store-surface__detail-title-block">
                    <div class="swse-store-surface__detail-name">{{vm.storeContext.selectedProduct.name}}</div>
                    <div class="swse-store-surface__detail-subtitle">{{vm.storeContext.selectedProduct.typeLabel}} · {{vm.storeContext.selectedProduct.category}}{{#if vm.storeContext.selectedProduct.subcategory}} · {{vm.storeContext.selectedProduct.subcategory}}{{/if}}</div>
                    <div class="swse-store-surface__detail-tags">
                      <span>{{vm.storeContext.selectedProduct.rarityLabel}}</span>
                      <span>{{vm.storeContext.selectedProduct.availability}}</span>
                      {{#if vm.storeContext.selectedProduct.suggestionTierLabel}}<span>{{vm.storeContext.selectedProduct.suggestionTierLabel}}</span>{{/if}}
                    </div>
                  </div>
                  <button type="button" class="swse-store-surface__detail-close" data-action="detail-back" title="{{localize 'SWSE.ShellUI.ClearSelectedListing'}}">×</button>
                </div>

                <div class="swse-store-surface__detail-price-strip">
                  {{#each vm.storeContext.selectedProductDetail.priceOptions}}
                  <div class="swse-store-surface__detail-price-option">
                    <span>{{label}}</span>
                    <strong>{{valueLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></strong>
                  </div>
                  {{/each}}
                </div>

                <div class="swse-store-surface__detail-summary">{{vm.storeContext.selectedProductDetail.summary}}</div>

                {{#if vm.storeContext.selectedProductDetail.rows.length}}
                <div class="swse-store-surface__detail-specs">
                  {{#each vm.storeContext.selectedProductDetail.rows}}
                  <div class="swse-store-surface__detail-spec-row"><span>{{label}}</span><strong>{{value}}</strong></div>
                  {{/each}}
                </div>
                {{/if}}

                {{#if vm.storeContext.selectedProduct.suggestionBullets.length}}
                <div class="swse-store-surface__detail-section">
                  <div class="swse-store-surface__detail-section-title">{{localize "SWSE.ShellUI.FitNotes"}}</div>
                  <ul class="swse-store-surface__detail-bullets">
                    {{#each vm.storeContext.selectedProduct.suggestionBullets}}<li>{{this}}</li>{{/each}}
                  </ul>
                </div>
                {{/if}}

                {{#if vm.storeContext.selectedProduct.techDetailsHtml}}
                <div class="swse-store-surface__detail-section swse-store-surface__detail-section--scroll">
                  <div class="swse-store-surface__detail-section-title">{{localize "SWSE.ShellUI.TechnicalReadout"}}</div>
                  {{{vm.storeContext.selectedProduct.techDetailsHtml}}}
                </div>
                {{/if}}

                {{#if vm.storeContext.selectedProduct.flavorReviewsHtml}}
                <div class="swse-store-surface__detail-section swse-store-surface__detail-section--scroll">
                  <div class="swse-store-surface__detail-section-title">{{localize "SWSE.ShellUI.MarketplaceReviews"}}</div>
                  {{{vm.storeContext.selectedProduct.flavorReviewsHtml}}}
                </div>
                {{/if}}

                <div class="swse-store-surface__detail-actions">
                  {{#if (eq vm.storeContext.selectedProduct.type 'vehicle')}}
                  <button type="button" class="swse-store-surface__rail-btn" data-action="add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="vehicle" data-condition="used">{{localize "SWSE.ShellUI.USEDMODEL"}}</button>
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="vehicle" data-condition="new">{{localize "SWSE.ShellUI.NEWMODEL"}}</button>
                  <button type="button" class="swse-store-surface__rail-btn" data-action="store-build-from-scratch" data-builder-kind="vehicle">{{localize "SWSE.ShellUI.BUILDFROMSCRATCH"}}</button>
                  {{else}}
                  {{#if (eq vm.storeContext.selectedProduct.type 'droid')}}
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="detail-add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="droid">{{localize "SWSE.ShellUI.ADDDROID"}}</button>
                  <button type="button" class="swse-store-surface__rail-btn" data-action="store-build-from-scratch" data-builder-kind="droid">{{localize "SWSE.ShellUI.BUILDFROMSCRATCH"}}</button>
                  {{else}}
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="detail-add-to-cart" data-item-id="{{vm.storeContext.selectedProduct.id}}" data-item-type="{{vm.storeContext.selectedProduct.type}}">{{localize "SWSE.ShellUI.ADDTOCART"}}</button>
                  {{/if}}
                  {{/if}}
                </div>
              </div>
              {{else}}
              <div class="swse-store-surface__detail-empty">
                <div class="swse-store-surface__detail-empty-glyph">⌁</div>
                <div class="swse-store-surface__detail-empty-title">{{localize "SWSE.ShellUI.NoListingSelected"}}</div>
                <div class="swse-store-surface__detail-empty-copy">{{localize "SWSE.ShellUI.ClickAnyMarketCardToRouteItsStats"}}</div>
              </div>
              {{/if}}
            </section>
            {{#if vm.storeContext.hasBuilderActions}}
            <section class="swse-store-surface__side-card swse-store-surface__builder-card">
              <div class="swse-store-surface__side-head">
                <span>{{localize "SWSE.ShellUI.CustomBuild"}}</span>
                <span class="hint">{{localize "SWSE.ShellUI.Scratch"}}</span>
              </div>
              <div class="swse-store-surface__builder-actions">
                {{#each vm.storeContext.builderActions}}
                <button type="button"
                        class="swse-store-surface__builder-btn swse-store-surface__builder-btn--{{tone}}"
                        data-action="store-build-from-scratch"
                        data-builder-kind="{{key}}">
                  <span class="swse-store-surface__builder-icon">{{icon}}</span>
                  <span class="swse-store-surface__builder-copy">
                    <strong>{{label}}</strong>
                    <small>{{sublabel}}</small>
                  </span>
                </button>
                {{/each}}
              </div>
            </section>
            {{/if}}

            <section class="swse-store-surface__side-card swse-store-surface__cart-card">
              <div class="swse-store-surface__side-head">
                <span>{{localize "SWSE.ShellUI.Cart"}}</span>
                <span class="hint">{{#if vm.storeContext.cartCount}}{{vm.storeContext.cartCount}} staged{{else}}empty{{/if}}</span>
              </div>
              <div class="swse-store-surface__mini-cart">
                {{#if vm.storeContext.cartEntries.length}}
                <div class="swse-store-surface__mini-cart-list">
                  {{#each vm.storeContext.cartEntries}}
                  <div class="swse-store-surface__mini-cart-item">
                    <div class="swse-store-surface__mini-cart-name">{{this.name}}</div>
                    <div class="swse-store-surface__mini-cart-qty">×{{this.qty}}</div>
                    <div class="swse-store-surface__mini-cart-price">{{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></div>
                  </div>
                  {{/each}}
                </div>
                <div class="swse-store-surface__mini-cart-summary">
                  <div class="swse-store-surface__mini-cart-row"><span>{{localize "SWSE.ShellUI.SUBTOTAL"}}</span><strong>{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></strong></div>
                  <div class="swse-store-surface__mini-cart-row"><span>{{localize "SWSE.ShellUI.AFTERHAUL"}}</span><strong>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></strong></div>
                </div>
                <div class="swse-store-surface__rail-actions">
                  <button type="button" class="swse-store-surface__rail-btn" data-ss-tab="cart">{{localize "SWSE.ShellUI.OPENCART"}}</button>
                  <button type="button" class="swse-store-surface__rail-btn swse-store-surface__rail-btn--primary" data-action="proceed-checkout" {{#if vm.storeContext.checkoutBlocked}}disabled aria-disabled="true" title="{{vm.storeContext.checkoutBlockedReason}}"{{/if}}>{{localize "SWSE.ShellUI.SETTLE"}}</button>
                </div>
                {{else}}
                <div class="swse-store-surface__mini-cart-empty">
                  <div class="swse-store-surface__mini-cart-empty-glyph">◳</div>
                  <div class="swse-store-surface__mini-cart-empty-msg">{{localize "SWSE.ShellUI.NoItemsStaged"}}</div>
                  <div class="swse-store-surface__mini-cart-empty-sub">{{localize "SWSE.ShellUI.ClickACardS"}} <span>{{localize "SWSE.ShellUI.ADD"}}</span> {{localize "SWSE.ShellUI.ToStartAHaul"}}</div>
                </div>
                <div class="swse-store-surface__rail-actions">
                  <button type="button" class="swse-store-surface__rail-btn" data-ss-tab="browse">{{localize "SWSE.ShellUI.BROWSEFLOOR"}}</button>
                </div>
                {{/if}}
              </div>
            </section>

            <section class="swse-store-surface__side-card swse-store-surface__wallet-card">
              <div class="swse-store-surface__side-head">
                <span>{{localize "SWSE.ShellUI.Wallet"}}</span>
                <span class="hint">{{localize "SWSE.ShellUI.SAGAStd"}}</span>
              </div>
              <div class="swse-store-surface__wallet-grid">
                <div class="swse-store-surface__wallet-cell">
                  <span>{{localize "SWSE.ShellUI.Balance"}}</span>
                  <strong>{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></strong>
                </div>
                <div class="swse-store-surface__wallet-cell {{#if vm.storeContext.cartRemainingNeg}}neg{{else}}pos{{/if}}">
                  <span>{{localize "SWSE.ShellUI.AfterHaul"}}</span>
                  <strong>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></strong>
                </div>
              </div>
            </section>

            <section class="swse-store-surface__side-card swse-store-surface__market-card">
              <div class="swse-store-surface__side-head">
                <span>{{localize "SWSE.ShellUI.MarketFeed"}}</span>
                <span class="hint">{{localize "SWSE.ShellUI.Live"}}</span>
              </div>
              <div class="swse-store-surface__market-line"><span>{{localize "SWSE.ShellUI.Category"}}</span><strong>{{vm.storeContext.currentCategoryLabel}}</strong></div>
              <div class="swse-store-surface__market-line"><span>{{localize "SWSE.ShellUI.Listings2"}}</span><strong>{{vm.storeContext.visibleItemCount}}</strong></div>
              <div class="swse-store-surface__market-line"><span>{{localize "SWSE.ShellUI.Rendered"}}</span><strong>{{vm.storeContext.renderedItemCount}}</strong></div>
            </section>

            <section class="swse-store-surface__side-card swse-store-surface__chatter-card">
              <div class="swse-store-surface__side-head">
                <span>{{localize "SWSE.ShellUI.FloorChatter"}}</span>
                <span class="hint">{{localize "SWSE.ShellUI.Live2"}}</span>
              </div>
              <div class="swse-store-surface__ticker" aria-label="{{localize 'SWSE.ShellUI.StoreChatterFeed'}}">
                <div class="swse-store-surface__ticker-track">
                  <span>{{localize "SWSE.ShellUI.RendarrNoRefundsOnThermalDetonators"}}</span>
                  <span>{{localize "SWSE.ShellUI.OuterRimSurplusJustClearedCustoms"}}</span>
                  <span>{{localize "SWSE.ShellUI.LicensedStockMayNeedGMApproval"}}</span>
                  <span>{{localize "SWSE.ShellUI.UsedVehiclesAreInspectedNotBlessed"}}</span>
                </div>
              </div>
            </section>

          </aside>
        </section>

        <div class="swse-store-surface__empty" style="display:none">
          <div class="swse-store-surface__empty-glyph">◌</div>
          <div class="swse-store-surface__empty-msg">{{localize "SWSE.ShellUI.NoListingsMatchTheCurrentFilters"}}</div>
          <div class="swse-store-surface__empty-sub">{{localize "SWSE.ShellUI.TryAnotherCategoryOrClearTheSearchParameters"}}</div>
        </div>
        {{/if}}

        {{#if (eq vm.storeContext.currentView 'cart')}}
        <section class="swse-store-surface__pane swse-store-surface__pane-cart">
          {{#if vm.storeContext.cartEntries.length}}
          <div class="swse-store-surface__cart-list">
            {{#each vm.storeContext.cartEntries}}
            <div class="swse-store-surface__cart-row">
              {{#if this.img}}<img class="swse-store-surface__cart-img" src="{{this.img}}" alt="{{this.name}}"/>{{else}}<div class="swse-store-surface__cart-glyph">{{this.glyph}}</div>{{/if}}
              <div class="swse-store-surface__cart-meta">
                <div class="swse-store-surface__cart-name">{{this.name}}</div>
                <div class="swse-store-surface__cart-type">{{this.summary}}</div>
              </div>
              <div class="swse-store-surface__cart-qty">×{{this.qty}}</div>
              <div class="swse-store-surface__cart-linecost">{{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></div>
              <button type="button" class="swse-store-surface__btn swse-store-surface__btn--ghost" data-action="remove-from-cart" data-item-id="{{this.id}}" data-item-type="{{this.itemType}}" data-condition="{{this.condition}}">{{localize "SWSE.ShellUI.REMOVE"}}</button>
            </div>
            {{/each}}
          </div>
          <div class="swse-store-surface__cart-summary">
            <div class="swse-store-surface__cart-summary-row">
              <span>{{localize "SWSE.ShellUI.TOTAL"}}</span>
              <span class="swse-store-surface__cart-total">{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
            </div>
            <div class="swse-store-surface__cart-summary-row dim">
              <span>{{localize "SWSE.ShellUI.AVAILABLE"}}</span>
              <span>{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
            </div>
            <div class="swse-store-surface__cart-summary-row {{#if vm.storeContext.cartRemainingNeg}}neg{{else}}pos{{/if}}">
              <span>{{localize "SWSE.ShellUI.RESERVEAFTERTRADE"}}</span>
              <span>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
            </div>
            {{#if vm.storeContext.hasCheckoutWarnings}}
            <div class="swse-store-surface__checkout-status {{#if vm.storeContext.cartRemainingNeg}}warn{{/if}}">
              {{#each vm.storeContext.checkoutWarnings}}
              <div class="swse-store-surface__checkout-status-line">{{this}}</div>
              {{/each}}
            </div>
            {{/if}}
            <div class="swse-store-surface__cart-actions">
              <button type="button" class="swse-store-surface__btn" data-action="clear-cart">{{localize "SWSE.ShellUI.CLEARCART"}}</button>
              <button type="button" class="swse-store-surface__btn swse-store-surface__btn--primary" data-action="proceed-checkout" {{#if vm.storeContext.checkoutBlocked}}disabled aria-disabled="true" title="{{vm.storeContext.checkoutBlockedReason}}"{{/if}}>{{localize "SWSE.ShellUI.PROCEEDTOCHECKOUT"}}</button>
            </div>
          </div>
          {{else}}
          <div class="swse-store-surface__empty">
            <div class="swse-store-surface__empty-glyph">◳</div>
            <div class="swse-store-surface__empty-msg">{{localize "SWSE.ShellUI.YourCartIsEmpty"}}</div>
            <div class="swse-store-surface__empty-sub">{{localize "SWSE.ShellUI.BrowseListingsAndStageGearBeforeCheckout"}}</div>
            <button type="button" class="swse-store-surface__btn swse-store-surface__btn--primary" data-ss-tab="browse">{{localize "SWSE.ShellUI.BROWSELISTINGS"}}</button>
          </div>
          {{/if}}
        </section>
        {{/if}}

        {{#if (eq vm.storeContext.currentView 'checkout')}}
        <section class="swse-store-surface__pane swse-store-surface__pane-checkout">
          <div class="swse-store-surface__checkout-header">
            <span class="swse-store-surface__checkout-title">{{localize "SWSE.ShellUI.SETTLEMENTWINDOW"}}</span>
            <span class="swse-store-surface__checkout-sub">{{localize "SWSE.ShellUI.ReviewTheLockedManifestBeforeConfirmingTheTrade"}}</span>
          </div>
          {{#if vm.storeContext.cartEntries.length}}
          <div class="swse-store-surface__checkout-manifest">
            {{#each vm.storeContext.cartEntries}}
            <div class="swse-store-surface__checkout-row">
              <span class="swse-store-surface__checkout-row-name">{{this.name}}</span>
              <span class="swse-store-surface__checkout-row-type">{{this.summary}} · ×{{this.qty}}</span>
              <span class="swse-store-surface__checkout-row-cost">{{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
            </div>
            {{/each}}
          </div>
          <div class="swse-store-surface__checkout-ledger">
            <div class="swse-store-surface__checkout-ledger-row"><span>{{localize "SWSE.ShellUI.AVAILABLECREDITS"}}</span><span>{{vm.actorCredits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span></div>
            <div class="swse-store-surface__checkout-ledger-row debit"><span>{{localize "SWSE.ShellUI.TRADEDEBIT"}}</span><span>−{{vm.storeContext.cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span></div>
            <div class="swse-store-surface__checkout-ledger-row {{#if vm.storeContext.cartRemainingNeg}}neg{{else}}pos{{/if}} total"><span>{{localize "SWSE.ShellUI.REMAININGRESERVE"}}</span><span>{{vm.storeContext.cartRemainingActualLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span></div>
          </div>
          {{#if vm.storeContext.hasCheckoutWarnings}}
          <div class="swse-store-surface__checkout-status {{#if vm.storeContext.cartRemainingNeg}}warn{{/if}}">
            {{#each vm.storeContext.checkoutWarnings}}
            <div class="swse-store-surface__checkout-status-line">{{this}}</div>
            {{/each}}
          </div>
          {{/if}}
          <div class="swse-store-surface__checkout-actions">
            <button type="button" class="swse-store-surface__btn" data-action="return-to-cart">{{localize "SWSE.ShellUI.RETURNTOCART"}}</button>
            <button type="button" class="swse-store-surface__btn swse-store-surface__btn--confirm" data-action="confirm-checkout" {{#if vm.storeContext.checkoutBlocked}}disabled aria-disabled="true" title="{{vm.storeContext.checkoutBlockedReason}}"{{/if}}>{{localize "SWSE.ShellUI.CONFIRMTRADE"}}</button>
          </div>
          {{else}}
          <div class="swse-store-surface__empty">
            <div class="swse-store-surface__empty-msg">{{localize "SWSE.ShellUI.NothingToSettleCartIsEmpty"}}</div>
            <button type="button" class="swse-store-surface__btn" data-action="return-to-cart">{{localize "SWSE.ShellUI.RETURNTOCART"}}</button>
          </div>
          {{/if}}
        </section>
        {{/if}}

        {{#if (eq vm.storeContext.currentView 'history')}}
        <section class="swse-store-surface__pane swse-store-surface__pane-history">
          {{#if vm.storeContext.purchaseHistoryEntries.length}}
          <div class="swse-store-surface__history-list">
            {{#each vm.storeContext.purchaseHistoryEntries}}
            <div class="swse-store-surface__history-entry">
              <div class="swse-store-surface__history-entry-header">
                <span class="swse-store-surface__history-date">{{this.timestamp}}</span>
                <span class="swse-store-surface__history-total">{{this.total}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span></span>
              </div>
              <div class="swse-store-surface__history-items">
                {{#each this.items}}
                <span class="swse-store-surface__history-item">{{this.name}} ×{{this.qty}} ({{this.cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.ShellUI.Credits3'}}"></span>)</span>
                {{/each}}
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="swse-store-surface__empty">
            <div class="swse-store-surface__empty-glyph">◎</div>
            <div class="swse-store-surface__empty-msg">{{localize "SWSE.ShellUI.NoPurchaseHistory"}}</div>
            <div class="swse-store-surface__empty-sub">{{localize "SWSE.ShellUI.PreviousExchangeLogsWillAppearHere"}}</div>
          </div>
          {{/if}}
        </section>
        {{/if}}

      </main>
    </form>
  </section>

  {{else}}
  <div class="swse-store-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>{{localize "SWSE.ShellUI.UnableToLoadStore"}}</span>
  </div>
  {{/if}}

</div>
