{{!-- Hintaro active-table partial. Production actions remain data-games-action driven. --}}
        <div class="swse-pazaak-table swse-hintaro-table" data-hintaro-session-id="{{vm.activeTable.sessionId}}">
          <div class="swse-pazaak-topbar">
            <div>
              <span class="swse-games-kicker">HINTARO TABLE</span>
              <h3>{{vm.activeTable.hintaro.title}}</h3>
              <p>Ante {{vm.activeTable.hintaro.ante}} · hintaron {{vm.activeTable.hintaro.hintaronLabel}} · {{vm.activeTable.hintaro.hintaronModeLabel}} · round {{vm.activeTable.hintaro.round}}</p>
            </div>
            <div class="swse-pazaak-topbar__right">
              <span>{{vm.activeTable.hintaro.statusLabel}}</span>
              {{#if vm.activeTable.hintaro.canStartRound}}
              <form data-games-action="hintaro-next-round"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><button type="submit" class="swse-games-primary">Next Round</button></form>
              {{/if}}
              {{#if vm.activeTable.hintaro.canCashOut}}
              <form data-games-action="hintaro-cash-out"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><button type="submit" class="swse-games-ghost">Cash Out</button></form>
              {{/if}}
              {{#if vm.activeTable.hintaro.canCancel}}
              <form data-games-action="hintaro-cancel-session"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><input type="hidden" name="reason" value="Hintaro table cancelled from Holopad Games."><button type="submit" class="swse-games-ghost swse-games-ghost--danger">Cancel</button></form>
              {{/if}}
              <button type="button" class="swse-games-ghost" data-games-action="close-table">Close Table</button>
            </div>
          </div>

          <div class="swse-pazaak-alert">
            <b>{{vm.activeTable.hintaro.message}}</b>
            {{#if vm.activeTable.hintaro.showBetting}}<span>Betting: {{vm.activeTable.hintaro.activeSeatLabel}} acts · live bet {{vm.activeTable.hintaro.betting.currentBet}}</span>{{/if}}
            {{#if vm.activeTable.hintaro.showReroll}}<span>Reroll choice: {{vm.activeTable.hintaro.activeSeatLabel}}</span>{{/if}}
            <span>Pot: {{vm.activeTable.hintaro.pot}} · carryover {{vm.activeTable.hintaro.carriedPot}}</span>
            <span>Hintaro die: {{vm.activeTable.hintaro.hintaroDie.label}}</span>
          </div>

          <aside class="swse-games-chatter swse-hintaro-dealer-callout" data-game-sound-cue="{{vm.activeTable.hintaro.soundCue}}">
            <span class="swse-games-kicker">HINTARON CALLOUT</span>
            <p><b>{{vm.activeTable.hintaro.hintaronLabel}}</b> <span>{{vm.activeTable.hintaro.dealerCallout}}</span></p>
          </aside>

          <section class="swse-hintaro-die-rail">
            <div class="swse-hintaro-special-die tone-{{vm.activeTable.hintaro.hintaroDie.tone}}"><b>{{vm.activeTable.hintaro.hintaroDie.shortLabel}}</b><small>{{vm.activeTable.hintaro.hintaroDie.label}}</small></div>
            <div><span class="swse-games-kicker">RANKS</span><p>Hin cancels Tukar; Taro cancels Kulro.</p><ol class="swse-hintaro-rank-list">{{#each vm.activeTable.hintaro.rankOrder}}<li><b>{{this.label}}</b> <span>{{this.description}}</span></li>{{/each}}</ol></div>
          </section>

          <section class="swse-pazaak-play swse-hintaro-play">
            <div class="swse-pazaak-seat-grid">
              {{#each vm.activeTable.hintaro.seats}}
              <article class="swse-pazaak-seat swse-hintaro-seat {{#if this.isCurrent}}is-current{{/if}} {{#if this.isViewer}}is-viewer{{/if}} {{#if this.dropped}}is-bust{{/if}}">
                <header><div><b>{{this.displayName}}</b><span>{{this.statusLabel}} · wins {{this.wins}} · table credits {{this.tableCredits}}</span>{{#if this.isAi}}<small>AI: {{this.aiProfileLabel}}</small>{{/if}}</div><strong>{{this.rankLabel}}</strong></header>
                <div class="swse-hintaro-cubes">
                  {{#if this.hasSymbols}}
                    {{#each this.dice}}
                    <span class="swse-hintaro-cube swse-hintaro-die tone-{{this.tone}}"><b>Die {{this.displayIndex}}</b><small>{{#each this.symbols}}<i class="tone-{{this.tone}}">{{this.shortLabel}}</i>{{/each}}</small></span>
                    {{/each}}
                  {{else}}
                    <span class="swse-pazaak-no-cards">No cubes rolled.</span>
                  {{/if}}
                </div>
                <footer><span>{{this.lastAction}}</span><span>{{this.modifiedLabel}}</span></footer>
              </article>
              {{/each}}
            </div>

            {{#if vm.activeTable.hintaro.viewerSeat.canBettingAct}}
            <section class="swse-pazaak-hand-panel swse-hintaro-actions">
              <div class="swse-pazaak-builder-head"><div><span class="swse-games-kicker">YOUR BET</span><strong>Table credits {{vm.activeTable.hintaro.viewerTableCredits}} · to call {{vm.activeTable.hintaro.betting.toCall}}</strong></div>
                <div class="swse-pazaak-turn-actions">
                  <form data-games-action="hintaro-check"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><button type="submit" class="swse-games-ghost" {{#unless vm.activeTable.hintaro.betting.canCheck}}disabled{{/unless}}>Check</button></form>
                  <form data-games-action="hintaro-bet"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><input type="hidden" name="amount" value="{{vm.activeTable.hintaro.betting.minBet}}"><button type="submit" class="swse-games-primary" {{#unless vm.activeTable.hintaro.betting.canBet}}disabled{{/unless}}>Bet {{vm.activeTable.hintaro.betting.minBet}}</button></form>
                  <form data-games-action="hintaro-call-bet"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><button type="submit" class="swse-games-primary" {{#unless vm.activeTable.hintaro.betting.canCall}}disabled{{/unless}}>Call {{vm.activeTable.hintaro.betting.toCall}}</button></form>
                  <form data-games-action="hintaro-raise"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><input type="hidden" name="amount" value="{{vm.activeTable.hintaro.betting.minRaise}}"><button type="submit" class="swse-games-ghost" {{#unless vm.activeTable.hintaro.betting.canRaise}}disabled{{/unless}}>Raise {{vm.activeTable.hintaro.betting.minRaise}}</button></form>
                  <form data-games-action="hintaro-drop"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><button type="submit" class="swse-games-ghost swse-games-ghost--danger">Drop</button></form>
                </div>
              </div>
            </section>
            {{/if}}

            {{#if vm.activeTable.hintaro.viewerSeat.canRerollAct}}
            <section class="swse-pazaak-hand-panel swse-hintaro-actions">
              <div class="swse-pazaak-builder-head"><div><span class="swse-games-kicker">YOUR REROLL</span><strong>Reroll one cube or keep your result.</strong></div>
                <form data-games-action="hintaro-keep-roll"><input type="hidden" name="sessionId" value="{{vm.activeTable.hintaro.id}}"><input type="hidden" name="seatId" value="{{vm.activeTable.hintaro.currentSeatId}}"><button type="submit" class="swse-games-primary">Keep Roll</button></form>
              </div>
              <div class="swse-pazaak-hand-grid">
                {{#each vm.activeTable.hintaro.viewerSeat.dice}}
                <form class="swse-hintaro-reroll-card" data-games-action="hintaro-reroll-die"><input type="hidden" name="sessionId" value="{{this.sessionId}}"><input type="hidden" name="seatId" value="{{this.seatId}}"><input type="hidden" name="dieIndex" value="{{this.index}}"><button type="submit" class="swse-hintaro-cube swse-hintaro-die tone-{{this.tone}}"><b>Die {{this.displayIndex}}</b><small>Reroll this cube</small></button></form>
                {{/each}}
              </div>
            </section>
            {{/if}}
          </section>

          {{#if vm.activeTable.hintaro.hasRoundHistory}}<section class="swse-pazaak-history"><span class="swse-games-kicker">ROUND HISTORY</span>{{#each vm.activeTable.hintaro.roundHistory}}<div><b>Round {{this.round}}</b><span>{{this.winnerLabel}} · {{this.rankLabel}} · {{this.timeLabel}}</span></div>{{/each}}</section>{{/if}}
          {{#if vm.activeTable.hintaro.hasEventLog}}<section class="swse-pazaak-history swse-pazaak-log"><span class="swse-games-kicker">TABLE LOG</span>{{#each vm.activeTable.hintaro.eventLog}}<div class="tone-{{this.tone}}"><b>{{#if this.seatLabel}}{{this.seatLabel}}{{else}}{{this.type}}{{/if}}</b><span>{{this.message}}{{#if this.timeLabel}} · {{this.timeLabel}}{{/if}}</span></div>{{/each}}</section>{{/if}}
        </div>
