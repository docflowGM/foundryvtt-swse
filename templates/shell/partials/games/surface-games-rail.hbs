{{!-- Library right rail: active tables, pending invites, recent results, and system notes. --}}
<aside class="swse-games-lib-col swse-games-lib-col--rail">
  <section class="swse-games-rail-card">
    <div class="swse-games-rail-head"><span class="swse-games-kicker">Active Tables</span><span class="swse-games-rail-hint">{{vm.activeSessions.length}} live</span></div>
    {{#if vm.hasActiveSessions}}
      {{#each vm.activeSessions}}
      <article class="swse-games-table-row">
        <span class="swse-games-table-row__glyph">{{this.gameIcon}}</span>
        <button type="button" class="swse-games-table-row__body" data-games-action="open-session" data-session-id="{{this.id}}">
          <span class="name">{{this.title}}</span>
          <span class="meta">{{this.gameTitle}} · {{this.rulesMode}}{{#if this.wager.enabled}} · pot {{this.wager.pot}} cr{{/if}}</span>
        </button>
        <button type="button" class="swse-games-table-row__cta" data-games-action="open-session" data-session-id="{{this.id}}">Resume</button>
      </article>
      {{/each}}
    {{else}}
      <div class="swse-games-empty swse-games-empty--compact"><b>No active tables.</b><span>Accepted game envelopes appear here.</span></div>
    {{/if}}
  </section>

  <section class="swse-games-rail-card">
    <div class="swse-games-rail-head"><span class="swse-games-kicker">Pending Invites</span><span class="swse-games-rail-hint">{{vm.inviteSessions.length}}</span></div>
    {{#if vm.hasInviteSessions}}
      {{#each vm.inviteSessions}}
      <article class="swse-games-table-row invite">
        <span class="swse-games-table-row__glyph">{{this.gameIcon}}</span>
        <button type="button" class="swse-games-table-row__body" data-games-action="open-session" data-session-id="{{this.id}}">
          <span class="name">{{this.title}}</span>
          <span class="meta">{{this.gameTitle}} · {{this.rulesMode}}{{#if this.wager.enabled}} · {{this.wager.pot}} cr pot{{/if}}</span>
        </button>
        <div class="swse-games-table-row__actions">
          {{#if this.canRespond}}
          <button type="button" class="swse-games-table-row__cta" data-games-action="accept-invite" data-thread-id="{{this.holonetThreadId}}" data-record-id="{{this.holonetMessageId}}">Accept</button>
          <button type="button" class="swse-games-ghost mini" data-games-action="decline-invite" data-thread-id="{{this.holonetThreadId}}" data-record-id="{{this.holonetMessageId}}">Decline</button>
          {{/if}}
          {{#if this.canOpenThread}}<button type="button" class="swse-games-ghost mini" data-games-action="open-thread" data-thread-id="{{this.holonetThreadId}}">Messenger</button>{{/if}}
        </div>
      </article>
      {{/each}}
    {{else}}
      <div class="swse-games-empty swse-games-empty--compact"><b>No pending invites.</b><span>Holonet game requests appear here.</span></div>
    {{/if}}
  </section>

  <section class="swse-games-rail-card">
    <div class="swse-games-rail-head"><span class="swse-games-kicker">Recent Results</span><span class="swse-games-rail-hint">ledger</span></div>
    {{#if vm.hasRecentSessions}}
      {{#each vm.recentSessions}}
      <button type="button" class="swse-games-feed-row" data-games-action="open-session" data-session-id="{{this.id}}">
        <span class="ico {{this.statusTone}}">{{this.resultGlyph}}</span>
        <span><span class="em">{{this.gameTitle}}</span> — {{this.status}}</span>
        <span class="time">{{this.updatedAt}}</span>
      </button>
      {{/each}}
    {{else}}
      <div class="swse-games-empty swse-games-empty--compact"><b>No completed games yet.</b><span>Settled tables will create this rail history.</span></div>
    {{/if}}
  </section>

  <section class="swse-games-rail-card swse-games-rail-card--notes">
    <div class="swse-games-rail-head"><span class="swse-games-kicker">Rules Guardrails</span><span class="swse-games-rail-hint">SSOT</span></div>
    <div class="swse-games-note-stack">
      {{#each vm.infrastructureNotes}}
      <p>{{this}}</p>
      {{/each}}
    </div>
  </section>
</aside>
