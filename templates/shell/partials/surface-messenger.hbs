<div class="swse-shell-surface swse-shell-surface--messenger swse-holonet-comm" data-shell-region="surface-messenger" data-surface-id="{{vm.id}}">
  <div class="swse-shell-surface__header swse-messenger-header hl-hud hl-hud--concept">
    <button class="swse-shell-surface__back-btn hl-icon-btn" data-shell-action="return-to-home" type="button" title="Return to Home">
      <i class="fas fa-arrow-left"></i>
      <span>Home</span>
    </button>

    <div class="swse-shell-surface__title hl-hud-title">
      <span>HOLOCOM</span><small>ONLINE</small>
      {{#if vm.unreadCount}}<span class="swse-messenger-title-badge hl-badge">{{vm.unreadCount}}</span>{{/if}}
    </div>

    <div class="swse-home-header__actions hl-hud-r">
      {{#if vm.partyFund.enabled}}
      <span class="hl-hud-pill hl-partyfund-pill">PARTY FUND // {{vm.partyFund.balance}} CR</span>
      {{/if}}
      {{#if vm.transferApprovalRequired}}<span class="hl-hud-pill">TRANSFER APPROVAL // ON</span>{{/if}}
      <button class="swse-home-header__notice-btn hl-icon-btn" data-shell-action="open-notifications" type="button" title="Holonet alerts">
        <span class="swse-home-header__notice-icon">◌</span>
        <span>Alerts</span>
        {{#if vm.notificationCenter.totalUnread}}<span class="swse-home-header__notice-badge hl-badge">{{vm.notificationCenter.totalUnread}}</span>{{/if}}
      </button>
      <div class="swse-home-header__actor hl-hud-pill"><span class="hl-dot"></span>{{vm.actorName}}</div>
      <form class="hl-presence-form" data-holonet-action="set-presence">
        <select name="preset" title="Holonet status">
          <option value="available" {{#if (eq vm.presence.preset "available")}}selected{{/if}}>Available</option>
          <option value="ready" {{#if (eq vm.presence.preset "ready")}}selected{{/if}}>Ready</option>
          <option value="training" {{#if (eq vm.presence.preset "training")}}selected{{/if}}>Training</option>
          <option value="shopping" {{#if (eq vm.presence.preset "shopping")}}selected{{/if}}>Shopping</option>
          <option value="need-gm" {{#if (eq vm.presence.preset "need-gm")}}selected{{/if}}>Need GM</option>
          <option value="away" {{#if (eq vm.presence.preset "away")}}selected{{/if}}>Away</option>
        </select>
        <input type="text" name="status" value="{{vm.presence.status}}" placeholder="Set status...">
        <input type="hidden" name="visibility" value="party">
        <button type="submit" class="hl-icon-btn">Set</button>
      </form>
    </div>
  </div>

  <div class="swse-shell-surface__body swse-messenger-body hl-shell">
    <nav class="hl-applist" aria-label="Holocom applications">
      <button class='hl-appbtn {{#unless (eq vm.appMode "jobs")}}on{{/unless}}' data-holonet-action="set-app-mode" data-app-mode="chat" type="button" title="Chat">
        <span class="ic">✉</span>
        <span>Chat</span>
        {{#if vm.unreadCount}}<span class="pip">{{vm.unreadCount}}</span>{{/if}}
      </button>
      <button class="hl-appbtn" data-shell-action="open-notifications" type="button" title="Alerts">
        <span class="ic">!</span>
        <span>Alerts</span>
        {{#if vm.notificationCenter.totalUnread}}<span class="pip">{{vm.notificationCenter.totalUnread}}</span>{{/if}}
      </button>
      <button class="hl-appbtn" data-holonet-action="open-compose" type="button" title="New Transmission">
        <span class="ic">+</span>
        <span>New</span>
      </button>
      <button class='hl-appbtn {{#if (eq vm.appMode "jobs")}}on{{/if}}' data-holonet-action="set-app-mode" data-app-mode="jobs" type="button" title="Job Board">
        <span class="ic">◆</span>
        <span>Jobs</span>
        {{#if vm.jobThreads.length}}<span class="pip">{{vm.jobThreads.length}}</span>{{/if}}
      </button>
      {{#if vm.canCreateJobs}}
      <button class="hl-appbtn gm" data-holonet-action="open-compose" type="button" title="GM Post">
        <span class="ic">＋</span>
        <span>GM</span>
      </button>
      {{/if}}
    </nav>

    <main class="hl-main-area">
      {{#if (eq vm.appMode "jobs")}}
      <section class="hl-jobboard-view swse-panel">
        <header class="hl-jobboard-head">
          <div>
            <div class="hl-label hl-label--accent">Job Board</div>
            <h2>Active Holocom Contracts</h2>
            <p>Open, accepted, and completed job signals routed through the party channel.</p>
          </div>
          <div class="hl-jobboard-controls" aria-label="Job board filters">
            <span class="hl-jobboard-tab on">All</span>
            <span class="hl-jobboard-tab">Open</span>
            <span class="hl-jobboard-tab">Accepted</span>
            <span class="hl-jobboard-tab">Completed</span>
          </div>
        </header>
        {{#if vm.hasJobThreads}}
        <div class="hl-job-grid">
          {{#each vm.jobThreads}}
          <button class="hl-job-card swse-messenger-thread" data-thread-id="{{this.id}}" type="button">
            <div class="hl-job-card-top">
              <span class="hl-job-giver">{{#if this.ownerLabel}}{{this.ownerLabel}}{{else}}Holonet Contact{{/if}}</span>
              <span class="hl-job-status">{{#if this.job.statusLabel}}{{this.job.statusLabel}}{{else}}Open{{/if}}</span>
            </div>
            <h3>{{this.title}}</h3>
            <p>{{this.preview}}</p>
            <div class="hl-job-tags">
              <span class="hl-chip job">Job</span>
              {{#if this.isPendingInvite}}<span class="hl-chip warn">Invite Pending</span>{{/if}}
              {{#if this.canManage}}<span class="hl-chip owner">Owner</span>{{/if}}
            </div>
            <div class="hl-job-card-foot">
              <strong>{{#if this.job.rewardCreditsLabel}}{{this.job.rewardCreditsLabel}}{{else}}{{#if this.job.rewardCredits}}{{this.job.rewardCredits}} cr{{else}}Reward TBD{{/if}}{{/if}}</strong>
              <span>{{#if this.job.hasObjectives}}{{this.job.objectives.length}} objective(s){{else}}No objectives logged{{/if}}</span>
            </div>
          </button>
          {{/each}}
        </div>
        {{else}}
        <div class="hl-job-empty">
          <div class="hl-conv-empty-icon">◆</div>
          <div class="hl-label">No job signals available.</div>
          {{#if vm.canCreateJobs}}<button class="hl-btn-accent" data-holonet-action="open-compose" type="button">Post New Job</button>{{/if}}
        </div>
        {{/if}}
      </section>
      {{else}}
      <div class="hl-ms-root {{#if vm.selectedThread}}has-thread{{/if}} {{#if vm.selectedThread.job}}info-open{{/if}}">
    <aside class="swse-messenger-threads swse-panel hl-tlist">
      <div class="hl-tlist-top">
        <div class="hl-tlist-hd">
          <div>
            <div class="swse-panel__title hl-label hl-label--accent">Transmissions</div>
            <div class="swse-messenger-rail-subtitle hl-subtle">Private, party, job, and side-channel traffic</div>
          </div>
          <button class="swse-messenger-icon-btn hl-new-btn" data-holonet-action="open-compose" type="button" title="New Transmission">＋</button>
        </div>
      </div>

      <form class="hl-thread-filter-form hl-search-form" data-holonet-action="thread-filter">
        <div class="hl-search-wrap">
          <span class="hl-search-icon">⌕</span>
          <input class="hl-search" type="search" name="threadSearch" value="{{vm.threadSearch}}" placeholder="Search threads..." aria-label="Search messenger threads">
        </div>
        <label class="hl-thread-filter-toggle">
          <input type="checkbox" name="includeArchived" value="true" {{#if vm.includeArchived}}checked{{/if}}>
          <span>Archived</span>
        </label>
        <button class="hl-icon-btn" type="submit">Filter</button>
        {{#if vm.hasThreadSearch}}<button class="hl-ghost-btn" data-holonet-action="clear-thread-filter" type="button">Clear</button>{{/if}}
      </form>

      <div class="swse-messenger-thread-list hl-tlist-scroll">
        {{#if vm.threads.length}}
          <div class="hl-cat hl-cat--requests">
            <div class="hl-cat-label">Holocom Requests</div>
            {{#each vm.threads}}
            {{#if this.isPendingInvite}}
            <div class="hl-invite hl-invite--rail">
              <div class="hl-invite-badge"><span class="hl-pulse-dot"></span><strong>{{this.title}}</strong></div>
              <div class="hl-subtle">{{this.preview}}</div>
              <div class="hl-action-row">
                <button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-invite" data-thread-id="{{this.id}}" type="button">Accept</button>
                <button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-invite" data-thread-id="{{this.id}}" type="button">Decline</button>
              </div>
            </div>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">Channels</div>
            {{#each vm.threads}}
            {{#if this.isParty}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">Party</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">Side</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">Job</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">Private</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">Invite</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">Muted</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">Owner</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">Job Signals</div>
            {{#each vm.threads}}
            {{#if this.isJob}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">Party</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">Side</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">Job</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">Private</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">Invite</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">Muted</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">Owner</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">Side Deals</div>
            {{#each vm.threads}}
            {{#if this.isSide}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">Party</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">Side</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">Job</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">Private</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">Invite</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">Muted</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">Owner</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">Private</div>
            {{#each vm.threads}}
            {{#if this.isPrivate}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">Party</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">Side</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">Job</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">Private</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">Invite</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">Muted</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">Owner</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>
        {{else}}
          <div class="swse-messenger-empty hl-empty">No transmissions yet. Start a thread or wait for a contact to hail you.</div>
        {{/if}}
      </div>
    </aside>

    <section class="swse-messenger-main swse-panel hl-conv">
      {{#if vm.composeMode}}
      <div class="swse-messenger-compose-shell hl-compose-shell">
        <div class="swse-messenger-main-head hl-conv-header">
          <div>
            <div class="swse-panel__title hl-title">New Transmission</div>
            <div class="swse-messenger-rail-subtitle hl-subtle">Create a private holochat, side thread, party channel, or GM job posting.</div>
          </div>
        </div>

        <div class="hl-compose-scroll">
          <form class="swse-messenger-compose-new hl-compose-card" data-holonet-action="create-thread">
            <div class="swse-messenger-mode-grid hl-mode-grid">
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="private" checked>
                <span>Private Holochat</span>
                <small>Invite selected contacts. Recipients can accept or decline.</small>
              </label>
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="side">
                <span>Side Thread</span>
                <small>Create a flexible planning channel with invited members.</small>
              </label>
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="party">
                <span>Party Channel</span>
                <small>Open a shared crew channel for the current party.</small>
              </label>
            </div>

            <label class="swse-messenger-field hl-field">
              <span>Thread Title</span>
              <input type="text" name="title" placeholder="Optional transmission title">
            </label>
            {{#if vm.isGm}}
            <label class="swse-messenger-field hl-field">
              <span>Send As</span>
              <select name="senderRecipientId">
                <option value="{{vm.participantId}}">GM / Current Identity</option>
                {{#each vm.recipientOptions}}{{#if this.isPersona}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/if}}{{/each}}
              </select>
            </label>
            {{/if}}

            <div class="swse-messenger-recipient-picker hl-recipient-picker">
              <div class="swse-messenger-recipient-picker__title hl-label hl-label--accent">Recipients</div>
              <div class="swse-messenger-recipient-grid hl-recipient-grid">
                {{#each vm.recipientOptions}}
                <div class="swse-messenger-recipient-option hl-recipient-row hl-recipient-row--with-action {{#if this.isPersona}}swse-messenger-recipient-option--persona{{/if}}">
                  <label class="hl-recipient-choice">
                    <input type="checkbox" name="recipientIds" value="{{this.id}}">
                    {{#if this.avatar}}<img class="swse-messenger-recipient-option__avatar hl-avatar" src="{{this.avatar}}" alt="">{{else}}<span class="swse-messenger-recipient-option__avatar swse-messenger-recipient-option__avatar--blank hl-avatar hl-avatar--blank">◇</span>{{/if}}
                    <span class="swse-messenger-recipient-option__label">{{this.label}}</span>
                    <span class="swse-messenger-recipient-option__type hl-subtle">{{this.typeLabel}}</span>
                  </label>
                  {{#if this.canQuickStart}}<button class="swse-messenger-mini-btn hl-ghost-btn" data-holonet-action="quick-thread" data-recipient-id="{{this.id}}" type="button">Hail</button>{{/if}}
                </div>
                {{/each}}
              </div>
            </div>

            <textarea name="body" rows="5" placeholder="Message thread..." data-holonet-editor="message"></textarea>
            <label class="swse-messenger-field swse-messenger-field--inline hl-field">
              <span>Holostill / Image Path</span>
              <input type="text" name="imageUrl" placeholder="Optional image path or URL">
            </label>
            <div class="hl-drop-zone" data-holonet-drop-zone data-holonet-drop-input="attachmentUuids">
              <b>Drop Item Cards Here</b>
              <span>Compendium or actor items attach to this transmission.</span>
            </div>
            <div class="swse-messenger-composer__meta hl-composer-meta">
              <div class="swse-messenger-help hl-help">
                {{#each vm.composerHelp}}<span>{{this}}</span>{{/each}}
              </div>
              <button type="submit" class="swse-btn swse-btn--primary hl-btn-accent">Send Hail</button>
            </div>
          </form>

          {{#if vm.canCreateJobs}}
          <form class="swse-messenger-compose-new swse-messenger-job-form hl-job-compose" data-holonet-action="create-job">
            <div class="swse-messenger-detail-card__title hl-title">GM Job Board Posting</div>
            <label class="swse-messenger-field hl-field">
              <span>Job Title</span>
              <input type="text" name="title" placeholder="Kessel Run Escort, Bounty Pickup, Supply Contract...">
            </label>
            <label class="swse-messenger-field hl-field">
              <span>Job Brief</span>
              <textarea name="body" rows="4" placeholder="Describe the job, risks, contact expectations, and payment terms."></textarea>
            </label>
            <div class="swse-messenger-job-grid hl-form-grid">
              <label class="swse-messenger-field hl-field">
                <span>Credit Reward</span>
                <input type="number" name="rewardCredits" min="0" step="1" placeholder="0">
              </label>
              <label class="swse-messenger-field hl-field">
                <span>Item / Gear Rewards</span>
                <input type="text" name="rewardItems" placeholder="Optional item notes or promised gear">
              </label>
              <div class="hl-drop-zone hl-drop-zone--compact" data-holonet-drop-zone data-holonet-drop-input="rewardItemUuids">
                <b>Drop Reward Items</b>
                <span>Drag compendium item cards here for job payment.</span>
              </div>
            </div>
            <label class="swse-messenger-field hl-field">
