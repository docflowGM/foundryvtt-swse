                      <div class="hl-credit-actions">
                        <button class="hl-icon-btn red" data-holonet-action="destroy-secret-note" data-record-id="{{this.id}}" data-reason="gm-destroy" type="button">Destroy Note</button>
                      </div>
                      {{/if}}
                    </div>
                    {{else}}
                    <div class="swse-msg__body hl-msg-text">{{{this.bodyHtml}}}</div>
                    {{#if this.imageUrl}}<img class="swse-msg__image hl-msg-image" src="{{this.imageUrl}}" alt="Holonet attachment">{{/if}}
                    {{#if this.hasAttachments}}
                    <div class="hl-attachments">
                      {{#each this.attachments}}
                      <div class="hl-attachment-card">{{#if this.img}}<img src="{{this.img}}" alt="">{{else}}<span>▣</span>{{/if}}<b>{{this.name}}</b><small>{{this.type}}</small></div>
                      {{/each}}
                    </div>
                    {{/if}}
                    {{/if}}
                    <div class="swse-msg__time hl-msg-time">
                      <span>{{this.createdAt}}</span>
                      {{#if this.canPin}}{{#if this.isPinned}}<button type="button" class="hl-pin-btn" data-holonet-action="thread-action" data-thread-action="unpin-message" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}">Unpin</button>{{else}}<button type="button" class="hl-pin-btn" data-holonet-action="thread-action" data-thread-action="pin-message" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}">Pin</button>{{/if}}{{/if}}
                    </div>
                  </div>
                </article>
                {{/if}}
                {{/if}}
                {{/if}}
                {{/if}}
                {{/if}}
                {{/if}}
              </div>
              {{/each}}
            {{else}}
              <div class="swse-messenger-empty hl-empty">Thread is empty.</div>
            {{/if}}
          </div>

          {{#if vm.selectedThread.canSend}}
          <form class="swse-messenger-composer hl-composer hl-composer--concept" data-holonet-action="send-message" data-thread-id="{{vm.selectedThread.id}}">
