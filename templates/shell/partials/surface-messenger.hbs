                      {{#if this.assetTransfer.canApprove}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="approve-asset-transfer" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.GMApprove"}}</button>{{/if}}
                      {{#if this.assetTransfer.canAcceptCounter}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-asset-counter" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.AcceptCounter"}}</button>{{/if}}
                      {{#if this.assetTransfer.canApproveCounter}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="approve-asset-counter" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.GMApproveCounter"}}</button>{{/if}}
                      {{#if this.assetTransfer.canDeclineCounter}}<button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-asset-counter" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.DeclineCounter"}}</button>{{/if}}
                      {{#if this.assetTransfer.canAccept}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-asset-transfer" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.AcceptAsset"}}</button>{{/if}}
                      {{#if this.assetTransfer.canDecline}}<button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-asset-transfer" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>{{/if}}
                      {{#if this.assetTransfer.canCancel}}<button class="hl-icon-btn red" data-holonet-action="thread-action" data-thread-action="cancel-asset-transfer" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>{{/if}}
                    </div>
                  </div>
                </article>
                {{else}}
                {{#if this.hasGameInvite}}
                <article class="swse-msg-system hl-game-invite-card-wrap">
                  <div class="hl-attach-card hl-game-invite-card">
                    <div class="hl-credit-title">{{localize "SWSE.ShellUI.HolopadGameInvite"}}</div>
                    <div class="hl-title">{{this.gameInvite.gameTitle}}</div>
                    <div class="hl-credit-line">{{localize "SWSE.ShellUI.Rules2"}} <strong>{{this.gameInvite.rulesLabel}}</strong></div>
                    {{#if this.gameInvite.buyInLabel}}<div class="hl-credit-line">{{localize "SWSE.ShellUI.BuyIn2"}} <strong>{{this.gameInvite.buyInLabel}}</strong></div>{{/if}}
                    {{#if this.gameInvite.hostLabel}}<div class="hl-credit-line">Host: {{this.gameInvite.hostLabel}}</div>{{/if}}
                    {{#if this.gameInvite.invitedLabel}}<div class="hl-credit-line">Invited: {{this.gameInvite.invitedLabel}}</div>{{/if}}
                    {{#if this.gameInvite.memo}}<div class="hl-credit-memo">Memo: {{this.gameInvite.memo}}</div>{{/if}}
                    <div class="hl-credit-status">{{this.gameInvite.statusLabel}}</div>
                    <div class="hl-credit-actions">
                      {{#if this.gameInvite.canAccept}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-game-invite" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.AcceptInvite"}}</button>{{/if}}
                      {{#if this.gameInvite.canDecline}}<button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-game-invite" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>{{/if}}
                      {{#if this.gameInvite.canCancel}}<button class="hl-icon-btn red" data-holonet-action="thread-action" data-thread-action="cancel-game-invite" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>{{/if}}
                    </div>
                  </div>
                </article>
                {{else}}
                {{#if this.hasReceipt}}
                <article class="swse-msg-system hl-receipt-card-wrap">
                  <div class="hl-receipt-card">
                    <div class="hl-credit-title">{{this.receipt.title}}</div>
                    {{#if this.receipt.amountLabel}}<div class="hl-credit-amount">{{this.receipt.amountLabel}}</div>{{/if}}
                    {{#each this.receipt.lines}}<div class="hl-credit-line">{{this}}</div>{{/each}}
                  </div>
                </article>
                {{else}}
                {{#if this.isSystem}}
                <article class="swse-msg-system hl-sys-msg">
                  <span class="hl-sys-line"></span><span>{{{this.bodyHtml}}}</span><span class="hl-sys-line"></span>
                </article>
                {{else}}
                <article class="swse-msg-row hl-msg {{#if this.isOwn}}swse-msg-row--own own{{else}}swse-msg-row--other other{{/if}} {{#if this.isUnread}}swse-msg-row--unread{{/if}}">
                  {{#if this.isOther}}
                    {{#if this.senderAvatar}}<img class="swse-msg-avatar hl-avatar" src="{{this.senderAvatar}}" alt="">{{else}}<span class="swse-msg-avatar swse-msg-avatar--blank hl-avatar hl-avatar--blank">◇</span>{{/if}}
                  {{/if}}
                  <div class="swse-msg-bubble hl-msg-bubble {{#if this.isOwn}}swse-msg-bubble--own{{else}}swse-msg-bubble--other{{/if}}">
                    {{#unless this.sameSenderAsPrevious}}<div class="swse-msg__sender hl-msg-meta">{{this.senderLabel}}</div>{{/unless}}
                    {{#if this.hasSecretNote}}
                    <div class="hl-secret-note-card {{#if this.secretNote.isSealed}}is-sealed{{/if}}" data-record-id="{{this.id}}" {{#if this.secretNote.canAutoDestroy}}data-secret-note-expire-ms="{{this.secretNote.expiresAtMs}}"{{/if}}>
                      <div class="hl-secret-note-head">
                        <span class="hl-secret-note-sigil">✷</span>
                        <div>
                          <div class="hl-label hl-label--accent">{{this.secretNote.sourceLabel}}</div>
                          <h4>{{this.secretNote.title}}</h4>
                        </div>
                        <span class="hl-chip warn">{{this.secretNote.status}}</span>
                      </div>
                      {{#if this.secretNote.isSealed}}
                      <p class="hl-secret-note-locked">{{localize "SWSE.ShellUI.EncryptedPayloadSealedRevealOnlyWhenThePlayer"}}</p>
                      <div class="hl-credit-actions">
                        <button class="hl-btn-accent" data-holonet-action="reveal-secret-note" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.RevealNote"}}</button>
                      </div>
                      {{else}}
                      <div class="hl-secret-note-body holonet-rendered-text">{{{this.secretNote.bodyHtml}}}</div>
                      {{#if this.secretNote.hasDecryption}}
                      <div class="hl-decryption-console {{#if this.secretNote.decryption.solved}}is-solved{{/if}} {{#if this.secretNote.decryption.failed}}is-failed{{/if}}">
                        <div class="hl-decryption-head">
                          <div><span class="hl-label hl-label--accent">DECRYPTION MATRIX</span><strong>{{this.secretNote.decryption.levelLabel}}</strong></div>
                          <span class="hl-chip">{{this.secretNote.decryption.percent}}%</span>
                        </div>
                        {{#if this.secretNote.decryption.locked}}
                        <div class="hl-decryption-grid" aria-label="Encrypted glyph stream">
                          {{#each this.secretNote.decryption.tokens}}
                            {{#if (eq this.type "sep")}}<span class="hl-decryption-sep">{{this.text}}</span>{{else}}
                            <span class="hl-decryption-word">
                              {{#each this.cells}}<span class="hl-decryption-cell {{#if this.isKnown}}is-known{{/if}}"><span class="hl-decryption-cipher">{{{this.glyphHtml}}}</span><b>{{this.plain}}</b></span>{{/each}}
                            </span>
                            {{/if}}
                          {{/each}}
                        </div>
                        <div class="hl-decryption-actions">
                          {{#each this.secretNote.decryption.skills}}
                          <button type="button" class="hl-btn-accent" data-holonet-action="attempt-secret-note-decryption" data-record-id="{{../id}}" data-skill-key="{{this.key}}" {{#if this.disabled}}disabled{{/if}}>{{this.label}} +{{this.mod}} vs DC {{../secretNote.decryption.dc}}</button>
                          {{/each}}
                          {{#if this.secretNote.decryption.canForceOpen}}<button type="button" class="hl-icon-btn" data-holonet-action="force-decrypt-secret-note" data-record-id="{{this.id}}">GM Decrypt</button>{{/if}}
                        </div>
                        {{else}}
                        <div class="hl-decryption-result holonet-rendered-text">{{{this.secretNote.decryption.decryptedText}}}</div>
                        {{/if}}
                        {{#if this.secretNote.decryption.log.length}}
                        <div class="hl-decryption-log">
                          {{#each this.secretNote.decryption.log}}<span class="{{this.cls}}">{{this.text}}</span>{{/each}}
                        </div>
                        {{/if}}
                      </div>
                      {{/if}}
                      {{#if this.secretNote.imageUrl}}<img class="swse-msg__image hl-msg-image" src="{{this.secretNote.imageUrl}}" alt="{{localize 'SWSE.ShellUI.SecretNoteImage'}}">{{/if}}
                      {{#if this.secretNote.hasAttachments}}
                      <div class="hl-attachments">
                        {{#each this.secretNote.attachments}}
                        <div class="hl-attachment-card">{{#if this.img}}<img src="{{this.img}}" alt="">{{else}}<span>▣</span>{{/if}}<b>{{this.name}}</b><small>{{this.type}}</small></div>
                        {{/each}}
                      </div>
                      {{/if}}
                      {{#if this.secretNote.selfDestruct}}<p class="hl-secret-note-countdown">This message will self-destruct: {{this.secretNote.expiryLabel}}</p>{{/if}}
                      {{/if}}
                      {{#if this.secretNote.canDestroy}}
                      <div class="hl-credit-actions">
                        <button class="hl-icon-btn red" data-holonet-action="destroy-secret-note" data-record-id="{{this.id}}" data-reason="gm-destroy" type="button">{{localize "SWSE.ShellUI.DestroyNote"}}</button>
                      </div>
                      {{/if}}
                    </div>
                    {{else}}
                    <div class="swse-msg__body hl-msg-text">{{{this.bodyHtml}}}</div>
                    {{#if this.imageUrl}}<img class="swse-msg__image hl-msg-image" src="{{this.imageUrl}}" alt="{{localize 'SWSE.ShellUI.HolonetAttachment'}}">{{/if}}
                    {{#if this.hasAttachments}}
                    <div class="hl-attachments">
                      {{#each this.attachments}}
                      <div class="hl-attachment-card">{{#if this.img}}<img src="{{this.img}}" alt="">{{else}}<span>▣</span>{{/if}}<b>{{this.name}}</b><small>{{this.type}}</small></div>
                      {{/each}}
                    </div>
                    {{/if}}
                    {{/if}}
                    <div class="swse-msg__time hl-msg-time">
                      <span>{{this.createdAt}}</span>
                      {{#if this.canPin}}{{#if this.isPinned}}<button type="button" class="hl-pin-btn" data-holonet-action="thread-action" data-thread-action="unpin-message" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}">{{localize "SWSE.ShellUI.Unpin"}}</button>{{else}}<button type="button" class="hl-pin-btn" data-holonet-action="thread-action" data-thread-action="pin-message" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}">{{localize "SWSE.ShellUI.Pin"}}</button>{{/if}}{{/if}}
                    </div>
                  </div>
                </article>
                {{/if}}
                {{/if}}
                {{/if}}
                {{/if}}
                {{/if}}
                {{/if}}
              </div>
              {{/each}}
            {{else}}
              <div class="swse-messenger-empty hl-empty">{{localize "SWSE.ShellUI.ThreadIsEmpty"}}</div>
            {{/if}}
          </div>

          {{#if vm.selectedThread.canSend}}
          <form class="swse-messenger-composer hl-composer hl-composer--concept" data-holonet-action="send-message" data-thread-id="{{vm.selectedThread.id}}">
            <div class="hl-composer-meta-row">
              {{#if vm.isGm}}
              <label class="swse-messenger-field swse-messenger-field--inline hl-persona-row">
                <span>{{localize "SWSE.ShellUI.SendingAs"}}</span>
                <select name="senderRecipientId">
                  <option value="{{vm.participantId}}">{{localize "SWSE.ShellUI.GMCurrentIdentity"}}</option>
                  {{#each vm.recipientOptions}}{{#if this.isPersona}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/if}}{{/each}}
                </select>
              </label>
              {{/if}}
              <label class="swse-messenger-field swse-messenger-field--inline hl-holostill-row">
                <span>{{localize "SWSE.ShellUI.Holostill"}}</span>
                <input type="text" name="imageUrl" placeholder="{{localize 'SWSE.ShellUI.OptionalImagePathOrURL'}}">
              </label>
            </div>
            <div class="hl-attach-dock">
              <button class="hl-attach-btn" type="button" title="{{localize 'SWSE.ShellUI.AttachOrTransfer'}}">⊞</button>
              <div class="hl-attach-menu-inline">
                {{#if vm.transferPolicy.creditsEnabled}}
                <button class="hl-attach-opt" data-holonet-action="open-credit-composer" data-composition-mode="send" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">₡</span><span>{{localize "SWSE.ShellUI.SendCredits"}}</span></button>
                <button class="hl-attach-opt" data-holonet-action="open-credit-composer" data-composition-mode="request" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">?</span><span>{{localize "SWSE.ShellUI.RequestCredits"}}</span></button>
                {{/if}}
                {{#if vm.transferPolicy.itemTradesEnabled}}
                <button class="hl-attach-opt" data-holonet-action="open-item-composer" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">⌬</span><span>{{localize "SWSE.ShellUI.Items"}}</span></button>
                {{/if}}
                {{#if vm.transferPolicy.assetTradesEnabled}}
                <button class="hl-attach-opt" data-holonet-action="open-asset-composer" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">▣</span><span>{{localize "SWSE.ShellUI.ShipDroid"}}</span></button>
                {{/if}}
                {{#if vm.isGm}}
                <button class="hl-attach-opt hl-attach-opt--secret" data-holonet-action="open-secret-note-composer" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">✷</span><span>{{localize "SWSE.ShellUI.SecretNote"}}</span></button>
                {{/if}}
              </div>
              <div class="hl-drop-zone hl-drop-zone--compact" data-holonet-drop-zone data-holonet-drop-input="attachmentUuids">
                <b>{{localize "SWSE.ShellUI.DropItemToAttach"}}</b><span>{{localize "SWSE.ShellUI.CompendiumItemsBecomeHolonetCards"}}</span>
              </div>
            </div>
            <div class="hl-composer-input-row">
              <textarea class="hl-composer-ta" name="body" rows="2" placeholder="Message {{vm.selectedThread.title}}..." data-holonet-editor="message"></textarea>
              <button type="submit" class="swse-btn swse-btn--primary hl-send-btn"><span>{{localize "SWSE.ShellUI.Send"}}</span><span aria-hidden="true">▶</span></button>
            </div>
          </form>
          {{/if}}
        </div>

        <aside class="swse-messenger-detail-column hl-info-panel">
          {{#if vm.selectedThread.job}}
          <div class="swse-messenger-detail-card hl-info-section hl-job-detail-card">
