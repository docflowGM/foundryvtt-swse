<div class="swse-shell-surface swse-shell-surface--messenger swse-holonet-comm" data-shell-region="surface-messenger" data-surface-id="{{vm.id}}">
  <div class="swse-shell-surface__header swse-messenger-header hl-hud hl-hud--concept">
    <button class="swse-shell-surface__back-btn hl-icon-btn" data-shell-action="return-to-home" type="button" title="{{localize 'SWSE.ShellUI.ReturnToHome'}}">
      <i class="fas fa-arrow-left"></i>
      <span>{{localize "SWSE.ShellUI.Home"}}</span>
    </button>

    <div class="swse-shell-surface__title hl-hud-title">
      <span>{{localize "SWSE.ShellUI.HOLOCOM"}}</span><small>{{localize "SWSE.ShellUI.ONLINE"}}</small>
      {{#if vm.unreadCount}}<span class="swse-messenger-title-badge hl-badge">{{vm.unreadCount}}</span>{{/if}}
    </div>

    <div class="swse-home-header__actions hl-hud-r">
      {{#if vm.partyFund.enabled}}
      <span class="hl-hud-pill hl-partyfund-pill">PARTY FUND // {{vm.partyFund.balance}} CR</span>
      {{/if}}
      {{#if vm.transferApprovalRequired}}<span class="hl-hud-pill">{{localize "SWSE.ShellUI.TRANSFERAPPROVALON"}}</span>{{/if}}
      <button class="swse-home-header__notice-btn hl-icon-btn" data-shell-action="open-notifications" type="button" title="{{localize 'SWSE.ShellUI.HolonetAlerts'}}">
        <span class="swse-home-header__notice-icon">◌</span>
        <span>{{localize "SWSE.ShellUI.Alerts"}}</span>
        {{#if vm.notificationCenter.totalUnread}}<span class="swse-home-header__notice-badge hl-badge">{{vm.notificationCenter.totalUnread}}</span>{{/if}}
      </button>
      <div class="swse-home-header__actor hl-hud-pill"><span class="hl-dot"></span>{{vm.actorName}}</div>
      <form class="hl-presence-form" data-holonet-action="set-presence">
        <select name="preset" title="{{localize 'SWSE.ShellUI.HolonetStatus'}}">
          <option value="available" {{#if (eq vm.presence.preset "available")}}selected{{/if}}>{{localize "SWSE.ShellUI.Available"}}</option>
          <option value="ready" {{#if (eq vm.presence.preset "ready")}}selected{{/if}}>{{localize "SWSE.ShellUI.Ready"}}</option>
          <option value="training" {{#if (eq vm.presence.preset "training")}}selected{{/if}}>{{localize "SWSE.ShellUI.Training"}}</option>
          <option value="shopping" {{#if (eq vm.presence.preset "shopping")}}selected{{/if}}>{{localize "SWSE.ShellUI.Shopping"}}</option>
          <option value="need-gm" {{#if (eq vm.presence.preset "need-gm")}}selected{{/if}}>{{localize "SWSE.ShellUI.NeedGM"}}</option>
          <option value="away" {{#if (eq vm.presence.preset "away")}}selected{{/if}}>{{localize "SWSE.ShellUI.Away"}}</option>
        </select>
        <input type="text" name="status" value="{{vm.presence.status}}" placeholder="{{localize 'SWSE.ShellUI.SetStatus'}}">
        <input type="hidden" name="visibility" value="party">
        <button type="submit" class="hl-icon-btn">{{localize "SWSE.ShellUI.Set"}}</button>
      </form>
    </div>
  </div>

  <div class="swse-shell-surface__body swse-messenger-body hl-shell">
    <nav class="hl-applist" aria-label="{{localize 'SWSE.ShellUI.HolocomApplications'}}">
      <button class='hl-appbtn {{#unless (eq vm.appMode "jobs")}}on{{/unless}}' data-holonet-action="set-app-mode" data-app-mode="chat" type="button" title="{{localize 'SWSE.ShellUI.Chat'}}">
        <span class="ic">✉</span>
        <span>{{localize "SWSE.ShellUI.Chat"}}</span>
        {{#if vm.unreadCount}}<span class="pip">{{vm.unreadCount}}</span>{{/if}}
      </button>
      <button class="hl-appbtn" data-shell-action="open-notifications" type="button" title="{{localize 'SWSE.ShellUI.Alerts'}}">
        <span class="ic">!</span>
        <span>{{localize "SWSE.ShellUI.Alerts"}}</span>
        {{#if vm.notificationCenter.totalUnread}}<span class="pip">{{vm.notificationCenter.totalUnread}}</span>{{/if}}
      </button>
      <button class="hl-appbtn" data-holonet-action="open-compose" type="button" title="{{localize 'SWSE.ShellUI.NewTransmission'}}">
        <span class="ic">+</span>
        <span>{{localize "SWSE.ShellUI.New"}}</span>
      </button>
      <button class='hl-appbtn {{#if (eq vm.appMode "jobs")}}on{{/if}}' data-holonet-action="set-app-mode" data-app-mode="jobs" type="button" title="{{localize 'SWSE.ShellUI.JobBoard'}}">
        <span class="ic">◆</span>
        <span>{{localize "SWSE.ShellUI.Jobs"}}</span>
        {{#if vm.jobThreads.length}}<span class="pip">{{vm.jobThreads.length}}</span>{{/if}}
      </button>
      {{#if vm.canCreateJobs}}
      <button class="hl-appbtn gm" data-holonet-action="open-compose" type="button" title="{{localize 'SWSE.ShellUI.GMPost'}}">
        <span class="ic">＋</span>
        <span>{{localize "SWSE.ShellUI.GM"}}</span>
      </button>
      {{/if}}
    </nav>

    <main class="hl-main-area">
      {{#if (eq vm.appMode "jobs")}}
      <section class="hl-jobboard-view swse-panel">
        <header class="hl-jobboard-head">
          <div>
            <div class="hl-label hl-label--accent">{{localize "SWSE.ShellUI.JobBoard"}}</div>
            <h2>{{localize "SWSE.ShellUI.ActiveHolocomContracts"}}</h2>
            <p>{{localize "SWSE.ShellUI.OpenAcceptedAndCompletedJobSignalsRoutedThrough"}}</p>
          </div>
          <div class="hl-jobboard-controls" aria-label="{{localize 'SWSE.ShellUI.JobBoardFilters'}}">
            <span class="hl-jobboard-tab on">{{localize "SWSE.ShellUI.All"}}</span>
            <span class="hl-jobboard-tab">{{localize "SWSE.ShellUI.Open"}}</span>
            <span class="hl-jobboard-tab">{{localize "SWSE.ShellUI.Accepted"}}</span>
            <span class="hl-jobboard-tab">{{localize "SWSE.ShellUI.Completed"}}</span>
          </div>
        </header>
        {{#if vm.hasJobThreads}}
        <div class="hl-job-grid">
          {{#each vm.jobThreads}}
          <button class="hl-job-card swse-messenger-thread" data-thread-id="{{this.id}}" type="button">
            <div class="hl-job-card-top">
              <span class="hl-job-giver">{{#if this.job.issuer.label}}{{this.job.issuer.label}}{{else}}{{#if this.ownerLabel}}{{this.ownerLabel}}{{else}}Holonet Contact{{/if}}{{/if}}</span>
              <span class="hl-job-status">{{#if this.job.statusLabel}}{{this.job.statusLabel}}{{else}}Open{{/if}}</span>
            </div>
            {{#if this.job.issuer}}
            <div class="hl-job-issuer-strip">
              {{#if this.job.issuer.hasImage}}<img src="{{this.job.issuer.image}}" alt="{{this.job.issuer.label}}">{{/if}}
              <div>
                <strong>{{this.job.issuer.label}}</strong>
                <span>{{this.job.issuer.typeLabel}}{{#if this.job.issuer.subline}} · {{this.job.issuer.subline}}{{/if}}</span>
              </div>
            </div>
            {{/if}}
            <h3>{{this.title}}</h3>
            <p>{{this.preview}}</p>
            <div class="hl-job-tags">
              <span class="hl-chip job">{{localize "SWSE.ShellUI.Job"}}</span>
              {{#if this.isPendingInvite}}<span class="hl-chip warn">{{localize "SWSE.ShellUI.InvitePending"}}</span>{{/if}}
              {{#if this.canManage}}<span class="hl-chip owner">{{localize "SWSE.ShellUI.Owner"}}</span>{{/if}}
            </div>
            <div class="hl-job-card-foot">
              <strong>{{#if this.job.rewardCreditsLabel}}{{this.job.rewardCreditsLabel}}{{else}}{{#if this.job.rewardCredits}}{{this.job.rewardCredits}} cr{{else}}Reward TBD{{/if}}{{/if}}</strong>
              <span>{{#if this.job.hasObjectives}}{{this.job.objectives.length}} objective(s){{else}}No objectives logged{{/if}}</span>
            </div>
          </button>
          {{/each}}
        </div>
        {{else}}
        <div class="hl-job-empty">
          <div class="hl-conv-empty-icon">◆</div>
          <div class="hl-label">{{localize "SWSE.ShellUI.NoJobSignalsAvailable"}}</div>
          {{#if vm.canCreateJobs}}<button class="hl-btn-accent" data-holonet-action="open-compose" type="button">{{localize "SWSE.ShellUI.PostNewJob"}}</button>{{/if}}
        </div>
        {{/if}}
      </section>
      {{else}}
      <div class="hl-ms-root {{#if vm.selectedThread}}has-thread{{/if}} {{#if vm.selectedThread.job}}info-open{{/if}}">
    <aside class="swse-messenger-threads swse-panel hl-tlist">
      <div class="hl-tlist-top">
        <div class="hl-tlist-hd">
          <div>
            <div class="swse-panel__title hl-label hl-label--accent">{{localize "SWSE.ShellUI.Transmissions"}}</div>
            <div class="swse-messenger-rail-subtitle hl-subtle">{{localize "SWSE.ShellUI.PrivatePartyJobAndSideChannelTraffic"}}</div>
          </div>
          <button class="swse-messenger-icon-btn hl-new-btn" data-holonet-action="open-compose" type="button" title="{{localize 'SWSE.ShellUI.NewTransmission'}}">＋</button>
        </div>
      </div>

      <form class="hl-thread-filter-form hl-search-form" data-holonet-action="thread-filter">
        <div class="hl-search-wrap">
          <span class="hl-search-icon">⌕</span>
          <input class="hl-search" type="search" name="threadSearch" value="{{vm.threadSearch}}" placeholder="{{localize 'SWSE.ShellUI.SearchThreads'}}" aria-label="{{localize 'SWSE.ShellUI.SearchMessengerThreads'}}">
        </div>
        <label class="hl-thread-filter-toggle">
          <input type="checkbox" name="includeArchived" value="true" {{#if vm.includeArchived}}checked{{/if}}>
          <span>{{localize "SWSE.ShellUI.Archived"}}</span>
        </label>
        <button class="hl-icon-btn" type="submit">{{localize "SWSE.ShellUI.Filter"}}</button>
        {{#if vm.hasThreadSearch}}<button class="hl-ghost-btn" data-holonet-action="clear-thread-filter" type="button">{{localize "SWSE.ShellUI.Clear"}}</button>{{/if}}
      </form>

      <div class="swse-messenger-thread-list hl-tlist-scroll">
        {{#if vm.threads.length}}
          <div class="hl-cat hl-cat--requests">
            <div class="hl-cat-label">{{localize "SWSE.ShellUI.HolocomRequests"}}</div>
            {{#each vm.threads}}
            {{#if this.isPendingInvite}}
            <div class="hl-invite hl-invite--rail">
              <div class="hl-invite-badge"><span class="hl-pulse-dot"></span><strong>{{this.title}}</strong></div>
              <div class="hl-subtle">{{this.preview}}</div>
              <div class="hl-action-row">
                <button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-invite" data-thread-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Accept"}}</button>
                <button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-invite" data-thread-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>
              </div>
            </div>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">{{localize "SWSE.ShellUI.Channels"}}</div>
            {{#each vm.threads}}
            {{#if this.isParty}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">{{localize "SWSE.ShellUI.Party"}}</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">{{localize "SWSE.ShellUI.Side"}}</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">{{localize "SWSE.ShellUI.Job"}}</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">{{localize "SWSE.ShellUI.Private"}}</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">{{localize "SWSE.ShellUI.Invite"}}</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">{{localize "SWSE.ShellUI.Muted"}}</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">{{localize "SWSE.ShellUI.Owner"}}</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">{{localize "SWSE.ShellUI.JobSignals"}}</div>
            {{#each vm.threads}}
            {{#if this.isJob}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">{{localize "SWSE.ShellUI.Party"}}</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">{{localize "SWSE.ShellUI.Side"}}</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">{{localize "SWSE.ShellUI.Job"}}</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">{{localize "SWSE.ShellUI.Private"}}</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">{{localize "SWSE.ShellUI.Invite"}}</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">{{localize "SWSE.ShellUI.Muted"}}</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">{{localize "SWSE.ShellUI.Owner"}}</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">{{localize "SWSE.ShellUI.SideDeals"}}</div>
            {{#each vm.threads}}
            {{#if this.isSide}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">{{localize "SWSE.ShellUI.Party"}}</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">{{localize "SWSE.ShellUI.Side"}}</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">{{localize "SWSE.ShellUI.Job"}}</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">{{localize "SWSE.ShellUI.Private"}}</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">{{localize "SWSE.ShellUI.Invite"}}</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">{{localize "SWSE.ShellUI.Muted"}}</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">{{localize "SWSE.ShellUI.Owner"}}</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>

          <div class="hl-cat">
            <div class="hl-cat-label">{{localize "SWSE.ShellUI.Private"}}</div>
            {{#each vm.threads}}
            {{#if this.isPrivate}}
            <button class="swse-messenger-thread hl-titem {{#if (eq ../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isPendingInvite}}swse-messenger-thread--invite hl-titem--invite{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
              <span class="hl-titem-icon">{{#if this.isJob}}◆{{else}}{{#if this.isParty}}#{{else}}{{#if this.isSide}}◇{{else}}⊕{{/if}}{{/if}}{{/if}}</span>
              <span class="hl-titem-body">
                <span class="hl-titem-top">
                  <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                  <span class="hl-titem-right">
                    {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                  </span>
                </span>
                <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                <span class="swse-messenger-thread__chips hl-titem-chips">
                  {{#if this.isParty}}<span class="swse-messenger-chip swse-messenger-chip--party hl-chip party">{{localize "SWSE.ShellUI.Party"}}</span>{{/if}}
                  {{#if this.isSide}}<span class="swse-messenger-chip swse-messenger-chip--side hl-chip">{{localize "SWSE.ShellUI.Side"}}</span>{{/if}}
                  {{#if this.isJob}}<span class="swse-messenger-chip swse-messenger-chip--job hl-chip job">{{localize "SWSE.ShellUI.Job"}}</span>{{/if}}
                  {{#if this.isPrivate}}<span class="swse-messenger-chip swse-messenger-chip--private hl-chip private">{{localize "SWSE.ShellUI.Private"}}</span>{{/if}}
                  {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">{{localize "SWSE.ShellUI.Invite"}}</span>{{/if}}
                  {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">{{localize "SWSE.ShellUI.Muted"}}</span>{{/if}}
                  {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">{{localize "SWSE.ShellUI.Owner"}}</span>{{/if}}
                </span>
              </span>
            </button>
            {{/if}}
            {{/each}}
          </div>
        {{else}}
          <div class="swse-messenger-empty hl-empty">{{localize "SWSE.ShellUI.NoTransmissionsYetStartAThreadOrWait"}}</div>
        {{/if}}
      </div>
    </aside>

    <section class="swse-messenger-main swse-panel hl-conv">
      {{#if vm.composeMode}}
      <div class="swse-messenger-compose-shell hl-compose-shell">
        <div class="swse-messenger-main-head hl-conv-header">
          <div>
            <div class="swse-panel__title hl-title">{{localize "SWSE.ShellUI.NewTransmission"}}</div>
            <div class="swse-messenger-rail-subtitle hl-subtle">{{localize "SWSE.ShellUI.CreateAPrivateHolochatSideThreadPartyChannel"}}</div>
          </div>
        </div>

        <div class="hl-compose-scroll">
          <form class="swse-messenger-compose-new hl-compose-card" data-holonet-action="create-thread">
            <div class="swse-messenger-mode-grid hl-mode-grid">
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="private" checked>
                <span>{{localize "SWSE.ShellUI.PrivateHolochat"}}</span>
                <small>{{localize "SWSE.ShellUI.InviteSelectedContactsRecipientsCanAcceptOrDecline"}}</small>
              </label>
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="side">
                <span>{{localize "SWSE.ShellUI.SideThread"}}</span>
                <small>{{localize "SWSE.ShellUI.CreateAFlexiblePlanningChannelWithInvitedMembers"}}</small>
              </label>
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="party">
                <span>{{localize "SWSE.ShellUI.PartyChannel"}}</span>
                <small>{{localize "SWSE.ShellUI.OpenASharedCrewChannelForTheCurrent"}}</small>
              </label>
            </div>

            <label class="swse-messenger-field hl-field">
              <span>{{localize "SWSE.ShellUI.ThreadTitle"}}</span>
              <input type="text" name="title" placeholder="{{localize 'SWSE.ShellUI.OptionalTransmissionTitle'}}">
            </label>
            {{#if vm.isGm}}
            <label class="swse-messenger-field hl-field">
              <span>{{localize "SWSE.ShellUI.SendAs"}}</span>
              <select name="senderRecipientId">
                <option value="{{vm.participantId}}">{{localize "SWSE.ShellUI.GMCurrentIdentity"}}</option>
                {{#each vm.recipientOptions}}{{#if this.isPersona}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/if}}{{/each}}
              </select>
            </label>
            {{/if}}

