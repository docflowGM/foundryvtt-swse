                <select name="senderRecipientId">
                  <option value="{{vm.participantId}}">GM / Current Identity</option>
                  {{#each vm.recipientOptions}}{{#if this.isPersona}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/if}}{{/each}}
                </select>
              </label>
              {{/if}}
              <label class="swse-messenger-field swse-messenger-field--inline hl-holostill-row">
                <span>Holostill</span>
                <input type="text" name="imageUrl" placeholder="Optional image path or URL">
              </label>
            </div>
            <div class="hl-attach-dock">
              <button class="hl-attach-btn" type="button" title="Attach or transfer">⊞</button>
              <div class="hl-attach-menu-inline">
                {{#if vm.transferPolicy.creditsEnabled}}
                <button class="hl-attach-opt" data-holonet-action="open-credit-composer" data-composition-mode="send" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">₡</span><span>Send Credits</span></button>
                <button class="hl-attach-opt" data-holonet-action="open-credit-composer" data-composition-mode="request" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">?</span><span>Request Credits</span></button>
                {{/if}}
                {{#if vm.transferPolicy.itemTradesEnabled}}
                <button class="hl-attach-opt" data-holonet-action="open-item-composer" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">⌬</span><span>Items</span></button>
                {{/if}}
                {{#if vm.transferPolicy.assetTradesEnabled}}
                <button class="hl-attach-opt" data-holonet-action="open-asset-composer" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">▣</span><span>Ship / Droid</span></button>
                {{/if}}
                {{#if vm.isGm}}
                <button class="hl-attach-opt hl-attach-opt--secret" data-holonet-action="open-secret-note-composer" data-thread-id="{{vm.selectedThread.id}}" type="button"><span class="hl-attach-opt-icon">✷</span><span>Secret Note</span></button>
                {{/if}}
              </div>
              <div class="hl-drop-zone hl-drop-zone--compact" data-holonet-drop-zone data-holonet-drop-input="attachmentUuids">
                <b>Drop Item to Attach</b><span>Compendium items become Holonet cards.</span>
              </div>
            </div>
            <div class="hl-composer-input-row">
              <textarea class="hl-composer-ta" name="body" rows="2" placeholder="Message {{vm.selectedThread.title}}..." data-holonet-editor="message"></textarea>
              <button type="submit" class="swse-btn swse-btn--primary hl-send-btn"><span>Send</span><span aria-hidden="true">▶</span></button>
            </div>
          </form>
          {{/if}}
        </div>

        <aside class="swse-messenger-detail-column hl-info-panel">
          {{#if vm.selectedThread.job}}
          <div class="swse-messenger-detail-card hl-info-section hl-job-detail-card">
            <div class="swse-messenger-detail-card__title hl-info-label">Job Board</div>
            <div class="hl-title">{{vm.selectedThread.job.title}}</div>
            <div class="hl-chip job">{{vm.selectedThread.job.statusLabel}}</div>
            {{#if vm.selectedThread.job.rewardCredits}}<div class="hl-credit-line">Credits: {{vm.selectedThread.job.rewardCredits}} cr</div>{{/if}}
            {{#if vm.selectedThread.job.rewardItems}}<div class="hl-credit-line">Items: {{vm.selectedThread.job.rewardItems}}</div>{{/if}}
            {{#if vm.selectedThread.job.hasObjectives}}
            <div class="hl-job-objectives">
              <div class="hl-info-label">Objectives</div>
              {{#each vm.selectedThread.job.objectives}}
              <div class="hl-job-objective-card">
                <div class="hl-credit-line"><strong>{{this.label}}</strong> <span class="hl-chip job">{{this.statusLabel}}</span>{{#if this.isRequired}} <span class="hl-chip warn">Required</span>{{/if}}</div>
                {{#if this.description}}<div class="hl-credit-memo">{{this.description}}</div>{{/if}}
                {{#if this.rewardCreditsLabel}}<div class="hl-credit-line">Objective credits: {{this.rewardCreditsLabel}}</div>{{/if}}
                {{#if ../vm.selectedThread.job.canManage}}
                <form class="hl-job-objective-form" data-holonet-action="job-objective-status" data-thread-id="{{../vm.selectedThread.id}}">
                  <input type="hidden" name="objectiveId" value="{{this.id}}">
                  <select name="objectiveStatus">
                    <option value="open">Open</option>
                    <option value="claimed">Claimed</option>
                    <option value="submitted">Submitted</option>
                    <option value="pendingReview">Pending Review</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                    <option value="failed">Failed</option>
                  </select>
                  <textarea name="objectiveNote" rows="2" placeholder="Objective note"></textarea>
                  <button class="hl-icon-btn gm" type="submit">Update Objective</button>
                </form>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{#if vm.selectedThread.job.canManage}}
            <form class="hl-job-status-form" data-holonet-action="job-status" data-thread-id="{{vm.selectedThread.id}}">
              <select name="status">
                <option value="posted">Posted</option>
                <option value="accepted">Accepted</option>
                <option value="inProgress">In Progress</option>
                <option value="review">Review</option>
                <option value="complete">Complete</option>
                <option value="paid">Paid</option>
                <option value="failed">Failed</option>
                <option value="archived">Archived</option>
              </select>
              <button class="hl-icon-btn gm" type="submit">Set Status</button>
            </form>
            {{#if vm.selectedThread.job.hasItemRewards}}
            <form class="hl-award-items-form" data-holonet-action="award-job-items" data-thread-id="{{vm.selectedThread.id}}">
              <select name="recipientId">
                {{#each vm.selectedThread.transferTargets}}{{#unless this.isPersona}}<option value="{{this.id}}">{{this.label}}</option>{{/unless}}{{/each}}
              </select>
              {{#each vm.selectedThread.job.rewardItemUuids}}<input type="hidden" name="itemUuids" value="{{this}}">{{/each}}
              <button class="hl-btn-accent" type="submit">Award Items</button>
            </form>
            {{/if}}
            {{/if}}
          </div>
          {{/if}}

          <div class="swse-messenger-detail-card hl-info-section">
            <div class="swse-messenger-detail-card__title hl-info-label">Participants</div>
            <div class="swse-messenger-participants">
              {{#each vm.selectedThread.participants}}
              <div class="swse-messenger-participant hl-info-person">
                {{#if this.avatar}}<img class="hl-avatar" src="{{this.avatar}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">◇</span>{{/if}}
                <b>{{this.label}}</b>
                <small>{{this.typeLabel}}</small>{{#if this.presenceStatus}}<em class="hl-presence-text">{{this.presenceStatus}}</em>{{/if}}
                {{#if ../vm.selectedThread.canManage}}
                  {{#unless this.isSelf}}<button class="hl-ghost-btn" data-holonet-action="thread-action" data-thread-action="remove-member" data-thread-id="{{../vm.selectedThread.id}}" data-recipient-id="{{this.id}}" type="button">Remove</button>{{/unless}}
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{#if vm.selectedThread.pendingInvites.length}}
            <div class="swse-messenger-detail-card__subtitle hl-info-label">Pending Invites</div>
            <div class="swse-messenger-participants swse-messenger-participants--pending">
              {{#each vm.selectedThread.pendingInvites}}
              <div class="swse-messenger-participant hl-info-person">
                {{#if this.avatar}}<img class="hl-avatar" src="{{this.avatar}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">◇</span>{{/if}}
                <b>{{this.label}}</b>
                <small>Invited</small>
                {{#if ../vm.selectedThread.canManage}}<button class="hl-ghost-btn" data-holonet-action="thread-action" data-thread-action="remove-member" data-thread-id="{{../vm.selectedThread.id}}" data-recipient-id="{{this.id}}" type="button">Cancel</button>{{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
          </div>

          {{#if vm.selectedThread.canManage}}
          <form class="swse-messenger-detail-card hl-info-section" data-holonet-action="manage-members" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">Add Members</div>
            <select name="recipientIds" multiple size="5">
              {{#each vm.selectedThread.addableRecipients}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/each}}
            </select>
            <div class="swse-messenger-member-actions hl-action-row">
              <button class="swse-btn hl-icon-btn" name="memberAction" value="invite-members" type="submit">Invite</button>
              {{#if vm.isGm}}<button class="swse-btn hl-icon-btn" name="memberAction" value="insert-members" type="submit">GM Insert</button>{{/if}}
            </div>
          </form>
          {{/if}}

          {{#if vm.transferPolicy.creditsEnabled}}
          {{#if vm.selectedThread.transferTargets.length}}
          <form class="swse-messenger-detail-card hl-info-section" data-holonet-action="transfer-credits" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">Credits</div>
            <div class="swse-messenger-credit-balance hl-subtle">Available: {{vm.actorCredits}} cr</div>
            <select name="recipientId">
              {{#each vm.selectedThread.transferTargets}}<option value="{{this.id}}">{{this.label}}</option>{{/each}}
            </select>
            <input type="number" name="amount" min="1" step="1" placeholder="Amount">
            {{#if vm.selectedThread.canUseJobPayout}}
            {{#if vm.partyFund.enabled}}
            <label class="hl-field hl-field--compact"><span>Party Fund Cut %</span><input type="number" name="partyFundCutPercent" min="0" max="100" step="1" value="{{vm.partyFund.defaultCutPercent}}"></label>
            {{/if}}
            {{/if}}
            <button class="swse-btn swse-btn--primary hl-btn-accent" name="transferMode" value="offer-credit-transfer" type="submit">Offer Transfer</button>
            {{#if vm.selectedThread.canUseJobPayout}}<button class="swse-btn hl-icon-btn" name="transferMode" value="job-payout" type="submit">Pay Job Reward</button>{{/if}}
          </form>
          {{/if}}
          {{/if}}

          {{#if vm.transferPolicy.itemTradesEnabled}}
          {{#if vm.isGm}}
          {{#if vm.selectedThread.transferTargets.length}}
          <form class="swse-messenger-detail-card hl-info-section hl-item-transfer-form" data-holonet-action="item-transfer" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">Item Delivery</div>
            <select name="recipientId">
              {{#each vm.selectedThread.transferTargets}}{{#unless this.isPersona}}<option value="{{this.id}}">{{this.label}}</option>{{/unless}}{{/each}}
            </select>
            <div class="hl-drop-zone" data-holonet-drop-zone data-holonet-drop-input="attachmentUuids">
              <b>Drop Item to Send</b><span>Recipient must accept before the item is granted.</span>
            </div>
            <button class="swse-btn hl-icon-btn" name="itemTransferMode" value="offer-item-transfer" type="submit">Offer Item</button>
          </form>
          {{/if}}
          {{/if}}
          {{/if}}

          {{#if vm.partyFund.enabled}}
          <form class="swse-messenger-detail-card hl-info-section hl-partyfund-card" data-holonet-action="party-fund" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">Party Fund</div>
            <div class="hl-credit-amount">{{vm.partyFund.balance}} cr</div>
            <input type="number" name="amount" min="1" step="1" placeholder="Amount">
            {{#if vm.isGm}}
            <select name="recipientId">
              {{#each vm.selectedThread.transferTargets}}{{#unless this.isPersona}}<option value="{{this.id}}">{{this.label}}</option>{{/unless}}{{/each}}
            </select>
            {{/if}}
            <button class="swse-btn swse-btn--primary hl-btn-accent" name="partyFundAction" value="contribute-party-fund" type="submit">Contribute</button>
            {{#if vm.isGm}}
            <button class="swse-btn hl-icon-btn" name="partyFundAction" value="pay-from-party-fund" type="submit">Pay Out</button>
            <button class="swse-btn hl-icon-btn red" name="partyFundAction" value="charge-party-fund" type="submit">Charge</button>
            {{/if}}
          </form>
          {{/if}}
        </aside>
      </div>
      {{else}}
      <div class="swse-messenger-empty hl-empty">Select a thread or start a new transmission.</div>
      {{/if}}
      {{/if}}
    </section>
      </div>
      {{/if}}
    </main>
  </div>
  {{#if vm.composition}}
  <div class="hl-composition-modal" data-holonet-composition-modal>
    <div class="hl-composition-backdrop" data-holonet-action="close-composer"></div>
    <section class="hl-composition-panel swse-panel">
      <header class="hl-composition-head">
        <div>
          <div class="hl-label hl-label--accent">{{vm.composition.title}}</div>
          <h3>{{vm.composition.actorName}}</h3>
        </div>
        <button class="hl-icon-btn" data-holonet-action="close-composer" type="button">Close</button>
      </header>

      {{#if (eq vm.composition.type "credits")}}
      <form class="hl-composition-form" data-holonet-action="submit-credit-composer" data-thread-id="{{vm.composition.threadId}}" data-composition-mode="{{vm.composition.mode}}">
        <div class="hl-bank-banner">
          <strong>Coruscant Credit Union</strong>
          <span>Available: {{vm.composition.actorCredits}} cr</span>
        </div>
        <label class="hl-field"><span>Amount</span><input type="number" name="amount" min="1" step="1" required></label>
        <label class="hl-field"><span>Memo</span><input type="text" name="memo" maxlength="120" placeholder="Optional memo line"></label>
        <div class="hl-recipient-picker">
          <div class="hl-label">Recipients</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="checkbox" name="recipientIds" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        {{#if vm.composition.hasMultipleTargets}}
        <div class="hl-split-options">
          <label><input type="radio" name="splitMode" value="split-total" checked> Split total amount between recipients</label>
          <label><input type="radio" name="splitMode" value="send-each"> {{#if (eq vm.composition.mode "request")}}Request this amount from each recipient{{else}}Send this amount to each recipient{{/if}}</label>
        </div>
        {{/if}}
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">{{#if (eq vm.composition.mode "request")}}Send Request{{else}}Send Credits{{/if}}</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">Cancel</button>
        </div>
      </form>
      {{/if}}

      {{#if (eq vm.composition.type "items")}}
      <form class="hl-composition-form" data-holonet-action="submit-item-composer" data-thread-id="{{vm.composition.threadId}}">
        <div class="hl-help hl-trade-guide">
          <strong>Trade flow:</strong> open this actor's owned inventory, click the items to add, choose recipient(s), then gift them or request credits/terms in exchange. Compendium items must be added to the actor first before players can offer them.
        </div>
        <div class="hl-inventory-launch-row">
          <div>
            <div class="hl-label hl-label--accent">Selected cargo</div>
            <div class="hl-subtle">{{#if vm.composition.inventory.itemCountLabel}}{{vm.composition.inventory.itemCountLabel}} available{{else}}Owned inventory picker{{/if}}</div>
          </div>
          <button class="hl-btn-accent hl-open-inventory-btn" data-holonet-action="toggle-inventory-picker" type="button" aria-expanded="false">Open Inventory</button>
        </div>
        <div class="hl-selected-cargo" data-holonet-selected-items>
          <div class="hl-selected-cargo-empty" data-holonet-selected-items-empty>No items selected yet.</div>
        </div>
        {{#if vm.composition.inventory.hasItems}}
        <section class="hl-inventory-picker" data-holonet-inventory-picker hidden>
          <div class="hl-filter-row">
            <label class="hl-field"><span>Filter inventory</span><input type="search" data-holonet-item-filter autocomplete="off" spellcheck="false" placeholder="Search item, type, equipped, value..."></label>
            <button class="hl-ghost-btn hl-filter-clear" data-holonet-action="clear-item-filter" type="button">Clear</button>
          </div>
          <div class="hl-item-composer-list hl-item-composer-list--flat" data-holonet-item-list>
            {{#each vm.composition.inventory.items}}
            <label class="hl-item-row hl-inventory-item-row" data-item-id="{{this.id}}" data-item-name="{{this.name}}" data-item-type="{{this.typeLabel}}" data-item-summary="{{this.summary}}" data-item-search="{{this.searchKey}}">
              <input type="checkbox" name="itemIds" value="{{this.id}}">
              {{#if this.img}}<img src="{{this.img}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">▣</span>{{/if}}
              <span class="hl-item-row__main">
                <b>{{this.name}}</b>
                <small>{{this.summary}}</small>
              </span>
              {{#if this.statusLabel}}<span class="hl-chip hl-item-status">{{this.statusLabel}}</span>{{else}}<span class="hl-chip muted">Inventory</span>{{/if}}
              <span class="hl-qty-control"><span>Qty</span><input type="number" name="quantity.{{this.id}}" min="1" max="{{this.quantity}}" value="1"></span>
            </label>
            {{/each}}
            <div class="hl-item-empty hl-item-empty--filter" data-holonet-item-filter-empty hidden>No matching owned items. Clear the filter or add the item to this actor first.</div>
          </div>
        </section>
        {{else}}
        <div class="hl-item-empty">{{vm.composition.inventory.emptyMessage}}</div>
        {{/if}}
        <label class="hl-field"><span>Memo</span><input type="text" name="memo" maxlength="120" placeholder="Optional trade memo"></label>
        <div class="hl-trade-terms">
          <label class="hl-trade-toggle"><input type="radio" name="tradeIntent" value="gift" checked><span><b>Send / gift these items</b><small>Recipient can accept or decline the transfer.</small></span></label>
          <label class="hl-trade-toggle"><input type="radio" name="tradeIntent" value="trade"><span><b>Request trade terms</b><small>Attach requested credits or a note for a counter-offer.</small></span></label>
          <label class="hl-field"><span>Requested Credits</span><input type="number" name="requestedCredits" min="0" step="1" placeholder="0"></label>
          <label class="hl-field"><span>Requested Items / Notes</span><input type="text" name="requestedItemsNote" maxlength="160" placeholder="Optional: ask for an item, service, or mixed trade"></label>
        </div>
        <div class="hl-recipient-picker">
          <div class="hl-label">Recipient(s)</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="checkbox" name="recipientIds" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        {{#if vm.composition.hasMultipleTargets}}
        <div class="hl-split-options">
          <label><input type="radio" name="distributionMode" value="single" checked> Send selected items to one chosen recipient</label>
          <label><input type="radio" name="distributionMode" value="split"> Split quantities across selected recipients</label>
        </div>
        {{/if}}
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">Continue / Send Offer</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">Cancel</button>
        </div>
      </form>
      {{/if}}

      {{#if (eq vm.composition.type "secret-note")}}
      <form class="hl-composition-form hl-secret-note-form" data-holonet-action="submit-secret-note-composer" data-thread-id="{{vm.composition.threadId}}">
        <div class="hl-help">Create a GM-only clue, puzzle, image, or secret transmission. Players can reveal it when ready; optional self-destruct starts after reveal.</div>
        <label class="hl-field"><span>Note Title</span><input type="text" name="title" maxlength="80" placeholder="Encrypted clue, puzzle fragment, strange signal..."></label>
        <label class="hl-field"><span>Secret Message</span><textarea name="body" rows="5" placeholder="The message, clue, or puzzle text the player will see after reveal."></textarea></label>
        <label class="hl-field"><span>Image / Puzzle Path</span><input type="text" name="imageUrl" placeholder="Optional image path or URL"></label>
        <div class="hl-form-grid">
          <label class="hl-field"><span>Source</span>
            <select name="source">
              <option value="messenger">Messenger</option>
              <option value="job">Job Reward</option>
              <option value="game">Game Reward</option>
              <option value="puzzle">Puzzle Drop</option>
              <option value="gm-note">GM Note</option>
            </select>
          </label>
          <label class="hl-field"><span>Self-Destruct</span>
            <select name="expiresAfterSeconds">
              <option value="0">Persistent</option>
              <option value="30">30 seconds after reveal</option>
              <option value="60">60 seconds after reveal</option>
              <option value="300">5 minutes after reveal</option>
            </select>
          </label>
        </div>
        <div class="hl-recipient-picker">
          <div class="hl-label">Optional extra recipients</div>
          <div class="hl-subtle">The current thread receives the note. Add recipients here only if they should be added to this thread too.</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="checkbox" name="recipientIds" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">Transmit Secret Note</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">Cancel</button>
        </div>
      </form>
      {{/if}}

      {{#if (eq vm.composition.type "assets")}}
      <form class="hl-composition-form" data-holonet-action="submit-asset-composer" data-thread-id="{{vm.composition.threadId}}">
        <div class="hl-help">Ship and droid trades move owned actor sheets. They default to GM approval unless the GM disables that requirement.</div>
        <label class="hl-field"><span>Filter</span><input type="search" data-holonet-asset-filter placeholder="Search ships, droids, vehicles..."></label>
        <div class="hl-item-composer-list">
          {{#each vm.composition.assets.categories}}
          <section class="hl-item-category" data-asset-category="{{this.name}}">
            <h4>{{this.name}}</h4>
            {{#each this.assets}}
            <label class="hl-item-row" data-asset-name="{{this.name}} {{this.typeLabel}}">
              <input type="checkbox" name="assetIds" value="{{this.id}}">
              {{#if this.img}}<img src="{{this.img}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">▣</span>{{/if}}
              <span><b>{{this.name}}</b><small>{{this.typeLabel}}{{#if this.summary}} · {{this.summary}}{{/if}}</small></span>
            </label>
            {{/each}}
          </section>
          {{/each}}
        </div>
        <label class="hl-field"><span>Requested Credits</span><input type="number" name="requestedCredits" min="0" step="1" placeholder="0"></label>
        <label class="hl-field"><span>Memo</span><input type="text" name="memo" maxlength="120" placeholder="Optional asset transfer memo"></label>
        <div class="hl-recipient-picker">
          <div class="hl-label">Recipient</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="radio" name="recipientId" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">Send Asset Offer</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">Cancel</button>
        </div>
      </form>
      {{/if}}
    </section>
  </div>
  {{/if}}

</div>
