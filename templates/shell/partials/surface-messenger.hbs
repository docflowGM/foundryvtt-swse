            {{#if vm.selectedThread.job.issuer}}
            <div class="hl-job-issuer-card">
              {{#if vm.selectedThread.job.issuer.hasImage}}<img src="{{vm.selectedThread.job.issuer.image}}" alt="{{vm.selectedThread.job.issuer.label}}">{{/if}}
              <div>
                <span class="hl-info-label">Issuer</span>
                <strong>{{vm.selectedThread.job.issuer.label}}</strong>
                <small>{{vm.selectedThread.job.issuer.typeLabel}}{{#if vm.selectedThread.job.issuer.subline}} · {{vm.selectedThread.job.issuer.subline}}{{/if}}</small>
              </div>
            </div>
            {{/if}}
            {{#if vm.selectedThread.job.rewardCredits}}<div class="hl-credit-line">Credits: {{vm.selectedThread.job.rewardCredits}} cr</div>{{/if}}
            {{#if vm.selectedThread.job.rewardItems}}<div class="hl-credit-line">Items: {{vm.selectedThread.job.rewardItems}}</div>{{/if}}
            {{#if vm.selectedThread.job.hasFactionConsequences}}
            <div class="hl-job-consequence-card">
              <div class="hl-info-label">Faction Consequences</div>
              {{#each vm.selectedThread.job.consequenceEntries}}
              <div class="hl-job-consequence-row {{#if this.isRival}}is-rival{{/if}}">
                <span>{{this.label}}</span>
                <strong>{{this.factionName}}</strong>
                <small>Success {{this.successDeltaLabel}} · Failure {{this.failureDeltaLabel}}</small>
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{#if vm.selectedThread.job.hasObjectives}}
            <div class="hl-job-objectives">
              <div class="hl-info-label">{{localize "SWSE.ShellUI.Objectives"}}</div>
              {{#each vm.selectedThread.job.objectives}}
              <div class="hl-job-objective-card">
                <div class="hl-credit-line"><strong>{{this.label}}</strong> <span class="hl-chip job">{{this.statusLabel}}</span>{{#if this.isRequired}} <span class="hl-chip warn">{{localize "SWSE.ShellUI.Required"}}</span>{{/if}}</div>
                {{#if this.description}}<div class="hl-credit-memo">{{this.description}}</div>{{/if}}
                {{#if this.rewardCreditsLabel}}<div class="hl-credit-line">Objective credits: {{this.rewardCreditsLabel}}</div>{{/if}}
                {{#if ../vm.selectedThread.job.canManage}}
                <form class="hl-job-objective-form" data-holonet-action="job-objective-status" data-thread-id="{{../vm.selectedThread.id}}">
                  <input type="hidden" name="objectiveId" value="{{this.id}}">
                  <select name="objectiveStatus">
                    <option value="open">{{localize "SWSE.ShellUI.Open"}}</option>
                    <option value="claimed">{{localize "SWSE.ShellUI.Claimed"}}</option>
                    <option value="submitted">{{localize "SWSE.ShellUI.Submitted"}}</option>
                    <option value="pendingReview">{{localize "SWSE.ShellUI.PendingReview"}}</option>
                    <option value="approved">{{localize "SWSE.ShellUI.Approved"}}</option>
                    <option value="rejected">{{localize "SWSE.ShellUI.Rejected"}}</option>
                    <option value="failed">{{localize "SWSE.ShellUI.Failed"}}</option>
                  </select>
                  <textarea name="objectiveNote" rows="2" placeholder="{{localize 'SWSE.ShellUI.ObjectiveNote'}}"></textarea>
                  <button class="hl-icon-btn gm" type="submit">{{localize "SWSE.ShellUI.UpdateObjective"}}</button>
                </form>
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{#if vm.selectedThread.job.canManage}}
            <form class="hl-job-status-form" data-holonet-action="job-status" data-thread-id="{{vm.selectedThread.id}}">
              <select name="status">
                <option value="posted">{{localize "SWSE.ShellUI.Posted"}}</option>
                <option value="accepted">{{localize "SWSE.ShellUI.Accepted"}}</option>
                <option value="inProgress">{{localize "SWSE.ShellUI.InProgress"}}</option>
                <option value="review">{{localize "SWSE.ShellUI.Review"}}</option>
                <option value="complete">{{localize "SWSE.ShellUI.Complete"}}</option>
                <option value="paid">{{localize "SWSE.ShellUI.Paid"}}</option>
                <option value="failed">{{localize "SWSE.ShellUI.Failed"}}</option>
                <option value="archived">{{localize "SWSE.ShellUI.Archived"}}</option>
              </select>
              <button class="hl-icon-btn gm" type="submit">{{localize "SWSE.ShellUI.SetStatus2"}}</button>
            </form>
            {{#if vm.selectedThread.job.hasItemRewards}}
            <form class="hl-award-items-form" data-holonet-action="award-job-items" data-thread-id="{{vm.selectedThread.id}}">
              <select name="recipientId">
                {{#each vm.selectedThread.transferTargets}}{{#unless this.isPersona}}<option value="{{this.id}}">{{this.label}}</option>{{/unless}}{{/each}}
              </select>
              {{#each vm.selectedThread.job.rewardItemUuids}}<input type="hidden" name="itemUuids" value="{{this}}">{{/each}}
              <button class="hl-btn-accent" type="submit">{{localize "SWSE.ShellUI.AwardItems"}}</button>
            </form>
            {{/if}}
            {{/if}}
          </div>
          {{/if}}

          <div class="swse-messenger-detail-card hl-info-section">
            <div class="swse-messenger-detail-card__title hl-info-label">{{localize "SWSE.ShellUI.Participants"}}</div>
            <div class="swse-messenger-participants">
              {{#each vm.selectedThread.participants}}
              <div class="swse-messenger-participant hl-info-person">
                {{#if this.avatar}}<img class="hl-avatar" src="{{this.avatar}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">◇</span>{{/if}}
                <b>{{this.label}}</b>
                <small>{{this.typeLabel}}</small>{{#if this.presenceStatus}}<em class="hl-presence-text">{{this.presenceStatus}}</em>{{/if}}
                {{#if ../vm.selectedThread.canManage}}
                  {{#unless this.isSelf}}<button class="hl-ghost-btn" data-holonet-action="thread-action" data-thread-action="remove-member" data-thread-id="{{../vm.selectedThread.id}}" data-recipient-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Remove"}}</button>{{/unless}}
                {{/if}}
              </div>
              {{/each}}
            </div>
            {{#if vm.selectedThread.pendingInvites.length}}
            <div class="swse-messenger-detail-card__subtitle hl-info-label">{{localize "SWSE.ShellUI.PendingInvites"}}</div>
            <div class="swse-messenger-participants swse-messenger-participants--pending">
              {{#each vm.selectedThread.pendingInvites}}
              <div class="swse-messenger-participant hl-info-person">
                {{#if this.avatar}}<img class="hl-avatar" src="{{this.avatar}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">◇</span>{{/if}}
                <b>{{this.label}}</b>
                <small>{{localize "SWSE.ShellUI.Invited"}}</small>
                {{#if ../vm.selectedThread.canManage}}<button class="hl-ghost-btn" data-holonet-action="thread-action" data-thread-action="remove-member" data-thread-id="{{../vm.selectedThread.id}}" data-recipient-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>{{/if}}
              </div>
              {{/each}}
            </div>
            {{/if}}
          </div>

          {{#if vm.selectedThread.canManage}}
          <form class="swse-messenger-detail-card hl-info-section" data-holonet-action="manage-members" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">{{localize "SWSE.ShellUI.AddMembers"}}</div>
            <select name="recipientIds" multiple size="5">
              {{#each vm.selectedThread.addableRecipients}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/each}}
            </select>
            <div class="swse-messenger-member-actions hl-action-row">
              <button class="swse-btn hl-icon-btn" name="memberAction" value="invite-members" type="submit">{{localize "SWSE.ShellUI.Invite"}}</button>
              {{#if vm.isGm}}<button class="swse-btn hl-icon-btn" name="memberAction" value="insert-members" type="submit">{{localize "SWSE.ShellUI.GMInsert"}}</button>{{/if}}
            </div>
          </form>
          {{/if}}

          {{#if vm.transferPolicy.creditsEnabled}}
          {{#if vm.selectedThread.transferTargets.length}}
          <form class="swse-messenger-detail-card hl-info-section" data-holonet-action="transfer-credits" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">{{localize "SWSE.ShellUI.Credits2"}}</div>
            <div class="swse-messenger-credit-balance hl-subtle">Available: {{vm.actorCredits}} cr</div>
            <select name="recipientId">
              {{#each vm.selectedThread.transferTargets}}<option value="{{this.id}}">{{this.label}}</option>{{/each}}
            </select>
            <input type="number" name="amount" min="1" step="1" placeholder="{{localize 'SWSE.ShellUI.Amount'}}">
            {{#if vm.selectedThread.canUseJobPayout}}
            {{#if vm.partyFund.enabled}}
            <label class="hl-field hl-field--compact"><span>{{localize "SWSE.ShellUI.PartyFundCut"}}</span><input type="number" name="partyFundCutPercent" min="0" max="100" step="1" value="{{vm.partyFund.defaultCutPercent}}"></label>
            {{/if}}
            {{/if}}
            <button class="swse-btn swse-btn--primary hl-btn-accent" name="transferMode" value="offer-credit-transfer" type="submit">{{localize "SWSE.ShellUI.OfferTransfer"}}</button>
            {{#if vm.selectedThread.canUseJobPayout}}<button class="swse-btn hl-icon-btn" name="transferMode" value="job-payout" type="submit">{{localize "SWSE.ShellUI.PayJobReward"}}</button>{{/if}}
          </form>
          {{/if}}
          {{/if}}

          {{#if vm.transferPolicy.itemTradesEnabled}}
          {{#if vm.isGm}}
          {{#if vm.selectedThread.transferTargets.length}}
          <form class="swse-messenger-detail-card hl-info-section hl-item-transfer-form" data-holonet-action="item-transfer" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">{{localize "SWSE.ShellUI.ItemDelivery"}}</div>
            <select name="recipientId">
              {{#each vm.selectedThread.transferTargets}}{{#unless this.isPersona}}<option value="{{this.id}}">{{this.label}}</option>{{/unless}}{{/each}}
            </select>
            <div class="hl-drop-zone" data-holonet-drop-zone data-holonet-drop-input="attachmentUuids">
              <b>{{localize "SWSE.ShellUI.DropItemToSend"}}</b><span>{{localize "SWSE.ShellUI.RecipientMustAcceptBeforeTheItemIsGranted"}}</span>
            </div>
            <button class="swse-btn hl-icon-btn" name="itemTransferMode" value="offer-item-transfer" type="submit">{{localize "SWSE.ShellUI.OfferItem"}}</button>
          </form>
          {{/if}}
          {{/if}}
          {{/if}}

          {{#if vm.partyFund.enabled}}
          <form class="swse-messenger-detail-card hl-info-section hl-partyfund-card" data-holonet-action="party-fund" data-thread-id="{{vm.selectedThread.id}}">
            <div class="swse-messenger-detail-card__title hl-info-label">{{localize "SWSE.ShellUI.PartyFund"}}</div>
            <div class="hl-credit-amount">{{vm.partyFund.balance}} cr</div>
            <input type="number" name="amount" min="1" step="1" placeholder="{{localize 'SWSE.ShellUI.Amount'}}">
            {{#if vm.isGm}}
            <select name="recipientId">
              {{#each vm.selectedThread.transferTargets}}{{#unless this.isPersona}}<option value="{{this.id}}">{{this.label}}</option>{{/unless}}{{/each}}
            </select>
            {{/if}}
            <button class="swse-btn swse-btn--primary hl-btn-accent" name="partyFundAction" value="contribute-party-fund" type="submit">{{localize "SWSE.ShellUI.Contribute"}}</button>
            {{#if vm.isGm}}
            <button class="swse-btn hl-icon-btn" name="partyFundAction" value="pay-from-party-fund" type="submit">{{localize "SWSE.ShellUI.PayOut"}}</button>
            <button class="swse-btn hl-icon-btn red" name="partyFundAction" value="charge-party-fund" type="submit">{{localize "SWSE.ShellUI.Charge"}}</button>
            {{/if}}
          </form>
          {{/if}}
        </aside>
      </div>
      {{else}}
      <div class="swse-messenger-empty hl-empty">{{localize "SWSE.ShellUI.SelectAThreadOrStartANewTransmission"}}</div>
      {{/if}}
      {{/if}}
    </section>
      </div>
      {{/if}}
    </main>
  </div>
  {{#if vm.composition}}
  <div class="hl-composition-modal" data-holonet-composition-modal>
    <div class="hl-composition-backdrop" data-holonet-action="close-composer"></div>
    <section class="hl-composition-panel swse-panel">
      <header class="hl-composition-head">
        <div>
          <div class="hl-label hl-label--accent">{{vm.composition.title}}</div>
          <h3>{{vm.composition.actorName}}</h3>
        </div>
        <button class="hl-icon-btn" data-holonet-action="close-composer" type="button">{{localize "SWSE.ShellUI.Close"}}</button>
      </header>

      {{#if (eq vm.composition.type "credits")}}
      <form class="hl-composition-form" data-holonet-action="submit-credit-composer" data-thread-id="{{vm.composition.threadId}}" data-composition-mode="{{vm.composition.mode}}">
        <div class="hl-bank-banner">
          <strong>{{localize "SWSE.ShellUI.CoruscantCreditUnion"}}</strong>
          <span>Available: {{vm.composition.actorCredits}} cr</span>
        </div>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.Amount"}}</span><input type="number" name="amount" min="1" step="1" required></label>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.Memo"}}</span><input type="text" name="memo" maxlength="120" placeholder="{{localize 'SWSE.ShellUI.OptionalMemoLine'}}"></label>
        <div class="hl-recipient-picker">
          <div class="hl-label">{{localize "SWSE.ShellUI.Recipients"}}</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="checkbox" name="recipientIds" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        {{#if vm.composition.hasMultipleTargets}}
        <div class="hl-split-options">
          <label><input type="radio" name="splitMode" value="split-total" checked> {{localize "SWSE.ShellUI.SplitTotalAmountBetweenRecipients"}}</label>
          <label><input type="radio" name="splitMode" value="send-each"> {{#if (eq vm.composition.mode "request")}}Request this amount from each recipient{{else}}Send this amount to each recipient{{/if}}</label>
        </div>
        {{/if}}
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">{{#if (eq vm.composition.mode "request")}}Send Request{{else}}Send Credits{{/if}}</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>
        </div>
      </form>
      {{/if}}

      {{#if (eq vm.composition.type "items")}}
      <form class="hl-composition-form" data-holonet-action="submit-item-composer" data-thread-id="{{vm.composition.threadId}}">
        <div class="hl-help hl-trade-guide">
          <strong>{{localize "SWSE.ShellUI.TradeFlow"}}</strong> open this actor's owned inventory, click the items to add, choose recipient(s), then gift them or request credits/terms in exchange. Compendium items must be added to the actor first before players can offer them.
        </div>
        <div class="hl-inventory-launch-row">
          <div>
            <div class="hl-label hl-label--accent">{{localize "SWSE.ShellUI.SelectedCargo"}}</div>
            <div class="hl-subtle">{{#if vm.composition.inventory.itemCountLabel}}{{vm.composition.inventory.itemCountLabel}} available{{else}}Owned inventory picker{{/if}}</div>
          </div>
          <button class="hl-btn-accent hl-open-inventory-btn" data-holonet-action="toggle-inventory-picker" type="button" aria-expanded="false">{{localize "SWSE.ShellUI.OpenInventory"}}</button>
        </div>
        <div class="hl-selected-cargo" data-holonet-selected-items>
          <div class="hl-selected-cargo-empty" data-holonet-selected-items-empty>{{localize "SWSE.ShellUI.NoItemsSelectedYet"}}</div>
        </div>
        {{#if vm.composition.inventory.hasItems}}
        <section class="hl-inventory-picker" data-holonet-inventory-picker hidden>
          <div class="hl-filter-row">
            <label class="hl-field"><span>{{localize "SWSE.ShellUI.FilterInventory"}}</span><input type="search" data-holonet-item-filter autocomplete="off" spellcheck="false" placeholder="{{localize 'SWSE.ShellUI.SearchItemTypeEquippedValue'}}"></label>
            <button class="hl-ghost-btn hl-filter-clear" data-holonet-action="clear-item-filter" type="button">{{localize "SWSE.ShellUI.Clear"}}</button>
          </div>
          <div class="hl-item-composer-list hl-item-composer-list--flat" data-holonet-item-list>
            {{#each vm.composition.inventory.items}}
            <label class="hl-item-row hl-inventory-item-row" data-item-id="{{this.id}}" data-item-name="{{this.name}}" data-item-type="{{this.typeLabel}}" data-item-summary="{{this.summary}}" data-item-search="{{this.searchKey}}">
              <input type="checkbox" name="itemIds" value="{{this.id}}">
              {{#if this.img}}<img src="{{this.img}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">▣</span>{{/if}}
              <span class="hl-item-row__main">
                <b>{{this.name}}</b>
                <small>{{this.summary}}</small>
              </span>
              {{#if this.statusLabel}}<span class="hl-chip hl-item-status">{{this.statusLabel}}</span>{{else}}<span class="hl-chip muted">{{localize "SWSE.ShellUI.Inventory"}}</span>{{/if}}
              <span class="hl-qty-control"><span>{{localize "SWSE.ShellUI.Qty"}}</span><input type="number" name="quantity.{{this.id}}" min="1" max="{{this.quantity}}" value="1"></span>
            </label>
            {{/each}}
            <div class="hl-item-empty hl-item-empty--filter" data-holonet-item-filter-empty hidden>{{localize "SWSE.ShellUI.NoMatchingOwnedItemsClearTheFilterOr"}}</div>
          </div>
        </section>
        {{else}}
        <div class="hl-item-empty">{{vm.composition.inventory.emptyMessage}}</div>
        {{/if}}
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.Memo"}}</span><input type="text" name="memo" maxlength="120" placeholder="{{localize 'SWSE.ShellUI.OptionalTradeMemo'}}"></label>
        <div class="hl-trade-terms">
          <label class="hl-trade-toggle"><input type="radio" name="tradeIntent" value="gift" checked><span><b>{{localize "SWSE.ShellUI.SendGiftTheseItems"}}</b><small>{{localize "SWSE.ShellUI.RecipientCanAcceptOrDeclineTheTransfer"}}</small></span></label>
          <label class="hl-trade-toggle"><input type="radio" name="tradeIntent" value="trade"><span><b>{{localize "SWSE.ShellUI.RequestTradeTerms"}}</b><small>{{localize "SWSE.ShellUI.AttachRequestedCreditsOrANoteForA"}}</small></span></label>
          <label class="hl-field"><span>{{localize "SWSE.ShellUI.RequestedCredits"}}</span><input type="number" name="requestedCredits" min="0" step="1" placeholder="0"></label>
          <label class="hl-field"><span>{{localize "SWSE.ShellUI.RequestedItemsNotes"}}</span><input type="text" name="requestedItemsNote" maxlength="160" placeholder="{{localize 'SWSE.ShellUI.OptionalAskForAnItemServiceOrMixed'}}"></label>
        </div>
        <div class="hl-recipient-picker">
          <div class="hl-label">{{localize "SWSE.ShellUI.RecipientS"}}</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="checkbox" name="recipientIds" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        {{#if vm.composition.hasMultipleTargets}}
        <div class="hl-split-options">
          <label><input type="radio" name="distributionMode" value="single" checked> {{localize "SWSE.ShellUI.SendSelectedItemsToOneChosenRecipient"}}</label>
          <label><input type="radio" name="distributionMode" value="split"> {{localize "SWSE.ShellUI.SplitQuantitiesAcrossSelectedRecipients"}}</label>
        </div>
        {{/if}}
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">{{localize "SWSE.ShellUI.ContinueSendOffer"}}</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>
        </div>
      </form>
      {{/if}}

      {{#if (eq vm.composition.type "secret-note")}}
      <form class="hl-composition-form hl-secret-note-form" data-holonet-action="submit-secret-note-composer" data-thread-id="{{vm.composition.threadId}}">
        <div class="hl-help">{{localize "SWSE.ShellUI.CreateAGMOnlyCluePuzzleImageOr"}}</div>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.NoteTitle"}}</span><input type="text" name="title" maxlength="80" placeholder="{{localize 'SWSE.ShellUI.EncryptedCluePuzzleFragmentStrangeSignal'}}"></label>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.SecretMessage"}}</span><textarea name="body" rows="5" placeholder="{{localize 'SWSE.ShellUI.TheMessageClueOrPuzzleTextThePlayer'}}"></textarea></label>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.ImagePuzzlePath"}}</span><input type="text" name="imageUrl" placeholder="{{localize 'SWSE.ShellUI.OptionalImagePathOrURL'}}"></label>
        <div class="hl-form-grid">
          <label class="hl-field"><span>{{localize "SWSE.ShellUI.Source"}}</span>
            <select name="source">
              <option value="messenger">{{localize "SWSE.ShellUI.Messenger"}}</option>
              <option value="job">{{localize "SWSE.ShellUI.JobReward"}}</option>
              <option value="game">{{localize "SWSE.ShellUI.GameReward"}}</option>
              <option value="puzzle">{{localize "SWSE.ShellUI.PuzzleDrop"}}</option>
              <option value="gm-note">{{localize "SWSE.ShellUI.GMNote"}}</option>
            </select>
          </label>
          <label class="hl-field"><span>{{localize "SWSE.ShellUI.SelfDestruct"}}</span>
            <select name="expiresAfterSeconds">
              <option value="0">{{localize "SWSE.ShellUI.Persistent"}}</option>
              <option value="30">{{localize "SWSE.ShellUI.Text30SecondsAfterReveal"}}</option>
              <option value="60">{{localize "SWSE.ShellUI.Text60SecondsAfterReveal"}}</option>
              <option value="300">{{localize "SWSE.ShellUI.Text5MinutesAfterReveal"}}</option>
            </select>
          </label>
        </div>
        <div class="hl-recipient-picker">
          <div class="hl-label">{{localize "SWSE.ShellUI.OptionalExtraRecipients"}}</div>
          <div class="hl-subtle">{{localize "SWSE.ShellUI.TheCurrentThreadReceivesTheNoteAddRecipients"}}</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="checkbox" name="recipientIds" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">{{localize "SWSE.ShellUI.TransmitSecretNote"}}</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>
        </div>
      </form>
      {{/if}}

      {{#if (eq vm.composition.type "assets")}}
      <form class="hl-composition-form" data-holonet-action="submit-asset-composer" data-thread-id="{{vm.composition.threadId}}">
        <div class="hl-help">{{localize "SWSE.ShellUI.ShipAndDroidTradesMoveOwnedActorSheets"}}</div>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.Filter"}}</span><input type="search" data-holonet-asset-filter placeholder="{{localize 'SWSE.ShellUI.SearchShipsDroidsVehicles'}}"></label>
        <div class="hl-item-composer-list">
          {{#each vm.composition.assets.categories}}
          <section class="hl-item-category" data-asset-category="{{this.name}}">
            <h4>{{this.name}}</h4>
            {{#each this.assets}}
            <label class="hl-item-row" data-asset-name="{{this.name}} {{this.typeLabel}}">
              <input type="checkbox" name="assetIds" value="{{this.id}}">
              {{#if this.img}}<img src="{{this.img}}" alt="">{{else}}<span class="hl-avatar hl-avatar--blank">▣</span>{{/if}}
              <span><b>{{this.name}}</b><small>{{this.typeLabel}}{{#if this.summary}} · {{this.summary}}{{/if}}</small></span>
            </label>
            {{/each}}
          </section>
          {{/each}}
        </div>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.RequestedCredits"}}</span><input type="number" name="requestedCredits" min="0" step="1" placeholder="0"></label>
        <label class="hl-field"><span>{{localize "SWSE.ShellUI.Memo"}}</span><input type="text" name="memo" maxlength="120" placeholder="{{localize 'SWSE.ShellUI.OptionalAssetTransferMemo'}}"></label>
        <div class="hl-recipient-picker">
          <div class="hl-label">{{localize "SWSE.ShellUI.Recipient"}}</div>
          <div class="hl-recipient-grid">
            {{#each vm.composition.targets}}
            <label class="hl-recipient-row"><input type="radio" name="recipientId" value="{{this.id}}"><span>{{this.label}}</span><small>{{this.typeLabel}}</small></label>
            {{/each}}
          </div>
        </div>
        <div class="hl-composition-actions">
          <button class="swse-btn swse-btn--primary hl-btn-accent" type="submit">{{localize "SWSE.ShellUI.SendAssetOffer"}}</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="close-composer" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>
        </div>
      </form>
      {{/if}}
    </section>
  </div>
  {{/if}}

</div>
