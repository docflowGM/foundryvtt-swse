<div class="swse-shell-surface swse-shell-surface--messenger swse-holonet-comm" data-shell-region="surface-messenger" data-surface-id="{{vm.id}}">
  <div class="swse-shell-surface__header swse-messenger-header hl-hud hl-hud--concept">
    <button class="swse-shell-surface__back-btn hl-icon-btn" data-shell-action="return-to-home" type="button" title="{{localize 'SWSE.ShellUI.ReturnToHome'}}">
      <i class="fas fa-arrow-left"></i>
      <span>{{localize "SWSE.ShellUI.Home"}}</span>
    </button>

    <div class="swse-shell-surface__title hl-hud-title">
      <span>{{localize "SWSE.ShellUI.HOLOCOM"}}</span><small>{{localize "SWSE.ShellUI.ONLINE"}}</small>
      {{#if vm.unreadCount}}<span class="swse-messenger-title-badge hl-badge">{{vm.unreadCount}}</span>{{/if}}
    </div>

    <div class="swse-home-header__actions hl-hud-r">
      {{#if vm.partyFund.enabled}}
      <span class="hl-hud-pill hl-partyfund-pill">PARTY FUND // {{vm.partyFund.balance}} CR</span>
      {{/if}}
      {{#if vm.transferApprovalRequired}}<span class="hl-hud-pill">{{localize "SWSE.ShellUI.TRANSFERAPPROVALON"}}</span>{{/if}}
      <button class="swse-home-header__notice-btn hl-icon-btn" data-shell-action="open-notifications" type="button" title="{{localize 'SWSE.ShellUI.HolonetAlerts'}}">
        <span class="swse-home-header__notice-icon">◌</span>
        <span>{{localize "SWSE.ShellUI.Alerts"}}</span>
        {{#if vm.notificationCenter.totalUnread}}<span class="swse-home-header__notice-badge hl-badge">{{vm.notificationCenter.totalUnread}}</span>{{/if}}
      </button>
      <div class="swse-home-header__actor hl-hud-pill"><span class="hl-dot"></span>{{vm.actorName}}</div>
      <form class="hl-presence-form" data-holonet-action="set-presence">
        <select name="preset" title="{{localize 'SWSE.ShellUI.HolonetStatus'}}">
          <option value="available" {{#if (eq vm.presence.preset "available")}}selected{{/if}}>{{localize "SWSE.ShellUI.Available"}}</option>
          <option value="ready" {{#if (eq vm.presence.preset "ready")}}selected{{/if}}>{{localize "SWSE.ShellUI.Ready"}}</option>
          <option value="training" {{#if (eq vm.presence.preset "training")}}selected{{/if}}>{{localize "SWSE.ShellUI.Training"}}</option>
          <option value="shopping" {{#if (eq vm.presence.preset "shopping")}}selected{{/if}}>{{localize "SWSE.ShellUI.Shopping"}}</option>
          <option value="need-gm" {{#if (eq vm.presence.preset "need-gm")}}selected{{/if}}>{{localize "SWSE.ShellUI.NeedGM"}}</option>
          <option value="away" {{#if (eq vm.presence.preset "away")}}selected{{/if}}>{{localize "SWSE.ShellUI.Away"}}</option>
        </select>
        <input type="text" name="status" value="{{vm.presence.status}}" placeholder="{{localize 'SWSE.ShellUI.SetStatus'}}">
        <input type="hidden" name="visibility" value="party">
        <button type="submit" class="hl-icon-btn">{{localize "SWSE.ShellUI.Set"}}</button>
      </form>
    </div>
  </div>

  <div class="swse-shell-surface__body swse-messenger-body hl-shell">
    <nav class="hl-applist" aria-label="{{localize 'SWSE.ShellUI.HolocomApplications'}}">
      <button class='hl-appbtn {{#unless (eq vm.appMode "jobs")}}on{{/unless}}' data-holonet-action="set-app-mode" data-app-mode="chat" type="button" title="{{localize 'SWSE.ShellUI.Chat'}}">
        <span class="ic">✉</span>
        <span>{{localize "SWSE.ShellUI.Chat"}}</span>
        {{#if vm.unreadCount}}<span class="pip">{{vm.unreadCount}}</span>{{/if}}
      </button>
      <button class="hl-appbtn" data-shell-action="open-notifications" type="button" title="{{localize 'SWSE.ShellUI.Alerts'}}">
        <span class="ic">!</span>
        <span>{{localize "SWSE.ShellUI.Alerts"}}</span>
        {{#if vm.notificationCenter.totalUnread}}<span class="pip">{{vm.notificationCenter.totalUnread}}</span>{{/if}}
      </button>
      <button class="hl-appbtn" data-holonet-action="open-compose" type="button" title="{{localize 'SWSE.ShellUI.NewTransmission'}}">
        <span class="ic">+</span>
        <span>{{localize "SWSE.ShellUI.New"}}</span>
      </button>
      <button class='hl-appbtn {{#if (eq vm.appMode "jobs")}}on{{/if}}' data-holonet-action="set-app-mode" data-app-mode="jobs" type="button" title="{{localize 'SWSE.ShellUI.JobBoard'}}">
        <span class="ic">◆</span>
        <span>{{localize "SWSE.ShellUI.Jobs"}}</span>
        {{#if vm.jobThreads.length}}<span class="pip">{{vm.jobThreads.length}}</span>{{/if}}
      </button>
      <button class='hl-appbtn {{#if (eq vm.appMode "intel")}}on{{/if}}' data-holonet-action="set-app-mode" data-app-mode="intel" type="button" title="Intel">
        <span class="ic">◈</span>
        <span>Intel</span>
        {{#if vm.intelBoard.count}}<span class="pip">{{vm.intelBoard.count}}</span>{{/if}}
      </button>
      {{#if vm.canCreateJobs}}
      <button class="hl-appbtn gm" data-holonet-action="open-compose" type="button" title="{{localize 'SWSE.ShellUI.GMPost'}}">
        <span class="ic">＋</span>
        <span>{{localize "SWSE.ShellUI.GM"}}</span>
      </button>
      {{/if}}
    </nav>

    <main class="hl-main-area">
      {{#if (eq vm.appMode "jobs")}}
      <section class="hl-jobboard-view jb-root jb-root--holonet swse-panel" aria-label="{{localize 'SWSE.ShellUI.JobBoard'}}">
        <header class="jb-head hl-jobboard-head">
          <div class="jb-head-top">
            <div class="jb-brand">
              <span class="jb-brand-mark">◆</span>
              <div class="jb-brand-tt">
                <span class="t">{{localize "SWSE.ShellUI.JobBoard"}}</span>
                <span class="s">{{localize "SWSE.ShellUI.ActiveHolocomContracts"}}</span>
              </div>
            </div>
            <div class="jb-head-actions">
              {{#if vm.jobBoard.stats.attention}}<span class="hl-chip warn jb-attention-chip">{{vm.jobBoard.stats.attention}} attention</span>{{/if}}
              {{#if vm.canCreateJobs}}<button class="hl-btn-accent jb-new-contract" data-holonet-action="open-compose" type="button">{{localize "SWSE.ShellUI.PostNewJob"}}</button>{{/if}}
            </div>
          </div>

          <div class="jb-shelf jb-shelf--interactive" aria-label="{{localize 'SWSE.ShellUI.JobBoardFilters'}}">
            {{#each vm.jobBoard.filterOptions}}
            <button type="button" class="jb-shelf-tab {{this.tone}} {{#if this.isActive}}on{{/if}}" data-holonet-action="set-job-board-filter" data-job-filter="{{this.id}}" aria-pressed="{{#if this.isActive}}true{{else}}false{{/if}}">
              <span>{{this.label}}</span><span class="jb-shelf-count">{{this.count}}</span>
            </button>
            {{/each}}
          </div>

          <form class="jb-subbar hl-jobboard-search" data-holonet-action="thread-filter">
            <label class="jb-search">
              <span class="ic">⌕</span>
              <input type="search" name="threadSearch" value="{{vm.threadSearch}}" placeholder="Search contracts, issuers, factions..." aria-label="{{localize 'SWSE.ShellUI.SearchThreads'}}">
            </label>
            <label class="hl-thread-filter-toggle jb-archive-toggle">
              <input type="checkbox" name="includeArchived" value="true" {{#if vm.includeArchived}}checked{{/if}}>
              <span>{{localize "SWSE.ShellUI.Archived"}}</span>
            </label>
            <button class="hl-icon-btn" type="submit">{{localize "SWSE.ShellUI.Filter"}}</button>
            {{#if vm.hasThreadSearch}}<button class="hl-ghost-btn" data-holonet-action="clear-thread-filter" type="button">{{localize "SWSE.ShellUI.Clear"}}</button>{{/if}}
          </form>
          <div class="jb-active-filter-strip">
            <span class="hl-chip">Showing {{vm.jobBoard.visibleJobCount}} / {{vm.jobBoard.stats.total}}</span>
            <span class="hl-chip {{vm.jobBoard.activeFilter}}">{{vm.jobBoard.activeFilterLabel}}</span>
            {{#if vm.jobBoard.hiddenByFilter}}<span class="hl-chip muted">{{vm.jobBoard.hiddenByFilter}} hidden by lifecycle filter</span>{{/if}}
          </div>
        </header>

        {{#if vm.jobBoard.hasJobs}}
        <div class="jb-content jb-content--holonet has-detail jb-content--phase5">
          <div class="jb-scroll">
            {{#each vm.jobBoard.groups}}
            <section class="jb-group jb-group--{{this.id}}" data-job-status-group="{{this.id}}">
              <header class="jb-group-hd">
                <span class="jb-group-dot {{this.tone}}"></span>
                <span class="jb-group-lbl">{{this.label}}</span>
                <span class="jb-group-count">{{this.count}}</span>
                <hr>
              </header>
              <div class="jb-cards grid">
                {{#each this.items}}
                <button class="hl-job-card jb-card {{this.statusTone}} {{#if this.isSelected}}on{{/if}} {{#if this.needsAttention}}attention{{/if}} {{#if this.isPendingInvite}}pending-invite{{/if}}" data-holonet-action="select-job" data-thread-id="{{this.id}}" type="button" style="--jb-progress: {{this.progressPercent}}%;">
                  {{#if this.needsAttention}}<span class="jb-attn">{{#if this.isPendingInvite}}{{localize "SWSE.ShellUI.InvitePending"}}{{else}}Needs Review{{/if}}</span>{{/if}}
                  <div class="jb-card-top">
                    <div class="jb-card-poster">
                      <span class="jb-card-avatar">
                        {{#if this.hasIssuerImage}}<img src="{{this.issuerImage}}" alt="{{this.issuerLabel}}">{{else}}◆{{/if}}
                      </span>
                      <span class="jb-card-poster-copy">
                        <span class="pn">{{this.issuerLabel}}</span>
                        <span class="po">{{#if this.issuerTypeLine}}{{this.issuerTypeLine}}{{else}}Holonet Contract Authority{{/if}}</span>
                      </span>
                    </div>
                    <span class="jb-status {{this.statusTone}}"><span class="d"></span>{{this.statusLabel}}</span>
                  </div>

                  <div class="jb-card-title">{{this.title}}</div>
                  <div class="jb-card-brief">{{this.preview}}</div>

                  <div class="jb-card-tags">
                    <span class="hl-chip job">{{localize "SWSE.ShellUI.Job"}}</span>
                    {{#if this.factionLabel}}<span class="hl-chip party">{{this.factionLabel}}</span>{{/if}}
                    {{#if this.canManage}}<span class="hl-chip owner">{{localize "SWSE.ShellUI.Owner"}}</span>{{/if}}
                  </div>

                  <div class="jb-prog" aria-label="Contract objective progress">
                    <span class="jb-prog-bar"><i style="width: {{this.progressPercent}}%;"></i></span>
                    <span class="jb-prog-lbl">{{this.objectiveSummary}}</span>
                  </div>

                  <div class="jb-card-foot">
                    <span class="jb-reward-inline">
                      <span class="cr">{{this.rewardCreditsLabel}}</span>
                      {{#if this.rewardXpLabel}}<span class="xp">{{this.rewardXpLabel}}</span>{{/if}}
                    </span>
                    <span class="jb-card-meta">{{this.progress.requiredLabel}}</span>
                  </div>
                </button>
                {{/each}}
              </div>
            </section>
            {{/each}}
          </div>

          <aside class="jb-detail jb-detail--holonet jb-detail--phase5">
            {{#if vm.jobBoard.selectedJob}}
            <header class="jb-detail-hd">
              <div class="jb-detail-poster">
                <span class="jb-card-avatar jb-detail-avatar">
                  {{#if vm.jobBoard.selectedJob.hasIssuerImage}}<img src="{{vm.jobBoard.selectedJob.issuerImage}}" alt="{{vm.jobBoard.selectedJob.issuerLabel}}">{{else}}◆{{/if}}
                </span>
                <div>
                  <span class="hl-label">Mission Dossier</span>
                  <h3 class="jb-detail-title">{{vm.jobBoard.selectedJob.title}}</h3>
                </div>
              </div>
              <span class="jb-status {{vm.jobBoard.selectedJob.statusTone}}"><span class="d"></span>{{vm.jobBoard.selectedJob.statusLabel}}</span>
            </header>

            <div class="jb-detail-body">
              <section class="jb-payout">
                <div class="jb-payout-top">
                  <span class="jb-payout-tot">{{vm.jobBoard.selectedJob.rewardCreditsLabel}}</span>
                  {{#if vm.jobBoard.selectedJob.rewardXpLabel}}<span class="jb-payout-xp">{{vm.jobBoard.selectedJob.rewardXpLabel}}</span>{{/if}}
                </div>
                <div class="jb-payout-break">
                  <span><b>Base</b> {{vm.jobBoard.selectedJob.reward.baseCreditsLabel}}</span>
                  <span><b>Objectives</b> {{vm.jobBoard.selectedJob.reward.objectiveCreditsLabel}}</span>
                </div>
                <div class="jb-payout-note"><span>◇</span>{{vm.jobBoard.selectedJob.reward.itemSummary}} · {{vm.jobBoard.selectedJob.reward.assetSummary}}</div>
              </section>

              <section class="jb-sec jb-issuer-dossier">
                <div class="jb-sec-hd"><span class="jb-sec-lbl">Issuer</span></div>
                <div class="hl-job-issuer-card jb-issuer-card">
                  {{#if vm.jobBoard.selectedJob.hasIssuerImage}}<img src="{{vm.jobBoard.selectedJob.issuerImage}}" alt="{{vm.jobBoard.selectedJob.issuerLabel}}">{{/if}}
                  <div>
                    <strong>{{vm.jobBoard.selectedJob.issuerLabel}}</strong>
                    <small>{{#if vm.jobBoard.selectedJob.issuerTypeLine}}{{vm.jobBoard.selectedJob.issuerTypeLine}}{{else}}Holonet Contract Authority{{/if}}</small>
                    {{#if vm.jobBoard.selectedJob.factionLabel}}<em>{{vm.jobBoard.selectedJob.factionLabel}}</em>{{/if}}
                  </div>
                </div>
              </section>

              {{#if vm.jobBoard.selectedJob.briefingBody}}
              <section class="jb-sec">
                <div class="jb-sec-hd"><span class="jb-sec-lbl">Briefing</span></div>
                <p class="jb-detail-brief">{{vm.jobBoard.selectedJob.briefingBody}}</p>
                {{#if vm.jobBoard.selectedJob.briefingInstructions}}<p class="jb-detail-brief jb-detail-brief--muted">{{vm.jobBoard.selectedJob.briefingInstructions}}</p>{{/if}}
              </section>
              {{/if}}

              {{#if vm.jobBoard.selectedJob.hasObjectives}}
              <section class="jb-sec">
                <div class="jb-sec-hd">
                  <span class="jb-sec-lbl">Objectives</span>
                  <span class="jb-obj-prog">{{vm.jobBoard.selectedJob.objectiveSummary}}</span>
                </div>
                {{#if vm.jobBoard.selectedJob.canManage}}
                <form class="jb-bulk-review-form" data-holonet-action="job-objective-bulk-status" data-thread-id="{{vm.jobBoard.selectedJob.id}}">
                  <input type="hidden" name="threadId" value="{{vm.jobBoard.selectedJob.id}}">
                  <input class="hl-input" type="text" name="objectiveNote" placeholder="Optional GM bulk review note">
                  <button class="jb-mini ok" type="submit" name="bulkObjectiveStatus" value="approved">Approve Pending</button>
                  <button class="jb-mini no" type="submit" name="bulkObjectiveStatus" value="rejected">Reject Pending</button>
                  <button class="jb-mini" type="submit" name="bulkObjectiveStatus" value="open">Reopen Failed</button>
                </form>
                {{/if}}
                <div class="jb-obj-list">
                  {{#each vm.jobBoard.selectedJob.objectives}}
                  <article class="jb-obj {{this.statusTone}} {{#if this.isRequired}}required{{/if}}">
                    <span class="jb-obj-check" aria-hidden="true">{{#if (eq this.status "approved")}}✓{{else}}•{{/if}}</span>
                    <div class="jb-obj-mid">
                      <div class="jb-obj-line">
                        <span class="jb-obj-tier {{this.tierTone}}">{{this.tierLabel}}</span>
                        <strong class="jb-obj-text">{{this.label}}</strong>
                      </div>
                      {{#if this.description}}<div class="jb-obj-meta">{{this.description}}</div>{{/if}}
                      <div class="jb-obj-meta">
                        {{#if this.rewardCreditsLabel}}<span class="rw">{{this.rewardCreditsLabel}}</span>{{/if}}
                        {{#if this.rewardXpLabel}}<span class="rwx">{{this.rewardXpLabel}}</span>{{/if}}
                        {{#if this.reviewNote}}<span>{{this.reviewNote}}</span>{{/if}}
                      </div>
                    </div>
                    <div class="jb-obj-rt">
                      <span class="jb-obj-badge {{this.statusTone}}">{{this.statusLabel}}</span>
                      <div class="jb-obj-actions" data-job-objective-card>
                        <textarea data-objective-action-note rows="2" placeholder="{{this.actionNotePlaceholder}}"></textarea>
                        <div class="jb-obj-action-row">
                          {{#if this.canSubmit}}<button type="button" class="jb-mini ok" data-holonet-action="job-objective-submit" data-thread-id="{{../vm.jobBoard.selectedJob.id}}" data-objective-id="{{this.id}}">Submit</button>{{/if}}
                          {{#if this.canFail}}<button type="button" class="jb-mini no" data-holonet-action="job-objective-fail" data-thread-id="{{../vm.jobBoard.selectedJob.id}}" data-objective-id="{{this.id}}">Fail</button>{{/if}}
                        </div>
                      </div>
                    </div>
                  </article>
                  {{/each}}
                </div>
              </section>
              {{/if}}

              {{#if vm.jobBoard.selectedJob.hasFactionConsequences}}
              <section class="jb-sec">
                <div class="jb-sec-hd"><span class="jb-sec-lbl">Faction Consequences</span></div>
                <div class="jb-cons">
                  {{#each vm.jobBoard.selectedJob.consequenceEntries}}
                  <div class="jb-cons-row {{#if this.isRival}}rival{{/if}}">
                    <div class="jb-cons-fac">
                      <div class="fn">{{this.factionName}}</div>
                      <div class="fnote">{{this.label}}{{#if this.notes}} · {{this.notes}}{{/if}}</div>
                    </div>
                    <div class="jb-cons-delta up swse-signed swse-signed--{{this.successTone}}"><span class="lbl">Success</span>{{this.successDeltaLabel}}</div>
                    <div class="jb-cons-delta down swse-signed swse-signed--{{this.failureTone}}"><span class="lbl">Failure</span>{{this.failureDeltaLabel}}</div>
                  </div>
                  {{/each}}
                </div>
              </section>
              {{/if}}

              {{#if vm.jobBoard.selectedJob.hasParticipants}}
              <section class="jb-sec">
                <div class="jb-sec-hd"><span class="jb-sec-lbl">Participants</span></div>
                <div class="jb-party">
                  {{#each vm.jobBoard.selectedJob.participants}}
                  <span class="jb-party-chip"><span class="g">{{#if this.avatar}}<img src="{{this.avatar}}" alt="">{{else}}◇{{/if}}</span>{{this.label}}</span>
                  {{/each}}
                </div>
              </section>
              {{/if}}

              {{#if vm.jobBoard.selectedJob.hasTimeline}}
              <section class="jb-sec">
                <div class="jb-sec-hd"><span class="jb-sec-lbl">Timeline</span></div>
                <div class="jb-timeline">
                  {{#each vm.jobBoard.selectedJob.timeline}}
                  <div class="jb-tl">
                    <div class="jb-tl-mark"><span class="jb-tl-dot"></span><span class="jb-tl-line"></span></div>
                    <div class="jb-tl-body"><div class="jb-tl-lbl"><b>{{this.label}}</b></div><div class="jb-tl-at">{{this.atLabel}}{{#if this.detail}} · {{this.detail}}{{/if}}</div></div>
                  </div>
                  {{/each}}
                </div>
              </section>
              {{/if}}
            </div>

            <footer class="jb-detail-foot">
              {{#if vm.jobBoard.selectedJob.isPendingInvite}}
              <div class="row">
                <button class="jb-big-btn pos" data-holonet-action="thread-action" data-thread-action="accept-invite" data-thread-id="{{vm.jobBoard.selectedJob.id}}" type="button">{{localize "SWSE.ShellUI.Accept"}}</button>
                <button class="jb-big-btn ghost" data-holonet-action="thread-action" data-thread-action="decline-invite" data-thread-id="{{vm.jobBoard.selectedJob.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>
              </div>
              {{/if}}
              <button class="jb-big-btn" data-holonet-action="set-app-mode" data-app-mode="chat" data-thread-id="{{vm.jobBoard.selectedJob.id}}" type="button">Open Transmission</button>
            </footer>
            {{else}}
            <div class="jb-empty jb-empty--rail">
              <div class="glyph">◆</div>
              <div class="t">No Contract Selected</div>
              <div class="s">Select a job card to inspect it.</div>
            </div>
            {{/if}}
          </aside>
        </div>
        {{else}}
        <div class="hl-job-empty jb-empty">
          <div class="glyph">◆</div>
          <div class="t">{{localize "SWSE.ShellUI.NoJobSignalsAvailable"}}</div>
          <div class="s">No contracts match the current Holonet filter.</div>
          {{#if vm.canCreateJobs}}<button class="hl-btn-accent" data-holonet-action="open-compose" type="button">{{localize "SWSE.ShellUI.PostNewJob"}}</button>{{/if}}
        </div>
        {{/if}}
      </section>
      {{else if (eq vm.appMode "intel")}}
      <section class="hl-intel-view swse-panel" aria-label="Intel Archive">
        <header class="hl-intel-head">
          <div>
            <div class="hl-label hl-label--accent">Intel Archive</div>
            <h2>Shared information packets</h2>
            <p>Capture rumors, clues, NPC notes, mission leads, and discoveries as reusable Holopad intel.</p>
          </div>
          <div class="hl-intel-stats">
            <span class="hl-chip party">{{vm.intelBoard.count}} packets</span>
            <span class="hl-chip">{{vm.intelBoard.partyCount}} party</span>
            <span class="hl-chip job">{{vm.intelBoard.jobCount}} job-linked</span>
            {{#if vm.intelBoard.hiddenBySearch}}<span class="hl-chip muted">{{vm.intelBoard.hiddenBySearch}} hidden</span>{{/if}}
          </div>
        </header>

        <form class="hl-intel-filter" data-holonet-action="intel-filter">
          <label class="jb-search">
            <span class="ic">⌕</span>
            <input type="search" name="intelSearch" value="{{vm.intelBoard.intelSearch}}" placeholder="Search intel, NPCs, rumors, tags..." aria-label="Search intel packets">
          </label>
          <button class="hl-icon-btn" type="submit">Filter</button>
          {{#if vm.intelBoard.hasIntelSearch}}<button class="hl-ghost-btn" data-holonet-action="clear-intel-filter" type="button">Clear</button>{{/if}}
        </form>

        <div class="hl-intel-layout">
          <section class="hl-intel-list">
            {{#if vm.intelBoard.hasItems}}
            {{#each vm.intelBoard.items}}
            <article class="hl-intel-card {{#if this.isPartyIntel}}party{{/if}} {{#if this.isJobIntel}}job{{/if}} {{#if this.isUnread}}unread{{/if}}">
              <header>
                <div>
                  <div class="hl-label">{{this.sourceThreadTitle}}</div>
                  <h3>{{this.title}}</h3>
                </div>
                <span class="hl-chip">{{this.timeLabel}}</span>
              </header>
              <p>{{this.summary}}</p>
              {{#if this.hasTags}}
              <div class="hl-intel-tags">
                {{#each this.tags}}<span class="hl-chip">#{{this}}</span>{{/each}}
              </div>
              {{/if}}
              <footer>
                <span>{{this.sourceLabel}} · {{this.visibilityLabel}}</span>
                {{#if this.canOpenThread}}<button type="button" class="hl-icon-btn" data-holonet-action="set-app-mode" data-app-mode="chat" data-thread-id="{{this.threadId}}">Open Thread</button>{{/if}}
              </footer>
            </article>
            {{/each}}
            {{else}}
            <div class="jb-empty hl-intel-empty">
              <div class="glyph">◈</div>
              <div class="t">No Intel Saved</div>
              <div class="s">Create an intel packet from a party, job, or side-thread transmission so players can review it later.</div>
            </div>
            {{/if}}
          </section>

          <aside class="hl-intel-compose">
            <div class="hl-info-label">Create Intel Packet</div>
            {{#if vm.intelBoard.canCreate}}
            <form data-holonet-action="create-intel-note" data-thread-id="{{vm.intelBoard.selectedThreadId}}">
              <label class="hl-field-label">Save To
                <select class="hl-select" name="threadId">
                  {{#each vm.intelBoard.threadOptions}}
                  <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.kind}} // {{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label class="hl-field-label">Intel Title
                <input class="hl-input" type="text" name="intelTitle" placeholder="Steve the Space Pirate">
              </label>
              <label class="hl-field-label">Information
                <textarea class="hl-composer-ta" name="intelBody" rows="7" placeholder="Write the clue, rumor, NPC note, or discovery here."></textarea>
              </label>
              <label class="hl-field-label">Tags
                <input class="hl-input" type="text" name="intelTags" placeholder="npc, dagobah, rebellion">
              </label>
              <button class="hl-btn-accent" type="submit">Save Intel</button>
              <p class="hl-intel-help">Intel is posted into the chosen thread and indexed here for everyone who can see that thread.</p>
            </form>
            {{else}}
            <p class="hl-intel-help">Join or create a thread before saving intel.</p>
            {{/if}}
          </aside>
        </div>
      </section>
      {{else}}
      <div class="hl-ms-root hl-ms-root--phase2 {{#if vm.selectedThread}}has-thread info-open{{/if}}">
    <aside class="swse-messenger-threads swse-panel hl-tlist">
      <div class="hl-tlist-top">
        <div class="hl-tlist-hd">
          <div>
            <div class="swse-panel__title hl-label hl-label--accent">{{localize "SWSE.ShellUI.Transmissions"}}</div>
            <div class="swse-messenger-rail-subtitle hl-subtle">{{localize "SWSE.ShellUI.PrivatePartyJobAndSideChannelTraffic"}}</div>
          </div>
          <button class="swse-messenger-icon-btn hl-new-btn" data-holonet-action="open-compose" type="button" title="{{localize 'SWSE.ShellUI.NewTransmission'}}">＋</button>
        </div>
      </div>

      <form class="hl-thread-filter-form hl-search-form" data-holonet-action="thread-filter">
        <div class="hl-search-wrap">
          <span class="hl-search-icon">⌕</span>
          <input class="hl-search" type="search" name="threadSearch" value="{{vm.threadSearch}}" placeholder="{{localize 'SWSE.ShellUI.SearchThreads'}}" aria-label="{{localize 'SWSE.ShellUI.SearchMessengerThreads'}}">
        </div>
        <label class="hl-thread-filter-toggle">
          <input type="checkbox" name="includeArchived" value="true" {{#if vm.includeArchived}}checked{{/if}}>
          <span>{{localize "SWSE.ShellUI.Archived"}}</span>
        </label>
        <button class="hl-icon-btn" type="submit">{{localize "SWSE.ShellUI.Filter"}}</button>
        {{#if vm.hasThreadSearch}}<button class="hl-ghost-btn" data-holonet-action="clear-thread-filter" type="button">{{localize "SWSE.ShellUI.Clear"}}</button>{{/if}}
      </form>

      <div class="swse-messenger-thread-list hl-tlist-scroll hl-thread-groups">
        {{#if vm.threads.length}}
          {{#each vm.threadGroups}}
          {{#if this.hasItems}}
          <section class="hl-cat hl-cat--{{this.id}}">
            <div class="hl-cat-label">
              <span class="hl-cat-label__main"><span aria-hidden="true">{{this.icon}}</span>{{localize this.labelKey}}</span>
              <span class="hl-cat-label__count">{{this.count}}</span>
            </div>
            <div class="hl-cat-stack">
              {{#each this.items}}
              {{#if this.isPendingInvite}}
              <article class="hl-invite hl-invite--rail hl-transmission-card hl-transmission-card--invite">
                <div class="hl-invite-badge"><span class="hl-pulse-dot"></span><strong>{{this.title}}</strong></div>
                <div class="hl-transmission-preview">{{this.preview}}</div>
                <div class="hl-action-row">
                  <button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-invite" data-thread-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Accept"}}</button>
                  <button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-invite" data-thread-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>
                </div>
              </article>
              {{else}}
              <button class="swse-messenger-thread hl-titem hl-transmission-card {{#if (eq ../../vm.selectedThreadId this.id)}}active on{{/if}} {{#if this.isParty}}hl-titem--party{{/if}} {{#if this.isJob}}hl-titem--job{{/if}} {{#if this.isSide}}hl-titem--side{{/if}} {{#if this.isPrivate}}hl-titem--private{{/if}} {{#if this.isMuted}}swse-messenger-thread--muted hl-titem--muted{{/if}}" data-thread-id="{{this.id}}" type="button">
                <span class="hl-titem-icon" aria-hidden="true">{{this.kindGlyph}}</span>
                <span class="hl-titem-body">
                  <span class="hl-titem-top">
                    <span class="swse-messenger-thread__title hl-titem-title">{{this.title}}</span>
                    <span class="hl-titem-right">
                      {{#if this.timeLabel}}<span class="hl-titem-time">{{this.timeLabel}}</span>{{/if}}
                      {{#if this.unreadCount}}<span class="swse-messenger-thread__badge hl-badge">{{this.unreadCount}}</span>{{/if}}
                    </span>
                  </span>
                  <span class="swse-messenger-thread__preview hl-titem-preview">{{this.preview}}</span>
                  <span class="swse-messenger-thread__chips hl-titem-chips">
                    <span class="swse-messenger-chip hl-chip">{{this.kindLabel}}</span>
                    {{#if this.isPendingInvite}}<span class="swse-messenger-chip swse-messenger-chip--invite hl-chip warn">{{localize "SWSE.ShellUI.Invite"}}</span>{{/if}}
                    {{#if this.isMuted}}<span class="swse-messenger-chip swse-messenger-chip--muted hl-chip muted">{{localize "SWSE.ShellUI.Muted"}}</span>{{/if}}
                    {{#if this.canManage}}<span class="swse-messenger-chip swse-messenger-chip--owner hl-chip owner">{{localize "SWSE.ShellUI.Owner"}}</span>{{/if}}
                  </span>
                </span>
              </button>
              {{/if}}
              {{/each}}
            </div>
          </section>
          {{/if}}
          {{/each}}
        {{else}}
          <div class="swse-messenger-empty hl-empty">{{localize "SWSE.ShellUI.NoTransmissionsYetStartAThreadOrWait"}}</div>
        {{/if}}
      </div>
    </aside>

    <section class="swse-messenger-main swse-panel hl-conv">
      {{#if vm.composeMode}}
      <div class="swse-messenger-compose-shell hl-compose-shell">
        <div class="swse-messenger-main-head hl-conv-header">
          <div>
            <div class="swse-panel__title hl-title">{{localize "SWSE.ShellUI.NewTransmission"}}</div>
            <div class="swse-messenger-rail-subtitle hl-subtle">{{localize "SWSE.ShellUI.CreateAPrivateHolochatSideThreadPartyChannel"}}</div>
          </div>
        </div>

        <div class="hl-compose-scroll">
          <form class="swse-messenger-compose-new hl-compose-card" data-holonet-action="create-thread">
            <div class="swse-messenger-mode-grid hl-mode-grid">
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="private" checked>
                <span>{{localize "SWSE.ShellUI.PrivateHolochat"}}</span>
                <small>{{localize "SWSE.ShellUI.InviteSelectedContactsRecipientsCanAcceptOrDecline"}}</small>
              </label>
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="side">
                <span>{{localize "SWSE.ShellUI.SideThread"}}</span>
                <small>{{localize "SWSE.ShellUI.CreateAFlexiblePlanningChannelWithInvitedMembers"}}</small>
              </label>
              <label class="swse-messenger-mode-card hl-mode-card">
                <input type="radio" name="threadType" value="party">
                <span>{{localize "SWSE.ShellUI.PartyChannel"}}</span>
                <small>{{localize "SWSE.ShellUI.OpenASharedCrewChannelForTheCurrent"}}</small>
              </label>
            </div>

            <label class="swse-messenger-field hl-field">
              <span>{{localize "SWSE.ShellUI.ThreadTitle"}}</span>
              <input type="text" name="title" placeholder="{{localize 'SWSE.ShellUI.OptionalTransmissionTitle'}}">
            </label>
            {{#if vm.isGm}}
            <label class="swse-messenger-field hl-field">
              <span>{{localize "SWSE.ShellUI.SendAs"}}</span>
              <select name="senderRecipientId">
                <option value="{{vm.participantId}}">{{localize "SWSE.ShellUI.GMCurrentIdentity"}}</option>
                {{#each vm.recipientOptions}}{{#if this.isPersona}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/if}}{{/each}}
              </select>
            </label>
            {{/if}}

            <div class="swse-messenger-recipient-picker hl-recipient-picker">
              <div class="swse-messenger-recipient-picker__title hl-label hl-label--accent">{{localize "SWSE.ShellUI.Recipients"}}</div>
              <div class="swse-messenger-recipient-grid hl-recipient-grid">
                {{#each vm.recipientOptions}}
                <div class="swse-messenger-recipient-option hl-recipient-row hl-recipient-row--with-action {{#if this.isPersona}}swse-messenger-recipient-option--persona{{/if}}">
                  <label class="hl-recipient-choice">
                    <input type="checkbox" name="recipientIds" value="{{this.id}}">
                    {{#if this.avatar}}<img class="swse-messenger-recipient-option__avatar hl-avatar" src="{{this.avatar}}" alt="">{{else}}<span class="swse-messenger-recipient-option__avatar swse-messenger-recipient-option__avatar--blank hl-avatar hl-avatar--blank">◇</span>{{/if}}
                    <span class="swse-messenger-recipient-option__label">{{this.label}}</span>
                    <span class="swse-messenger-recipient-option__type hl-subtle">{{this.typeLabel}}</span>
                  </label>
                  {{#if this.canQuickStart}}<button class="swse-messenger-mini-btn hl-ghost-btn" data-holonet-action="quick-thread" data-recipient-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Hail"}}</button>{{/if}}
                </div>
                {{/each}}
              </div>
            </div>

            <textarea name="body" rows="5" placeholder="{{localize 'SWSE.ShellUI.MessageThread'}}" data-holonet-editor="message"></textarea>
            <label class="swse-messenger-field swse-messenger-field--inline hl-field">
              <span>{{localize "SWSE.ShellUI.HolostillImagePath"}}</span>
              <input type="text" name="imageUrl" placeholder="{{localize 'SWSE.ShellUI.OptionalImagePathOrURL'}}">
            </label>
            <div class="hl-drop-zone" data-holonet-drop-zone data-holonet-drop-input="attachmentUuids">
              <b>{{localize "SWSE.ShellUI.DropItemCardsHere"}}</b>
              <span>{{localize "SWSE.ShellUI.CompendiumOrActorItemsAttachToThisTransmission"}}</span>
            </div>
            <div class="swse-messenger-composer__meta hl-composer-meta">
              <div class="swse-messenger-help hl-help">
                {{#each vm.composerHelp}}<span>{{this}}</span>{{/each}}
              </div>
              <button type="submit" class="swse-btn swse-btn--primary hl-btn-accent">{{localize "SWSE.ShellUI.SendHail"}}</button>
            </div>
          </form>

          {{#if vm.canCreateJobs}}
          <form class="swse-messenger-compose-new swse-messenger-job-form hl-job-compose" data-holonet-action="create-job">
            <div class="swse-messenger-detail-card__title hl-title">{{localize "SWSE.ShellUI.GMJobBoardPosting"}}</div>
            <label class="swse-messenger-field hl-field">
              <span>{{localize "SWSE.ShellUI.JobTitle"}}</span>
              <input type="text" name="title" placeholder="{{localize 'SWSE.ShellUI.KesselRunEscortBountyPickupSupplyContract'}}">
            </label>
            <label class="swse-messenger-field hl-field">
              <span>{{localize "SWSE.ShellUI.JobBrief"}}</span>
              <textarea name="body" rows="4" placeholder="{{localize 'SWSE.ShellUI.DescribeTheJobRisksContactExpectationsAndPayment'}}"></textarea>
            </label>
            <div class="swse-messenger-job-grid hl-form-grid">
              <label class="swse-messenger-field hl-field">
                <span>{{localize "SWSE.ShellUI.CreditReward"}}</span>
                <input type="number" name="rewardCredits" min="0" step="1" placeholder="0">
              </label>
              <label class="swse-messenger-field hl-field">
                <span>{{localize "SWSE.ShellUI.ItemGearRewards"}}</span>
                <input type="text" name="rewardItems" placeholder="{{localize 'SWSE.ShellUI.OptionalItemNotesOrPromisedGear'}}">
              </label>
              <div class="hl-drop-zone hl-drop-zone--compact" data-holonet-drop-zone data-holonet-drop-input="rewardItemUuids">
                <b>{{localize "SWSE.ShellUI.DropRewardItems"}}</b>
                <span>{{localize "SWSE.ShellUI.DragCompendiumItemCardsHereForJobPayment"}}</span>
              </div>
            </div>
            <label class="swse-messenger-field hl-field">
              <span>{{localize "SWSE.ShellUI.ContactPersona"}}</span>
              <select name="contactRecipientId">
                <option value="">{{localize "SWSE.ShellUI.GMJobBoard"}}</option>
                {{#each vm.recipientOptions}}{{#if this.isPersona}}<option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>{{/if}}{{/each}}
              </select>
            </label>
            <div class="swse-messenger-recipient-picker hl-recipient-picker">
              <div class="swse-messenger-recipient-picker__title hl-label hl-label--accent">{{localize "SWSE.ShellUI.Recipients"}}</div>
              <div class="swse-messenger-recipient-grid hl-recipient-grid">
                {{#each vm.recipientOptions}}
                <label class="swse-messenger-recipient-option hl-recipient-row {{#if this.isPersona}}swse-messenger-recipient-option--persona{{/if}}">
                  <input type="checkbox" name="recipientIds" value="{{this.id}}">
                  {{#if this.avatar}}<img class="swse-messenger-recipient-option__avatar hl-avatar" src="{{this.avatar}}" alt="">{{else}}<span class="swse-messenger-recipient-option__avatar swse-messenger-recipient-option__avatar--blank hl-avatar hl-avatar--blank">◇</span>{{/if}}
                  <span class="swse-messenger-recipient-option__label">{{this.label}}</span>
                  <span class="swse-messenger-recipient-option__type hl-subtle">{{this.typeLabel}}</span>
                </label>
                {{/each}}
              </div>
            </div>
            <button type="submit" class="swse-btn swse-btn--primary hl-btn-accent">{{localize "SWSE.ShellUI.PostJob"}}</button>
          </form>

          <form class="swse-messenger-compose-new hl-persona-compose" data-holonet-action="create-persona">
            <div class="swse-messenger-detail-card__title hl-title">{{localize "SWSE.ShellUI.GMMessagePersona"}}</div>
            <div class="hl-help">{{localize "SWSE.ShellUI.CreateANonActorSenderSuchAsRebel"}}</div>
            <label class="swse-messenger-field hl-field"><span>{{localize "SWSE.ShellUI.Name"}}</span><input type="text" name="label" placeholder="{{localize 'SWSE.ShellUI.RebelAlliance'}}"></label>
            <label class="swse-messenger-field hl-field"><span>{{localize "SWSE.ShellUI.AvatarSigilPath"}}</span><input type="text" name="avatar" placeholder="{{localize 'SWSE.ShellUI.OptionalImagePath'}}"></label>
            <label class="swse-messenger-field hl-field"><span>{{localize "SWSE.ShellUI.Notes"}}</span><input type="text" name="notes" placeholder="{{localize 'SWSE.ShellUI.InternalGMNote'}}"></label>
            <button type="submit" class="swse-btn hl-icon-btn gm">{{localize "SWSE.ShellUI.CreatePersona"}}</button>
          </form>
          {{/if}}
        </div>
      </div>
      {{else}}
      {{#if vm.selectedThread}}
      <div class="swse-messenger-main-head hl-conv-header">
        <div class="hl-conv-header-left">
          <div class="swse-panel__title hl-title">{{vm.selectedThread.title}}</div>
          <div class="swse-messenger-rail-subtitle hl-subtle">{{vm.selectedThread.subtitle}}</div>
          <div class="hl-titem-chips">
            {{#if vm.selectedThread.isParty}}<span class="hl-chip party">{{localize "SWSE.ShellUI.Party"}}</span>{{/if}}
            {{#if vm.selectedThread.isSide}}<span class="hl-chip">{{localize "SWSE.ShellUI.Side"}}</span>{{/if}}
            {{#if vm.selectedThread.isJob}}<span class="hl-chip job">{{localize "SWSE.ShellUI.Job"}}</span>{{/if}}
            {{#if vm.selectedThread.isPrivate}}<span class="hl-chip private">{{localize "SWSE.ShellUI.Private"}}</span>{{/if}}
            <span class="hl-chip gm-vis">{{localize "SWSE.ShellUI.GMVisible"}}</span>
          </div>
        </div>
        <div class="swse-messenger-thread-actions hl-thread-actions">
          <button class="swse-btn hl-icon-btn" type="button" aria-disabled="true">{{localize "SWSE.ShellUI.Info"}}</button>
          {{#if vm.selectedThread.isPendingInvite}}
          <button class="swse-btn swse-btn--primary hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-invite" data-thread-id="{{vm.selectedThread.id}}" type="button">{{localize "SWSE.ShellUI.Accept"}}</button>
          <button class="swse-btn hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-invite" data-thread-id="{{vm.selectedThread.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>
          {{/if}}
          {{#if vm.selectedThread.canEnter}}
          <button class="swse-btn hl-icon-btn" data-holonet-action="thread-action" data-thread-action="enter-thread" data-thread-id="{{vm.selectedThread.id}}" type="button">{{localize "SWSE.ShellUI.EnterChat"}}</button>
          {{/if}}
          <button class="swse-btn hl-icon-btn" data-holonet-action="thread-action" data-thread-action="{{vm.selectedThread.muteAction}}" data-thread-id="{{vm.selectedThread.id}}" type="button">{{vm.selectedThread.muteActionLabel}}</button>
          {{#if vm.selectedThread.canLeave}}
          <button class="swse-btn hl-icon-btn" data-holonet-action="thread-action" data-thread-action="leave-thread" data-thread-id="{{vm.selectedThread.id}}" type="button">{{localize "SWSE.ShellUI.Leave"}}</button>
          {{/if}}
          {{#if vm.selectedThread.isArchivedForCurrent}}
          <button class="swse-btn hl-icon-btn" data-holonet-action="thread-action" data-thread-action="unarchive-thread" data-thread-id="{{vm.selectedThread.id}}" type="button">{{localize "SWSE.ShellUI.Unarchive"}}</button>
          {{else}}
          <button class="swse-btn hl-icon-btn" data-holonet-action="thread-action" data-thread-action="archive-thread" data-thread-id="{{vm.selectedThread.id}}" type="button">{{localize "SWSE.ShellUI.Archive"}}</button>
          {{/if}}
        </div>
      </div>

      <div class="swse-messenger-layout hl-chat-layout">
        <div class="swse-messenger-chat-column hl-chat-column">
          {{#if vm.selectedThread.isPendingInvite}}
          <div class="swse-messenger-invite-card hl-invite">
            <div class="hl-invite-badge"><span class="hl-pulse-dot"></span><strong>{{vm.selectedThread.ownerLabel}}</strong> {{localize "SWSE.ShellUI.WantsToHaveAHolochat"}}</div>
            <span>{{localize "SWSE.ShellUI.YouCanAcceptDeclineIgnoreArchiveOrLeave"}}</span>
          </div>
          {{/if}}

          {{#if vm.pinnedMessages.length}}
          <div class="hl-pinned-strip">
            <div class="hl-info-label">{{localize "SWSE.ShellUI.PinnedTransmissions"}}</div>
            {{#each vm.pinnedMessages}}
            <button type="button" class="hl-pin-msg" data-holonet-action="thread-action" data-thread-action="unpin-message" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}">
              <span>📌</span><span>{{this.senderLabel}}: {{{this.bodyHtml}}}</span>
            </button>
            {{/each}}
          </div>
          {{/if}}

          <div class="swse-messenger-conversation hl-messages" data-thread-id="{{vm.selectedThread.id}}" data-message-limit="{{vm.messageLimit}}" data-highlight-record-id="{{vm.highlightRecordId}}">
            {{#if vm.messages.length}}
              {{#if vm.hasOlderMessages}}
              <div class="hl-message-window-notice">
                <button class="hl-ghost-btn" data-holonet-action="load-older-messages" data-thread-id="{{vm.selectedThread.id}}" data-message-limit="{{vm.messageLimit}}" type="button">{{localize "SWSE.ShellUI.LoadOlderTransmissions"}}</button>
                <span>{{vm.hiddenOlderCount}} older transmissions hidden to keep repaint fast.</span>
              </div>
              {{/if}}
              {{#each vm.messages}}
              <div class="hl-message-anchor hl-message-anchor--phase3 {{#if this.hasCreditTransfer}}hl-message-anchor--card{{/if}} {{#if this.hasItemTransfer}}hl-message-anchor--card{{/if}} {{#if this.hasAssetTransfer}}hl-message-anchor--card{{/if}} {{#if this.hasGameInvite}}hl-message-anchor--card{{/if}} {{#if this.hasReceipt}}hl-message-anchor--card{{/if}} {{#if this.hasJobCard}}hl-message-anchor--card{{/if}} {{#if this.isSystem}}hl-message-anchor--system{{/if}} {{#if this.isHighlighted}}hl-message-anchor--highlight{{/if}}" data-holonet-message-id="{{this.id}}" data-holonet-record-id="{{this.id}}" {{#if this.isHighlighted}}data-holonet-highlight="true"{{/if}}> 
                {{#if this.hasCreditTransfer}}
                <article class="swse-msg-system hl-credit-card-wrap hl-message-card-wrap hl-message-card-wrap--credit">
                  <div class="hl-credit-card hl-credit-card--bank">
                    <div class="hl-credit-card-shimmer"></div>
                    <div class="hl-credit-title">{{localize "SWSE.ShellUI.CoruscantCreditUnion"}}</div>
                    {{#if this.transfer.isRequest}}
                    <div class="hl-credit-line"><strong>{{this.transfer.requesterLabel}}</strong> {{localize "SWSE.ShellUI.RequestsCredits"}}</div>
                    <div class="hl-credit-amount">{{this.transfer.amountLabel}}</div>
                    {{#if this.transfer.memo}}<div class="hl-credit-memo">Memo: {{this.transfer.memo}}</div>{{/if}}
                    {{#if this.transfer.ownShareLabel}}<div class="hl-credit-line">{{localize "SWSE.ShellUI.YourShare"}} <strong>{{this.transfer.ownShareLabel}}</strong></div>{{/if}}
                    <div class="hl-credit-status">{{this.transfer.statusLabel}} · Paid {{this.transfer.paidLabel}} · Remaining {{this.transfer.remainingLabel}}</div>
                    <div class="hl-credit-actions">
                      {{#if this.transfer.canPay}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="pay-credit-request" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Pay"}}</button>{{/if}}
                      {{#if this.transfer.canDeclineRequest}}<button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-credit-request" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>{{/if}}
                      {{#if this.transfer.canCancel}}<button class="hl-icon-btn red" data-holonet-action="thread-action" data-thread-action="cancel-credit-request" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Cancel"}}</button>{{/if}}
                    </div>
                    {{else}}
                    <div class="hl-credit-line"><strong>{{this.transfer.fromLabel}}</strong> → <strong>{{this.transfer.toLabel}}</strong></div>
                    <div class="hl-credit-amount">{{this.transfer.amountLabel}}</div>
                    {{#if this.transfer.memo}}<div class="hl-credit-memo">Memo: {{this.transfer.memo}}</div>{{/if}}
                    <div class="hl-credit-status">{{this.transfer.statusLabel}}</div>
                    <div class="hl-credit-actions">
                      {{#if this.transfer.canAccept}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="accept-transfer" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Deposit"}}</button>{{/if}}
                      {{#if this.transfer.canDecline}}<button class="hl-icon-btn" data-holonet-action="thread-action" data-thread-action="decline-transfer" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">{{localize "SWSE.ShellUI.Decline"}}</button>{{/if}}
