                      {{#if this.assetTransfer.canApproveCounter}}<button class="hl-btn-accent" data-holonet-action="thread-action" data-thread-action="approve-asset-counter" data-thread-id="{{../vm.selectedThread.id}}" data-record-id="{{this.id}}" type="button">GM Approve Counter</button>{{/if}}
