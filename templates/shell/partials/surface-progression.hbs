{{!--
  surface-progression.hbs
  Level-up Progression rendered inline inside the holopad shell.

  Uses ProgressionSurfaceAdapter to get a pre-rendered VM from the ProgressionShell.
  Renders the pre-built HTML strings (workSurfaceHtml, mentor rail, progress rail, etc.)
  directly inside the holopad cockpit — no separate ApplicationV2 window.

  vm:
    id           — 'progression'
    title        — 'Level Up'
    mode         — 'levelup'
    isLoading    — true while adapter initializes
    isReady      — true when content is available
    vm.*         — full ProgressionShell _prepareContext() output
    error        — error message if initialization failed
--}}

<div class="swse-shell-surface swse-shell-surface--progression swse-shell-surface--inline-app"
     data-shell-region="surface-progression"
     data-surface-id="{{vm.id}}"
     data-step-id="{{vm.vm.currentDescriptor.stepId}}">

  {{!-- Loading state --}}
  {{#if vm.isLoading}}
  <div class="swse-shell-surface__body swse-shell-surface__body--loading">
    <div class="swse-shell-launching">
      <div class="swse-shell-launching__icon"><i class="fas fa-spinner fa-spin"></i></div>
      <div class="swse-shell-launching__label">Initializing Progression…</div>
    </div>
  </div>

  {{!-- Error state --}}
  {{else if vm.error}}
  <div class="swse-shell-surface__body swse-shell-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>{{vm.error}}</span>
  </div>

  {{!-- Inline content: canonical ProgressionShell rendered by ProgressionSurfaceAdapter --}}
  {{else if vm.shellHtml}}
  <div class="swse-progression-inline-host swse-progression-inline-host--progression" data-inline-progression-host="progression">
    {{{vm.shellHtml}}}
  </div>

  {{else if vm.vm}}
  <div class="swse-shell-surface__body swse-shell-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>Progression shell rendered no HTML. Check ProgressionSurfaceAdapter canonical render.</span>
  </div>

  {{else}}
  <div class="swse-shell-surface__body swse-shell-surface__body--loading">
    <div class="swse-shell-launching">
      <div class="swse-shell-launching__label">Loading progression…</div>
    </div>
  </div>
  {{/if}}

</div>
