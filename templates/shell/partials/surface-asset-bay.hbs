{{!--
  surface-asset-bay.hbs — Central owned-asset control point.

  This is an owner dashboard, not a replacement for droid or vehicle sheets.
  Owned droids and ships/vehicles can be opened in their own shared actor sheet,
  or routed into Garage/Shipyard for purchase, sale, install, removal, and refit.
--}}

<div class="swse-shell-surface swse-shell-surface--asset-bay"
     data-shell-region="surface-asset-bay"
     data-surface-id="{{vm.id}}"
     data-bay-mode="{{vm.mode}}">
  <div class="swse-shell-surface__header">
    <button class="swse-shell-surface__back-btn"
            data-shell-action="return-to-home"
            type="button"
            title="{{localize 'SWSE.ShellUI.ReturnToHome'}}">
      <i class="fas fa-arrow-left"></i>
      <span>{{localize "SWSE.ShellUI.Home"}}</span>
    </button>
    <div class="swse-shell-surface__title">
      <i class="fas {{vm.surfaceIcon}}"></i>
      <span>{{vm.title}}</span>
    </div>
    <div class="swse-shell-surface__subtitle">{{vm.subtitle}}</div>
    <div class="swse-shell-surface__subtitle">Property management is separate from {{vm.actorName}}'s main character sheet.</div>
    {{#if vm.isGM}}<div class="swse-shell-surface__subtitle">GM: {{vm.grantHelp}}</div>{{/if}}
  </div>

  <div class="swse-shell-surface__body swse-shell-surface__body--asset-bay">
    <div class="swse-asset-bay-toolbar">
      <div class="swse-asset-bay-toolbar__summary">
        <span class="swse-asset-bay-count"><strong>{{vm.totalCount}}</strong> {{localize "SWSE.ShellUI.Assets"}}</span>
        <span class="swse-asset-bay-count"><strong>{{vm.droidCount}}</strong> {{localize "SWSE.ShellUI.Droids"}}</span>
        <span class="swse-asset-bay-count"><strong>{{vm.shipCount}}</strong> {{localize "SWSE.ShellUI.ShipsVehicles"}}</span>
      </div>
      {{#if vm.showModeFilters}}
      <div class="swse-asset-bay-mode-pills" role="group" aria-label="{{localize 'SWSE.ShellUI.AssetFilters'}}">
        <button type="button"
                class="swse-asset-bay-mode-pill {{#if vm.isAllMode}}is-active{{/if}}"
                data-asset-bay-action="switch-mode"
                data-bay-mode="all">
          <i class="fas fa-warehouse"></i>
          <span>{{localize "SWSE.ShellUI.AllAssets"}}</span>
        </button>
        <button type="button"
                class="swse-asset-bay-mode-pill {{#if vm.isGarageMode}}is-active{{/if}}"
                data-asset-bay-action="switch-mode"
                data-bay-mode="garage">
          <i class="fas fa-robot"></i>
          <span>{{localize "SWSE.ShellUI.Garage"}}</span>
        </button>
        <button type="button"
                class="swse-asset-bay-mode-pill {{#if vm.isShipyardMode}}is-active{{/if}}"
                data-asset-bay-action="switch-mode"
                data-bay-mode="shipyard">
          <i class="fas fa-rocket"></i>
          <span>{{localize "SWSE.ShellUI.Shipyard"}}</span>
        </button>
      </div>
      {{/if}}
    </div>

    <div class="swse-asset-bay-boundary-note">
      <i class="fas fa-info-circle"></i>
      <span><strong>{{localize "SWSE.ShellUI.Sheet"}}</strong> {{localize "SWSE.ShellUI.OpensTheOwnedActorForPlayAndStatus"}} <strong>{{localize "SWSE.ShellUI.GarageShipyard"}}</strong> {{localize "SWSE.ShellUI.IsWhereCreditsRequestsInstallsRemovalsSalesAnd"}}</span>
    </div>

    {{#if vm.error}}
      <div class="swse-shell-surface__error">
        <i class="fas fa-exclamation-triangle"></i>
        <span>{{vm.error}}</span>
      </div>
    {{else if vm.hasAssets}}
      <div class="swse-asset-bay-grid">
        {{#each vm.assets as |asset|}}
          <article class="swse-asset-bay-card swse-asset-bay-card--{{asset.bayMode}}" data-asset-id="{{asset.actorId}}" data-asset-type="{{asset.type}}" data-bay-mode="{{asset.bayMode}}">
            <div class="swse-asset-bay-card__portrait">
              <img src="{{asset.img}}" alt="{{asset.name}}" />
            </div>
            <div class="swse-asset-bay-card__body">
              <div class="swse-asset-bay-card__kicker"><i class="fas {{asset.kindIcon}}"></i> {{asset.kindLabel}}</div>
              <h3>{{asset.name}}</h3>
              <div class="swse-asset-bay-card__detail">{{asset.detail}}</div>
              <div class="swse-asset-bay-card__status">{{asset.status}}</div>
            </div>
            <div class="swse-asset-bay-card__actions">
              <button type="button"
                      class="swse-asset-bay-action"
                      data-asset-bay-action="open-sheet"
                      data-actor-id="{{asset.actorId}}"
                      {{#unless asset.canOpenSheet}}disabled{{/unless}}>
                <i class="fas fa-external-link-alt"></i>
                <span>{{asset.sheetLabel}}</span>
              </button>
              <button type="button"
                      class="swse-asset-bay-action primary"
                      data-asset-bay-action="modify"
                      data-actor-id="{{asset.actorId}}"
                      data-bay-mode="{{asset.bayMode}}"
                      {{#unless asset.canModify}}disabled{{/unless}}>
                <i class="fas fa-tools"></i>
                <span>{{asset.modifyLabel}}</span>
              </button>
              {{#if asset.canGrantAccess}}
              <button type="button"
                      class="swse-asset-bay-action"
                      data-asset-bay-action="grant-access"
                      data-actor-id="{{asset.actorId}}"
                      data-bay-mode="{{asset.bayMode}}">
                <i class="fas fa-gift"></i>
                <span>{{asset.grantAccessLabel}}</span>
              </button>
              {{/if}}
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <div class="swse-shell-empty-state">
        <i class="fas {{vm.surfaceIcon}}"></i>
        <h3>{{vm.emptyTitle}}</h3>
        <p>{{vm.emptyText}}</p>
      </div>
    {{/if}}
  </div>
</div>
