{{!--
  surface-customization.hbs
  Customization Bay (Droid Garage / Starship Shipyard) routed inside the holopad shell.

  This surface hosts the CustomizationBayApp for building and modifying droids
  and vehicles. Currently routes to the external app but rendered as a holopad surface.

  vm:
    id           — 'customization'
    title        — 'Customization Bay'
    actorId      — actor.id
    actorName    — actor.name
    bayMode      — 'garage' | 'shipyard'
    contextMode  — 'buildNew' | 'modifyExisting' | 'storeQuote' | 'chargenDraft'
--}}

<div class="swse-shell-surface swse-shell-surface--customization"
     data-shell-region="surface-customization"
     data-surface-id="{{vm.id}}"
     data-bay-mode="{{vm.bayMode}}">

  <div class="swse-shell-surface__header">
    <button class="swse-shell-surface__back-btn"
            data-shell-action="return-to-sheet"
            type="button"
            title="Return to Character Sheet">
      <i class="fas fa-arrow-left"></i>
      <span>Character Sheet</span>
    </button>

    <div class="swse-shell-surface__title">
      {{#if (eq vm.bayMode "garage")}}
      <i class="fas fa-robot"></i>
      <span>Droid Garage</span>
      {{else if (eq vm.bayMode "shipyard")}}
      <i class="fas fa-rocket"></i>
      <span>Starship Shipyard</span>
      {{else}}
      <i class="fas fa-tools"></i>
      <span>{{vm.title}}</span>
      {{/if}}
    </div>
  </div>

  {{#if vm.error}}
  <div class="swse-shell-surface__body swse-shell-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>{{vm.error}}</span>
  </div>
  {{else}}
  <div class="swse-shell-surface__body">
    <div class="swse-shell-launching">
      <div class="swse-shell-launching__icon">
        {{#if (eq vm.bayMode "garage")}}
        <i class="fas fa-robot"></i>
        {{else}}
        <i class="fas fa-rocket"></i>
        {{/if}}
      </div>
      <div class="swse-shell-launching__label">
        {{#if (eq vm.bayMode "garage")}}
        Droid Customization Bay
        {{else}}
        Starship Shipyard
        {{/if}}
      </div>
      <div class="swse-shell-launching__detail">
        {{vm.actorName}} — {{vm.contextMode}}
      </div>
    </div>
  </div>
  {{/if}}

</div>
