{{!--
  surface-customization.hbs
  Droid Garage / Starship Shipyard hosted inside the unified holopad shell.

  vm:
    id           — 'customization'
    title        — Customization Bay title
    contentHtml  — pre-rendered CustomizationBayApp content
    error        — optional load error
--}}

<div class="swse-shell-surface swse-shell-surface--customization"
     data-shell-region="surface-customization"
     data-surface-id="{{vm.id}}"
     data-bay-mode="{{vm.bayMode}}">

  {{#if vm.error}}
  <div class="swse-shell-surface__header">
    <button class="swse-shell-surface__back-btn"
            data-shell-action="return-to-home"
            type="button"
            title="Return to Home">
      <i class="fas fa-arrow-left"></i>
      <span>Home</span>
    </button>
    <div class="swse-shell-surface__title">
      <i class="fas fa-tools"></i>
      <span>{{vm.title}}</span>
    </div>
  </div>
  <div class="swse-shell-surface__body swse-shell-surface__error">
    <i class="fas fa-exclamation-triangle"></i>
    <span>{{vm.error}}</span>
  </div>
  {{else if vm.contentHtml}}
  <div class="swse-shell-surface__body swse-shell-surface__body--customization">
    {{{vm.contentHtml}}}
  </div>
  {{else}}
  <div class="swse-shell-surface__header">
    <button class="swse-shell-surface__back-btn"
            data-shell-action="return-to-home"
            type="button"
            title="Return to Home">
      <i class="fas fa-arrow-left"></i>
      <span>Home</span>
    </button>
    <div class="swse-shell-surface__title">
      <i class="fas fa-tools"></i>
      <span>{{vm.title}}</span>
    </div>
  </div>
  <div class="swse-shell-surface__body swse-shell-surface__body--loading">
    <div class="swse-shell-launching">
      <div class="swse-shell-launching__icon"><i class="fas fa-cog fa-spin"></i></div>
      <div class="swse-shell-launching__label">Loading Customization Bay</div>
      <div class="swse-shell-launching__detail">Preparing inline garage/shipyard surface…</div>
    </div>
  </div>
  {{/if}}

</div>
