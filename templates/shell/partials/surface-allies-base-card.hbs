<article class="swse-allies-base-card" data-base-id="{{base.id}}">
  <form class="swse-allies-base-form" data-base-id="{{base.id}}">
    <header class="swse-allies-base-card-head">
      <div>
        <span class="swse-allies-kicker">{{localize "SWSE.ShellUI.BASERECORD"}}</span>
        <input type="text" name="baseName" value="{{base.name}}" placeholder="{{localize 'SWSE.ShellUI.BaseName'}}">
      </div>
      <div class="swse-allies-base-actions">
        <button type="button" data-allies-action="save-base" data-base-id="{{base.id}}">{{localize "SWSE.ShellUI.Save"}}</button>
        <button type="button" class="is-danger" data-allies-action="remove-base" data-base-id="{{base.id}}">{{localize "SWSE.ShellUI.Remove"}}</button>
      </div>
    </header>

    <div class="swse-allies-base-grid">
      <label>
        <span>{{localize "SWSE.ShellUI.Location"}}</span>
        <input type="text" name="location" value="{{base.location}}" placeholder="{{localize 'SWSE.ShellUI.PlanetCitySectorCoordinatesEtc'}}">
      </label>
      <label>
        <span>{{localize "SWSE.ShellUI.BaseType"}}</span>
        <input type="text" name="type" value="{{base.type}}" placeholder="{{localize 'SWSE.ShellUI.SafehouseHeadquartersOutpostApartmentBusiness'}}">
      </label>
      <label class="swse-allies-base-wide">
        <span>{{localize "SWSE.ShellUI.GeneralNotes"}}</span>
        <textarea name="notes" rows="3" placeholder="{{localize 'SWSE.ShellUI.FreeformNotesForPlayersAndGMs'}}">{{base.notes}}</textarea>
      </label>
    </div>

    <section class="swse-allies-base-accommodations">
      <div class="swse-allies-base-subhead">
        <span class="swse-allies-kicker">{{localize "SWSE.ShellUI.ACCOMMODATIONSFACILITIES"}}</span>
        <p>{{localize "SWSE.ShellUI.RulesLightTextFieldsOnlyRecordWhateverThe"}}</p>
      </div>
      <div class="swse-allies-base-grid">
        {{#each base.accommodationFields}}
        <label>
          <span>{{this.label}}</span>
          <textarea name="accommodations.{{this.key}}" rows="2" placeholder="{{localize 'SWSE.ShellUI.DescribeThisFeatureCapacityQualityOrLeaveBlank'}}">{{this.value}}</textarea>
        </label>
        {{/each}}
      </div>
    </section>
  </form>
</article>
