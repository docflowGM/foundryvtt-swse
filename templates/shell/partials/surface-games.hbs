{{!--
  surface-games.hbs — Holopad Games surface.

  Phase 4 adds playable Pazaak credit buy-ins on top of the legal
  all-unlocked side-deck builder. Credit escrow/payout/refund goes through
  TransactionEngine, not direct actor mutation.
--}}

<div class="swse-shell-surface swse-shell-surface--games swse-games-surface"
     data-shell-region="surface-games"
     data-surface-id="{{vm.id}}">

  <header class="swse-games-hud">
    <div class="swse-games-hud__left">
      <span class="swse-games-led {{#if vm.settings.enabled}}is-online{{else}}is-offline{{/if}}"></span>
      <span>GAME CENTER</span>
      <span class="swse-games-hud__muted">{{#if vm.settings.enabled}}ONLINE{{else}}DISABLED BY GM{{/if}}</span>
    </div>
    <div class="swse-games-hud__right">
      <span>{{vm.sessionSummary.inviteCount}} INVITES</span>
      <span>{{vm.sessionSummary.activeCount}} ACTIVE</span>
      <button type="button" class="swse-games-ghost" data-shell-action="return-to-home">Home</button>
    </div>
  </header>

  <section class="swse-games-hero">
    <div>
      <div class="swse-games-kicker">HOLOPAD SIDE TABLES</div>
      <h2>{{vm.title}}</h2>
      <p>{{vm.subtitle}}</p>
    </div>
    <div class="swse-games-actor-chip">
      <img src="{{vm.actorImg}}" alt="{{vm.actorName}}">
      <div>
        <b>{{vm.actorName}}</b>
        <span>Table access node</span>
      </div>
    </div>
  </section>

  <main class="swse-games-layout">
    <section class="swse-games-panel swse-games-panel--library">
      <div class="swse-games-panel__head">
        <div>
          <span class="swse-games-kicker">INSTALLED GAMES</span>
          <h3>Game Library</h3>
        </div>
        <span class="swse-games-count">{{vm.games.length}}</span>
      </div>

      <div class="swse-games-library">
        {{#each vm.games}}
        <button type="button"
                class="swse-games-card {{#if this.selected}}is-selected{{/if}} {{#if this.disabled}}is-disabled{{/if}}"
                data-games-action="select-game"
                data-game-id="{{this.id}}"
                {{#if this.disabled}}disabled{{/if}}>
          <span class="swse-games-card__icon">{{this.icon}}</span>
          <span class="swse-games-card__body">
            <span class="swse-games-card__title">{{this.title}}</span>
            <span class="swse-games-card__sub">{{this.subtitle}}</span>
            <span class="swse-games-card__meta">{{this.playerRange}} players · {{this.implementationPhase}}</span>
          </span>
          <span class="swse-games-card__status">{{this.status}}</span>
        </button>
        {{/each}}
      </div>
    </section>

    <section class="swse-games-panel swse-games-panel--detail">
      {{#if vm.hasActiveTable}}
        {{#if vm.activeTable.isPazaak}}
        <div class="swse-pazaak-table" data-pazaak-session-id="{{vm.activeTable.sessionId}}">
          <div class="swse-pazaak-topbar">
            <div>
              <span class="swse-games-kicker">PAZAAK TABLE</span>
              <h3>{{vm.activeTable.pazaak.title}}</h3>
              <p>{{vm.activeTable.pazaak.rulesLabel}} · target {{vm.activeTable.pazaak.target}} · first to {{vm.activeTable.pazaak.setsToWin}} sets{{#if vm.activeTable.pazaak.wager.enabled}} · pot {{vm.activeTable.pazaak.wager.pot}} credits{{/if}}</p>
            </div>
            <div class="swse-pazaak-topbar__right">
              <span>{{vm.activeTable.pazaak.statusLabel}}</span>
              {{#if vm.activeTable.pazaak.canForfeit}}
              <form data-games-action="pazaak-forfeit">
                <input type="hidden" name="sessionId" value="{{vm.activeTable.pazaak.id}}">
                <input type="hidden" name="seatId" value="{{vm.activeTable.pazaak.currentSeatId}}">
                <button type="submit" class="swse-games-ghost swse-games-ghost--danger">Forfeit</button>
              </form>
              {{/if}}
              {{#if vm.activeTable.pazaak.canCancel}}
              <form data-games-action="pazaak-cancel-session">
                <input type="hidden" name="sessionId" value="{{vm.activeTable.pazaak.id}}">
                <input type="hidden" name="seatId" value="{{vm.activeTable.pazaak.currentSeatId}}">
                <input type="hidden" name="reason" value="Pazaak table cancelled from Holopad Games.">
                <button type="submit" class="swse-games-ghost swse-games-ghost--danger">Cancel</button>
              </form>
              {{/if}}
              <button type="button" class="swse-games-ghost" data-games-action="close-table">Close Table</button>
            </div>
          </div>

          <div class="swse-pazaak-alert">
            <b>{{vm.activeTable.pazaak.message}}</b>
            {{#if vm.activeTable.pazaak.showPlaying}}<span>Active turn: {{vm.activeTable.pazaak.activeSeatLabel}}</span>{{/if}}
            {{#if vm.activeTable.pazaak.showComplete}}<span>Winner: {{vm.activeTable.pazaak.winnerLabel}}</span>{{/if}}
            {{#if vm.activeTable.pazaak.wager.enabled}}<span>Wager: {{vm.activeTable.pazaak.wager.status}} · {{vm.activeTable.pazaak.wager.buyIn}} credit buy-in</span>{{/if}}
            {{#if vm.activeTable.pazaak.wager.settlementMessage}}<span>Economy policy: {{vm.activeTable.pazaak.wager.settlementMessage}}</span>{{/if}}
          </div>

          {{#if vm.activeTable.pazaak.showSetup}}
          <section class="swse-pazaak-setup">
            <div class="swse-pazaak-rules-card">
              <span class="swse-games-kicker">SIDE DECK RULES</span>
              <h4>Build a legal Pazaak side deck</h4>
              <p>All side cards are unlocked for this MVP. Before play begins, each human player must lock exactly {{vm.activeTable.pazaak.sideDeckSize}} unique side cards. At match start, {{vm.activeTable.pazaak.openingHandSize}} of those cards are randomly selected as that player's usable hand for the match.</p>
              {{#if vm.activeTable.pazaak.hasWaitingSeats}}
              <small>Waiting on: {{#each vm.activeTable.pazaak.waitingSeats}}{{this}} {{/each}}</small>
              {{/if}}
            </div>

            {{#if vm.activeTable.pazaak.canLockDeck}}
            <form class="swse-pazaak-side-builder" data-games-action="lock-pazaak-side-deck">
              <input type="hidden" name="sessionId" value="{{vm.activeTable.pazaak.id}}">
              <input type="hidden" name="seatId" value="{{vm.activeTable.pazaak.currentSeatId}}">
              <div class="swse-pazaak-builder-head">
                <div>
                  <span class="swse-games-kicker">ALL CARDS UNLOCKED</span>
                  <strong><span data-pazaak-selected-count>{{vm.activeTable.pazaak.selectedCount}}</span> / {{vm.activeTable.pazaak.sideDeckSize}} selected</strong>
                </div>
                <button type="submit" class="swse-games-primary" {{#unless vm.activeTable.pazaak.lockDeckReady}}disabled{{/unless}}>Lock Side Deck</button>
              </div>

              <div class="swse-pazaak-card-catalog">
                {{#each vm.activeTable.pazaak.catalog}}
                <label class="swse-pazaak-catalog-card {{this.toneClass}} {{#if this.selected}}is-selected{{/if}}">
                  <input type="checkbox" name="sideDeckIds" value="{{this.id}}" data-pazaak-side-card {{#if this.selected}}checked{{/if}}>
                  <span class="swse-pazaak-card-face">
                    <b>{{this.shortLabel}}</b>
                    <small>{{this.label}}</small>
                  </span>
                  <span class="swse-pazaak-card-desc">{{this.description}}</span>
                </label>
                {{/each}}
              </div>
            </form>
            {{else}}
            <div class="swse-games-empty">
              <b>Your side deck is locked or you are spectating this table.</b>
              <span>The match will start automatically when every human player has locked a legal side deck.</span>
            </div>
            {{/if}}
          </section>
          {{/if}}

          {{#if vm.activeTable.pazaak.showPlaying}}
          <section class="swse-pazaak-play">
            <div class="swse-pazaak-scoreboard">
              <span>Set {{vm.activeTable.pazaak.setNumber}}</span>
              <span>Target {{vm.activeTable.pazaak.target}}</span>
              <span>Table limit {{vm.activeTable.pazaak.tableLimit}}</span>
            </div>

            {{#if vm.activeTable.pazaak.hasAiThinking}}
            <div class="swse-pazaak-thinking-banner thinking-{{vm.activeTable.pazaak.aiThinking.intensity}}">
              <b>{{vm.activeTable.pazaak.aiThinking.seatLabel}} is {{vm.activeTable.pazaak.aiThinking.intensityLabel}}</b>
              <span>{{vm.activeTable.pazaak.aiThinking.message}}{{#if vm.activeTable.pazaak.aiThinking.delayLabel}} · {{vm.activeTable.pazaak.aiThinking.delayLabel}}{{/if}}</span>
            </div>
            {{/if}}

            <div class="swse-pazaak-seat-grid">
              {{#each vm.activeTable.pazaak.seats}}
              <article class="swse-pazaak-seat {{#if this.isCurrent}}is-current{{/if}} {{#if this.isViewer}}is-viewer{{/if}} {{#if this.bust}}is-bust{{/if}} {{#if this.isThinking}}is-thinking thinking-{{this.thinkingIntensity}}{{/if}}">
                <header>
                  <div>
                    <b>{{this.displayName}}</b>
                    <span>{{this.statusLabel}} · sets {{this.setsWon}}</span>
                    {{#if this.isAi}}
                    <small>AI: {{this.aiDifficultyLabel}} · {{this.aiFairnessLabel}} · {{this.aiPersonalityLabel}}{{#if this.aiForceSensitive}} · Force-sensitive{{/if}}</small>
                    {{#if this.profession}}<small>{{this.profession}}</small>{{/if}}
                    {{#if this.tableFact}}<small class="swse-pazaak-table-fact">{{this.tableFact}}</small>{{/if}}
                    {{#if this.isThinking}}<small class="swse-pazaak-thinking-line">{{this.thinkingMessage}}{{#if this.thinkingDelayLabel}} · {{this.thinkingDelayLabel}}{{/if}}</small>{{/if}}
                    {{/if}}
                  </div>
                  <strong>{{this.scoreLabel}}</strong>
                </header>

                <div class="swse-pazaak-table-cards">
                  {{#if this.hasTableCards}}
                    {{#each this.tableCards}}
                    <span class="swse-pazaak-played-card tone-{{this.tone}}">
                      <b>{{this.label}}</b>
                      <small>{{this.valueLabel}}</small>
                    </span>
                    {{/each}}
                  {{else}}
                    <span class="swse-pazaak-no-cards">No table cards yet.</span>
                  {{/if}}
                </div>

                <footer>
                  <span>{{this.lastAction}}</span>
                  {{#if this.showHand}}<span>{{this.handCount}} side cards in hand</span>{{else}}<span>{{this.handCount}} hidden side cards</span>{{/if}}
                </footer>
              </article>
              {{/each}}
            </div>

            {{#if vm.activeTable.pazaak.viewerSeat.canAct}}
            <section class="swse-pazaak-hand-panel">
              <div class="swse-pazaak-builder-head">
                <div>
                  <span class="swse-games-kicker">YOUR TURN</span>
                  <strong>Play one side card, stand, or end your turn.</strong>
                </div>
                <div class="swse-pazaak-turn-actions">
                  <form data-games-action="pazaak-stand">
                    <input type="hidden" name="sessionId" value="{{vm.activeTable.pazaak.id}}">
                    <input type="hidden" name="seatId" value="{{vm.activeTable.pazaak.currentSeatId}}">
                    <button type="submit" class="swse-games-primary">Stand</button>
                  </form>
                  <form data-games-action="pazaak-end-turn">
                    <input type="hidden" name="sessionId" value="{{vm.activeTable.pazaak.id}}">
                    <input type="hidden" name="seatId" value="{{vm.activeTable.pazaak.currentSeatId}}">
                    <button type="submit" class="swse-games-ghost">End Turn</button>
                  </form>
                </div>
              </div>

              <div class="swse-pazaak-hand-grid">
                {{#each vm.activeTable.pazaak.viewerSeat.hand}}
                <article class="swse-pazaak-hand-card tone-{{this.tone}}">
                  <div class="swse-pazaak-card-face">
                    <b>{{this.shortLabel}}</b>
                    <small>{{this.label}}</small>
                  </div>
                  <p>{{this.description}}</p>
                  <form data-games-action="pazaak-play-side-card">
                    <input type="hidden" name="sessionId" value="{{this.sessionId}}">
                    <input type="hidden" name="seatId" value="{{this.seatId}}">
                    <input type="hidden" name="cardInstanceId" value="{{this.id}}">
                    {{#if this.signOnly}}
                    <select name="sign">
                      <option value="plus">+</option>
                      <option value="minus">-</option>
                    </select>
                    {{/if}}
                    {{#if this.signAndValue}}
                    <select name="sign">
                      <option value="plus">+</option>
                      <option value="minus">-</option>
                    </select>
                    <select name="value">
                      <option value="1">1</option>
                      <option value="2">2</option>
                    </select>
                    {{/if}}
                    <button type="submit" class="swse-games-primary" {{#unless this.canPlay}}disabled{{/unless}}>Play</button>
                  </form>
                </article>
                {{/each}}
              </div>
            </section>
            {{else}}
            <div class="swse-games-empty">
              <b>Waiting for {{vm.activeTable.pazaak.activeSeatLabel}}.</b>
              <span>Your hand appears here when it is your turn.</span>
            </div>
            {{/if}}
          </section>
          {{/if}}

          {{#if vm.activeTable.pazaak.showComplete}}
          <section class="swse-pazaak-complete">
            <span class="swse-games-kicker">MATCH COMPLETE</span>
            <h4>{{vm.activeTable.pazaak.winnerLabel}} wins the Pazaak match.</h4>
            {{#if vm.activeTable.pazaak.wager.enabled}}
            <p>Credit payout/refund status: {{vm.activeTable.pazaak.wager.status}}. TransactionEngine ledger records remain the source of truth.</p>
            {{#if vm.activeTable.pazaak.wager.settlementMessage}}<p>{{vm.activeTable.pazaak.wager.settlementMessage}}</p>{{/if}}
            {{#if vm.activeTable.pazaak.wager.requiresGmSettlement}}<p><b>GM settlement required:</b> this payout exceeded automated AI/house policy gates and is waiting for a GM-adjusted payout phase.</p>{{/if}}
            {{#if vm.activeTable.pazaak.wager.payoutApproved}}<p>Approved payout: {{vm.activeTable.pazaak.wager.payoutApproved}} credits{{#if vm.activeTable.pazaak.wager.payoutRequested}} / requested {{vm.activeTable.pazaak.wager.payoutRequested}} credits{{/if}}.</p>{{/if}}
            {{else}}
            <p>Republic Senate Rules were active, so no credits, items, or assets were transferred.</p>
            {{/if}}
          </section>
          {{/if}}

          {{#if vm.activeTable.pazaak.hasSetHistory}}
          <section class="swse-pazaak-history">
            <span class="swse-games-kicker">SET HISTORY</span>
            {{#each vm.activeTable.pazaak.setHistory}}
            <div>
              <b>Set {{this.setNumber}}</b>
              <span>{{#if this.winnerLabel}}{{this.winnerLabel}} won{{else}}Tie{{/if}} · {{this.reason}}</span>
            </div>
            {{/each}}
          </section>
          {{/if}}

          {{#if vm.activeTable.pazaak.hasEventLog}}
          <section class="swse-pazaak-history swse-pazaak-log">
            <span class="swse-games-kicker">TABLE LOG</span>
            {{#each vm.activeTable.pazaak.eventLog}}
            <div class="tone-{{this.tone}}">
              <b>{{#if this.seatLabel}}{{this.seatLabel}}{{else}}{{this.type}}{{/if}}</b>
              <span>{{this.message}}{{#if this.timeLabel}} · {{this.timeLabel}}{{/if}}</span>
            </div>
            {{/each}}
          </section>
          {{/if}}
        </div>
        {{/if}}
      {{else}}
        {{#if vm.selectedGame}}
        <div class="swse-games-detail-head">
          <div class="swse-games-big-icon">{{vm.selectedGame.icon}}</div>
          <div>
            <span class="swse-games-kicker">SELECTED TABLE</span>
            <h3>{{vm.selectedGame.title}}</h3>
            <p>{{vm.selectedGame.description}}</p>
          </div>
        </div>

        <div class="swse-games-chip-row">
          {{#each vm.selectedGame.capabilityChips}}
          <span class="swse-games-chip {{#if this.enabled}}is-enabled{{else}}is-disabled{{/if}}">{{this.label}}</span>
          {{/each}}
        </div>

        <div class="swse-games-mode-grid">
          {{#each vm.modeCards}}
          <button type="button"
                  class="swse-games-mode {{#if this.selected}}is-selected{{/if}} {{#unless this.enabled}}is-disabled{{/unless}}"
                  data-games-action="select-rules-mode"
                  data-rules-mode="{{this.id}}"
                  {{#unless this.enabled}}disabled{{/unless}}>
            <b>{{this.title}}</b>
            <span>{{this.description}}</span>
          </button>
          {{/each}}
        </div>

        {{#if vm.canStartSoloAiPazaak}}
        <form class="swse-games-invite-form swse-pazaak-solo-form" data-games-action="start-solo-pazaak">
          <div>
            <span class="swse-games-kicker">INSTANT TABLE</span>
            <strong>Start Pazaak vs AI</strong>
            <small>{{#if vm.showCreditWagerControls}}Credit buy-in.{{else}}Republic Senate Rules. No betting.{{/if}} Side-deck setup happens before the first draw.</small>
          </div>
          <input type="hidden" name="rulesMode" value="{{vm.selectedRulesMode}}">
          <label>
            <span>Table Name</span>
            <input type="text" name="title" maxlength="80" placeholder="Optional custom table name">
          </label>
          {{#if vm.showCreditWagerControls}}
          <label>
            <span>Credit Buy-In</span>
            <input type="number" name="creditBuyIn" min="1" max="{{vm.maxCreditWager}}" step="1" value="{{vm.selectedCreditBuyIn}}">
          </label>
          {{/if}}
          <button type="submit" class="swse-games-primary">Start Pazaak Table</button>
        </form>
        {{/if}}

        {{#if vm.canSendInvites}}
        <form class="swse-games-invite-form" data-games-action="create-game-invite">
          <input type="hidden" name="gameId" value="{{vm.selectedGame.id}}">
          <input type="hidden" name="rulesMode" value="{{vm.selectedRulesMode}}">
          <div>
            <span class="swse-games-kicker">HOLOCRON REQUEST</span>
            <strong>Send Game Invite</strong>
            <small>Creates a Messenger thread with an accept/decline game card.</small>
          </div>
          <label>
            <span>Opponent</span>
            <select name="recipientId" required>
              {{#each vm.inviteTargets}}
              <option value="{{this.id}}">{{this.label}} // {{this.typeLabel}}</option>
              {{/each}}
            </select>
          </label>
          <label>
            <span>Table Name</span>
            <input type="text" name="title" maxlength="80" placeholder="Optional custom table name">
          </label>
          <label>
            <span>Message</span>
            <input type="text" name="memo" maxlength="140" placeholder="Optional table note">
          </label>
          {{#if vm.showCreditWagerControls}}
          <label>
            <span>Credit Buy-In</span>
            <input type="number" name="creditBuyIn" min="1" max="{{vm.maxCreditWager}}" step="1" value="{{vm.selectedCreditBuyIn}}">
          </label>
          {{/if}}
          <button type="submit" class="swse-games-primary">Send Game Request</button>
        </form>
        {{else}}
        <div class="swse-games-next-box">
          <div>
            <span class="swse-games-kicker">NEXT MILESTONE</span>
            <strong>{{vm.selectedGame.nextMilestone}}</strong>
            <small>{{#if vm.settings.useMessengerInvites}}No eligible invite targets are available for this table.{{else}}Messenger invites are disabled by GM settings.{{/if}}</small>
          </div>
          <button type="button" class="swse-games-primary" disabled>Create Table Soon</button>
        </div>
        {{/if}}
        {{else}}
        <div class="swse-games-empty">No games are registered.</div>
        {{/if}}
      {{/if}}
    </section>

    <aside class="swse-games-panel swse-games-panel--sessions">
      <div class="swse-games-panel__head">
        <div>
          <span class="swse-games-kicker">SESSION UPLINK</span>
          <h3>Tables & Invites</h3>
        </div>
      </div>

      <div class="swse-games-summary-grid">
        <div><b>{{vm.sessionSummary.inviteCount}}</b><span>Invites</span></div>
        <div><b>{{vm.sessionSummary.activeCount}}</b><span>Active</span></div>
        <div><b>{{vm.sessionSummary.pendingApprovalCount}}</b><span>GM Gate</span></div>
      </div>

      {{#if vm.hasSessions}}
      <div class="swse-games-session-list">
        {{#each vm.sessions}}
        <article class="swse-games-session {{#if this.canRespond}}is-actionable{{/if}}">
          <button type="button" class="swse-games-session__main" data-games-action="open-session" data-session-id="{{this.id}}">
            <b>{{this.title}}</b>
            <span>{{this.status}} · {{this.rulesMode}}{{#if this.wager.enabled}} · pot {{this.wager.pot}} cr{{/if}}</span>
            <small>{{this.seatCount}} seats · {{this.updatedAt}}</small>
          </button>
          <div class="swse-games-session__actions">
            {{#if this.canOpenThread}}<button type="button" class="swse-games-ghost" data-games-action="open-thread" data-thread-id="{{this.holonetThreadId}}">Messenger</button>{{/if}}
            {{#if this.canRespond}}
              <button type="button" class="swse-games-primary" data-games-action="accept-invite" data-thread-id="{{this.holonetThreadId}}" data-record-id="{{this.holonetMessageId}}">Accept</button>
              <button type="button" class="swse-games-ghost" data-games-action="decline-invite" data-thread-id="{{this.holonetThreadId}}" data-record-id="{{this.holonetMessageId}}">Decline</button>
            {{/if}}
          </div>
        </article>
        {{/each}}
      </div>
      {{else}}
      <div class="swse-games-empty">
        <b>No active tables.</b>
        <span>Messenger game requests and accepted table envelopes will populate here.</span>
      </div>
      {{/if}}

      <div class="swse-games-note-stack">
        {{#each vm.infrastructureNotes}}
        <p>{{this}}</p>
        {{/each}}
      </div>
    </aside>
  </main>
</div>
