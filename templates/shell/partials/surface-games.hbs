{{!--
  surface-games.hbs — Holopad Games surface.

  Phase 2 keeps production game behavior intact while moving the library/detail/rail
  view toward the new Game Center concept. Active tables still hard-branch into the
  table frame added in Phase 1.
--}}

<div class="swse-shell-surface swse-shell-surface--games swse-games-surface {{#if vm.hasActiveTable}}is-table-mode{{else}}is-library-mode{{/if}}"
     data-shell-region="surface-games"
     data-surface-id="{{vm.id}}">

  <header class="swse-games-hud swse-games-hud--concept">
    <div class="swse-games-hud__left">
      <span class="swse-games-tag"><span class="swse-games-led {{#if vm.settings.enabled}}is-online{{else}}is-offline{{/if}}"></span>{{#if vm.settings.enabled}}ONLINE{{else}}DISABLED{{/if}}</span>
      <span class="swse-games-hud__title">GAME CENTER</span>
      <span class="swse-games-tag"><span class="swse-games-led is-pink"></span>{{#if vm.hasActiveTable}}TABLE MODE · ACTIVE SESSION{{else}}HOLOPAD SIDE TABLES{{/if}}</span>
    </div>
    <div class="swse-games-hud__right">
      <span class="swse-games-credit-chip">CR <b>{{vm.actorCreditsLabel}}</b></span>
      <span>{{vm.sessionSummary.inviteCount}} INVITES</span>
      <span>{{vm.sessionSummary.activeCount}} ACTIVE</span>
      {{#if vm.hasActiveTable}}
      <button type="button" class="swse-games-ghost" data-games-action="close-table">Library</button>
      {{else}}
      <button type="button" class="swse-games-ghost" data-shell-action="return-to-home">Home</button>
      {{/if}}
    </div>
  </header>

  {{#if vm.hasActiveTable}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/games/surface-games-table-frame.hbs"}}
  {{else}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/games/surface-games-library.hbs"}}
  {{/if}}
</div>
