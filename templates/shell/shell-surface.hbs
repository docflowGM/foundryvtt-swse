{{!--
  shell-surface.hbs
  Shell surface layer rendered as an additional PART on the character sheet.

  This template renders NOTHING when shellIsSheet === true (normal sheet mode).
  When shellSurface !== 'sheet', it renders a full-coverage layer containing:
    - The active surface content (progression | chargen | upgrade)
    - The overlay layer (if shellOverlay is set)
    - The drawer layer (if shellDrawer is set)

  CSS ensures this layer covers the sheet body completely when active.
  Theme and datapad chrome are inherited from the parent sheet window.
--}}

{{#unless shellIsSheet}}
<div class="swse-shell-surface-host"
     data-shell-surface="{{shellSurface}}"
     data-has-overlay="{{#if shellOverlay}}true{{else}}false{{/if}}"
     data-has-drawer="{{#if shellDrawer}}true{{else}}false{{/if}}">

  {{!-- ═══════════════════════════════════════════════════════════════
    SURFACE CONTENT
    Renders the appropriate surface based on shellSurface value.
  ═══════════════════════════════════════════════════════════════════ --}}

  {{#if (eq shellSurface "home")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-home.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "progression")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-progression.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "chargen")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-chargen.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "upgrade")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-upgrade.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "settings")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-settings.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "mentor")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-mentor.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "messenger")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-messenger.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "store")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-store.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "games")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-games.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "allies")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-allies.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "workbench")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-workbench.hbs"
        vm=shellSurfaceVm}}
  {{/if}}

  {{#if (eq shellSurface "customization")}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/surface-customization.hbs"
        vm=shellSurfaceVm}}
  {{/if}}



  {{#if (eq shellSurface "gm-home")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/home.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-bulletin")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/bulletin.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-jobs")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/jobs.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-trade")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/trade.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-house-rules")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/house-rules.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-store")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/store.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-approvals")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/approvals.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-healing")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/healing.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-workspace")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/workspace.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-factions")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/factions.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-settings")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/settings.hbs"}}
  {{/if}}

  {{#if (eq shellSurface "gm-error")}}
    {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/error.hbs"}}
  {{/if}}

  {{!-- ═══════════════════════════════════════════════════════════════
    PERSISTENT HOME NAV
    Floating home button visible on all non-home surfaces.
    Lets the user jump to the Home launcher from any route.
  ═══════════════════════════════════════════════════════════════════ --}}
  {{#unless (eq shellSurface "home")}}
  <button class="swse-shell-home-nav"
          data-shell-action="open-home"
          type="button"
          title="Holopad Home">
    ⌂
  </button>
  {{/unless}}

  {{!-- ═══════════════════════════════════════════════════════════════
    DRAWER LAYER
    Rendered alongside the surface when shellDrawer is set.
    Appears as a side panel (right side by default).
  ═══════════════════════════════════════════════════════════════════ --}}

  {{#if shellDrawer}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/shell-drawer-layer.hbs"
        vm=shellDrawerVm
        drawerId=shellDrawer.drawerId}}
  {{/if}}

  {{!-- ═══════════════════════════════════════════════════════════════
    OVERLAY LAYER
    Rendered ABOVE surface and drawer when shellOverlay is set.
    Centered modal-like container with backdrop.
  ═══════════════════════════════════════════════════════════════════ --}}

  {{#if shellOverlay}}
    {{> "systems/foundryvtt-swse/templates/shell/partials/shell-overlay-layer.hbs"
        vm=shellOverlayVm
        overlayId=shellOverlay.overlayId}}
  {{/if}}

</div>
{{/unless}}

{{!-- ═══════════════════════════════════════════════════════════════
  SHEET-MODE OVERLAYS AND DRAWERS
  When in normal sheet mode, overlays and drawers still render
  above the sheet body via a lightweight anchor element.
═══════════════════════════════════════════════════════════════════ --}}

{{#if shellIsSheet}}

  {{!-- ═══════════════════════════════════════════════════════════════
    SHEET-MODE HOME NAV
    Floating home button visible on the character sheet.
    Rendered inside the shell-surface part so it floats above the body.
  ═══════════════════════════════════════════════════════════════════ --}}
  <div class="swse-shell-sheet-layers swse-shell-sheet-home"
       data-shell-region="sheet-home-nav">
    <button class="swse-shell-home-nav"
            data-shell-action="open-home"
            type="button"
            title="Holopad Home">
      ⌂
    </button>
  </div>

  {{#if shellOverlay}}
  <div class="swse-shell-surface-host swse-shell-sheet-layers"
       data-shell-surface="sheet"
       data-has-overlay="true">
    {{> "systems/foundryvtt-swse/templates/shell/partials/shell-overlay-layer.hbs"
        vm=shellOverlayVm
        overlayId=shellOverlay.overlayId}}
  </div>
  {{/if}}

  {{#if shellDrawer}}
  <div class="swse-shell-surface-host swse-shell-sheet-layers"
       data-shell-surface="sheet"
       data-has-drawer="true">
    {{> "systems/foundryvtt-swse/templates/shell/partials/shell-drawer-layer.hbs"
        vm=shellDrawerVm
        drawerId=shellDrawer.drawerId}}
  </div>
  {{/if}}
{{/if}}
