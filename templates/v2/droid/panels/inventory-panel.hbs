<section class="swse-panel inventory-panel">
  <div class="swse-panel__content">
    {{#if inventoryPanel.hasEntries}}
      {{#each inventoryPanel.entries as |entry|}}
        <div class="entry" data-row-id="{{entry.id}}">{{entry.name}} (×{{entry.quantity}})</div>
      {{/each}}
    {{else}}
      <p class="empty-state">No inventory</p>
    {{/if}}
  </div>
</section>
