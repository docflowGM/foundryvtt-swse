<section class="swse-panel skills-panel">
  <div class="swse-panel__content">
    {{#if skillsPanel.hasEntries}}
      {{#each skillsPanel.entries as |skill|}}
        <div class="skill-row">{{skill.name}} {{skill.bonus}}</div>
      {{/each}}
    {{else}}
      <p class="empty-state">No skills</p>
    {{/if}}
  </div>
</section>
