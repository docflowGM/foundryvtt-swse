{{!-- templates/v2/npc/npc-sheet-tabs.hbs --}}
{{!-- NPC Sheet tab navigation --}}

<div class="sheet-tabs">
  {{#each tabPanels as |panelNames tabName|}}
    <button class="tab{{#if (eq currentTab tabName)}} active{{/if}}"
            data-tab="{{tabName}}"
            type="button">
      {{capitalize tabName}}
    </button>
  {{/each}}
</div>

{{!-- Custom helper to capitalize --}}
{{#*inline "capitalize"}}
  {{capitalize this}}
{{/inline}}
