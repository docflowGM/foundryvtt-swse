{{!--
  SWSE Item Editor V2 — 3-Rail Layout (Header / Body / Footer)
  Architecture: Fixed Header | Scrollable Body | Fixed Footer
  Visual: Flat, compact, 2-column grid, thumbnail image scale
--}}

<form class="{{cssClass}} sheet-item item-sheet-form swse-item-editor-form" autocomplete="off" id="item-sheet-form">
  <section class="swse-item-editor">

    {{!-- ===== RAIL 1: FIXED HEADER ===== --}}
    <header class="item-editor__header">
      <div class="item-editor__identity">
        {{!-- Thumbnail image --}}
        <img src="{{item.img}}" alt="{{item.name}}" class="item-editor__image" title="{{item.name}}" />

        {{!-- Identity fields: name + type + category/branch selectors --}}
        <div class="item-editor__identity-fields">
          <div class="form-field form-field--name">
            <label>Name</label>
            <input type="text" name="name" value="{{item.name}}" placeholder="Item Name" />
          </div>

          <div class="item-editor__identity-row">
            <div class="form-field">
              <label>Type</label>
              <select name="type" class="item-type-select" {{#if itemId}}disabled{{/if}}>
                <option value="weapon" {{#if (eq item.type "weapon")}}selected{{/if}}>Weapon</option>
                <option value="armor" {{#if (eq item.type "armor")}}selected{{/if}}>Armor</option>
                <option value="equipment" {{#if (eq item.type "equipment")}}selected{{/if}}>Equipment</option>
                <option value="feat" {{#if (eq item.type "feat")}}selected{{/if}}>Feat</option>
                <option value="talent" {{#if (eq item.type "talent")}}selected{{/if}}>Talent</option>
                {{#unless (or (eq item.type "weapon") (eq item.type "armor") (eq item.type "equipment") (eq item.type "feat") (eq item.type "talent"))}}
                <option value="{{item.type}}" selected>{{item.type}}</option>
                {{/unless}}
              </select>
            </div>

            {{!-- WEAPON: Melee or Ranged (first selector) --}}
            {{#if (eq item.type "weapon")}}
            <div class="form-field">
              <label>Branch</label>
              <select name="system.meleeOrRanged" class="melee-or-ranged-select">
                <option value="melee" {{#if (eq system.meleeOrRanged "melee")}}selected{{/if}}>Melee</option>
                <option value="ranged" {{#if (eq system.meleeOrRanged "ranged")}}selected{{/if}}>Ranged</option>
              </select>
            </div>
            {{else if (eq item.type "armor")}}
            {{!-- ARMOR: Armor Type --}}
            <div class="form-field">
              <label>Category</label>
              <select name="system.armorType" class="item-category-select">
                <option value="light" {{#if (eq system.armorType "light")}}selected{{/if}}>Light</option>
                <option value="medium" {{#if (eq system.armorType "medium")}}selected{{/if}}>Medium</option>
                <option value="heavy" {{#if (eq system.armorType "heavy")}}selected{{/if}}>Heavy</option>
                <option value="shield" {{#if (eq system.armorType "shield")}}selected{{/if}}>Shield</option>
              </select>
            </div>
            {{else if (eq item.type "equipment")}}
            {{!-- EQUIPMENT: Generic category --}}
            <div class="form-field">
              <label>Category</label>
              <select name="system.category" class="item-category-select">
                <option value="gear" {{#if (eq system.category "gear")}}selected{{/if}}>Gear</option>
                <option value="consumable" {{#if (eq system.category "consumable")}}selected{{/if}}>Consumable</option>
                <option value="medical" {{#if (eq system.category "medical")}}selected{{/if}}>Medical</option>
              </select>
            </div>
            {{else if (eq item.type "feat")}}
            <div class="form-field">
              <label>Feat Type</label>
              <select name="system.featType" class="item-category-select">
                <option value="general" {{#if (eq system.featType "general")}}selected{{/if}}>General</option>
                <option value="class_feature" {{#if (eq system.featType "class_feature")}}selected{{/if}}>Class Feature</option>
                <option value="force" {{#if (eq system.featType "force")}}selected{{/if}}>Force</option>
                <option value="species" {{#if (eq system.featType "species")}}selected{{/if}}>Species</option>
                <option value="bonus" {{#if (eq system.featType "bonus")}}selected{{/if}}>Bonus</option>
              </select>
            </div>
            {{else if (eq item.type "talent")}}
            <div class="form-field">
              <label>Talent Tree</label>
              <input type="text" name="system.tree" value="{{system.tree}}" placeholder="e.g., Lineage" />
            </div>
            {{/if}}
          </div>

          {{!-- WEAPON: Weapon Category (second selector, filtered by melee/ranged) --}}
          {{#if (eq item.type "weapon")}}
          <div class="form-field">
            <label>Category</label>
            <select name="system.weaponCategory" class="weapon-category-select">
              {{#if (eq system.meleeOrRanged "melee")}}
              <option value="advanced" {{#if (eq system.weaponCategory "advanced")}}selected{{/if}}>Advanced</option>
              <option value="lightsaber" {{#if (eq system.weaponCategory "lightsaber")}}selected{{/if}}>Lightsaber</option>
              <option value="melee-exotic" {{#if (eq system.weaponCategory "melee-exotic")}}selected{{/if}}>Melee Exotic</option>
              <option value="natural" {{#if (eq system.weaponCategory "natural")}}selected{{/if}}>Natural</option>
              <option value="simple" {{#if (eq system.weaponCategory "simple")}}selected{{/if}}>Simple</option>
              {{else}}
              <option value="heavy" {{#if (eq system.weaponCategory "heavy")}}selected{{/if}}>Heavy</option>
              <option value="pistols" {{#if (eq system.weaponCategory "pistols")}}selected{{/if}}>Pistols</option>
              <option value="ranged-exotic" {{#if (eq system.weaponCategory "ranged-exotic")}}selected{{/if}}>Ranged Exotic</option>
              <option value="rifles" {{#if (eq system.weaponCategory "rifles")}}selected{{/if}}>Rifles</option>
              <option value="simple" {{#if (eq system.weaponCategory "simple")}}selected{{/if}}>Simple</option>
              {{/if}}
            </select>
          </div>
          {{/if}}

          {{#if (or (eq item.type "weapon") (eq item.type "armor") (eq item.type "equipment"))}}
          <div class="form-field form-field--checkbox">
            <label>
              <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} />
              Equipped
            </label>
          </div>
          {{/if}}

          {{!-- Action buttons: Manage Upgrades + Customize --}}
          {{#if (or (eq item.type "weapon") (eq item.type "armor") (eq item.type "equipment"))}}
          <div class="item-editor__toolbar">
            <button type="button" class="swse-btn swse-btn--action open-upgrade-app">
              <i class="{{getIconClass 'cog'}}"></i> Manage Upgrades
            </button>

            {{#if (eq item.type "weapon")}}
            {{#if (eq system.weaponCategory "lightsaber")}}
            <button type="button" class="swse-btn swse-btn--action customize-lightsaber">
              <i class="{{getIconClass 'wand2'}}"></i> Customize Lightsaber
            </button>
            {{/if}}
            {{#if (and (eq system.meleeOrRanged "ranged") (ne system.weaponCategory "simple"))}}
            <button type="button" class="swse-btn swse-btn--action customize-blaster">
              <i class="{{getIconClass 'palette'}}"></i> Blaster Color
            </button>
            {{/if}}
            {{/if}}
          </div>
          {{/if}}
        </div>
      </div>
    </header>

    {{!-- Tab navigation --}}
    <nav class="item-editor__tabs tabs" data-group="primary">
      <a class="item-editor__tab {{#if (eq activeTab 'data')}}active{{/if}}" data-tab="data">Data</a>
      <a class="item-editor__tab {{#if (eq activeTab 'description')}}active{{/if}}" data-tab="description">Description</a>
    </nav>

    {{!-- ===== RAIL 2: SCROLLABLE BODY ===== --}}
    <section class="item-editor__body">

      {{!-- DATA TAB --}}
      <div class="tab {{#if (eq activeTab 'data')}}active{{/if}}" data-tab="data">

        {{!-- ===== WEAPON EDITOR ===== --}}
        {{#if (eq item.type "weapon")}}
        <div class="item-editor__grid item-editor__grid--two-col">

          {{!-- COLUMN A: Core Stats (Classification fields removed - they are in header) --}}
          <div class="item-editor__col">
            <section class="item-editor__section">
              <h3 class="item-editor__section-title">Mechanics</h3>

              <div class="form-field">
                <label>Attack Attribute</label>
                <select name="system.attackAttribute">
                  <option value="str" {{#if (eq system.attackAttribute "str")}}selected{{/if}}>Strength</option>
                  <option value="dex" {{#if (eq system.attackAttribute "dex")}}selected{{/if}}>Dexterity</option>
                </select>
              </div>

              <div class="form-field">
                <label>Damage</label>
                <input type="text" name="system.damage" value="{{system.damage}}" placeholder="e.g., 1d6" />
              </div>

              <div class="form-field">
                <label>Damage Type</label>
                <select name="system.damageType">
                  <option value="energy" {{#if (eq system.damageType "energy")}}selected{{/if}}>Energy</option>
                  <option value="kinetic" {{#if (eq system.damageType "kinetic")}}selected{{/if}}>Kinetic</option>
                  <option value="ion" {{#if (eq system.damageType "ion")}}selected{{/if}}>Ion</option>
                </select>
              </div>

              <div class="form-field">
                <label>Damage Bonus</label>
                <select name="system.damageBonus">
                  <option value="" {{#if (eq system.damageBonus "")}}selected{{/if}}>(None)</option>
                  <option value="str" {{#if (eq system.damageBonus "str")}}selected{{/if}}>STR</option>
                  <option value="str2" {{#if (eq system.damageBonus "str2")}}selected{{/if}}>STR x2</option>
                  <option value="dex" {{#if (eq system.damageBonus "dex")}}selected{{/if}}>DEX</option>
                  <option value="dex2" {{#if (eq system.damageBonus "dex2")}}selected{{/if}}>DEX x2</option>
                </select>
              </div>
            </section>
          </div>

          {{!-- COLUMN B: Combat Stats --}}
          <div class="item-editor__col">
            <section class="item-editor__section">
              <h3 class="item-editor__section-title">Combat</h3>

              <div class="form-field">
                <label>Attack Bonus</label>
                <input type="number" name="system.attackBonus" value="{{system.attackBonus}}" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Critical Range</label>
                <input type="text" name="system.criticalRange" value="{{system.criticalRange}}" placeholder="e.g., 20 or 19-20" />
              </div>

              <div class="form-field">
                <label>Critical Multiplier</label>
                <input type="text" name="system.criticalMultiplier" value="{{system.criticalMultiplier}}" placeholder="e.g., x2, x3" />
              </div>

              <div class="form-field">
                <label>Range</label>
                <input type="text" name="system.range" value="{{system.range}}" placeholder="Auto from range profile or override manually" />
              </div>

              {{#if (eq system.meleeOrRanged "ranged")}}
              <div class="form-field">
                <label>Range Profile</label>
                <input type="text" name="system.rangeProfileName" value="{{system.rangeProfileName}}" placeholder="Auto: Pistols / Rifles / Heavy" readonly />
                <input type="hidden" name="system.rangeProfile" value="{{system.rangeProfile}}" />
              </div>
              {{/if}}

              <div class="form-field">
                <label>Weight (kg)</label>
                <input type="number" name="system.weight" value="{{system.weight}}" step="0.1" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Cost (credits)</label>
                <input type="number" name="system.cost" value="{{system.cost}}" data-dtype="Number" />
              </div>
            </section>
          </div>
        </div>

        {{#if (eq system.meleeOrRanged "ranged")}}
        <section class="item-editor__section item-editor__section--range-bands">
          <h3 class="item-editor__section-title">Range Bands</h3>
          <p class="item-editor__hint">Auto-hydrates from the weapon range data when Branch/Category changes. You may override any band before saving.</p>
          <div class="item-editor__grid item-editor__grid--four-col swse-range-band-grid">
            <div class="form-field">
              <label>PB Min</label>
              <input type="number" name="system.ranges.pb.min" value="{{system.ranges.pb.min}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>PB Max</label>
              <input type="number" name="system.ranges.pb.max" value="{{system.ranges.pb.max}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>PB Mod</label>
              <input type="number" name="system.ranges.pb.attackMod" value="{{system.ranges.pb.attackMod}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Short Max</label>
              <input type="number" name="system.ranges.short.max" value="{{system.ranges.short.max}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Short Min</label>
              <input type="number" name="system.ranges.short.min" value="{{system.ranges.short.min}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Short Mod</label>
              <input type="number" name="system.ranges.short.attackMod" value="{{system.ranges.short.attackMod}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Med Min</label>
              <input type="number" name="system.ranges.medium.min" value="{{system.ranges.medium.min}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Med Max</label>
              <input type="number" name="system.ranges.medium.max" value="{{system.ranges.medium.max}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Med Mod</label>
              <input type="number" name="system.ranges.medium.attackMod" value="{{system.ranges.medium.attackMod}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Long Min</label>
              <input type="number" name="system.ranges.long.min" value="{{system.ranges.long.min}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Long Max</label>
              <input type="number" name="system.ranges.long.max" value="{{system.ranges.long.max}}" data-dtype="Number" />
            </div>
            <div class="form-field">
              <label>Long Mod</label>
              <input type="number" name="system.ranges.long.attackMod" value="{{system.ranges.long.attackMod}}" data-dtype="Number" />
            </div>
          </div>
        </section>
        {{/if}}

        {{!-- Full-width sections for weapon --}}

        {{!-- RANGED: Ammunition fields --}}
        {{#if (eq system.meleeOrRanged "ranged")}}
        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Ammunition</h3>

          <div class="item-editor__grid item-editor__grid--two-col">
            <div class="item-editor__col">
              <div class="form-field">
                <label>Ammunition Type</label>
                <input type="text" name="system.ammunition.type" value="{{system.ammunition.type}}" placeholder="e.g., Power Pack, Slugs" />
              </div>

              <div class="form-field">
                <label>Ammo Current</label>
                <input type="number" name="system.ammunition.current" value="{{system.ammunition.current}}" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Ammo Max</label>
                <input type="number" name="system.ammunition.max" value="{{system.ammunition.max}}" data-dtype="Number" />
              </div>
            </div>

            <div class="item-editor__col">
              <div class="form-field form-field--checkbox">
                <label>
                  <input type="checkbox" name="system.autofire" {{#if system.autofire}}checked{{/if}} />
                  Autofire
                </label>
              </div>
            </div>
          </div>
        </section>
        {{/if}}

        {{!-- Handedness flags: Dual wielding applies to any weapon type, two-handed is melee only --}}
        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Handedness</h3>

          <div class="form-field form-field--checkbox">
            <label>
              <input type="checkbox" name="system.dualWielded" {{#if system.dualWielded}}checked{{/if}} />
              Dual Wielded
            </label>
          </div>

          {{#if (eq system.meleeOrRanged "melee")}}
          <div class="form-field form-field--checkbox">
            <label>
              <input type="checkbox" name="system.wieldedTwoHanded" {{#if system.wieldedTwoHanded}}checked{{/if}} />
              Two-Handed
            </label>
          </div>
          {{/if}}
        </section>

        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Special Effects</h3>
          <div class="form-field form-field--full">
            <label>Special Effects</label>
            <textarea name="system.specialEffects" rows="3">{{system.specialEffects}}</textarea>
          </div>

          <div class="form-field form-field--full">
            <label>Properties (comma-separated)</label>
            <input type="text" name="system.properties" value="{{#if system.properties}}{{join system.properties delimiter=', '}}{{/if}}" placeholder="e.g., Stun, Accurate, Autofire" />
          </div>
        </section>

        {{!-- Ranged-specific fields --}}
        {{#if (eq system.meleeOrRanged "ranged")}}
        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Ranged Visuals</h3>

          <div class="item-editor__grid item-editor__grid--two-col">
            <div class="form-field">
              <label>Beam Style</label>
              <select name="flags.swse.beamStyle">
                <option value="laser" {{#if (eq item.flags.swse.beamStyle "laser")}}selected{{/if}}>Laser Line</option>
                <option value="bolt" {{#if (eq item.flags.swse.beamStyle "bolt")}}selected{{/if}}>Energy Bolt</option>
                <option value="heavy" {{#if (eq item.flags.swse.beamStyle "heavy")}}selected{{/if}}>Heavy Bolt</option>
                <option value="pulse" {{#if (eq item.flags.swse.beamStyle "pulse")}}selected{{/if}}>Rapid Pulse</option>
                <option value="ion" {{#if (eq item.flags.swse.beamStyle "ion")}}selected{{/if}}>Ion Stream</option>
                <option value="plasma" {{#if (eq item.flags.swse.beamStyle "plasma")}}selected{{/if}}>Plasma Shot</option>
              </select>
            </div>

            <div class="form-field">
              <label>Bolt Color</label>
              <select name="flags.swse.boltColor">
                <option value="red" {{#if (eq item.flags.swse.boltColor "red")}}selected{{/if}}>Red</option>
                <option value="green" {{#if (eq item.flags.swse.boltColor "green")}}selected{{/if}}>Green</option>
                <option value="blue" {{#if (eq item.flags.swse.boltColor "blue")}}selected{{/if}}>Blue</option>
                <option value="cyan" {{#if (eq item.flags.swse.boltColor "cyan")}}selected{{/if}}>Cyan</option>
                <option value="orange" {{#if (eq item.flags.swse.boltColor "orange")}}selected{{/if}}>Orange</option>
              </select>
            </div>
          </div>
        </section>
        {{/if}}

        {{!-- Lightsaber-specific fields --}}
        {{#if (eq system.weaponCategory "lightsaber")}}
        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Lightsaber Options</h3>

          <div class="form-field">
            <label>Blade Color</label>
            <select name="flags.swse.bladeColor">
              {{#each bladeColorOptions}}
              <option value="{{this.name}}" {{#if (eq ../item.flags.swse.bladeColor this.name)}}selected{{/if}}>{{this.name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-field form-field--checkbox">
            <label>
              <input type="checkbox" class="emit-light-toggle" {{#if item.flags.swse.emitLight}}checked{{/if}} />
              Emit Blade Light
            </label>
          </div>

          <div class="item-editor__button-row">
            {{#if system.activated}}
            <button type="button" class="swse-btn swse-btn--warn deactivate-lightsaber">Deactivate Lightsaber</button>
            {{else}}
            <button type="button" class="swse-btn swse-btn--action activate-lightsaber">Activate Lightsaber</button>
            {{/if}}
          </div>
        </section>
        {{/if}}

        {{!-- ARMOR EDITOR --}}
        {{else if (eq item.type "armor")}}
        <div class="item-editor__grid item-editor__grid--two-col">

          {{!-- COLUMN A: Armor Defense (Classification in header) --}}
          <div class="item-editor__col">
            {{!-- Non-shield armor fields --}}
            {{#if (ne system.armorType "shield")}}
            <section class="item-editor__section">
              <h3 class="item-editor__section-title">Defense</h3>
              <div class="form-field">
                <label>Reflex Defense Bonus</label>
                <input type="number" name="system.reflexBonus" value="{{system.reflexBonus}}" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Fortitude Bonus</label>
                <input type="number" name="system.fortitudeBonus" value="{{system.fortitudeBonus}}" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Max Dex Bonus</label>
                <input type="number" name="system.maxDex" value="{{system.maxDex}}" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Armor Check Penalty</label>
                <input type="number" name="system.armorCheckPenalty" value="{{system.armorCheckPenalty}}" data-dtype="Number" />
              </div>
              {{/if}}
            </section>
          </div>

          {{!-- COLUMN B: Weight, Cost, Flags --}}
          <div class="item-editor__col">
            <section class="item-editor__section">
              <h3 class="item-editor__section-title">Properties</h3>

              <div class="form-field">
                <label>Weight (kg)</label>
                <input type="number" name="system.weight" value="{{system.weight}}" step="0.1" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Cost (credits)</label>
                <input type="number" name="system.cost" value="{{system.cost}}" data-dtype="Number" />
              </div>

              {{#if (eq system.armorType "shield")}}
              <div class="form-field">
                <label>Shield Rating (Max)</label>
                <input type="number" name="system.shieldRating" value="{{system.shieldRating}}" data-dtype="Number" />
              </div>

              <div class="form-field">
                <label>Current SR</label>
                <input type="number" name="system.currentSR" value="{{system.currentSR}}" data-dtype="Number" min="0" max="{{system.shieldRating}}" />
              </div>

              <div class="form-field">
                <label>Charges Current</label>
                <input type="number" name="system.charges.current" value="{{system.charges.current}}" data-dtype="Number" min="0" max="{{system.charges.max}}" />
              </div>

              <div class="form-field">
                <label>Charges Max</label>
                <input type="number" name="system.charges.max" value="{{system.charges.max}}" data-dtype="Number" />
              </div>
              {{/if}}
            </section>
          </div>
        </div>

        {{#if (ne system.armorType "shield")}}
        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Modifiers</h3>

          <div class="item-editor__grid item-editor__grid--two-col">
            <div class="form-field">
              <label>Speed Penalty (squares)</label>
              <input type="number" name="system.speedPenalty" value="{{system.speedPenalty}}" data-dtype="Number" />
            </div>

            <div class="form-field">
              <label>Equipment Perception Bonus</label>
              <input type="number" name="system.equipmentPerceptionBonus" value="{{system.equipmentPerceptionBonus}}" data-dtype="Number" />
            </div>
          </div>

          <div class="form-field form-field--full">
            <label>Special Features</label>
            <textarea name="system.features" rows="2">{{system.features}}</textarea>
          </div>

          <div class="form-field form-field--checkbox">
            <label>
              <input type="checkbox" name="system.armorProficiency" {{#if system.armorProficiency}}checked{{/if}} />
              Has Required Proficiency
            </label>
          </div>
        </section>
        {{/if}}

        {{!-- EQUIPMENT EDITOR --}}
        {{else if (eq item.type "equipment")}}
        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Properties</h3>

          <div class="item-editor__grid item-editor__grid--two-col">
            <div class="form-field">
              <label>Weight</label>
              <input type="text" name="system.weight" value="{{system.weight}}" />
            </div>

            <div class="form-field">
              <label>Cost</label>
              <input type="text" name="system.cost" value="{{system.cost}}" />
            </div>
          </div>
        </section>

        {{!-- FEAT EDITOR --}}
        {{else if (eq item.type "feat")}}
        <div class="item-editor__grid item-editor__grid--two-col">
          <section class="item-editor__section">
            <h3 class="item-editor__section-title">Feat Details</h3>
            <div class="form-field">
              <label>Category</label>
              <input type="text" name="system.category" value="{{system.category}}" placeholder="General, Force, Class..." />
            </div>
            <div class="form-field">
              <label>Source</label>
              <input type="text" name="system.source" value="{{system.source}}" placeholder="Manual" />
            </div>
            <div class="form-field form-field--full">
              <label>Prerequisites</label>
              <textarea name="system.prerequisite" rows="3">{{system.prerequisite}}</textarea>
            </div>
          </section>

          <section class="item-editor__section">
            <h3 class="item-editor__section-title">Rules Text</h3>
            <div class="form-field form-field--full">
              <label>Benefit</label>
              <textarea name="system.benefit" rows="5">{{system.benefit}}</textarea>
            </div>
            <div class="form-field form-field--full">
              <label>Special</label>
              <textarea name="system.special" rows="3">{{system.special}}</textarea>
            </div>
          </section>
        </div>

        {{!-- TALENT EDITOR --}}
        {{else if (eq item.type "talent")}}
        <div class="item-editor__grid item-editor__grid--two-col">
          <section class="item-editor__section">
            <h3 class="item-editor__section-title">Talent Details</h3>
            <div class="form-field">
              <label>Talent Tree</label>
              <input type="text" name="system.tree" value="{{system.tree}}" placeholder="Talent tree" />
            </div>
            <div class="form-field">
              <label>Source</label>
              <input type="text" name="system.source" value="{{system.source}}" placeholder="Manual" />
            </div>
            <div class="form-field form-field--full">
              <label>Prerequisites</label>
              <textarea name="system.prerequisite" rows="3">{{system.prerequisite}}</textarea>
            </div>
          </section>

          <section class="item-editor__section">
            <h3 class="item-editor__section-title">Rules Text</h3>
            <div class="form-field form-field--full">
              <label>Benefit</label>
              <textarea name="system.benefit" rows="5">{{system.benefit}}</textarea>
            </div>
            <div class="form-field form-field--full">
              <label>Special</label>
              <textarea name="system.special" rows="3">{{system.special}}</textarea>
            </div>
          </section>
        </div>

        {{/if}}
      </div>

      {{!-- DESCRIPTION TAB --}}
      <div class="tab {{#if (eq activeTab 'description')}}active{{/if}}" data-tab="description">
        <section class="item-editor__section">
          <h3 class="item-editor__section-title">Description</h3>

          <div class="form-field form-field--full">
            <textarea name="system.description" rows="8">{{system.description}}</textarea>
          </div>
        </section>
      </div>
    </section>

    {{!-- ===== RAIL 3: FIXED FOOTER ===== --}}
    <footer class="item-editor__footer">
      {{!-- Left: Cancel button --}}
      <button type="button" class="swse-btn item-editor__footer-cancel close-btn">
        Cancel
      </button>

      {{!-- Center: Credits display --}}
      <div class="item-editor__footer-credits">
        {{#if actorCredits}}
        Credits: <strong>{{actorCredits}}</strong>
        {{else}}
        <span class="credits-placeholder">No actor context</span>
        {{/if}}
      </div>

      {{!-- Right: Confirm button --}}
      <button type="submit" class="swse-btn swse-btn--primary item-editor__footer-confirm">
        Confirm
      </button>
    </footer>

  </section>
</form>
