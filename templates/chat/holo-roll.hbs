<div class="swse-chat-card swse-roll-card swse-roll-card--{{category}} {{#if hasWeaponRail}}swse-roll-card--weapon-rail{{/if}} {{#if hasDamageType}}swse-roll-card--has-damage-type{{/if}} {{#if eventContext.showProvisionalBadge}}swse-chat-card-event--pending{{/if}}"
     data-swse-chat-surface="roll"
     data-swse-chat-card-v2="true"
     data-expanded="false"
     {{#if eventContext.eventId}}data-swse-event-id="{{eventContext.eventId}}"{{/if}}
     {{#if eventContext.eventState}}data-swse-event-state="{{eventContext.eventState}}"{{/if}}
     {{#if abilityKey}}data-ability="{{abilityKey}}"{{/if}}
     {{#if forceDescriptor}}data-descriptor="{{forceDescriptor}}"{{/if}}
     {{#if railStyle}}style="{{railStyle}}"{{/if}}>
  <span class="corners" aria-hidden="true">
    <span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span>
  </span>
  <span class="headtick" aria-hidden="true"></span>

  {{#if isForceCard}}
    <svg class="glyph swse-force-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <circle cx="12" cy="12" r="9"></circle>
      <circle cx="12" cy="12" r="3.2"></circle>
      <path d="M12 3 V21 M3 12 H21" opacity="0.35"></path>
    </svg>
  {{/if}}

  {{#if eventContext.showProvisionalBadge}}
    <div class="swse-chat-resolution-badge swse-chat-provisional-note">
      <span class="swse-chat-resolution-label">{{eventContext.resolutionLabel}}</span>
      {{#if eventContext.reactionLabel}}<span class="swse-chat-resolution-sub">{{eventContext.reactionLabel}}</span>{{/if}}
    </div>
  {{/if}}

  <div class="head">
    <span class="type-chip">
      {{#if abilityBadge}}
        <span class="ability-hex">{{abilityBadge}}</span>
      {{else}}
        <span class="dot" aria-hidden="true"></span>
      {{/if}}
      {{typeChipLabel}}
    </span>
    <span class="who">{{actorName}}</span>
    {{#if timeLabel}}<span class="ts">{{timeLabel}}</span>{{/if}}
  </div>

  {{#if actionTitle}}
    <h3 class="action">{{{actionTitle}}}</h3>
  {{/if}}

  {{#if forceDescriptors.length}}
    <div class="desc-chip-row">
      {{#each forceDescriptors}}
        <span class="desc-chip" data-d="{{key}}">{{glyph}} {{label}}</span>
      {{/each}}
    </div>
  {{/if}}

  {{#if weaponVisual}}
    <div class="swse-roll-weapon-visual {{weaponVisual.kind}}" data-swse-weapon-visual="{{weaponVisual.kind}}">
      <span class="emitter swse-roll-weapon-visual__emitter" aria-hidden="true"></span>
      <span class="beam swse-roll-weapon-visual__beam" aria-hidden="true"></span>
      <span class="lbl swse-roll-weapon-visual__label">{{weaponVisual.label}}</span>
    </div>
  {{/if}}

  <div class="body">
    <button type="button" class="total swse-roll-total" aria-expanded="false">
      <span class="num">{{total}}</span>
      <span class="label">{{totalLabel}}</span>
      {{#if damageType}}<span class="dmg-type">{{damageType}}</span>{{/if}}
    </button>

    <div class="breakdown swse-roll-breakdown">
      {{#if formula}}<div class="formula">{{formula}}</div>{{/if}}
      {{#if parts}}
        <div class="parts">
          {{#each parts}}
            <span class="part {{#if kind}}part--{{kind}}{{/if}} {{#if isNat20}}part--nat20{{/if}} {{#if isNat1}}part--nat1{{/if}}">
              {{{label}}}{{#if value}} <b>{{value}}</b>{{/if}}{{#if note}} <span>{{note}}</span>{{/if}}
            </span>
          {{/each}}
        </div>
      {{/if}}
    </div>
  </div>

  {{#if isCritical}}
    <div class="crit-banner">★ Natural 20 — Critical Threat</div>
  {{/if}}

  {{#if forceTierGauge.length}}
    <div class="tier-gauge" aria-label="Force power DC tier reached">
      {{#each forceTierGauge}}
        <div class="seg {{#if hit}}hit{{/if}} {{#if top}}top{{/if}}">
          <span class="dc">{{dc}}</span>
          <span class="fx">{{effect}}</span>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{#if outcome}}
    <div class="outcome">
      {{#each outcome.meta}}
        <span class="meta"><span class="k">{{key}}</span><span class="v">{{value}}</span></span>
      {{/each}}
      {{#if outcome.label}}
        <span class="verdict {{outcome.state}}">{{outcome.label}}</span>
      {{/if}}
    </div>
  {{/if}}

  {{#if context.rerollOptions}}
    <div class="actions swse-skill-reroll-options">
      {{#each context.rerollOptions}}
        <button type="button"
                class="btn swse-skill-reroll-btn"
                data-actor-id="{{actorId}}"
                data-skill-key="{{skillKey}}"
                data-source-id="{{sourceId}}"
                data-source-name="{{sourceName}}"
                data-outcome="{{outcome}}"
                data-original-total="{{originalTotal}}"
                data-formula="{{formula}}">
          <span class="i">⟲</span>{{label}} Reroll
        </button>
      {{/each}}
    </div>
  {{/if}}

  {{#if context.attackRerollOptions}}
    <div class="actions swse-attack-reroll-options">
      {{#each context.attackRerollOptions}}
        <button type="button"
                class="btn swse-attack-reroll-btn"
                data-actor-id="{{actorId}}"
                data-weapon-id="{{weaponId}}"
                data-source-id="{{sourceId}}"
                data-source-name="{{sourceName}}"
                data-cost="{{cost}}"
                data-outcome="{{outcome}}"
                data-original-total="{{originalTotal}}"
                data-formula="{{formula}}"
                {{#unless canUse}}disabled{{/unless}}>
          <span class="i">⟲</span>{{label}} Reroll
        </button>
        {{#if disabledReason}}<span class="notes swse-roll-hint">{{disabledReason}}</span>{{/if}}
      {{/each}}
    </div>
  {{/if}}

  {{#if attackDamage}}
    <div class="swse-attack-damage-result">
      <div class="swse-attack-damage-line">
        <span class="k">{{attackDamage.label}}</span>
        <span class="v">{{attackDamage.total}}</span>
        {{#if attackDamage.damageType}}<span class="dmg-type">{{attackDamage.damageType}}</span>{{/if}}
      </div>
      {{#if attackDamage.formula}}<div class="formula">{{attackDamage.formula}}</div>{{/if}}
      <div class="actions swse-damage-actions">
        <button type="button"
                class="btn swse-apply-damage-btn"
                data-attacker="{{attackDamage.actorId}}"
                data-target="{{attackDamage.targetId}}"
                data-weapon="{{attackDamage.weaponId}}"
                data-amount="{{attackDamage.total}}"
                data-raw-amount="{{attackDamage.rawTotal}}"
                data-damage-type="{{attackDamage.damageType}}"
                data-damage-types="{{attackDamage.damageTypes}}"
                data-damage-components="{{attackDamage.damageComponents}}"
                data-workflow-id="{{attackDamage.workflowId}}"
                data-action-id="{{attackDamage.actionId}}"
                data-attack-mode="{{attackDamage.attackMode}}"
                data-context-tags="{{attackDamage.contextTags}}"
                data-hit="{{attackDamage.isHit}}"
                data-natural-1="{{attackDamage.natural1}}"
                data-natural-20="{{attackDamage.natural20}}"
                data-area-attack="{{attackDamage.areaAttack}}"
                data-burst-fire="{{attackDamage.burstFire}}"
                data-autofire="{{attackDamage.autofire}}"
                data-stun="{{attackDamage.stun}}"
                data-ion="{{attackDamage.ion}}"
                data-ammo-cost="{{attackDamage.ammoCost}}"
                data-workflow-context="{{attackDamage.workflowContextEncoded}}"
                data-is-crit="{{attackDamage.isCritical}}"
                data-crit-mult="{{attackDamage.critMultiplier}}">
          <span class="i">▸</span>{{attackDamage.applyLabel}}
        </button>
      </div>
    </div>
  {{/if}}

  {{#if damageApplyAction}}
    <div class="actions swse-damage-actions">
      <button type="button"
              class="btn swse-apply-damage-btn"
              data-attacker="{{damageApplyAction.actorId}}"
              data-target="{{damageApplyAction.targetId}}"
              data-weapon="{{damageApplyAction.weaponId}}"
              data-amount="{{damageApplyAction.amount}}"
              data-raw-amount="{{damageApplyAction.rawAmount}}"
              data-damage-type="{{damageApplyAction.damageType}}"
              data-damage-types="{{damageApplyAction.damageTypes}}"
              data-damage-components="{{damageApplyAction.damageComponents}}"
              data-workflow-id="{{damageApplyAction.workflowId}}"
              data-action-id="{{damageApplyAction.actionId}}"
              data-attack-mode="{{damageApplyAction.attackMode}}"
              data-context-tags="{{damageApplyAction.contextTags}}"
              data-hit="{{damageApplyAction.isHit}}"
              data-natural-1="{{damageApplyAction.natural1}}"
              data-natural-20="{{damageApplyAction.natural20}}"
              data-area-attack="{{damageApplyAction.areaAttack}}"
              data-burst-fire="{{damageApplyAction.burstFire}}"
              data-autofire="{{damageApplyAction.autofire}}"
              data-stun="{{damageApplyAction.stun}}"
              data-ion="{{damageApplyAction.ion}}"
              data-ammo-cost="{{damageApplyAction.ammoCost}}"
              data-workflow-context="{{damageApplyAction.workflowContextEncoded}}"
              data-is-crit="{{damageApplyAction.isCritical}}"
              data-crit-mult="{{damageApplyAction.critMultiplier}}">
        <span class="i">▸</span>{{damageApplyAction.label}}
      </button>
    </div>
  {{/if}}

  {{#if damageAction}}
    <div class="actions swse-damage-actions">
      <button type="button"
              class="btn swse-roll-damage"
              data-actor-id="{{damageAction.actorId}}"
              data-weapon-id="{{damageAction.weaponId}}"
              data-target="{{damageAction.targetId}}"
              data-workflow-id="{{damageAction.workflowId}}"
              data-action-id="{{damageAction.actionId}}"
              data-attack-mode="{{damageAction.attackMode}}"
              data-context-tags="{{damageAction.contextTags}}"
              data-hit="{{damageAction.isHit}}"
              data-natural-1="{{damageAction.natural1}}"
              data-natural-20="{{damageAction.natural20}}"
              data-area-attack="{{damageAction.areaAttack}}"
              data-burst-fire="{{damageAction.burstFire}}"
              data-autofire="{{damageAction.autofire}}"
              data-stun="{{damageAction.stun}}"
              data-ion="{{damageAction.ion}}"
              data-damage-types="{{damageAction.damageTypes}}"
              data-damage-components="{{damageAction.damageComponents}}"
              data-ammo-cost="{{damageAction.ammoCost}}"
              data-workflow-context="{{damageAction.workflowContextEncoded}}"
              data-is-crit="{{damageAction.isCritical}}"
              data-crit-mult="{{damageAction.critMultiplier}}"
              data-two-handed="{{damageAction.twoHanded}}">
        <span class="i">▸</span>{{damageAction.label}}
      </button>
    </div>
  {{/if}}

  {{#if reactionContext.reactions.length}}
    <div class="reactions-strip swse-chat-reaction-strip"
         role="group"
         aria-label="Available reactions"
         data-swse-reaction-owner="{{reactionContext.ownerUserId}}"
         data-swse-defender-id="{{reactionContext.defenderId}}"
         data-swse-attacker-id="{{reactionContext.attackerId}}">
      <div class="head-line">
        <span>Reaction Window</span>
        {{#if reactionContext.defenderName}}<span class="you">— {{reactionContext.defenderName}}</span>{{/if}}
        {{#if reactionContext.timerLabel}}<span class="timer">{{reactionContext.timerLabel}}</span>{{/if}}
      </div>
      <div class="pills">
        {{#each reactionContext.reactions}}
          <button type="button"
                  class="reaction-btn swse-chat-reaction-pill {{#unless available}}swse-chat-reaction-pill--blocked{{/unless}}"
                  data-key="{{key}}"
                  data-swse-reaction-key="{{key}}"
                  data-swse-reaction-owner="{{../reactionContext.ownerUserId}}"
                  data-swse-defender-id="{{../reactionContext.defenderId}}"
                  data-swse-attacker-id="{{../reactionContext.attackerId}}"
                  data-swse-event-id="{{../eventContext.eventId}}"
                  data-swse-message-id="{{../eventContext.messageId}}"
                  data-swse-dc="{{dc}}"
                  data-swse-attack-total="{{attackTotal}}"
                  data-swse-trigger="{{trigger}}"
                  {{#unless available}}disabled{{/unless}}>
            <span class="glyph">{{glyph}}</span>{{label}}
            {{#if sublabel}}<span class="sub">{{sublabel}}</span>{{/if}}
          </button>
        {{/each}}
      </div>
      {{#if reactionContext.reason}}
        <span class="reason">{{reactionContext.reason}}</span>
      {{/if}}
    </div>
  {{/if}}
</div>
