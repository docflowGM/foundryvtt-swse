<div class="swse-chat-card swse-roll-card swse-roll-card--{{category}} {{#if hasWeaponRail}}swse-roll-card--weapon-rail{{/if}} {{#if hasDamageType}}swse-roll-card--has-damage-type{{/if}}"
     data-swse-chat-surface="roll"
     data-swse-chat-card-v2="true"
     data-expanded="false"
     {{#if abilityKey}}data-ability="{{abilityKey}}"{{/if}}
     {{#if forceDescriptor}}data-descriptor="{{forceDescriptor}}"{{/if}}
     {{#if railStyle}}style="{{railStyle}}"{{/if}}>
  <span class="corners" aria-hidden="true">
    <span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span>
  </span>
  <span class="headtick" aria-hidden="true"></span>

  <div class="head">
    <span class="type-chip">
      {{#if abilityBadge}}
        <span class="ability-hex">{{abilityBadge}}</span>
      {{else}}
        <span class="dot" aria-hidden="true"></span>
      {{/if}}
      {{typeChipLabel}}
    </span>
    <span class="who">{{actorName}}</span>
    {{#if timeLabel}}<span class="ts">{{timeLabel}}</span>{{/if}}
  </div>

  {{#if actionTitle}}
    <h3 class="action">{{{actionTitle}}}</h3>
  {{/if}}

  {{#if weaponVisual}}
    <div class="swse-roll-weapon-visual {{weaponVisual.kind}}" data-swse-weapon-visual="{{weaponVisual.kind}}">
      <span class="emitter swse-roll-weapon-visual__emitter" aria-hidden="true"></span>
      <span class="beam swse-roll-weapon-visual__beam" aria-hidden="true"></span>
      <span class="lbl swse-roll-weapon-visual__label">{{weaponVisual.label}}</span>
    </div>
  {{/if}}

  <div class="body">
    <button type="button" class="total swse-roll-total" aria-expanded="false">
      <span class="num">{{total}}</span>
      <span class="label">{{totalLabel}}</span>
      {{#if damageType}}<span class="dmg-type">{{damageType}}</span>{{/if}}
    </button>

    <div class="breakdown swse-roll-breakdown">
      {{#if formula}}<div class="formula">{{formula}}</div>{{/if}}
      {{#if parts}}
        <div class="parts">
          {{#each parts}}
            <span class="part {{#if kind}}part--{{kind}}{{/if}} {{#if isNat20}}part--nat20{{/if}} {{#if isNat1}}part--nat1{{/if}}">
              {{{label}}}{{#if value}} <b>{{value}}</b>{{/if}}{{#if note}} <span>{{note}}</span>{{/if}}
            </span>
          {{/each}}
        </div>
      {{/if}}
    </div>
  </div>

  {{#if isCritical}}
    <div class="crit-banner">★ Natural 20 — Critical Threat</div>
  {{/if}}

  {{#if outcome}}
    <div class="outcome">
      {{#each outcome.meta}}
        <span class="meta"><span class="k">{{key}}</span><span class="v">{{value}}</span></span>
      {{/each}}
      {{#if outcome.label}}
        <span class="verdict {{outcome.state}}">{{outcome.label}}</span>
      {{/if}}
    </div>
  {{/if}}

  {{#if context.rerollOptions}}
    <div class="actions swse-skill-reroll-options">
      {{#each context.rerollOptions}}
        <button type="button"
                class="btn swse-skill-reroll-btn"
                data-actor-id="{{actorId}}"
                data-skill-key="{{skillKey}}"
                data-source-id="{{sourceId}}"
                data-source-name="{{sourceName}}"
                data-outcome="{{outcome}}"
                data-original-total="{{originalTotal}}"
                data-formula="{{formula}}">
          <span class="i">⟲</span>{{label}} Reroll
        </button>
      {{/each}}
    </div>
  {{/if}}

  {{#if context.attackRerollOptions}}
    <div class="actions swse-attack-reroll-options">
      {{#each context.attackRerollOptions}}
        <button type="button"
                class="btn swse-attack-reroll-btn"
                data-actor-id="{{actorId}}"
                data-weapon-id="{{weaponId}}"
                data-source-id="{{sourceId}}"
                data-source-name="{{sourceName}}"
                data-cost="{{cost}}"
                data-outcome="{{outcome}}"
                data-original-total="{{originalTotal}}"
                data-formula="{{formula}}"
                {{#unless canUse}}disabled{{/unless}}>
          <span class="i">⟲</span>{{label}} Reroll
        </button>
        {{#if disabledReason}}<span class="notes swse-roll-hint">{{disabledReason}}</span>{{/if}}
      {{/each}}
    </div>
  {{/if}}
</div>
