<div class="swse-progression-session">
  <header class="card-header">
    <h3>
      {{#if (eq mode "chargen")}}
        {{localize 'SWSE.Chat.Progression.CharacterCreated'}}
      {{else}}
        {{localize 'SWSE.Chat.Progression.LevelUpComplete'}}
      {{/if}}
    </h3>
    <div class="level-badge">{{localize 'SWSE.Chat.Progression.Level' level=newLevel}}</div>
  </header>

  <div class="card-content">
    <div class="actor-info">
      <strong>{{actor.name}}</strong>
    </div>

    {{#if changes.classLevels}}
    <section class="class-levels">
      <h4>{{localize 'SWSE.Chat.Progression.Classes'}}</h4>
      <ul>
        {{#each changes.classLevels}}
          <li><strong>{{this.classId}}</strong> {{localize 'SWSE.Chat.Progression.ClassLevel' level=this.levelInClass}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{#if changes.species}}
    <section class="species">
      <h4>{{localize 'SWSE.Chat.Progression.Species'}}</h4>
      <p>{{changes.species.speciesId}}</p>
    </section>
    {{/if}}

    {{#if changes.background}}
    <section class="background">
      <h4>{{localize 'SWSE.Chat.Progression.Background'}}</h4>
      <p>{{changes.background}}</p>
    </section>
    {{/if}}

    {{#if changes.talents}}
    <section class="talents">
      <h4>{{localize 'SWSE.Chat.Progression.TalentsSelected'}}</h4>
      <ul>
        {{#each changes.talents}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{#if changes.feats}}
    <section class="feats">
      <h4>{{localize 'SWSE.Chat.Progression.FeatsSelected'}}</h4>
      <ul>
        {{#each changes.feats}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{#if changes.skills}}
    <section class="skills">
      <h4>{{localize 'SWSE.Chat.Progression.SkillsTrained'}}</h4>
      <ul>
        {{#each changes.skills}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{#if changes.abilityIncreases}}
    <section class="ability-increases">
      <h4>{{localize 'SWSE.Chat.Progression.AbilityIncreases'}}</h4>
      <ul>
        {{#each changes.abilityIncreases}}
          {{#if this}}
            <li><strong>{{@key}}:</strong> +{{this}}</li>
          {{/if}}
        {{/each}}
      </ul>
    </section>
    {{/if}}

    {{#if changes.hp}}
    <section class="hp">
      <h4>{{localize 'SWSE.Chat.Progression.HPGained'}}</h4>
      <p>
        {{#each changes.hp}}
          +{{this}}{{#unless @last}}, {{/unless}}
        {{/each}}
      </p>
    </section>
    {{/if}}

    {{#if grants}}
    <section class="grants-summary">
      <h4>{{localize 'SWSE.Chat.Progression.SessionSummary'}}</h4>
      <ul>
        {{#if grants.talents}}
          <li>{{localize 'SWSE.Chat.Progression.TalentSlotsGranted' count=grants.talents}}</li>
        {{/if}}
        {{#if grants.bonusFeats}}
          <li>{{localize 'SWSE.Chat.Progression.BonusFeatsGranted' count=grants.bonusFeats}}</li>
        {{/if}}
        {{#if grants.forcePoints}}
          <li>{{localize 'SWSE.Chat.Progression.ForcePointsGranted' count=grants.forcePoints}}</li>
        {{/if}}
        {{#if grants.features}}
          <li>{{localize 'SWSE.Chat.Progression.Features'}} {{#each grants.features}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</li>
        {{/if}}
      </ul>
    </section>
    {{/if}}
  </div>

  <footer class="card-footer">
    <span class="session-id">{{localize 'SWSE.Chat.Progression.Session' id=sessionId}}</span>
  </footer>
</div>

