{{!--
  Upgrade Workshop — Main Shell
  Structure: mentor HUD · category tabs · [item rail | detail pane] · footer
  vm.categories — only visible (count > 0) categories are included by the service layer
--}}
<div class="swse-upgrade-app">

  {{!-- ═══════════════════ MENTOR HUD ═══════════════════ --}}
  <header class="upgrade-hud">
    <div class="upgrade-mentor">
      <div class="mentor-avatar-wrap">
        <div class="mentor-avatar-glow"></div>
        <div class="mentor-avatar-icon">
          <i class="fas fa-user-astronaut"></i>
        </div>
      </div>
      <div class="mentor-info">
        <span class="mentor-name">{{vm.mentor.name}}</span>
        <span class="mentor-role">{{vm.mentor.role}}</span>
        <p class="mentor-text">{{vm.mentor.text}}</p>
      </div>
    </div>
    <div class="upgrade-title-block">
      <h2 class="upgrade-title">UPGRADE WORKSHOP</h2>
      {{#if vm.selectedItem}}
        <span class="upgrade-subtitle">{{vm.selectedItem.name}}</span>
      {{/if}}
    </div>
  </header>

  {{!-- ═══════════════════ CATEGORY TABS ═══════════════════ --}}
  {{!-- Only categories with applicable items are present in vm.categories --}}
  {{#if vm.categories.length}}
  <nav class="upgrade-category-tabs">
    {{#each vm.categories}}
      <button type="button"
        class="upgrade-tab {{#if this.active}}active{{/if}}"
        data-category-id="{{this.id}}">
        <span class="tab-label">{{this.label}}</span>
        <span class="tab-badge">{{this.count}}</span>
      </button>
    {{/each}}
  </nav>
  {{/if}}

  {{!-- ═══════════════════ MAIN BODY ═══════════════════ --}}
  <div class="upgrade-body">

    {{#if vm.unavailableMessage}}

      {{!-- No upgradeable items state --}}
      <div class="upgrade-empty-state">
        <div class="empty-state-icon"><i class="fas fa-tools"></i></div>
        <p class="empty-state-text">{{vm.unavailableMessage}}</p>
      </div>

    {{else}}

      {{!-- LEFT: Item Rail --}}
      <aside class="upgrade-item-rail">
        {{#if vm.items.length}}
          {{#each vm.items}}
            <div class="item-rail-row {{#if this.selected}}selected{{/if}}"
                 data-item-id="{{this.id}}"
                 title="{{this.name}}">
              <img class="item-rail-icon"
                   src="{{this.ui.icon}}"
                   alt="{{this.name}}" />
              <div class="item-rail-info">
                <span class="item-rail-name">{{this.name}}</span>
                <span class="item-rail-type">{{this.ui.displayType}}</span>
                {{#if this.summary}}
                  <span class="item-rail-summary">{{this.summary}}</span>
                {{/if}}
              </div>
              {{#if this.equipped}}
                <span class="item-equipped-badge" title="Equipped">●</span>
              {{/if}}
            </div>
          {{/each}}
        {{else}}
          <div class="item-rail-empty">
            <p>No items in this category.</p>
          </div>
        {{/if}}
      </aside>

      {{!-- RIGHT: Detail Pane --}}
      <main class="upgrade-detail-pane">
        {{#if vm.selectedItem}}
          {{> "systems/foundryvtt-swse/templates/apps/upgrade/partials/upgrade-detail-pane.hbs"}}
        {{else}}
          <div class="detail-empty-state">
            <i class="fas fa-arrow-left"></i>
            <p>Select an item to view available upgrades.</p>
          </div>
        {{/if}}
      </main>

    {{/if}}

  </div>

  {{!-- ═══════════════════ FOOTER ═══════════════════ --}}
  <footer class="upgrade-footer-bar">
    {{> "systems/foundryvtt-swse/templates/apps/upgrade/partials/upgrade-footer.hbs"}}
  </footer>

</div>
