<div class="houserules-presets">
  <div class="presets-header">
    <h2>House Rule Presets</h2>
    <p class="description">
      Quick-load bundles of recommended houlerule configurations. Applying a preset overwrites all current houlerule settings with a curated starting point.
      <br><em>Settings marked ⚠ are Experimental or Partial — review them after applying.</em>
    </p>
  </div>

  <div class="presets-container">

    <!-- Core Rules Only -->
    <div class="preset-card {{#if (eq currentPreset "coreRules")}}active{{/if}}">
      <div class="preset-header">
        <h3>Core Rules Only</h3>
        <span class="preset-tag">RAW</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">Vanilla SWSE as written. No house rules. Perfect for purists.</p>
        <ul class="preset-highlights">
          <li><strong>4d6 Drop Lowest</strong> ability scores</li>
          <li><strong>Standard diagonal</strong> movement (2 squares)</li>
          <li><strong>Force Points</strong> recover on level up</li>
          <li><strong>Strict RAW</strong> Dark Side rules</li>
          <li><strong>Talents</strong> at odd levels only</li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="coreRules">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "coreRules")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

    <!-- Balanced Campaign -->
    <div class="preset-card {{#if (eq currentPreset "balanced")}}active{{/if}}">
      <div class="preset-header">
        <h3>Balanced Campaign</h3>
        <span class="preset-tag">Popular</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">Community-recommended balance fixes. Smooths rough edges without going cinematic.</p>
        <ul class="preset-highlights">
          <li><strong>Armored Defense</strong> for all characters</li>
          <li><strong>50% weapon ranges</strong> for tighter combat</li>
          <li><strong>Improved Second Wind</strong> heals CT</li>
          <li><strong>Lenient</strong> Dark Side rules</li>
          <li><strong>Retraining</strong> allowed</li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="balanced">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "balanced")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

    <!-- Heroic Cinematic -->
    <div class="preset-card {{#if (eq currentPreset "heroic")}}active{{/if}}">
      <div class="preset-header">
        <h3>Heroic Cinematic</h3>
        <span class="preset-tag">Cinematic</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">High-powered Star Wars. More talent options, Three Strikes death, narrative Force.</p>
        <ul class="preset-highlights">
          <li><strong>Talents every level</strong></li>
          <li><strong>Cross-class skills</strong> allowed</li>
          <li><strong>Three Strikes</strong> death system</li>
          <li><strong>Narrative Dark Side</strong> (GM discretion)</li>
          <li><strong>Full retraining</strong> allowed</li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="heroic">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "heroic")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

    <!-- Tactical VTT -->
    <div class="preset-card {{#if (eq currentPreset "tacticalVTT")}}active{{/if}}">
      <div class="preset-header">
        <h3>Tactical VTT</h3>
        <span class="preset-tag">Automation</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">Fully automated play: ammo tracking, flanking, status effects, action enforcement. Requires tokens on canvas.</p>
        <ul class="preset-highlights">
          <li><strong>Blaster charges</strong> tracked</li>
          <li><strong>Flanking</strong> enabled (+2 attack)</li>
          <li><strong>Status effects</strong> auto-tracked</li>
          <li><strong>Alternating diagonal</strong> movement</li>
          <li><strong>Fight Defensively</strong> RAW standard action</li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="tacticalVTT">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "tacticalVTT")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

    <!-- Theater of the Mind -->
    <div class="preset-card {{#if (eq currentPreset "theaterOfTheMind")}}active{{/if}}">
      <div class="preset-header">
        <h3>Theater of the Mind</h3>
        <span class="preset-tag">TotM</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">No token enforcement. Ranges and movement adjudicated by GM. Simpler, faster play.</p>
        <ul class="preset-highlights">
          <li><strong>No flanking</strong> (GM adjudicates)</li>
          <li><strong>No ammo tracking</strong></li>
          <li><strong>Simplified diagonal</strong> movement</li>
          <li><strong>RAI Fight Defensively</strong> (with normal attack)</li>
          <li><strong>Lenient</strong> Dark Side rules</li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="theaterOfTheMind">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "theaterOfTheMind")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

    <!-- Gritty / Simulationist -->
    <div class="preset-card {{#if (eq currentPreset "gritty")}}active{{/if}}">
      <div class="preset-header">
        <h3>Gritty / Simulationist</h3>
        <span class="preset-tag">Survival</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">Ammo, slower recovery, harsher wounds. For campaigns where danger and logistics matter.</p>
        <ul class="preset-highlights">
          <li><strong>Roll HP</strong> on level up</li>
          <li><strong>Blaster charges</strong> tracked</li>
          <li><strong>Enhanced Massive Damage</strong> module on</li>
          <li><strong>Persistent DT penalty</strong> enabled</li>
          <li><strong>Second Wind</strong> only after extended rest</li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="gritty">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "gritty")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

    <!-- Force-Cinematic -->
    <div class="preset-card {{#if (eq currentPreset "forceCinematic")}}active{{/if}}">
      <div class="preset-header">
        <h3>Force-Cinematic</h3>
        <span class="preset-tag">Force</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">Flexible Force suite reselection, per-session FP recovery, narrative Dark Side. For campaigns where the Force is front and center.</p>
        <ul class="preset-highlights">
          <li><strong>Suite reselection</strong> on level up</li>
          <li><strong>Force Points</strong> refresh each session</li>
          <li><strong>Narrative Dark Side</strong> (GM discretion)</li>
          <li><strong>Three Strikes</strong> death system</li>
          <li><strong>Eliminate Instant Death</strong> enabled</li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="forceCinematic">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "forceCinematic")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

    <!-- Vehicle-Heavy Campaign -->
    <div class="preset-card {{#if (eq currentPreset "vehicleHeavy")}}active{{/if}}">
      <div class="preset-header">
        <h3>Vehicle-Heavy Campaign</h3>
        <span class="preset-tag">Starships ⚠</span>
      </div>
      <div class="preset-content">
        <p class="preset-description">Full SWES subsystem engine, directional shields, pilot/engineer/commander roles, vehicle turn controller. ⚠ Experimental features — review after applying.</p>
        <ul class="preset-highlights">
          <li><strong>SWES subsystems</strong> enabled (⚠ Experimental)</li>
          <li><strong>Directional shields</strong> enabled (⚠ Experimental)</li>
          <li><strong>Enhanced Pilot/Engineer/Commander</strong></li>
          <li><strong>Vehicle Turn Controller</strong></li>
          <li><strong>Ship-Based Initiative</strong></li>
        </ul>
      </div>
      <button type="button" class="preset-action" data-action="apply-preset" data-preset="vehicleHeavy">
        <i class="{{getIconClass 'check'}}"></i> {{#if (eq currentPreset "vehicleHeavy")}}Active{{else}}Apply Preset{{/if}}
      </button>
    </div>

  </div>

  <div class="presets-utilities">
    <h3>Preset Management</h3>
    <p class="description">Export your current settings to JSON or import a previously saved configuration.</p>
    <div class="utility-buttons">
      <button type="button" class="utility-btn" data-action="export-settings">
        <i class="{{getIconClass 'download'}}"></i> Export Current Settings
      </button>
      <button type="button" class="utility-btn" data-action="import-settings">
        <i class="{{getIconClass 'upload'}}"></i> Import Settings from File
      </button>
    </div>
  </div>

  <div class="presets-notes">
    <p>
      <strong>Note:</strong> Applying a preset overwrites all houlerule settings. Export your current configuration first if you want to save it.
      Custom configurations can be saved by exporting, editing the JSON file, and importing it back.
    </p>
  </div>
</div>
