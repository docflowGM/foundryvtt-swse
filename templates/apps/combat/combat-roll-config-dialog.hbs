<div class="swse-combat-roll-config rcd" style="--accent-rgb:255,100,140">
  <header class="rcd-header">
    <div class="rcd-header-bg"></div>
    <div class="rcd-header-content">
      <span class="rcd-type-chip">⊕ {{#if (eq action.domain "initiative")}}{{localize 'SWSE.PlayerUI.CombatRoll.Initiative'}}{{else}}{{localize 'SWSE.PlayerUI.CombatRoll.Attack'}}{{/if}}</span>
      <span class="rcd-roll-name">{{actionTitle}}</span>
      <span class="rcd-actor">{{localize 'SWSE.PlayerUI.CombatRoll.Title'}}</span>
    </div>
  </header>

  <div class="rcd-formula-strip">
    <span class="rcd-formula-text">{{localize 'SWSE.PlayerUI.CombatRoll.ProjectedTotal' total=preview.total}}</span>
    <span class="rcd-formula-base-mod">{{localize 'SWSE.PlayerUI.CombatRoll.Resolver'}}</span>
    <span class="rcd-formula-chips">
      <span class="rcd-fchip">{{#if (eq action.domain "initiative")}}{{localize 'SWSE.PlayerUI.CombatRoll.Initiative'}}{{else}}{{localize 'SWSE.PlayerUI.CombatRoll.Weapon'}}{{/if}}</span>
      <span class="rcd-fchip">{{localize 'SWSE.PlayerUI.CombatRoll.LivePreview'}}</span>
    </span>
  </div>

  <div class="rcd-body">
    <main class="rcd-main">
      {{#unless (eq action.domain "initiative")}}
      <section class="swse-roll-config-panel">
        <h4>{{localize 'SWSE.PlayerUI.CombatRoll.TargetContext'}}</h4>
        <div class="swse-roll-config-grid">
          <label>{{localize 'SWSE.PlayerUI.CombatRoll.Range'}}
            <select name="range">
              <option value="pointblank" {{#if (eq options.range "pointblank")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.PointBlank'}}</option>
              <option value="normal" {{#if (eq options.range "normal")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Normal'}}</option>
              <option value="long" {{#if (eq options.range "long")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Long'}}</option>
              <option value="extreme" {{#if (eq options.range "extreme")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Extreme'}}</option>
            </select>
          </label>
          <label>{{localize 'SWSE.PlayerUI.CombatRoll.Cover'}}
            <select name="cover">
              <option value="none" {{#if (eq options.cover "none")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.None'}}</option>
              <option value="partial" {{#if (eq options.cover "partial")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Partial'}}</option>
              <option value="improved" {{#if (eq options.cover "improved")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Improved'}}</option>
              <option value="total" {{#if (eq options.cover "total")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Total'}}</option>
            </select>
          </label>
          <label>{{localize 'SWSE.PlayerUI.CombatRoll.Concealment'}}
            <select name="concealment">
              <option value="none" {{#if (eq options.concealment "none")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.None'}}</option>
              <option value="partial" {{#if (eq options.concealment "partial")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Partial'}}</option>
              <option value="total" {{#if (eq options.concealment "total")}}selected{{/if}}>{{localize 'SWSE.PlayerUI.CombatRoll.Total'}}</option>
            </select>
          </label>
          <label>{{localize 'SWSE.PlayerUI.CombatRoll.MiscModifier'}}
            <input type="number" name="misc" value="{{options.misc}}" step="1">
          </label>
        </div>
      </section>

      <section class="swse-roll-config-panel swse-roll-config-panel--resources">
        <h4>{{localize 'SWSE.PlayerUI.CombatRoll.Resources'}}</h4>
        <div class="rcd-resources">
          <label class="rcd-resource {{#if options.aim}}rcd-res-active{{/if}}">
            <span class="rcd-res-header"><input type="checkbox" name="aim" {{#if options.aim}}checked{{/if}}> <span class="rcd-res-icon">⌖</span><span class="rcd-res-name">{{localize 'SWSE.PlayerUI.CombatRoll.Aim'}}</span></span>
            <span class="rcd-res-detail">{{localize 'SWSE.PlayerUI.CombatRoll.AimDetail'}}</span>
          </label>
          <label class="rcd-resource {{#if options.force}}rcd-res-active{{/if}}">
            <span class="rcd-res-header"><input type="checkbox" name="force" {{#if options.force}}checked{{/if}}> <span class="rcd-res-icon">✦</span><span class="rcd-res-name">{{localize 'SWSE.PlayerUI.CombatRoll.ForcePoint'}}</span></span>
            <span class="rcd-res-detail">{{localize 'SWSE.PlayerUI.CombatRoll.ForcePointDetail'}}</span>
          </label>
        </div>
      </section>
      {{/unless}}

      {{#if preview.attackOptions.length}}
      <section class="swse-roll-config-panel combat-options">
        <h4>{{localize 'SWSE.PlayerUI.CombatRoll.AttackOptions'}}</h4>
        {{#each preview.attackOptions}}
          <div class="swse-roll-config-option combat-option-row combat-option-{{this.control}} {{#if this.disabled}}swse-roll-config-option--disabled{{/if}}">
            {{#if (eq this.control "slider")}}
              <span><b>{{this.label}}</b>{{#if this.summary}}<small>{{this.summary}}</small>{{/if}}</span>
              <input id="combat-option-{{this.id}}" type="range" name="combatOptions.{{this.id}}" min="{{this.min}}" max="{{this.max}}" step="{{this.step}}" value="{{this.value}}" {{#if this.disabled}}disabled{{/if}}>
              <span class="combat-option-value">{{this.value}} / {{this.max}}</span>
            {{else}}
              <input type="checkbox" name="combatOptions.{{this.id}}" {{#if this.checked}}checked{{/if}} {{#if this.disabled}}disabled{{/if}}>
              <span><b>{{this.label}}</b>{{#if this.summary}}<small>{{this.summary}}</small>{{/if}}</span>
            {{/if}}
            {{#if this.warning}}<p class="warning">{{this.warning}}</p>{{/if}}
          </div>
        {{/each}}
      </section>
      {{/if}}
    </main>

    <aside class="rcd-rail">
      <section class="rcd-rail-sec rcd-rail-sec--preview">
        <div class="rcd-rail-lbl">{{localize 'SWSE.PlayerUI.CombatRoll.ProjectedOutcome'}}</div>
        <div class="rcd-preview-formula">{{localize 'SWSE.PlayerUI.CombatRoll.CombatEnginePreview'}}</div>
        <div class="rcd-preview-total">{{preview.total}}</div>
        <div class="rcd-preview-label">{{localize 'SWSE.PlayerUI.CombatRoll.CurrentTotal'}}</div>
      </section>
      <section class="rcd-rail-sec">
        <div class="rcd-rail-lbl">{{localize 'SWSE.PlayerUI.CombatRoll.Breakdown'}}</div>
        {{#each preview.breakdown}}
          <div class="rcd-bd-row"><span class="rcd-bd-label">{{this.label}}</span><span class="rcd-bd-val">{{this.value}}</span></div>
        {{/each}}
      </section>
      <section class="rcd-rail-sec">
        <div class="rcd-rail-lbl">{{localize 'SWSE.PlayerUI.CombatRoll.Execution'}}</div>
        <p class="swse-roll-config-note">{{localize 'SWSE.PlayerUI.CombatRoll.ExecutionNote'}}</p>
      </section>
    </aside>
  </div>

  <footer class="rcd-footer">
    <button type="button" class="rcd-btn rcd-btn-pri roll-attack"><i class="fa-solid fa-dice-d20"></i> {{localize 'SWSE.PlayerUI.CombatRoll.Execute'}}</button>
  </footer>
</div>
