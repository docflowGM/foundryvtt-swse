{{!-- Chargen / progression step rail. Shows below the mentor rail and above utility controls. --}}
<div class="prog-progress-rail" role="navigation" aria-label="Character creation steps">
  <div class="prog-progress-rail__label">Progression Pipeline</div>
  <div class="prog-progress-rail__list" role="list">
    {{#each stepProgress}}
      <div role="button"
              class="prog-step prog-step--{{status}}{{#if isCurrent}} prog-step--active{{/if}}{{#if isComplete}} prog-step--complete{{/if}}{{#if isCaution}} prog-step--caution{{/if}}{{#if isError}} prog-step--error{{/if}}{{#if isConditional}} prog-step--conditional{{/if}}"
              data-action="jump-step"
              data-step-id="{{descriptor.stepId}}"
              data-step-index="{{index}}"
              data-can-navigate="{{#if canNavigate}}true{{else}}false{{/if}}"
              tabindex="{{#if canNavigate}}0{{else}}-1{{/if}}"
              {{#unless canNavigate}}aria-disabled="true"{{/unless}}
              title="{{descriptor.label}}">
        <span class="prog-step__icon">
          {{#if isComplete}}
            <i class="fas fa-check"></i>
          {{else}}{{#if isCurrent}}
            <i class="fas fa-circle"></i>
          {{else}}{{#if isError}}
            <i class="fas fa-triangle-exclamation"></i>
          {{else}}{{#if isCaution}}
            <i class="fas fa-circle-exclamation"></i>
          {{else}}
            <i class="fas {{descriptor.icon}}"></i>
          {{/if}}{{/if}}{{/if}}{{/if}}
        </span>
        <span class="prog-step__name">{{descriptor.label}}</span>
        {{#if isComplete}}<span class="prog-step__check"><i class="fas fa-check"></i></span>{{/if}}
        {{#if isConditional}}<span class="prog-step__check"><i class="fas fa-lock"></i></span>{{/if}}
      </div>
    {{/each}}
  </div>
</div>
