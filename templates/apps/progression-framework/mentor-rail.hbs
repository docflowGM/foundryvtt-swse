<div class="prog-mentor-rail swse-ui-panel swse-prog-mentor-rail" data-mood="{{mentor.mood}}">

  {{!-- Portrait zone: portrait display with CSS-based styling --}}
  <div class="prog-mentor__portrait-zone swse-ui-frame">
    <div class="prog-mentor__portrait prog-holo-mentor-media" data-mentor-portrait="{{mentor.id}}">
      {{#if mentor.portrait}}
        <img class="prog-mentor__portrait-image prog-holo-mentor-media__image"
             src="{{mentor.portrait}}"
             alt="{{mentor.name}}"
             title="{{mentor.name}}"
             onerror="this.onerror=null; this.src='systems/foundryvtt-swse/assets/mentors/salty.png';"/>
      {{else}}
        <img class="prog-mentor__portrait-image prog-holo-mentor-media__image"
             src="systems/foundryvtt-swse/assets/mentors/salty.png"
             alt="Ol' Salty"
             title="Ol' Salty"/>
      {{/if}}
    </div>
  </div>{{!-- /portrait-zone --}}

  {{! Name and title (hidden when mentor collapsed) — Phase 4: tighter identity framing }}
  <div class="prog-mentor__name"><span class="prog-mentor__name-prefix">▸</span>{{mentor.name}}</div>
  <div class="prog-mentor__title">{{mentor.title}}</div>

  {{! Dialogue box (hidden when collapsed) — AurebeshTranslator targets [data-mentor-dialogue] }}
  <div class="prog-mentor__dialogue swse-ui-frame" data-mentor-dialogue>
    <div class="prog-mentor__dialogue-content">
      <p class="prog-mentor__text{{#unless mentor.currentDialogue}} prog-mentor__text--idle{{/unless}}"
         data-mentor-text>
        {{#unless mentor.currentDialogue}}Awaiting your decision…{{/unless}}
      </p>
    </div>
  </div>

  {{! Ask Mentor button (only when enabled) }}
  {{#if mentor.askMentorEnabled}}
    <button class="prog-btn swse-ui-button prog-mentor__ask" data-action="ask-mentor" type="button">
      Ask Mentor
    </button>
  {{/if}}

  {{! Collapse button — always visible }}
  <button class="prog-mentor__collapse" data-action="toggle-mentor" type="button"
          title="{{#if mentorCollapsed}}Expand mentor{{else}}Collapse mentor{{/if}}">
    <i class="fas fa-chevron-{{#if mentorCollapsed}}right{{else}}left{{/if}}"></i>
  </button>
</div>
