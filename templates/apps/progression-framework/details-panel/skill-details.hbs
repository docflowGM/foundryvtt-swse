<div class="prog-skill-details">
  <div class="prog-skill-details__header">
    <h2 class="prog-skill-details__name">{{skillName}}</h2>
    <div class="prog-skill-details__chips">
      <span class="prog-chip">{{abilityLabel}}</span>
      {{#if skillSlug}}<span class="prog-chip prog-chip--muted">{{skillSlug}}</span>{{/if}}
    </div>
  </div>

  {{#if description}}
    <p class="prog-skill-details__description">{{description}}</p>
  {{else}}
    <p class="prog-skill-details__description">No description available.</p>
  {{/if}}

  <div class="prog-skill-details__section">
    <h4 class="prog-skill-details__section-title">Skill Summary</h4>
    <p><strong>Ability:</strong> {{abilityLabel}}</p>
    <p><strong>Category:</strong> {{category}}</p>
    <p><strong>Class Skill:</strong> {{#if isClassSkill}}Yes{{else}}No{{/if}}</p>
    <p><strong>Background Skill:</strong> {{#if isBackgroundSkill}}Yes{{else}}No{{/if}}</p>
    <p><strong>Species Class Skill:</strong> {{#if isSpeciesClassSkill}}Yes{{else}}No{{/if}}</p>
    <p><strong>Trained:</strong> {{#if trained}}Yes{{else}}No{{/if}}</p>
  </div>

  <div class="prog-skill-details__section">
    <h4 class="prog-skill-details__section-title">Extra Skill Uses</h4>
    {{#if hasSkillUses}}
      <ul class="prog-skill-details__uses">
        {{#each skillUses}}
          <li class="prog-skill-details__use">
            <strong>{{this.label}}</strong>
            {{#if this.dc}}<span class="prog-chip">DC {{this.dc}}</span>{{/if}}
            {{#if this.time}}<span class="prog-chip prog-chip--muted">{{this.time}}</span>{{/if}}
            {{#if this.effect}}<p>{{this.effect}}</p>{{else}}{{#if this.description}}<p>{{this.description}}</p>{{/if}}{{/if}}
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p class="prog-skill-details__description">No extra skill uses are listed for this skill.</p>
    {{/if}}
  </div>
</div>
