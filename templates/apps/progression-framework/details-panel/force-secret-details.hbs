{{!-- Force Secret Details Panel --}}

<div class="prog-force-secret-details">
  <div class="prog-force-secret-details__header">
    <h2 class="prog-force-secret-details__name">{{secret.name}}</h2>
    {{#if selectedCount}}
      <span class="prog-force-secret-details__selected-badge">
        <i class="fas fa-star" aria-hidden="true"></i>
        Selected {{selectedCount}} {{plural selectedCount "time" "times"}}
      </span>
    {{/if}}
  </div>

  {{#if description}}
    <div class="prog-force-secret-details__section">
      <h3 class="prog-force-secret-details__section-title">Description</h3>
      <p class="prog-force-secret-details__description">{{description}}</p>
    </div>
  {{/if}}

  {{#if prerequisites}}
    <div class="prog-force-secret-details__section">
      <h3 class="prog-force-secret-details__section-title">Prerequisites</h3>
      <p class="prog-force-secret-details__prerequisites">{{prerequisites}}</p>
    </div>
  {{/if}}

  <div class="prog-force-secret-details__actions">
    {{#if canAddMore}}
      {{#if selectedCount}}
        <p class="prog-force-secret-details__hint">
          <i class="fas fa-info-circle" aria-hidden="true"></i>
          You can select this Secret multiple times.
        </p>
      {{else}}
        <p class="prog-force-secret-details__hint">
          <i class="fas fa-info-circle" aria-hidden="true"></i>
          This Secret can be selected multiple times.
        </p>
      {{/if}}

      <button class="prog-btn prog-btn--primary" data-action="commit-item" data-item-id="{{secret.id}}" type="button">
        <i class="fas fa-{{#if selectedCount}}plus-circle{{else}}check-circle{{/if}}"></i>
        {{buttonLabel}}
      </button>
    {{else}}
      <p class="prog-force-secret-details__hint prog-force-secret-details__hint--blocked">
        <i class="fas fa-ban" aria-hidden="true"></i>
        No more selections available.
      </p>
    {{/if}}

    <button class="prog-btn" data-action="ask-mentor" type="button">
      <i class="fas fa-brain" aria-hidden="true"></i>
      Ask Mentor
    </button>
  </div>
</div>
