<div class="prog-class-details">
  {{#if img}}
    <div class="prog-class-details__portrait-frame prog-holo-media prog-holo-media--wide">
      <img class="prog-class-details__portrait prog-holo-media__image" src="{{img}}" alt="{{class.name}}">
      <div class="prog-holo-scan"></div>
    </div>
  {{else if class.img}}
    <div class="prog-class-details__portrait-frame prog-holo-media prog-holo-media--wide">
      <img class="prog-class-details__portrait prog-holo-media__image" src="{{class.img}}" alt="{{class.name}}">
      <div class="prog-holo-scan"></div>
    </div>
  {{/if}}

  <h2 class="prog-class-details__name">{{class.name}}</h2>

  {{#if canonicalDescription}}
    <p class="prog-class-details__description">{{canonicalDescription}}</p>
  {{else if fantasy}}
    <p class="prog-class-details__description">{{fantasy}}</p>
  {{/if}}

  {{#if hasSuggestionAnalysis}}
  <section class="prog-class-details__section prog-class-details__suggestion-analysis suggestion-evidence-note">
    <h4 class="prog-class-details__section-title"><i class="fas fa-route"></i> Mentor read</h4>
    {{#if suggestionReasonSummary}}
      <p class="prog-class-details__description">{{suggestionReasonSummary}}</p>
    {{/if}}

    {{#if suggestionPrimaryReasons.length}}
    <div class="suggestion-evidence-group suggestion-evidence-group--primary">
      <h5>Build fit</h5>
      <ul class="prog-class-details__list prog-class-details__suggestion-list">
        {{#each suggestionPrimaryReasons}}
          <li>{{text}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if suggestionForecastReasons.length}}
    <div class="suggestion-evidence-group suggestion-evidence-group--forecast">
      <h5>Forecast</h5>
      <ul class="prog-class-details__list prog-class-details__suggestion-list">
        {{#each suggestionForecastReasons}}
          <li>{{text}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if suggestionOpportunityReasons.length}}
    <div class="suggestion-evidence-group suggestion-evidence-group--opportunity">
      <h5>Opportunity</h5>
      <ul class="prog-class-details__list prog-class-details__suggestion-list">
        {{#each suggestionOpportunityReasons}}
          <li>{{text}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if suggestionCautionReasons.length}}
    <div class="suggestion-evidence-group suggestion-evidence-group--caution">
      <h5>Watch for</h5>
      <ul class="prog-class-details__list prog-class-details__suggestion-list">
        {{#each suggestionCautionReasons}}
          <li>{{text}}</li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
  </section>
  {{/if}}

  {{#if classSkills.length}}
  <section class="prog-class-details__section prog-class-details__class-skills">
    <h4 class="prog-class-details__section-title">{{localize "SWSE.Progression.Core.Class.ClassSkills"}}</h4>
    <div class="prog-class-details__skill-chip-list">
      {{#each classSkills}}
        <span class="prog-class-details__skill-chip {{this.abilityClass}}">
          <span class="prog-class-details__skill-name">{{this.name}}</span>
          <span class="prog-class-details__skill-ability">{{this.abilityLabel}}</span>
        </span>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if startingAbilities.length}}
  <section class="prog-class-details__section prog-class-details__abilities">
    <h4 class="prog-class-details__section-title">{{localize "SWSE.Progression.Core.Class.StartingAbilities"}}</h4>
    <ul class="prog-class-details__list">{{#each startingAbilities}}<li>{{this.name}}</li>{{/each}}</ul>
  </section>
  {{/if}}

  <section class="prog-class-details__section prog-class-details__defenses">
    <h4 class="prog-class-details__section-title">{{localize "SWSE.Progression.Core.Class.DefenseBonuses"}}</h4>
    <div class="prog-class-details__defense-row">
      <span class="prog-class-details__defense"><strong>{{localize "SWSE.Progression.Core.Defense.FortitudeAbbrev"}}</strong> +{{defenses.fortitude}}</span>
      <span class="prog-class-details__defense"><strong>{{localize "SWSE.Progression.Core.Defense.ReflexAbbrev"}}</strong> +{{defenses.reflex}}</span>
      <span class="prog-class-details__defense"><strong>{{localize "SWSE.Progression.Core.Defense.WillAbbrev"}}</strong> +{{defenses.will}}</span>
    </div>
  </section>

  <section class="prog-class-details__section prog-class-details__bab">
    <h4 class="prog-class-details__section-title">{{localize "SWSE.Progression.Core.Class.BAB"}}</h4>
    <div class="prog-class-details__bab-value">{{bab}}</div>
  </section>

  {{#if classTrees.length}}
  <section class="prog-class-details__section prog-class-details__trees">
    <h4 class="prog-class-details__section-title">{{localize "SWSE.Progression.Core.Class.ClassTrees"}}</h4>
    <ul class="prog-class-details__list prog-class-details__tree-list">{{#each classTrees}}<li>{{this}}</li>{{/each}}</ul>
  </section>
  {{/if}}

  <section class="prog-class-details__section prog-class-details__mentor">
    <h4 class="prog-class-details__section-title">{{localize "SWSE.Progression.Core.Class.Mentor"}}</h4>
    {{#if mentorPortrait}}
      <div class="prog-class-details__mentor-portrait-frame prog-holo-media prog-holo-media--avatar"
           style="width:72px;height:72px;margin:4px auto 6px;">
        <img class="prog-class-details__mentor-portrait prog-holo-media__image"
             data-src="{{mentorPortrait}}"
             src="data:image/gif;base64,R0lGODlhAQABAAAAACw="
             alt="{{mentorName}}"
             style="width:100%;height:100%;object-fit:contain;display:block;"
             onload="if(!this.dataset.swseResolved){this.dataset.swseResolved='1';let raw=this.dataset.src||'';let src=raw.trim().replace(/^\/systems\//i,'systems/').replace(/^\/foundryvtt-swse\//i,'systems/foundryvtt-swse/').replace(/^foundryvtt-swse\//i,'systems/foundryvtt-swse/').replace(/^assets\//i,'systems/foundryvtt-swse/assets/').replace(/(assets\/mentors\/[^?#.]+)\.png([?#].*)?$/i,'$1.webp$2');this.src=src||'systems/foundryvtt-swse/assets/mentors/salty.webp';}"
             onerror="this.onerror=null; this.src='systems/foundryvtt-swse/assets/mentors/salty.webp';">
      </div>
    {{/if}}
    <div class="prog-class-details__mentor-name">{{mentorName}}</div>
    {{#if mentorTitle}}<div class="prog-class-details__mentor-title">{{mentorTitle}}</div>{{/if}}
  </section>

  {{#if buildMetadata.length}}
  <section class="prog-class-details__section prog-class-details__metadata">
    <h4 class="prog-class-details__section-title">{{localize "SWSE.Progression.Core.Class.BuildMetadata"}}</h4>
    <div class="prog-class-details__metadata-chips">
      {{#each buildMetadata}}<span class="prog-chip">{{this}}</span>{{/each}}
    </div>
  </section>
  {{/if}}

  {{#if hasPrerequisiteRows}}
  <section class="prog-class-details__section prog-class-details__prereqs">
    <h4 class="prog-class-details__section-title"><i class="fas fa-clipboard-check"></i> {{localize "SWSE.Progression.Core.Class.Prerequisites"}}</h4>
    <ul class="prog-class-details__list prog-class-details__prereq-list">
      {{#each prerequisiteRows}}
        <li class="prog-class-details__prereq-row {{cssClass}}">
          {{#if met}}<i class="fas fa-check-circle"></i>{{else}}<i class="fas fa-times-circle"></i>{{/if}}
          <span>{{label}}</span>
        </li>
      {{/each}}
    </ul>
  </section>
  {{else if isLocked}}
  <section class="prog-class-details__section prog-class-details__locked">
    <h4 class="prog-class-details__section-title"><i class="fas fa-lock"></i> {{localize "SWSE.Progression.Core.Class.PrerequisitesRequired"}}</h4>
    <p class="prog-class-details__description">{{localize "SWSE.Progression.Core.Class.LockedByPrerequisites"}}</p>
  </section>
  {{/if}}

  <div class="prog-class-details__actions">
    {{#if isLocked}}
      <button class="prog-btn prog-btn--primary" data-action="commit-item" data-item-id="{{class.id}}" type="button" disabled title="{{lockReason}}"><i class="fas fa-lock"></i> {{localize "SWSE.Progression.Core.Class.Locked"}}</button>
    {{else}}
      <button class="prog-btn prog-btn--primary" data-action="commit-item" data-item-id="{{class.id}}" type="button"><i class="fas fa-check"></i> {{localize "SWSE.Progression.Core.Class.Choose" name=class.name}}</button>
    {{/if}}
  </div>
</div>
