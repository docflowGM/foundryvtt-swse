{{!-- Starship Maneuver Details Panel --}}
{{!-- CRITICAL: Uses stacking model (additional uses, not unique ownership) --}}

<div class="prog-starship-maneuver-details">
  <div class="prog-starship-maneuver-details__header">
    <h2 class="prog-starship-maneuver-details__name">{{maneuver.name}}</h2>
    {{#if selectedCount}}
      <span class="prog-starship-maneuver-details__selected-badge">
        <i class="fas fa-star" aria-hidden="true"></i>
        Selected {{selectedCount}} {{plural selectedCount "use" "uses"}}
      </span>
    {{/if}}
  </div>

  <div class="prog-starship-maneuver-details__section">
    <h3 class="prog-starship-maneuver-details__section-title">Description</h3>
    {{#if canonicalDescription}}
      <p class="prog-starship-maneuver-details__description">{{canonicalDescription}}</p>
    {{else}}
      <p class="prog-starship-maneuver-details__description prog-starship-maneuver-details__description--unavailable">No description available.</p>
    {{/if}}
  </div>

  <div class="prog-starship-maneuver-details__actions">
    {{#if selectedCount}}
      <p class="prog-starship-maneuver-details__hint">
        <i class="fas fa-hourglass-end" aria-hidden="true"></i>
        Current selection: <strong>{{selectedCount}}</strong> {{plural selectedCount "use" "uses"}} pending
      </p>

      {{!-- Inline quantity control --}}
      <div class="prog-starship-maneuver-details__quantity-inline">
        <button class="prog-quantity-btn prog-quantity-btn--decrement"
                data-action="decrement-quantity"
                data-item-id="{{maneuver.id}}"
                type="button"
                aria-label="Remove one">
          <i class="fas fa-minus" aria-hidden="true"></i>
        </button>
        <span class="prog-quantity-display">{{selectedCount}}</span>
        <button class="prog-quantity-btn prog-quantity-btn--increment"
                data-action="increment-quantity"
                data-item-id="{{maneuver.id}}"
                type="button"
                aria-label="Add one">
          <i class="fas fa-plus" aria-hidden="true"></i>
        </button>
      </div>
    {{/if}}

    {{#if canAddMore}}
      {{#if selectedCount}}
        <p class="prog-starship-maneuver-details__hint">
          <i class="fas fa-info-circle" aria-hidden="true"></i>
          You can select this maneuver multiple times for additional uses.
        </p>
      {{else}}
        <p class="prog-starship-maneuver-details__hint">
          <i class="fas fa-info-circle" aria-hidden="true"></i>
          This maneuver can be selected multiple times.
        </p>
      {{/if}}

      <button class="prog-btn prog-btn--primary" data-action="commit-item" data-item-id="{{maneuver.id}}" type="button">
        <i class="fas fa-{{#if selectedCount}}plus-circle{{else}}check-circle{{/if}}"></i>
        {{buttonLabel}}
      </button>
    {{else}}
      <p class="prog-starship-maneuver-details__hint prog-starship-maneuver-details__hint--blocked">
        <i class="fas fa-ban" aria-hidden="true"></i>
        No more maneuver selections available.
      </p>
    {{/if}}

    <button class="prog-btn" data-action="ask-mentor" type="button">
      <i class="fas fa-brain" aria-hidden="true"></i>
      Ask Mentor
    </button>
  </div>
</div>
