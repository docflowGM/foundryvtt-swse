{{!-- Force Power Details Panel --}}
{{!-- Shows focused power with stack count and add/deselect controls --}}

<div class="prog-force-power-details">

  {{!-- Header with power name and selected count --}}
  <div class="prog-force-power-details__header">
    <h2 class="prog-force-power-details__name">{{power.name}}</h2>
    {{#if selectedCount}}
      <span class="prog-force-power-details__selected-badge">
        <i class="fas fa-star" aria-hidden="true"></i>
        Selected {{selectedCount}} {{selectedCountLabel}}
      </span>
    {{/if}}
  </div>

  {{#if power.img}}
    <div class="prog-force-power-details__media prog-holo-media prog-holo-media--wide">
      <img class="prog-force-power-details__image prog-holo-media__image" src="{{power.img}}" alt="{{power.name}}">
      <div class="prog-holo-scan"></div>
    </div>
  {{/if}}

  {{!-- Description --}}
  <div class="prog-force-power-details__section">
    <h3 class="prog-force-power-details__section-title">Description</h3>
    {{#if canonicalDescription}}
      <p class="prog-force-power-details__description">{{canonicalDescription}}</p>
    {{else}}
      <p class="prog-force-power-details__description prog-force-power-details__description--unavailable">No description available.</p>
    {{/if}}
  </div>

  {{!-- Prerequisites --}}
  <div class="prog-force-power-details__section">
    <h3 class="prog-force-power-details__section-title">Prerequisites</h3>
    {{#if prerequisites}}
      <p class="prog-force-power-details__prerequisites">{{prerequisites}}</p>
    {{else}}
      <p class="prog-force-power-details__prerequisites prog-force-power-details__prerequisites--none">None</p>
    {{/if}}
  </div>

  {{!-- Descriptor tags --}}
  <div class="prog-force-power-details__section">
    <h3 class="prog-force-power-details__section-title">Descriptor</h3>
    {{#if hasDescriptors}}
      <div class="prog-force-power-details__chips">
        {{#each descriptors}}
          <span class="prog-force-power-details__chip prog-force-power-details__chip--descriptor">{{this}}</span>
        {{/each}}
      </div>
    {{else}}
      <p class="prog-force-power-details__prerequisites prog-force-power-details__prerequisites--none">None listed</p>
    {{/if}}
  </div>

  {{!-- Role metadata --}}
  <div class="prog-force-power-details__section">
    <h3 class="prog-force-power-details__section-title">Role Metadata</h3>
    {{#if hasRoleMetadataTags}}
      <div class="prog-force-power-details__chips">
        {{#each roleMetadataTags}}
          <span class="prog-force-power-details__chip prog-force-power-details__chip--role">{{this}}</span>
        {{/each}}
      </div>
    {{else}}
      <p class="prog-force-power-details__prerequisites prog-force-power-details__prerequisites--none">None listed</p>
    {{/if}}
  </div>

  {{!-- PHASE 8: Selection controls with quantity display --}}
  <div class="prog-force-power-details__actions">
    {{#if selectedCount}}
      <p class="prog-force-power-details__hint">
        <i class="fas fa-hourglass-end" aria-hidden="true"></i>
        Current selection: <strong>{{selectedCount}}</strong> {{selectedUseLabel}} pending
      </p>

      {{!-- Inline quantity control --}}
      <div class="prog-force-power-details__quantity-inline">
        <button class="prog-quantity-btn prog-quantity-btn--decrement"
                data-action="decrement-quantity"
                data-item-id="{{power.id}}"
                type="button"
                aria-label="Remove one">
          <i class="fas fa-minus" aria-hidden="true"></i>
        </button>
        <span class="prog-quantity-display">{{selectedCount}}</span>
        <button class="prog-quantity-btn prog-quantity-btn--increment"
                data-action="increment-quantity"
                data-item-id="{{power.id}}"
                type="button"
                aria-label="Add one">
          <i class="fas fa-plus" aria-hidden="true"></i>
        </button>
      </div>
    {{/if}}

    {{#if canAddMore}}
      {{#if selectedCount}}
        <p class="prog-force-power-details__hint">
          <i class="fas fa-info-circle" aria-hidden="true"></i>
          You can select this Power multiple times for additional uses.
        </p>
      {{else}}
        <p class="prog-force-power-details__hint">
          <i class="fas fa-info-circle" aria-hidden="true"></i>
          This Power can be selected multiple times.
        </p>
      {{/if}}

      <button class="prog-btn prog-btn--primary" data-action="commit-item" data-item-id="{{power.id}}" type="button">
        <i class="fas fa-{{#if selectedCount}}plus-circle{{else}}check-circle{{/if}}"></i>
        {{buttonLabel}}
      </button>
    {{else}}
      <p class="prog-force-power-details__hint prog-force-power-details__hint--blocked">
        <i class="fas fa-ban" aria-hidden="true"></i>
        No more Power selections available.
      </p>
    {{/if}}

    <button class="prog-btn" data-action="ask-mentor" type="button">
      <i class="fas fa-brain" aria-hidden="true"></i>
      Ask Mentor
    </button>
  </div>

</div>
