<div class="prog-species-details">

  {{!-- 2. Species portrait - only if art exists --}}
  {{#if img}}
    <div class="prog-species-details__portrait">
      <img class="prog-species-details__portrait-img" src="{{img}}" alt="{{species.name}}">
      <div class="prog-holo-scan"></div>
    </div>
  {{/if}}

  {{!-- 3. Name + source header --}}
  <div class="prog-species-details__header">
    <h2 class="prog-species-details__name">{{species.name}}</h2>
    {{#if source}}<span class="prog-chip">{{source}}</span>{{/if}}
  </div>

  {{!-- 4. Description text (lore/background) --}}
  {{#if canonicalDescription}}
    <p class="prog-species-details__desc">{{canonicalDescription}}</p>
  {{else}}
    <p class="prog-species-details__desc prog-species-details__desc--unavailable">No description available.</p>
  {{/if}}

  {{!-- 5. Key stats: size, speed --}}

  {{#if speciesTags.length}}
    <div class="prog-species-details__tags">
      <h4>Build Signals</h4>
      <div class="prog-tags">
        {{#each speciesTags}}<span class="prog-chip">{{this.label}}</span>{{/each}}
      </div>
    </div>
  {{/if}}

  <div class="prog-species-details__stats">
    {{#if size}}<div><strong>Size:</strong> {{size}}</div>{{/if}}
    {{#if speed}}<div><strong>Speed:</strong> {{speed}}</div>{{/if}}
  </div>

  {{!-- 6. Ability modifiers: +2 DEX, -2 CON, etc. --}}
  {{#if abilityRows.length}}
    <div class="prog-species-details__attrs">
      {{#each abilityRows}}
        <div class="prog-species-details__attr-row">
          <span>{{this.label}}:</span>
          <span class="{{this.cssClass}}">
            {{#if (gt this.value 0)}}+{{/if}}{{this.value}}
          </span>
        </div>
      {{/each}}
    </div>
  {{/if}}


  {{#if attributeForecast.boosts.length}}
    <div class="prog-species-details__forecast">
      <h4>Attribute Outlook</h4>
      {{#each attributeForecast.boosts}}
        <div class="prog-species-details__ability"><strong>{{this.signedValue}} {{this.ability}}</strong> — {{this.summary}}</div>
      {{/each}}
    </div>
  {{/if}}

  {{#if attributeForecast.mitigations.length}}
    <div class="prog-species-details__forecast prog-species-details__forecast--mitigation">
      <h4>Potential Weak Spots</h4>
      {{#each attributeForecast.mitigations}}
        <div class="prog-species-details__ability"><strong>{{this.signedValue}} {{this.ability}}</strong> — {{this.summary}}</div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- 7. Special abilities --}}
  {{#if abilities.length}}
    <div class="prog-species-details__special">
      <h4>Special Abilities</h4>
      {{#each abilities}}<div class="prog-species-details__ability">• {{this.name}}</div>{{/each}}
    </div>
  {{/if}}

  {{!-- 8. Languages --}}
  {{#if languages.length}}
    <div class="prog-species-details__languages">
      <h4>Languages</h4>
      <div>{{#each languages}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
    </div>
  {{/if}}

  {{!-- 9. CONFIRMATION ACTION - Confirm Species button or Near-Human builder entry --}}
  <div class="prog-species-details__actions">
    {{#if isNearHuman}}
      <button class="prog-btn prog-btn--primary" data-action="enter-near-human" type="button">
        <i class="fas fa-cogs"></i> Customize Near-Human
      </button>
    {{else}}
      <button class="prog-btn prog-btn--primary" data-action="commit-item"
              data-item-id="{{species.id}}" type="button">
        <i class="fas fa-check"></i> Confirm {{species.name}}
      </button>
    {{/if}}
  </div>

</div>
