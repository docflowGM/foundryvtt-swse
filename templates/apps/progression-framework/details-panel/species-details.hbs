<div class="prog-species-details">

  {{!-- 1. Variant/default selector first, when this species has options --}}
  {{#if speciesVariants.length}}
    <section class="prog-species-details__section prog-species-details__variants">
      <h4>{{localize "SWSE.Progression.Core.Species.Options"}}</h4>
      <div class="prog-species-variant-grid">
        <button class="prog-species-variant prog-species-variant--default {{#if defaultVariantSelected}}prog-species-variant--selected{{/if}}"
                data-action="select-species-variant"
                data-species-id="{{species.id}}"
                data-variant-id="default"
                type="button">
          <div class="prog-species-variant__header">
            <strong>{{localize "SWSE.Progression.Core.Species.Default"}}</strong>
            {{#if defaultVariantSelected}}<span class="prog-chip">{{localize "SWSE.Progression.Core.Species.Selected"}}</span>{{else}}<span class="prog-chip">{{localize "SWSE.Progression.Core.Species.BaseProfile"}}</span>{{/if}}
          </div>
          <div class="prog-species-variant__meta">
            {{#if abilityLine}}<span>{{abilityLine}}</span>{{/if}}
            {{#if size}}<span>{{localize "SWSE.Progression.Core.Species.SizeInline" size=size}}</span>{{/if}}
            {{#if speed}}<span>{{speed}}</span>{{/if}}
          </div>
        </button>

        {{#each speciesVariants}}
          <button class="prog-species-variant {{#if this.isSelected}}prog-species-variant--selected{{/if}}"
                  data-action="select-species-variant"
                  data-species-id="{{this.speciesId}}"
                  data-variant-id="{{this.id}}"
                  type="button">
            <div class="prog-species-variant__header">
              <strong>{{this.label}}</strong>
              {{#if this.isSelected}}<span class="prog-chip">{{localize "SWSE.Progression.Core.Species.Selected"}}</span>{{else}}{{#if this.source}}<span class="prog-chip">{{this.source}}</span>{{/if}}{{/if}}
            </div>
            <div class="prog-species-variant__meta">
              {{#if this.abilities}}<span>{{this.abilities}}</span>{{/if}}
              {{#if this.size}}<span>{{localize "SWSE.Progression.Core.Species.SizeInline" size=this.size}}</span>{{/if}}
              {{#if this.speed}}<span>{{this.speed}}</span>{{/if}}
              {{#if this.languages.length}}<span>{{localize "SWSE.Progression.Core.Species.Languages"}}: {{#each this.languages}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>{{/if}}
            </div>
            {{#if this.special.length}}
              <div class="prog-species-variant__list">
                {{#each this.special}}<span>• {{this.name}}</span>{{/each}}
              </div>
            {{/if}}
          </button>
        {{/each}}
      </div>
    </section>
  {{/if}}

  {{!-- 2. Photo --}}
  {{#if img}}
    <div class="prog-species-details__portrait prog-holo-media prog-holo-media--wide">
      <img class="prog-species-details__portrait-img prog-holo-media__image" src="{{img}}" alt="{{species.name}}">
      <div class="prog-holo-scan"></div>
    </div>
  {{/if}}

  {{!-- Header --}}
  <div class="prog-species-details__header">
    <div>
      <h2 class="prog-species-details__name">{{species.name}}</h2>
      {{#if selectedVariantLabel}}<span class="prog-species-details__variant-label">{{localize "SWSE.Progression.Core.Species.Profile" label=selectedVariantLabel}}</span>{{/if}}
    </div>
    {{#if source}}<span class="prog-chip">{{source}}</span>{{/if}}
  </div>

  {{!-- 3. Description --}}
  <section class="prog-species-details__section">
    <h4>{{localize "SWSE.Progression.Core.Species.Description"}}</h4>
    {{#if canonicalDescription}}
      <p class="prog-species-details__desc">{{canonicalDescription}}</p>
    {{else}}
      <p class="prog-species-details__desc prog-species-details__desc--unavailable">{{localize "SWSE.Progression.Core.Species.NoDescription"}}</p>
    {{/if}}
  </section>

  {{!-- 4. Attribute Adjustment --}}
  <section class="prog-species-details__section prog-species-details__attrs">
    <h4>{{localize "SWSE.Progression.Core.Species.AttributeAdjustment"}}</h4>
    {{#if abilityRows.length}}
      {{#each abilityRows}}
        <div class="prog-species-details__attr-row">
          <span>{{this.label}}</span>
          <span class="{{this.cssClass}}">{{this.signedValue}}</span>
        </div>
      {{/each}}
    {{else}}
      <div class="prog-species-details__muted">{{localize "SWSE.Progression.Core.Species.None"}}</div>
    {{/if}}
  </section>

  {{!-- 5. Size --}}
  <section class="prog-species-details__section prog-species-details__stats">
    <h4>{{localize "SWSE.Progression.Core.Species.Size"}}</h4>
    <div>{{#if size}}{{size}}{{else}}{{localize "SWSE.Progression.Core.Species.Medium"}}{{/if}}</div>
  </section>

  {{!-- 6. Speed --}}
  <section class="prog-species-details__section prog-species-details__stats">
    <h4>{{localize "SWSE.Progression.Core.Species.Speed"}}</h4>
    <div>{{#if speed}}{{speed}}{{else}}{{localize "SWSE.Progression.Core.Species.WalkSix"}}{{/if}}</div>
  </section>

  {{!-- 7. Species Abilities --}}
  <section class="prog-species-details__section prog-species-details__special">
    <h4>{{localize "SWSE.Progression.Core.Species.Abilities"}}</h4>
    {{#if abilities.length}}
      {{#each abilities}}
        <div class="prog-species-details__ability">
          <strong>{{this.name}}</strong>{{#if this.description}} — {{this.description}}{{/if}}
        </div>
      {{/each}}
    {{else}}
      <div class="prog-species-details__muted">{{localize "SWSE.Progression.Core.Species.NoneListed"}}</div>
    {{/if}}
  </section>

  {{!-- Ability choices such as Arkanian Offshoot --}}
  {{#if abilityChoices.length}}
    <section class="prog-species-details__section prog-species-details__ability-choice">
      <h4>{{localize "SWSE.Progression.Core.Species.RequiredChoice"}}</h4>
      {{#each abilityChoices}}
        <button class="prog-species-ability-choice {{#if this.isSelected}}prog-species-ability-choice--selected{{/if}}"
                data-action="select-species-ability-choice"
                data-species-id="{{this.speciesId}}"
                data-choice-index="{{this.index}}"
                data-ability="{{this.ability}}"
                type="button">
          <strong>{{this.label}}</strong>
          {{#if this.summary}}<span>{{this.summary}}</span>{{/if}}
        </button>
      {{/each}}
    </section>
  {{/if}}

  {{!-- 8. Languages --}}
  <section class="prog-species-details__section prog-species-details__languages">
    <h4>{{localize "SWSE.Progression.Core.Species.Languages"}}</h4>
    {{#if languages.length}}
      <div>{{#each languages}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
    {{else}}
      <div class="prog-species-details__muted">{{localize "SWSE.Progression.Core.Species.NoneListed"}}</div>
    {{/if}}
  </section>

  {{!-- 9. Build Signals --}}
  {{#if speciesTags.length}}
    <section class="prog-species-details__section prog-species-details__tags">
      <h4>{{localize "SWSE.Progression.Core.Species.BuildSignals"}}</h4>
      <div class="prog-tags">
        {{#each speciesTags}}<span class="prog-chip">{{this.label}}</span>{{/each}}
      </div>
    </section>
  {{/if}}

  {{#if attributeForecast.boosts.length}}
    <section class="prog-species-details__section prog-species-details__forecast">
      <h4>{{localize "SWSE.Progression.Core.Species.AttributeOutlook"}}</h4>
      {{#each attributeForecast.boosts}}
        <div class="prog-species-details__ability"><strong>{{this.signedValue}} {{this.ability}}</strong> — {{this.summary}}</div>
      {{/each}}
    </section>
  {{/if}}

  {{#if attributeForecast.mitigations.length}}
    <section class="prog-species-details__section prog-species-details__forecast prog-species-details__forecast--mitigation">
      <h4>{{localize "SWSE.Progression.Core.Species.WeakSpots"}}</h4>
      {{#each attributeForecast.mitigations}}
        <div class="prog-species-details__ability"><strong>{{this.signedValue}} {{this.ability}}</strong> — {{this.summary}}</div>
      {{/each}}
    </section>
  {{/if}}

  <div class="prog-species-details__actions">
    {{#if isNearHuman}}
      <button class="prog-btn prog-btn--primary" data-action="enter-near-human" type="button">
        <i class="fas fa-cogs"></i> {{localize "SWSE.Progression.Core.Species.CustomizeNearHuman"}}
      </button>
    {{else}}
      <button class="prog-btn prog-btn--primary" data-action="commit-item"
              data-item-id="{{species.id}}" type="button">
        <i class="fas fa-check"></i> {{localize "SWSE.Progression.Core.Species.Confirm" name=species.name}}
      </button>
    {{/if}}
  </div>

</div>
