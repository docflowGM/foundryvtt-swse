<div class="talent-details-panel">
  <div class="talent-details__header">
    <h2 class="talent-details__name">{{talent.name}}</h2>
    <div class="talent-details__meta">
      <span class="talent-meta-badge tree-badge">{{treeName}}</span>
      {{#if isOwned}}
      <span class="talent-meta-badge owned-badge"><i class="fa-solid fa-check"></i> Chosen</span>
      {{else}}
        {{#if meetsPrereqs}}
        <span class="talent-meta-badge available-badge"><i class="fa-solid fa-circle-check"></i> Available</span>
        {{else}}
        <span class="talent-meta-badge blocked-badge"><i class="fa-solid fa-circle-xmark"></i> Locked</span>
        {{/if}}
      {{/if}}
      {{#if isSelected}}
      <span class="talent-meta-badge selected-badge"><i class="fa-solid fa-bullseye"></i> Selected</span>
      {{/if}}
    </div>
  </div>

  <div class="talent-details__section talent-details__section--status">
    <h3 class="talent-details__section-title">Status</h3>
    <p class="talent-details__description">{{statusText}}</p>
  </div>

  <div class="talent-details__section">
    <h3 class="talent-details__section-title">Description</h3>
    <p class="talent-details__description">{{canonicalDescription}}</p>
  </div>

  {{#if mechanicalBenefit}}
  <div class="talent-details__section">
    <h3 class="talent-details__section-title">Benefit</h3>
    <p class="talent-details__description">{{mechanicalBenefit}}</p>
  </div>
  {{/if}}

  <div class="talent-details__section">
    <h3 class="talent-details__section-title">Prerequisites</h3>
    {{#if prerequisites}}
      <p class="talent-prerequisites__text">{{prerequisites}}</p>
    {{else}}
      <p class="talent-prerequisites__text talent-prerequisites__text--none">No prerequisites</p>
    {{/if}}
    {{#if hasMissingPrereqs}}
    <ul class="talent-prerequisites__missing-list">
      {{#each missingPrereqs}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
    {{/if}}
  </div>

  {{#if prerequisitePath}}
  <div class="talent-details__section talent-details__section--path">
    <h3 class="talent-details__section-title">Path</h3>
    <ol class="talent-path-list">
      {{#each prerequisitePath}}
      <li class="{{#if isMissing}}is-missing{{/if}}">{{name}}</li>
      {{/each}}
    </ol>
  </div>
  {{/if}}

  {{#if recommendationText}}
  <div class="talent-details__section talent-details__section--recommendation">
    <h3 class="talent-details__section-title">Why this might fit</h3>
    <p class="talent-details__description">{{recommendationText}}</p>
  </div>
  {{/if}}

  <div class="talent-details__actions">
    {{#if isSelected}}
    <button class="action-btn deselect-btn" data-action="commit-item" data-item-id="{{talentId}}">
      <i class="fa-solid fa-times-circle"></i>
      Deselect Talent
    </button>
    {{else}}
    <button class="action-btn select-btn" data-action="commit-item" data-item-id="{{talentId}}" {{#unless meetsPrereqs}}disabled{{/unless}}>
      <i class="fa-solid fa-check-circle"></i>
      Choose This Talent
    </button>
    {{/if}}

    <button class="action-btn mentor-btn" data-action="ask-mentor">
      <i class="fa-solid fa-brain"></i>
      Ask Mentor
    </button>
  </div>
</div>
