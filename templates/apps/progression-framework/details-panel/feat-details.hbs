{{!-- Feat Details Panel --}}
{{!-- Shows feat details, prerequisites, and selection controls --}}

<div class="feat-details-panel">

  {{!-- Feat Header --}}
  <div class="details-header feat-details-hero">
    <div class="feat-details-icon prog-holo-media prog-holo-media--icon" aria-hidden="true">
      {{#if feat.iconPath}}
      <img class="feat-details-icon__image prog-holo-media__image" src="{{feat.iconPath}}" alt="{{feat.name}}">
      {{else}}
      <i class="fa-solid {{categoryIcon}} feat-details-icon__fallback"></i>
      {{/if}}
      <div class="feat-details-icon__scan"></div>
    </div>

    <div class="feat-details-header-content">
      <h2 class="feat-name">{{feat.name}}</h2>
      <div class="feat-meta-badges">
        {{#if isSuggested}}
        <div class="meta-badge suggested-badge">
          <i class="fa-solid fa-lightbulb"></i> {{localize "SWSE.Progression.Common.Suggested"}}
        </div>
        {{/if}}
        {{#if isGranted}}
        <div class="meta-badge repeatable-badge">
          <i class="fa-solid fa-certificate"></i> {{localize "SWSE.Progression.Common.Granted"}}
        </div>
        {{else}}{{#if isOwned}}
        <div class="meta-badge repeatable-badge">
          <i class="fa-solid fa-check"></i> {{localize "SWSE.Progression.Common.Owned"}}
        </div>
        {{/if}}{{/if}}
        {{#if isRepeatable}}
        <div class="meta-badge repeatable-badge">
          <i class="fa-solid fa-repeat"></i> {{localize "SWSE.Progression.Common.Repeatable"}}
        </div>
        {{/if}}
      </div>
    </div>
  </div>

  {{!-- Feat Category --}}
  <div class="feat-category-row">
    <span class="row-label">{{localize "SWSE.Progression.Feat.Details.Category"}}</span>
    <span class="category-value">{{category}}</span>
  </div>

  {{!-- Tags (from feat-buckets-and-subbuckets.json mapping) --}}
  {{#if uiBroadTags.length}}
  <div class="feat-tags-row">
    <span class="row-label">{{localize "SWSE.Progression.Feat.Details.Tags"}}</span>
    <div class="feat-tags">
      {{#each uiBroadTags}}
      <span class="feat-tag-badge">{{this}}</span>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Feat Description --}}
  <div class="feat-description-section">
    {{#if shortSummary}}
    <div class="feat-quick-summary">
      <span class="row-label">{{localize "SWSE.Progression.Feat.Details.QuickSummary"}}</span>
      <span>{{shortSummary}}</span>
    </div>
    {{/if}}
    <h3>{{localize "SWSE.Progression.Common.Description"}}</h3>
    {{#if description}}
      <p class="feat-description">{{description}}</p>
    {{else}}
      <p class="feat-description feat-description--unavailable">{{localize "SWSE.Progression.Common.NoDescriptionAvailable"}}</p>
    {{/if}}
  </div>

  {{!-- Prerequisites Section (text-only, no validation) --}}
  <div class="feat-prerequisites-section">
    <h3>{{localize "SWSE.Progression.Common.Prerequisites"}}</h3>
    {{#if prerequisiteLine}}
      <p class="feat-prerequisites">{{prerequisiteLine}}</p>
      {{#if prerequisiteLinks.length}}
      <div class="prerequisite-link-list prerequisite-link-list--feat" aria-label="Clickable prerequisite feats">
        {{#each prerequisiteLinks}}
        <button type="button" class="prerequisite-jump prerequisite-jump--feat {{#unless isAvailable}}is-unavailable{{/unless}}" data-action="jump-feat-prerequisite" data-feat-id="{{id}}">
          <i class="fa-solid {{#if isOwned}}fa-check{{else}}{{#if isAvailable}}fa-arrow-turn-down{{else}}fa-triangle-exclamation{{/if}}{{/if}}"></i>
          <span>{{name}}</span>
        </button>
        {{/each}}
      </div>
      {{/if}}
    {{else}}
      <p class="feat-prerequisites feat-prerequisites--none">{{localize "SWSE.Progression.Common.NoPrerequisites"}}</p>
    {{/if}}
  </div>

  {{#if missingPrerequisites.length}}
  <div class="feat-note unavailable-note feat-missing-prereqs">
    <p><strong>{{localize "SWSE.Progression.Feat.Details.NotMetPrerequisites"}}</strong></p>
    <ul>
      {{#each missingPrerequisites}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if blockingReasons.length}}
  <div class="feat-note unavailable-note feat-blocking-reasons">
    <p><strong>{{localize "SWSE.Progression.Feat.Details.OtherBlockers"}}</strong></p>
    <ul>
      {{#each blockingReasons}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{#if unavailabilityReason}}
  <div class="feat-note unavailable-note">
    <p><strong>{{localize "SWSE.Progression.Common.Status"}}</strong> {{unavailabilityReason}}</p>
  </div>
  {{/if}}

  {{!-- Selection Controls --}}
  <div class="details-actions">
    {{#if isSelected}}
    <button class="action-btn deselect-btn" data-action="commit-item" data-item-id="{{feat.id}}">
      <i class="fa-solid fa-times-circle"></i>
      {{localize "SWSE.Progression.Common.Deselect"}}
    </button>
    {{else}}
    <button class="action-btn select-btn" data-action="commit-item" data-item-id="{{feat.id}}" {{#unless isAvailable}}disabled title="{{unavailabilityReason}}"{{/unless}}>
      <i class="fa-solid fa-check-circle"></i>
      {{#if isAvailable}}{{localize "SWSE.Progression.Feat.Actions.ChooseThisFeat"}}{{else}}{{localize "SWSE.Progression.Common.Unavailable"}}{{/if}}
    </button>
    {{/if}}

    <button class="action-btn mentor-btn" data-action="ask-mentor">
      <i class="fa-solid fa-brain"></i>
      {{localize "SWSE.Progression.Common.AskMentor"}}
    </button>
  </div>

  {{!-- Additional Notes --}}
  {{#if isSuggested}}
  <div class="feat-note suggested-note">
    <p><strong>{{localize "SWSE.Progression.Feat.Details.WhySuggested"}}</strong>
      {{#if suggestionReasonSummary}}{{suggestionReasonSummary}}{{else}}{{localize "SWSE.Progression.Feat.Details.WhySuggestedBody"}}{{/if}}
    </p>
    {{#if suggestionReasonBullets.length}}
    <ul class="feat-suggestion-reasons">
      {{#each suggestionReasonBullets}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
    {{/if}}
  </div>
  {{/if}}

  {{#if isRepeatable}}
  <div class="feat-note repeatable-note">
    <p><strong>{{localize "SWSE.Progression.Common.Repeatable"}}</strong> {{localize "SWSE.Progression.Feat.Details.RepeatableBody"}}</p>
  </div>
  {{/if}}

</div>
