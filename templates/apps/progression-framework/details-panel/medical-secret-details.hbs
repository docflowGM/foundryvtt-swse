{{!-- Medical Secret Details Panel --}}

<div class="prog-force-secret-details prog-medical-secret-details">
  <div class="prog-force-secret-details__header">
    <h2 class="prog-force-secret-details__name">{{secret.name}}</h2>
    {{#if selected}}
      <span class="prog-force-secret-details__selected-badge">
        <i class="fas fa-kit-medical" aria-hidden="true"></i>
        Selected
      </span>
    {{/if}}
  </div>

  <div class="prog-force-secret-details__section">
    <h3 class="prog-force-secret-details__section-title">Treat Injury Benefit</h3>
    {{#if canonicalDescription}}
      <p class="prog-force-secret-details__description">{{canonicalDescription}}</p>
    {{else}}
      <p class="prog-force-secret-details__description prog-force-secret-details__description--unavailable">No description available.</p>
    {{/if}}
  </div>

  {{#if treatInjuryHook}}
    <div class="prog-force-secret-details__section">
      <h3 class="prog-force-secret-details__section-title">Procedure Hook</h3>
      <p class="prog-force-secret-details__prerequisites">{{treatInjuryHook}}</p>
    </div>
  {{/if}}

  <div class="prog-force-secret-details__actions">
    {{#if canAddMore}}
      <p class="prog-force-secret-details__hint">
        <i class="fas fa-info-circle" aria-hidden="true"></i>
        A Medic can select a given Medical Secret only once.
      </p>
      <button class="prog-btn prog-btn--primary" data-action="commit-item" data-item-id="{{secret.id}}" type="button">
        <i class="fas fa-check-circle"></i>
        {{buttonLabel}}
      </button>
    {{else}}
      <p class="prog-force-secret-details__hint prog-force-secret-details__hint--blocked">
        <i class="fas fa-ban" aria-hidden="true"></i>
        {{#if selected}}Already selected.{{else}}No more selections available.{{/if}}
      </p>
    {{/if}}

    <button class="prog-btn" data-action="ask-mentor" type="button">
      <i class="fas fa-brain" aria-hidden="true"></i>
      Ask Mentor
    </button>
  </div>
</div>
