{{!--
  species-work-surface.hbs
  CENTER PANEL — quick-reference species table.

  Rows stay compact and scrollable in the middle body.
  Right body owns the richer descriptive details.
--}}

<div class="prog-species-browse prog-quickref-stage">
  <div class="prog-quickref-table prog-species-table" role="listbox" aria-label="Species">
    <div class="prog-quickref-table__header prog-species-table__header">
      <span>Species</span>
      <span>Size</span>
      <span>Attribute Adjustments</span>
      <span>Status</span>
    </div>

    <div class="prog-quickref-table__body prog-species-list">
      {{#each species}}
        <button class="prog-quickref-row prog-species-row
                       {{#if (eq id ../focusedSpeciesId)}}prog-quickref-row--focused prog-species-row--focused{{/if}}
                       {{#if (eq id ../committedSpeciesId)}}prog-quickref-row--committed prog-species-row--committed{{/if}}"
                data-action="focus-item"
                data-item-id="{{this.id}}"
                type="button"
                role="option"
                {{#if (eq id ../committedSpeciesId)}}aria-selected="true"{{/if}}>

          <span class="prog-quickref-row__cell prog-species-row__name-cell">
            <span class="prog-species-row__name">{{this.name}}</span>
          </span>

          <span class="prog-quickref-row__cell prog-species-row__size">{{this.size}}</span>

          <span class="prog-quickref-row__cell prog-species-row__mods">
            {{#if this.abilityRows.length}}
              <span class="prog-species-row__mods-list">
                {{#each this.abilityRows}}
                  <span class="prog-species-row__mod {{this.cssClass}}">{{this.shortLabel}} {{this.signedValue}}</span>
                {{/each}}
              </span>
            {{else}}
              <span class="prog-species-row__mods-empty">—</span>
            {{/if}}
          </span>

          <span class="prog-quickref-row__cell prog-species-row__status">
            {{#if (eq id ../committedSpeciesId)}}
              <span class="prog-species-row__check"><i class="fas fa-check-circle"></i> Selected</span>
            {{else if (eq id ../focusedSpeciesId)}}
              <span class="prog-species-row__focus">Inspecting</span>
            {{else}}
              <span class="prog-species-row__source">{{this.source}}</span>
            {{/if}}
          </span>
        </button>
      {{else}}
        <p class="prog-species-browse__empty">No species match your search or filters.</p>
      {{/each}}
    </div>
  </div>
</div>
