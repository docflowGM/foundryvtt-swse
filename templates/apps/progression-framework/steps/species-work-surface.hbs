{{!--
  species-work-surface.hbs
  CENTER PANEL — angled option-card layout for species selection.

  Cards are presented in a responsive grid with the new SVG option frames.
  Right body owns the richer descriptive details.
--}}

<div class="prog-species-browse prog-quickref-stage">
  <div class="prog-species-grid" role="listbox" aria-label="Species">
    {{#each species}}
      <button class="swse-option-card prog-species-card
                     {{#if (eq id ../focusedSpeciesId)}}swse-option-card--focused{{/if}}
                     {{#if (eq id ../committedSpeciesId)}}swse-option-card--selected{{/if}}"
              data-action="focus-item"
              data-item-id="{{this.id}}"
              data-selected="{{#if (eq id ../committedSpeciesId)}}true{{else}}false{{/if}}"
              data-focused="{{#if (eq id ../focusedSpeciesId)}}true{{else}}false{{/if}}"
              type="button"
              role="option"
              {{#if (eq id ../committedSpeciesId)}}aria-selected="true"{{/if}}>

        <div class="swse-option-card__header">
          <h3 class="swse-option-card__title prog-species-card__name">{{this.name}}</h3>
          <span class="swse-option-card__subtitle">Size: {{this.size}}</span>
        </div>

        {{#if this.abilityRows.length}}
          <div class="swse-option-card__body prog-species-card__details">
            {{#each this.abilityRows}}
              <span class="prog-species-mod {{this.cssClass}}">{{this.shortLabel}} {{this.signedValue}}</span>
            {{/each}}
          </div>
        {{/if}}

        <div class="swse-option-card__meta">
          {{#if (eq id ../committedSpeciesId)}}
            <span class="swse-option-card__badge"><i class="fas fa-check"></i> Selected</span>
          {{else if (eq id ../focusedSpeciesId)}}
            <span class="swse-option-card__badge">Inspecting</span>
          {{else}}
            <span class="swse-option-card__badge">{{this.source}}</span>
          {{/if}}
        </div>
      </button>
    {{else}}
      <div class="prog-species-browse__empty">No species match your search or filters.</div>
    {{/each}}
  </div>
</div>
