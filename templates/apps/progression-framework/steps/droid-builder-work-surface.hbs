{{!-- Droid Chassis Builder — Garage-style construction work surface --}}
{{!-- Phase 5: right-rail component selection/action flow using builderVm while preserving existing state contracts. --}}

{{#if builderVm.chassis}}
<div class="prog-droid-builder prog-droid-builder--garage prog-droid-builder--mode-{{builderVm.modeClass}} swse-droid-builder-surface" data-builder-mode="{{builderVm.modeClass}}" data-builder-context="{{builderVm.contextMode}}" data-builder-host="{{builderVm.contextProfile.hostKind}}">
  <div class="prog-droid-builder__hud">
    <div class="prog-droid-builder__hud-tag prog-droid-builder__hud-tag--mode"><span class="prog-droid-builder__hud-dot"></span>{{builderVm.contextProfile.hudLabel}}</div>
    <div class="prog-droid-builder__hud-tag">{{builderVm.contextProfile.hostLabel}}</div>
    <div class="prog-droid-builder__hud-tag prog-droid-builder__hud-tag--serial">{{builderVm.chassis.degreeLabel}} · {{builderVm.chassis.sizeLabel}}</div>
  </div>

  <header class="prog-droid-builder__header prog-droid-builder__garage-header">
    <div>
      <h2 class="prog-droid-builder__title">{{builderVm.title}}</h2>
      <p class="prog-droid-builder__subtitle">{{builderVm.subtitle}}</p>
    </div>
    <div class="prog-droid-builder__badge prog-droid-builder__badge--{{builderVm.validation.tone}}">
      {{builderVm.validation.summary}}
    </div>
  </header>

  <section class="prog-droid-builder__builder-strip" aria-label="Droid chassis controls">
    <div class="prog-droid-builder__control-group">
      <label for="droid-builder-degree">Degree</label>
      <select id="droid-builder-degree"
              class="prog-droid-builder__select"
              data-action="set-degree"
              aria-label="Selected droid degree"
              {{#if builderVm.chassis.degreeLocked}}disabled{{/if}}>
        {{#each builderVm.chassis.degreeOptions}}
          <option value="{{this.id}}" {{#if this.isSelected}}selected{{/if}} {{#if this.disabled}}disabled{{/if}}>{{this.label}} — {{this.roles}}</option>
        {{/each}}
      </select>
    </div>
    <div class="prog-droid-builder__control-group">
      <label for="droid-builder-size">Size</label>
      <select id="droid-builder-size"
              class="prog-droid-builder__select"
              data-action="set-size"
              aria-label="Selected droid size"
              {{#if builderVm.chassis.sizeLocked}}disabled{{/if}}>
        {{#each builderVm.chassis.sizeOptions}}
          <option value="{{this.id}}" {{#if this.isSelected}}selected{{/if}} {{#if this.disabled}}disabled{{/if}}>{{this.label}} · {{this.multiplierLabel}} cost</option>
        {{/each}}
      </select>
    </div>
    <div class="prog-droid-builder__control-group">
      <span class="prog-droid-builder__chip">Multiplier {{builderVm.chassis.multiplierLabel}}</span>
      <span class="prog-droid-builder__chip">Systems {{builderVm.installedCount}}</span>
      <span class="prog-droid-builder__chip prog-droid-builder__chip--{{builderVm.budget.tone}}">{{builderVm.budget.statusLabel}}</span>
    </div>
  </section>

  <div class="prog-droid-builder__workbench prog-droid-builder__workbench--browser" data-droid-builder-workbench>
    {{!-- LEFT RAIL: Current build, budget, checklist --}}
    <aside class="prog-droid-builder__left-rail" aria-label="Current droid build">
      <section class="prog-droid-builder__garage-panel prog-droid-builder__garage-summary">
        <div class="prog-droid-builder__garage-head">
          <h3>{{builderVm.contextProfile.railLabel}}</h3>
          <span>{{builderVm.contextProfile.modeLabel}}</span>
        </div>
        <div class="prog-droid-builder__budget">
          <div class="prog-droid-builder__budget-rows">
            <div class="prog-droid-builder__budget-row">
              <span>Starting Budget</span>
              <strong>{{builderVm.budget.base}} cr</strong>
            </div>
            <div class="prog-droid-builder__budget-row">
              <span>Spent</span>
              <strong>{{builderVm.budget.spent}} cr</strong>
            </div>
            <div class="prog-droid-builder__budget-row">
              <span>Remaining</span>
              <strong class="prog-droid-builder__budget-value--{{builderVm.budget.tone}}">{{builderVm.budget.remaining}} cr</strong>
            </div>
          </div>
          <div class="prog-droid-builder__budget-bar {{#if builderVm.budget.isOverBudget}}prog-droid-builder__budget-bar--over{{/if}}" role="meter" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{builderVm.budget.percentSpent}}" aria-label="Construction budget spent"><span style="width: {{builderVm.budget.percentSpent}}%;"></span></div>
        </div>
      </section>

      <section class="prog-droid-builder__garage-panel">
        <div class="prog-droid-builder__garage-head">
          <h3>Required Systems</h3>
          <span>{{#if builderVm.validation.isValid}}READY{{else}}CHECK{{/if}}</span>
        </div>
        <ul class="prog-droid-builder__required-list">
          {{#each builderVm.requiredChecklist}}
            <li class="prog-droid-builder__check-item {{#if this.complete}}prog-droid-builder__check-item--complete{{else}}prog-droid-builder__check-item--missing{{/if}}">
              <span class="prog-droid-builder__installed-item-name">{{this.label}}</span>
              <span class="prog-droid-builder__badge prog-droid-builder__badge--{{this.tone}}">{{#if this.complete}}OK{{else}}REQ{{/if}}</span>
              <small>{{this.message}}</small>
            </li>
          {{/each}}
        </ul>
      </section>

      <section class="prog-droid-builder__garage-panel prog-droid-builder__scroll">
        <div class="prog-droid-builder__garage-head">
          <h3>Installed Systems</h3>
          <span>{{builderVm.installedCount}}</span>
        </div>
        {{#each builderVm.installedGroups}}
          <div class="prog-droid-builder__group-label">{{this.label}}</div>
          <ul class="prog-droid-builder__installed-list">
            {{#if this.items}}
              {{#each this.items}}
                <li class="prog-droid-builder__installed-item prog-droid-builder__installed-item--complete {{#if this.isSelected}}prog-droid-builder__installed-item--selected{{/if}}"
                    role="button"
                    tabindex="0"
                    data-action="select-component"
                    data-component-category="{{this.removeAction.category}}"
                    data-component-id="{{this.removeAction.id}}"
                    data-component-subcategory="{{this.removeAction.subcategory}}"
                    data-component-uid="{{this.detailKey}}">
                  <span class="prog-droid-builder__installed-item-name">{{this.name}}</span>
                  <span class="prog-droid-builder__chip">{{this.cost}} cr</span>
                  <span class="prog-droid-builder__chip prog-droid-builder__chip--neutral">Inspect</span>
                </li>
              {{/each}}
            {{else}}
              <li class="prog-droid-builder__installed-item prog-droid-builder__installed-item--missing">
                <span class="prog-droid-builder__installed-item-name">No {{this.label}} installed</span>
                {{#if this.required}}<span class="prog-droid-builder__badge prog-droid-builder__badge--negative">Required</span>{{/if}}
              </li>
            {{/if}}
          </ul>
        {{/each}}
      </section>
    </aside>

    {{!-- MIDDLE RAIL: Available systems browser --}}
    <main class="prog-droid-builder__middle-rail" aria-label="Available droid systems">
      <div class="prog-droid-builder__filter-bar">
        <input class="prog-droid-builder__search" type="search" placeholder="Search components…" aria-label="Search droid systems" data-action="filter-systems">
        <div class="prog-droid-builder__filter-tabs" role="tablist" aria-label="Droid system categories">
          {{#each builderVm.availableGroups}}
            <button class="prog-droid-builder__filter-tab prog-droid-builder__tab {{#if this.isActive}}prog-droid-builder__tab--active{{/if}}"
                    type="button"
                    data-category="{{this.id}}">
              {{this.label}}
            </button>
          {{/each}}
        </div>
      </div>

      <div class="prog-droid-builder__scroll prog-droid-builder__systems-browser">
        {{#each builderVm.availableGroups}}
          <section class="prog-droid-builder__panel {{#if this.isActive}}prog-droid-builder__panel--active{{/if}}" data-panel="{{this.id}}">
            <div class="prog-droid-builder__garage-head prog-droid-builder__system-head">
              <div class="prog-droid-builder__system-title-wrap">
                <h3>{{this.label}}</h3>
                <span class="prog-droid-builder__badge prog-droid-builder__badge--{{this.requirementTone}}">{{this.requirementStatusLabel}}</span>
              </div>
              <span>{{this.enabledCount}}/{{this.count}} available</span>
            </div>
            {{#if this.description}}
              <p class="prog-droid-builder__system-description">{{this.description}}</p>
            {{/if}}

            {{#if this.subgroups}}
              {{#each this.subgroups}}
                <div class="prog-droid-builder__group-label">{{this.label}}</div>
                <div class="prog-droid-builder__card-grid">
                  {{#each this.items}}
                    <article class="prog-droid-builder__component-card prog-droid-builder__component-card--{{this.category}} {{#if this.isSelected}}prog-droid-builder__component-card--selected{{/if}} {{#if this.isInstalled}}prog-droid-builder__component-card--installed{{/if}} {{#unless this.canInstall}}{{#unless this.isInstalled}}prog-droid-builder__component-card--disabled{{/unless}}{{/unless}}"
                             role="button"
                             tabindex="0"
                             data-action="select-component"
                             data-component-id="{{this.id}}"
                             data-component-category="{{this.category}}"
                             data-component-subcategory="{{this.subcategory}}"
                             data-component-uid="{{this.uid}}"
                             aria-disabled="{{#if this.disabled}}true{{else}}false{{/if}}">
                      <div class="prog-droid-builder__component-card-eyebrow">{{this.type}}</div>
                      <h4 class="prog-droid-builder__component-card-title">{{this.name}}</h4>
                      {{#if this.description}}<p class="prog-droid-builder__component-card-body">{{this.description}}</p>{{/if}}
                      <div class="prog-droid-builder__component-card-meta">
                        <span class="prog-droid-builder__chip">{{this.adjustedCost}} cr</span>
                        {{#if this.isInstalled}}<span class="prog-droid-builder__chip prog-droid-builder__chip--positive">Installed</span>{{/if}}
                        {{#if this.isSuggested}}<span class="prog-droid-builder__chip prog-droid-builder__chip--neutral">Recommended</span>{{/if}}
                        {{#unless this.canInstall}}{{#unless this.isInstalled}}<span class="prog-droid-builder__chip prog-droid-builder__chip--negative">Blocked</span>{{/unless}}{{/unless}}
                      </div>
                      {{#if this.disabledReasons}}
                        <div class="prog-droid-builder__component-card-body">
                          {{#each this.disabledReasons}}<div>• {{this}}</div>{{/each}}
                        </div>
                      {{/if}}
                      <div class="prog-droid-builder__component-card-foot">
                        <span class="prog-droid-builder__chip prog-droid-builder__chip--neutral">Select for Detail</span>
                      </div>
                    </article>
                  {{/each}}
                </div>
              {{/each}}
            {{else}}
              <div class="prog-droid-builder__card-grid">
                {{#each this.items}}
                  <article class="prog-droid-builder__component-card prog-droid-builder__component-card--{{this.category}} {{#if this.isSelected}}prog-droid-builder__component-card--selected{{/if}} {{#if this.isInstalled}}prog-droid-builder__component-card--installed{{/if}} {{#unless this.canInstall}}{{#unless this.isInstalled}}prog-droid-builder__component-card--disabled{{/unless}}{{/unless}}"
                           role="button"
                           tabindex="0"
                           data-action="select-component"
                           data-component-id="{{this.id}}"
                           data-component-category="{{this.category}}"
                           data-component-subcategory="{{this.subcategory}}"
                           data-component-uid="{{this.uid}}"
                           aria-disabled="{{#if this.disabled}}true{{else}}false{{/if}}">
                    <div class="prog-droid-builder__component-card-eyebrow">{{this.type}}</div>
                    <h4 class="prog-droid-builder__component-card-title">{{this.name}}</h4>
                    {{#if this.description}}<p class="prog-droid-builder__component-card-body">{{this.description}}</p>{{/if}}
                    <div class="prog-droid-builder__component-card-meta">
                      <span class="prog-droid-builder__chip">{{this.adjustedCost}} cr</span>
                      {{#if this.speed}}<span class="prog-droid-builder__chip">SPD {{this.speed}}</span>{{/if}}
                      {{#if this.isInstalled}}<span class="prog-droid-builder__chip prog-droid-builder__chip--positive">Installed</span>{{/if}}
                      {{#if this.isSuggested}}<span class="prog-droid-builder__chip prog-droid-builder__chip--neutral">Recommended</span>{{/if}}
                      {{#unless this.canInstall}}{{#unless this.isInstalled}}<span class="prog-droid-builder__chip prog-droid-builder__chip--negative">Blocked</span>{{/unless}}{{/unless}}
                    </div>
                    {{#if this.disabledReasons}}
                      <div class="prog-droid-builder__component-card-body">
                        {{#each this.disabledReasons}}<div>• {{this}}</div>{{/each}}
                      </div>
                    {{/if}}
                    <div class="prog-droid-builder__component-card-foot">
                      <span class="prog-droid-builder__chip prog-droid-builder__chip--neutral">Select for Detail</span>
                    </div>
                  </article>
                {{/each}}
              </div>
            {{/if}}
          </section>
        {{/each}}
      </div>
    </main>

  </div>
</div>
{{else}}
<div class="prog-droid-builder prog-droid-builder--garage swse-droid-builder-surface">
  <div class="prog-droid-builder__detail-empty">
    <i class="fas fa-robot"></i>
    <p>Droid construction state is not available.</p>
  </div>
</div>
{{/if}}
