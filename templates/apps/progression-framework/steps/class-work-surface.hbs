<div class="prog-class-browse prog-quickref-stage {{#if isDroidProgression}}prog-class-browse--droid{{/if}}">
  {{#if isDroidProgression}}
    <div class="prog-class-browse__droid-hud">
      <div class="prog-class-browse__droid-eyebrow">Droid Assembly Registry</div>
      <h2 class="prog-class-browse__droid-title">Select Droid Class</h2>
      <p class="prog-class-browse__droid-subtitle">Choose the unit role package before chassis systems are installed.</p>
    </div>
  {{/if}}
  <div class="prog-class-grid" role="listbox" aria-label="Class">
    {{#each classes}}
      <button class="swse-option-card prog-class-card prog-class-card--visual
                     {{#if (eq id ../focusedClassId)}}swse-option-card--focused prog-class-card--focused{{/if}}
                     {{#if (eq id ../committedClassId)}}swse-option-card--selected prog-class-card--selected{{/if}}
                     {{#if this.isSuggested}}prog-class-card--suggested prog-class-card--suggested-{{this.confidenceLevel}}{{/if}}"
              data-action="focus-item"
              data-item-id="{{this.id}}"
              data-selected="{{#if (eq id ../committedClassId)}}true{{else}}false{{/if}}"
              data-focused="{{#if (eq id ../focusedClassId)}}true{{else}}false{{/if}}"
              data-recommended="{{#if this.isSuggested}}true{{/if}}"
              data-confidence-level="{{this.confidenceLevel}}"
              type="button"
              role="option"
              aria-label="{{this.name}} class"
              {{#if (eq id ../committedClassId)}}aria-selected="true"{{/if}}>

        <div class="prog-class-card__visual-wrap prog-holo-media prog-holo-media--wide">
          {{#if this.img}}
            <img class="prog-class-card__image prog-holo-media__image" src="{{this.img}}" alt="{{this.name}}">
          {{/if}}
          <div class="prog-class-card__scanline"></div>
          <div class="prog-class-card__holo-overlay" aria-hidden="true"></div>
          <div class="prog-class-card__quote" aria-hidden="true">{{this.profileQuote}}</div>
          <div class="prog-class-card__nameplate">
            <span class="prog-class-card__name">{{this.name}}</span>
            <span class="prog-class-card__type">{{this.type}}</span>
          </div>
        </div>

        <div class="prog-class-card__chips" aria-hidden="true">
          {{#if this.badgeLabel}}
            <span class="swse-option-card__badge swse-option-card__badge--recommended">{{this.badgeLabel}}</span>
          {{/if}}
          {{#if this.mentorName}}
            <span class="swse-option-card__badge"><i class="fas fa-user-circle"></i> {{this.mentorName}}</span>
          {{/if}}
          {{#if (eq id ../committedClassId)}}
            <span class="swse-option-card__badge"><i class="fas fa-check"></i> Selected</span>
          {{/if}}
        </div>
      </button>
    {{else}}
      <div class="prog-class-browse__empty">No classes found. Adjust your search or filters.</div>
    {{/each}}
  </div>
</div>
