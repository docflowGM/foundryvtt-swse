{{#if (eq mode "levelup")}}
<div class="prog-summary-surface prog-summary-surface--levelup">
  <div class="prog-panel prog-panel--center prog-panel--summary-preview">
    <h3 class="prog-panel-title">Level-Up Delta</h3>

    {{#if levelupSummary.metadataChanges.length}}
    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header"><span><i class="fas fa-layer-group"></i> Class Progression</span></div>
      <div class="prog-items-list">
        {{#each levelupSummary.metadataChanges}}
          <div class="prog-item-entry"><i class="fas {{#if this.isNew}}fa-plus-circle{{else}}fa-arrow-up{{/if}}"></i> {{this.after}}</div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{#if levelupSummary.statChanges.length}}
    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header"><span><i class="fas fa-chart-line"></i> Derived Changes</span></div>
      <div class="prog-summary-delta-grid">
        {{#each levelupSummary.statChanges}}
          <div class="prog-summary-delta-row">
            <span>{{this.label}}</span>
            <strong>{{this.before}} → {{this.after}}</strong>
          </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{#if levelupSummary.attributeChanges.length}}
    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header"><span><i class="fas fa-dumbbell"></i> Attribute Changes</span></div>
      <div class="prog-summary-delta-grid">
        {{#each levelupSummary.attributeChanges}}
          <div class="prog-summary-delta-row"><span>{{this.label}}</span><strong>{{this.before}} → {{this.after}}</strong></div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header"><span><i class="fas fa-plus-circle"></i> New Picks</span></div>
      <div class="prog-summary-columns">
        <div>
          <h4>Feats</h4>
          {{#if levelupSummary.addedFeats.length}}
            {{#each levelupSummary.addedFeats}}<div class="prog-item-entry"><i class="fas fa-check-circle"></i> {{this}}</div>{{/each}}
          {{else}}<div class="prog-placeholder">None</div>{{/if}}
        </div>
        <div>
          <h4>Talents</h4>
          {{#if levelupSummary.addedTalents.length}}
            {{#each levelupSummary.addedTalents}}<div class="prog-item-entry"><i class="fas fa-check-circle"></i> {{this}}</div>{{/each}}
          {{else}}<div class="prog-placeholder">None</div>{{/if}}
        </div>
        <div>
          <h4>Skills</h4>
          {{#if levelupSummary.addedSkills.length}}
            {{#each levelupSummary.addedSkills}}<div class="prog-item-entry"><i class="fas fa-check-circle"></i> {{this}}</div>{{/each}}
          {{else}}<div class="prog-placeholder">None</div>{{/if}}
        </div>
      </div>
    </div>
  </div>
</div>
{{else}}
<div class="prog-summary-surface prog-summary-surface--chargen">
  <div class="prog-panel prog-panel--center prog-panel--summary-preview">
    <h3 class="prog-panel-title">Character Preview</h3>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header"><span><i class="fas fa-fist-raised"></i> Derived Combat Stats</span></div>
      <div class="prog-combat-grid">
        {{#each summary.combatStats}}
          <div class="prog-combat-stat">
            <span class="prog-combat-stat__label">{{this.label}}</span>
            <span class="prog-combat-stat__value {{this.toneClass}}">{{this.value}}</span>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-chart-bar"></i> Attributes</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="attributes" type="button" aria-label="Edit attributes"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-attributes-grid prog-attributes-grid--summary">
        {{#each summary.attributeSummary}}
          <div class="prog-attr-display prog-attr-display--summary">
            <span class="prog-attr-name">{{this.label}}</span>
            <span class="prog-attr-score">{{this.score}}</span>
            <span class="prog-attr-modifier {{this.toneClass}}">{{this.modifierDisplay}}</span>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-book-open"></i> Skills</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="skills" type="button" aria-label="Edit skills"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-skill-table">
        {{#if summary.skillRows.length}}
          {{#each summary.skillRows}}
            <div class="prog-skill-row {{#if this.trained}}is-trained{{/if}}">
              <span class="prog-skill-row__name">{{this.label}}</span>
              <span class="prog-skill-row__meta">{{this.ability}}{{#if this.trained}} • Trained{{/if}}{{#if this.focused}} • Focus{{/if}}</span>
              <span class="prog-skill-row__total {{this.toneClass}}">{{this.totalDisplay}}</span>
            </div>
          {{/each}}
        {{else}}
          <div class="prog-placeholder">No trained skills selected</div>
        {{/if}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-star"></i> Feats</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="general-feat" type="button" aria-label="Edit feats"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-chip-list">
        {{#if summary.feats.length}}
          {{#each summary.feats}}<span class="prog-chip">{{this}}</span>{{/each}}
        {{else}}<span class="prog-placeholder">No feats selected</span>{{/if}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-gem"></i> Talents</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="class-talent" type="button" aria-label="Edit talents"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-chip-list">
        {{#if summary.talents.length}}
          {{#each summary.talents}}<span class="prog-chip">{{this}}</span>{{/each}}
        {{else}}<span class="prog-placeholder">No talents selected</span>{{/if}}
      </div>
    </div>

    {{#if summary.languages.length}}
    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-language"></i> Languages</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="languages" type="button" aria-label="Edit languages"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-chip-list">
        {{#each summary.languages}}<span class="prog-chip">{{this}}</span>{{/each}}
      </div>
    </div>
    {{/if}}

    {{#if summary.forcePowers.length}}
    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header"><span><i class="fas fa-hand-sparkles"></i> Force Powers</span></div>
      <div class="prog-chip-list">
        {{#each summary.forcePowers}}<span class="prog-chip">{{this}}</span>{{/each}}
      </div>
    </div>
    {{/if}}
  </div>
</div>
{{/if}}
