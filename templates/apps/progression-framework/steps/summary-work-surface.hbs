{{#if (eq mode "levelup")}}
<div class="prog-summary-surface prog-summary-surface--levelup">
  <div class="prog-panel prog-panel--left">
    <h3 class="prog-panel-title">Level-Up Delta</h3>
    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled">
      <div class="prog-section-header"><i class="fas fa-layer-group"></i> Class Progression</div>
      {{#if levelupSummary.metadataChanges.length}}
        <div class="prog-items-list">
          {{#each levelupSummary.metadataChanges}}
            <div class="prog-item-entry">
              <i class="fas {{#if this.isNew}}fa-plus-circle{{else}}
<div class="prog-summary-surface prog-summary-surface--chargen">
  <div class="prog-panel prog-panel--left">
    <h3 class="prog-panel-title">Metadata</h3>

    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-dna"></i> Species</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="species" type="button" aria-label="Edit species"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-summary-line-value">{{#if summary.species}}{{summary.species}}{{else}}<span class="prog-placeholder">Not selected</span>{{/if}}</div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-shield-alt"></i> Class</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="class" type="button" aria-label="Edit class"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-summary-line-value">{{#if summary.class}}{{summary.class}}{{else}}<span class="prog-placeholder">Not selected</span>{{/if}}</div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-book"></i> Background</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="background" type="button" aria-label="Edit background"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-summary-line-value">{{#if summary.background}}{{summary.background}}{{else}}<span class="prog-placeholder">Not selected</span>{{/if}}</div>
    </div>
  </div>

  <div class="prog-panel prog-panel--center">
    <h3 class="prog-panel-title">Character Preview</h3>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-fist-raised"></i> Derived Combat Stats</span>
      </div>
      <div class="prog-combat-grid">
        {{#each summary.combatStats}}
          <div class="prog-combat-stat">
            <span class="prog-combat-stat__label">{{this.label}}</span>
            <span class="prog-combat-stat__value {{this.toneClass}}">{{this.value}}</span>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-chart-bar"></i> Attributes</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="attribute" type="button" aria-label="Edit attributes"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-attributes-grid prog-attributes-grid--summary">
        {{#each summary.attributeSummary}}
          <div class="prog-attr-display prog-attr-display--summary">
            <span class="prog-attr-name">{{this.label}}</span>
            <span class="prog-attr-score">{{this.score}}</span>
            <span class="prog-attr-modifier {{this.toneClass}}">{{this.modifierDisplay}}</span>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-language"></i> Languages</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="languages" type="button" aria-label="Edit languages"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-chip-list">
        {{#if summary.languages.length}}
          {{#each summary.languages}}
            <span class="prog-chip">{{this}}</span>
          {{/each}}
        {{else}}
          <span class="prog-placeholder">No languages selected</span>
        {{/if}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-star"></i> Feats</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="general-feat" type="button" aria-label="Edit feats"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-items-list">
        {{#if summary.feats.length}}
          {{#each summary.feats}}
            <div class="prog-item-entry"><i class="fas fa-check-circle"></i> {{this}}</div>
          {{/each}}
        {{else}}
          <div class="prog-placeholder">No feats selected</div>
        {{/if}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-gem"></i> Talents</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="class-talent" type="button" aria-label="Edit talents"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-items-list">
        {{#if summary.talents.length}}
          {{#each summary.talents}}
            <div class="prog-item-entry"><i class="fas fa-check-circle"></i> {{this}}</div>
          {{/each}}
        {{else}}
          <div class="prog-placeholder">No talents selected</div>
        {{/if}}
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-book-open"></i> Skills</span>
        <button class="summary-step-edit-btn prog-inline-edit-btn" data-step="skills" type="button" aria-label="Edit skills"><i class="fas fa-pencil-alt"></i></button>
      </div>
      <div class="prog-skill-table">
        {{#each summary.skillRows}}
          <div class="prog-skill-row {{#if this.trained}}is-trained{{/if}}">
            <span class="prog-skill-row__name">{{this.label}}</span>
            <span class="prog-skill-row__meta">{{this.ability}}{{#if this.trained}} • Trained{{/if}}{{#if this.focused}} • Focus{{/if}}</span>
            <span class="prog-skill-row__total {{this.toneClass}}">{{this.totalDisplay}}</span>
          </div>
        {{/each}}
      </div>
    </div>

    {{#if summary.forcePowers.length}}
    <div class="prog-summary-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-hand-sparkles"></i> Force Powers</span>
      </div>
      <div class="prog-items-list">
        {{#each summary.forcePowers}}
          <div class="prog-item-entry"><i class="fas fa-check-circle"></i> {{this}}</div>
        {{/each}}
      </div>
    </div>
    {{/if}}
  </div>

  <div class="prog-panel prog-panel--right">
    <h3 class="prog-panel-title">Business Items</h3>

    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-id-card"></i> Name</span>
      </div>
      <div class="prog-name-input-section">
        <label for="summary-name-input" class="prog-input-label">Character Name</label>
        <input
          type="text"
          id="summary-name-input"
          class="summary-step-name-input prog-text-input"
          placeholder="Enter or generate a name..."
          value="{{characterName}}"
        />
        <div class="prog-random-name-buttons">
          <button class="summary-step-random-name-btn prog-btn prog-btn--small" type="button"><i class="fas fa-dice"></i> Generate Name</button>
          <button class="summary-step-random-droid-name-btn prog-btn prog-btn--small" type="button"><i class="fas fa-dice"></i> Droid Name</button>
        </div>
      </div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-heartbeat"></i> HP</span>
      </div>
      <div class="prog-summary-line-value prog-number-positive">{{summary.hpCalculation.total}}</div>
    </div>

    <div class="prog-summary-section swse-card-schema swse-card-schema--identity swse-card-schema--filled prog-summary-card">
      <div class="prog-section-header">
        <span><i class="fas fa-credit-card"></i> Starting Currency</span>
      </div>
      <div class="prog-summary-line-value prog-number-positive">{{summary.startingCredits}}</div>
    </div>

    {{#if issuesSummary}}
    <div class="prog-finalization-status {{#if issuesSummary.isReadyToFinalize}}ready{{else}}incomplete{{/if}}">
      <div class="prog-finalization-header">
        {{#if issuesSummary.isReadyToFinalize}}
          <i class="fas fa-check-circle"></i>
          <span class="prog-status-text">Ready to Create Character</span>
        {{else if issuesSummary.hasErrors}}
          <i class="fas fa-exclamation-circle"></i>
          <span class="prog-status-text">{{issuesSummary.errorCount}} Issue{{#unless (eq issuesSummary.errorCount 1)}}s{{/unless}} to Fix</span>
        {{else}}
          <i class="fas fa-circle-notch"></i>
          <span class="prog-status-text">Incomplete</span>
        {{/if}}
      </div>

      {{#if issuesSummary.hasErrors}}
      <div class="prog-status-errors">
        <div class="prog-status-section-title">Blocking Issues:</div>
        <ul class="prog-issue-list">
          {{#each issuesSummary.errors}}
            <li class="prog-issue-item prog-issue-error"><i class="fas fa-times-circle"></i> {{this}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if issuesSummary.hasCaution}}
      <div class="prog-status-cautions">
        <div class="prog-status-section-title">Review Recommended:</div>
        <ul class="prog-issue-list">
          {{#each issuesSummary.cautions}}
            <li class="prog-issue-item prog-issue-caution"><i class="fas fa-exclamation-triangle"></i> {{this.message}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}
    </div>
    {{/if}}
  </div>
</div>
{{/if}}
