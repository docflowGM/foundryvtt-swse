<div class="prog-attribute-surface">
  <div class="prog-attribute-header">
    <h3 class="prog-attribute-title">Assign Your Attributes</h3>
    <p class="prog-attribute-help">
      Choose your base scores, then species modifiers will be applied automatically.
    </p>
  </div>

  <div class="prog-attribute-method-selector">
    <label class="prog-attribute-method-label">Method:</label>
    <div class="prog-attribute-method-buttons">
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "point-buy")}}active{{/if}}" data-method="point-buy" type="button">
        <i class="fas fa-coins"></i> Point Buy
      </button>
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "array")}}active{{/if}}" data-method="array" type="button">
        <i class="fas fa-th-large"></i> Array
      </button>
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "standard")}}active{{/if}}" data-method="standard" type="button">
        <i class="fas fa-dice-d6"></i> Standard
      </button>
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "organic")}}active{{/if}}" data-method="organic" type="button">
        <i class="fas fa-dice"></i> Organic
      </button>
    </div>
  </div>

  {{#if showArrayTypeSelector}}
    <div class="prog-attribute-submethod-selector">
      <button class="prog-btn prog-btn--submethod attr-array-type-btn {{#if (eq arrayType "standard")}}active{{/if}}" data-array-type="standard" type="button">
        Standard Array
      </button>
      <button class="prog-btn prog-btn--submethod attr-array-type-btn {{#if (eq arrayType "highPower")}}active{{/if}}" data-array-type="highPower" type="button">
        High Power Array
      </button>
    </div>
  {{/if}}

  <div class="prog-attribute-toolbar">
    <div class="prog-attribute-toolbar__status">
      {{currentMethodDescription}}
      {{#if poolInstruction}}
        <div class="prog-attribute-toolbar__hint">{{poolInstruction}}</div>
      {{/if}}
    </div>
    <div class="prog-attribute-toolbar__actions">
      <button class="prog-btn prog-btn--secondary" data-attr-reroll type="button">
        <i class="fas fa-rotate-right"></i> {{rerollButtonLabel}}
      </button>
      <button class="prog-btn prog-btn--secondary" data-attr-auto-assign type="button">
        <i class="fas fa-wand-magic-sparkles"></i> Auto Assign
      </button>
      <button class="prog-btn prog-btn--primary" data-attr-lock type="button">
        <i class="fas fa-lock"></i> {{lockButtonLabel}}
      </button>
    </div>
  </div>

  {{#if showPointBuy}}
    <div class="prog-attribute-pointbuy-status {{#if pointBuyStatus.isComplete}}prog-attribute-pointbuy--complete{{/if}}">
      <div class="prog-attribute-pointbuy-bar">
        <div class="prog-attribute-pointbuy-used" style="width: {{pointBuyStatus.percent}}%"></div>
      </div>
      <div class="prog-attribute-pointbuy-text">
        {{pointBuyStatus.spent}} / {{pointBuyPool}} points allocated — {{pointBuyStatus.status}}
      </div>
    </div>
  {{/if}}

  {{#if showGeneratedPool}}
    <div class="prog-attribute-pool-panel">
      <div class="prog-attribute-pool-panel__header">
        <div>
          <h4>{{#if (eq method "organic")}}Organic Dice Pool{{else}}Generated Results{{/if}}</h4>
          <p>
            {{#if remainingPoolAssignments}}
              {{remainingPoolAssignments}} attributes still need a result.
            {{else}}
              All generated results are placed. You can still reassign them before locking.
            {{/if}}
          </p>
        </div>
      </div>
      <div class="prog-attribute-tile-grid {{#if (eq method "organic")}}prog-attribute-tile-grid--organic{{/if}}">
        {{#each scorePool}}
          <button
            class="prog-attribute-tile {{#if isSelected}}is-focused{{/if}} {{#if isUsed}}is-assigned{{/if}}"
            data-score-pool-id="{{id}}"
            draggable="{{#if isDraggable}}true{{else}}false{{/if}}"
            type="button"
          >
            <span class="prog-attribute-tile__value">{{value}}</span>
            <span class="prog-attribute-tile__label">{{assignedLabel}}</span>
          </button>
        {{/each}}
      </div>
    </div>
  {{/if}}

  <div class="prog-attribute-rows">
    {{#each abilities}}
      <div class="prog-attribute-row {{#if isFocused}}prog-attribute-row--focused{{/if}} {{#if isUnassigned}}prog-attribute-row--pending{{/if}}" data-ability-row="{{id}}" role="button" tabindex="0">
        <div class="prog-attribute-row__header">
          <div>
            <div class="prog-attribute-row__label">{{label}}</div>
            {{#if assignmentHint}}
              <div class="prog-attribute-row__subtext">{{assignmentHint}}</div>
            {{/if}}
          </div>
          <div class="prog-attribute-row__header-actions">
            {{#if showClear}}
              <button class="prog-attribute-row__clear" data-clear-ability="{{id}}" type="button" aria-label="Clear {{label}} assignment">
                <i class="fas fa-rotate-left"></i>
              </button>
            {{/if}}
          </div>
        </div>

        {{#if assignedValues.length}}
          <div class="prog-attribute-row__assignments">
            {{#each assignedValues}}
              <span class="prog-attribute-assignment-chip">{{this}}</span>
            {{/each}}
            {{#if (lt assignedValues.length assignmentCapacity)}}
              <span class="prog-attribute-assignment-chip prog-attribute-assignment-chip--empty">+ drag more</span>
            {{/if}}
          </div>
        {{/if}}

        <div class="prog-attribute-row__stats">
          <div class="prog-attribute-stat">
            <span class="prog-attribute-stat__label">Base</span>
            <span class="prog-attribute-stat__value">{{baseDisplay}}</span>
          </div>
          <div class="prog-attribute-stat">
            <span class="prog-attribute-stat__label">Species</span>
            <span class="prog-attribute-stat__value {{speciesModClass}}">
              {{#if (gt speciesMod 0)}}+{{/if}}{{speciesMod}}
            </span>
          </div>
          <div class="prog-attribute-stat">
            <span class="prog-attribute-stat__label">Final</span>
            <span class="prog-attribute-stat__value prog-attribute-stat__value--final">{{finalDisplay}}</span>
          </div>
          <div class="prog-attribute-stat">
            <span class="prog-attribute-stat__label">Mod</span>
            <span class="prog-attribute-stat__value {{modClass}}">{{modifierFormatted}}</span>
          </div>
        </div>

        {{#if canAdjust}}
          <div class="prog-attribute-row__pointbuy">
            <button class="prog-attribute-btn prog-attribute-btn--minus" data-ability="{{id}}" data-delta="-1" type="button">−</button>
            <button class="prog-attribute-btn prog-attribute-btn--plus" data-ability="{{id}}" data-delta="1" type="button">+</button>
          </div>
        {{/if}}
      </div>
    {{/each}}
  </div>
</div>
