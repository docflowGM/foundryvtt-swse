<div class="prog-attribute-surface">

  <div class="prog-attribute-header">
    <h3 class="prog-attribute-title">Assign Your Attributes</h3>
    <p class="prog-attribute-help">
      Choose your base scores, then species modifiers will be applied automatically.
    </p>
  </div>

  <div class="prog-attribute-method-selector">
    <label class="prog-attribute-method-label">Method:</label>
    <div class="prog-attribute-method-buttons">
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "point-buy")}}active{{/if}}"
              data-method="point-buy"
              type="button"
              title="Point buy: spend points to raise scores from 8">
        <i class="fas fa-coins"></i> Point Buy
      </button>
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "array")}}active{{/if}}"
              data-method="array"
              type="button"
              title="Canonical standard array: 15, 14, 13, 12, 10, 8">
        <i class="fas fa-layer-group"></i> Array
      </button>
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "high-power")}}active{{/if}}"
              data-method="high-power"
              type="button"
              title="High Power array: 16, 14, 12, 10, 10, 8">
        <i class="fas fa-bolt"></i> High Power
      </button>
      <button class="prog-btn prog-btn--method attr-method-btn {{#if (eq method "organic")}}active{{/if}}"
              data-method="organic"
              type="button"
              title="Organic: legacy 21d6 drop lowest 3 pool">
        <i class="fas fa-dice"></i> Organic
      </button>
    </div>
  </div>

  {{#if isPointBuy}}
    <div class="prog-attribute-pointbuy-status {{#if pointBuyStatus.isComplete}}prog-attribute-pointbuy-status--complete{{/if}}">
      <div class="prog-attribute-pointbuy-bar">
        <div class="prog-attribute-pointbuy-used" style="width: {{div pointBuyStatus.spent pointBuyStatus.total 100}}%"></div>
      </div>
      <div class="prog-attribute-pointbuy-text">
        {{pointBuyStatus.spent}}/{{pointBuyStatus.total}} points allocated — {{pointBuyStatus.status}}
      </div>
    </div>
  {{/if}}

  {{#if isPoolMethod}}
    <div class="prog-attribute-pool-panel">
      <div class="prog-attribute-pool-header">
        <div class="prog-attribute-pool-title">{{methodLabel}} Pool</div>
        <div class="prog-attribute-pool-help">{{poolInstruction}}</div>
      </div>
      <div class="prog-attribute-pool {{#unless hasAvailablePool}}prog-attribute-pool--empty{{/unless}}" data-pool-dropzone="true">
        {{#if hasAvailablePool}}
          {{#each availablePool}}
            <div class="prog-attribute-pool-tile"
                 role="button"
                 tabindex="0"
                 draggable="true"
                 data-pool-id="{{id}}"
                 title="{{tooltip}}">
              <span class="prog-attribute-pool-tile__value">{{value}}</span>
              <span class="prog-attribute-pool-tile__origin">{{origin}}</span>
            </div>
          {{/each}}
        {{else}}
          <div class="prog-attribute-pool-empty">{{poolEmptyText}}</div>
        {{/if}}
      </div>
    </div>
  {{/if}}

  <div class="prog-attribute-rows">
    {{#each abilities}}
      <div class="prog-attribute-row {{#if isFocused}}prog-attribute-row--focused{{/if}} {{#if isSuggested}}prog-attribute-row--suggested prog-attribute-row--suggested-{{confidenceLevel}}{{/if}}"
           data-ability-row="{{id}}"
           data-recommended="{{#if isSuggested}}true{{/if}}"
           data-confidence-level="{{confidenceLevel}}"
           role="button"
           tabindex="0">

        <div class="prog-attribute-row__label">
          {{label}}
          {{#if badgeLabel}}
            <span class="swse-option-card__badge swse-option-card__badge--recommended">{{badgeLabel}}</span>
          {{/if}}
        </div>

        <div class="prog-attribute-row__score prog-attribute-row__base">
          {{#if canAdjust}}
            <button class="prog-attribute-btn prog-attribute-btn--minus"
                    data-ability="{{id}}"
                    data-delta="-1"
                    type="button"
                    {{#unless canDecrement}}disabled{{/unless}}>−</button>
            <span class="prog-attribute-value">{{base}}</span>
            <div class="prog-attribute-increment-info">
              <button class="prog-attribute-btn prog-attribute-btn--plus"
                      data-ability="{{id}}"
                      data-delta="1"
                      type="button"
                      {{#unless canIncrement}}disabled{{/unless}}>+</button>
              {{#if nextIncrementCost}}
                <span class="prog-attribute-cost {{#unless canAffordNext}}prog-attribute-cost--unaffordable{{/unless}}">+ costs {{nextIncrementCost}}</span>
              {{/if}}
            </div>
          {{else}}
            <div class="prog-attribute-assignment-box {{#if assigned}}prog-attribute-assignment-box--assigned{{/if}} {{#if isFocused}}prog-attribute-assignment-box--focused{{/if}}"
                 data-assign-ability="{{id}}">
              {{#if assigned}}
                <div class="prog-attribute-assigned-tile"
                     draggable="true"
                     data-assigned-tile-id="{{assignedTileId}}"
                     title="Drag to another ability or back to the pool">
                  <span class="prog-attribute-value">{{baseDisplay}}</span>
                  {{#if assignedOrigin}}
                    <span class="prog-attribute-assigned-tile__origin">{{assignedOrigin}}</span>
                  {{/if}}
                </div>
                <button class="prog-attribute-clear"
                        type="button"
                        data-clear-ability="{{id}}"
                        title="Return value to pool">×</button>
              {{else}}
                <span class="prog-attribute-assignment-placeholder">drop value here</span>
              {{/if}}
            </div>
          {{/if}}
        </div>

        <div class="prog-attribute-row__score prog-attribute-row__species">
          <span class="prog-attribute-value {{speciesModClass}}">{{speciesModDisplay}}</span>
        </div>

        <div class="prog-attribute-row__score prog-attribute-row__final">
          <span class="prog-attribute-value prog-attribute-value--final">{{finalDisplay}}</span>
        </div>

        <div class="prog-attribute-row__score prog-attribute-row__modifier">
          <span class="prog-attribute-value {{modClass}}">{{modifierFormatted}}</span>
        </div>
      </div>
    {{/each}}
  </div>

  <div class="prog-attribute-headers">
    <div class="prog-attribute-headers__label"></div>
    <div class="prog-attribute-headers__base">Base</div>
    <div class="prog-attribute-headers__species">Species</div>
    <div class="prog-attribute-headers__final">Final</div>
    <div class="prog-attribute-headers__modifier">Mod</div>
  </div>

</div>
