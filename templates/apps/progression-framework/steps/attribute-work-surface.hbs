<div class="prog-attribute-surface prog-attribute-surface--v2 {{#if isCommitted}}is-locked{{/if}}" data-attribute-method="{{method}}">
  <header class="prog-attr-v2-header">
    <div class="prog-attr-v2-stepnum">{{#if attributeIncreaseMode}}LV{{else}}03{{/if}}</div>
    <div class="prog-attr-v2-titleblock">
      <h3>{{#if attributeIncreaseMode}}Ability Increase Calibration{{else}}Ability Calibration{{/if}}</h3>
      <p>{{stepSubtitle}}</p>
    </div>
    <div class="prog-attr-v2-status-chip {{lockButtonTone}}">
      <i class="fas {{lockButtonIcon}}"></i>
      <span>{{#if isCommitted}}Locked{{else}}Unlocked{{/if}}</span>
    </div>
  </header>

  {{#if showMethodSelector}}
    <div class="prog-attr-v2-methods" role="tablist" aria-label="Attribute generation method">
      {{#each methodCards}}
        <button class="prog-attr-v2-method attr-method-btn {{#if isActive}}active{{/if}}" data-method="{{id}}" type="button" role="tab" aria-selected="{{#if isActive}}true{{else}}false{{/if}}" {{#if disabled}}disabled{{/if}}>
          <i class="fas {{icon}}"></i>
          <span class="label">{{label}}</span>
          <span class="sub">{{sub}}</span>
        </button>
      {{/each}}
    </div>
  {{/if}}

  {{#if showArrayTypeSelector}}
    <div class="prog-attr-v2-array-toggle">
      <button class="attr-array-type-btn {{#if (eq arrayType "standard")}}active{{/if}}" data-array-type="standard" type="button">Standard Array</button>
      <button class="attr-array-type-btn {{#if (eq arrayType "highPower")}}active{{/if}}" data-array-type="highPower" type="button">High Power Array</button>
    </div>
  {{/if}}

  {{#if isSpeciesFixed}}
    <section class="prog-attr-v2-alert">
      <strong>{{attributeOverride.label}}</strong>
      <span>{{attributeOverride.helpText}}</span>
      {{#if speciesFixedAllocation}}
        <em>{{speciesFixedAllocation.spent}} / {{speciesFixedAllocation.total}} clone increases allocated{{#if speciesFixedAllocation.remaining}} · {{speciesFixedAllocation.remaining}} remaining{{/if}}</em>
      {{/if}}
    </section>
  {{/if}}

  <div class="prog-attr-v2-layout">
    <main class="prog-attr-v2-board">
      {{#if hasGeneratedPool}}
        <section class="prog-attr-v2-pool">
          <div class="prog-attr-v2-pool-head">
            <div>
              <span>{{#if (eq method "organic")}}Organic Dice Pool{{else}}Generated Results{{/if}}</span>
              <p>{{poolInstruction}}</p>
            </div>
            <div class="prog-attr-v2-pool-meter">
              <b>{{poolAssigned}}</b><small>/ {{poolTotal}} placed</small>
            </div>
          </div>
          <div class="prog-attr-v2-pool-grid {{#if (eq method "organic")}}is-organic{{/if}}">
            {{#each scorePool}}
              <button class="prog-attr-v2-pool-chip {{#if isSelected}}is-focused{{/if}} {{#if isUsed}}is-assigned{{/if}}" data-score-pool-id="{{id}}" draggable="{{#if isDraggable}}true{{else}}false{{/if}}" type="button">
                <span>{{value}}</span>
                <em>{{assignedLabel}}</em>
              </button>
            {{/each}}
          </div>
        </section>
      {{/if}}

      <section class="prog-attr-v2-cluster">
        <div class="prog-attr-v2-cluster-head">
          <span class="ico">◈</span>
          <span>Physical Series</span>
          <em>STR · DEX · CON</em>
        </div>
        <div class="prog-attr-v2-cells">
          {{#each physicalAbilities}}
            <article class="prog-attr-v2-cell attr-v2--{{colorClass}} {{#if isFocused}}is-focused{{/if}} {{#if isUnassigned}}is-pending{{/if}} {{#if isExcluded}}is-excluded{{/if}}" data-ability-row="{{id}}" data-ability="{{id}}" role="button" tabindex="0">
              <div class="prog-attr-v2-cell-code">{{label}}<span>{{fullName}}</span></div>
              <div class="prog-attr-v2-mod {{modTone}}">{{modifierFormatted}}</div>
              <div class="prog-attr-v2-value-row">
                {{#if canAdjust}}
                  <button class="prog-attr-v2-stepper minus" data-ability="{{id}}" data-delta="-1" type="button" {{#unless canDecrease}}disabled aria-disabled="true"{{/unless}}>−</button>
                {{else}}
                  <span class="prog-attr-v2-stepper ghost"></span>
                {{/if}}
                <div class="prog-attr-v2-score {{valueTone}}">{{finalDisplay}}</div>
                {{#if canAdjust}}
                  <button class="prog-attr-v2-stepper plus" data-ability="{{id}}" data-delta="1" type="button" {{#unless canIncrease}}disabled aria-disabled="true"{{/unless}}>+</button>
                {{else}}
                  <span class="prog-attr-v2-stepper ghost"></span>
                {{/if}}
              </div>
              <div class="prog-attr-v2-math">
                <span><b>{{baseDisplay}}</b> base</span>
                <span class="species {{speciesModClass}}">{{#if (gt speciesMod 0)}}+{{/if}}{{speciesMod}} {{#if ../secondColumnLabel}}{{../secondColumnLabel}}{{else}}species{{/if}}</span>
                {{#if costLabel}}<span class="cost">{{costLabel}}</span>{{/if}}
              </div>
              {{#if assignedPoolItems.length}}
                <div class="prog-attr-v2-assigned">
                  {{#each assignedPoolItems}}
                    <button class="prog-attr-v2-assigned-chip {{#if isSelected}}is-focused{{/if}}" data-score-pool-id="{{id}}" type="button">{{value}}</button>
                  {{/each}}
                  {{#if showClear}}
                    <button class="prog-attr-v2-clear" data-clear-ability="{{id}}" type="button" aria-label="Clear {{label}} assignment"><i class="fas fa-rotate-left"></i></button>
                  {{/if}}
                </div>
              {{else}}
                {{#if assignmentHint}}<div class="prog-attr-v2-hint">{{assignmentHint}}</div>{{/if}}
              {{/if}}
            </article>
          {{/each}}
        </div>
      </section>

      <section class="prog-attr-v2-cluster">
        <div class="prog-attr-v2-cluster-head">
          <span class="ico">◇</span>
          <span>Mental Series</span>
          <em>INT · WIS · CHA</em>
        </div>
        <div class="prog-attr-v2-cells">
          {{#each mentalAbilities}}
            <article class="prog-attr-v2-cell attr-v2--{{colorClass}} {{#if isFocused}}is-focused{{/if}} {{#if isUnassigned}}is-pending{{/if}} {{#if isExcluded}}is-excluded{{/if}}" data-ability-row="{{id}}" data-ability="{{id}}" role="button" tabindex="0">
              <div class="prog-attr-v2-cell-code">{{label}}<span>{{fullName}}</span></div>
              <div class="prog-attr-v2-mod {{modTone}}">{{modifierFormatted}}</div>
              <div class="prog-attr-v2-value-row">
                {{#if canAdjust}}
                  <button class="prog-attr-v2-stepper minus" data-ability="{{id}}" data-delta="-1" type="button" {{#unless canDecrease}}disabled aria-disabled="true"{{/unless}}>−</button>
                {{else}}
                  <span class="prog-attr-v2-stepper ghost"></span>
                {{/if}}
                <div class="prog-attr-v2-score {{valueTone}}">{{finalDisplay}}</div>
                {{#if canAdjust}}
                  <button class="prog-attr-v2-stepper plus" data-ability="{{id}}" data-delta="1" type="button" {{#unless canIncrease}}disabled aria-disabled="true"{{/unless}}>+</button>
                {{else}}
                  <span class="prog-attr-v2-stepper ghost"></span>
                {{/if}}
              </div>
              <div class="prog-attr-v2-math">
                <span><b>{{baseDisplay}}</b> base</span>
                <span class="species {{speciesModClass}}">{{#if (gt speciesMod 0)}}+{{/if}}{{speciesMod}} {{#if ../secondColumnLabel}}{{../secondColumnLabel}}{{else}}species{{/if}}</span>
                {{#if costLabel}}<span class="cost">{{costLabel}}</span>{{/if}}
              </div>
              {{#if assignedPoolItems.length}}
                <div class="prog-attr-v2-assigned">
                  {{#each assignedPoolItems}}
                    <button class="prog-attr-v2-assigned-chip {{#if isSelected}}is-focused{{/if}}" data-score-pool-id="{{id}}" type="button">{{value}}</button>
                  {{/each}}
                  {{#if showClear}}
                    <button class="prog-attr-v2-clear" data-clear-ability="{{id}}" type="button" aria-label="Clear {{label}} assignment"><i class="fas fa-rotate-left"></i></button>
                  {{/if}}
                </div>
              {{else}}
                {{#if assignmentHint}}<div class="prog-attr-v2-hint">{{assignmentHint}}</div>{{/if}}
              {{/if}}
            </article>
          {{/each}}
        </div>
      </section>
    </main>

    <aside class="prog-attr-v2-rail">
      <div class="prog-attr-v2-rail-head">◆ Live Derivations</div>
      <div class="prog-attr-v2-derived-grid">
        {{#each derivedStats}}
          <div class="prog-attr-v2-derived">
            <span>{{label}}</span>
            <b class="{{tone}}">{{value}}</b>
            <em>{{source}}</em>
          </div>
        {{/each}}
      </div>

      {{#if focusedAbility}}
        <section class="prog-attr-v2-detail attr-v2--{{focusedAbility.colorClass}}">
          <div class="prog-attr-v2-detail-kicker">Selected Attribute</div>
          <h4>{{focusedAbility.fullName}} <span>{{focusedAbility.label}}</span></h4>
          <p>{{focusedAbility.detail}}</p>
          <div class="prog-attr-v2-detail-row"><span>Base</span><b>{{focusedAbility.baseDisplay}}</b></div>
          <div class="prog-attr-v2-detail-row"><span>Final</span><b>{{focusedAbility.finalDisplay}}</b></div>
          <div class="prog-attr-v2-detail-row"><span>Modifier</span><b>{{focusedAbility.modifierFormatted}}</b></div>
          {{#if focusedAbility.assignmentHint}}<div class="prog-attr-v2-detail-note">{{focusedAbility.assignmentHint}}</div>{{/if}}
        </section>
      {{/if}}

      <section class="prog-attr-v2-advice">
        <span>◉ Vocation Read</span>
        <p>{{currentMethodDescription}}</p>
      </section>
    </aside>
  </div>

  <footer class="prog-attr-v2-dock">
    <div class="prog-attr-v2-meter">
      {{#if showPointBuy}}
        <div class="prog-attr-v2-meter-label"><span>Point Budget</span><b>{{pointBuyStatus.spent}} / {{pointBuyPool}}</b></div>
        <div class="prog-attr-v2-meter-bar"><i style="width: {{pointBuyStatus.percent}}%"></i></div>
        <em>{{pointBuyStatus.status}}</em>
      {{else}}
        <div class="prog-attr-v2-meter-label"><span>{{methodCopy.label}}</span><b>{{#if hasGeneratedPool}}{{poolAssigned}} / {{poolTotal}}{{else}}{{#if attributeIncreaseMode}}{{pointBuyStatus.spent}}{{else}}{{methodCopy.sub}}{{/if}}{{/if}}</b></div>
        <div class="prog-attr-v2-meter-bar"><i style="width: {{#if hasGeneratedPool}}{{poolPercent}}{{else}}{{#if pointBuyStatus.percent}}{{pointBuyStatus.percent}}{{else}}100{{/if}}{{/if}}%"></i></div>
        <em>{{poolInstruction}}</em>
      {{/if}}
    </div>

    <div class="prog-attr-v2-actions">
      {{#if showUtilityActions}}{{#unless isSpeciesFixed}}
        <button class="prog-attr-v2-btn" data-attr-reroll type="button"><i class="fas fa-rotate-right"></i>{{rerollButtonLabel}}</button>
        <button class="prog-attr-v2-btn" data-attr-auto-assign type="button"><i class="fas fa-wand-magic-sparkles"></i>Auto Assign</button>
      {{/unless}}{{/if}}
      {{#if showSpeciesFixedOverride}}
        <button class="prog-attr-v2-btn warn" data-action="attribute-override-species-fixed" type="button"><i class="fas fa-user-shield"></i>Override</button>
      {{/if}}
      <button class="prog-attr-v2-btn primary {{lockButtonTone}}" data-action="attribute-lock" type="button"><i class="fas {{lockButtonIcon}}"></i>{{lockButtonLabel}}</button>
    </div>
  </footer>
</div>
