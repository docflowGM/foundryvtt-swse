{{!-- Force Power Selection Work Surface --}}
{{!-- Feat-step-style browser for Force Powers and Lightsaber Form Powers. --}}

<div class="prog-force-power-browse swse-force-selector swse-store-stage">
  {{#if noNewPowerChoices}}
    <section class="prog-force-power-no-choice-banner" aria-label="No new Force Power choices">
      <i class="fas fa-forward-step" aria-hidden="true"></i>
      <div>
        <strong>No new Force Power choices</strong>
        <p>{{noNewPowerChoicesMessage}}</p>
      </div>
    </section>
  {{/if}}

  {{#if hasTrainingSummary}}
    <section class="prog-force-power-training-summary" aria-label="Force Power training allowance">
      <div class="prog-force-power-training-summary__main">
        <span class="prog-force-power-training-summary__label">Force Power Training</span>
        <strong class="prog-force-power-training-summary__count">{{selectedPowerTraining}} / {{selectionBudget}}</strong>
        <span class="prog-force-power-training-summary__remaining">{{remainingPicks}} remaining</span>
        {{#if removedPowerCount}}
          <span class="prog-force-power-training-summary__remaining">{{removedPowerCount}} replacement slot(s)</span>
        {{/if}}
      </div>
      {{#if entitlementReasons.length}}
        <ul class="prog-force-power-training-summary__reasons">
          {{#each entitlementReasons}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}
    </section>
  {{/if}}

  <div class="feat-browser-toolbar force-power-browser-toolbar">
    <div class="feat-browser-toolbar__left">
      {{#if hasSearchQuery}}
        <span class="feat-browser-mode-pill feat-browser-mode-pill--search">
          <i class="fa-solid fa-magnifying-glass"></i>
          Search: {{searchQueryLabel}}
        </span>
      {{else}}
        <span class="feat-browser-mode-pill">
          <i class="fa-solid {{activeCategoryIcon}}"></i>
          {{activeCategoryLabel}}
        </span>
      {{/if}}
    </div>

    <div class="feat-browser-toolbar__right">
      <button class="feat-filter-btn" data-action="reset-force-power-browser" type="button" title="Clear search and filters">
        <i class="fa-solid fa-rotate-left"></i>
        <span>Reset</span>
      </button>
      {{#unless hasSearchQuery}}
        <button class="feat-filter-btn feat-category-collapse-toggle" data-action="toggle-force-power-category-sidebar" type="button">
          <i class="fa-solid {{#if categorySidebarCollapsed}}fa-angles-right{{else}}fa-angles-left{{/if}}"></i>
          <span>{{#if categorySidebarCollapsed}}Show Categories{{else}}Collapse Categories{{/if}}</span>
        </button>
      {{/unless}}
    </div>
  </div>

  <section class="feat-browser force-power-browser {{#if categorySidebarCollapsed}}feat-browser--sidebar-collapsed{{/if}} {{#if hasSearchQuery}}feat-browser--search-mode{{/if}}">
    {{#unless hasSearchQuery}}
      {{#unless categorySidebarCollapsed}}
        <aside class="feat-category-sidebar force-power-category-sidebar" aria-label="Force Power categories">
          <div class="feat-category-sidebar__header">
            <span>Categories</span>
            <button class="feat-category-sidebar__collapse" data-action="toggle-force-power-category-sidebar" type="button" title="Collapse categories">
              <i class="fa-solid fa-chevron-left"></i>
            </button>
          </div>
          <div class="feat-category-list force-power-category-list">
            {{#each categoryOptions as |category|}}
              <button class="feat-category-button force-power-category-button {{#if category.isActive}}active{{/if}} {{#if category.isMajor}}force-power-category-button--major{{/if}} {{#if category.isSubcategory}}force-power-category-button--sub{{/if}}"
                      data-action="select-force-power-category"
                      data-category="{{category.key}}"
                      type="button">
                <span class="feat-category-button__main">
                  <i class="fa-solid {{category.icon}}"></i>
                  <span>{{category.label}}</span>
                </span>
                <span class="feat-category-button__count">{{category.totalCount}}</span>
              </button>
            {{/each}}
          </div>
        </aside>
      {{/unless}}
    {{/unless}}

    <main class="feat-results-pane force-power-results-pane">
      {{#if hasSearchQuery}}
        <header class="feat-results-pane__header feat-results-pane__header--search">
          <div>
            <h3><i class="fa-solid fa-magnifying-glass"></i> Search Results</h3>
            <p>Matching Force Powers and Lightsaber Form Powers.</p>
          </div>
          <span class="feat-count-badge">{{searchResultCount}}</span>
        </header>

        {{#if searchResults.length}}
          <div class="feat-compact-list feat-search-results-list force-power-compact-list">
            {{#each searchResults as |power|}}
              <div class="feat-compact-row force-power-compact-row {{#if power.isFocused}}focused{{/if}} {{#if power.isSelected}}selected{{/if}} {{#if power.isSuggested}}suggested{{/if}}"
       data-power-id="{{power.stateId}}"
       data-item-id="{{power.stateId}}"
       data-action="focus-item"
       tabindex="0"
       role="option">
    <div class="feat-compact-row__content">
      <div class="feat-compact-row__line feat-compact-row__line--primary">
        <span class="feat-name">{{power.name}}</span>
        {{#if power.shortSummary}}<span class="feat-quick-summary">{{truncate power.shortSummary 120}}</span>{{/if}}
      </div>
      <div class="feat-compact-row__line feat-compact-row__line--meta">
        <span class="feat-subcategory-pill">{{power.searchCategoryLabel}}</span>
        {{#if power.prerequisiteText}}<span class="feat-prereq-line"><i class="fa-solid fa-link"></i> {{power.prerequisiteText}}</span>{{/if}}
        {{#if power.isSuggested}}<span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Recommended</span>{{/if}}
        {{#with (lookup ../cardStates power.stateId)}}
          {{#if isCommitted}}<span class="feat-owned-pill">Known {{effectiveOwnedCount}}</span>{{/if}}
          {{#if isPending}}<span class="feat-owned-pill">Pending {{pendingCount}}</span>{{/if}}
          {{#if isRemoved}}<span class="feat-unavail-badge"><i class="fa-solid fa-rotate-left"></i> Reselecting {{removedCount}}</span>{{/if}}
        {{/with}}
      </div>
    </div>
    <div class="force-power-compact-row__controls">
      {{#with (lookup ../cardStates power.stateId)}}
        <button class="prog-quantity-btn prog-quantity-btn--decrement"
                data-action="decrement-quantity"
                data-item-id="{{powerId}}"
                type="button"
                aria-label="Remove one selection"
                title="Remove"
                {{#unless canDecrement}}disabled{{/unless}}>
          <i class="fas fa-minus" aria-hidden="true"></i>
        </button>
        <span class="prog-quantity-display">{{totalCount}}</span>
        <button class="prog-quantity-btn prog-quantity-btn--increment"
                data-action="increment-quantity"
                data-item-id="{{powerId}}"
                type="button"
                aria-label="Add one more"
                title="Add"
                {{#unless canIncrement}}disabled{{/unless}}>
          <i class="fas fa-plus" aria-hidden="true"></i>
        </button>
      {{else}}
        <i class="fa-solid fa-chevron-right"></i>
      {{/with}}
    </div>
  </div>
            {{/each}}
          </div>
        {{else}}
          <div class="feat-search-empty">
            <i class="fa-solid fa-radar"></i>
            <span>No Force Powers match “{{searchQueryLabel}}”.</span>
            <span class="feat-search-empty__hint">Try a power name, descriptor, form, or keyword.</span>
          </div>
        {{/if}}
      {{else}}
        <header class="feat-results-pane__header">
          <div>
            <h3><i class="fa-solid {{activeCategoryIcon}}"></i> {{activeCategoryLabel}}</h3>
            <p>Select a power to inspect it. Use + / − to add or remove selections.</p>
          </div>
          <span class="feat-count-badge">{{activeCategoryCount}}</span>
        </header>

        {{#if activeCategoryPowers.length}}
          <div class="feat-compact-list force-power-compact-list">
            {{#each activeCategoryPowers as |power|}}
              <div class="feat-compact-row force-power-compact-row {{#if power.isFocused}}focused{{/if}} {{#if power.isSelected}}selected{{/if}} {{#if power.isSuggested}}suggested{{/if}}"
       data-power-id="{{power.stateId}}"
       data-item-id="{{power.stateId}}"
       data-action="focus-item"
       tabindex="0"
       role="option">
    <div class="feat-compact-row__content">
      <div class="feat-compact-row__line feat-compact-row__line--primary">
        <span class="feat-name">{{power.name}}</span>
        {{#if power.shortSummary}}<span class="feat-quick-summary">{{truncate power.shortSummary 120}}</span>{{/if}}
      </div>
      <div class="feat-compact-row__line feat-compact-row__line--meta">
        <span class="feat-subcategory-pill">{{power.searchCategoryLabel}}</span>
        {{#if power.prerequisiteText}}<span class="feat-prereq-line"><i class="fa-solid fa-link"></i> {{power.prerequisiteText}}</span>{{/if}}
        {{#if power.isSuggested}}<span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Recommended</span>{{/if}}
        {{#with (lookup ../cardStates power.stateId)}}
          {{#if isCommitted}}<span class="feat-owned-pill">Known {{effectiveOwnedCount}}</span>{{/if}}
          {{#if isPending}}<span class="feat-owned-pill">Pending {{pendingCount}}</span>{{/if}}
          {{#if isRemoved}}<span class="feat-unavail-badge"><i class="fa-solid fa-rotate-left"></i> Reselecting {{removedCount}}</span>{{/if}}
        {{/with}}
      </div>
    </div>
    <div class="force-power-compact-row__controls">
      {{#with (lookup ../cardStates power.stateId)}}
        <button class="prog-quantity-btn prog-quantity-btn--decrement"
                data-action="decrement-quantity"
                data-item-id="{{powerId}}"
                type="button"
                aria-label="Remove one selection"
                title="Remove"
                {{#unless canDecrement}}disabled{{/unless}}>
          <i class="fas fa-minus" aria-hidden="true"></i>
        </button>
        <span class="prog-quantity-display">{{totalCount}}</span>
        <button class="prog-quantity-btn prog-quantity-btn--increment"
                data-action="increment-quantity"
                data-item-id="{{powerId}}"
                type="button"
                aria-label="Add one more"
                title="Add"
                {{#unless canIncrement}}disabled{{/unless}}>
          <i class="fas fa-plus" aria-hidden="true"></i>
        </button>
      {{else}}
        <i class="fa-solid fa-chevron-right"></i>
      {{/with}}
    </div>
  </div>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-message feat-browser-empty prog-force-power-browse__empty">
            <i class="fas fa-hand-sparkles" aria-hidden="true"></i>
            <p>No Force Powers are available in this category.</p>
          </div>
        {{/if}}
      {{/if}}
    </main>
  </section>
</div>
