{{!-- Force Power Selection Work Surface --}}
{{!-- Shows browsable force power cards with counts for duplicate selections --}}

<div class="prog-force-power-browse swse-force-selector swse-store-stage">
  {{#if powers.length}}
    <div class="prog-force-power-grid" role="list">
      {{#each powers}}
        <div class="prog-force-power-card
                    {{#if (arrayIncludes ../committedCounts @key)}}prog-force-power-card--selected{{/if}}
                    {{#if this.isSuggested}}prog-power-card--suggested prog-power-card--suggested-{{this.confidenceLevel}}{{/if}}"
             data-action="focus-item"
             data-item-id="{{this.id}}"
             data-recommended="{{#if this.isSuggested}}true{{/if}}"
             data-confidence-level="{{this.confidenceLevel}}"
             tabindex="0" role="option"
             aria-selected="{{#if (arrayIncludes ../committedCounts @key)}}true{{else}}false{{/if}}">

          {{!-- Force power holographic image slot (Phase 7) --}}
          {{#if this.img}}
            <div class="prog-forcepower-card__media prog-holo-media prog-holo-media--wide">
              <img class="prog-forcepower-card__image prog-holo-media__image" src="{{this.img}}" alt="{{this.name}}">
              <div class="prog-holo-scan"></div>
            </div>
          {{/if}}

          {{!-- Power name --}}
          <div class="prog-force-power-card__header">
            <h3 class="prog-force-power-card__name">
              {{this.name}}
              {{#if this.badgeLabel}}
                <span class="swse-option-card__badge swse-option-card__badge--recommended">{{this.badgeLabel}}</span>
              {{/if}}
            </h3>
            {{#if (lookup ../committedCounts this.id)}}
              <span class="prog-force-power-card__count-badge">
                ×{{lookup ../committedCounts this.id}}
              </span>
            {{/if}}
          </div>

          {{!-- Description snippet --}}
          {{#if this.description}}
            <p class="prog-force-power-card__description">
              {{truncate this.description 100}}
            </p>
          {{/if}}

          {{!-- PHASE 8: Selection state indicator + status --}}
          {{#if (lookup ../cardStates this.id)}}
            {{#with (lookup ../cardStates this.id)}}
              <div class="prog-force-power-card__state-section">
                {{!-- Status badges --}}
                {{#if isCommitted}}
                  <span class="prog-force-power-card__status-badge prog-force-power-card__status-badge--committed">
                    <i class="fas fa-lock" aria-hidden="true"></i>
                    Committed ({{committedCount}})
                  </span>
                {{/if}}
                {{#if isPending}}
                  <span class="prog-force-power-card__status-badge prog-force-power-card__status-badge--pending">
                    <i class="fas fa-hourglass-end" aria-hidden="true"></i>
                    Pending ({{pendingCount}})
                  </span>
                {{/if}}

                {{!-- Quantity controls for pending selections --}}
                {{#if isPending}}
                  <div class="prog-force-power-card__quantity-control">
                    <button class="prog-quantity-btn prog-quantity-btn--decrement"
                            data-action="decrement-quantity"
                            data-item-id="{{powerId}}"
                            type="button"
                            aria-label="Remove one selection"
                            title="Remove">
                      <i class="fas fa-minus" aria-hidden="true"></i>
                    </button>
                    <span class="prog-quantity-display">{{pendingCount}}</span>
                    <button class="prog-quantity-btn prog-quantity-btn--increment"
                            data-action="increment-quantity"
                            data-item-id="{{powerId}}"
                            type="button"
                            aria-label="Add one more"
                            title="Add">
                      <i class="fas fa-plus" aria-hidden="true"></i>
                    </button>
                  </div>
                {{else}}
                  {{!-- Committed: show add button or unavailable state --}}
                  {{#if isCommitted}}
                    <div class="prog-force-power-card__quantity-hint">
                      <i class="fas fa-info-circle" aria-hidden="true"></i>
                      {{committedCount}} {{plural committedCount "use" "uses"}} locked
                    </div>
                  {{else}}
                    <div class="prog-force-power-card__state-hint prog-force-power-card__state-hint--available">
                      <i class="fas fa-plus-circle" aria-hidden="true"></i>
                      Available
                    </div>
                  {{/if}}
                {{/if}}
              </div>
            {{/with}}
          {{else}}
            {{!-- Fallback: legacy display if cardStates missing --}}
            {{#if (lookup ../pendingCounts this.id)}}
              <div class="prog-force-power-card__state-hint">
                <i class="fas fa-star" aria-hidden="true"></i>
                Selected {{lookup ../pendingCounts this.id}} {{plural (lookup ../pendingCounts this.id) "time" "times"}}
              </div>
            {{else}}
              <div class="prog-force-power-card__state-hint prog-force-power-card__state-hint--available">
                <i class="fas fa-plus-circle" aria-hidden="true"></i>
                Available
              </div>
            {{/if}}
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="prog-force-power-browse__empty">
      <i class="fas fa-hand-sparkles" aria-hidden="true"></i>
      <p>No Force Powers match your search or filters.</p>
    </div>
  {{/if}}
</div>
