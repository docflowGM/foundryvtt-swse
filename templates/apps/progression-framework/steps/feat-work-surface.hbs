{{!-- Feat Work Surface --}}
{{!-- Quick-reference grouped feat browser. Middle body stays compact; right body owns details. --}}

<div class="feat-work-surface prog-quickref-stage">

  {{!-- PHASE 2 UX: Micro-progress indicator --}}
  {{#if slotProgress}}
  <div class="prog-micro-progress prog-micro-progress--feats">
    {{#if slotProgress.isComplete}}
      <div class="prog-progress-status prog-progress-status--complete">
        <i class="fas fa-check-circle"></i>
        <span class="prog-progress-label">{{slotProgress.progressLabel}}</span>
        <span class="prog-badge prog-badge--complete">Complete</span>
      </div>
    {{else}}
      <div class="prog-progress-status prog-progress-status--incomplete">
        <i class="fas fa-circle-notch"></i>
        <span class="prog-progress-label">{{slotProgress.progressLabel}}</span>
        <span class="prog-progress-remaining">{{slotProgress.remainingLabel}}</span>
      </div>
    {{/if}}
  </div>
  {{/if}}

  {{!-- Type & Tag Filter Bar --}}
  <div class="feat-filter-bar">
    {{!-- Type dropdown --}}
    {{#if typeOptions}}
    <div class="feat-filter-group">
      <button class="feat-filter-btn{{#if (eq openFilterPanel 'type')}} is-open{{/if}}"
              data-action="open-filter-panel" data-panel="type" type="button">
        <span>Type</span>
        {{#if selectedTypesCount}}<span class="feat-filter-active-count">{{selectedTypesCount}}</span>{{/if}}
        <i class="fa-solid fa-chevron-{{#if (eq openFilterPanel 'type')}}up{{else}}down{{/if}}"></i>
      </button>
      {{#if (eq openFilterPanel 'type')}}
      <div class="feat-filter-panel">
        {{#each typeOptions}}
        <label class="feat-filter-option">
          <input type="checkbox" data-filter-group="type" value="{{this.value}}" {{#if this.checked}}checked{{/if}}>
          <span class="feat-filter-option__label">{{this.label}}</span>
        </label>
        {{/each}}
      </div>
      {{/if}}
    </div>
    {{/if}}

    {{!-- Tags dropdown --}}
    {{#if tagOptions}}
    <div class="feat-filter-group">
      <button class="feat-filter-btn{{#if (eq openFilterPanel 'tag')}} is-open{{/if}}"
              data-action="open-filter-panel" data-panel="tag" type="button">
        <span>Tags</span>
        {{#if selectedTagsCount}}<span class="feat-filter-active-count">{{selectedTagsCount}}</span>{{/if}}
        <i class="fa-solid fa-chevron-{{#if (eq openFilterPanel 'tag')}}up{{else}}down{{/if}}"></i>
      </button>
      {{#if (eq openFilterPanel 'tag')}}
      <div class="feat-filter-panel">
        {{#each tagOptions}}
        <label class="feat-filter-option">
          <input type="checkbox" data-filter-group="tag" value="{{this.value}}" {{#if this.checked}}checked{{/if}}>
          <span class="feat-filter-option__label">{{this.label}}</span>
        </label>
        {{/each}}
      </div>
      {{/if}}
    </div>
    {{/if}}
  </div>

  {{#if groupedFeats.suggested}}
  <section class="feat-group suggested-group">
    <div class="group-header" data-action="toggle-category" data-category="suggested">
      <div class="header-content">
        <i class="fa-solid fa-star group-icon"></i>
        <h3 class="group-title">Suggested for Your Build</h3>
        <span class="feat-count-badge">{{groupedFeats.suggested.feats.length}}</span>
      </div>
      <button class="expand-toggle {{#if groupedFeats.suggested.isExpanded}}expanded{{/if}}">
        <i class="fa-solid fa-chevron-down"></i>
      </button>
    </div>

    {{#if groupedFeats.suggested.isExpanded}}
    <div class="feat-list suggested-list">
      {{#each groupedFeats.suggested.feats}}
      <div class="feat-item suggested-feat {{#if this.isFocused}}focused{{/if}} {{#if this.isSelected}}selected{{/if}}"
           data-feat-id="{{this.id}}"
           data-item-id="{{this.id}}"
           data-action="focus-item">
        {{#if this.iconPath}}
        <div class="feat-item__icon">
          <img class="feat-item__icon-image" src="{{this.iconPath}}" alt="{{this.name}}" title="{{this.name}}">
          <div class="feat-item__icon-scan"></div>
        </div>
        {{/if}}
        <div class="feat-item-content">
          <span class="feat-name">{{this.name}}</span>
          <span class="feat-prereq-line">{{this.prerequisiteLine}}</span>
        </div>
        <div class="feat-item-meta">
          <span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Suggested</span>
          <span class="feat-state-indicator">{{#if this.isSelected}}<i class="fa-solid fa-check-circle selected-icon"></i>{{/if}}</span>
        </div>
      </div>
      {{/each}}
    </div>
    {{/if}}
  </section>
  {{/if}}

  {{#each groupedFeats as |group categoryKey|}}
  {{#unless (eq categoryKey "suggested")}}
  <section class="feat-group category-group">
    <div class="group-header" data-action="toggle-category" data-category="{{categoryKey}}">
      <div class="header-content">
        <i class="fa-solid {{group.icon}} group-icon"></i>
        <h3 class="group-title">{{group.label}}</h3>
        <span class="feat-count-badge">{{group.totalCount}}</span>
      </div>
      <button class="expand-toggle {{#if group.isExpanded}}expanded{{/if}}">
        <i class="fa-solid fa-chevron-down"></i>
      </button>
    </div>

    {{#if group.isExpanded}}
    <div class="feat-list category-list">
      {{#each group.feats as |feat idx|}}
      {{#if (or (lt idx group.visibleCount) group.isExpanded)}}
      <div class="feat-item category-feat {{#if feat.isFocused}}focused{{/if}} {{#if feat.isSelected}}selected{{/if}} {{#unless feat.isAvailable}}unavailable{{/unless}}"
           data-feat-id="{{feat.id}}"
           data-item-id="{{feat.id}}"
           data-action="focus-item"
           {{#unless feat.isAvailable}}title="{{feat.unavailabilityReason}}"{{/unless}}>
        {{#if feat.iconPath}}
        <div class="feat-item__icon">
          <img class="feat-item__icon-image" src="{{feat.iconPath}}" alt="{{feat.name}}" title="{{feat.name}}">
          <div class="feat-item__icon-scan"></div>
        </div>
        {{/if}}
        <div class="feat-item-content">
          <span class="feat-name">{{feat.name}}</span>
          {{!-- PHASE 6 UX: Show prerequisite line more prominently --}}
          {{#if feat.prerequisiteLine}}
            <span class="feat-prereq-line" title="{{feat.prerequisiteLine}}">
              <i class="fa-solid fa-link-slash"></i> {{feat.prerequisiteLine}}
            </span>
          {{/if}}
          {{#if feat.unavailabilityReason}}
            <span class="feat-unavail-reason">{{feat.unavailabilityReason}}</span>
          {{/if}}
        </div>
        <div class="feat-item-meta">
          {{#if feat.isSuggested}}
          <span class="feat-synergy-badge">synergy</span>
          {{/if}}
          {{#unless feat.isAvailable}}
            <span class="feat-unavail-badge"><i class="fa-solid fa-ban"></i> Unavailable</span>
          {{else}}
            <span class="feat-state-indicator">{{#if feat.isSelected}}<i class="fa-solid fa-check-circle selected-icon"></i>{{/if}}</span>
          {{/unless}}
        </div>
      </div>
      {{/if}}
      {{/each}}

      {{#if group.canExpand}}
      <div class="feat-show-more">
        <p class="small-text">{{subtract group.totalCount group.visibleCount}} more {{group.label}} feats...</p>
      </div>
      {{/if}}
    </div>
    {{/if}}
  </section>
  {{/unless}}
  {{/each}}

  {{#unless groupedFeats}}
  <section class="feat-group empty-state">
    <div class="empty-message">
      {{!-- PHASE 8 UX: Enhanced empty state with helpful guidance --}}
      <i class="fa-solid fa-hexagon-exclamation"></i>
      <p class="empty-title">No {{#if showAll}}more{{else}}Available{{/if}} Feats</p>
      {{#if showAll}}
        <p class="empty-description">You've explored all available feats. Every feat either:</p>
        <ul class="empty-reasons">
          <li>Has already been selected by you</li>
          <li>Does not meet your character's prerequisites</li>
          <li>Is restricted by your class or species</li>
        </ul>
        <p class="empty-hint">Try reviewing your earlier choices if you need different options.</p>
      {{else}}
        <p class="empty-description">No feats meet your current character prerequisites. Your current build:</p>
        <ul class="empty-reasons">
          <li>May not have unlocked certain feats yet</li>
          <li>May require specific abilities or classes</li>
          <li>May have restrictions based on species or level</li>
        </ul>
        <p class="empty-hint"><strong>Tip:</strong> Enable "Show All" to see what prerequisites are blocking each feat. You can review your earlier choices to unlock more options.</p>
      {{/if}}
    </div>
  </section>
  {{/unless}}

</div>
