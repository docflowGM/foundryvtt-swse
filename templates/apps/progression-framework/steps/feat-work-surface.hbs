{{!-- Feat Work Surface --}}
{{!-- Summary and detail rails stay outside this template; this body rail owns feat browsing only. --}}

<div class="feat-work-surface prog-quickref-stage">

  {{#if slotProgress}}
  <div class="prog-micro-progress prog-micro-progress--feats">
    {{#if slotProgress.isComplete}}
      <div class="prog-progress-status prog-progress-status--complete">
        <i class="fas fa-check-circle"></i>
        <span class="prog-progress-label">{{slotProgress.progressLabel}}</span>
        <span class="prog-badge prog-badge--complete">Complete</span>
      </div>
    {{else}}
      <div class="prog-progress-status prog-progress-status--incomplete">
        <i class="fas fa-circle-notch"></i>
        <span class="prog-progress-label">{{slotProgress.progressLabel}}</span>
        <span class="prog-progress-remaining">{{slotProgress.remainingLabel}}</span>
      </div>
    {{/if}}
  </div>
  {{/if}}

  {{#if isMulticlassStartingFeatSlot}}
  <section class="feat-group feat-group--flat-list multiclass-starting-feats">
    <div class="group-header group-header--static">
      <div class="header-content">
        <i class="fa-solid fa-list-check group-icon"></i>
        <h3 class="group-title">Legal Starting Feats</h3>
        <span class="feat-count-badge">{{flatFeatList.length}}</span>
      </div>
    </div>

    <div class="feat-list category-list feat-list--flat">
      {{#each flatFeatList as |feat|}}
      <div class="feat-item category-feat {{#if feat.isFocused}}focused{{/if}} {{#if feat.isSelected}}selected{{/if}}"
           style="--feat-tree-indent: {{feat.treeIndent}};"
           data-feat-id="{{feat.id}}"
           data-item-id="{{feat.id}}"
           data-action="focus-item">
        <div class="feat-item-content">
          <span class="feat-name">{{feat.name}}</span>
          {{#if feat.shortSummary}}<span class="feat-search-summary">{{feat.shortSummary}}</span>{{/if}}
          {{#if feat.prerequisiteLine}}
            <span class="feat-prereq-line" title="{{feat.prerequisiteLine}}">
              <i class="fa-solid fa-link"></i> {{feat.prerequisiteLine}}
            </span>
          {{/if}}
        </div>
        <div class="feat-item-meta">
          {{#if feat.isSuggested}}
          <span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Suggested</span>
          {{/if}}
          <span class="feat-state-indicator">{{#if feat.isSelected}}<i class="fa-solid fa-check-circle selected-icon"></i>{{/if}}</span>
        </div>
      </div>
      {{/each}}
    </div>

    {{#unless flatFeatList.length}}
    <div class="empty-message">
      <i class="fa-solid fa-hexagon-exclamation"></i>
      <p class="empty-title">No Legal Starting Feats</p>
      <p class="empty-description">No feat from this class's starting-feat pool currently meets your prerequisites.</p>
    </div>
    {{/unless}}
  </section>
  {{else}}

  <div class="feat-browser-toolbar">
    <div class="feat-browser-toolbar__left">
      <button class="feat-filter-btn feat-show-all-toggle{{#if showAll}} is-open{{/if}}"
              data-action="toggle-show-all-feats" type="button"
              title="Toggle between legal selectable feats and the full hydrated feat browser">
        <i class="fa-solid {{#if showAll}}fa-eye{{else}}fa-eye-slash{{/if}}"></i>
        <span>{{#if showAll}}Showing All{{else}}Legal Only{{/if}}</span>
        <span class="feat-filter-active-count">{{#if showAll}}{{allFeatCount}}{{else}}{{legalFeatCount}}{{/if}}</span>
      </button>

      {{#if hasSearchQuery}}
      <span class="feat-browser-mode-pill feat-browser-mode-pill--search">
        <i class="fa-solid fa-magnifying-glass"></i>
        Search: {{searchQueryLabel}}
      </span>
      {{else}}
      <span class="feat-browser-mode-pill">
        <i class="fa-solid {{activeCategoryIcon}}"></i>
        {{activeCategoryLabel}}
      </span>
      {{/if}}
    </div>

    <div class="feat-browser-toolbar__right">
      <button class="feat-filter-btn" data-action="reset-feat-browser" type="button" title="Clear feat search and filters">
        <i class="fa-solid fa-rotate-left"></i>
        <span>Reset</span>
      </button>
      {{#unless hasSearchQuery}}
      <button class="feat-filter-btn feat-category-collapse-toggle" data-action="toggle-feat-category-sidebar" type="button">
        <i class="fa-solid {{#if categorySidebarCollapsed}}fa-angles-right{{else}}fa-angles-left{{/if}}"></i>
        <span>{{#if categorySidebarCollapsed}}Show Categories{{else}}Collapse Categories{{/if}}</span>
      </button>
      {{/unless}}
    </div>
  </div>

  <section class="feat-browser {{#if categorySidebarCollapsed}}feat-browser--sidebar-collapsed{{/if}} {{#if hasSearchQuery}}feat-browser--search-mode{{/if}}">
    {{#unless hasSearchQuery}}
    {{#unless categorySidebarCollapsed}}
    <aside class="feat-category-sidebar" aria-label="Feat categories">
      <div class="feat-category-sidebar__header">
        <span>Categories</span>
        <button class="feat-category-sidebar__collapse" data-action="toggle-feat-category-sidebar" type="button" title="Collapse categories">
          <i class="fa-solid fa-chevron-left"></i>
        </button>
      </div>
      <div class="feat-category-list">
        {{#each categoryOptions as |category|}}
        <button class="feat-category-button {{#if category.isActive}}active{{/if}} {{#if category.isSuggested}}suggested{{/if}}"
                data-action="select-feat-category"
                data-category="{{category.key}}"
                type="button">
          <span class="feat-category-button__main">
            <i class="fa-solid {{category.icon}}"></i>
            <span>{{category.label}}</span>
          </span>
          <span class="feat-category-button__count">{{category.totalCount}}</span>
        </button>
        {{/each}}
      </div>
    </aside>
    {{/unless}}
    {{/unless}}

    <main class="feat-results-pane">
      {{#if hasSearchQuery}}
      <header class="feat-results-pane__header feat-results-pane__header--search">
        <div>
          <h3><i class="fa-solid fa-magnifying-glass"></i> Search Results</h3>
          <p>Only feats related to your search are shown here.</p>
        </div>
        <span class="feat-count-badge">{{searchResultCount}}</span>
      </header>

      {{#if searchResults.length}}
      <div class="feat-compact-list feat-search-results-list">
        {{#each searchResults as |feat|}}
        <div class="feat-compact-row {{#if feat.isFocused}}focused{{/if}} {{#if feat.isSelected}}selected{{/if}} {{#unless feat.isAvailable}}unavailable{{/unless}}"
             style="--feat-tree-indent: {{feat.treeIndent}};"
             data-feat-id="{{feat.id}}"
             data-item-id="{{feat.id}}"
             data-action="focus-item"
             {{#unless feat.isAvailable}}title="{{feat.unavailabilityReason}}"{{/unless}}>
          <div class="feat-compact-row__content">
            <div class="feat-compact-row__line feat-compact-row__line--primary">
              <span class="feat-name">{{feat.name}}</span>
              {{#if feat.shortSummary}}<span class="feat-quick-summary">{{feat.shortSummary}}</span>{{/if}}
            </div>
            <div class="feat-compact-row__line feat-compact-row__line--meta">
              <span class="feat-subcategory-pill">{{feat.searchCategoryLabel}}</span>
              {{#if feat.prerequisiteLine}}<span class="feat-prereq-line"><i class="fa-solid fa-link"></i> {{feat.prerequisiteLine}}</span>{{/if}}
              {{#if feat.isSuggested}}<span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Recommended</span>{{/if}}
              {{#if feat.isGranted}}<span class="feat-owned-pill">Granted</span>{{else}}{{#if feat.isOwned}}<span class="feat-owned-pill">Owned</span>{{/if}}{{/if}}
              {{#unless feat.isAvailable}}<span class="feat-unavail-badge"><i class="fa-solid fa-ban"></i> Unavailable</span>{{/unless}}
            </div>
          </div>
          <div class="feat-compact-row__state">
            {{#if feat.isSelected}}<i class="fa-solid fa-check-circle selected-icon"></i>{{else}}<i class="fa-solid fa-chevron-right"></i>{{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="feat-search-empty">
        <i class="fa-solid fa-radar"></i>
        <span>No feats match “{{searchQueryLabel}}” in the feat catalog.</span>
        <span class="feat-search-empty__hint">Try a shorter name, prerequisite, or tag.</span>
      </div>
      {{/if}}
      {{else}}
      <header class="feat-results-pane__header">
        <div>
          <h3><i class="fa-solid {{activeCategoryIcon}}"></i> {{activeCategoryLabel}}</h3>
          <p>Select a feat to inspect it in the detail rail.</p>
        </div>
        <span class="feat-count-badge">{{activeCategoryCount}}</span>
      </header>

      {{#if activeCategoryFeats.length}}
      <div class="feat-compact-list">
        {{#each activeCategoryFeats as |feat|}}
        <div class="feat-compact-row {{#if feat.isFocused}}focused{{/if}} {{#if feat.isSelected}}selected{{/if}} {{#unless feat.isAvailable}}unavailable{{/unless}} {{#if feat.isSuggested}}suggested{{/if}}"
             style="--feat-tree-indent: {{feat.treeIndent}};"
             data-feat-id="{{feat.id}}"
             data-item-id="{{feat.id}}"
             data-action="focus-item"
             {{#unless feat.isAvailable}}title="{{feat.unavailabilityReason}}"{{/unless}}>
          <div class="feat-compact-row__content">
            <div class="feat-compact-row__line feat-compact-row__line--primary">
              <span class="feat-name">{{feat.name}}</span>
              {{#if feat.shortSummary}}<span class="feat-quick-summary">{{feat.shortSummary}}</span>{{/if}}
            </div>
            <div class="feat-compact-row__line feat-compact-row__line--meta">
              {{#if feat.prerequisiteLine}}<span class="feat-prereq-line"><i class="fa-solid fa-link"></i> {{feat.prerequisiteLine}}</span>{{/if}}
              {{#if feat.isSuggested}}<span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Recommended</span>{{/if}}
              {{#if feat.isGranted}}<span class="feat-owned-pill">Granted</span>{{else}}{{#if feat.isOwned}}<span class="feat-owned-pill">Owned</span>{{/if}}{{/if}}
              {{#unless feat.isAvailable}}<span class="feat-unavail-badge"><i class="fa-solid fa-ban"></i> Unavailable</span>{{/unless}}
            </div>
          </div>
          <div class="feat-compact-row__state">
            {{#if feat.isSelected}}<i class="fa-solid fa-check-circle selected-icon"></i>{{else}}<i class="fa-solid fa-chevron-right"></i>{{/if}}
          </div>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="empty-message feat-browser-empty">
        <i class="fa-solid fa-hexagon-exclamation"></i>
        <p class="empty-title">No Feats in This View</p>
        <p class="empty-description">Try another category, clear search, or toggle Show All to inspect locked options.</p>
      </div>
      {{/if}}
      {{/if}}
    </main>
  </section>

  {{#unless groupedFeats}}
  <section class="feat-group empty-state">
    <div class="empty-message">
      <i class="fa-solid fa-hexagon-exclamation"></i>
      <p class="empty-title">No {{#if showAll}}more{{else}}Available{{/if}} Feats</p>
      <p class="empty-description">No feats meet this slot's current display rules.</p>
      <p class="empty-hint"><strong>Tip:</strong> Enable "Show All" to inspect blocked feat prerequisites.</p>
    </div>
  </section>
  {{/unless}}

  {{/if}}

</div>
