{{!-- Medical Secret Selection Work Surface --}}

<div class="prog-force-secret-browse prog-medical-secret-browse">
  {{#if secrets.length}}
    <div class="prog-force-secret-grid prog-medical-secret-grid" role="list">
      {{#each secrets}}
        <div class="prog-force-secret-card prog-medical-secret-card
                    {{#if this.isSelected}}prog-force-secret-card--selected prog-medical-secret-card--selected{{/if}}
                    {{#if this.isSuggested}}prog-secret-card--suggested prog-secret-card--suggested-{{this.confidenceLevel}}{{/if}}"
             data-action="focus-item"
             data-item-id="{{this.id}}"
             data-recommended="{{#if this.isSuggested}}true{{/if}}"
             data-confidence-level="{{this.confidenceLevel}}"
             tabindex="0" role="option"
             aria-selected="{{#if this.isSelected}}true{{else}}false{{/if}}">

          <div class="prog-force-secret-card__header">
            <h3 class="prog-force-secret-card__name">
              {{this.name}}
              {{#if this.badgeLabel}}
                <span class="swse-option-card__badge swse-option-card__badge--recommended">{{this.badgeLabel}}</span>
              {{/if}}
            </h3>
            {{#if this.isSelected}}
              <span class="prog-force-secret-card__count-badge">
                <i class="fas fa-kit-medical" aria-hidden="true"></i>
              </span>
            {{/if}}
          </div>

          {{#if this.description}}
            <p class="prog-force-secret-card__description">
              {{truncate this.description 120}}
            </p>
          {{/if}}

          {{#if this.isSelected}}
            <div class="prog-force-secret-card__state-hint">
              <i class="fas fa-check-circle" aria-hidden="true"></i>
              Selected
            </div>
          {{else}}
            <div class="prog-force-secret-card__state-hint prog-force-secret-card__state-hint--available">
              <i class="fas fa-plus-circle" aria-hidden="true"></i>
              Available once
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="prog-force-secret-browse__empty">
      <i class="fas fa-kit-medical" aria-hidden="true"></i>
      <p>No Medical Secrets match your search or filters.</p>
    </div>
  {{/if}}
</div>
