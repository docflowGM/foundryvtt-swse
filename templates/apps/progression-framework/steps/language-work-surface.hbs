{{!-- Language Work Surface --}}
{{!-- Shows known/granted languages, selected bonus languages, and available selectable languages --}}

<div class="language-work-surface">

  {{!-- Known/Granted Languages Section --}}
  {{#if knownLanguages}}
  <section class="language-section known-languages-section">
    <h3 class="section-title">
      <i class="fa-solid fa-check-circle"></i>
      Known Languages ({{knownLanguages.length}})
    </h3>
    <p class="section-description">You automatically know these from your species and background.</p>

    <div class="language-list known-list">
      {{#each knownLanguages}}
      <div class="language-item known-language" data-language-id="{{this.language.id}}" data-action="focus-item">
        <div class="language-item-content">
          <span class="language-name">{{this.name}}</span>
          <span class="language-source-badge">automatic</span>
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- Selected Bonus Languages Section --}}
  {{#if selectedBonusLanguages}}
  <section class="language-section selected-languages-section">
    <h3 class="section-title">
      <i class="fa-solid fa-star"></i>
      Selected Bonus Languages ({{selectedBonusLanguages.length}})
    </h3>
    <p class="section-description">These are your bonus language choices this step.</p>

    <div class="language-list selected-list">
      {{#each selectedBonusLanguages}}
      <div class="language-item selected-language" data-language-id="{{this.language.id}}" data-action="focus-item">
        <div class="language-item-content">
          <span class="language-name">{{this.name}}</span>
          <span class="language-selected-badge">selected</span>
        </div>
        <button class="language-remove-btn" data-action="remove-language" data-language-id="{{this.language.id}}" title="Remove this selection">
          <i class="fa-solid fa-times"></i>
        </button>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- Available Languages Section --}}
  {{#if hasAvailableLanguages}}
  <section class="language-section available-languages-section">
    <h3 class="section-title">
      <i class="fa-solid fa-book-open"></i>
      Available Languages
      <span class="remaining-picks-badge">{{remainingPicks}} pick{{#unless (eq remainingPicks 1)}}s{{/unless}} remaining</span>
    </h3>
    <p class="section-description">Choose additional languages up to your bonus limit.</p>

    <div class="language-list available-list">
      {{#each availableLanguages}}
      <div class="language-item available-language" data-language-id="{{this.id}}" data-action="focus-item">
        <div class="language-item-content">
          <span class="language-name">{{this.name}}</span>
          <span class="language-category-badge {{this.category}}">{{this.category}}</span>
        </div>
        {{#if this.canSelect}}
        <button class="language-add-btn" data-action="add-language" data-language-id="{{this.id}}" title="Select this language">
          <i class="fa-solid fa-plus"></i>
        </button>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{else}}
  {{#if (gt bonusLanguagesAvailable 0)}}
  <section class="language-section empty-state">
    <div class="empty-message">
      <i class="fa-solid fa-language"></i>
      <p>No languages available to select.</p>
      <p class="small">You may have already selected all available languages.</p>
    </div>
  </section>
  {{/if}}
  {{/if}}

  {{!-- Empty State if No Bonus Picks Available --}}
  {{#if (eq bonusLanguagesAvailable 0)}}
  <section class="language-section zero-picks-state">
    <div class="zero-picks-message">
      <i class="fa-solid fa-check-circle"></i>
      <p>No bonus language picks available.</p>
      <p class="small">You know the languages granted by your species and background.</p>
    </div>
  </section>
  {{/if}}

</div>
