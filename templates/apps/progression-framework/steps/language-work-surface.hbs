{{!-- Language Work Surface --}}
{{!-- Shows known/granted languages, selected bonus languages, and available selectable languages --}}

<div class="language-work-surface prog-quickref-stage" data-prog-scroll-key="language-work-surface">

  <section class="language-section language-rules-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled">
    <h3 class="section-title"><i class="fa-solid fa-calculator"></i> Language Formula</h3>
    <p class="section-description">Native language + Basic are automatic. Bonus picks: INT modifier ({{languageRuleBreakdown.intModPicks}}) + Linguist ({{languageRuleBreakdown.linguistPicks}}).</p>
  </section>

  {{!-- Known/Granted Languages Section --}}
  {{#if knownLanguages}}
  <section class="language-section known-languages-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled">
    <h3 class="section-title">
      <i class="fa-solid fa-check-circle"></i>
      Known Languages ({{knownLanguages.length}})
    </h3>
    <p class="section-description">You automatically know these from your species and background.</p>

    <div class="language-list known-list">
      {{#each knownLanguages}}
      <div class="language-item known-language swse-card-schema swse-card-schema--enumerated swse-card-schema--filled" data-language-id="{{this.language.id}}" data-item-id="{{this.language.id}}" data-action="focus-item">
        <div class="language-item-content">
          <span class="language-name">{{this.name}}</span>
          <span class="language-source-badge">automatic</span>
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- Selected Bonus Languages Section --}}
  {{#if selectedBonusLanguages}}
  <section class="language-section selected-languages-section swse-card-schema swse-card-schema--enumerated swse-card-schema--filled">
    <h3 class="section-title">
      <i class="fa-solid fa-star"></i>
      Selected Bonus Languages ({{selectedBonusLanguages.length}})
    </h3>
    <p class="section-description">These are your bonus language choices this step.</p>

    <div class="language-list selected-list" data-prog-scroll-key="language-selected-list">
      {{#each selectedBonusLanguages}}
      <div class="language-item selected-language swse-card-schema swse-card-schema--enumerated swse-card-schema--filled" data-language-id="{{this.language.id}}" data-action="focus-item">
        <div class="language-item-content">
          <span class="language-name">{{this.name}}</span>
          <span class="language-selected-badge">selected</span>
        </div>
        <button class="language-remove-btn" data-action="remove-language" data-language-id="{{this.language.id}}" title="Remove this selection">
          <i class="fa-solid fa-times"></i>
        </button>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- Available Languages Section --}}
  {{#if hasAvailableLanguages}}
  <section class="language-section available-languages-section swse-card-schema swse-card-schema--choice swse-card-schema--pending">
    <h3 class="section-title">
      <i class="fa-solid fa-book-open"></i>
      Available Languages
      <span class="remaining-picks-badge">{{remainingPicks}} pick{{#unless (eq remainingPicks 1)}}s{{/unless}} remaining</span>
    </h3>
    <p class="section-description">Choose additional languages up to your bonus limit.</p>

    <div class="language-list available-list" data-prog-scroll-key="language-available-list">
      {{#each availableLanguages}}
      <div class="language-item available-language swse-card-schema swse-card-schema--choice swse-card-schema--pending
                  {{#if this.isSuggested}}prog-language-item--suggested prog-language-item--suggested-{{this.confidenceLevel}}{{/if}}"
           data-language-id="{{this.id}}"
           data-item-id="{{this.id}}"
           data-action="focus-item"
           data-recommended="{{#if this.isSuggested}}true{{/if}}"
           data-confidence-level="{{this.confidenceLevel}}">
        <div class="language-item-content">
          <span class="language-name">
            {{this.name}}
            {{#if this.badgeLabel}}
              <span class="swse-option-card__badge swse-option-card__badge--recommended">{{this.badgeLabel}}</span>
            {{/if}}
          </span>
          <span class="language-category-badge {{this.category}}">{{this.category}}</span>
        </div>
        {{#if this.canSelect}}
        <button class="language-add-btn" data-action="add-language" data-language-id="{{this.id}}" title="Select this language">
          <i class="fa-solid fa-plus"></i>
        </button>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{else}}
  {{#if (gt bonusLanguagesAvailable 0)}}
  <section class="language-section empty-state swse-card-schema swse-card-schema--choice swse-card-schema--placeholder">
    <div class="empty-message">
      <i class="fa-solid fa-language"></i>
      <p>No languages available to select.</p>
      <p class="small">You may have already selected all available languages.</p>
    </div>
  </section>
  {{/if}}
  {{/if}}

  {{!-- Empty State if No Bonus Picks Available --}}
  {{#if (eq bonusLanguagesAvailable 0)}}
  <section class="language-section zero-picks-state swse-card-schema swse-card-schema--enumerated swse-card-schema--placeholder">
    <div class="zero-picks-message">
      <i class="fa-solid fa-check-circle"></i>
      <p>No bonus language picks available.</p>
      <p class="small">You know the languages granted by your species and background.</p>
    </div>
  </section>
  {{/if}}

</div>
