{{#if (eq introVariant "actor-v2")}}
{{!-- ========================================================================
     ACTOR V2 SPLASH VARIANT
     ======================================================================== --}}
<div class="prog-intro-surface prog-intro-surface--actor-v2 swse-ui-shell {{#if localizedMode}}prog-intro-surface--localized{{else}}prog-intro-surface--foreign{{/if}} {{#if isComplete}}is-complete{{/if}} {{#if erroring}}is-erroring{{/if}} {{#if succeeding}}is-succeeding{{/if}}">
  <div class="stage">
    <div class="tablet">
      <div class="rivet tl"></div><div class="rivet tr"></div><div class="rivet bl"></div><div class="rivet br"></div>
      <div class="rivet mid-l"></div><div class="rivet mid-r"></div>
      <div class="btn-phys top1"></div><div class="btn-phys top2"></div>
      <div class="btn-phys right1"></div><div class="btn-phys right2"></div>
      <div class="vent"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
      <div class="cam"></div>
      <div class="bezel-led a"></div><div class="bezel-led b"></div><div class="bezel-led c"></div><div class="bezel-led d"></div>
      <div class="bezel-label">{{bezelLabel}}</div>
      <div class="bezel-serial">{{bezelSerial}}</div>
      <div class="bezel-fcc">{{bezelCertification}}</div>
      <div class="bezel-manu">{{bezelManufacturer}}</div>

      <div class="screen" data-role="intro-screen">
        {{#if showManufacturerCard}}
        <div class="manu-card" data-role="intro-manu-card">
          <div class="tag">{{manufacturerTag}}</div>
          <div class="logo">{{manufacturerLogo}}</div>
          <div class="spin"></div>
          <div class="version">{{manufacturerVersion}}</div>
          <div class="tag intro-subtag">{{manufacturerSubtag}}</div>
        </div>
        {{/if}}

        <div class="scan-v"></div>
        <div class="glitch-overlay {{#if glitchFire}}fire{{/if}}" data-role="intro-glitch"></div>
        <div class="red-wash {{#if erroring}}on{{/if}}" data-role="intro-red-wash"></div>
        <div class="green-wash {{#if greenWashOn}}on{{/if}}" data-role="intro-green-wash"></div>
        <div class="big-banner {{bannerClass}}" data-role="intro-big-banner">{{bannerText}}</div>

        <div class="pixel-test {{#if pixelTestOn}}on{{/if}}" data-role="intro-pixel-test">
          <div class="bar r"></div><div class="bar g"></div><div class="bar b"></div><div class="bar w"></div>
        </div>

        <div class="corner tl"></div><div class="corner tr"></div><div class="corner bl"></div><div class="corner br"></div>

        <div class="hud">
          <div class="hud-left">
            <span class="tag"><span class="dot"></span>LINK</span>
            <span class="tag" data-role="boot-stage-tag"><span class="dot {{bootStageDotClass}}"></span>{{bootStageTag}}</span>
            <span class="tag">ENC · AES-2048</span>
            <span class="tag intro-diag-tag"><span class="dot intro-purple-dot"></span>DIAG</span>
          </div>
          <div class="hud-title">{{hudTitle}}</div>
          <div class="hud-right">
            <span class="tag"><span class="signal">{{#each signalBars}}<span></span>{{/each}}</span></span>
            <span class="tag battery">{{#each batteryCells}}<span class="cell {{#if this.empty}}empty{{/if}}"></span>{{/each}}</span>
            <span class="tag" data-role="clock">{{currentTime}}</span>
          </div>
        </div>

        <div class="boot">
          <div class="pane diag">
            <div class="pane-head">Channel Diagnostics <span class="mini-led"></span></div>
            <div class="channels">
              {{#each channels}}
              <div class="channel {{stateClass}}" data-ch="{{id}}">
                <div class="lbl">{{label}}</div>
                <div class="gauge"><div class="fill" style="width:{{pct}}%"></div></div>
                <div class="val">{{displayValue}}</div>
              </div>
              {{/each}}
            </div>

            <div class="pane-head">Capacitor <span class="mini-led"></span></div>
            <div class="cap">
              <div class="cap-label">CHG</div>
              <div class="cap-body"><div class="cap-fill" style="width:{{capacitorPct}}%" data-role="cap-fill"></div></div>
              <div class="cap-val" data-role="cap-val">{{capacitorLabel}}</div>
            </div>

            <div class="pane-head">Chip Map · A7 <span class="mini-led"></span></div>
            <div class="die" data-role="die-map">
              {{#each chipBanks}}
              <div class="bank {{#if hot}}hot{{/if}} {{#if err}}err{{/if}}" style="{{style}}">{{label}}</div>
              {{/each}}
            </div>
          </div>

          <div class="pane hero">
            <div class="stage-marquee">
              <div class="stg-idx" data-role="stage-index">{{stageIndex}}</div>
              <div class="stg-name" data-role="stage-name">{{stageName}}</div>
              <div class="stg-glyph" data-role="stage-glyph">{{stageGlyph}}</div>
            </div>

            <div class="hero-progress">
              <div class="hp-row">
                <div class="hp-counter">
                  <span class="lbl">Loaded</span>
                  <span class="pct-big" data-role="intro-progress-percent">{{progressPercent}}%</span>
                </div>
                <div>
                  <div class="seg-bar" data-role="seg-bar">
                    {{#each progressSegments}}<div class="seg {{#if active}}on{{/if}} {{#if leading}}leading{{/if}}"></div>{{/each}}
                  </div>
                  <div class="hp-ticks">
                    {{#each progressTicks}}<span class="{{#if major}}major{{/if}}">{{label}}</span>{{/each}}
                  </div>
                </div>
                <div class="hp-counter right">
                  <span class="lbl">ETA</span>
                  <span class="pct-big" data-role="eta-big">{{etaLabel}}</span>
                </div>
              </div>

              <div class="sub-track">
                <span class="task" data-role="current-task">{{currentTask}}</span>
                <div class="sub-bar"><div class="sub-fill" style="width:{{taskProgress}}%" data-role="sub-fill"></div></div>
                <span class="eta" data-role="task-count">{{taskCount}}</span>
              </div>
            </div>

            <div class="intro-ring-row">
              <div class="ring">
                <div class="halo"></div>
                <svg class="r-outer" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><circle cx="100" cy="100" r="94" opacity="0.25"></circle><circle cx="100" cy="100" r="94" stroke-dasharray="2 6" opacity="0.7"></circle><circle cx="100" cy="100" r="94" stroke-dasharray="30 550" stroke-width="2" opacity="0.9"></circle></svg>
                <svg class="r-mid" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><circle cx="100" cy="100" r="74" opacity="0.3"></circle><path d="M100 26 L100 34 M174 100 L166 100 M100 174 L100 166 M26 100 L34 100" stroke-width="2"></path><circle cx="100" cy="26" r="3" fill="currentColor"></circle><circle cx="174" cy="100" r="2" fill="currentColor"></circle></svg>
                <svg class="r-inner" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><circle cx="100" cy="100" r="54" opacity="0.5"></circle><path d="M100 46 L110 54 L100 62 L90 54 Z" fill="currentColor" opacity="0.6"></path><circle cx="100" cy="100" r="54" stroke-dasharray="1 4" opacity="0.5"></circle></svg>
                <div class="core" data-role="core-glyph">{{coreGlyph}}</div>
                <div class="scan"></div>
              </div>

              <div class="status intro-status-block">
                <span class="label" data-role="status-label">{{statusLabel}}</span>
                <span class="msg {{statusClass}}" data-role="status-msg">{{statusMessage}}</span>
                <span class="glyph-src" data-role="status-src">{{statusSource}}</span>
              </div>
            </div>

            <div class="translate {{#if isTranslating}}on{{/if}}" data-role="translate-zone">
              <span class="lbl">Aurebesh translation</span>
              <span class="src" data-role="trans-src">{{translationSource}}</span>
              <span class="arrow">▸</span>
              <span class="dst" data-role="trans-dst">{{translationTarget}}</span>
            </div>
          </div>

          <div class="pane stream">
            <div class="pane-head">Boot Log · Stream <span class="mini-led"></span></div>
            <div class="log" data-role="boot-log">
              {{#each logLines}}
              <div class="log-line"><span class="t">[{{time}}]</span><span class="{{tagClass}}">[{{tag}}]</span> <span class="txt">{{text}}</span></div>
              {{/each}}
            </div>

            <div class="prompt"><span class="intro-prompt-prefix">versa:~$ </span><span data-role="prompt-text">{{promptText}}</span><span class="blink"></span></div>

            <div class="pane-head">Uplink · RTT (ms)<span data-role="rtt-val" class="intro-rtt-val">{{rttLabel}}</span></div>
            <div class="spark"><canvas class="spark-canvas" data-role="spark-canvas" width="300" height="52"></canvas></div>

            <div class="pane-head">Active Thread <span class="mini-led"></span></div>
            <div class="thread">
              <div><span class="k">tid:</span> <span class="intro-thread-value">{{thread.tid}}</span></div>
              <div><span class="k">cpu:</span> <span class="intro-thread-pos">{{thread.cpu}}</span></div>
              <div><span class="k">mem:</span> <span class="intro-thread-value">{{thread.mem}}</span></div>
              <div><span class="k">pkts:</span> <span class="intro-thread-value">{{thread.pkts}}</span></div>
              <div><span class="k">warn:</span> <span class="intro-thread-warn">{{thread.warn}}</span></div>
              <div><span class="k">err: </span> <span class="intro-thread-neg">{{thread.err}}</span></div>
            </div>

            <div class="identity {{#if showIdentity}}on{{/if}}" data-role="identity-card">
              <div class="bust"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><circle cx="50" cy="36" r="16"></circle><path d="M22 88 Q22 58 50 58 Q78 58 78 88"></path><path d="M14 50 L86 50" stroke-dasharray="2 4" opacity="0.4"></path><path d="M50 8 L50 96" stroke-dasharray="2 4" opacity="0.4"></path></svg></div>
              <div class="info">
                <span class="badge">{{identity.badge}}</span>
                <div class="name">{{identity.name}}</div>
                <div class="sub">{{identity.sub}}</div>
                <div class="meta-grid">{{#each identity.meta}}<div class="m"><div class="k">{{key}}</div><div class="v">{{value}}</div></div>{{/each}}</div>
              </div>
            </div>

            <div class="register {{#if showRegister}}on{{/if}}" data-role="register-banner">
              <div class="msg">{{registerMessage}}</div>
              <div class="cta"><span>{{registerCta}}</span><span class="finger">☟</span></div>
            </div>
          </div>
        </div>

        <div class="actions">
          <div class="hint"><kbd>SPACE</kbd> skip · <kbd>ENTER</kbd> continue · <kbd>R</kbd> replay</div>
          <div class="intro-action-row">
            <button class="btn ghost" type="button" data-action="skip-intro">Skip Boot</button>
            <button class="btn primary" type="button" data-action="next-step" {{#unless isComplete}}disabled{{/unless}}>{{continueLabel}}</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{{else if (eq introVariant "droid-v2")}}
{{!-- ========================================================================
     DROID V2 SPLASH VARIANT
     ======================================================================== --}}
<div class="prog-intro-surface prog-intro-surface--droid-v2 swse-ui-shell {{#if isComplete}}is-complete{{/if}}">
  <div class="stage">
    <div class="datapad">
      <div class="rivet tl"></div><div class="rivet tr"></div><div class="rivet bl"></div><div class="rivet br"></div>
      <div class="bezel-label">{{bezelLabel}}</div>
      <div class="bezel-serial">{{bezelSerial}}</div>
      <div class="vent"></div>
      <div class="power-led"></div>

      <div class="screen">
        <div class="screen-inner holo">
          <div class="corner tl"></div><div class="corner tr"></div><div class="corner bl"></div><div class="corner br"></div>

          <div class="hud">
            <div class="hud-left">
              <span class="tag"><span class="dot"></span>BUS</span>
              <span class="tag" data-role="boot-stage-tag"><span class="dot warn"></span>{{bootStageTag}}</span>
              <span class="tag">BOLT · DISENGAGED</span>
            </div>
            <div class="hud-title">{{hudTitle}}</div>
            <div class="hud-right">
              <span class="tag">
                <span class="signal"><span></span><span></span><span></span><span></span></span>
              </span>
              <span class="tag battery">
                <span class="cell"></span><span class="cell"></span><span class="cell"></span><span class="cell"></span><span class="cell empty"></span>
              </span>
              <span class="tag" data-role="clock">{{currentTime}}</span>
            </div>
          </div>

          <div class="boot">
            <div class="diag">
              <div class="diag-head">Channel Diagnostics</div>
              {{#each channels}}
              <div class="channel {{stateClass}}" data-ch="{{id}}">
                <div class="lbl">{{label}}</div>
                <div class="gauge"><div class="fill" style="width:{{pct}}%"></div></div>
                <div class="val">{{displayValue}}</div>
              </div>
              {{/each}}

              <div class="diag-head droid-registry-head">Chassis Registry</div>
              <div class="droid-registry-card">
                <div><span class="k">FIRM</span> <span class="v">DROID-OS 9.3.1</span></div>
                <div><span class="k">FRAME</span> <span class="v">CX-7 BIPED</span></div>
                <div><span class="k">DEG</span> <span class="v">1ST · AUTONOMOUS</span></div>
                <div><span class="k">OWNER</span> <span class="v">UNASSIGNED</span></div>
              </div>
            </div>

            <div class="hero">
              <div class="ring">
                <svg class="r-outer" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <circle cx="100" cy="100" r="94" opacity="0.25"></circle>
                  <circle cx="100" cy="100" r="94" stroke-dasharray="2 6" opacity="0.7"></circle>
                  <circle cx="100" cy="100" r="94" stroke-dasharray="30 550" stroke-width="2" opacity="0.9"></circle>
                </svg>
                <svg class="r-mid" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <circle cx="100" cy="100" r="74" opacity="0.3"></circle>
                  <path d="M100 26 L100 34 M174 100 L166 100 M100 174 L100 166 M26 100 L34 100" stroke-width="2"></path>
                  <circle cx="100" cy="26" r="3" fill="currentColor"></circle>
                  <circle cx="174" cy="100" r="2" fill="currentColor"></circle>
                </svg>
                <svg class="r-inner" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <circle cx="100" cy="100" r="54" opacity="0.5"></circle>
                  <path d="M100 46 L110 54 L100 62 L90 54 Z" fill="currentColor" opacity="0.6"></path>
                  <circle cx="100" cy="100" r="54" stroke-dasharray="1 4" opacity="0.5"></circle>
                </svg>
                <div class="core" data-role="core-glyph">{{coreGlyph}}</div>
                <div class="scan"></div>
              </div>

              <div class="status">
                <div class="label" data-role="status-label">{{statusLabel}}</div>
                <div class="msg" data-role="status-msg">{{statusMessage}}</div>
                <div class="glyph-src" data-role="status-src">{{statusSource}}</div>
              </div>

              <div class="loader-block">
                <div class="loader-row">
                  <span>Progress</span>
                  <span class="pct" data-role="intro-progress-percent">{{progressPercent}}%</span>
                </div>
                <div class="loader-bar">
                  <div class="loader-fill" style="width:{{progressPercent}}%" data-role="loader-fill"></div>
                </div>
                <div class="loader-row loader-row--subtle">
                  <span data-role="current-task">{{currentTask}}</span>
                  <span data-role="task-count">{{taskCount}}</span>
                </div>
              </div>

              <div class="translate {{#if isTranslating}}on{{/if}}" data-role="translate-zone">
                <span class="lbl">{{translationLabel}}</span>
                <span class="src" data-role="trans-src">{{translationSource}}</span>
                <span class="arrow">▸</span>
                <span class="dst" data-role="trans-dst">{{translationTarget}}</span>
              </div>
            </div>

            <div class="stream">
              <div class="diag-head">POST Log // Stream</div>
              <div class="log" data-role="boot-log">
                {{#each logLines}}
                <div class="log-line">
                  <span class="t">[{{time}}]</span><span class="{{tagClass}}">[{{tag}}]</span>
                  <span class="txt">{{text}}</span>
                </div>
                {{/each}}
              </div>

              <div class="diag-head droid-process-head">Active Process</div>
              <div class="droid-process-card">
                <div><span class="k">pid:</span> <span class="v">0x0C0D · droid.assemble</span></div>
                <div><span class="k">cpu:</span> <span class="v pos">12%</span></div>
                <div><span class="k">mem:</span> <span class="v">48M / 512M</span></div>
                <div><span class="k">pkts:</span> <span class="v">0</span></div>
                <div><span class="k">warn:</span> <span class="v zero">0</span></div>
                <div><span class="k">err:</span> <span class="v neg">0</span></div>
              </div>

              <div class="identity {{#if showIdentity}}on{{/if}}" data-role="identity-card">
                <div class="bust">
                  <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
                    <rect x="28" y="18" width="44" height="32" rx="4"></rect>
                    <rect x="36" y="26" width="10" height="10" rx="1"></rect>
                    <rect x="54" y="26" width="10" height="10" rx="1"></rect>
                    <circle cx="41" cy="31" r="2" fill="currentColor"></circle>
                    <circle cx="59" cy="31" r="2" fill="currentColor"></circle>
                    <path d="M34 42 L66 42" stroke-dasharray="2 3"></path>
                    <path d="M22 54 L78 54"></path>
                    <path d="M26 58 L26 84 L74 84 L74 58"></path>
                    <path d="M38 60 L38 80 M50 60 L50 80 M62 60 L62 80" stroke-dasharray="1 2" opacity="0.6"></path>
                    <circle cx="50" cy="10" r="3"></circle>
                    <path d="M50 13 L50 18"></path>
                  </svg>
                </div>

                <div class="info">
                  <span class="badge">{{identity.badge}}</span>
                  <div class="name">{{identity.name}}</div>
                  <div class="sub">{{identity.sub}}</div>
                  <div class="meta-grid">
                    {{#each identity.meta}}
                    <div class="m">
                      <div class="k">{{key}}</div>
                      <div class="v">{{value}}</div>
                    </div>
                    {{/each}}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="actions">
            <div class="hint">
              <kbd>SPACE</kbd> skip ·
              <kbd>ENTER</kbd> continue ·
              <kbd>R</kbd> replay
            </div>
            <div class="intro-action-row">
              <button class="btn ghost" type="button" data-action="skip-intro">Skip Boot</button>
              <button class="btn" type="button" data-action="next-step" {{#if continueDisabled}}disabled{{/if}}>{{continueLabel}}</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{{else}}
{{!-- ========================================================================
     STANDARD/DROID SPLASH VARIANT (original intro framework)
     ======================================================================== --}}
<div class="prog-intro-surface swse-ui-shell swse-splash-screen prog-intro-surface--{{introVariant}} {{#if localizedMode}}prog-intro-surface--localized{{else}}prog-intro-surface--foreign{{/if}}">
  {{!-- OS Header Bar --}}
  <div class="prog-intro-header">
    <div class="prog-intro-header__left">
      <span class="prog-intro-system-name">{{systemName}}</span>
    </div>
    <div class="prog-intro-header__center">
      <span class="prog-intro-time">{{currentTime}}</span>
    </div>
    <div class="prog-intro-header__right">
      <div class="prog-intro-signal">
        {{#each signalBars}}
          <span class="prog-intro-signal__bar {{#if this.active}}active{{/if}}"></span>
        {{/each}}
      </div>
      <span class="prog-intro-battery">{{battery}}%</span>
    </div>
  </div>

  {{!-- Main Panel --}}
  <div class="prog-intro-panel">
    {{!-- Scanline Overlay --}}
    <div class="prog-intro-scanlines"></div>

    {{!-- Text Display Area --}}
    <div class="prog-intro-text-area">
      {{#if currentStepData}}
        <div class="prog-intro-text-container">
          {{!-- Label (English) --}}
          {{!-- STABLE DOM: Engine can bind to label for state updates --}}
          <div class="prog-intro-label prog-intro-label--{{currentStepData.state}}" data-role="intro-label">
            {{currentStepData.label}}
          </div>

          {{!-- Aurabesh Text (Diegetic) --}}
          {{!-- STABLE DOM: Engine can bind to aurabesh and cursor --}}
          <div class="prog-intro-aurabesh prog-intro-aurabesh--{{currentStepData.state}}" data-role="intro-aurabesh-container">
            <span class="prog-intro-aurabesh__text" data-role="intro-aurabesh">{{currentStepData.aurabesh}}</span>
            {{#if (eq currentStepData.state "processing")}}
              <span class="prog-intro-cursor prog-intro-cursor--blink" data-role="intro-cursor"></span>
            {{/if}}
          </div>

          {{!-- Status Indicator --}}
          {{!-- STABLE DOM: Engine binds to status for state updates --}}
          <div class="prog-intro-status prog-intro-status--{{currentStepData.state}} {{#if currentStepData.localized}}prog-intro-status--localized{{else}}prog-intro-status--foreign{{/if}}" data-role="intro-status">
            <span class="prog-intro-status__icon" data-role="intro-status-icon">{{currentStepData.statusIcon}}</span>
            <span class="prog-intro-status__text" data-role="intro-status-text">{{currentStepData.statusText}}</span>
          </div>

          {{!-- Microlabel (Diegetic System Messages) --}}
          {{!-- STABLE DOM: Engine binds to this for system status updates --}}
          <div class="prog-intro-microlabel" data-role="intro-microlabel">
            {{currentStepData.microlabel}}
          </div>
        </div>
      {{/if}}

      {{!-- Translation Text (hidden by default, shown during TRANSLATING phase) --}}
      {{!-- STABLE DOM: Always mounted, hidden/shown via classes for engine binding --}}
      <div class="prog-intro-text-container prog-intro-translation-container {{#unless isTranslating}}hidden{{/unless}}"
           data-role="intro-translation"
           style="{{#if isTranslating}}display: flex{{else}}display: none{{/if}}">
        <div class="prog-intro-label prog-intro-label--success" data-role="intro-status-label">TRANSLATING</div>
        <div class="prog-intro-translation-text">
          <div class="prog-intro-translation__content" data-role="intro-translation-text">{{translatedText}}</div>
        </div>
        <div class="prog-intro-source-text" data-role="intro-source-text" style="display: none;">
          <span class="prog-intro-aurabesh" data-role="intro-aurabesh">{{currentStepData.aurabesh}}</span>
        </div>
      </div>
    </div>

    {{!-- Progress Bar --}}
    {{!-- STABLE DOM: Engine binds to these for direct progress updates --}}
    <div class="prog-intro-progress-container">
      {{!-- Segmented progress bar (Phase 1+ boot sequence) --}}
      <div class="prog-intro-progress-bar prog-intro-progress-bar--segmented">
        {{#each progressSegments}}
          <div class="prog-intro-segment {{#if this.active}}active{{/if}}" data-role="intro-segment"></div>
        {{/each}}
      </div>
      {{!-- Smooth fill (backward compatibility, hidden) --}}
      <div class="prog-intro-progress-bar prog-intro-progress-bar--smooth" style="display: none;">
        <div class="prog-intro-progress-fill" style="width: {{progressPercent}}%" data-role="intro-progress-fill"></div>
      </div>
      {{!-- Nested node for intro-progress-percent selector (Phase 1 contract) --}}
      <div class="prog-intro-progress-text prog-intro-progress-text--neutral" data-role="intro-progress-label">
        <span data-role="intro-progress-percent">{{progressPercent}}%</span>
      </div>
    </div>


  </div>

  {{!-- Footer: Action Buttons (shown when sequence complete) --}}
  {{!-- Three-button grid: Go Back / Proceed / Choose a Pregenerated Character --}}
  {{#if sequenceComplete}}
    <div class="prog-intro-footer prog-intro-footer--fade-in">
      <div class="prog-intro-actions">
        {{!-- Go Back: uses existing previous-step handler --}}
        <button class="prog-intro-btn prog-btn prog-btn--primary"
                type="button"
                data-action="previous-step"
                title="Close character generation and return to character sheet" aria-label="Close character generation and return to character sheet">
          <i class="fas fa-arrow-left"></i>
          Go Back
        </button>

        {{!-- Proceed: uses existing next-step handler --}}
        <button class="prog-intro-btn prog-btn prog-btn--primary"
                type="button"
                data-action="next-step"
                title="{{continueTitle}}" aria-label="{{continueTitle}}">
          <i class="fas fa-arrow-right"></i>
          {{continueLabel}}
        </button>

        {{#if showPregenerated}}
        {{!-- Choose a Pregenerated Character: bound directly in intro-step.js --}}
        <button class="prog-intro-btn prog-btn prog-btn--primary"
                type="button"
                data-role="intro-pick-profile"
                title="Choose a pregenerated character" aria-label="Choose a pregenerated character">
          <i class="fas fa-scroll"></i>
          Pick Galactic Profile
        </button>
        {{/if}}
      </div>
    </div>
  {{else}}
    <div class="prog-intro-footer">
      <div class="prog-intro-footer-placeholder"></div>
    </div>
  {{/if}}
</div>
{{/if}}
