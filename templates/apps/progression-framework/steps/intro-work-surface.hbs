<div class="prog-intro-surface swse-ui-shell swse-splash-screen">
  {{!-- OS Header Bar --}}
  <div class="prog-intro-header">
    <div class="prog-intro-header__left">
      <span class="prog-intro-system-name">{{systemName}}</span>
    </div>
    <div class="prog-intro-header__center">
      <span class="prog-intro-time">{{currentTime}}</span>
    </div>
    <div class="prog-intro-header__right">
      <div class="prog-intro-signal">
        {{#each signalBars}}
          <span class="prog-intro-signal__bar {{#if this.active}}active{{/if}}"></span>
        {{/each}}
      </div>
      <span class="prog-intro-battery">{{battery}}%</span>
    </div>
  </div>

  {{!-- Main Panel --}}
  <div class="prog-intro-panel">
    {{!-- Scanline Overlay --}}
    <div class="prog-intro-scanlines"></div>

    {{!-- Text Display Area --}}
    <div class="prog-intro-text-area">
      {{#if currentStepData}}
        <div class="prog-intro-text-container">
          {{!-- Label (English) --}}
          {{!-- STABLE DOM: Engine can bind to label for state updates --}}
          <div class="prog-intro-label prog-intro-label--{{currentStepData.state}}" data-role="intro-label">
            {{currentStepData.label}}
          </div>

          {{!-- Aurabesh Text (Diegetic) --}}
          {{!-- STABLE DOM: Engine can bind to aurabesh and cursor --}}
          <div class="prog-intro-aurabesh prog-intro-aurabesh--{{currentStepData.state}}" data-role="intro-aurabesh-container">
            <span class="prog-intro-aurabesh__text" data-role="intro-aurabesh">{{currentStepData.aurabesh}}</span>
            {{#if (eq currentStepData.state "processing")}}
              <span class="prog-intro-cursor prog-intro-cursor--blink" data-role="intro-cursor"></span>
            {{/if}}
          </div>

          {{!-- Status Indicator --}}
          {{!-- STABLE DOM: Engine binds to status for state updates --}}
          <div class="prog-intro-status prog-intro-status--{{currentStepData.state}}" data-role="intro-status">
            {{#if (eq currentStepData.state "processing")}}
              <span class="prog-intro-status__icon" data-role="intro-status-icon">⊙</span>
              <span class="prog-intro-status__text" data-role="intro-status-text">PROCESSING</span>
            {{else if (eq currentStepData.state "success")}}
              <span class="prog-intro-status__icon" data-role="intro-status-icon">✓</span>
              <span class="prog-intro-status__text" data-role="intro-status-text">SUCCESS</span>
            {{else if (eq currentStepData.state "unknown")}}
              <span class="prog-intro-status__icon" data-role="intro-status-icon">!</span>
              <span class="prog-intro-status__text" data-role="intro-status-text">UNKNOWN</span>
            {{else}}
              <span class="prog-intro-status__icon" data-role="intro-status-icon">○</span>
              <span class="prog-intro-status__text" data-role="intro-status-text">WAITING</span>
            {{/if}}
          </div>

          {{!-- Microlabel (Diegetic System Messages) --}}
          {{!-- STABLE DOM: Engine binds to this for system status updates --}}
          <div class="prog-intro-microlabel" data-role="intro-microlabel">
            > initializing system...
          </div>
        </div>
      {{/if}}

      {{!-- Translation Text (hidden by default, shown during TRANSLATING phase) --}}
      {{!-- STABLE DOM: Always mounted, hidden/shown via classes for engine binding --}}
      <div class="prog-intro-text-container {{#unless isTranslating}}hidden{{/unless}}"
           data-role="intro-translation"
           style="{{#if isTranslating}}display: block{{else}}display: none{{/if}}">
        <div class="prog-intro-label prog-intro-label--success" data-role="intro-status-label">TRANSLATING</div>
        <div class="prog-intro-translation-text">
          <span class="prog-intro-translation__content" data-role="intro-translation-text">{{translatedText}}</span>
        </div>
        <div class="prog-intro-source-text" data-role="intro-source-text" style="display: none;">
          <span class="prog-intro-aurabesh" data-role="intro-aurabesh">{{currentStepData.aurabesh}}</span>
        </div>
      </div>
    </div>

    {{!-- Progress Bar --}}
    {{!-- STABLE DOM: Engine binds to these for direct progress updates --}}
    <div class="prog-intro-progress-container">
      {{!-- Segmented progress bar (Phase 1+ boot sequence) --}}
      <div class="prog-intro-progress-bar prog-intro-progress-bar--segmented">
        {{#each progressSegments}}
          <div class="prog-intro-segment {{#if this.active}}active{{/if}}" data-role="intro-segment"></div>
        {{/each}}
      </div>
      {{!-- Smooth fill (backward compatibility, hidden) --}}
      <div class="prog-intro-progress-bar prog-intro-progress-bar--smooth" style="display: none;">
        <div class="prog-intro-progress-fill" style="width: {{progressPercent}}%" data-role="intro-progress-fill"></div>
      </div>
      {{!-- Nested node for intro-progress-percent selector (Phase 1 contract) --}}
      <div class="prog-intro-progress-text" data-role="intro-progress-label">
        <span data-role="intro-progress-percent">{{stepNumber}} / {{bootSequenceLength}}</span>
      </div>
    </div>

    {{!-- Identity Block (shown after sequence complete) --}}
    {{#if sequenceComplete}}
      <div class="prog-intro-identity-block prog-intro-identity-block--fade-in">
        <div class="prog-intro-identity-label">WELCOME</div>
        <div class="prog-intro-identity-subtext">Ready to begin character registration.</div>
      </div>
    {{/if}}
  </div>

  {{!-- Footer: Continue Button (shown when sequence complete) --}}
  {{!-- data-action="next-step" delegates to shell._onNextStep via ApplicationV2 action system --}}
  {{#if sequenceComplete}}
    <div class="prog-intro-footer prog-intro-footer--fade-in">
      <button class="prog-intro-continue-btn prog-btn prog-btn--primary"
              type="button"
              data-action="next-step">
        <i class="fas fa-arrow-right"></i>
        Continue
      </button>
    </div>
  {{else}}
    <div class="prog-intro-footer">
      <div class="prog-intro-footer-placeholder"></div>
    </div>
  {{/if}}
</div>
