{{!-- Talent Tree Graph (Stage 2) --}}
<div class="talent-work-surface talent-stage-graph">
  <div class="talent-graph-header">
    <div class="talent-graph-header__title-wrap">
      <h3 class="talent-graph-header__title">
        <i class="fa-solid fa-diagram-project"></i>
        {{selectedTreeName}}
      </h3>
      <p class="talent-graph-header__subtitle">Select a node to inspect it. Double-click a legal node or use the detail rail to choose it.</p>
    </div>
    <button class="talent-graph-header__exit-btn" data-role="exit-tree" type="button" title="Return to tree browser">
      <i class="fa-solid fa-arrow-left"></i> Back to Trees
    </button>
  </div>

  <div class="talent-graph-container">
    <div class="talent-graph-viewport">
      <div class="talent-tree-graph-container talent-graph-canvas" data-graph-id="{{selectedTreeId}}"></div>
    </div>
  </div>

  <div class="talent-graph-legend">
    <div class="talent-legend-item">
      <span class="talent-legend-swatch talent-legend-swatch--owned"></span>
      <span class="talent-legend-label">Purchased</span>
    </div>
    <div class="talent-legend-item">
      <span class="talent-legend-swatch talent-legend-swatch--default"></span>
      <span class="talent-legend-label">Default</span>
    </div>
    <div class="talent-legend-item">
      <span class="talent-legend-swatch talent-legend-swatch--available"></span>
      <span class="talent-legend-label">Meets Prereq</span>
    </div>
    <div class="talent-legend-item">
      <span class="talent-legend-swatch talent-legend-swatch--blocked"></span>
      <span class="talent-legend-label">Does Not Meet Prereq</span>
    </div>
  </div>
</div>
