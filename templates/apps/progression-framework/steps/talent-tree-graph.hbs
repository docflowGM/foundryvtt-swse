{{!-- Talent Planner (Stage 2) --}}
<div class="talent-work-surface talent-stage-graph talent-planner-stage talent-planner-stage--{{viewMode}} talent-holomap-stage {{visualThemeClass}}">
  <div class="talent-graph-header talent-planner-header talent-planner-header--holomap">
    <div class="talent-graph-header__title-wrap">
      <div class="talent-browser-header__eyebrow">// ACTIVE TREE</div>
      <h3 class="talent-graph-header__title">
        <span class="talent-graph-header__sigil" aria-hidden="true">{{visualIcon}}</span>
        <span>{{selectedTreeName}}</span>
      </h3>
      <p class="talent-graph-header__subtitle">
{{visualSignal}} · {{visualMotion}} · Drag the map to move. Scroll to zoom. Legal nodes glow when they can be activated.
      </p>
    </div>

    <div class="talent-planner-controls" role="toolbar" aria-label="Talent planner controls">
      <button class="talent-planner-control {{#if (eq viewMode "both")}}is-active{{/if}}" data-action="set-talent-view" data-view-mode="both" type="button">
        <i class="fa-solid fa-table-columns"></i> Both
      </button>
      <button class="talent-planner-control {{#if (eq viewMode "list")}}is-active{{/if}}" data-action="set-talent-view" data-view-mode="list" type="button">
        <i class="fa-solid fa-list"></i> List
      </button>
      <button class="talent-planner-control {{#if (eq viewMode "map")}}is-active{{/if}}" data-action="set-talent-view" data-view-mode="map" type="button">
        <i class="fa-solid fa-sitemap"></i> Map
      </button>
      <button class="talent-planner-control" data-action="fit-talent-tree" type="button" title="Fit the whole tree in the map panel">
        <i class="fa-solid fa-up-right-and-down-left-from-center"></i> Fit
      </button>
      <button class="talent-graph-header__exit-btn" data-action="exit-tree" type="button" title="Return to tree browser">
        <i class="fa-solid fa-arrow-left"></i> Back to Trees
      </button>
    </div>
  </div>

  <div class="talent-planner-grid talent-planner-grid--holomap">
    <section class="talent-choice-panel talent-choice-panel--holomap" data-prog-scroll-key="talent-choice-panel" aria-label="Talent choices">
      <div class="talent-choice-panel__header">
        <div>
          <h4>Available Choices</h4>
          <p>{{slotProgress.progressLabel}} · {{slotProgress.remainingLabel}}{{#if recommendedTalentCount}} · {{recommendedTalentCount}} mentor suggestion{{#unless (eq recommendedTalentCount 1)}}s{{/unless}}{{/if}}</p>
        </div>
        {{#if selectedTalent}}
        <span class="talent-choice-panel__selected-pill"><i class="fa-solid fa-diamond"></i> {{selectedTalent.name}}</span>
        {{/if}}
      </div>

      {{#if availableTalents}}
      <div class="talent-choice-section talent-choice-section--available">
        <h5><i class="fa-solid fa-circle-check"></i> Legal Activations</h5>
        <div class="talent-choice-list" data-prog-scroll-key="talent-choice-list">
          {{#each availableTalents}}
          <article class="talent-choice-card {{#if isFocused}}is-focused{{/if}} {{#if isSelected}}is-selected{{/if}}"
                   data-action="focus-talent"
                   data-talent-id="{{id}}"
                   tabindex="0"
                   role="button"
                   aria-label="Inspect {{name}}">
            <div class="talent-choice-card__main">
              <h6>{{name}}</h6>
              <p>{{summary}}</p>
              <div class="talent-choice-card__meta">
                {{#if isSuggestedTalent}}<span class="talent-choice-badge talent-choice-badge--suggested"><i class="fa-solid fa-star"></i> {{recommendationLabel}}</span>{{/if}}
                <span class="talent-choice-badge talent-choice-badge--available">Legal</span>
                {{#if isSelected}}<span class="talent-choice-badge talent-choice-badge--selected">Pending</span>{{/if}}
                {{#if chosenElsewhere}}<span class="talent-choice-badge talent-choice-badge--locked">Already Picked</span>{{/if}}
                {{#if isActorOwned}}<span class="talent-choice-badge talent-choice-badge--locked">Known</span>{{/if}}
              </div>
              {{#if recommendationReason}}
              <p class="talent-choice-card__recommendation">{{recommendationReason}}</p>
              {{/if}}
            </div>
            <button class="talent-choice-card__choose" data-action="commit-item" data-item-id="{{id}}" type="button">
              {{#if isSelected}}Deselect{{else}}Activate{{/if}}
            </button>
          </article>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if lockedTalents}}
      <details class="talent-choice-section talent-choice-section--locked" {{#unless availableTalents}}open{{/unless}}>
        <summary class="talent-choice-section__summary"><i class="fa-solid fa-lock"></i> Locked / Future <span>{{lockedTalentCount}}</span></summary>
        <div class="talent-choice-list" data-prog-scroll-key="talent-locked-list">
          {{#each lockedTalents}}
          <article class="talent-choice-card talent-choice-card--locked {{#if isFocused}}is-focused{{/if}}"
                   data-action="focus-talent"
                   data-talent-id="{{id}}"
                   tabindex="0"
                   role="button"
                   aria-label="Inspect locked talent {{name}}">
            <div class="talent-choice-card__main">
              <h6>{{name}}</h6>
              <p>{{lockReason}}</p>
              <div class="talent-choice-card__meta">
                <span class="talent-choice-badge talent-choice-badge--locked">Locked</span>
              </div>
            </div>
            <button class="talent-choice-card__choose" data-action="commit-item" data-item-id="{{id}}" type="button" disabled>
              Locked
            </button>
          </article>
          {{/each}}
        </div>
      </details>
      {{/if}}

      {{#unless availableTalents}}
        {{#unless lockedTalents}}
        <div class="talent-empty-state talent-empty-state--compact talent-empty-state--holomap">
          <i class="fa-solid fa-hexagon-exclamation"></i>
          <p>No talents matched your current filters in this tree.</p>
        </div>
        {{/unless}}
      {{/unless}}
    </section>

    <section class="talent-map-panel talent-map-panel--holomap" data-prog-scroll-key="talent-map-panel" aria-label="Talent tree map">
      <div class="talent-map-panel__header">
        <div>
          <h4>Tree Holomap</h4>
          <p>Drag to move · Scroll to zoom · Hover to reveal prerequisite flow · Double-click a legal node to activate.</p>
        </div>
        <button class="talent-planner-control" data-action="center-talent-node" type="button" title="Refocus the selected or inspected node">
          <i class="fa-solid fa-crosshairs"></i> Center
        </button>
      </div>

      <div class="talent-graph-container talent-graph-container--holomap">
        <div class="talent-graph-viewport talent-graph-viewport--holomap" data-prog-scroll-key="talent-graph-viewport" data-talent-graph-viewport>
          <div class="talent-tree-graph-container talent-graph-canvas talent-graph-canvas--holomap" data-graph-id="{{selectedTreeId}}"></div>
        </div>
      </div>

      <div class="talent-graph-legend talent-graph-legend--holomap">
        <div class="talent-legend-item">
          <span class="talent-legend-swatch talent-legend-swatch--owned"></span>
          <span class="talent-legend-label">Known</span>
        </div>
        <div class="talent-legend-item">
          <span class="talent-legend-swatch talent-legend-swatch--available"></span>
          <span class="talent-legend-label">Legal</span>
        </div>
        <div class="talent-legend-item">
          <span class="talent-legend-swatch talent-legend-swatch--pending"></span>
          <span class="talent-legend-label">Pending</span>
        </div>
        <div class="talent-legend-item">
          <span class="talent-legend-swatch talent-legend-swatch--blocked"></span>
          <span class="talent-legend-label">Locked</span>
        </div>
      </div>
    </section>
  </div>
</div>
