<div class="prog-l1-survey">
  <div class="prog-l1-survey__intro">
    <h2 class="prog-l1-survey__title">Intent Survey</h2>
    <p class="prog-l1-survey__subtitle">
      {{#if surveyDefinition}}
        {{surveyDefinition.classDisplayName}} path · short answers only.
      {{else}}
        The mentor is still reading the shape of your path.
      {{/if}}
    </p>
    <div class="prog-l1-survey__progress-row">
      <span class="prog-chip">Answered {{answeredCount}} / {{totalQuestions}}</span>
      {{#if remainingCount}}<span class="prog-chip prog-chip--dim">{{remainingCount}} remaining</span>{{else}}<span class="prog-chip prog-chip--positive">Survey complete</span>{{/if}}
    </div>
  </div>

  {{#if activeQuestion}}
    <section class="prog-l1-survey__question prog-l1-survey__question--active">
      <div class="prog-l1-survey__question-kicker">Question {{activeQuestionNumber}} of {{totalQuestions}}</div>
      <h3 class="prog-l1-survey__q-title">{{activeQuestion.text}}</h3>
      <div class="prog-l1-survey__options">
        {{#each activeQuestion.options}}
        <label class="prog-l1-survey__option {{#if (eq ../activeQuestion.selected this.id)}}prog-l1-survey__option--selected{{/if}}">
          <input type="radio" name="survey-{{../activeQuestion.id}}" value="{{this.id}}" data-survey-question-id data-question-id="{{../activeQuestion.id}}" {{#if (eq ../activeQuestion.selected this.id)}}checked{{/if}}>
          <span class="prog-l1-survey__option-body">
            <span class="prog-l1-survey__option-label">{{this.label}}</span>
                      </span>
        </label>
        {{/each}}
      </div>
    </section>
  {{/if}}

  {{#if topMatches.length}}
  <div class="prog-l1-survey__matches">
    <div class="prog-l1-survey__matches-title">Current mentor read</div>
    <div class="prog-l1-survey__match-list">
      {{#each topMatches}}
      <div class="prog-l1-survey__match">
        <div class="prog-l1-survey__match-name">{{this.archetype.name}}</div>
        <div class="prog-l1-survey__match-note">{{this.archetype.notes}}</div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}
</div>
