<div class="prog-l1-survey-shell">
  <section class="prog-l1-survey-stage">
    <div class="prog-l1-survey-stage__mentor-frame">
      <div class="prog-l1-survey-stage__mentor-lines"></div>
      <div class="prog-l1-survey-stage__mentor-portrait">
        {{{mentorPortraitMarkup}}}
        <div class="prog-l1-survey-stage__mentor-scan"></div>
        <div class="prog-l1-survey-stage__mentor-nameplate">
          <span class="prog-l1-survey-stage__mentor-name">{{mentorName}}</span>
          {{#if mentorTitle}}<span class="prog-l1-survey-stage__mentor-title">{{mentorTitle}}</span>{{/if}}
        </div>
      </div>
    </div>

    <div class="prog-l1-survey-stage__dialogue-panel" data-phase="{{surveyPhase}}">
      <div class="prog-l1-survey-stage__header">
        <div>
          <div class="prog-l1-survey-stage__eyebrow">Level 1 Survey</div>
          <h2 class="prog-l1-survey-stage__title">{{#if surveyDefinition}}{{surveyDefinition.classDisplayName}} Intent Read{{else}}Intent Read{{/if}}</h2>
          <div class="prog-l1-survey-stage__subtitle">
            {{answeredCount}} / {{totalQuestions}} answered
            {{#if remainingCount}} · {{remainingCount}} remaining{{else}} · survey complete{{/if}}
          </div>
        </div>

        {{#if progressDots.length}}
        <div class="prog-l1-survey-stage__progress" aria-label="Survey progress">
          {{#each progressDots}}
          <span class="prog-l1-survey-stage__progress-dot {{#if isDone}}is-done{{/if}} {{#if isActive}}is-active{{/if}}"></span>
          {{/each}}
        </div>
        {{/if}}
      </div>

      {{#if (eq surveyPhase "intro")}}
      <div class="prog-l1-survey-stage__dialogue-text is-intro" data-l1-survey-dialogue-text>{{introText}}</div>
      <div class="prog-l1-survey-stage__command-row">
        <button type="button" class="swse-btn swse-ui-button swse-btn--advance-ready prog-l1-survey-stage__command" data-action="survey-start">
          Begin Survey
        </button>
      </div>
      {{/if}}

      {{#if (eq surveyPhase "question")}}
      <div class="prog-l1-survey-stage__question-block">
        <div class="prog-l1-survey-stage__question-kicker">Question {{activeQuestionNumber}} of {{totalQuestions}}</div>
        <div class="prog-l1-survey-stage__dialogue-text" data-l1-survey-dialogue-text>{{promptText}}</div>
      </div>
      <div class="prog-l1-survey-stage__choices">
        {{#each activeQuestion.options}}
        <button type="button"
                class="prog-l1-survey-stage__choice"
                data-action="survey-choose"
                data-question-id="{{../activeQuestion.id}}"
                data-option-id="{{this.id}}">
          <span class="prog-l1-survey-stage__choice-index">{{this.displayIndex}}</span>
          <span class="prog-l1-survey-stage__choice-copy">
            <span class="prog-l1-survey-stage__choice-label">{{this.label}}</span>
            {{#if this.detailTags.length}}
            <span class="prog-l1-survey-stage__choice-tags">
              {{#each this.detailTags}}
              <span class="prog-l1-survey-stage__choice-tag">{{this}}</span>
              {{/each}}
            </span>
            {{/if}}
          </span>
        </button>
        {{/each}}
      </div>
      {{/if}}

      {{#if (eq surveyPhase "response")}}
      <div class="prog-l1-survey-stage__question-block">
        <div class="prog-l1-survey-stage__question-kicker">Question {{activeQuestionNumber}} of {{totalQuestions}}</div>
        <div class="prog-l1-survey-stage__dialogue-text" data-l1-survey-dialogue-text>{{responseText}}</div>
      </div>

      {{#if selectedOption}}
      <div class="prog-l1-survey-stage__response-card">
        <div class="prog-l1-survey-stage__response-label">Your answer</div>
        <div class="prog-l1-survey-stage__response-choice">{{selectedOption.label}}</div>
        {{#if selectedOption.detailTags.length}}
        <div class="prog-l1-survey-stage__response-tags">
          {{#each selectedOption.detailTags}}
          <span class="prog-l1-survey-stage__choice-tag">{{this}}</span>
          {{/each}}
        </div>
        {{/if}}
      </div>
      {{/if}}

      <div class="prog-l1-survey-stage__command-row">
        {{#if (gt activeQuestionNumber 1)}}
        <button type="button" class="swse-btn swse-ui-button swse-btn--secondary prog-l1-survey-stage__command" data-action="survey-previous-question">
          Go Back
        </button>
        {{/if}}
        <button type="button" class="swse-btn swse-ui-button swse-btn--secondary prog-l1-survey-stage__command" data-action="survey-change-answer">
          Change Answer
        </button>
        <button type="button" class="swse-btn swse-ui-button swse-btn--advance-ready prog-l1-survey-stage__command" data-action="survey-continue">
          {{#if remainingCount}}Next Question{{else}}Complete Survey{{/if}}
        </button>
      </div>
      {{/if}}

      {{#if (eq surveyPhase "complete")}}
      <div class="prog-l1-survey-stage__dialogue-text is-complete" data-l1-survey-dialogue-text>{{completionText}}</div>

      {{#if topMatches.length}}
      <div class="prog-l1-survey-stage__reads">
        <div class="prog-l1-survey-stage__reads-title">Current mentor read</div>
        <div class="prog-l1-survey-stage__reads-list">
          {{#each topMatches}}
          <article class="prog-l1-survey-stage__read-card">
            <div class="prog-l1-survey-stage__read-name">{{this.archetype.name}}</div>
            <div class="prog-l1-survey-stage__read-note">{{this.archetype.notes}}</div>
          </article>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if completionTags.length}}
      <div class="prog-l1-survey-stage__completion-tags">
        {{#each completionTags}}
        <span class="prog-l1-survey-stage__choice-tag {{cssClass}}">{{label}}</span>
        {{/each}}
      </div>
      {{/if}}

      <div class="prog-l1-survey-stage__command-row">
        <button type="button" class="swse-btn swse-ui-button swse-btn--secondary prog-l1-survey-stage__command" data-action="survey-previous-question">
          Go Back
        </button>
        <button type="button" class="swse-btn swse-ui-button swse-btn--secondary prog-l1-survey-stage__command" data-action="survey-retake">
          Start Over
        </button>
        <button type="button" class="swse-btn swse-ui-button swse-btn--advance-ready prog-l1-survey-stage__command" data-action="survey-finish">
          Continue to Background
        </button>
      </div>
      {{/if}}
    </div>
  </section>
</div>
