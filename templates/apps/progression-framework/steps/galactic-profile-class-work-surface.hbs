<div class="prog-galactic-profile prog-galactic-profile--class">
  <header class="prog-profile-header">
    <div>
      <div class="eyebrow">Galactic Profile</div>
      <h2>Profile Class</h2>
      <p>Pick the training channel first. The selected class comes forward; the others recede into the holo-stack.</p>
    </div>
    <div class="prog-profile-flow">CLASS → ARCHETYPE → REVIEW</div>
  </header>

  <section class="prog-profile-class-strip" aria-label="Profile classes">
    {{#each classes}}
      <button type="button" class="prog-profile-class-card {{#if selected}}is-selected{{else}}is-dimmed{{/if}}" data-profile-class-id="{{id}}">
        <span class="holo-img holo-img--class"><img src="{{image}}" alt="{{name}}" /></span>
        <span class="class-copy"><strong>{{name}}</strong><em>{{count}} profiles</em></span>
      </button>
    {{/each}}
  </section>

  <section class="prog-profile-callout">
    <i class="fas fa-satellite-dish"></i>
    <div>
      <strong>Channel locked to shell navigation.</strong>
      <span>Continue to Archetype to choose the actual profile package.</span>
    </div>
  </section>
</div>
