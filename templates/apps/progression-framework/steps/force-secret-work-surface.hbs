{{!-- Force Secret Selection Work Surface --}}
{{!-- Shows browsable force secret cards with counts for duplicate selections --}}

<div class="prog-force-secret-browse">
  {{#if secrets.length}}
    <div class="prog-force-secret-grid" role="list">
      {{#each secrets}}
        <div class="prog-force-secret-card
                    {{#if (arrayIncludes ../committedCounts @key)}}prog-force-secret-card--selected{{/if}}"
             data-action="focus-item"
             data-item-id="{{this.id}}"
             tabindex="0" role="option"
             aria-selected="{{#if (arrayIncludes ../committedCounts @key)}}true{{else}}false{{/if}}">

          <div class="prog-force-secret-card__header">
            <h3 class="prog-force-secret-card__name">{{this.name}}</h3>
            {{#if (lookup ../committedCounts this.id)}}
              <span class="prog-force-secret-card__count-badge">
                ×{{lookup ../committedCounts this.id}}
              </span>
            {{/if}}
          </div>

          {{#if this.description}}
            <p class="prog-force-secret-card__description">
              {{truncate this.description 100}}
            </p>
          {{/if}}

          {{#if (lookup ../committedCounts this.id)}}
            <div class="prog-force-secret-card__state-hint">
              <i class="fas fa-star" aria-hidden="true"></i>
              Selected {{lookup ../committedCounts this.id}} {{plural (lookup ../committedCounts this.id) "time" "times"}}
            </div>
          {{else}}
            <div class="prog-force-secret-card__state-hint prog-force-secret-card__state-hint--available">
              <i class="fas fa-plus-circle" aria-hidden="true"></i>
              Available
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="prog-force-secret-browse__empty">
      <i class="fas fa-eye-slash" aria-hidden="true"></i>
      <p>No Force Secrets match your search or filters.</p>
    </div>
  {{/if}}
</div>
