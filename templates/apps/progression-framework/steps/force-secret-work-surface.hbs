{{!-- Force Secret Selection Work Surface --}}
{{!-- Compact category browser for Force Secrets, matching Force Power/Technique visual language. --}}

<div class="prog-force-secret-browse swse-force-selector swse-store-stage">
  <div class="feat-browser-toolbar force-secret-browser-toolbar">
    <div class="feat-browser-toolbar__left">
      {{#if hasSearchQuery}}
        <span class="feat-browser-mode-pill feat-browser-mode-pill--search">
          <i class="fa-solid fa-magnifying-glass"></i>
          Search: {{searchQueryLabel}}
        </span>
      {{else}}
        <span class="feat-browser-mode-pill">
          <i class="fa-solid {{activeCategoryIcon}}"></i>
          {{activeCategoryLabel}}
        </span>
      {{/if}}
    </div>

    <div class="feat-browser-toolbar__right">
      <button class="feat-filter-btn" data-action="reset-force-secret-browser" type="button" title="Clear search and filters">
        <i class="fa-solid fa-rotate-left"></i>
        <span>Reset</span>
      </button>
      {{#unless hasSearchQuery}}
        <button class="feat-filter-btn feat-category-collapse-toggle" data-action="toggle-force-secret-category-sidebar" type="button">
          <i class="fa-solid {{#if categorySidebarCollapsed}}fa-angles-right{{else}}fa-angles-left{{/if}}"></i>
          <span>{{#if categorySidebarCollapsed}}Show Categories{{else}}Collapse Categories{{/if}}</span>
        </button>
      {{/unless}}
    </div>
  </div>

  <section class="feat-browser force-secret-browser {{#if categorySidebarCollapsed}}feat-browser--sidebar-collapsed{{/if}} {{#if hasSearchQuery}}feat-browser--search-mode{{/if}}">
    {{#unless hasSearchQuery}}
      {{#unless categorySidebarCollapsed}}
        <aside class="feat-category-sidebar force-secret-category-sidebar" aria-label="Force Secret categories">
          <div class="feat-category-sidebar__header">
            <span>Categories</span>
            <button class="feat-category-sidebar__collapse" data-action="toggle-force-secret-category-sidebar" type="button" title="Collapse categories">
              <i class="fa-solid fa-chevron-left"></i>
            </button>
          </div>
          <div class="feat-category-list force-secret-category-list">
            {{#each categoryOptions as |category|}}
              <button class="feat-category-button force-secret-category-button {{#if category.isActive}}active{{/if}} {{#if category.isMajor}}force-secret-category-button--major{{/if}}"
                      data-action="select-force-secret-category"
                      data-category="{{category.key}}"
                      type="button">
                <span class="feat-category-button__main">
                  <i class="fa-solid {{category.icon}}"></i>
                  <span>{{category.label}}</span>
                </span>
                <span class="feat-category-button__count">{{category.totalCount}}</span>
              </button>
            {{/each}}
          </div>
        </aside>
      {{/unless}}
    {{/unless}}

    <main class="feat-results-pane force-secret-results-pane">
      {{#if hasSearchQuery}}
        <header class="feat-results-pane__header feat-results-pane__header--search">
          <div>
            <h3><i class="fa-solid fa-magnifying-glass"></i> Search Results</h3>
            <p>Matching Force Secrets.</p>
          </div>
          <span class="feat-count-badge">{{searchResultCount}}</span>
        </header>

        {{#if searchResults.length}}
          <div class="feat-compact-list feat-search-results-list force-secret-compact-list" role="list">
            {{#each searchResults as |secret|}}
              <div class="feat-compact-row force-secret-compact-row {{#if secret.isFocused}}focused{{/if}} {{#if secret.isSelected}}selected{{/if}} {{#if secret.isSuggested}}suggested{{/if}}"
                   data-secret-id="{{secret.id}}"
                   data-item-id="{{secret.id}}"
                   data-action="focus-item"
                   data-recommended="{{#if secret.isSuggested}}true{{/if}}"
                   tabindex="0"
                   role="option">
                <div class="feat-compact-row__content">
                  <div class="feat-compact-row__line feat-compact-row__line--primary">
                    <span class="feat-name">{{secret.name}}</span>
                    <span class="feat-subcategory-pill">{{secret.searchCategoryLabel}}</span>
                  </div>
                  <div class="feat-compact-row__line feat-compact-row__line--meta">
                    {{#if secret.costLabel}}<span class="feat-prereq-line"><i class="fa-solid fa-coins"></i> {{secret.costLabel}}</span>{{/if}}
                    {{#if secret.isSuggested}}<span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Recommended</span>{{/if}}
                    {{#if (lookup ../committedCounts secret.id)}}<span class="feat-owned-pill">Selected ×{{lookup ../committedCounts secret.id}}</span>{{/if}}
                  </div>
                </div>
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="feat-search-empty">
            <i class="fa-solid fa-magnifying-glass"></i>
            <span>No Force Secrets match “{{searchQueryLabel}}”.</span>
            <span class="feat-search-empty__hint">Try a secret name, cost, or category keyword.</span>
          </div>
        {{/if}}
      {{else}}
        <header class="feat-results-pane__header">
          <div>
            <h3><i class="fa-solid {{activeCategoryIcon}}"></i> {{activeCategoryLabel}}</h3>
            <p>Select a secret to inspect it in the detail rail.</p>
          </div>
          <span class="feat-count-badge">{{activeCategoryCount}}</span>
        </header>

        {{#if activeCategorySecrets.length}}
          <div class="feat-compact-list force-secret-compact-list" role="list">
            {{#each activeCategorySecrets as |secret|}}
              <div class="feat-compact-row force-secret-compact-row {{#if secret.isFocused}}focused{{/if}} {{#if secret.isSelected}}selected{{/if}} {{#if secret.isSuggested}}suggested{{/if}}"
                   data-secret-id="{{secret.id}}"
                   data-item-id="{{secret.id}}"
                   data-action="focus-item"
                   data-recommended="{{#if secret.isSuggested}}true{{/if}}"
                   tabindex="0"
                   role="option">
                <div class="feat-compact-row__content">
                  <div class="feat-compact-row__line feat-compact-row__line--primary">
                    <span class="feat-name">{{secret.name}}</span>
                    <span class="feat-subcategory-pill">{{secret.searchCategoryLabel}}</span>
                  </div>
                  <div class="feat-compact-row__line feat-compact-row__line--meta">
                    {{#if secret.costLabel}}<span class="feat-prereq-line"><i class="fa-solid fa-coins"></i> {{secret.costLabel}}</span>{{/if}}
                    {{#if secret.isSuggested}}<span class="feat-suggestion-badge"><i class="fa-solid fa-lightbulb"></i> Recommended</span>{{/if}}
                    {{#if (lookup ../committedCounts secret.id)}}<span class="feat-owned-pill">Selected ×{{lookup ../committedCounts secret.id}}</span>{{/if}}
                  </div>
                </div>
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-message feat-browser-empty prog-force-secret-browse__empty">
            <i class="fas fa-eye-slash" aria-hidden="true"></i>
            <p>No Force Secrets are available in this category.</p>
          </div>
        {{/if}}
      {{/if}}
    </main>
  </section>
</div>
