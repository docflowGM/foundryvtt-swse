<div class="prog-skills-surface">

  <div class="prog-panel prog-panel--left">
    <h3 class="prog-panel-title">{{localize "SWSE.Progression.Core.Skills.TrainingSummary"}}</h3>

    <div class="prog-skills-counter">
      <div class="prog-counter-bar">
        <div class="prog-counter-fill" style="width: {{skillProgressPercent}}%"></div>
      </div>
      <div class="prog-counter-text">
        <span class="prog-counter-value">{{trainedCount}}</span>
        <span class="prog-counter-label">{{localize "SWSE.Progression.Core.Skills.TrainedCounter" count=allowedCount}}</span>
      </div>
    </div>

    {{#if (gt trainedCount 0)}}
      <div class="prog-trained-skills-list">
        <h4 class="prog-list-title">{{localize "SWSE.Progression.Core.Skills.SelectedSkills"}}</h4>
        {{#each allSkills}}
          {{#if this.isTrained}}
            <div class="prog-trained-skill-badge">
              <i class="fas fa-check"></i> {{this.name}}
            </div>
          {{/if}}
        {{/each}}
      </div>
    {{/if}}

    {{#if (eq trainedCount allowedCount)}}
      <div class="prog-skills-complete">
        <i class="fas fa-star"></i> {{localize "SWSE.Progression.Core.Skills.SlotsFilled"}}
      </div>
    {{else}}
      <div class="prog-skills-remaining">
        {{localize "SWSE.Progression.Core.Skills.SlotsRemaining" count=remainingSkillSlots}}
      </div>
    {{/if}}
  </div>

  <div class="prog-panel prog-panel--center">
    <h3 class="prog-panel-title">{{localize "SWSE.Progression.Core.Skills.SelectYourSkills"}}</h3>

    <p class="prog-help-text">
      {{localize "SWSE.Progression.Core.Skills.HelpTrain" count=allowedCount}}
      {{localize "SWSE.Progression.Core.Skills.HelpLegalOnly"}}
    </p>

    {{#if isFallbackFullChart}}
      <div class="prog-skills-status prog-skills-status--warning">
        {{localize "SWSE.Progression.Core.Skills.FallbackWarning"}}
      </div>
    {{else}}
      <div class="prog-skills-status prog-skills-status--info">
        {{localize "SWSE.Progression.Core.Skills.AvailableStatus" count=availableSkillCount}}
      </div>
    {{/if}}

    {{#if (gt allSkills.length 0)}}
      <div class="prog-skills-list">
        {{#each allSkills}}
          {{#if (or this.alwaysVisible this.available)}}
            <div class="prog-skill-row {{#if this.isTrained}}trained{{/if}} {{#if (eq ../focusedSkillId this.id)}}is-focused{{/if}}"
                 data-skill-row="{{this.key}}"
                 data-item-id="{{this.id}}"
                 data-action="focus-item"
                 role="button"
                 tabindex="0">

              <div class="prog-skill-info">
                <div class="prog-skill-name-wrap">
                  <div class="prog-skill-name">{{this.name}}</div>
                  {{#if this.isTrained}}
                    <span class="prog-skill-state-chip">{{localize "SWSE.Progression.Core.Skills.Trained"}}</span>
                  {{/if}}
                </div>

                <div class="prog-skill-tags">
                  {{#if this.isClassSkill}}
                    <span class="prog-skill-tag prog-skill-tag--class">{{localize "SWSE.Progression.Core.Skills.Class"}}</span>
                  {{/if}}

                  {{#if this.isBackgroundSkill}}
                    <span class="prog-skill-tag prog-skill-tag--background">{{localize "SWSE.Progression.Core.Skills.Background"}}</span>
                  {{/if}}

                  {{#if this.isSpeciesClassSkill}}
                    <span class="prog-skill-tag prog-skill-tag--species">{{localize "SWSE.Progression.Core.Skills.Species"}}</span>
                  {{/if}}

                  {{#if this.badgeLabel}}
                    <span class="prog-skill-tag prog-skill-tag--suggested">{{this.badgeLabel}}</span>
                  {{/if}}
                </div>

                {{#if this.category}}
                  <div class="prog-skill-category">{{this.category}}</div>
                {{/if}}
              </div>

              <div class="prog-skill-controls">
                {{#if this.isTrained}}
                  <button type="button"
                          class="prog-btn prog-btn--small prog-btn--selected"
                          data-action="skill-untrain"
                          data-skill="{{this.key}}"
                          title='{{localize 'SWSE.Progression.Core.Skills.UntrainTitle'}}'>
                    <i class="fas fa-check"></i> {{localize "SWSE.Progression.Core.Skills.Untrain"}}
                  </button>
                {{else if this.canTrain}}
                  <button type="button"
                          class="prog-btn prog-btn--small prog-btn--secondary"
                          data-action="skill-train"
                          data-skill="{{this.key}}"
                          {{#if (eq ../trainedCount ../allowedCount)}}disabled{{/if}}
                          title='{{localize 'SWSE.Progression.Core.Skills.TrainTitle'}}'>
                    <i class="fas fa-plus"></i> {{localize "SWSE.Progression.Core.Skills.Train"}}
                  </button>
                {{else}}
                  <div class="prog-skill-controls__placeholder" title='{{localize 'SWSE.Progression.Core.Skills.LockedTitle'}}'>
                    <i class="fas fa-lock"></i> {{localize "SWSE.Progression.Core.Class.Locked"}}
                  </div>
                {{/if}}
              </div>
            </div>
          {{/if}}
        {{/each}}
      </div>

      <div class="prog-skills-actions">
        <button type="button"
                class="prog-btn prog-btn--secondary prog-btn--small"
                data-action="skill-reset"
                title='{{localize 'SWSE.Progression.Core.Skills.ResetTitle'}}'>
          <i class="fas fa-redo"></i> {{localize "SWSE.Progression.Core.Skills.ResetAll"}}
        </button>
      </div>
    {{else}}
      <div class="prog-skills-empty">
        <i class="fas fa-triangle-exclamation"></i>
        {{localize "SWSE.Progression.Core.Skills.Empty"}}
      </div>
    {{/if}}
  </div>

  <div class="prog-panel prog-panel--right">
    <h3 class="prog-panel-title">{{localize "SWSE.Progression.Core.Skills.Expertise"}}</h3>

    <div class="prog-details-text">
      <p>
        <strong>{{localize "SWSE.Progression.Core.Skills.TrainedSkills"}}</strong> These are the skills your character is explicitly trained in at character creation.
      </p>

      <p>
        <strong>{{localize "SWSE.Progression.Core.Skills.ClassSkills"}}</strong> Skills granted by your class are legal to train here and receive the normal class-skill benefits.
      </p>

      <p>
        <strong>{{localize "SWSE.Progression.Core.Skills.BackgroundSkills"}}</strong> Some backgrounds expand what you can legally train during chargen.
      </p>

      <p>
        <strong>{{localize "SWSE.Progression.Core.Skills.SpeciesClassSkills"}}</strong> Some species make a specific skill count as a class skill. Those skills are also legal training choices here.
      </p>

      <p class="prog-guidance-tip">
        <i class="fas fa-lightbulb"></i>
        {{localize "SWSE.Progression.Core.Skills.GuidanceTip"}}
      </p>
    </div>
  </div>

</div>
