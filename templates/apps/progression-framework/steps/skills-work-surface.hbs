<div class="prog-skills-surface">

  <div class="prog-panel prog-panel--left">
    <h3 class="prog-panel-title">Training Summary</h3>

    <div class="prog-skills-counter">
      <div class="prog-counter-bar">
        <div class="prog-counter-fill" style="width: {{div trainedCount allowedCount 100}}%"></div>
      </div>
      <div class="prog-counter-text">
        <span class="prog-counter-value">{{trainedCount}}</span>
        <span class="prog-counter-label">/ {{allowedCount}} trained</span>
      </div>
    </div>

    {{#if (gt trainedCount 0)}}
      <div class="prog-trained-skills-list">
        <h4 class="prog-list-title">Selected Skills</h4>
        {{#each allSkills}}
          {{#if this.isTrained}}
            <div class="prog-trained-skill-badge">
              <i class="fas fa-check"></i> {{this.name}}
            </div>
          {{/if}}
        {{/each}}
      </div>
    {{/if}}

    {{#if (eq trainedCount allowedCount)}}
      <div class="prog-skills-complete">
        <i class="fas fa-star"></i> Slots Filled
      </div>
    {{else}}
      <div class="prog-skills-remaining">
        {{sub allowedCount trainedCount}} slot(s) remaining
      </div>
    {{/if}}
  </div>

  <div class="prog-panel prog-panel--center">
    <h3 class="prog-panel-title">Select Your Skills</h3>

    <p class="prog-help-text">
      Train {{allowedCount}} skill{{#unless (eq allowedCount 1)}}s{{/unless}} to specialize your character's expertise.
      Only legal class and background skills are trainable here.
    </p>

    {{#if isFallbackFullChart}}
      <div class="prog-skills-status prog-skills-status--warning">
        Class or background skill entitlement did not fully resolve. Only skills already selected or positively matched by the current build are shown.
      </div>
    {{else}}
      <div class="prog-skills-status prog-skills-status--info">
        Showing {{availableSkillCount}} legal trainable skill{{#unless (eq availableSkillCount 1)}}s{{/unless}} from class and background.
      </div>
    {{/if}}

    {{#if (gt allSkills.length 0)}}
      <div class="prog-skills-list">
        {{#each allSkills}}
          {{#if (or this.alwaysVisible this.available)}}
            <div class="prog-skill-row {{#if this.isTrained}}trained{{/if}} {{#if (eq ../focusedSkillId this.id)}}is-focused{{/if}}"
                 data-skill-row="{{this.key}}"
                 data-item-id="{{this.id}}"
                 data-action="focus-item"
                 role="button"
                 tabindex="0">

              <div class="prog-skill-info">
                <div class="prog-skill-name-wrap">
                  <div class="prog-skill-name">{{this.name}}</div>
                  {{#if this.isTrained}}
                    <span class="prog-skill-state-chip">Trained</span>
                  {{/if}}
                </div>

                <div class="prog-skill-tags">
                  {{#if this.isClassSkill}}
                    <span class="prog-skill-tag prog-skill-tag--class">Class</span>
                  {{/if}}

                  {{#if this.isBackgroundSkill}}
                    <span class="prog-skill-tag prog-skill-tag--background">Background</span>
                  {{/if}}

                  {{#if this.badgeLabel}}
                    <span class="prog-skill-tag prog-skill-tag--suggested">{{this.badgeLabel}}</span>
                  {{/if}}
                </div>

                {{#if this.category}}
                  <div class="prog-skill-category">{{this.category}}</div>
                {{/if}}
              </div>

              <div class="prog-skill-controls">
                {{#if this.isTrained}}
                  <button type="button"
                          class="prog-btn prog-btn--small prog-btn--selected skills-step-untrain-btn"
                          data-skill="{{this.key}}"
                          title="Skill trained — click to untrain">
                    <i class="fas fa-check"></i> Untrain
                  </button>
                {{else if this.canTrain}}
                  <button type="button"
                          class="prog-btn prog-btn--small prog-btn--secondary skills-step-train-btn"
                          data-skill="{{this.key}}"
                          {{#if (eq ../trainedCount ../allowedCount)}}disabled{{/if}}
                          title="Train this skill">
                    <i class="fas fa-plus"></i> Train
                  </button>
                {{else}}
                  <div class="prog-skill-controls__placeholder" title="Only class or background skills can be trained">
                    <i class="fas fa-lock"></i> Locked
                  </div>
                {{/if}}
              </div>
            </div>
          {{/if}}
        {{/each}}
      </div>

      <div class="prog-skills-actions">
        <button type="button"
                class="prog-btn prog-btn--secondary prog-btn--small skills-step-reset-btn"
                title="Reset all skill selections">
          <i class="fas fa-redo"></i> Reset All
        </button>
      </div>
    {{else}}
      <div class="prog-skills-empty">
        <i class="fas fa-triangle-exclamation"></i>
        No legal skills are currently available. Choose a class or background first.
      </div>
    {{/if}}
  </div>

  <div class="prog-panel prog-panel--right">
    <h3 class="prog-panel-title">Skill Expertise</h3>

    <div class="prog-details-text">
      <p>
        <strong>Trained Skills:</strong> These are the skills your character is explicitly trained in at character creation.
      </p>

      <p>
        <strong>Class Skills:</strong> Skills granted by your class are legal to train here and receive the normal class-skill benefits.
      </p>

      <p>
        <strong>Background Skills:</strong> Some backgrounds expand what you can legally train during chargen.
      </p>

      <p class="prog-guidance-tip">
        <i class="fas fa-lightbulb"></i>
        Use Train and Untrain to spend your limited slots deliberately. Suggested skills are tagged directly in the main list.
      </p>
    </div>
  </div>

</div>
