{{!-- Final Droid Configuration Details Panel --}}
{{!-- Shows droid build statistics and budget info --}}

<div class="prog-final-droid-details">
  <h3>Droid Statistics</h3>

  <div class="details-section">
    <h4>Identity</h4>
    <div class="detail-item">
      <span class="detail-label">Degree:</span>
      <span class="detail-value">{{droidInfo.degree}}</span>
    </div>
    <div class="detail-item">
      <span class="detail-label">Size:</span>
      <span class="detail-value">{{droidInfo.size}}</span>
    </div>
  </div>

  <div class="details-section">
    <h4>Configuration</h4>
    <div class="detail-item">
      <span class="detail-label">Total Systems:</span>
      <span class="detail-value">{{systemCount}}</span>
    </div>
    <div class="detail-item">
      <span class="detail-label">Total Cost:</span>
      <span class="detail-value">{{totalCost}} credits</span>
    </div>
    <div class="detail-item">
      <span class="detail-label">Total Weight:</span>
      <span class="detail-value">{{totalWeight}} kg</span>
    </div>
  </div>

  <div class="details-section">
    <h4>Budget Status</h4>
    <div class="detail-item">
      <span class="detail-label">Dedicated Budget:</span>
      <span class="detail-value">{{creditsBase}} credits</span>
    </div>
    <div class="detail-item">
      <span class="detail-label">Spent:</span>
      <span class="detail-value">{{creditsSpent}} credits</span>
    </div>
    <div class="detail-item {{#if (gte creditsRemaining 0)}}detail-item--positive{{else}}detail-item--negative{{/if}}">
      <span class="detail-label">Remaining:</span>
      <span class="detail-value">{{creditsRemaining}} credits</span>
    </div>
    {{#if (lt creditsRemaining 0)}}
      <div class="budget-warning">
        <strong>⚠️ Over Budget!</strong>
        You are {{abs creditsRemaining}} credits over budget. Remove systems to proceed.
      </div>
    {{/if}}
  </div>

  {{#if isFinalized}}
    <div class="details-section finalized-badge">
      <i class="fas fa-check-circle"></i> Configuration Confirmed
    </div>
  {{/if}}
</div>

<style scoped>
.prog-final-droid-details {
  padding: 1rem;
}

.prog-final-droid-details h3 {
  margin: 0 0 1rem 0;
  color: #fff;
  font-size: 1.2rem;
}

.details-section {
  margin: 1.5rem 0;
  padding: 1rem;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 4px;
  border-left: 3px solid #7cb342;
}

.details-section h4 {
  margin: 0 0 0.75rem 0;
  color: #7cb342;
  font-size: 0.95rem;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 0.5rem 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  color: #999;
  font-weight: 600;
}

.detail-value {
  color: #fff;
  font-weight: bold;
}

.detail-item--positive .detail-value {
  color: #7cb342;
}

.detail-item--negative .detail-value {
  color: #ff9800;
}

.budget-warning {
  margin-top: 0.75rem;
  padding: 0.75rem;
  background-color: rgba(255, 152, 0, 0.1);
  border-left: 3px solid #ff9800;
  color: #ffb74d;
  border-radius: 3px;
  font-size: 0.9rem;
}

.finalized-badge {
  text-align: center;
  background-color: rgba(124, 179, 66, 0.2);
  border-left-color: #7cb342;
  color: #7cb342;
  padding: 1rem;
}

.finalized-badge i {
  margin-right: 0.5rem;
}
</style>
