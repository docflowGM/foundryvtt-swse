{{!-- Droid Builder Details Panel — focused component action rail. --}}
<div class="prog-droid-builder prog-droid-builder--garage prog-droid-builder--detail-panel">
  <section class="prog-droid-builder__garage-panel prog-droid-builder__detail">
    <div class="prog-droid-builder__garage-head">
      <h3>Component Detail</h3>
      <span>{{builderVm.contextProfile.actionRailLabel}}</span>
    </div>

    {{#if builderVm.selectedDetail.isEmpty}}
      <div class="prog-droid-builder__detail-empty">
        <i class="fas fa-microchip"></i>
        <p>{{builderVm.selectedDetail.message}}</p>
      </div>
    {{else}}
      <div class="prog-droid-builder__detail-kicker">{{builderVm.selectedDetail.item.type}}</div>
      <h3 class="prog-droid-builder__detail-title">{{builderVm.selectedDetail.item.name}}</h3>

      {{#if builderVm.selectedDetail.item.description}}
        <p class="prog-droid-builder__detail-description">{{builderVm.selectedDetail.item.description}}</p>
      {{/if}}

      <div class="prog-droid-builder__cost-table">
        <div class="prog-droid-builder__cost-row"><span>Base Cost</span><strong>{{builderVm.selectedDetail.item.baseCost}}</strong></div>
        <div class="prog-droid-builder__cost-row"><span>Size Multiplier</span><strong>{{builderVm.selectedDetail.item.sizeMultiplier}}</strong></div>
        <div class="prog-droid-builder__cost-row prog-droid-builder__cost-row--total"><span>Adjusted Cost</span><strong>{{builderVm.selectedDetail.item.adjustedCost}} cr</strong></div>
        <div class="prog-droid-builder__cost-row"><span>Budget Impact</span><strong>{{builderVm.selectedDetail.item.budgetImpactLabel}}</strong></div>
        {{#if builderVm.selectedDetail.item.weight}}<div class="prog-droid-builder__cost-row"><span>Weight</span><strong>{{builderVm.selectedDetail.item.weight}} kg</strong></div>{{/if}}
        {{#if builderVm.selectedDetail.item.speed}}<div class="prog-droid-builder__cost-row"><span>Speed</span><strong>{{builderVm.selectedDetail.item.speed}}</strong></div>{{/if}}
      </div>

      {{#if builderVm.selectedDetail.item.features}}
        <div class="prog-droid-builder__garage-panel prog-droid-builder__detail-subpanel">
          <div class="prog-droid-builder__garage-head"><h3>Effects</h3><span>System Text</span></div>
          <ul class="prog-droid-builder__required-list">
            {{#each builderVm.selectedDetail.item.features}}
              <li class="prog-droid-builder__check-item prog-droid-builder__check-item--complete"><span>{{this}}</span></li>
            {{/each}}
          </ul>
        </div>
      {{/if}}

      {{#if builderVm.selectedDetail.item.disabledReasons}}
        <div class="prog-droid-builder__garage-panel prog-droid-builder__detail-subpanel">
          <div class="prog-droid-builder__garage-head"><h3>Restrictions</h3><span>Blocked</span></div>
          <ul class="prog-droid-builder__required-list">
            {{#each builderVm.selectedDetail.item.disabledReasons}}
              <li class="prog-droid-builder__check-item prog-droid-builder__check-item--missing"><span>{{this}}</span></li>
            {{/each}}
          </ul>
        </div>
      {{else}}
        <div class="prog-droid-builder__garage-panel prog-droid-builder__detail-subpanel">
          <div class="prog-droid-builder__garage-head"><h3>Compatibility</h3><span>Ready</span></div>
          <p class="prog-droid-builder__detail-description">This component is compatible with the current chassis and builder context.</p>
        </div>
      {{/if}}

      <div class="prog-droid-builder__detail-actions">
        {{#if builderVm.selectedDetail.item.isInstalled}}
          {{#if builderVm.selectedDetail.item.canRemove}}
            <button class="prog-droid-builder__action prog-droid-builder__action--remove"
                    type="button"
                    data-action="remove-system"
                    data-category="{{builderVm.selectedDetail.item.removeAction.category}}"
                    data-id="{{builderVm.selectedDetail.item.removeAction.id}}"
                    data-subcategory="{{builderVm.selectedDetail.item.removeAction.subcategory}}">
              Remove Highlighted Component
            </button>
          {{else}}
            <button class="prog-droid-builder__action" type="button" disabled>Required Component</button>
          {{/if}}
        {{else}}
          <button class="prog-droid-builder__action prog-droid-builder__action--install"
                  type="button"
                  data-action="install-system"
                  data-category="{{builderVm.selectedDetail.item.installAction.category}}"
                  data-id="{{builderVm.selectedDetail.item.installAction.id}}"
                  data-subcategory="{{builderVm.selectedDetail.item.installAction.subcategory}}"
                  {{#unless builderVm.selectedDetail.item.canInstall}}disabled{{/unless}}>
            Install Highlighted Component
          </button>
        {{/if}}
      </div>
    {{/if}}
  </section>
</div>
