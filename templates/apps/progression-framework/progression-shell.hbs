{{!--
  progression-shell.hbs
  Root template for the ProgressionShell.

  TWO RENDER MODES controlled by `isIntroMode`:

  INTRO MODE (isIntroMode = true)
    The shell renders as a clean boot/splash stage with no furniture.
    Only the work-surface fills the inner frame — no mentor rail, no step
    chips, no footer. The outer datapad frame (window chrome) persists.
    The intro's own Continue button is the sole action.

  NORMAL MODE (isIntroMode = false)
    6 named regions — all present:
      mentor-rail     Always visible; collapsible to portrait strip
      progress-rail   Step indicators
      utility-bar     Search/filter/sort; always present; collapsible
      work-surface    Primary step interaction area
      details-panel   Selected item details; always mounted; empty state when nothing focused
      action-footer   Back / Center status / Next/Confirm
      modal-host      In-shell modal stack
--}}

<div class="progression-shell swse-ui-shell swse-sheet-ui swse-progression-shell swse-prog-v2-shell prog-holo {{#if isProcessing}}is-processing{{/if}}"
     data-application-content
     data-step-id="{{currentDescriptor.stepId}}"
     data-theme="{{themeKey}}"
     data-motion-style="{{motionStyle}}">

{{#if isIntroMode}}

  {{!-- ======================================================================
    INTRO MODE — Boot/splash takeover.
    Single work-surface fills the entire shell interior.
    No mentor rail, no progress rail, no footer. Same outer frame.
  ======================================================================= --}}
  <div class="prog-intro-stage" data-region="work-surface">
    {{#if workSurfaceHtml}}
      {{{workSurfaceHtml}}}
    {{/if}}
  </div>

{{else}}

  {{!-- ======================================================================
    NORMAL MODE — Full shell furniture.
  ======================================================================= --}}

  {{!-- ======================================================================
    MENTOR HEADER BAND — top of shell, horizontal layout
    Portrait (left) + Dialogue (right)
  ======================================================================= --}}
  <div data-region="mentor-rail"
       data-collapsed="{{mentorCollapsed}}"
       data-mood="{{mentor.mood}}">
    {{{parts.mentorRail}}}
  </div>{{!-- /mentor-rail --}}

  {{!-- ======================================================================
    MAIN COLUMN — progress-rail (horizontal tabs) + utility-bar + content-row + action-footer
  ======================================================================= --}}
  <div class="prog-main-column">

    {{!-- ====================================================================
      PROGRESS RAIL — compact horizontal step progression
    ==================================================================== --}}
    <div data-region="progress-rail">
      {{{parts.progressRail}}}
    </div>{{!-- /progress-rail --}}

    {{!-- ====================================================================
      UTILITY BAR — always present; content varies by step
    ==================================================================== --}}
    <div data-region="utility-bar"
         data-collapsed="{{utilityBarCollapsed}}"
         data-mode="{{utilityBarConfig.mode}}">
      {{{parts.utilityBar}}}
    </div>{{!-- /utility-bar --}}

    {{!-- ====================================================================
      DIAGNOSTIC BANNERS — Phase 8 hydration diagnostics (errors/warnings)
    ==================================================================== --}}
    {{> "systems/foundryvtt-swse/templates/apps/progression-framework/diagnostic-banner.hbs"}}

    {{!-- ====================================================================
      CONTENT ROW — summary-panel (left) + work-surface (center) + details-panel (right)
    ==================================================================== --}}
    <div class="prog-content-row">

      {{!-- ==================================================================
        SUMMARY PANEL — left column, compact build snapshot
      ================================================================== --}}
      <aside data-region="summary-panel">

        {{#if summaryPanelHtml}}
          {{{summaryPanelHtml}}}
        {{else}}
          <div class="prog-summary-placeholder swse-card-schema swse-card-schema--identity swse-card-schema--placeholder">
            {{#if currentDescriptor}}
              <i class="fas {{currentDescriptor.icon}} prog-summary-placeholder__icon"></i>
            {{/if}}
          </div>
        {{/if}}

      </aside>{{!-- /summary-panel --}}

      {{!-- ==================================================================
        WORK SURFACE — center column, primary step interaction
      ================================================================== --}}
      <div data-region="work-surface">

        {{!-- PHASE 1 UX: Step context indicator --}}
        {{#if stepContext}}
        <div class="prog-step-context-banner">
          <span class="prog-step-counter">{{stepContext.displayText}}</span>
          {{#if currentDescriptor.label}}
            <span class="prog-step-label">— {{currentDescriptor.label}}</span>
          {{/if}}
        </div>
        {{/if}}

        {{#if workSurfaceHtml}}
          {{{workSurfaceHtml}}}
        {{else}}
          <div class="prog-work-placeholder swse-card-schema swse-card-schema--choice swse-card-schema--placeholder">
            {{#if currentDescriptor}}
              <div class="prog-work-placeholder__header prog-heading">
                <i class="fas {{currentDescriptor.icon}}"></i>
                {{currentDescriptor.label}}
                {{#if currentDescriptor.isConditional}}
                  <span class="prog-chip prog-chip--warning">
                    Engine-Unlocked
                  </span>
                {{/if}}
              </div>
              <p class="prog-work-placeholder__hint">
                Step {{add currentStepIndex 1}} of {{totalSteps}}
                {{#if currentDescriptor.isConditional}}
                  — Unlocked by: {{currentDescriptor.unlockReason}}
                {{/if}}
              </p>
              {{#if lastError}}
                <div class="prog-work-placeholder__error">
                  <i class="fas fa-exclamation-triangle"></i>
                  {{lastError.message}}
                </div>
              {{/if}}
            {{else}}
              <p class="prog-work-placeholder__empty">No steps available.</p>
            {{/if}}
          </div>
        {{/if}}

      </div>{{!-- /work-surface --}}


      {{!-- ==================================================================
        DETAILS PANEL — always mounted on desktop; empty state when nothing focused
      ================================================================== --}}
      <div data-region="details-panel" class="prog-details-panel-no-frame">

        {{#if detailsPanelHtml}}
          {{{detailsPanelHtml}}}
        {{else}}
          <div class="prog-details-placeholder prog-details-placeholder--no-frame swse-card-schema swse-card-schema--enumerated swse-card-schema--placeholder">
            {{#if focusedItem}}
              <div class="prog-details-placeholder__name prog-heading">
                {{focusedItem.name}}
              </div>
              <div class="prog-details-placeholder__content">
                <p>{{focusedItem.description}}</p>
              </div>
            {{else}}
              {{#if currentDescriptor}}
                <div class="prog-details-placeholder__empty">
                  <i class="fas {{currentDescriptor.icon}} prog-details-placeholder__empty-icon"></i>
                  <p>Select an item to see details.</p>
                </div>
              {{/if}}
            {{/if}}
          </div>
        {{/if}}

      </div>{{!-- /details-panel --}}

    </div>{{!-- /content-row --}}


    {{!-- ====================================================================
      ACTION FOOTER — Back | Step Chips | Confirm
      Three-column grid: nav anchor | step chips | confirm anchor
      Step chips use SVG frame backgrounds per state (current/complete/locked/warning).
      data-font-mode controls label font-family: 'standard' | 'aurabesh'
    ==================================================================== --}}
    <div data-region="action-footer" class="swse-ui-frame swse-progression-footer-frame">
      <footer class="swse-footer" data-font-mode="{{fontMode}}">

        {{!-- ── LEFT: Back button ── --}}
        <div class="action-footer__nav">
          <button type="button"
                  class="swse-btn swse-ui-button swse-btn--back"
                  data-action="previous-step"
                  {{#unless footer.back.enabled}}disabled{{/unless}}>
            <span class="swse-btn__label">{{footer.back.label}}</span>
          </button>
        </div>

        {{!-- ── CENTER: Status indicators only (no step chips here) ── --}}
        <div class="action-footer__status">

          {{!-- PHASE 3 UX: Blocker explanation (specific, actionable message) --}}
          {{#if (and (not footer.next.enabled) footer.blockerExplanation)}}
            <div class="prog-blocker-explanation prog-blocker-explanation--primary">
              <i class="fas fa-lightbulb"></i>
              <span class="prog-blocker-text">{{footer.blockerExplanation}}</span>
            </div>
          {{else if footer.blockingIssues.length}}
            <div class="swse-footer__status swse-footer__status--blocking">
              <i class="fas fa-exclamation-circle"></i>
              {{#each footer.blockingIssues}}
                <span>{{this}}</span>
              {{/each}}
            </div>
          {{else if footer.warnings.length}}
            <div class="swse-footer__status swse-footer__status--warning">
              <i class="fas fa-exclamation-triangle"></i>
              {{#each footer.warnings}}
                <span>{{this}}</span>
              {{/each}}
            </div>
          {{/if}}

        </div>

        {{!-- ── RIGHT: Next / Confirm button ── --}}
        {{#unless footer.next.hidden}}
        <div class="action-footer__confirm">
          <button type="button"
                  class="swse-btn swse-btn--confirm
                         {{#if footer.next.isLastStep}}swse-btn--last-step{{/if}} {{#if footer.next.enabled}}swse-btn--advance-ready{{/if}}"
                  data-action="{{#if footer.next.isLastStep}}confirm-step{{else}}next-step{{/if}}"
                  {{#unless footer.next.enabled}}disabled{{/unless}}>
            <span class="swse-btn__label">{{footer.next.label}}</span>
          </button>
        </div>
        {{/unless}}

      </footer>
    </div>{{!-- /action-footer --}}

  </div>{{!-- /main-column --}}


  {{!-- ======================================================================
    MODAL HOST — in-shell modal stack
  ======================================================================= --}}
  <div data-region="modal-host"></div>

{{/if}}{{!-- /isIntroMode --}}

</div>{{!-- /progression-shell --}}
