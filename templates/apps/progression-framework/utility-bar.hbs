<div class="prog-utility-bar swse-ui-panel swse-prog-utility-shell" data-mode="{{utilityBarConfig.mode}}">
  {{! Step icon + label }}
  <span class="prog-utility-bar__icon" aria-hidden="true">
    <i class="{{currentDescriptor.icon}}"></i>
  </span>
  <span class="prog-utility-bar__label">{{currentDescriptor.label}}</span>

  {{! Search input (rich and compact modes) — wrapped in field container }}
  {{#if utilityBarConfig.search.enabled}}
    <div class="prog-field swse-filter-field swse-filter-field--search">
      <input class="prog-input swse-ui-input"
             type="search"
             placeholder="{{utilityBarConfig.search.placeholder}}"
             data-utility-search
             autocomplete="off">
    </div>
  {{/if}}

  {{! Filter chips (size buttons) }}
  {{#if utilityBarConfig.filters}}
    <div class="prog-utility-bar__filters">
      {{#each utilityBarConfig.filters}}
        <button class="prog-utility-bar__filter-chip swse-ui-button{{#if this.defaultOn}} prog-utility-bar__filter-chip--active{{/if}}"
                data-utility-filter="{{this.id}}"
                data-active="{{#if this.defaultOn}}true{{else}}false{{/if}}"
                type="button">{{this.label}}</button>
      {{/each}}
    </div>
  {{/if}}

  {{! Bonus Stat Dropdown }}
  {{#if utilityBarConfig.bonusDropdown}}
    <div class="prog-utility-bar__dropdown-group">
      <label class="prog-utility-bar__dropdown-label">{{utilityBarConfig.bonusDropdown.label}}</label>
      <div class="prog-field swse-filter-field swse-filter-field--select">
        <select class="prog-input"
                data-utility-select="{{utilityBarConfig.bonusDropdown.id}}"
                data-dropdown-type="bonus">
          {{#each utilityBarConfig.bonusDropdown.options}}
            <option value="{{this.value}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  {{/if}}

  {{! Penalty Stat Dropdown }}
  {{#if utilityBarConfig.penaltyDropdown}}
    <div class="prog-utility-bar__dropdown-group">
      <label class="prog-utility-bar__dropdown-label">{{utilityBarConfig.penaltyDropdown.label}}</label>
      <div class="prog-field swse-filter-field swse-filter-field--select">
        <select class="prog-input"
                data-utility-select="{{utilityBarConfig.penaltyDropdown.id}}"
                data-dropdown-type="penalty">
          {{#each utilityBarConfig.penaltyDropdown.options}}
            <option value="{{this.value}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  {{/if}}

  {{! Sort dropdown }}
  {{#if utilityBarConfig.sorts}}
    <div class="prog-field swse-filter-field swse-filter-field--select">
      <select class="prog-input" data-utility-sort>
        {{#each utilityBarConfig.sorts}}
          <option value="{{this.id}}">{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  {{/if}}

  {{! Custom controls — button, toggle, label only (Wave 2 partial implementation) }}
  {{#if utilityBarConfig.customControls}}
    <div class="prog-utility-bar__custom-controls">
      {{#each utilityBarConfig.customControls}}
        {{#if (eq this.type "button")}}
          <button class="prog-btn swse-ui-button" data-action="{{this.action}}" type="button">
            {{#if this.icon}}<i class="{{this.icon}}"></i>{{/if}} {{this.label}}
          </button>
        {{else if (eq this.type "toggle")}}
          <button class="prog-utility-bar__filter-chip"
                  data-utility-custom="{{this.id}}"
                  data-action="{{this.action}}"
                  type="button">
            {{#if this.icon}}<i class="{{this.icon}}"></i>{{/if}} {{this.label}}
          </button>
        {{else if (eq this.type "label")}}
          <span class="prog-chip">{{this.label}}</span>
        {{/if}}
      {{/each}}
    </div>
  {{/if}}


  <button class="prog-btn swse-ui-button prog-utility-bar__reset" data-action="reset-utility-filters" type="button">
    Reset Filters
  </button>

  {{! Conditional step badge }}
  {{#if currentDescriptor.isConditional}}
    <span class="prog-chip prog-chip--warning prog-utility-bar__conditional">Conditional</span>
  {{/if}}

  {{! Collapse button — always visible, even when collapsed }}
  <button class="prog-utility-bar__collapse swse-ui-button" data-action="toggle-utility-bar" type="button"
          title="{{#if utilityBarCollapsed}}Expand{{else}}Collapse{{/if}}">
    <i class="fas fa-chevron-{{#if utilityBarCollapsed}}down{{else}}up{{/if}}"></i>
  </button>
</div>
