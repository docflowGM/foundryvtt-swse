<div class="swse-modification-modal">
  <!-- Hologram Scanline Overlay -->
  <div class="ls-scanline-overlay"></div>

  <form class="ls-form flexcol">

    <!-- FIXED HEADER: Item image + Title -->
    <header class="modal-header">
      <div class="modal-header-content">
        {{#if itemImg}}
        <img src="{{itemImg}}" alt="{{itemName}}" class="modal-header-image" />
        {{/if}}

        <div class="modal-header-title">
          <h1>{{headerContent.title}}</h1>
          {{#if headerContent.subtitle}}
          <p class="modal-header-subtitle">{{headerContent.subtitle}}</p>
          {{/if}}
        </div>
      </div>
    </header>

    <!-- SCROLLABLE BODY: 2-Panel Layout -->
    <div class="modal-body">
      <!-- Left Panel: Selection List -->
      <div class="modal-left">
        {{{mainContent.list}}}
      </div>

      <!-- Right Panel: Detail View -->
      <div class="modal-right">
        {{{mainContent.detail}}}
      </div>
    </div>

    <!-- FIXED FOOTER: Cancel | Cost Info | Confirm -->
    <footer class="modal-footer">
      <button type="button" class="modal-footer-btn modal-footer-cancel" data-action="cancel">
        Cancel
      </button>

      <div class="modal-footer-cost">
        {{#if footerContent.totalCost}}
        <span class="modal-cost-label">Total Cost:</span>
        <span class="modal-cost-value">{{footerContent.totalCost}}</span>
        {{/if}}

        {{#if footerContent.wallet}}
        <span class="modal-wallet-label">Wallet:</span>
        <span class="modal-wallet-value">{{footerContent.wallet}}</span>
        {{/if}}
      </div>

      <button type="submit" class="modal-footer-btn modal-footer-confirm" data-action="confirm" {{#unless footerContent.canConfirm}}disabled{{/unless}}>
        Confirm
      </button>
    </footer>

  </form>
</div>
