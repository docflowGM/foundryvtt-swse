<div class="stock-droid-conversion-dialog">
  <div class="conversion-header">
    <h2><i class="fas fa-robot"></i> Convert Stock Droid to Custom</h2>
    <p class="subtitle">Review inferred values before customization</p>
  </div>

  <div class="conversion-content">
    <!-- Source Information -->
    <section class="conversion-section">
      <h3><i class="fas fa-file-import"></i> Source</h3>
      <div class="source-info">
        <p><strong>Name:</strong> {{source.sourceName}}</p>
        <p><strong>Import Mode:</strong> Stock Statblock</p>
        <p class="source-note"><i class="fas fa-info-circle"></i> Converting from published values. Results may differ from original.</p>
      </div>
    </section>

    <!-- Confidence & Warnings -->
    {{#if conversionMeta.confidence}}
    <section class="conversion-section confidence-section">
      <h3><i class="fas fa-gauge-high"></i> Conversion Confidence</h3>
      <div class="confidence-badge {{conversionMeta.confidence}}">
        {{conversionMeta.confidence}}
      </div>
      <p class="confidence-note">{{#switch conversionMeta.confidence}}
        {{#case 'high'}}Most values inferred from source with high confidence.{{/case}}
        {{#case 'medium'}}Some values inferred; others using safe defaults.{{/case}}
        {{#case 'low'}}Many values require user selection in builder.{{/case}}
      {{/switch}}</p>
    </section>
    {{/if}}

    <!-- Inferred Systems -->
    <section class="conversion-section">
      <h3><i class="fas fa-cogs"></i> Inferred Systems</h3>

      <div class="system-card">
        <div class="system-label">Degree</div>
        <div class="system-value">{{inferredSeed.degree}}</div>
        <div class="system-confidence">{{#if assumptions}}
          {{#each assumptions}}
            {{#if this~}}
              <small>✓ {{this}}</small>
            {{/if~}}
          {{/each}}
        {{else}}<small>Default value</small>{{/if}}</div>
      </div>

      <div class="system-card">
        <div class="system-label">Size</div>
        <div class="system-value">{{inferredSeed.size}}</div>
        <div class="system-confidence"><small>{{#if (eq inferredSeed.size 'Medium')}}Default{{else}}Inferred from source{{/if}}</small></div>
      </div>

      <div class="system-card">
        <div class="system-label">Locomotion</div>
        <div class="system-value">{{#if inferredSeed.locomotion.name}}{{inferredSeed.locomotion.name}}{{else}}<em>(Requires selection)</em>{{/if}}</div>
        <div class="system-confidence">
          <small>{{inferredSeed.locomotion.reason}}</small>
          {{#if inferredSeed.locomotion.confidence}}<small class="confidence-tag {{inferredSeed.locomotion.confidence}}">{{inferredSeed.locomotion.confidence}}</small>{{/if}}
        </div>
      </div>

      <div class="system-card">
        <div class="system-label">Processor</div>
        <div class="system-value"><em>(Requires selection)</em></div>
        <div class="system-confidence"><small>Cannot infer from statblock</small></div>
      </div>

      <div class="system-card">
        <div class="system-label">Armor</div>
        <div class="system-value"><em>(Requires selection)</em></div>
        <div class="system-confidence"><small>{{#each unresolved.blockers}}{{#if (includes this 'armor' 'Armor')}}{{this}}{{/if}}{{/each}}</small></div>
      </div>
    </section>

    <!-- Unresolved Fields -->
    {{#if unresolved.blockers}}
    <section class="conversion-section blockers-section">
      <h3><i class="fas fa-exclamation-triangle"></i> Requires User Selection</h3>
      <ul class="blocker-list">
        {{#each unresolved.blockers}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    <!-- Warnings -->
    {{#if conversionMeta.warnings}}
    <section class="conversion-section warnings-section">
      <h3><i class="fas fa-warning"></i> Important Notes</h3>
      <ul class="warning-list">
        {{#each conversionMeta.warnings}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    <!-- Key Insight -->
    <section class="conversion-section insight-section">
      <h3><i class="fas fa-lightbulb"></i> What Happens Next</h3>
      <ol class="insight-steps">
        <li><strong>Open Builder:</strong> You'll customize the remaining systems (processor, armor, appendages, sensors)</li>
        <li><strong>Builder Calculates:</strong> Defenses, abilities, and costs are derived from your selections</li>
        <li><strong>Finalize:</strong> When you save, your custom droid is created with full builder authority</li>
      </ol>
    </section>
  </div>

  <!-- Footer Actions -->
  <div class="conversion-footer">
    <button class="btn btn-secondary" data-action="cancel">
      <i class="fas fa-times"></i> Cancel
    </button>
    <button class="btn btn-primary" data-action="proceed">
      <i class="fas fa-arrow-right"></i> Proceed to Builder
    </button>
  </div>
</div>

