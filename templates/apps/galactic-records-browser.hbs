<div class="galactic-records-browser">
  <div class="browser-header">
    <h2>Access Galactic Records</h2>
    <p class="subtitle">Browse and load profiles from the galactic archives.</p>
  </div>

  <div class="browser-content">
    <!-- Category Selection -->
    <div class="category-section">
      <h3>Step 1: Select Category</h3>
      <div class="category-buttons">
        {{#each categories}}
        <button
          class="category-btn {{#if (eq @root.selectedCategory this.id)}}active{{/if}}"
          data-category="{{this.id}}"
          title="{{this.description}}"
          {{#unless this.supported}}disabled{{/unless}}
        >
          <i class="fas {{this.icon}}"></i>
          <span>{{this.label}}</span>
          {{#if this.count}}<span class="count">({{this.count}})</span>{{/if}}
        </button>
        {{/each}}
      </div>
    </div>

    <!-- Templates List -->
    {{#if selectedCategory}}
    <div class="templates-section">
      <h3>Step 2: Select Record</h3>

      {{#if categoryInfo.supported}}
        {{#if isLoading}}
        <div class="loading-spinner">
          <p><i class="fas fa-spinner fa-spin"></i> Accessing archives...</p>
        </div>
        {{else}}
          {{#if templates}}
          <div class="templates-list">
            {{#each templates}}
            <div
              class="template-item {{#if (eq @root.selectedTemplate.id this.id)}}selected{{/if}}"
              data-template-id="{{this.id}}"
            >
              <div class="template-image">
                <img src="{{this.portrait}}" alt="{{this.name}}" />
              </div>
              <div class="template-info">
                <div class="template-name">{{this.name}}</div>
                {{#if this.metadata.species}}
                <div class="template-detail">
                  <span class="label">Species:</span>
                  <span class="value">{{this.metadata.species}}</span>
                </div>
                {{/if}}
                {{#if this.metadata.classLevels}}
                <div class="template-detail">
                  <span class="label">Classes:</span>
                  <span class="value">
                    {{#each this.metadata.classLevels}}
                    <span class="class-badge">{{@key}} {{this}}</span>
                    {{/each}}
                  </span>
                </div>
                {{/if}}
              </div>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="no-templates">
            <p><i class="fas fa-info-circle"></i> No archived profiles available for this category.</p>
          </div>
          {{/if}}
        {{/if}}
      {{else}}
        <!-- Unsupported category -->
        <div class="category-unavailable">
          <div class="unavailable-content">
            <i class="fas fa-lock"></i>
            <h3>Records Unavailable</h3>
            <p>{{categoryInfo.unavailableReason}}</p>
            <p class="coming-soon">This classification system is coming in a future update.</p>
          </div>
        </div>
      {{/if}}
    </div>
    {{/if}}

    <!-- Preview & Actions -->
    {{#if selectedTemplate}}
    <div class="preview-section">
      <h3>Step 3: Review & Import</h3>
      {{#if (eq @root.selectedCategory 'droid')}}
      <div class="import-mode-notice">
        <i class="fas fa-info-circle"></i>
        <span><strong>Stock Droid Statblock</strong> — Published values will be used for play. To fully customize, create or convert to a custom droid in the builder.</span>
      </div>
      {{/if}}
      <div class="selected-preview">
        <div class="preview-item">
          <img src="{{selectedTemplate.portrait}}" alt="{{selectedTemplate.name}}" />
          <div class="preview-details">
            <h4>{{selectedTemplate.name}}</h4>
            {{#if selectedTemplate.metadata.species}}
            <p><strong>Species:</strong> {{selectedTemplate.metadata.species}}</p>
            {{/if}}
            {{#if selectedTemplate.metadata.classLevels}}
            <p><strong>Classification:</strong>
              {{#each selectedTemplate.metadata.classLevels}}
              {{@key}} {{this}}{{#unless @last}}, {{/unless}}
              {{/each}}
            </p>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
    {{/if}}
  </div>

  <!-- Footer Actions -->
  <div class="browser-footer">
    <button class="close-btn" type="button">
      <i class="fas fa-times"></i> Close
    </button>
    {{#if selectedTemplate}}
    <button class="import-now-btn" type="button">
      <i class="fas fa-bolt"></i> Import Now
    </button>
    <button class="import-customize-btn" type="button">
      <i class="fas fa-wand-magic-sparkles"></i> Customize & Import
    </button>
    {{/if}}
  </div>
</div>

<style>
.galactic-records-browser {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 1.5rem;
  background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
  color: #e0e0e0;
  font-family: var(--font-primary, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
}

.browser-header {
  text-align: center;
  margin-bottom: 1.5rem;
  border-bottom: 1px solid #3a3f4a;
  padding-bottom: 1rem;
}

.browser-header h2 {
  margin: 0 0 0.5rem 0;
  color: #fff;
  font-size: 1.5rem;
}

.browser-header .subtitle {
  margin: 0;
  color: #a0a0a0;
  font-size: 0.9rem;
}

.browser-content {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 1rem;
  padding-right: 0.5rem;
}

.browser-content > div {
  margin-bottom: 1.5rem;
}

.browser-content h3 {
  color: #fff;
  font-size: 1rem;
  margin: 0 0 1rem 0;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Category Buttons */
.category-buttons {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.category-btn {
  padding: 0.75rem 1.25rem;
  border: 2px solid #3a3f4a;
  border-radius: 0.4rem;
  background: #15192a;
  color: #a0a0a0;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  font-weight: 500;
  white-space: nowrap;
}

.category-btn:hover:not(:disabled) {
  border-color: #5a5f6a;
  background: #1a1f33;
  color: #e0e0e0;
}

.category-btn.active {
  border-color: #ffc107;
  background: #2a2f42;
  color: #ffc107;
  box-shadow: 0 0 10px rgba(255, 193, 7, 0.2);
}

.category-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.category-btn i {
  font-size: 1rem;
}

.category-btn .count {
  font-size: 0.75rem;
  opacity: 0.7;
  margin-left: 0.25rem;
}

/* Templates List */
.templates-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 1rem;
  max-height: 350px;
  overflow-y: auto;
}

.template-item {
  padding: 1rem;
  border: 2px solid #3a3f4a;
  border-radius: 0.4rem;
  background: #15192a;
  cursor: pointer;
  transition: all 0.3s ease;
}

.template-item:hover {
  border-color: #5a5f6a;
  background: #1a1f33;
  transform: translateY(-2px);
}

.template-item.selected {
  border-color: #ffc107;
  background: #2a2f42;
  box-shadow: 0 0 10px rgba(255, 193, 7, 0.2);
}

.template-image {
  width: 100%;
  height: 100px;
  border-radius: 0.3rem;
  overflow: hidden;
  margin-bottom: 0.75rem;
  background: #0a0e27;
}

.template-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.template-info .template-name {
  font-weight: bold;
  color: #fff;
  margin-bottom: 0.5rem;
  font-size: 0.85rem;
  word-break: break-word;
}

.template-detail {
  font-size: 0.7rem;
  margin: 0.25rem 0;
  color: #a0a0a0;
}

.template-detail .label {
  color: #ffc107;
  font-weight: bold;
}

.class-badge {
  display: inline-block;
  background: #3a3f4a;
  padding: 0.2rem 0.3rem;
  border-radius: 0.2rem;
  margin-right: 0.2rem;
  font-size: 0.65rem;
}

/* Category Unavailable */
.category-unavailable {
  min-height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  text-align: center;
}

.unavailable-content {
  color: #808090;
}

.unavailable-content i {
  font-size: 3rem;
  margin-bottom: 1rem;
  opacity: 0.5;
}

.unavailable-content h3 {
  color: #a0a0a0;
  font-size: 1.2rem;
  margin: 0 0 0.5rem 0;
}

.unavailable-content p {
  margin: 0.5rem 0;
  font-size: 0.9rem;
}

.coming-soon {
  color: #707080;
  font-size: 0.8rem !important;
  font-style: italic;
}

/* Loading/Empty States */
.loading-spinner,
.no-templates {
  text-align: center;
  padding: 2rem;
  color: #a0a0a0;
}

/* Preview */
.import-mode-notice {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  margin-bottom: 1rem;
  border-left: 3px solid #ffc107;
  background: #2a2f42;
  border-radius: 0.3rem;
  color: #e0e0e0;
  font-size: 0.85rem;
  line-height: 1.4;
}

.import-mode-notice i {
  color: #ffc107;
  flex-shrink: 0;
  margin-top: 0.1rem;
}

.selected-preview {
  padding: 1rem;
  border: 1px solid #3a3f4a;
  border-radius: 0.4rem;
  background: #15192a;
}

.preview-item {
  display: flex;
  gap: 1rem;
}

.preview-item img {
  width: 80px;
  height: 80px;
  border-radius: 0.3rem;
  object-fit: cover;
  flex-shrink: 0;
}

.preview-details {
  flex: 1;
}

.preview-details h4 {
  margin: 0 0 0.5rem 0;
  color: #fff;
  font-size: 0.95rem;
}

.preview-details p {
  margin: 0.3rem 0;
  font-size: 0.85rem;
  color: #a0a0a0;
}

/* Footer */
.browser-footer {
  display: flex;
  gap: 1rem;
  justify-content: flex-end;
  border-top: 1px solid #3a3f4a;
  padding-top: 1rem;
}

.close-btn,
.import-now-btn,
.import-customize-btn {
  padding: 0.7rem 1.5rem;
  border: 1px solid #3a3f4a;
  border-radius: 0.3rem;
  background: #15192a;
  color: #e0e0e0;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  font-weight: 500;
}

.close-btn:hover {
  background: #1a1f33;
  border-color: #5a5f6a;
}

.import-now-btn {
  background: #4a90e2;
  color: #fff;
  border-color: #3a7bb8;
}

.import-now-btn:hover {
  background: #357abd;
  border-color: #2a5fa0;
  box-shadow: 0 0 10px rgba(74, 144, 226, 0.3);
}

.import-customize-btn {
  background: #ffc107;
  color: #000;
  border-color: #ffb300;
  font-weight: 600;
}

.import-customize-btn:hover {
  background: #ffb300;
  border-color: #ff9800;
  box-shadow: 0 0 10px rgba(255, 193, 7, 0.3);
}

/* Scrollbars */
.browser-content::-webkit-scrollbar,
.templates-list::-webkit-scrollbar {
  width: 8px;
}

.browser-content::-webkit-scrollbar-track,
.templates-list::-webkit-scrollbar-track {
  background: #15192a;
}

.browser-content::-webkit-scrollbar-thumb,
.templates-list::-webkit-scrollbar-thumb {
  background: #3a3f4a;
  border-radius: 4px;
}

.browser-content::-webkit-scrollbar-thumb:hover,
.templates-list::-webkit-scrollbar-thumb:hover {
  background: #5a5f6a;
}

/* Responsive */
@media (max-width: 768px) {
  .category-buttons {
    flex-direction: column;
  }

  .category-btn {
    width: 100%;
    justify-content: center;
  }

  .templates-list {
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  }

  .browser-footer {
    flex-direction: column;
  }

  .browser-footer button {
    width: 100%;
  }

  .preview-item {
    flex-direction: column;
  }

  .preview-item img {
    width: 100%;
  }
}
</style>
