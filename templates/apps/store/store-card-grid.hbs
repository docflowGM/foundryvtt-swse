<div class="swse-sheet">
<form class="swse-store swse-store-ui store-shell" autocomplete="off">

  <div class="store-header">
    <div class="store-portrait">
      <img src="{{rendarrImage}}" alt="Rendarr" class="rendarr-image"/>
    </div>
    <div class="store-rendarr-meta">
      <div class="store-rendarr-name">{{localize 'SWSE.Store.Header.ExchangeName'}}</div>
      <div class="store-rendarr-sub">{{localize 'SWSE.Store.Header.Subtitle'}}</div>
      <div class="store-rendarr-kicker">{{localize 'SWSE.Store.Header.Kicker'}}</div>
      <div class="store-rendarr-quote">
        <span class="holo-message">"{{rendarrWelcome}}"</span>
      </div>
      <div class="store-category-label">{{currentCategoryLabel}} · <span data-results-count>{{allItems.length}}</span> {{localize 'SWSE.Store.Header.Listings'}}</div>
    </div>
    <div class="store-credits-block">
      <div class="store-credits-label">{{localize 'SWSE.Store.Header.Account'}}</div>
      <div class="store-credits-val">{{credits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></div>
      <div class="store-credits-reserve">{{localize 'SWSE.Store.Header.Reserve'}} {{pageContext.cartRemaining}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></div>
      <div class="store-credits-cart">{{localize 'SWSE.Store.Header.Cart'}}: <span data-cart-count>{{cartCount}}</span></div>
    </div>
  </div>

  <div class="store-scanline"></div>

  <div class="store-tabs">
    <button type="button" class="store-tab {{#if (eq currentView 'browse')}}active{{/if}}" data-action="show-browse">
      <span class="store-tab-glyph">⊞</span> {{localize 'SWSE.Store.Tabs.Browse'}}
    </button>
    <button type="button" class="store-tab {{#if (eq currentView 'cart')}}active{{/if}}{{#if (eq currentView 'checkout')}} active{{/if}}" data-action="view-cart">
      <span class="store-tab-glyph">◳</span> {{localize 'SWSE.Store.Tabs.Cart'}}
      {{#if cartCount}}<span class="store-tab-badge">{{cartCount}}</span>{{/if}}
    </button>
    <button type="button" class="store-tab {{#if (eq currentView 'history')}}active{{/if}}" data-action="show-history">
      <span class="store-tab-glyph">◎</span> {{localize 'SWSE.Store.Tabs.History'}}
    </button>
  </div>

  {{#if (eq currentView 'browse')}}
  <div class="store-filter-bar">
    <div class="store-filter-search">
      <i class="fa-solid fa-search store-filter-ico"></i>
      <input type="text" id="store-search" class="store-search-input" placeholder="{{localize 'SWSE.Store.Filters.SearchListings'}}" aria-label="{{localize 'SWSE.Store.Filters.SearchItemsAria'}}"/>
    </div>
    <div class="store-filter-cats">
      {{#each categorySummary}}
        <button type="button" class="store-chip {{#if (eq ../currentCategory key)}}active{{/if}}" data-action="category-nav" data-category="{{key}}">
          {{label}}<span class="store-chip-count">{{count}}</span>
        </button>
      {{/each}}
    </div>

    {{!-- Phase 2: Secondary navigation for subcategories (standalone) --}}
    {{#if navigationModel.topCategories}}
    {{#each navigationModel.topCategories}}
    {{#if (eq key ../currentCategory)}}
    {{#if children}}
    <div class="store-subcat-nav">
      {{!-- "All [Category]" reset chip --}}
      <button type="button" class="store-chip store-subcat-chip {{#unless ../../../currentSubcategory}}active{{/unless}}" data-action="subcategory-nav" data-subcategory="" data-family="">
        {{localize 'SWSE.Store.Navigation.AllCategory' category=label}}<span class="store-chip-count">{{count}}</span>
      </button>

      {{#if familyTabs}}
      <div class="store-family-tabs" aria-label="{{label}} folders">
        <button type="button" class="store-chip store-family-chip {{#unless ../../../currentFamily}}active{{/unless}}" data-action="family-nav" data-family="">
          {{#if allLabel}}{{allLabel}}{{else}}{{localize 'SWSE.Store.Navigation.AllCategory' category=label}}{{/if}}<span class="store-chip-count">{{count}}</span>
        </button>
        {{#each familyTabs}}
        <button type="button" class="store-chip store-family-chip {{#if active}}active{{/if}}" data-action="family-nav" data-family="{{family}}">
          {{label}}<span class="store-chip-count">{{count}}</span>
        </button>
        {{/each}}
      </div>
      {{/if}}
      {{#each children}}
      <button type="button" class="store-chip store-subcat-chip store-subcat-chip--{{family}} {{#if active}}active{{/if}}"
              data-action="subcategory-nav" data-subcategory="{{label}}" data-family="{{family}}">
        {{label}}<span class="store-chip-count">{{count}}</span>
      </button>
      {{/each}}
    </div>
    {{/if}}
    {{/if}}
    {{/each}}
    {{/if}}
    <div class="store-filter-controls">
      <select id="store-availability-filter" class="store-filter-select" aria-label="{{localize 'SWSE.Store.Filters.FilterAvailabilityAria'}}">
        <option value="">{{localize 'SWSE.Store.Filters.AllAvailability'}}</option>
        <option value="Standard">{{localize 'SWSE.Store.Filters.Standard'}}</option>
        <option value="Licensed">{{localize 'SWSE.Store.Filters.Licensed'}}</option>
        <option value="Restricted">{{localize 'SWSE.Store.Filters.Restricted'}}</option>
        <option value="Military">{{localize 'SWSE.Store.Filters.Military'}}</option>
        <option value="Illegal">{{localize 'SWSE.Store.Filters.Illegal'}}</option>
        <option value="Rare">{{localize 'SWSE.Store.Filters.Rare'}}</option>
      </select>
      <select id="store-sort" class="store-filter-select" aria-label="{{localize 'SWSE.Store.Filters.SortItemsAria'}}">
        <option value="suggested">{{localize 'SWSE.Store.Filters.Suggested'}}</option>
        <option value="price-asc">{{localize 'SWSE.Store.Filters.PriceAsc'}}</option>
        <option value="price-desc">{{localize 'SWSE.Store.Filters.PriceDesc'}}</option>
        <option value="name-asc">{{localize 'SWSE.Store.Filters.NameAZ'}}</option>
      </select>
      {{#if (eq currentCategory 'vehicles')}}
      <select id="store-vehicle-size-filter" class="store-filter-select" aria-label="Filter vehicles by size">
        <option value="">All Sizes</option>
        {{#each vehicleSizeOptions}}
        <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
      <select id="store-vehicle-cl-filter" class="store-filter-select" aria-label="Filter vehicles by challenge level" {{#unless vehicleClOptions.length}}disabled{{/unless}}>
        <option value="">{{#if vehicleClOptions.length}}All CL{{else}}CL unavailable{{/if}}</option>
        {{#each vehicleClOptions}}
        <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}} ({{count}})</option>
        {{/each}}
      </select>
      <select id="store-vehicle-crew-filter" class="store-filter-select" aria-label="Filter vehicles by crew size" {{#unless vehicleCrewOptions.length}}disabled{{/unless}}>
        <option value="">All Crew</option>
        {{#each vehicleCrewOptions}}
        <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}} ({{count}})</option>
        {{/each}}
      </select>
      <select id="store-vehicle-cargo-filter" class="store-filter-select" aria-label="Filter vehicles by cargo capacity" {{#unless vehicleCargoOptions.length}}disabled{{/unless}}>
        <option value="">All Cargo</option>
        {{#each vehicleCargoOptions}}
        <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}} ({{count}})</option>
        {{/each}}
      </select>
      <select id="store-vehicle-hyperdrive-filter" class="store-filter-select" aria-label="Filter vehicles by hyperdrive" {{#unless vehicleHyperdriveOptions.length}}disabled{{/unless}}>
        <option value="">Hyperdrive: Any</option>
        {{#each vehicleHyperdriveOptions}}
        <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}} ({{count}})</option>
        {{/each}}
      </select>
      <select id="store-vehicle-weapons-filter" class="store-filter-select" aria-label="Filter vehicles by weapons" {{#unless vehicleWeaponsOptions.length}}disabled{{/unless}}>
        <option value="">Weapons: Any</option>
        {{#each vehicleWeaponsOptions}}
        <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}} ({{count}})</option>
        {{/each}}
      </select>
      <select id="store-vehicle-shields-filter" class="store-filter-select" aria-label="Filter vehicles by shields" {{#unless vehicleShieldsOptions.length}}disabled{{/unless}}>
        <option value="">Shields: Any</option>
        {{#each vehicleShieldsOptions}}
        <option value="{{key}}" {{#if active}}selected{{/if}}>{{label}} ({{count}})</option>
        {{/each}}
      </select>
      {{/if}}
      <button type="button" class="store-chip" data-action="clear-filters" title="{{localize 'SWSE.Store.Filters.ResetFilters'}}">
        <i class="fa-solid fa-filter-circle-xmark"></i>
      </button>
    </div>
  </div>
  {{/if}}

  <div class="store-viewport">

    {{#if (eq currentView 'detail')}}
    <div class="store-pane store-pane-detail">
      <div class="store-pane-header">
        <button type="button" class="store-back-btn holo-btn secondary" data-action="show-browse">
          <i class="fa-solid fa-chevron-left"></i> {{localize 'SWSE.Store.Detail.Back'}}
        </button>
        <div class="store-pane-title-group">
          <div class="store-page-kicker">{{localize 'SWSE.Store.Detail.ProductDetail'}}</div>
          <h2 class="store-page-title">{{selectedProduct.name}}</h2>
        </div>
      </div>
      {{#if selectedProduct}}
        <div class="store-detail-layout">
          <div class="store-detail-hero swse-holo-card">
            <div class="glyph-panel detail-glyph-panel"><div class="store-glyph" aria-hidden="true">{{selectedProduct.glyph}}</div></div>
            <div class="store-detail-meta">
              <div class="detail-chip">{{selectedProduct.category}}</div>
              <div class="detail-chip">{{selectedProduct.availability}}</div>
              {{#if selectedProduct.suggestionTierLabel}}<div class="detail-chip highlight">{{selectedProduct.suggestionTierLabel}}</div>{{/if}}
            </div>
            <div class="store-detail-price">{{selectedProduct.priceLabel}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span>{{#if selectedProduct.priceOverrideApplied}} <span class="policy-price-chip">{{localize 'SWSE.Store.Detail.GmPrice'}}</span>{{/if}}</div>
            {{#unless selectedProduct.canPurchase}}<div class="store-policy-lock store-policy-lock--detail"><i class="fa-solid fa-lock"></i> {{selectedProduct.blockedReason}}</div>{{/unless}}
            <div class="store-detail-qty-row">
              <button type="button" class="detail-qty-minus holo-btn secondary">−</button>
              <input type="number" class="detail-qty-input" value="1" min="1" max="999" />
              <button type="button" class="detail-qty-plus holo-btn secondary">+</button>
              <button type="button" class="detail-add-btn holo-btn" data-action="detail-add-to-cart" {{#unless selectedProduct.canPurchase}}disabled title="{{selectedProduct.blockedReason}}"{{/unless}}>{{localize 'SWSE.Store.Detail.AddToCart'}}</button>
              <button type="button" class="detail-customize-btn holo-btn secondary" data-action="detail-customize-item">{{localize 'SWSE.Store.Detail.Customize'}}</button>
              <button type="button" class="detail-save-btn holo-btn secondary" data-action="detail-save-for-later">{{localize 'SWSE.Store.Detail.SaveForLater'}}</button>
            </div>
          </div>
          <div class="store-detail-main">
            {{#if selectedProduct.suggestionBullets.length}}
              <section class="detail-section swse-holo-card">
                <div class="detail-section-title">{{localize 'SWSE.Store.Detail.RecommendationNotes'}}</div>
                <ul class="detail-bullets">
                  {{#each selectedProduct.suggestionBullets}}<li>{{this}}</li>{{/each}}
                </ul>
              </section>
            {{/if}}
            {{#if selectedProduct.techDetailsHtml}}
              <section class="detail-section swse-holo-card">
                <div class="detail-section-title">{{localize 'SWSE.Store.Detail.TechnicalSpecifications'}}</div>
                <div class="detail-specs">{{{selectedProduct.techDetailsHtml}}}</div>
              </section>
            {{/if}}
            {{#if selectedProduct.description}}
              <section class="detail-section swse-holo-card">
                <div class="detail-section-title">{{localize 'SWSE.Store.Detail.ItemBrief'}}</div>
                <div class="detail-description store-item-brief" data-description-source="{{selectedProduct.descriptionSource}}">
                  <div class="store-item-brief-aurebesh" data-role="translation-text">{{selectedProduct.descriptionAurebesh}}</div>
                  <div class="store-item-brief-basic">{{selectedProduct.descriptionBasic}}</div>
                </div>
              </section>
            {{/if}}
            {{#if selectedProduct.mentorReview}}
              <section class="detail-section swse-holo-card mentor-review-card">
                <div class="detail-section-title">{{localize 'SWSE.Store.Detail.QuartermasterGuidance'}}</div>
                <p class="mentor-review-text">"{{selectedProduct.mentorReview}}"</p>
              </section>
            {{/if}}
            {{#if selectedProduct.flavorReviewsHtml}}
              <section class="detail-section swse-holo-card">
                <div class="detail-section-title">{{localize 'SWSE.Store.Detail.MarketplaceReviews'}}</div>
                <div class="detail-reviews">{{{selectedProduct.flavorReviewsHtml}}}</div>
              </section>
            {{/if}}
          </div>
        </div>
      {{/if}}
    </div>

    {{else}}
    {{#if (eq currentView 'cart')}}
    <div class="store-pane store-pane-cart">
      <div class="store-pane-header">
        <button type="button" class="store-back-btn holo-btn secondary" data-action="show-browse">
          <i class="fa-solid fa-chevron-left"></i> {{localize 'SWSE.Store.Detail.Back'}}
        </button>
        <div class="store-pane-title-group">
          <div class="store-page-kicker">{{localize 'SWSE.Store.Cart.CartManifest'}}</div>
          <h2 class="store-page-title">{{localize 'SWSE.Store.Cart.TradeLedger'}}</h2>
        </div>
      </div>
      <div class="store-cart-layout">
        <div class="store-cart-list swse-holo-card">
          {{#if cartEntries.length}}
            {{#each cartEntries}}
              <div class="cart-item-row">
                <div class="glyph-panel cart-glyph-panel"><div class="store-glyph" aria-hidden="true">{{type}}</div></div>
                <div class="cart-item-meta">
                  <div class="cart-item-name">{{name}}</div>
                  <div class="cart-item-type">{{type}}</div>
                </div>
                <div class="cart-item-cost">{{cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></div>
                <button type="button" class="cart-item-remove holo-btn secondary" data-action="remove-cart-row" data-type="{{type}}" data-id="{{id}}">
                  <i class="fa-solid fa-times"></i>
                </button>
              </div>
            {{/each}}
          {{else}}
            <div class="empty-state compact">
              <i class="fa-solid fa-cart-shopping"></i>
              <p>{{localize 'SWSE.Store.Cart.YourCartIsEmpty'}}</p>
            </div>
          {{/if}}
        </div>
        <div class="store-cart-summary swse-holo-card">
          <div class="detail-section-title">{{localize 'SWSE.Store.Cart.Totals'}}</div>
          <div class="summary-line"><span>{{localize 'SWSE.Store.Cart.Subtotal'}}</span><strong>{{cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></strong></div>
          <div class="summary-line"><span>{{localize 'SWSE.Store.Cart.Remaining'}}</span><strong>{{cartRemaining}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></strong></div>
          <div class="rail-action-cluster stacked">
            <button type="button" class="checkout-btn holo-btn" id="checkout-cart">{{localize 'SWSE.Store.Cart.ProceedToCheckout'}}</button>
            <button type="button" class="clear-cart-btn holo-btn secondary" id="clear-cart">{{localize 'SWSE.Store.Cart.ClearCart'}}</button>
          </div>
        </div>
      </div>
    </div>

    {{else}}
    {{#if (eq currentView 'checkout')}}
    <div class="store-pane store-pane-checkout">
      <div class="store-pane-header">
        <button type="button" class="store-back-btn holo-btn secondary" data-action="view-cart">
          <i class="fa-solid fa-chevron-left"></i> {{localize 'SWSE.Store.Checkout.BackToCart'}}
        </button>
        <div class="store-pane-title-group">
          <div class="store-page-kicker">{{localize 'SWSE.Store.Checkout.ExchangeConfirmation'}}</div>
          <h2 class="store-page-title">{{localize 'SWSE.Store.Checkout.FinalizeTrade'}}</h2>
        </div>
      </div>
      <div class="store-checkout-layout">
        <section class="store-checkout-ledger swse-holo-card">
          <div class="detail-section-title">{{localize 'SWSE.Store.Checkout.LockedManifest'}}</div>
          {{#if cartEntries.length}}
            <div class="checkout-ledger-list">
              {{#each cartEntries}}
                <div class="checkout-ledger-row">
                  <span class="checkout-ledger-name">{{name}}</span>
                  <span class="checkout-ledger-type">{{type}}</span>
                  <span class="checkout-ledger-cost">{{cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></span>
                </div>
              {{/each}}
            </div>
          {{else}}
            <div class="empty-state compact"><i class="fa-solid fa-cart-shopping"></i><p>{{localize 'SWSE.Store.Checkout.NoItemsStaged'}}</p></div>
          {{/if}}
        </section>
        <aside class="store-checkout-summary swse-holo-card">
          <div class="detail-section-title">{{localize 'SWSE.Store.Checkout.Settlement'}}</div>
          <div class="summary-line"><span>{{localize 'SWSE.Store.Checkout.Available'}}</span><strong>{{credits}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></strong></div>
          <div class="summary-line"><span>{{localize 'SWSE.Store.Checkout.Debit'}}</span><strong>{{cartTotal}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></strong></div>
          <div class="summary-line"><span>{{localize 'SWSE.Store.Checkout.ReserveAfterTrade'}}</span><strong><span id="cart-remaining">{{pageContext.cartRemaining}}</span><span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></strong></div>
          <div class="checkout-guidance">{{localize 'SWSE.Store.Checkout.Guidance'}}</div>
          <div class="rail-action-cluster stacked">
            <button type="button" class="checkout-btn holo-btn primary" id="confirm-checkout">{{localize 'SWSE.Store.Checkout.ConfirmTrade'}}</button>
            <button type="button" class="holo-btn secondary" data-action="view-cart">{{localize 'SWSE.Store.Checkout.ReturnToCart'}}</button>
          </div>
        </aside>
      </div>
    </div>

    {{else}}
    {{#if (eq currentView 'history')}}
    <div class="store-pane store-pane-history">
      <div class="store-pane-header">
        <button type="button" class="store-back-btn holo-btn secondary" data-action="show-browse">
          <i class="fa-solid fa-chevron-left"></i> {{localize 'SWSE.Store.Detail.Back'}}
        </button>
        <div class="store-pane-title-group">
          <div class="store-page-kicker">{{localize 'SWSE.Store.History.AccountArchive'}}</div>
          <h2 class="store-page-title">{{localize 'SWSE.Store.History.PurchaseHistory'}}</h2>
        </div>
      </div>
      <div class="store-history-layout swse-holo-card">
        {{#if purchaseHistoryEntries.length}}
          <div class="store-history-list">
            {{#each purchaseHistoryEntries}}
              <div class="history-entry">
                <div class="history-header">
                  <span class="history-date"><i class="fa-solid fa-calendar"></i> {{timestamp}}</span>
                  <span class="history-total">{{total}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></span>
                </div>
                <div class="history-items">
                  {{#each items}}
                    <div class="history-item">
                      <span class="item-name">{{name}}</span>
                      <span class="item-qty">×{{qty}}</span>
                      <span class="item-cost">{{cost}}<span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span></span>
                    </div>
                  {{/each}}
                </div>
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-state compact store-history-empty">
            <i class="fa-solid fa-receipt"></i>
            <p>{{localize 'SWSE.Store.History.NoPurchases'}}</p>
          </div>
        {{/if}}
      </div>
    </div>

    {{else}}
    <div class="store-pane store-pane-browse">
      {{#if (eq currentCategory 'droids')}}
      <div class="store-browse-actions">
        <button type="button" class="create-custom-droid holo-btn secondary">
          <i class="fa-solid fa-robot"></i> {{localize 'SWSE.Store.Browse.BuildCustomDroid'}}
        </button>
        <button type="button" class="build-droid-from-template holo-btn secondary">
          <i class="fa-solid fa-clone"></i> {{localize 'SWSE.Store.Browse.FromTemplate'}}
        </button>
      </div>
      {{/if}}
      {{#if (eq currentCategory 'vehicles')}}
      <div class="store-browse-actions">
        <button type="button" class="create-custom-starship holo-btn secondary">
          <i class="fa-solid fa-rocket"></i> {{localize 'SWSE.Store.Browse.BuildShipVehicle'}}
        </button>
      </div>
      {{/if}}
      <div class="card-grid-container">
        <div class="products-grid" id="products-grid">
          {{#each allItems}}
            <div class="holo-card product-card {{#unless this.canPurchase}}is-policy-blocked{{/unless}}" data-item-id="{{this.id}}" data-category="{{this.category}}" data-category-key="{{this.categoryKey}}" data-subcategory="{{this.subcategory}}" data-subcategory-key="{{this.subcategoryKey}}" data-family="{{#if this.navigationFamily}}{{this.navigationFamily}}{{else}}{{this.weaponFamily}}{{/if}}" data-vehicle-size="{{this.vehicleSizeKey}}" data-vehicle-cl="{{this.vehicleChallengeBand}}" data-vehicle-crew="{{this.vehicleCrewGroup}}" data-vehicle-cargo="{{this.vehicleCargoGroup}}" data-vehicle-hyperdrive="{{this.vehicleHyperdriveKey}}" data-vehicle-weapons="{{this.vehicleWeaponsKey}}" data-vehicle-shields="{{this.vehicleShieldsKey}}" data-availability="{{this.availability}}" data-availability-key="{{this.availabilityKey}}" data-rarity="{{this.rarityClass}}" data-can-purchase="{{this.canPurchase}}">
              <div class="card-header">
                {{#if this.suggestion}}
                  <span class="suggestion-badge tier-{{this.suggestion.tier}}">{{this.suggestion.tierLabel}}</span>
                {{/if}}
              </div>
              <div class="card-body">
                <div class="glyph-panel"><div class="store-glyph" aria-hidden="true">{{#if this.cardLetter}}{{this.cardLetter}}{{else}}{{this.glyph}}{{/if}}</div></div>
                <h4 class="card-title">{{this.name}}</h4>
                {{#if this.suggestion.bullets}}
                  <div class="card-explanations">
                    {{#each this.suggestion.bullets}}<div class="explanation-bullet">• {{this}}</div>{{/each}}
                  </div>
                {{/if}}
                <div class="card-meta-row">
                  <span class="detail-chip">{{this.category}}</span>
                  {{#if this.subcategory}}<span class="detail-chip">{{this.subcategory}}</span>{{/if}}
                  {{#if this.vehicleSizeLabel}}<span class="detail-chip">{{this.vehicleSizeLabel}}</span>{{/if}}
                  {{#if this.vehicleChallengeLabel}}<span class="detail-chip">{{this.vehicleChallengeLabel}}</span>{{/if}}
                  {{#if this.vehicleCrewLabel}}<span class="detail-chip">{{this.vehicleCrewLabel}}</span>{{/if}}
                  {{#if this.vehicleHyperdriveKey}}<span class="detail-chip">{{#if (eq this.vehicleHyperdriveKey 'yes')}}Hyperdrive{{else}}No Hyperdrive{{/if}}</span>{{/if}}
                  {{#if this.vehicleWeaponsKey}}<span class="detail-chip">{{#if (eq this.vehicleWeaponsKey 'yes')}}Armed{{else}}Unarmed{{/if}}</span>{{/if}}
                  {{#if this.vehicleShieldsKey}}<span class="detail-chip">{{#if (eq this.vehicleShieldsKey 'yes')}}Shielded{{else}}No Shields{{/if}}</span>{{/if}}
                  <span class="detail-chip">{{this.availability}}</span>
                </div>
                <div class="card-price"><span class="price-amount">{{this.priceLabel}}</span><span class="swse-credit-symbol swse-credit-symbol--suffix" aria-label="{{localize 'SWSE.Store.Header.Credits'}}"></span>{{#if this.priceOverrideApplied}}<span class="policy-price-chip">{{localize 'SWSE.Store.Detail.GmPrice'}}</span>{{/if}}</div>
                {{#unless this.canPurchase}}<div class="store-policy-lock"><i class="fa-solid fa-lock"></i> {{this.blockedReason}}</div>{{/unless}}
              </div>
              <div class="card-footer">
                <button type="button" class="expand-btn holo-btn" data-action="expand-product" data-item-id="{{this.id}}">{{localize 'SWSE.Store.Detail.OpenListing'}}</button>
                <button type="button" class="add-to-cart-btn holo-btn secondary" data-action="add-to-cart" data-item-id="{{this.id}}" {{#unless this.canPurchase}}disabled title="{{this.blockedReason}}"{{/unless}}>
                  {{#if this.canPurchase}}<i class="fa-solid fa-plus"></i>{{else}}<i class="fa-solid fa-lock"></i>{{/if}}
                </button>
              </div>
            </div>
          {{/each}}
        </div>
        <div class="empty-state store-no-results" style="display:none;">
          <i class="fa-solid fa-box-open"></i>
          <p>{{localize 'SWSE.Store.Browse.NoResults'}}</p>
        </div>
      </div>
    </div>
    {{/if}}
    {{/if}}
    {{/if}}
    {{/if}}

  </div>

</form>
</div>
