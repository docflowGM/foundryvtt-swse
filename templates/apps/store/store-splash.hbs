<section class="swse-store-splash swse-store-splash--rendarrs"
         data-splash="store"
         data-store-status="{{#if storeOpen}}open{{else}}closed{{/if}}"
         data-store-motion="{{sheetMotionStyle}}"
         data-theme="{{sheetTheme}}"
         tabindex="0"
         aria-label="Rendarr's Outfitters market splash screen">
  <script type="application/json" data-store-hot-deals-json>{{{hotDealsJson}}}</script>

  <!-- Scanline + corner HUD overlays (screen effects, not a second shell) -->
  <div class="ren-scan-v" aria-hidden="true"></div>
  <span class="ren-corner ren-corner--tl" aria-hidden="true"></span>
  <span class="ren-corner ren-corner--tr" aria-hidden="true"></span>
  <span class="ren-corner ren-corner--bl" aria-hidden="true"></span>
  <span class="ren-corner ren-corner--br" aria-hidden="true"></span>

  <!-- Top HUD -->
  <div class="ren-hud">
    <div class="ren-hud__left">
      <span class="ren-hud__app">RENDARR // OUTFITTERS <span class="ren-hud__ver">v3.41 · holo</span></span>
    </div>
    <div class="ren-hud__right">
      <span><span class="ren-dot"></span>HOLONET · 4 bars</span>
      <span><span class="ren-dot ren-dot--warn"></span>encrypted · class 3</span>
      <span data-ren-clock>00:00:00 · GST</span>
    </div>
  </div>

  <!-- GEX Live Ticker -->
  <div class="ren-ticker-wrap" aria-label="Galactic Exchange live feed">
    <div class="ren-ticker-tag">GEX · LIVE</div>
    <div class="ren-ticker" aria-hidden="true">
      <div class="ren-ticker__track" data-store-ticker-track></div>
    </div>
    <div class="ren-ticker-end">RX // FLOOR FEED</div>
  </div>

  <!-- Hero: neon sign + open sign + rate card -->
  <div class="ren-hero">
    <div class="ren-neon-stack">
      <div class="ren-eyebrow" aria-hidden="true">
        <span class="ren-eyebrow__pip"></span>
        EST. 14 ABY <span class="ren-eyebrow__x">×</span> DOCK 9 · NAR SHADDAA
        <span class="ren-eyebrow__pip"></span> ALL CREDITS HONORED
      </div>
      <div class="ren-neon-sign" aria-label="Rendarr's Outfitters">
        <span class="ren-neon-line">Rendarr<span class="ren-neon-amp">'s</span></span>
        <span class="ren-neon-line ren-neon-line--two">Outfitters</span>
      </div>
      <div class="ren-tube-rail" aria-hidden="true"></div>
      <div class="ren-tagline" aria-hidden="true">Guns <span class="ren-tagline__star">★</span> Gear <span class="ren-tagline__star">★</span> Glory <span class="ren-tagline__star">★</span> No&nbsp;Questions</div>
    </div>

    <div class="ren-hero-right">
      <!-- OPEN / CLOSED neon sign -->
      <div class="ren-open-sign {{#if storeOpen}}is-open{{else}}is-closed{{/if}}" aria-live="polite">
        <span class="ren-open-sign__chain ren-open-sign__chain--l" aria-hidden="true"></span>
        <span class="ren-open-sign__chain ren-open-sign__chain--r" aria-hidden="true"></span>
        <div class="ren-open-sign__word">{{#if storeOpen}}<span class="ren-open-sign__o">O</span>PEN{{else}}CLOSED{{/if}}</div>
        <div class="ren-open-sign__sub" data-store-status-label>{{storeStatusLabel}}</div>
      </div>

      <!-- GM tax / discount rate card -->
      <div class="ren-rate-card" data-ren-rate-card data-buy-modifier="{{marketControls.buyModifier}}">
        <div class="ren-rate-card__head">
          <span class="ren-rate-card__label" data-ren-rate-label>GM MARKET</span>
          <span class="ren-rate-card__pulse" aria-hidden="true"></span>
        </div>
        <div class="ren-rate-card__val" data-ren-rate-val>
          {{#if marketControls.taxLabel}}{{marketControls.taxLabel}}{{else}}±0%{{/if}}
        </div>
        <div class="ren-rate-card__reason" data-ren-rate-reason>
          <span class="ren-em">MARKET</span> stable · no active modifiers
        </div>
      </div>
    </div>
  </div>

  <!-- Rendarr hologram greeting strip -->
  <div class="ren-rendarr-strip">
    <div class="ren-holo-portrait" aria-hidden="true">
      <img class="ren-holo-portrait__img"
           src="systems/foundryvtt-swse/assets/mentors/Rendarr.png"
           alt="" />
      <div class="ren-holo-portrait__pedestal"></div>
    </div>
    <div class="ren-rendarr-greet">
      <div class="ren-rendarr-greet__name">
        <span class="ren-rendarr-greet__mark">⚐</span>RENDARR
        <span class="ren-rendarr-greet__sub">— PROPRIETOR · EX-CLONE · INDEX 4,712</span>
      </div>
      <div class="ren-rendarr-greet__line" data-ren-greeting>
        Boot the terminal, friend. I don't care why you're here — I care what you're spending.<span class="ren-cursor" aria-hidden="true"></span>
      </div>
    </div>
    <div class="ren-strip-meta">
      <div class="ren-strip-meta__label">WALLET</div>
      <div class="ren-strip-meta__val" data-ren-wallet>{{#if credits}}{{credits}}{{else}}—{{/if}}</div>
      <div class="ren-strip-meta__label">{{actorName}}</div>
    </div>
  </div>

  <!-- Hot Items Tonight -->
  <div class="ren-hot-section">
    <div class="ren-hot-head">
      <div class="ren-hot-head__title"><span class="ren-hot-head__flame">▲</span>HOT ITEMS · TONIGHT</div>
      <div class="ren-hot-head__sub">moves fast · <span class="ren-em">tap to jump</span> · rotates</div>
    </div>
    <div class="ren-hot-grid-wrap">
      <div class="ren-hot-grid" data-hot-grid></div>
    </div>
  </div>

  <!-- CTA bar -->
  <div class="ren-cta-bar">
    <div class="ren-cta-side">
      <div class="ren-cta-side__label">FLOOR FOOTFALL</div>
      <div class="ren-cta-side__big">23 / hr</div>
      <div class="ren-cta-side__label">3 BROWSING NOW</div>
    </div>
    <button type="button"
            class="ren-enter-btn{{#unless storeOpen}} is-closed{{/unless}}"
            data-action="store-splash-continue">
      {{#if storeOpen}}ENTER OUTFITTERS →{{else}}STORE CLOSED{{/if}}
    </button>
    <div class="ren-cta-side ren-cta-side--right">
      <div class="ren-cta-side__label">HAGGLE WINDOW</div>
      <div class="ren-cta-side__big ren-cta-side__big--alt">2H 14M</div>
      <div class="ren-cta-side__label">BEFORE STOCK ROTATES</div>
    </div>
  </div>

  <!-- Footer -->
  <div class="ren-footer">
    <div class="ren-footer__left">
      <span><span class="ren-footer__pulse" aria-hidden="true"></span>UPLINK · STABLE</span>
      <span data-store-boot-label>{{#if storeOpen}}Opening Rendarr vendor channel{{else}}Catalog frozen // vendor channel closed{{/if}}</span>
    </div>
    <div class="ren-footer__right">
      <span>© RENDARR INDUSTRIES</span>
      <span>NO REFUNDS · NO QUESTIONS</span>
    </div>
  </div>
</section>
