<div class="purchase-history swse-dense-region swse-store-stage">
  {{#each entries}}
  <div class="history-entry swse-ui-panel swse-history-entry">
    <div class="history-header swse-card-header">
      <span class="history-date">
        <i class="{{getIconClass 'calendar'}}"></i> {{timestamp}}
      </span>
      <span class="history-total">
        <span class="credits-icon">$</span> {{total}}
      </span>
    </div>

    <div class="history-items">
      {{#each items}}
      <div class="history-item swse-row-surface">
        <span class="item-name">{{name}}</span>
        <span class="item-qty">×{{qty}}</span>
        <span class="item-cost">
          <span class="credits-icon">$</span>{{cost}}
        </span>
        {{#if condition}}
        {{#unless condition equals "new"}}
        <span class="item-condition">({{condition}})</span>
        {{/unless}}
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>
  {{/each}}
</div>
