<form class="swse-chargen-form swse-chargen-dashboard">
  <div class="swse-chargen-shell">
    <div class="swse-console-topline"><span>ONLINE DATAPAD</span><span>·</span><span>INITIATE NEW PROFILE</span><span class="swse-console-power">CHARGEN</span></div>
    <div class="swse-chargen-hero">
      <div class="swse-chargen-copy">
        <h1>WELCOME BACK</h1>
        <p>Access character records, progression training, and workbench tools from a single tactical console.</p>
        <div class="swse-chargen-actions"><button type="submit" class="dialog-button default">Create Actor</button></div>
      </div>
      <div class="swse-radial-shell chargen-shell"><div class="swse-radial-ring swse-radial-ring--outer"></div><div class="swse-radial-ring swse-radial-ring--mid"></div><div class="swse-radial-core"><span>NEW</span></div></div>
    </div>
    <div class="swse-form-grid two-col">
      <label>Actor Name<input type="text" name="name" placeholder="Enter a name" /></label>
      <label>Actor Type<select name="type">{{#each actorTypes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select></label>
    </div>
  </div>
</form>
