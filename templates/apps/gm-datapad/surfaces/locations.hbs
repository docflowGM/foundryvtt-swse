<div class="gm-datapad-page gm-datapad-locations swse-gm-locations gm-v2-surface gm-v2-surface--locations gm-phase5-locations gm-location-ux" data-shell-surface="locations" data-gm-surface="locations">
  <header class="gm-datapad-page-header swse-locations-hero gm-phase5-location-hero gm-location-ux-hero">
    <div class="gm-phase5-location-hero__copy">
      <p class="gm-datapad-kicker">GALACTIC LOCATION INDEX</p>
      <h2>{{surface.pageTitle}}</h2>
      <p>{{surface.pageDescription}}</p>
    </div>
    <div class="swse-location-stat-grid gm-phase5-location-metrics">
      <div><strong>{{surface.locationManager.stats.importedCount}}</strong><span>Imported</span></div>
      <div><strong>{{surface.locationManager.stats.quickLibraryCount}}</strong><span>Quick Planets</span></div>
      <div><strong>{{surface.locationManager.stats.quickLibraryRecordCount}}</strong><span>Possible Records</span></div>
      <div><strong>{{surface.locationManager.stats.known}}</strong><span>Known</span></div>
      <div><strong>{{surface.locationManager.stats.active}}</strong><span>Active</span></div>
      <div><strong>{{surface.locationManager.stats.leadDiscoveryCount}}</strong><span>Leads</span></div>
      <div><strong>{{surface.locationManager.stats.withScenes}}</strong><span>Scenes</span></div>
    </div>
  </header>

  <section class="gm-location-command-deck gm-location-command-deck--primary">
    <button type="button" class="gm-location-command-card gm-location-command-card--import" data-location-action="open-import-modal">
      <span class="gm-phase5-location-eyebrow">Quick Library</span>
      <strong>Import Location</strong>
      <p>Open a guided importer for {{surface.locationManager.library.summary.total}} quick planets. Import one or more with starter POIs and Atlas facts.</p>
      <em>{{surface.locationManager.library.summary.unimportedVisible}} matching unimported · {{surface.locationManager.library.summary.totalRecordCount}} possible records</em>
    </button>
    <button type="button" class="gm-location-command-card gm-location-command-card--create" data-location-action="new">
      <span class="gm-phase5-location-eyebrow">Creation Wizard</span>
      <strong>New Location</strong>
      <p>Build a planet, city, POI, base, ship, station, or strange site through a guided modal wizard.</p>
      <em>No blank dropdowns. Pick answers step by step.</em>
    </button>
    {{#if surface.locationManager.selected}}
      <button type="button" class="gm-location-command-card gm-location-command-card--edit" data-location-action="edit" data-location-id="{{surface.locationManager.selected.id}}">
        <span class="gm-phase5-location-eyebrow">Selected Dossier</span>
        <strong>Edit {{surface.locationManager.selected.name}}</strong>
        <p>Open this location in the guided wizard, then reveal, activate, or link it to Jobs/Intel/Scenes.</p>
        <em>{{surface.locationManager.selected.revealLabel}} · {{surface.locationManager.selected.typeLabel}}</em>
      </button>
    {{/if}}
  </section>

  <section class="gm-location-library-strip">
    <div>
      <span class="gm-phase5-location-eyebrow">Quick Location Library</span>
      <h3>{{surface.locationManager.library.summary.visible}} quick planets ready</h3>
      <p>These are not imported Atlas records yet. Use <strong>Import Location</strong> to choose one or more, or use the visible cards below as a preview of what the modal will offer.</p>
    </div>
    <div class="gm-location-library-strip__cards">
      {{#each surface.locationManager.library.previewCards}}
        <button type="button" class="gm-location-library-preview {{#if imported}}is-imported{{/if}}" data-location-action="open-import-modal">
          <strong>{{name}}</strong>
          <span>{{typeLabel}} · {{recordLabel}}</span>
        </button>
      {{else}}
        <span class="gm-location-library-preview is-empty">No quick library matches current filters.</span>
      {{/each}}
    </div>
  </section>

  <section class="gm-location-workbench">
    <aside class="gm-location-browser">
      <section class="swse-location-panel gm-phase5-location-panel gm-location-browser-filters">
        <div class="swse-location-panel-head gm-phase5-location-panel-head">
          <div>
            <span class="gm-phase5-location-eyebrow">Navigator</span>
            <h3>Find Locations</h3>
          </div>
          <span class="swse-location-chip">{{surface.locationManager.cards.length}} shown</span>
        </div>
        <label class="swse-location-field swse-location-field--wide">
          <span>Search</span>
          <input type="search" value="{{surface.locationManager.filters.search}}" data-location-filter="search" placeholder="planet, city, POI, faction, tag..." />
        </label>
        <div class="gm-location-filter-section">
          <span>Category</span>
          <div class="gm-location-filter-pills">
            {{#each surface.locationManager.categoryFilterButtons}}
              <button type="button" class="gm-location-filter-pill {{#if selected}}is-active{{/if}}" data-location-filter-button data-filter-key="category" data-filter-value="{{value}}">{{label}}</button>
            {{/each}}
          </div>
        </div>
        <div class="gm-location-filter-section">
          <span>Type</span>
          <div class="gm-location-filter-pills gm-location-filter-pills--scroll">
            {{#each surface.locationManager.typeFilterButtons}}
              <button type="button" class="gm-location-filter-pill {{#if selected}}is-active{{/if}}" data-location-filter-button data-filter-key="type" data-filter-value="{{value}}">{{label}}</button>
            {{/each}}
          </div>
        </div>
        <div class="gm-location-filter-section">
          <span>Reveal</span>
          <div class="gm-location-filter-pills">
            {{#each surface.locationManager.revealFilterButtons}}
              <button type="button" class="gm-location-filter-pill {{#if selected}}is-active{{/if}}" data-location-filter-button data-filter-key="revealState" data-filter-value="{{value}}">{{label}}</button>
            {{/each}}
          </div>
        </div>
        <div class="gm-location-filter-section">
          <span>Quick Filter</span>
          <div class="gm-location-filter-pills">
            {{#each surface.locationManager.specialFilterButtons}}
              <button type="button" class="gm-location-filter-pill {{#if selected}}is-active{{/if}}" data-location-filter-button data-filter-key="special" data-filter-value="{{value}}">{{label}}</button>
            {{/each}}
          </div>
        </div>
      </section>

      <section class="swse-location-panel gm-phase5-location-panel gm-location-browser-list">
        <div class="swse-location-panel-head gm-phase5-location-panel-head">
          <div>
            <span class="gm-phase5-location-eyebrow">Registry</span>
            <h3>Location Library</h3>
          </div>
        </div>
        {{#if surface.locationManager.filtersRelaxed}}
          <div class="gm-location-filter-warning">
            <strong>Filters hid all imported locations.</strong>
            <span>Showing all {{surface.locationManager.stats.importedCount}} imported records instead. Clear filters to return to the default view.</span>
            <button type="button" class="swse-mini-button" data-location-action="clear-location-filters">Clear Filters</button>
          </div>
        {{/if}}
        {{#if surface.locationManager.hasVisibleLocations}}
          <div class="gm-location-card-stack">
            {{#each surface.locationManager.cards}}
              <article class="swse-location-card gm-location-registry-card {{revealClass}} {{#if activeForParty}}is-party-active{{/if}} {{depthClass}} {{#if selected}}is-selected{{/if}}" data-location-id="{{id}}" data-swse-drag-kind="location" data-swse-drag-id="{{id}}" data-swse-drag-name="{{name}}" data-swse-drag-type="{{type}}" data-swse-drag-source="locations">
                <button type="button" class="swse-location-card-main" data-location-action="select" data-location-id="{{id}}">
                  <div class="swse-location-card-title-row">
                    <h3>{{name}}</h3>
                    <span class="swse-location-chip">{{typeLabel}}</span>
                  </div>
                  <p>{{#if chain}}{{chain}}{{else}}{{categoryLabel}}{{/if}}</p>
                  <div class="swse-location-card-meta">
                    <span>{{revealLabel}}</span>
                    <span>{{#if controllingFactionName}}{{controllingFactionName}}{{else}}No controller{{/if}}</span>
                    <span>{{childCount}} child</span>
                    <span>{{atlasFactCount}} facts</span>
                  </div>
                </button>
              </article>
            {{/each}}
          </div>
        {{else}}
          <div class="swse-empty-state gm-phase5-location-empty">
            <h3>No locations found</h3>
            <p>Import a quick location or create one with the guided wizard.</p>
            <p class="gm-location-empty-hint">Use the Import Location or New Location command cards above.</p>
          </div>
        {{/if}}
      </section>
    </aside>

    <main class="gm-location-detail">
      {{#if surface.locationManager.selected}}
        <section class="swse-location-panel gm-phase5-location-panel gm-location-selected-card swse-drop-zone" data-location-drop-zone data-location-id="{{surface.locationManager.selected.id}}">
          <div class="swse-location-panel-head gm-phase5-location-panel-head">
            <div>
              <span class="gm-phase5-location-eyebrow">Selected Location</span>
              <h3>{{surface.locationManager.selected.name}}</h3>
            </div>
            <span class="swse-location-chip {{surface.locationManager.selected.revealClass}}">{{surface.locationManager.selected.revealLabel}}</span>
          </div>
          <p class="gm-location-selected-summary">{{#if surface.locationManager.selected.publicSummary}}{{surface.locationManager.selected.publicSummary}}{{else}}No player-facing summary yet. Edit this location to add Atlas text.{{/if}}</p>
          <div class="gm-location-selected-stats">
            <div><strong>{{surface.locationManager.selected.categoryLabel}}</strong><span>Category</span></div>
            <div><strong>{{surface.locationManager.selected.typeLabel}}</strong><span>Type</span></div>
            <div><strong>{{surface.locationManager.selected.scaleLabel}}</strong><span>Scale</span></div>
            <div><strong>{{surface.locationManager.selected.childCount}}</strong><span>Children</span></div>
            <div><strong>{{surface.locationManager.selected.atlasFactCount}}</strong><span>Facts</span></div>
            <div><strong>{{surface.locationManager.selected.encounterSeedCount}}</strong><span>Seeds</span></div>
          </div>
          <div class="gm-location-selected-grid">
            <div><span>Region</span><strong>{{#if surface.locationManager.selected.raw.region}}{{surface.locationManager.selected.raw.region}}{{else}}Unassigned{{/if}}</strong></div>
            <div><span>Sector</span><strong>{{#if surface.locationManager.selected.raw.sector}}{{surface.locationManager.selected.raw.sector}}{{else}}Unassigned{{/if}}</strong></div>
            <div><span>System</span><strong>{{#if surface.locationManager.selected.raw.system}}{{surface.locationManager.selected.raw.system}}{{else}}Unassigned{{/if}}</strong></div>
            <div><span>Controller</span><strong>{{#if surface.locationManager.selected.controllingFactionName}}{{surface.locationManager.selected.controllingFactionName}}{{else}}None{{/if}}</strong></div>
          </div>
          <p class="swse-location-help">Drop Factions, NPC dossiers, Actors, Scenes, Journals, Intel, or Jobs on this card to link them.</p>
          <div class="swse-location-editor-actions gm-location-selected-actions">
            <button type="button" class="swse-mini-button primary" data-location-action="edit" data-location-id="{{surface.locationManager.selected.id}}">Edit in Wizard</button>
            <button type="button" data-location-action="reveal" data-location-id="{{surface.locationManager.selected.id}}">Reveal</button>
            <button type="button" data-location-action="hide" data-location-id="{{surface.locationManager.selected.id}}">GM Only</button>
            <button type="button" data-location-action="set-party-location" data-location-id="{{surface.locationManager.selected.id}}">Set Active</button>
            <button type="button" data-location-action="create-intel" data-location-id="{{surface.locationManager.selected.id}}">Create Intel</button>
            <button type="button" data-location-action="create-job" data-location-id="{{surface.locationManager.selected.id}}">Create Job</button>
            <button type="button" data-location-action="open-scene" data-location-id="{{surface.locationManager.selected.id}}">Open Scene</button>
            <button type="button" data-location-action="create-scene" data-location-id="{{surface.locationManager.selected.id}}">Create Scene</button>
            <button type="button" data-location-action="stage-encounter-seeds" data-location-id="{{surface.locationManager.selected.id}}">Stage Seeds</button>
            <button type="button" class="danger" data-location-action="delete" data-location-id="{{surface.locationManager.selected.id}}">Delete</button>
          </div>
        </section>

        <section class="swse-location-panel gm-phase5-location-panel gm-location-selected-support">
          <div>
            <span class="gm-phase5-location-eyebrow">Children</span>
            {{#each surface.locationManager.selected.children}}
              <button type="button" class="gm-location-linked-row" data-location-action="select" data-location-id="{{id}}">{{name}} <span>{{typeLabel}}</span></button>
            {{else}}
              <p>No child locations yet.</p>
            {{/each}}
          </div>
          <div>
            <span class="gm-phase5-location-eyebrow">Atlas Facts</span>
            {{#each surface.locationManager.selected.atlasFacts}}
              <div class="gm-location-fact-row">
                <strong>{{title}}</strong>
                <span>{{categoryLabel}} · {{revealLabel}} · {{outputLabel}}</span>
                <div>
                  <button type="button" data-location-action="fact-intel" data-location-id="{{../surface.locationManager.selected.id}}" data-fact-id="{{id}}">Intel</button>
                  <button type="button" data-location-action="fact-job" data-location-id="{{../surface.locationManager.selected.id}}" data-fact-id="{{id}}">Job</button>
                  <button type="button" data-location-action="remove-fact" data-location-id="{{../surface.locationManager.selected.id}}" data-fact-id="{{id}}">Remove</button>
                </div>
              </div>
            {{else}}
              <p>No Atlas facts seeded yet.</p>
            {{/each}}
          </div>
        </section>
      {{else}}
        <section class="swse-location-panel gm-phase5-location-panel gm-location-empty-detail">
          <span class="gm-phase5-location-eyebrow">No Selection</span>
          <h3>Import or create the first location</h3>
          <p>Locations are easier as modal workflows: import from the Quick Library, or create a new record step by step.</p>
          <div class="swse-location-editor-actions">
            <button type="button" class="swse-mini-button primary" data-location-action="open-import-modal">Import Location</button>
            <button type="button" class="swse-mini-button" data-location-action="new">New Location</button>
          </div>
        </section>
      {{/if}}
    </main>
  </section>

  {{#if surface.locationManager.modal.isImport}}
    <div class="gm-location-modal-layer" data-location-modal="import">
      <form class="gm-location-modal gm-location-modal--import gm-location-wizard" data-location-import-form data-location-wizard="import" data-current-page="1">
        <header class="gm-location-modal-head">
          <div>
            <span class="gm-phase5-location-eyebrow">Quick Locations Compendium</span>
            <h3>Import Locations</h3>
            <p>Pick one or more planets from the library, choose import options, then confirm.</p>
          </div>
          <button type="button" class="gm-location-modal-close" data-location-action="close-modal">×</button>
        </header>

        <div class="gm-location-wizard-steps">
          <span class="is-active" data-wizard-step-indicator="1">1 Browse</span>
          <span data-wizard-step-indicator="2">2 Options</span>
          <span data-wizard-step-indicator="3">3 Import</span>
        </div>

        <section class="gm-location-wizard-page is-active" data-wizard-page="1">
          <section class="gm-location-modal-stats">
            <div><strong>{{surface.locationManager.library.summary.total}}</strong><span>planets</span></div>
            <div><strong>{{surface.locationManager.library.summary.visible}}</strong><span>shown</span></div>
            <div><strong>{{surface.locationManager.library.summary.visibleRecordCount}}</strong><span>records if imported</span></div>
            <div><strong>{{surface.locationManager.library.summary.imported}}</strong><span>imported</span></div>
          </section>
          <section class="gm-location-modal-filters gm-location-modal-filters--friendly">
            <label class="swse-location-field">
              <span>Search Library</span>
              <input type="search" value="{{surface.locationManager.filters.librarySearch}}" data-location-filter="librarySearch" placeholder="Tatooine, water, Sith, underworld, temple..." />
            </label>
            <div class="gm-location-filter-section">
              <span>Biome / Theme</span>
              <div class="gm-location-filter-pills gm-location-filter-pills--scroll">
                {{#each surface.locationManager.libraryBiomeButtons}}
                  <button type="button" class="gm-location-filter-pill {{#if selected}}is-active{{/if}}" data-location-filter-button data-filter-key="libraryBiome" data-filter-value="{{value}}">{{label}}</button>
                {{/each}}
              </div>
            </div>
            <div class="gm-location-filter-section">
              <span>Category</span>
              <div class="gm-location-filter-pills">
                {{#each surface.locationManager.libraryCategoryButtons}}
                  <button type="button" class="gm-location-filter-pill {{#if selected}}is-active{{/if}}" data-location-filter-button data-filter-key="libraryCategory" data-filter-value="{{value}}">{{label}}</button>
                {{/each}}
              </div>
            </div>
            <button type="button" class="swse-mini-button" data-location-action="clear-library-filters">Clear Filters</button>
          </section>
          <section class="gm-location-import-list">
            {{#each surface.locationManager.library.cards}}
              <label class="gm-location-import-card {{#if imported}}is-imported{{/if}}">
                <input type="checkbox" name="seedIds" value="{{id}}" {{#if imported}}disabled{{/if}} />
                <div>
                  <strong>{{name}}</strong>
                  <span>{{categoryLabel}} · {{typeLabel}} · {{region}}</span>
                  <p>{{summary}}</p>
                  <small>{{recordLabel}} · {{biomeLabels}}</small>
                </div>
                {{#if imported}}<em>Imported</em>{{else}}<em>Select</em>{{/if}}
              </label>
            {{else}}
              <div class="gm-location-modal-empty">
                <h4>No quick locations match those filters.</h4>
                <p>Clear filters or search a broader term such as desert, city, water, Jedi, Sith, underworld, or frontier.</p>
              </div>
            {{/each}}
          </section>
        </section>

        <section class="gm-location-wizard-page" data-wizard-page="2">
          <div class="gm-location-choice-section">
            <span class="gm-phase5-location-eyebrow">Import Contents</span>
            <label class="gm-location-toggle-card"><input type="checkbox" name="includeChildren" checked /> Include starter sites / POIs</label>
            <label class="gm-location-toggle-card"><input type="checkbox" name="includeAtlasFacts" checked /> Include starter Atlas facts and leads</label>
            <label class="gm-location-toggle-card"><input type="checkbox" name="knownToPlayers" /> Start as known to players</label>
          </div>
          <div class="gm-location-choice-section">
            <span class="gm-phase5-location-eyebrow">Initial Reveal State</span>
            <div class="gm-location-choice-grid gm-location-choice-grid--compact">
              {{#each surface.locationManager.editorRevealOptions}}
                <label class="gm-location-choice"><input type="radio" name="revealState" value="{{value}}" {{#if selected}}checked{{/if}} /> <strong>{{label}}</strong></label>
              {{/each}}
            </div>
          </div>
        </section>

        <section class="gm-location-wizard-page" data-wizard-page="3">
          <div class="gm-location-review-card">
            <h4>Ready to import</h4>
            <p>Selected planets will be imported as GM-owned location records. Existing records are skipped instead of overwritten.</p>
            <ul>
              <li>Use <strong>Import Selected</strong> for checked planets.</li>
              <li>Use <strong>Import All Shown</strong> for the current filtered list.</li>
              <li>Imported locations can be edited immediately from the registry.</li>
            </ul>
          </div>
        </section>

        <footer class="gm-location-modal-foot">
          <button type="button" data-location-action="close-modal">Cancel</button>
          <button type="button" data-location-action="wizard-back" data-wizard-target="import">Back</button>
          <button type="button" class="primary" data-location-action="wizard-next" data-wizard-target="import">Next</button>
          <button type="button" data-location-action="import-library-visible-now">Import All Shown</button>
          <button type="submit" class="primary">Import Selected</button>
        </footer>
      </form>
    </div>
  {{/if}}

  {{#if surface.locationManager.modal.isCreate}}
    <div class="gm-location-modal-layer" data-location-modal="create">
      <form class="gm-location-modal gm-location-modal--create gm-location-wizard" data-location-form data-location-wizard="create" data-current-page="1">
        <header class="gm-location-modal-head">
          <div>
            <span class="gm-phase5-location-eyebrow">Location Wizard</span>
            <h3>{{#if surface.locationManager.selected}}Edit Location{{else}}New Location{{/if}}</h3>
            <p>Answer the steps. No blank dropdowns, no hidden popup windows.</p>
          </div>
          <button type="button" class="gm-location-modal-close" data-location-action="close-modal">×</button>
        </header>
        <input type="hidden" name="id" value="{{surface.locationManager.editor.id}}" />

        <div class="gm-location-wizard-steps">
          <span class="is-active" data-wizard-step-indicator="1">1 Identity</span>
          <span data-wizard-step-indicator="2">2 Placement</span>
          <span data-wizard-step-indicator="3">3 Visibility</span>
          <span data-wizard-step-indicator="4">4 Notes</span>
        </div>

        <section class="gm-location-wizard-page is-active" data-wizard-page="1">
          <label class="swse-location-field swse-location-field--wide"><span>Name</span><input name="name" value="{{surface.locationManager.editor.name}}" placeholder="Tatooine, Mos Eisley, Docking Bay 94..." /></label>
          <div class="gm-location-choice-section"><span class="gm-phase5-location-eyebrow">Category</span><div class="gm-location-choice-grid gm-location-choice-grid--compact">{{#each surface.locationManager.editorCategoryOptions}}<label class="gm-location-choice"><input type="radio" name="category" value="{{value}}" {{#if selected}}checked{{/if}} /> <strong>{{label}}</strong></label>{{/each}}</div></div>
          <div class="gm-location-choice-section"><span class="gm-phase5-location-eyebrow">Type</span><div class="gm-location-choice-grid">{{#each surface.locationManager.editorTypeOptions}}<label class="gm-location-choice"><input type="radio" name="type" value="{{value}}" {{#if selected}}checked{{/if}} /> <strong>{{label}}</strong></label>{{/each}}</div></div>
          <div class="gm-location-choice-section"><span class="gm-phase5-location-eyebrow">Scale</span><div class="gm-location-choice-grid gm-location-choice-grid--compact">{{#each surface.locationManager.editorScaleOptions}}<label class="gm-location-choice"><input type="radio" name="scale" value="{{value}}" {{#if selected}}checked{{/if}} /> <strong>{{label}}</strong></label>{{/each}}</div></div>
        </section>

        <section class="gm-location-wizard-page" data-wizard-page="2">
          <div class="swse-location-field-grid">
            <label class="swse-location-field"><span>Region</span><input name="region" value="{{surface.locationManager.editor.raw.region}}" placeholder="Outer Rim" /></label>
            <label class="swse-location-field"><span>Sector</span><input name="sector" value="{{surface.locationManager.editor.raw.sector}}" placeholder="Arkanis Sector" /></label>
            <label class="swse-location-field"><span>System</span><input name="system" value="{{surface.locationManager.editor.raw.system}}" placeholder="Tatoo System" /></label>
            <label class="swse-location-field"><span>Coordinates</span><input name="coordinates" value="{{surface.locationManager.editor.raw.coordinates}}" placeholder="R-16 / GM notes" /></label>
          </div>
          <label class="swse-location-field swse-location-field--wide"><span>Parent Location ID</span><input name="parentLocationId" value="{{surface.locationManager.editor.raw.parentLocationId}}" list="gm-location-parent-options" placeholder="Leave blank for standalone, or type/select an existing location id" /></label>
          <datalist id="gm-location-parent-options">{{#each surface.locationManager.locationOptions}}<option value="{{value}}">{{label}}</option>{{/each}}</datalist>
          <label class="swse-location-field swse-location-field--wide"><span>Controller Faction ID</span><input name="controllingFactionId" value="{{surface.locationManager.editor.raw.controllingFactionId}}" list="gm-location-faction-options" placeholder="Optional controlling faction" /></label>
          <datalist id="gm-location-faction-options">{{#each surface.locationManager.factionOptions}}<option value="{{value}}">{{label}}</option>{{/each}}</datalist>
        </section>

        <section class="gm-location-wizard-page" data-wizard-page="3">
          <div class="gm-location-choice-section"><span class="gm-phase5-location-eyebrow">Reveal State</span><div class="gm-location-choice-grid gm-location-choice-grid--compact">{{#each surface.locationManager.editorRevealOptions}}<label class="gm-location-choice"><input type="radio" name="revealState" value="{{value}}" {{#if selected}}checked{{/if}} /> <strong>{{label}}</strong></label>{{/each}}</div></div>
          <div class="gm-phase5-toggle-row">
            <label class="gm-location-toggle-card"><input type="checkbox" name="knownToPlayers" {{#if surface.locationManager.editor.raw.knownToPlayers}}checked{{/if}} /> Known to players / Atlas-visible</label>
            <label class="gm-location-toggle-card"><input type="checkbox" name="activeForParty" {{#if surface.locationManager.editor.raw.activeForParty}}checked{{/if}} /> Active party location</label>
          </div>
          <label class="swse-location-field swse-location-field--wide"><span>Image</span><input name="image" value="{{surface.locationManager.editor.raw.image}}" placeholder="icons/svg/planet.svg or asset path" /></label>
          <label class="swse-location-field swse-location-field--wide"><span>Tags</span><input name="tags" value="{{surface.locationManager.editor.tags}}" placeholder="outer rim, underworld, desert" /></label>
        </section>

        <section class="gm-location-wizard-page" data-wizard-page="4">
          <label class="swse-location-field swse-location-field--wide"><span>Public Atlas Summary</span><textarea name="publicSummary" rows="4">{{surface.locationManager.editor.raw.publicSummary}}</textarea></label>
          <label class="swse-location-field swse-location-field--wide"><span>GM Notes</span><textarea name="gmNotes" rows="4">{{surface.locationManager.editor.raw.gmNotes}}</textarea></label>
          <details class="gm-location-optional-fields"><summary>Advanced links and map fields</summary>
            <label class="swse-location-field"><span>Faction IDs</span><input name="factionIds" value="{{surface.locationManager.editor.factionIdsText}}" /></label>
            <label class="swse-location-field"><span>Named NPC/contact IDs</span><input name="contactIds" value="{{surface.locationManager.editor.contactIdsText}}" /></label>
            <label class="swse-location-field"><span>Actor UUIDs</span><textarea name="npcActorUuids" rows="2">{{surface.locationManager.editor.npcActorUuidsText}}</textarea></label>
            <label class="swse-location-field"><span>Intel IDs</span><textarea name="linkedIntelIds" rows="2">{{surface.locationManager.editor.linkedIntelIdsText}}</textarea></label>
            <label class="swse-location-field"><span>Job IDs</span><textarea name="linkedJobIds" rows="2">{{surface.locationManager.editor.linkedJobIdsText}}</textarea></label>
            <label class="swse-location-field"><span>Linked Scene UUID</span><input name="mapSceneUuid" value="{{surface.locationManager.editor.mapSceneUuid}}" /></label>
            <label class="swse-location-field"><span>Map Image Path</span><input name="mapImagePath" value="{{surface.locationManager.editor.mapImagePath}}" /></label>
            <input type="hidden" name="linkedSceneUuids" value="{{surface.locationManager.editor.linkedSceneUuidsText}}" />
            <input type="hidden" name="linkedJournalUuid" value="{{surface.locationManager.editor.raw.linkedJournalUuid}}" />
            <input type="hidden" name="mapDefaultGrid" value="{{surface.locationManager.editor.mapDefaultGrid}}" />
            <input type="hidden" name="mapDefaultPadding" value="{{surface.locationManager.editor.mapDefaultPadding}}" />
            <input type="hidden" name="mapDefaultWidth" value="{{surface.locationManager.editor.mapDefaultWidth}}" />
            <input type="hidden" name="mapDefaultHeight" value="{{surface.locationManager.editor.mapDefaultHeight}}" />
            <input type="hidden" name="mapNotes" value="{{surface.locationManager.editor.mapNotes}}" />
            <input type="hidden" name="hazards" value="{{surface.locationManager.editor.raw.hazards}}" />
            <input type="hidden" name="rumors" value="{{surface.locationManager.editor.raw.rumors}}" />
            <input type="hidden" name="commerceNotes" value="{{surface.locationManager.editor.raw.commerceNotes}}" />
            <input type="hidden" name="travelNotes" value="{{surface.locationManager.editor.raw.travelNotes}}" />
          </details>
        </section>

        <footer class="gm-location-modal-foot">
          <button type="button" data-location-action="close-modal">Cancel</button>
          <button type="button" data-location-action="wizard-back" data-wizard-target="create">Back</button>
          <button type="button" class="primary" data-location-action="wizard-next" data-wizard-target="create">Next</button>
          <button type="submit" class="primary">Save Location</button>
        </footer>
      </form>
    </div>
  {{/if}}

  {{#if surface.locationManager.modal.isDelete}}
    <div class="gm-location-modal-layer" data-location-modal="delete">
      <section class="gm-location-modal gm-location-modal--delete">
        <header class="gm-location-modal-head">
          <div>
            <span class="gm-phase5-location-eyebrow">Confirm Registry Delete</span>
            <h3>Delete Location?</h3>
            <p>This removes only the GM Location registry record. Child locations are reparented to standalone.</p>
          </div>
          <button type="button" class="gm-location-modal-close" data-location-action="close-modal">×</button>
        </header>
        <div class="gm-location-delete-card">
          <strong>{{surface.locationManager.modal.deleteLocationName}}</strong>
          <span>{{surface.locationManager.modal.deleteLocationId}}</span>
        </div>
        <footer class="gm-location-modal-foot">
          <button type="button" data-location-action="close-modal">Cancel</button>
          <button type="button" class="danger" data-location-action="confirm-delete" data-location-id="{{surface.locationManager.modal.deleteLocationId}}">Delete Location</button>
        </footer>
      </section>
    </div>
  {{/if}}
</div>
