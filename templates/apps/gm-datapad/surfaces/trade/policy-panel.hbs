{{!-- GM Trade policy panel. --}}
<section class="swse-ui-panel trade-policy-panel gm-phase4-trade-policy">
  <div class="trade-section-header compact">
    <div>
      <span class="gm-command-eyebrow">POLICY</span>
      <h3>Messenger Trade Rules</h3>
    </div>
  </div>
  <form data-trade-policy-form class="trade-policy-form gm-phase4-policy-form">
    <label class="gm-phase4-policy-row">
      <span><strong>Allow credit transfers</strong><em>Players can transfer credits through Messenger trades.</em></span>
      <input type="checkbox" name="holonetCreditTransfersEnabled" {{#if tradeConsole.policy.creditTransfersEnabled}}checked{{/if}}>
    </label>
    <label class="gm-phase4-policy-row">
      <span><strong>GM approval for credit transfers</strong><em>Credit movement queues for approval before settlement.</em></span>
      <input type="checkbox" name="holonetRequireCreditTransferApproval" {{#if tradeConsole.policy.requireCreditApproval}}checked{{/if}}>
    </label>
    <label class="gm-phase4-policy-row">
      <span><strong>Allow item trades</strong><em>Player-owned items can be included in trade terms.</em></span>
      <input type="checkbox" name="holonetItemTradesEnabled" {{#if tradeConsole.policy.itemTradesEnabled}}checked{{/if}}>
    </label>
    <label class="gm-phase4-policy-row">
      <span><strong>GM approval for item trades</strong><em>Item movement queues for GM review.</em></span>
      <input type="checkbox" name="holonetRequireItemTradeApproval" {{#if tradeConsole.policy.requireItemApproval}}checked{{/if}}>
    </label>
    <label class="gm-phase4-policy-row">
      <span><strong>Allow ship/droid trades</strong><em>Assets can be proposed through Messenger trade records.</em></span>
      <input type="checkbox" name="holonetAssetTradesEnabled" {{#if tradeConsole.policy.assetTradesEnabled}}checked{{/if}}>
    </label>
    <label class="gm-phase4-policy-row">
      <span><strong>GM approval for ship/droid trades</strong><em>Asset movement is held until the GM approves.</em></span>
      <input type="checkbox" name="holonetRequireAssetTradeApproval" {{#if tradeConsole.policy.requireAssetApproval}}checked{{/if}}>
    </label>
    <label class="gm-phase4-policy-row">
      <span><strong>Enable party fund</strong><em>Party-held credits can participate in settlement flows.</em></span>
      <input type="checkbox" name="holonetPartyFundEnabled" {{#if tradeConsole.policy.partyFundEnabled}}checked{{/if}}>
    </label>
    <label class="gm-phase4-policy-row gm-phase4-policy-row--number">
      <span><strong>Default party fund job cut %</strong><em>Default percentage routed into the shared party fund.</em></span>
      <input type="number" min="0" max="100" step="1" name="holonetPartyFundDefaultCutPercent" value="{{tradeConsole.policy.partyFundCutPercent}}">
    </label>
    <button type="submit" class="swse-ui-button bulletin-primary-action"><i class="fa-solid fa-floppy-disk"></i> Save Trade Policy</button>
  </form>
</section>
