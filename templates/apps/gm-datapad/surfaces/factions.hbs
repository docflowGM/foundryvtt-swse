{{!-- GM Datapad Galactic Dossier — Phase 5 faction/contact to Intel bridge. --}}
<div class="gm-datapad-page gm-datapad-factions gm-datapad-dossier gm-phase2-page gm-phase5-page flexcol" data-gm-wizard-scope="factions">
  <div class="page-header gm-app-header gm-faction-header gm-phase2-header">
    <button class="back-button swse-ui-button" data-nav-to="home">Back</button>
    <div class="gm-app-header-copy">
      <span class="gm-command-eyebrow">GALACTIC DOSSIER</span>
      <h2>{{pageTitle}}</h2>
      <p class="page-subtitle">{{pageDescription}}</p>
    </div>
    <div class="gm-approval-count-strip" aria-label="Faction counts">
      <span><strong>{{factionManager.counts.registry}}</strong>Factions</span>
      <span><strong>{{factionManager.counts.contacts}}</strong>Contacts</span>
      <span><strong>{{factionManager.counts.relationships}}</strong>Relations</span>
      <span><strong>{{factionManager.counts.suggestions}}</strong>Pending</span>
      <span><strong>{{factionManager.counts.intel}}</strong>Intel</span>
      <button type="button" class="swse-ui-button primary gm-phase2-primary" data-gm-wizard-open="faction"><i class="fa-solid fa-plus"></i> Add Faction Dossier</button>
    </div>
  </div>

  <section class="swse-ui-panel gm-faction-registry-panel gm-phase2-panel">
    <div class="job-board-section-header compact">
      <div><span class="gm-command-eyebrow">INFLUENCE REGISTRY</span><h3>Faction Dossiers</h3><p class="gm-phase2-hint">Persistent faction authority stays in the existing registry. Phase 5 bridges factions and named NPC dossiers into Holonet-backed Intel drafts without creating a parallel notes store.</p></div>
    </div>
    <div class="gm-faction-registry-list gm-phase2-registry-list">
      {{#each factionManager.registry}}
      <article class="gm-faction-registry-card gm-phase2-faction-card {{#if this.isFocused}}is-focused{{/if}}" data-search="{{this.searchText}}" data-faction-name="{{this.name}}" data-swse-drag-kind="faction" data-swse-drag-id="{{this.id}}" data-swse-drag-name="{{this.name}}" data-swse-drag-source="factions">
        <div class="gm-faction-card-glow" aria-hidden="true"></div>
        <form class="gm-faction-registry-form" data-gm-faction-registry-form>
          <input type="hidden" name="id" value="{{this.id}}">
          <div class="gm-faction-card-command gm-faction-card-shell">
            <div class="gm-faction-card-title-block">
              <span class="gm-command-eyebrow">Faction Dossier</span>
              <h4>{{this.name}}</h4>
              <div class="gm-faction-meta-strip">
                <span>{{this.type}}</span>
                <span>Scale {{this.scale}}</span>
                {{#if this.planetSystem}}<span>{{this.planetSystem}}</span>{{/if}}
                {{#if this.leader}}<span>Leader: {{this.leader}}</span>{{/if}}
              </div>
            </div>
            <div class="gm-faction-command-side">
              <div class="gm-faction-score-chip {{this.scoreClass}}"><span>Standing</span><strong>{{this.scoreLabel}}</strong></div>
              <div class="gm-faction-row-actions gm-faction-primary-actions">
                <button type="button" class="swse-ui-button primary gm-faction-action-button" data-gm-faction-action="make-job-faction" data-faction-id="{{this.id}}" data-faction-name="{{this.name}}"><i class="fa-solid fa-clipboard-list"></i> Make Job</button>
                <button type="button" class="swse-ui-button" data-gm-faction-action="view-jobs-faction" data-faction-id="{{this.id}}" data-faction-name="{{this.name}}"><i class="fa-solid fa-filter"></i> View Jobs</button>
                <button type="button" class="swse-ui-button gm-dossier-intel-action" data-gm-faction-action="create-intel-faction" data-faction-id="{{this.id}}" data-faction-name="{{this.name}}"><i class="fa-solid fa-file-shield"></i> Create Intel</button>
                <button type="button" class="swse-ui-button gm-dossier-intel-action" data-gm-faction-action="reveal-faction" data-faction-id="{{this.id}}" data-faction-name="{{this.name}}"><i class="fa-solid fa-eye"></i> Reveal</button>
                <button type="submit" class="swse-ui-button approve"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                <button type="button" class="swse-ui-button danger" data-gm-faction-action="delete-registry" data-faction-id="{{this.id}}"><i class="fa-solid fa-trash"></i> Delete</button>
              </div>
            </div>
          </div>
          <div class="gm-faction-card-intel-grid" aria-label="Faction quick intelligence">
            <div class="gm-faction-intel-chip"><span>Jobs</span><strong>{{this.jobStats.total}}</strong></div>
            <div class="gm-faction-intel-chip"><span>Open</span><strong>{{this.jobStats.open}}</strong></div>
            <div class="gm-faction-intel-chip"><span>Active</span><strong>{{this.jobStats.active}}</strong></div>
            <div class="gm-faction-intel-chip"><span>Payout</span><strong>{{this.jobStats.payout}}</strong></div>
            <div class="gm-faction-intel-chip"><span>Contacts</span><strong>{{this.contactCount}}</strong></div>
            <div class="gm-faction-intel-chip is-known"><span>Known NPCs</span><strong>{{this.knownContactCount}}</strong></div>
            <div class="gm-faction-intel-chip is-hidden"><span>GM Only</span><strong>{{this.hiddenContactCount}}</strong></div>
            <div class="gm-faction-intel-chip is-known"><span>Intel</span><strong>{{this.intelCount}}</strong></div>
          </div>
          <details class="gm-phase2-details">
            <summary>Edit registry details</summary>
            <div class="gm-faction-form-grid compact">
              <label>Name<input type="text" name="name" value="{{this.name}}" required></label>
              <label>Type<input type="text" name="type" value="{{this.type}}"></label>
              <label>Planet<input type="text" name="planet" value="{{this.planet}}"></label>
              <label>System<input type="text" name="system" value="{{this.system}}"></label>
              <label>Scale<input type="number" name="scale" min="1" max="20" step="1" value="{{this.scale}}"></label>
              <label>Score<input type="number" name="score" step="1" value="{{this.score}}"></label>
              <label>Starting Score<input type="number" name="startingScore" step="1" value="{{this.startingScore}}"></label>
              <label>Leader<input type="text" name="leader" value="{{this.leader}}"></label>
              <label>Source<select name="source">{{#each ../factionManager.sourceTypes}}<option value="{{this.value}}" {{#if (eq this.value ../source)}}selected{{/if}}>{{this.label}}</option>{{/each}}</select></label>
              <label>Status<input type="text" name="status" value="{{this.status}}"></label>
              <label class="is-wide">Benefits<textarea name="benefits" rows="2">{{this.benefits}}</textarea></label>
              <label class="is-wide">Public Notes<textarea name="notes" rows="2">{{this.notes}}</textarea></label>
              <label class="is-wide">GM Notes<textarea name="gmNotes" rows="2">{{this.gmNotes}}</textarea></label>
            </div>
            <div class="gm-faction-job-defaults">
              <span class="gm-command-eyebrow">Job Defaults</span>
              <div class="gm-faction-form-grid compact">
                <label>Default Objective<input type="text" name="defaultObjective" value="{{this.jobDefaults.objective}}" placeholder="Secure the shipment"></label>
                <label>Default Credits<input type="number" name="defaultCredits" min="0" step="500" value="{{this.jobDefaults.credits}}"></label>
                <label>Default XP<input type="number" name="defaultXp" min="0" step="100" value="{{this.jobDefaults.xp}}"></label>
                <label>Success Rep<input type="number" name="defaultSuccessDelta" step="1" value="{{this.jobDefaults.successDelta}}"></label>
                <label>Failure Rep<input type="number" name="defaultFailureDelta" step="1" value="{{this.jobDefaults.failureDelta}}"></label>
                <label>Status<select name="defaultVisibility"><option value="posted" {{#if (eq this.jobDefaults.visibility "posted")}}selected{{/if}}>Post Open</option><option value="draft" {{#if (eq this.jobDefaults.visibility "draft")}}selected{{/if}}>Save Draft</option></select></label>
                <label>Tone<input type="text" name="defaultJobTone" value="{{this.jobDefaults.tone}}" placeholder="formal, threatening..."></label>
                <label>Reward Style<input type="text" name="defaultRewardStyle" value="{{this.jobDefaults.rewardStyle}}" placeholder="credits, favors..."></label>
                <label>Pay Style<input type="text" name="defaultPayStyle" value="{{this.jobDefaults.payStyle}}" placeholder="flat, bounty, favor"></label>
                <label>Legality<input type="text" name="defaultLegality" value="{{this.jobDefaults.legality}}" placeholder="legal, gray, illegal"></label>
                <label>Rival Faction<input type="text" name="defaultRivalFactionName" value="{{this.jobDefaults.rivalFactionName}}" placeholder="Optional opposed faction"></label>
                <label>Rival Success Rep<input type="number" name="defaultRivalSuccessDelta" step="1" value="{{this.jobDefaults.rivalSuccessDelta}}"></label>
                <label>Rival Failure Rep<input type="number" name="defaultRivalFailureDelta" step="1" value="{{this.jobDefaults.rivalFailureDelta}}"></label>
                <label class="is-wide">Consequence Notes<textarea name="defaultConsequenceNotes" rows="2">{{this.jobDefaults.consequenceNotes}}</textarea></label>
                <label class="is-wide">Default Briefing<textarea name="defaultBriefing" rows="2">{{this.jobDefaults.briefing}}</textarea></label>
                <label class="is-wide">Default Instructions<textarea name="defaultInstructions" rows="2">{{this.jobDefaults.instructions}}</textarea></label>
              </div>
            </div>
          </details>
        </form>
        <section class="gm-faction-contacts-panel">
          <header class="job-board-section-header compact">
            <div><span class="gm-command-eyebrow">NAMED NPC DOSSIERS</span><h4>Known Contacts</h4><p class="gm-phase2-hint">Contacts remain lightweight registry records until promoted or linked to actors.</p></div>
            <span class="job-board-chip">{{this.contactCount}} NPC Dossier{{#unless (eq this.contactCount 1)}}s{{/unless}}</span>
          </header>
          <div class="gm-faction-job-stats gm-faction-job-stats--secondary">
            <span>Completed: <strong>{{this.jobStats.completed}}</strong></span>
            <span>Failed: <strong>{{this.jobStats.failed}}</strong></span>
          </div>
          {{#if this.jobStats.hasJobs}}
          <div class="gm-faction-recent-jobs">
            <span class="gm-command-eyebrow">Recent Jobs</span>
            {{#each this.recentJobs}}
            <button type="button" class="gm-faction-recent-job" data-gm-faction-action="view-jobs-faction" data-faction-id="{{../id}}" data-faction-name="{{../name}}">
              <strong>{{this.title}}</strong><span>{{this.statusLabel}}</span>
            </button>
            {{/each}}
          </div>
          {{/if}}
          <div class="gm-faction-contact-list">
            {{#each this.contacts}}
            <article class="gm-faction-contact-card {{#if this.isFocused}}is-focused{{/if}}" data-search="{{this.searchText}}" data-swse-drag-kind="contact" data-swse-drag-id="{{this.id}}" data-swse-drag-contact-id="{{this.id}}" data-swse-drag-faction-id="{{../id}}" data-swse-drag-name="{{this.name}}" data-swse-drag-uuid="{{this.actorUuid}}" data-swse-drag-source="factions">
              <div class="gm-faction-contact-summary">
                <span class="gm-command-eyebrow">NPC Dossier</span>
                <strong>{{this.name}}</strong>
                <div class="gm-dossier-chip-row">
                  <span>{{this.role}}{{#if this.factionRank}} · {{this.factionRank}}{{/if}}</span>
                  <span>{{this.dossierTypeLabel}}</span>
                  <span>{{this.dispositionLabel}}</span>
                  <span>{{this.revealStateLabel}}</span>
                  <span>{{this.visibilityLabel}}</span>
                  <span>Intel {{this.intelCount}}</span>
                </div>
                {{#if this.lastKnownLocation}}<small class="gm-dossier-contact-line"><i class="fa-solid fa-location-dot"></i> Last known: {{this.lastKnownLocation}}</small>{{/if}}
                {{#if this.publicNotes}}<p class="gm-dossier-contact-note is-public"><strong>Public:</strong> {{this.publicNotes}}</p>{{/if}}
                {{#if this.agenda}}<p class="gm-dossier-contact-note"><strong>Agenda:</strong> {{this.agenda}}</p>{{/if}}
                {{#if this.gmNotes}}<p class="gm-dossier-contact-note is-gm"><strong>GM:</strong> {{this.gmNotes}}</p>{{/if}}
                {{#if this.secret}}<p class="gm-dossier-contact-note is-secret"><strong>Secret:</strong> {{this.secret}}</p>{{/if}}
                {{#if this.hasLinkedIntel}}<small class="gm-dossier-contact-line"><i class="fa-solid fa-file-shield"></i> Linked Intel IDs: {{this.linkedIntelIdsLabel}}</small>{{/if}}
                {{#if this.hasActorLink}}<small class="gm-faction-contact-actor">Linked Actor: {{this.actorLinkLabel}}</small>{{else}}<small class="gm-faction-contact-actor muted">Lightweight contact · no actor created</small>{{/if}}
                <div class="gm-faction-job-stats mini">
                  <span>Jobs: <strong>{{this.jobStats.total}}</strong></span>
                  <span>Open: <strong>{{this.jobStats.open}}</strong></span>
                  <span>Active: <strong>{{this.jobStats.active}}</strong></span>
                  <span>Done: <strong>{{this.jobStats.completed}}</strong></span>
                </div>
                {{#if this.jobStats.hasJobs}}
                <div class="gm-faction-recent-jobs mini">
                  {{#each this.recentJobs}}
                  <button type="button" class="gm-faction-recent-job" data-gm-faction-action="view-jobs-contact" data-faction-id="{{../../id}}" data-faction-name="{{../../name}}" data-contact-id="{{../id}}" data-contact-name="{{../name}}">
                    <strong>{{this.title}}</strong><span>{{this.statusLabel}}</span>
                  </button>
                  {{/each}}
                </div>
                {{/if}}
              </div>
              <form class="gm-faction-contact-form" data-gm-faction-contact-form>
                <input type="hidden" name="factionId" value="{{../id}}">
                <input type="hidden" name="contactId" value="{{this.id}}">
                <input type="hidden" name="actorId" value="{{this.actorId}}">
                <input type="hidden" name="actorUuid" value="{{this.actorUuid}}">
                <input type="hidden" name="actorName" value="{{this.actorName}}">
                <input type="hidden" name="promotedAt" value="{{this.promotedAt}}">
                <div class="gm-faction-row-actions gm-faction-contact-actions">
                  <button type="button" class="swse-ui-button primary" data-gm-faction-action="make-job-contact" data-faction-id="{{../id}}" data-faction-name="{{../name}}" data-contact-id="{{this.id}}" data-contact-name="{{this.name}}"><i class="fa-solid fa-clipboard-list"></i> Make Job</button>
                  <button type="button" class="swse-ui-button" data-gm-faction-action="view-jobs-contact" data-faction-id="{{../id}}" data-faction-name="{{../name}}" data-contact-id="{{this.id}}" data-contact-name="{{this.name}}"><i class="fa-solid fa-filter"></i> View Jobs</button>
                  <button type="button" class="swse-ui-button gm-dossier-intel-action" data-gm-faction-action="create-intel-contact" data-faction-id="{{../id}}" data-faction-name="{{../name}}" data-contact-id="{{this.id}}" data-contact-name="{{this.name}}"><i class="fa-solid fa-file-shield"></i> Create Intel</button>
                  <button type="button" class="swse-ui-button gm-dossier-skeleton-action" data-gm-faction-action="send-contact-message" data-faction-id="{{../id}}" data-faction-name="{{../name}}" data-contact-id="{{this.id}}" data-contact-name="{{this.name}}"><i class="fa-solid fa-message"></i> Send as NPC</button>
                  {{#if this.knownToPlayers}}
                  <button type="button" class="swse-ui-button" data-gm-faction-action="hide-contact" data-faction-id="{{../id}}" data-faction-name="{{../name}}" data-contact-id="{{this.id}}" data-contact-name="{{this.name}}"><i class="fa-solid fa-eye-slash"></i> GM Only</button>
                  {{else}}
                  <button type="button" class="swse-ui-button approve" data-gm-faction-action="reveal-contact" data-faction-id="{{../id}}" data-faction-name="{{../name}}" data-contact-id="{{this.id}}" data-contact-name="{{this.name}}"><i class="fa-solid fa-eye"></i> Reveal</button>
                  {{/if}}
                  {{#if this.hasActorLink}}
                  <button type="button" class="swse-ui-button" data-gm-faction-action="open-contact-actor" data-actor-id="{{this.actorId}}" data-actor-uuid="{{this.actorUuid}}"><i class="fa-solid fa-user"></i> Open Actor</button>
                  {{else}}
                  <button type="button" class="swse-ui-button" data-gm-faction-action="promote-contact" data-faction-id="{{../id}}" data-contact-id="{{this.id}}"><i class="fa-solid fa-user-plus"></i> Promote</button>
                  {{/if}}
                  <button type="submit" class="swse-ui-button approve"><i class="fa-solid fa-floppy-disk"></i> Save Contact</button>
                  <button type="button" class="swse-ui-button danger" data-gm-faction-action="delete-contact" data-faction-id="{{../id}}" data-contact-id="{{this.id}}"><i class="fa-solid fa-trash"></i> Delete</button>
                </div>
                <details class="gm-faction-contact-edit">
                  <summary>Edit NPC dossier profile and job defaults</summary>
                  <div class="gm-faction-form-grid compact">
                    <label>Name<input type="text" name="name" value="{{this.name}}" required></label>
                    <label>Role<input type="text" name="role" value="{{this.role}}"></label>
                    <label>Title<input type="text" name="title" value="{{this.title}}"></label>
                    <label>Image<input type="text" name="image" value="{{this.image}}"></label>
                    <label>Faction Rank<input type="text" name="factionRank" value="{{this.factionRank}}" placeholder="Vigo, Captain, Handler..."></label>
                    <label>Last Known Location<input type="text" name="lastKnownLocation" value="{{this.lastKnownLocation}}" placeholder="Nar Shaddaa safehouse"></label>
                    <label>Disposition<select name="disposition">{{#each this.dispositionOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select></label>
                    <label>Reveal State<select name="revealState">{{#each this.revealStateOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select></label>
                    <label class="gm-faction-checkbox-label"><input type="checkbox" name="knownToPlayers" {{#if this.knownToPlayers}}checked{{/if}}> Known to players</label>
                    <label>Messenger Persona ID<input type="text" name="messengerPersonaId" value="{{this.messengerPersonaId}}" placeholder="Optional existing persona id"></label>
                    <label class="is-wide">Description<textarea name="description" rows="2">{{this.description}}</textarea></label>
                    <label class="is-wide">Public Notes<textarea name="publicNotes" rows="2" placeholder="Safe player-facing dossier text.">{{this.publicNotes}}</textarea></label>
                    <label class="is-wide">GM Notes<textarea name="gmNotes" rows="2" placeholder="Private GM-only notes.">{{this.gmNotes}}</textarea></label>
                    <label class="is-wide">Agenda<textarea name="agenda" rows="2" placeholder="What this NPC wants or is trying to accomplish.">{{this.agenda}}</textarea></label>
                    <label class="is-wide">Secret<textarea name="secret" rows="2" placeholder="Hidden affiliation, betrayal, leverage, etc.">{{this.secret}}</textarea></label>
                    <label class="is-wide">Linked Intel IDs<input type="text" name="linkedIntelIds" value="{{this.linkedIntelIdsLabel}}" placeholder="Holonet Intel ids, comma-separated"></label>
                    <label>Tags<input type="text" name="tags" value="{{this.tagsLabel}}" placeholder="broker, underworld"></label>
                    <label>Job Tone<input type="text" name="defaultJobTone" value="{{this.defaultJobTone}}" placeholder="threatening, formal..."></label>
                    <label>Reward Style<input type="text" name="defaultRewardStyle" value="{{this.defaultRewardStyle}}" placeholder="credits, favors..."></label>
                    <label>Default Objective<input type="text" name="defaultObjective" value="{{this.defaultObjective}}" placeholder="Recover the asset"></label>
                    <label>Credits<input type="number" name="defaultCredits" min="0" step="500" value="{{this.defaultCredits}}"></label>
                    <label>XP<input type="number" name="defaultXp" min="0" step="100" value="{{this.defaultXp}}"></label>
                    <label>Success Rep<input type="number" name="defaultSuccessDelta" step="1" value="{{this.defaultSuccessDelta}}"></label>
                    <label>Failure Rep<input type="number" name="defaultFailureDelta" step="1" value="{{this.defaultFailureDelta}}"></label>
                    <label>Status<select name="defaultVisibility"><option value="posted" {{#if (eq this.defaultVisibility "posted")}}selected{{/if}}>Post Open</option><option value="draft" {{#if (eq this.defaultVisibility "draft")}}selected{{/if}}>Save Draft</option></select></label>
                    <label>Rival Faction<input type="text" name="defaultRivalFactionName" value="{{this.defaultRivalFactionName}}" placeholder="Optional opposed faction"></label>
                    <label>Rival Success Rep<input type="number" name="defaultRivalSuccessDelta" step="1" value="{{this.defaultRivalSuccessDelta}}"></label>
                    <label>Rival Failure Rep<input type="number" name="defaultRivalFailureDelta" step="1" value="{{this.defaultRivalFailureDelta}}"></label>
                    <label class="is-wide">Consequence Notes<textarea name="defaultConsequenceNotes" rows="2">{{this.defaultConsequenceNotes}}</textarea></label>
                    <label class="is-wide">Default Briefing<textarea name="defaultBriefing" rows="2">{{this.defaultBriefing}}</textarea></label>
                    <label class="is-wide">Default Instructions<textarea name="defaultInstructions" rows="2">{{this.defaultInstructions}}</textarea></label>
                  </div>
                </details>
              </form>
            </article>
            {{else}}
            <p class="placeholder">No named NPC dossiers yet. Add a job broker, commander, handler, faction face, or rumor source below.</p>
            {{/each}}
          </div>
          <details class="gm-faction-add-contact-drawer">
            <summary><i class="fa-solid fa-user-plus"></i> Add named NPC dossier</summary>
            <form class="gm-faction-contact-create-form" data-gm-faction-contact-form>
              <input type="hidden" name="factionId" value="{{this.id}}">
              <div class="gm-faction-form-grid compact">
                <label>New NPC Name<input type="text" name="name" placeholder="Vigo Sarn Kel"></label>
                <label>Role<input type="text" name="role" placeholder="Job Broker"></label>
                <label>Faction Rank<input type="text" name="factionRank" placeholder="Captain, Vigo, Handler"></label>
                <label>Last Known Location<input type="text" name="lastKnownLocation" placeholder="Docking Bay 42"></label>
                <label>Disposition<select name="disposition">{{#each ../factionManager.contactDispositions}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select></label>
                <label>Reveal State<select name="revealState">{{#each ../factionManager.contactRevealStates}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select></label>
                <label class="gm-faction-checkbox-label"><input type="checkbox" name="knownToPlayers"> Known to players</label>
                <label class="is-wide">Dossier Summary<textarea name="description" rows="2" placeholder="What the GM knows, suspects, or wants to track about this contact."></textarea></label>
                <label class="is-wide">Public Notes<textarea name="publicNotes" rows="2" placeholder="Safe player-facing dossier text."></textarea></label>
                <label class="is-wide">GM Notes<textarea name="gmNotes" rows="2" placeholder="Private GM-only note."></textarea></label>
                <label class="is-wide">Agenda<textarea name="agenda" rows="2" placeholder="What this NPC wants."></textarea></label>
                <label class="is-wide">Secret<textarea name="secret" rows="2" placeholder="Hidden affiliation, leverage, or twist."></textarea></label>
                <label>Default Credits<input type="number" name="defaultCredits" min="0" step="500" placeholder="0"></label>
                <label>Default XP<input type="number" name="defaultXp" min="0" step="100" placeholder="0"></label>
                <label>Rival Faction<input type="text" name="defaultRivalFactionName" placeholder="Optional opposed faction"></label>
              </div>
              <div class="gm-faction-row-actions">
                <button type="submit" class="swse-ui-button approve">Add NPC Dossier</button>
              </div>
            </form>
          </details>
        </section>
      </article>
      {{else}}
      <p class="placeholder">No faction dossiers are currently registered.</p>
      {{/each}}
    </div>
  </section>

  {{#if factionManager.hasSuggestions}}
  <section class="swse-ui-panel gm-faction-suggestions-panel gm-phase2-panel">
    <div class="job-board-section-header compact"><div><span class="gm-command-eyebrow">PLAYER REQUESTS</span><h3>Faction Suggestions</h3></div></div>
    <div class="gm-faction-suggestion-list">
      {{#each factionManager.suggestions}}
      <article class="gm-faction-suggestion-card" data-faction-suggestion-card>
        <div><strong>{{this.name}}</strong><span>{{this.actorName}} · {{this.type}} · {{this.relationshipType}}</span>{{#if this.notes}}<p>{{this.notes}}</p>{{/if}}</div>
        <label>Reject reason<input type="text" name="rejectReason" placeholder="Optional player-facing reason"></label>
        <div class="gm-faction-row-actions">
          <button type="button" class="swse-ui-button approve" data-gm-faction-action="approve-suggestion" data-actor-id="{{this.actorId}}" data-faction-id="{{this.id}}">Approve</button>
          <button type="button" class="swse-ui-button deny" data-gm-faction-action="reject-suggestion" data-actor-id="{{this.actorId}}" data-faction-id="{{this.id}}">Reject</button>
        </div>
      </article>
      {{/each}}
    </div>
  </section>
  {{/if}}

  <section class="swse-ui-panel gm-faction-relationships-panel gm-phase2-panel">
    <div class="job-board-section-header compact"><div><span class="gm-command-eyebrow">PARTY-WIDE INFLUENCE LEDGER</span><h3>Actor Faction Relationships</h3></div></div>
    <div class="gm-faction-filter-bar">
      <label>Search<input type="search" data-gm-faction-search placeholder="Actor, faction, contact, type, notes..."></label>
      <label>Actor<select data-gm-faction-filter="actorId"><option value="">All Actors</option>{{#each factionManager.actors}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}</select></label>
      <label>Relationship<select data-gm-faction-filter="relationshipType"><option value="">All Types</option>{{#each factionManager.relationshipTypes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select></label>
      <label>Status<select data-gm-faction-filter="status"><option value="">All Statuses</option><option value="active">Active</option><option value="approved">Approved</option><option value="pending">Pending</option><option value="rejected">Rejected</option></select></label>
      <label class="gm-faction-checkbox-label"><input type="checkbox" data-gm-faction-filter="missingRegistry"> Stale registry only</label>
    </div>
    {{#if factionManager.hasRelationships}}
    <div class="gm-faction-relationship-list gm-phase2-rel-list">
      {{#each factionManager.relationships}}
      <article class="gm-faction-relationship-card gm-phase2-rel-row" data-gm-faction-filter-row data-search="{{this.searchText}}" data-actor-id="{{this.actorId}}" data-relationship-type="{{this.relationshipType}}" data-status="{{this.status}}" data-registry-missing="{{this.registryMissing}}">
        <form data-gm-faction-relationship-form>
          <input type="hidden" name="actorId" value="{{this.actorId}}">
          <input type="hidden" name="relationshipId" value="{{this.id}}">
          <input type="hidden" name="factionId" value="{{this.factionId}}">
          <header>
            <img src="{{this.actorImg}}" alt="{{this.actorName}}">
            <div>
              <span class="gm-command-eyebrow">{{this.actorName}}</span>
              <input type="text" name="factionName" value="{{this.factionName}}">
              {{#if this.registryMissing}}<small class="gm-faction-stale-warning">{{this.missingRegistryLabel}}</small>{{/if}}
            </div>
            <span class="gm-faction-rel-badge {{this.relationshipType}}">{{this.relationshipType}}</span>
            <div class="gm-faction-score {{this.scoreClass}}"><span>Score</span><input type="number" name="score" step="1" value="{{this.score}}"></div>
            <button type="submit" class="swse-ui-button approve"><i class="fa-solid fa-floppy-disk"></i> Save</button>
            <button type="button" class="swse-ui-button danger" data-gm-faction-action="remove-relationship" data-actor-id="{{this.actorId}}" data-relationship-id="{{this.id}}">Remove</button>
          </header>
          <details class="gm-phase2-details">
            <summary>Relationship details</summary>
            <div class="gm-faction-form-grid compact">
              <label>Type<input type="text" name="type" value="{{this.type}}"></label>
              <label>Planet<input type="text" name="planet" value="{{this.planet}}"></label>
              <label>System<input type="text" name="system" value="{{this.system}}"></label>
              <label>Scale<input type="number" name="scale" min="1" max="20" step="1" value="{{this.scale}}"></label>
              <label>Leader<input type="text" name="leader" value="{{this.leader}}"></label>
              <label>Relationship<select name="relationshipType">{{#each ../factionManager.relationshipTypes}}<option value="{{this.value}}" {{#if (eq this.value ../relationshipType)}}selected{{/if}}>{{this.label}}</option>{{/each}}</select></label>
              <label class="is-wide">Benefits<textarea name="benefits" rows="2">{{this.benefits}}</textarea></label>
              <label class="is-wide">Player Notes<textarea name="notes" rows="2">{{this.notes}}</textarea></label>
              <label class="is-wide">GM Notes<textarea name="gmNotes" rows="2">{{this.gmNotes}}</textarea></label>
            </div>
                      </details>
        </form>
        <form class="gm-faction-adjust-form" data-gm-faction-adjust-form>
          <input type="hidden" name="actorId" value="{{this.actorId}}">
          <input type="hidden" name="factionId" value="{{this.factionId}}">
          <input type="hidden" name="factionName" value="{{this.factionName}}">
          <input type="hidden" name="relationshipType" value="{{this.relationshipType}}">
          <label>Delta<input type="number" name="delta" step="1" placeholder="+/-"></label>
          <label>Reason<input type="text" name="reason" placeholder="Mission, favor, betrayal, obligation..."></label>
          <button type="submit" class="swse-ui-button">Apply Delta</button>
        </form>
      </article>
      {{/each}}
    </div>
    {{else}}
    <p class="placeholder">No actor faction relationships have been attached yet.</p>
    {{/if}}
  </section>

  <section class="gm-wizard-overlay" data-gm-wizard="faction" hidden aria-label="Add Faction Wizard">
    <form class="gm-wizard-panel gm-faction-create-form" data-gm-faction-create-form data-gm-wizard-form="faction" novalidate>
      <header class="gm-wizard-bar">
        <div class="gm-wizard-steps" aria-label="Faction wizard steps">
          <button type="button" class="gm-wizard-step is-active" data-gm-wizard-step-button="1"><span>1</span>Identity</button><i></i>
          <button type="button" class="gm-wizard-step" data-gm-wizard-step-button="2"><span>2</span>Actors</button><i></i>
          <button type="button" class="gm-wizard-step" data-gm-wizard-step-button="3"><span>3</span>Notes</button>
        </div>
        <button type="button" class="gm-wizard-close" data-gm-wizard-close>✕ Cancel</button>
      </header>
      <div class="gm-wizard-body">
        <section class="gm-wizard-page is-active" data-gm-wizard-page="1">
          <div class="gm-wizard-card"><span class="gm-command-eyebrow">FACTION IDENTITY</span>
            <div class="gm-wizard-grid two"><label>Faction Name<input type="text" name="name" placeholder="Republic Remnant / Black Sun / CorSec" required></label><label>Type<input type="text" name="type" placeholder="Government, syndicate, guild..."></label></div>
            <div class="gm-wizard-grid three"><label>Planet<input type="text" name="planet" placeholder="Coruscant"></label><label>System / Region<input type="text" name="system" placeholder="Core Worlds"></label><label>Scale<input type="number" name="scale" min="1" max="20" value="3"></label></div>
            <div class="gm-wizard-grid two"><label>Leader / Public Face<input type="text" name="leader" placeholder="Director Vex, Unknown"></label><label>Starting Score<input type="number" name="score" step="1" value="0" class="gm-wizard-score-input"></label></div>
          </div>
          <div class="gm-wizard-card"><span class="gm-command-eyebrow">PRIMARY RELATIONSHIP TYPE</span>
            <select name="relationshipType">{{#each factionManager.relationshipTypes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select>
          </div>
        </section>
        <section class="gm-wizard-page" data-gm-wizard-page="2">
          <div class="gm-wizard-card"><span class="gm-command-eyebrow">ATTACH ACTORS</span>
            <p class="gm-phase2-hint">Select any actors that should start with this faction relationship. Unselected actors are ignored and the faction is saved to the GM registry only.</p>
            <div class="gm-faction-wizard-actor-list">
              {{#each factionManager.actors}}
              <label class="gm-faction-wizard-actor-row">
                <input type="checkbox" name="actorIds" value="{{this.id}}">
                <span class="gm-faction-wizard-actor-main"><strong>{{this.name}}</strong><em>{{this.typeLabel}}</em></span>
                <select name="actorRelationshipType:{{this.id}}">{{#each ../factionManager.relationshipTypes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select>
                <input type="number" name="actorScore:{{this.id}}" step="1" value="0" aria-label="Starting score for {{this.name}}">
              </label>
              {{else}}
              <p class="placeholder">No actors are currently available to attach.</p>
              {{/each}}
            </div>
          </div>
        </section>
        <section class="gm-wizard-page" data-gm-wizard-page="3">
          <div class="gm-wizard-card"><span class="gm-command-eyebrow">BENEFITS & ACCESS</span><textarea name="benefits" rows="3" placeholder="GM-governed benefits, discounts, access, or consequences."></textarea></div>
          <div class="gm-wizard-card"><span class="gm-command-eyebrow">PUBLIC NOTES</span><textarea name="notes" rows="3" placeholder="What players know about this faction."></textarea></div>
          <div class="gm-wizard-card"><span class="gm-command-eyebrow">GM NOTES</span><textarea name="gmNotes" rows="3" placeholder="Private GM notes — future plot hooks, hidden agendas..."></textarea></div>
        </section>
      </div>
      <footer class="gm-wizard-footer"><span>Step <b data-gm-wizard-current>1</b> of 3 — Add Faction Dossier</span><div><button type="button" class="swse-ui-button" data-gm-wizard-back hidden>Back</button><button type="button" class="swse-ui-button primary" data-gm-wizard-next>Next: Attach Actors</button><button type="submit" class="swse-ui-button primary" data-gm-wizard-submit hidden>Create Faction Dossier</button></div></footer>
    </form>
  </section>
</div>
