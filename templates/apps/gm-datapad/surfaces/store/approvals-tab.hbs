{{!-- GM Store approvals tab — Phase 10 command queue finish. --}}
        <section class="gm-store-tab-panel gm-phase10-approvals {{#if (eq currentTab 'approvals')}}active{{/if}}" data-store-tab-panel="approvals" {{#unless (eq currentTab 'approvals')}}hidden{{/unless}}>
          <div class="gm-store-section-heading gm-phase10-section-heading">
            <div>
              <span class="gm-command-eyebrow">COMMERCE APPROVAL QUEUE</span>
              <h3>Commerce Requests</h3>
              <p>Sale, haggle, restricted purchase, and custom acquisition requests that touch the store economy.</p>
            </div>
            <div class="gm-store-status-strip gm-store-status-strip--compact">
              <span><strong>{{approvalQueueMetrics.total}}</strong>Total</span>
              <span><strong>{{approvalQueueMetrics.sales}}</strong>Sales</span>
              <span><strong>{{approvalQueueMetrics.customAssets}}</strong>Custom Assets</span>
              <span><strong>{{approvalQueueMetrics.warnings}}</strong>Warnings</span>
            </div>
          </div>

          <div class="gm-phase10-approval-layout">
            <article class="gm-command-card gm-phase10-approval-panel">
              <header class="gm-store-card-header">
                <i class="fa-solid fa-scale-balanced"></i>
                <div>
                  <h4>Pending Sales / Haggles</h4>
                  <p>Resolve player sale requests through the store operations service.</p>
                </div>
              </header>
              {{#if pendingSales.length}}
                <div class="gm-store-approval-list gm-store-sale-request-list">
                  {{#each pendingSales}}
                    <div class="gm-store-approval-card gm-store-sale-request-card gm-phase10-sale-card" data-sale-request-id="{{this.id}}">
                      <div class="gm-store-sale-request-main">
                        <div>
                          <span class="gm-command-eyebrow">{{this.type}} REQUEST · {{this.submittedDisplay}}</span>
                          <strong>{{this.item}}</strong>
                          <span>{{this.actor}}</span>
                        </div>
                        <span class="gm-store-status-chip {{#if this.warning}}warn{{else}}ok{{/if}}">{{#if this.warning}}Needs Review{{else}}Pending{{/if}}</span>
                      </div>

                      <div class="gm-store-sale-request-grid">
                        <div><span>Base Price</span><strong>{{this.basePriceDisplay}}</strong></div>
                        <div><span>Suggested Offer</span><strong>{{this.suggestedPriceDisplay}}</strong></div>
                        <div><span>Requested / Default</span><strong>{{this.requestedPriceDisplay}}</strong></div>
                      </div>

                      {{#if this.warning}}<p class="gm-store-warning gm-store-sale-warning">{{this.warning}}</p>{{/if}}

                      <div class="gm-store-sale-controls">
                        <label><span>GM Amount</span><input type="number" min="0" step="1" class="swse-ui-input" data-sale-custom-amount value="{{#if this.defaultAmount}}{{this.defaultAmount}}{{/if}}" placeholder="Set offer"></label>
                        <label><span>GM Note / Denial Reason</span><textarea class="swse-ui-input" data-sale-reason rows="2" placeholder="Optional note for approval; denial reason if denied."></textarea></label>
                      </div>

                      <div class="gm-store-sale-actions">
                        {{#if this.canApprove}}
                          <button type="button" class="swse-ui-button approve" data-action="approve-sale-request" data-request-id="{{this.id}}" data-default-amount="{{this.defaultAmount}}">Approve Suggested</button>
                        {{else}}
                          <button type="button" class="swse-ui-button approve" data-action="approve-sale-request" data-request-id="{{this.id}}">Approve Amount</button>
                        {{/if}}
                        <button type="button" class="swse-ui-button secondary" data-action="counteroffer-sale-request" data-request-id="{{this.id}}">Approve Custom Amount</button>
                        <button type="button" class="swse-ui-button danger" data-action="deny-sale-request" data-request-id="{{this.id}}">Deny</button>
                      </div>
                    </div>
                  {{/each}}
                </div>
              {{else}}
                <p class="gm-store-empty-note">No sale or haggle requests are currently queued.</p>
              {{/if}}
            </article>

            <aside class="gm-command-card gm-phase10-custom-asset-panel">
              <header class="gm-store-card-header">
                <i class="fa-solid fa-robot"></i>
                <div>
                  <h4>Custom Assets</h4>
                  <p>Droids, ships, and vehicles are reviewed in the full GM Approvals app.</p>
                </div>
              </header>
              {{#if pendingApprovals.length}}
                <div class="gm-store-approval-list">
                  {{#each pendingApprovals}}
                    <div class="gm-store-approval-card gm-phase10-asset-card">
                      <span class="gm-command-eyebrow">{{capitalize this.type}}</span>
                      <strong>{{#if this.assetName}}{{this.assetName}}{{else}}{{this.draftData.name}}{{/if}}</strong>
                      <span>{{this.ownerActorName}}</span>
                      {{#if this.frameLabel}}<span>Frame: {{this.frameLabel}}</span>{{/if}}
                      {{#if this.epSummary}}<span>EP: {{this.epSummary}}</span>{{/if}}
                      {{#if this.reviewWarning}}<span class="gm-store-warning">{{this.reviewWarning}}</span>{{/if}}
                      <em>{{#if this.costLabel}}{{this.costLabel}}{{else}}{{this.costCredits}} cr{{/if}}</em>
                      {{#if this.currentCreditsLabel}}<small>Wallet {{this.currentCreditsLabel}} → {{this.afterCreditsLabel}}</small>{{/if}}
                    </div>
                  {{/each}}
                </div>
                <button type="button" class="swse-ui-button primary" data-nav-to="approvals">Open Full Approval Review</button>
              {{else}}
                <p class="gm-store-empty-note">No custom droid or vehicle purchases are queued.</p>
              {{/if}}
            </aside>
          </div>
        </section>
