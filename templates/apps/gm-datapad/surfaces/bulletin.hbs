{{!-- GM Datapad bulletin surface. Extracted from gm-datapad.hbs in Phase 1; behavior unchanged. --}}
    <div class="gm-datapad-page gm-datapad-bulletin">
      <div class="page-header">
        <button class="back-button swse-ui-button" data-nav-to="home">Back</button>
        <h2>{{pageTitle}}</h2>
        <p class="page-subtitle">{{pageDescription}}</p>
      </div>

      <div class="bulletin-console-metrics" aria-label="Bulletin console status">
        <span><strong>{{bulletinStats.live}}</strong> Live</span>
        <span><strong>{{bulletinStats.drafts}}</strong> Drafts</span>
        <span><strong>{{bulletinStats.urgent}}</strong> Alerts</span>
        <span><strong>{{bulletinStats.pinned}}</strong> Last Session</span>
        <span><strong>{{bulletinStats.archived}}</strong> Archived</span>
      </div>

      <div class="bulletin-shell">
        <aside class="bulletin-nav-grid">
          {{#each bulletinNav}}
          <button class="bulletin-nav-card {{#if (eq ../bulletinSection this.id)}}is-active{{/if}}" data-bulletin-section="{{this.id}}">
            <span class="bulletin-nav-copy">
              <span class="bulletin-nav-label">{{this.label}}</span>
              <span class="bulletin-nav-hint">{{this.hint}}</span>
            </span>
            {{#if this.count}}<span class="bulletin-nav-count">{{this.count}}</span>{{/if}}
          </button>
          {{/each}}
        </aside>

        <section class="bulletin-surface swse-ui-panel">
          {{#if (eq bulletinSection "events")}}
          {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/bulletin/events-panel.hbs" }}
          {{else if (eq bulletinSection "holonews")}}
          {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/bulletin/holonews-panel.hbs" }}
          {{else if (eq bulletinSection "messages")}}
          {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/bulletin/messages-panel.hbs" }}
          {{else if (eq bulletinSection "players")}}
          {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/bulletin/player-state-panel.hbs" }}
          {{else if (eq bulletinSection "party")}}
          {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/bulletin/party-state-panel.hbs" }}
          {{/if}}
        </section>

        {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/bulletin/live-preview.hbs" }}
      </div>
    </div>
