{{!-- GM Datapad jobs surface. Extracted from gm-datapad.hbs in Phase 1; behavior unchanged. --}}
    <div class="gm-datapad-page gm-datapad-jobs">
      <div class="page-header job-board-header">
        <button class="back-button swse-ui-button" data-nav-to="home">Back</button>
        <div>
          <h2>GM Job Board</h2>
          <p>Contract command board for posted work, objective review, and reward payout.</p>
        </div>
        <div class="job-board-header-actions">
          <span class="job-board-chip attention">{{jobBoard.stats.review}} Review</span>
          <span class="job-board-chip payout">{{jobBoard.stats.payout}} Payout</span>
        </div>
      </div>

      <div class="job-board-metrics" aria-label="Job board status">
        <span><strong>{{jobBoard.stats.total}}</strong> Total</span>
        <span><strong>{{jobBoard.stats.open}}</strong> Open</span>
        <span><strong>{{jobBoard.stats.active}}</strong> Active</span>
        <span><strong>{{jobBoard.stats.review}}</strong> Review</span>
        <span><strong>{{jobBoard.stats.payout}}</strong> Ready to Pay</span>
        <span><strong>{{jobBoard.stats.archived}}</strong> Archived</span>
      </div>

      <section class="swse-ui-panel job-contract-wizard">
        <div class="job-board-section-header compact">
          <div>
            <span class="gm-command-eyebrow">CONTRACT WIZARD</span>
            <h3>Create Job Contract</h3>
          </div>
          <span class="job-board-help">Client → objectives → briefing → optional faction consequences.</span>
        </div>
        <form class="job-contract-form" data-job-create-form>
          <div class="job-contract-grid">
            <fieldset>
              <legend>Step 1 · Client</legend>
              <label>Client Type
                <select name="clientType">
                  {{#each jobBoard.creation.clientTypes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}
                </select>
              </label>
              <label>Client / Faction / NPC Name<input type="text" name="clientName" placeholder="Galaxy News Net / Black Sun Vigo / Master Tholos"></label>
              <label>Faction Name<input type="text" name="clientFaction" placeholder="Optional faction relationship anchor"></label>
              <label>Client Image / Sigil<input type="text" name="clientImage" placeholder="icons/svg/mystery-man.svg"></label>
              <label class="job-inline-check"><input type="checkbox" name="clientSave"> Save as reusable contact later</label>
            </fieldset>

            <fieldset>
              <legend>Step 2 · Objectives</legend>
              <label>Primary Objective <input type="text" name="primaryObjective" placeholder="Required objective"></label>
              <textarea name="primaryDescription" rows="2" placeholder="Primary memo / player-facing clarity"></textarea>
              <div class="job-reward-row"><input type="number" name="primaryCredits" min="0" step="1" placeholder="Credits"><input type="number" name="primaryXp" min="0" step="1" placeholder="XP"><input type="text" name="primaryItems" placeholder="Item rewards"></div>
              <label>Secondary Objective <input type="text" name="secondaryObjective" placeholder="Optional or required secondary objective"></label>
              <label class="job-inline-check"><input type="checkbox" name="secondaryRequired"> Required for completion</label>
              <textarea name="secondaryDescription" rows="2" placeholder="Secondary memo"></textarea>
              <div class="job-reward-row"><input type="number" name="secondaryCredits" min="0" step="1" placeholder="Credits"><input type="number" name="secondaryXp" min="0" step="1" placeholder="XP"><input type="text" name="secondaryItems" placeholder="Item rewards"></div>
              <label>Tertiary Objective <input type="text" name="tertiaryObjective" placeholder="Always optional bonus objective"></label>
              <textarea name="tertiaryDescription" rows="2" placeholder="Tertiary memo"></textarea>
              <div class="job-reward-row"><input type="number" name="tertiaryCredits" min="0" step="1" placeholder="Credits"><input type="number" name="tertiaryXp" min="0" step="1" placeholder="XP"><input type="text" name="tertiaryItems" placeholder="Item rewards"></div>
            </fieldset>

            <fieldset>
              <legend>Step 3 · Briefing</legend>
              <label>Job Title<input type="text" name="title" placeholder="Retrieve artifact from Korriban" required></label>
              <textarea name="briefing" rows="4" placeholder="What the players are told about this job"></textarea>
              <textarea name="instructions" rows="2" placeholder="Player instructions / rendezvous / conditions"></textarea>
              <textarea name="oocNote" rows="2" placeholder="Optional OOC GM note to players"></textarea>
              <div class="job-reward-row"><input type="number" name="flatCredits" min="0" step="1" placeholder="Flat credits"><input type="text" name="flatItems" placeholder="Flat item reward notes"></div>
            </fieldset>

            <fieldset>
              <legend>Audience & Faction Notes</legend>
              <label>Status
                <select name="status"><option value="draft">Save Draft</option><option value="posted">Post Now</option></select>
              </label>
              <div class="job-recipient-picker">
                <span>Visible to</span>
                {{#each jobBoard.creation.recipients}}
                <label class="job-inline-check"><input type="checkbox" name="recipientIds" value="{{this.id}}"> {{this.label}}</label>
                {{else}}
                <p class="placeholder">No player characters are linked to users yet. The job can still be saved as a GM draft.</p>
                {{/each}}
              </div>
              <label>Success relationship delta<input type="number" name="factionSuccessDelta" step="1" value="0"></label>
              <label>Failure relationship delta<input type="number" name="factionFailureDelta" step="1" value="0"></label>
              <textarea name="factionNotes" rows="2" placeholder="GM-only relationship consequence notes"></textarea>
            </fieldset>
          </div>
          <button type="submit" class="swse-ui-button bulletin-primary-action">Create Contract</button>
        </form>
      </section>

      {{#if jobBoard.hasJobs}}
      <div class="job-board-shell">
        <section class="job-board-command swse-ui-panel">
          <div class="job-board-section-header">
            <div>
              <span class="gm-command-eyebrow">CONTRACT BOARD</span>
              <h3>Mission Pipeline</h3>
            </div>
            <span class="job-board-help">Players see feed updates; GM manages lifecycle here.</span>
          </div>
          <div class="job-board-columns">
            {{#each jobBoard.columns}}
            <section class="job-board-column" data-job-column="{{this.id}}">
              <header>
                <div>
                  <h4>{{this.label}}</h4>
                  <p>{{this.hint}}</p>
                </div>
                <span>{{this.count}}</span>
              </header>
              <div class="job-card-stack">
                {{#each this.jobs}}
                <button type="button" class="job-board-card {{this.statusTone}}" data-job-select="{{this.threadId}}">
                  <div class="job-card-topline">
                    <span class="job-board-chip {{this.statusTone}}">{{this.statusLabel}}</span>
                    {{#if this.needsAttention}}<span class="job-board-chip attention">Needs GM</span>{{/if}}
                  </div>
                  <div class="job-card-title">{{this.title}}</div>
                  <div class="job-card-client">{{this.clientLabel}}{{#if this.factionName}} - {{this.factionName}}{{/if}}</div>
                  <div class="job-card-progress">
                    <span>{{this.requiredProgressLabel}}</span>
                    <span>{{this.optionalProgressLabel}}</span>
                  </div>
                  <div class="job-card-reward">{{this.rewards.approvedCreditsLabel}} - {{this.rewards.approvedXpLabel}}</div>
                  <div class="job-card-footer">
                    <span>{{this.participantCount}} participant(s)</span>
                    <span>{{this.messageCount}} thread events</span>
                  </div>
                </button>
                {{else}}
                <div class="job-column-empty">No jobs here.</div>
                {{/each}}
              </div>
            </section>
            {{/each}}
          </div>
        </section>

        <aside class="job-board-rail swse-ui-panel">
          {{#if jobBoard.selectedJob}}
          <div class="job-board-section-header compact">
            <div>
              <span class="gm-command-eyebrow">DOSSIER</span>
              <h3>{{jobBoard.selectedJob.title}}</h3>
            </div>
            <span class="job-board-chip {{jobBoard.selectedJob.statusTone}}">{{jobBoard.selectedJob.statusLabel}}</span>
          </div>

          <div class="job-detail-client">
            {{#if jobBoard.selectedJob.clientImage}}<img src="{{jobBoard.selectedJob.clientImage}}" alt="{{jobBoard.selectedJob.clientLabel}}">{{/if}}
            <div>
              <strong>{{jobBoard.selectedJob.clientLabel}}</strong>
              <span>{{jobBoard.selectedJob.clientTypeLabel}}{{#if jobBoard.selectedJob.factionName}} - {{jobBoard.selectedJob.factionName}}{{/if}}</span>
              {{#if jobBoard.selectedJob.hasFactionConsequences}}<em>Faction consequence metadata present</em>{{/if}}
            </div>
          </div>

          <label class="job-status-note">
            <span>Lifecycle GM Note</span>
            <textarea rows="2" data-job-status-note placeholder="Optional reason for status override / lifecycle change"></textarea>
          </label>
          <div class="job-detail-actions">
            {{#each jobBoard.statusActions}}
            <button type="button" class="swse-ui-button" data-job-status-action data-thread-id="{{../jobBoard.selectedJob.threadId}}" data-status="{{this.value}}">{{this.label}}</button>
            {{/each}}
          </div>

          <div class="job-detail-block">
            <h4>Objectives</h4>
            <div class="job-objective-list">
              {{#each jobBoard.selectedJob.objectives}}
              <article class="job-objective-card {{this.statusTone}}">
                <div class="job-objective-head">
                  <span class="job-board-chip {{this.type}}">{{this.typeLabel}}</span>
                  <span class="job-board-chip {{this.statusTone}}">{{this.statusLabel}}</span>
                  <span class="job-board-chip required">{{this.requiredLabel}}</span>
                </div>
                <strong>{{this.title}}</strong>
                {{#if this.description}}<p>{{this.description}}</p>{{/if}}
                <div class="job-objective-rewards">
                  {{#if this.rewardCreditsLabel}}<span>{{this.rewardCreditsLabel}}</span>{{/if}}
                  {{#if this.rewardXpLabel}}<span>{{this.rewardXpLabel}}</span>{{/if}}
                  {{#if this.rewardItems}}<span>{{this.rewardItems}}</span>{{/if}}
                </div>
                <label class="job-objective-note"><span>GM Review Note</span><textarea rows="2" data-job-objective-note-for="{{this.id}}" placeholder="Optional approval/rejection/failure note"></textarea></label>
                <div class="job-objective-actions">
                  <button type="button" class="swse-ui-button" data-job-objective-action data-thread-id="{{../jobBoard.selectedJob.threadId}}" data-objective-id="{{this.id}}" data-objective-status="approved">Approve</button>
                  <button type="button" class="swse-ui-button" data-job-objective-action data-thread-id="{{../jobBoard.selectedJob.threadId}}" data-objective-id="{{this.id}}" data-objective-status="rejected">Reject</button>
                  <button type="button" class="swse-ui-button" data-job-objective-action data-thread-id="{{../jobBoard.selectedJob.threadId}}" data-objective-id="{{this.id}}" data-objective-status="failed">Fail</button>
                  <button type="button" class="swse-ui-button" data-job-objective-action data-thread-id="{{../jobBoard.selectedJob.threadId}}" data-objective-id="{{this.id}}" data-objective-status="open">Reopen</button>
                </div>
              </article>
              {{/each}}
            </div>
          </div>

          <div class="job-detail-block">
            <h4>Participants</h4>
            <div class="job-participant-list">
              {{#each jobBoard.selectedJob.participants}}
              <div class="job-participant-row">
                {{#if this.avatar}}<img src="{{this.avatar}}" alt="{{this.label}}">{{/if}}
                <span>{{this.label}}</span>
                <em>{{this.typeLabel}}</em>
              </div>
              {{else}}
              <p class="placeholder">No non-GM participants are attached to this job yet.</p>
              {{/each}}
            </div>
          </div>

          <div class="job-detail-block job-payout-panel">
            <h4>Reward Distribution</h4>
            <div class="job-reward-summary">
              <span>Credits: <strong>{{jobBoard.selectedJob.rewards.approvedCreditsLabel}}</strong></span>
              <span>XP: <strong>{{jobBoard.selectedJob.rewards.approvedXpLabel}}</strong></span>
              <span>Items: <strong>{{jobBoard.selectedJob.rewards.itemSummary}}</strong></span>
            </div>
            <form class="job-payout-form job-distribution-form" data-job-distribution-form>
              <input type="hidden" name="threadId" value="{{jobBoard.selectedJob.threadId}}">
              <label>Distribution mode
                <select name="payoutMode">
                  {{#each jobBoard.payoutModes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}
                </select>
              </label>
              <label>Single-player recipient
                <select name="recipientId">
                  {{#each jobBoard.selectedJob.actorPayoutTargets}}
                  <option value="{{this.id}}">{{this.label}}</option>
                  {{/each}}
                  {{#each jobBoard.selectedJob.payoutTargets}}
                    {{#if this.partyFund}}<option value="{{this.id}}">{{this.label}}</option>{{/if}}
                  {{/each}}
                </select>
              </label>
              <div class="job-recipient-picker">
                <span>Selected recipients for split/full payout</span>
                {{#each jobBoard.selectedJob.actorPayoutTargets}}
                <label class="job-inline-check"><input type="checkbox" name="recipientIds" value="{{this.id}}" checked> {{this.label}}</label>
                {{else}}
                <p class="placeholder">No actor participants are attached to this job yet.</p>
                {{/each}}
              </div>
              <label>Amount
                <input type="number" name="amount" min="0" step="1" value="{{jobBoard.selectedJob.rewards.totalCredits}}">
              </label>
              {{#if jobBoard.partyFundEnabled}}
              <label>Party fund cut %
                <input type="number" name="partyFundCutPercent" min="0" max="100" step="1" value="0">
              </label>
              {{/if}}
              <button type="submit" class="swse-ui-button bulletin-primary-action">Distribute Credits</button>
            </form>
            {{#if jobBoard.selectedJob.rewards.approvedXp}}
            <form class="job-payout-form job-xp-form" data-job-xp-form>
              <input type="hidden" name="threadId" value="{{jobBoard.selectedJob.threadId}}">
              <label>XP mode
                <select name="payoutMode">
                  {{#each jobBoard.xpPayoutModes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}
                </select>
              </label>
              <label>Single-player recipient
                <select name="recipientId">
                  {{#each jobBoard.selectedJob.actorPayoutTargets}}
                  <option value="{{this.id}}">{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <div class="job-recipient-picker">
                <span>Selected recipients for split/full XP</span>
                {{#each jobBoard.selectedJob.actorPayoutTargets}}
                <label class="job-inline-check"><input type="checkbox" name="recipientIds" value="{{this.id}}" checked> {{this.label}}</label>
                {{else}}
                <p class="placeholder">No actor participants are attached to this job yet.</p>
                {{/each}}
              </div>
              <label>XP Amount
                <input type="number" name="amount" min="0" step="1" value="{{jobBoard.selectedJob.rewards.approvedXp}}">
              </label>
              <button type="submit" class="swse-ui-button bulletin-primary-action">Award XP</button>
            </form>
            {{/if}}
            <form class="job-payout-form" data-job-payout-form>
              <input type="hidden" name="threadId" value="{{jobBoard.selectedJob.threadId}}">
              <label>Legacy direct credit recipient
                <select name="recipientId">
                  {{#each jobBoard.selectedJob.payoutTargets}}
                  <option value="{{this.id}}">{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>Amount
                <input type="number" name="amount" min="0" step="1" value="{{jobBoard.selectedJob.rewards.totalCredits}}">
              </label>
              {{#if jobBoard.partyFundEnabled}}
              <label>Party fund cut %
                <input type="number" name="partyFundCutPercent" min="0" max="100" step="1" value="0">
              </label>
              {{/if}}
              <button type="submit" class="swse-ui-button">Legacy Direct Pay</button>
            </form>
            {{#if jobBoard.selectedJob.hasAttachedItemRewards}}
            <form class="job-payout-form" data-job-award-items-form>
              <input type="hidden" name="threadId" value="{{jobBoard.selectedJob.threadId}}">
              {{#each jobBoard.selectedJob.rewardItemUuids}}<input type="hidden" name="itemUuids" value="{{this}}">{{/each}}
              <label>Item distribution
                <select name="distributionMode">
                  {{#each jobBoard.itemDistributionModes}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}
                </select>
              </label>
              <label>Single item recipient
                <select name="recipientId">
                  {{#each jobBoard.selectedJob.payoutTargets}}
                    {{#if this.actorId}}<option value="{{this.id}}">{{this.label}}</option>{{/if}}
                  {{/each}}
                </select>
              </label>
              <div class="job-recipient-picker">
                <span>Selected recipients for copied/unique item distribution</span>
                {{#each jobBoard.selectedJob.actorPayoutTargets}}
                <label class="job-inline-check"><input type="checkbox" name="recipientIds" value="{{this.id}}" checked> {{this.label}}</label>
                {{else}}
                <p class="placeholder">No actor participants are attached to this job yet.</p>
                {{/each}}
              </div>
              <button type="submit" class="swse-ui-button">Award Attached Items</button>
            </form>
            {{/if}}
          </div>

          <div class="job-detail-block">
            <h4>Timeline</h4>
            <div class="job-timeline">
              {{#each jobBoard.selectedJob.timeline}}
              <div class="job-timeline-row">
                <strong>{{this.label}}</strong>
                <span>{{this.atLabel}}</span>
              </div>
              {{else}}
              <p class="placeholder">No job timeline yet.</p>
              {{/each}}
            </div>
          </div>
          {{else}}
          <p class="placeholder">Select a job to inspect its dossier.</p>
          {{/if}}
        </aside>
      </div>

      <div class="job-queue-grid">
        <section class="swse-ui-panel job-queue-panel">
          <div class="job-board-section-header compact">
            <div>
              <span class="gm-command-eyebrow">REVIEW QUEUE</span>
              <h3>Objective Claims</h3>
            </div>
            <span class="job-board-chip attention">{{jobBoard.reviewItems.length}}</span>
          </div>
          {{#each jobBoard.reviewItems}}
          <article class="job-queue-card">
            <span class="job-board-chip review">{{this.statusLabel}}</span>
            <strong>{{this.jobTitle}}</strong>
            <p>{{this.typeLabel}}: {{this.title}}</p>
            <label class="job-objective-note compact"><span>GM Review Note</span><textarea rows="2" data-job-objective-note-for="{{this.id}}" placeholder="Optional note"></textarea></label>
            <div class="job-objective-actions">
              <button type="button" class="swse-ui-button" data-job-objective-action data-thread-id="{{this.threadId}}" data-objective-id="{{this.id}}" data-objective-status="approved">Approve</button>
              <button type="button" class="swse-ui-button" data-job-objective-action data-thread-id="{{this.threadId}}" data-objective-id="{{this.id}}" data-objective-status="rejected">Reject</button>
            </div>
          </article>
          {{else}}
          <p class="placeholder">No objective claims need review.</p>
          {{/each}}
        </section>

        <section class="swse-ui-panel job-queue-panel">
          <div class="job-board-section-header compact">
            <div>
              <span class="gm-command-eyebrow">PAYOUT QUEUE</span>
              <h3>Completed Contracts</h3>
            </div>
            <span class="job-board-chip payout">{{jobBoard.payoutItems.length}}</span>
          </div>
          {{#each jobBoard.payoutItems}}
          <article class="job-queue-card">
            <span class="job-board-chip payout">Ready</span>
            <strong>{{this.title}}</strong>
            <p>{{this.rewards.approvedCreditsLabel}} - {{this.rewards.approvedXpLabel}}</p>
            <button type="button" class="swse-ui-button" data-job-select="{{this.threadId}}">Distribute Rewards</button>
          </article>
          {{else}}
          <p class="placeholder">No completed contracts are waiting on payout.</p>
          {{/each}}
        </section>
      </div>
      {{else}}
      <div class="swse-ui-panel job-board-empty-state">
        <h3>No jobs posted yet</h3>
        <p>Job threads created through Messenger will appear here as contract cards with lifecycle, review, and payout controls.</p>
      </div>
      {{/if}}
    </div>

    {{!-- Trade Console Page --}}
