{{!-- GM Datapad healing surface. Extracted from gm-datapad.hbs in Phase 1; behavior unchanged. --}}
    <div class="gm-datapad-page gm-datapad-healing gm-combat-recovery">
      <div class="page-header combat-recovery-header">
        <button class="back-button swse-ui-button" data-nav-to="home">Back</button>
        <div>
          <h2>{{pageTitle}}</h2>
          <p class="page-subtitle">{{pageDescription}}</p>
        </div>
        <div class="combat-recovery-status {{#if combatRecovery.hasActiveCombat}}active{{else}}idle{{/if}}">
          <span class="status-label">Encounter</span>
          <strong>{{combatRecovery.activeCombatLabel}}</strong>
        </div>
      </div>

      <div class="combat-recovery-metrics" aria-label="Combat and recovery status">
        <div class="combat-recovery-metric"><span>Roster</span><strong>{{combatRecovery.metrics.total}}</strong></div>
        <div class="combat-recovery-metric"><span>Combatants</span><strong>{{combatRecovery.metrics.activeCombatants}}</strong></div>
        <div class="combat-recovery-metric warning"><span>Wounded</span><strong>{{combatRecovery.metrics.wounded}}</strong></div>
        <div class="combat-recovery-metric critical"><span>Down</span><strong>{{combatRecovery.metrics.downed}}</strong></div>
        <div class="combat-recovery-metric warning"><span>CT Impaired</span><strong>{{combatRecovery.metrics.conditionImpaired}}</strong></div>
        <div class="combat-recovery-metric info"><span>SW Spent</span><strong>{{combatRecovery.metrics.secondWindSpent}}</strong></div>
        <div class="combat-recovery-metric critical"><span>Poisons</span><strong>{{combatRecovery.metrics.activePoisons}}</strong></div>
        <div class="combat-recovery-metric warning"><span>Ongoing</span><strong>{{combatRecovery.metrics.ongoingEffects}}</strong></div>
        <div class="combat-recovery-metric stable"><span>Rest Eligible</span><strong>{{combatRecovery.metrics.restEligible}}</strong></div>
        <div class="combat-recovery-metric muted"><span>Droids</span><strong>{{combatRecovery.metrics.droids}}</strong></div>
      </div>

      <div class="combat-recovery-shell">
        {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/healing/party-board.hbs" }}

        {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/healing/selected-actor-rail.hbs" }}
      </div>
    </div>
