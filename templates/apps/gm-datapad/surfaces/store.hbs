{{!-- GM Datapad store surface. Extracted from gm-datapad.hbs in Phase 1; behavior unchanged. --}}
    <div class="gm-datapad-page gm-datapad-store gm-store-control-console swse-store-ui swse-ui-shell swse-store-shell flexcol">
      <div class="page-header gm-app-header gm-store-header">
        <button class="back-button swse-ui-button" data-nav-to="home">Back</button>
        <div class="gm-app-header-copy">
          <span class="gm-command-eyebrow">COMMERCE COMMAND</span>
          <h2>{{pageTitle}}</h2>
          <p class="page-subtitle">{{pageDescription}}</p>
        </div>
        <div class="gm-store-status-strip" aria-label="Store command status">
          <span class="{{#if storeOpen}}online{{else}}offline{{/if}}"><strong>{{#if storeOpen}}OPEN{{else}}CLOSED{{/if}}</strong>Store</span>
          <span><strong>{{transactions.length}}</strong>Transactions</span>
          <span><strong>{{storeApprovalCounts.total}}</strong>Approvals</span>
          <span><strong>{{inventoryStats.total}}</strong>Inventory</span>
        </div>
      </div>

      <nav class="gm-store-tabs swse-ui-tabs swse-ui-frame" aria-label="Store control tabs">
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'options')}}active{{/if}}" data-store-tab="options" aria-selected="{{#if (eq currentTab 'options')}}true{{else}}false{{/if}}">Store Options</button>
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'transactions')}}active{{/if}}" data-store-tab="transactions" aria-selected="{{#if (eq currentTab 'transactions')}}true{{else}}false{{/if}}">Transactions <span>{{transactionStats.total}}</span></button>
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'approvals')}}active{{/if}}" data-store-tab="approvals" aria-selected="{{#if (eq currentTab 'approvals')}}true{{else}}false{{/if}}">Approvals <span>{{approvalQueueMetrics.total}}</span></button>
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'inventory')}}active{{/if}}" data-store-tab="inventory" aria-selected="{{#if (eq currentTab 'inventory')}}true{{else}}false{{/if}}">Inventory <span>{{inventoryStats.total}}</span></button>
      </nav>

      <div class="gm-store-tab-content swse-ui-panel">

        {{!-- TAB 1: STORE OPTIONS --}}
        {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/store/options-tab.hbs" }}

        {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/store/transactions-tab.hbs" }}

        {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/store/approvals-tab.hbs" }}

        {{> "systems/foundryvtt-swse/templates/apps/gm-datapad/surfaces/store/inventory-tab.hbs" }}

      </div>
    </div>
