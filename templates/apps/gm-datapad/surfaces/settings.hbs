{{!-- GM Datapad settings command surface. --}}
<div class="gm-datapad-page gm-datapad-settings gm-phase7-settings swse-shell-surface-host" data-shell-surface="settings">
  <div class="gm-phase6-command-header gm-phase7-settings-header">
    <button class="ph-back" type="button" data-nav-to="home">
      <i class="fa-solid fa-arrow-left"></i>&nbsp;Home
    </button>
    <div class="gm-phase6-command-copy">
      <span class="gm-command-eyebrow">INTERFACE CONFIGURATION</span>
      <h2>{{pageTitle}}</h2>
      <p>{{pageDescription}}</p>
    </div>
  </div>

  <div class="gm-phase7-settings-layout">
    <section class="gm-command-card gm-phase7-shell-settings-card">
      <header class="gm-store-card-header">
        <i class="fa-solid fa-palette"></i>
        <div>
          <h3>Shell Theme & Display</h3>
          <p>Shared holopad settings for accent colors, motion, scanlines, glow, and language.</p>
        </div>
      </header>
      <div class="gm-phase7-shared-settings-frame">
        {{> "systems/foundryvtt-swse/templates/shell/partials/surface-settings.hbs" vm=settingsVm}}
      </div>
    </section>

    <section class="gm-game-policy-panel gm-command-card gm-phase7-policy-panel" data-gm-game-policy-panel>
      <header class="gm-store-card-header">
        <i class="fa-solid fa-dice-d20"></i>
        <div>
          <span class="gm-command-eyebrow">GAME POLICY</span>
          <h3>{{gamePolicyVm.title}}</h3>
          <p>{{gamePolicyVm.description}}</p>
        </div>
      </header>

      <div class="gm-phase7-policy-grid">
        {{#each gamePolicyVm.groups}}
        <article class="gm-phase7-policy-group" data-game-policy-group="{{this.id}}">
          <header>
            <div>
              <span class="gm-command-eyebrow">{{this.id}}</span>
              <h4>{{this.label}}</h4>
            </div>
            <span class="gm-phase7-policy-count">{{this.fields.length}}</span>
          </header>
          <div class="gm-game-policy-fields gm-phase7-policy-fields">
            {{#each this.fields}}
            <label class="gm-game-policy-field gm-phase7-policy-field {{this.type}}">
              <span>
                <strong>{{this.label}}</strong>
                <em>{{this.description}}</em>
              </span>
              {{#if (eq this.type "checkbox")}}
                <input type="checkbox" data-game-policy-field="{{this.key}}" {{#if this.checked}}checked{{/if}}>
              {{else if (eq this.type "select")}}
                <select class="swse-ui-input" data-game-policy-field="{{this.key}}">
                  {{#each this.choices}}
                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              {{else}}
                <input type="number" class="swse-ui-input" min="{{this.min}}" max="{{this.max}}" step="{{this.step}}" value="{{this.value}}" data-game-policy-field="{{this.key}}">
              {{/if}}
            </label>
            {{/each}}
          </div>
        </article>
        {{/each}}
      </div>
    </section>
  </div>
</div>
