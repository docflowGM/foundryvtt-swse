{{!-- GM Datapad settings surface. Extracted from gm-datapad.hbs in Phase 1; behavior unchanged. --}}
    <div class="gm-datapad-page gm-datapad-settings swse-shell-surface-host" data-shell-surface="settings">
      {{> "systems/foundryvtt-swse/templates/shell/partials/surface-settings.hbs" vm=settingsVm}}

      <section class="gm-game-policy-panel swse-ui-panel" data-gm-game-policy-panel>
        <div class="gm-command-panel-header">
          <div>
            <span class="gm-command-eyebrow">GAME POLICY</span>
            <h3>{{gamePolicyVm.title}}</h3>
            <p>{{gamePolicyVm.description}}</p>
          </div>
        </div>
        <div class="gm-game-policy-grid">
          {{#each gamePolicyVm.groups}}
          <article class="gm-command-card gm-game-policy-group" data-game-policy-group="{{this.id}}">
            <header class="gm-store-card-header">
              <i class="fa-solid fa-dice-d20"></i>
              <div>
                <h4>{{this.label}}</h4>
                <p>Campaign-facing player/GM coordination gates.</p>
              </div>
            </header>
            <div class="gm-game-policy-fields">
              {{#each this.fields}}
              <label class="gm-game-policy-field {{this.type}}">
                <span>
                  <strong>{{this.label}}</strong>
                  <em>{{this.description}}</em>
                </span>
                {{#if (eq this.type "checkbox")}}
                  <input type="checkbox" data-game-policy-field="{{this.key}}" {{#if this.checked}}checked{{/if}}>
                {{else if (eq this.type "select")}}
                  <select class="swse-ui-input" data-game-policy-field="{{this.key}}">
                    {{#each this.choices}}
                      <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                  </select>
                {{else}}
                  <input type="number" class="swse-ui-input" min="{{this.min}}" max="{{this.max}}" step="{{this.step}}" value="{{this.value}}" data-game-policy-field="{{this.key}}">
                {{/if}}
              </label>
              {{/each}}
            </div>
          </article>
          {{/each}}
        </div>
      </section>
    </div>

    {{!-- Combat & Recovery Page --}}
