<div class="gm-datapad-container swse-ui-shell swse-datapad flexcol" data-theme="{{themeKey}}" data-motion-style="{{motionStyle}}" style="{{{themeStyleInline}}}; {{{motionStyleInline}}};">
  {{!-- GM Datapad Shell — mirrors the actor holopad tablet chrome/navigation while keeping GM page logic intact. --}}
  <div class="swse-sheet-v2-shell swse-sheet-v2-shell--concept swse-sheet-v2-shell--gm-datapad sheet-shell" data-shell-surface="{{currentPage}}" data-theme="{{themeKey}}" data-motion-style="{{motionStyle}}" style="{{{themeStyleInline}}}; {{{motionStyleInline}}};">
    <div class="swse-v2-tablet swse-v2-tablet--concept gm-datapad-tablet">
      <div class="swse-tablet-rivet swse-tablet-rivet--tl" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--tr" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--bl" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--br" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--ml" aria-hidden="true"></div>
      <div class="swse-tablet-rivet swse-tablet-rivet--mr" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--top-a" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--top-b" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--right-a" aria-hidden="true"></div>
      <div class="swse-tablet-phys swse-tablet-phys--right-b" aria-hidden="true"></div>
      <div class="swse-tablet-camera" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--a" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--b" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--c" aria-hidden="true"></div>
      <div class="swse-tablet-led swse-tablet-led--d" aria-hidden="true"></div>

      <div class="swse-tablet-top-bezel" data-action="tablet-drag" title="Drag datapad" aria-label="Datapad drag rail">
        <div class="swse-tablet-drag-handle" data-action="tablet-drag" aria-hidden="true"></div>
      </div>

      <div class="swse-tablet-hardware-rail swse-tablet-top-right-rail" aria-label="GM datapad controls">
        <span class="swse-tablet-serial swse-tablet-serial--aurebesh" aria-label="GM command datapad">GM-CMD-{{currentPage}}</span>
        <span class="swse-tablet-status-lights" aria-hidden="true"><span></span><span></span><span></span></span>
        <button type="button" class="swse-tablet-control swse-tablet-control--home" data-nav-to="home" title="Home" aria-label="Home"><span class="swse-tablet-control__home-glyph" aria-hidden="true"></span></button>
      </div>

      <div class="swse-tablet-vent swse-tablet-vent--top" aria-hidden="true"><span></span><span></span><span></span><span></span></div>

      <div class="swse-v2-screen swse-v2-screen--concept gm-datapad-screen-shell">
        <div class="scan-v" aria-hidden="true"></div>
        <div class="corner tl" aria-hidden="true"></div>
        <div class="corner tr" aria-hidden="true"></div>
        <div class="corner bl" aria-hidden="true"></div>
        <div class="corner br" aria-hidden="true"></div>
        <div class="swse-datapad swse-screen gm-datapad-screen flexcol">

    {{!-- Home Page --}}
    {{#if (eq currentPage "home")}}
    <div class="gm-datapad-page gm-datapad-home swse-home-surface" data-shell-region="surface-home">
      <div class="swse-home-hud">
        <div class="swse-home-hud-left">
          <span class="swse-home-dot"></span>
          <span class="swse-home-hud-title">GM COMMAND HOLOPAD</span>
          <span class="swse-home-tag">OPS</span>
          <span class="swse-home-tag">SHELL PARITY</span>
        </div>
        <div class="swse-home-hud-right">
          <span>GM ACCESS</span>
          <span class="swse-home-signal"><span></span><span></span><span></span><span></span></span>
          <span class="swse-home-battery"><span class="swse-home-cell"><span class="swse-home-fill"></span></span> 78%</span>
        </div>
      </div>

      <div class="swse-home-page-header gm-home-page-header">
        <div>
          <div class="swse-home-page-title">GM Operations</div>
          <div class="swse-home-page-kicker">COMMAND NODE · SHARED HOLOPAD SHELL</div>
          <div class="swse-home-page-subtitle">▸ Dashboard, store control, approvals, healing, workspace, and bulletin operations</div>
        </div>
        <div class="swse-home-page-greeting">
          <span class="em">{{user.name}}</span> · game master console<br>
          <span class="stardate">GM DATAPAD · GLOBAL THEME CONTEXT</span>
        </div>
      </div>

      <div class="gm-command-dashboard" aria-label="GM command summary">
        {{#each commandStats}}
        <button type="button" class="gm-command-status-card {{this.tone}}" data-nav-to="{{this.route}}">
          <span class="gm-command-status-label">{{this.label}}</span>
          <strong>{{this.value}}</strong>
          <span class="gm-command-status-detail">{{this.detail}}</span>
        </button>
        {{/each}}
      </div>

      <div class="gm-command-grid">
        <section class="gm-command-panel gm-command-panel--intel swse-ui-panel">
          <div class="gm-command-panel-header">
            <div>
              <span class="gm-command-eyebrow">LIVE OPS</span>
              <h3>Command Intel</h3>
            </div>
            <span class="gm-command-panel-chip {{#if combatStatus.active}}crit{{else}}stable{{/if}}">{{combatStatus.label}}</span>
          </div>

          <div class="gm-intel-grid">
            {{#each dashboardPanels}}
            <button type="button" class="gm-intel-card {{this.tone}}" data-nav-to="{{this.route}}">
              <span class="gm-intel-icon"><i class="{{this.icon}}"></i></span>
              <span class="gm-intel-label">{{this.label}}</span>
              <strong>{{this.value}}</strong>
              <span class="gm-intel-detail">{{this.detail}}</span>
            </button>
            {{/each}}
          </div>
        </section>

        <aside class="gm-command-panel gm-command-panel--alerts swse-ui-panel">
          <div class="gm-command-panel-header">
            <div>
              <span class="gm-command-eyebrow">WATCHLIST</span>
              <h3>Alerts</h3>
            </div>
          </div>

          <div class="gm-alert-stack">
            {{#if dashboardAlerts.length}}
              {{#each dashboardAlerts}}
              <button type="button" class="gm-alert-row {{this.tone}}" data-nav-to="{{this.route}}">
                <span class="gm-alert-pip"></span>
                <span><strong>{{this.label}}</strong><em>{{this.detail}}</em></span>
              </button>
              {{/each}}
            {{else}}
              <p class="gm-empty-intel">No priority alerts. Command board is stable.</p>
            {{/if}}
          </div>
        </aside>
      </div>

      <div class="gm-command-grid gm-command-grid--lower">
        <section class="gm-command-panel gm-command-panel--transactions swse-ui-panel">
          <div class="gm-command-panel-header">
            <div>
              <span class="gm-command-eyebrow">RECENT ACTIVITY</span>
              <h3>Store Ledger</h3>
            </div>
            <button type="button" class="swse-ui-button gm-mini-button" data-nav-to="store">View Store</button>
          </div>

          {{#if recentTransactions.length}}
          <div class="gm-transaction-list">
            {{#each recentTransactions}}
            <div class="gm-transaction-row">
              <span class="gm-transaction-main"><strong>{{this.actor}}</strong><em>{{this.item}}</em></span>
              <span class="gm-transaction-meta">{{this.timeLabel}}</span>
              <span class="gm-transaction-amount {{this.amountTone}}">{{this.amountLabel}}</span>
            </div>
            {{/each}}
          </div>
          {{else}}
            <p class="gm-empty-intel">No store transactions have been recorded.</p>
          {{/if}}
        </section>

        <aside class="gm-command-panel gm-command-panel--quick swse-ui-panel">
          <div class="gm-command-panel-header">
            <div>
              <span class="gm-command-eyebrow">FAST PATHS</span>
              <h3>Quick Actions</h3>
            </div>
          </div>
          <div class="gm-quick-action-grid">
            {{#each quickActions}}
            <button type="button" class="gm-quick-action {{this.tone}}" data-nav-to="{{this.route}}">
              <i class="{{this.icon}}"></i>
              <span>{{this.label}}</span>
            </button>
            {{/each}}
          </div>
        </aside>
      </div>

      <div class="app-cards-grid gm-shell-app-grid">
        {{#each apps}}
        <button class="app-card swse-home-tile gm-shell-app-card {{#if this.featured}}featured{{/if}}" data-app-card="{{this.id}}" data-route-id="{{this.id}}"
                title="{{this.description}}">
          <span class="swse-home-tile-id">{{this.code}}</span>
          <div class="app-card-icon swse-home-tile-icon">
            <i class="{{this.icon}}"></i>
          </div>
          <div class="app-card-label swse-home-tile-label">{{this.label}}</div>
          <div class="app-card-desc">{{this.description}}</div>
          <div class="swse-home-tile-status"><span class="swse-home-dot {{this.statusTone}}"></span><span>{{this.status}}</span></div>
          {{#if this.badgeCount}}<span class="app-card-badge swse-home-badge {{this.badgeType}}">{{this.badgeCount}}</span>{{/if}}
        </button>
        {{/each}}
      </div>
    </div>


    {{!-- Bulletin Page --}}
    {{else if (eq currentPage "bulletin")}}
    <div class="gm-datapad-page gm-datapad-bulletin">
      <div class="page-header">
        <button class="back-button swse-ui-button" data-nav-to="home">← Back</button>
        <h2>{{pageTitle}}</h2>
        <p class="page-subtitle">{{pageDescription}}</p>
      </div>

      <div class="bulletin-console-metrics" aria-label="Bulletin console status">
        <span><strong>{{bulletinStats.live}}</strong> Live</span>
        <span><strong>{{bulletinStats.drafts}}</strong> Drafts</span>
        <span><strong>{{bulletinStats.urgent}}</strong> Alerts</span>
        <span><strong>{{bulletinStats.pinned}}</strong> Last Session</span>
        <span><strong>{{bulletinStats.archived}}</strong> Archived</span>
      </div>

      <div class="bulletin-shell">
        <aside class="bulletin-nav-grid">
          {{#each bulletinNav}}
          <button class="bulletin-nav-card {{#if (eq ../bulletinSection this.id)}}is-active{{/if}}" data-bulletin-section="{{this.id}}">
            <span class="bulletin-nav-copy">
              <span class="bulletin-nav-label">{{this.label}}</span>
              <span class="bulletin-nav-hint">{{this.hint}}</span>
            </span>
            {{#if this.count}}<span class="bulletin-nav-count">{{this.count}}</span>{{/if}}
          </button>
          {{/each}}
        </aside>

        <section class="bulletin-surface swse-ui-panel">
          {{#if (eq bulletinSection "events")}}
          <div class="bulletin-panel-header">
            <div>
              <h3>Manage Events</h3>
              <p>Broadcast campaign news, session recaps, and public Holonet updates.</p>
            </div>
          </div>

          <form class="bulletin-composer" data-bulletin-form="events">
            <input type="hidden" name="recordId" value="{{eventEditorRecord.id}}">
            <input type="hidden" name="submitMode" value="draft">
            <div class="bulletin-form-grid">
              <label>
                <span>Headline</span>
                <input type="text" name="title" value="{{eventEditorRecord.title}}" placeholder="Hyperlane disruption at @Docking Ring Aurek">
              </label>
              <label>
                <span>Category</span>
                <input type="text" name="category" value="{{eventEditorRecord.category}}" placeholder="news / mission / warning">
              </label>
              <label>
                <span>Priority</span>
                <select name="priority">
                  <option value="low" {{#if (eq eventEditorRecord.priority "low")}}selected{{/if}}>Low</option>
                  <option value="normal" {{#if (or (not eventEditorRecord.priority) (eq eventEditorRecord.priority "normal"))}}selected{{/if}}>Normal</option>
                  <option value="high" {{#if (eq eventEditorRecord.priority "high")}}selected{{/if}}>High</option>
                  <option value="critical" {{#if (eq eventEditorRecord.priority "critical")}}selected{{/if}}>Critical</option>
                </select>
              </label>
              <label>
                <span>Published By</span>
                <input type="text" name="authorName" value="{{eventEditorRecord.senderName}}" placeholder="Galactic News Service">
              </label>
              <label class="bulletin-image-field">
                <span>Holostill / Feed Image</span>
                <span class="bulletin-image-row">
                  <input type="text" name="imageUrl" value="{{eventEditorRecord.imageUrl}}" placeholder="systems/foundryvtt-swse/assets/.../image.webp" data-bulletin-image-input>
                  <button type="button" class="swse-ui-button" data-action="bulletin-pick-image">Browse</button>
                </span>
              </label>
            </div>

            <div class="bulletin-form-grid bulletin-form-grid-audience">
              <label>
                <span>Audience</span>
                <select name="audienceType">
                  {{#each audienceOptions}}
                  <option value="{{this.value}}" {{#if (eq ../eventEditorRecord.audienceType this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <div class="bulletin-recipient-picker">
                <span>Recipients</span>
                <div class="bulletin-recipient-list">
                  {{#each bulletinPlayers}}
                  <label class="bulletin-recipient-chip">
                    <input type="checkbox" name="playerIds" value="{{this.userId}}" {{#if (contains ../eventEditorRecord.audiencePlayerIds this.userId)}}checked{{/if}}>
                    <span>{{this.actorName}}</span>
                  </label>
                  {{/each}}
                </div>
              </div>
            </div>

            <div class="bulletin-console-controls">
              <label class="bulletin-toggle-chip">
                <input type="checkbox" name="urgent" {{#if eventEditorRecord.isUrgent}}checked{{/if}}>
                <span>Urgent home alert</span>
              </label>
              <label class="bulletin-toggle-chip">
                <input type="checkbox" name="pinAsLastSession" {{#if eventEditorRecord.isPinned}}checked{{/if}}>
                <span>Pin as Last Session</span>
              </label>
              <label class="bulletin-slot-select">
                <span>Home Placement</span>
                <select name="homeSlot">
                  <option value="feed" {{#if (or (not eventEditorRecord.homeSlot) (eq eventEditorRecord.homeSlot "feed"))}}selected{{/if}}>Comm Feed</option>
                  <option value="last-session" {{#if (eq eventEditorRecord.homeSlot "last-session")}}selected{{/if}}>Last Session</option>
                </select>
              </label>
            </div>

            <label class="bulletin-body-field">
              <span>Body</span>
              <textarea name="body" rows="6" placeholder="Imperial patrols spotted near @Wayfarer. Avoid the #south docking ring until the patrol window closes." data-holonet-editor="bulletin-event">{{eventEditorRecord.body}}</textarea>
            </label>

            <div class="bulletin-syntax-guide">
              {{#each syntaxGuide}}<span>{{this}}</span>{{/each}}
            </div>

            <div class="bulletin-form-actions">
              <button type="submit" class="swse-ui-button" data-submit-mode="draft">Save Draft</button>
              <button type="submit" class="swse-ui-button bulletin-primary-action" data-submit-mode="publish">Publish Event</button>
            </div>
          </form>

          <div class="bulletin-record-grid">
            {{#each eventRecords}}
            <article class="bulletin-record-card {{this.state}} {{this.recordTone}}">
              <div class="bulletin-record-meta">
                <span class="bulletin-chip state">{{this.stateLabel}}</span>
                <span class="bulletin-chip category">{{this.category}}</span>
                <span class="bulletin-chip priority">{{this.priority}}</span>
                <span class="bulletin-chip audience">{{this.audienceLabel}}</span>
                <span class="bulletin-chip home-slot">{{this.homeSlotLabel}}</span>
                {{#if this.isBreakingNews}}<span class="bulletin-chip breaking">BREAKING</span>{{else if this.isUrgent}}<span class="bulletin-chip urgent">ALERT</span>{{/if}}
                {{#if this.isPinned}}<span class="bulletin-chip pinned">PINNED</span>{{/if}}
              </div>
              <h4>{{this.title}}</h4>
              <div class="bulletin-record-sender">{{this.senderName}}</div>
              {{#if this.imageUrl}}<img class="bulletin-record-image" src="{{this.imageUrl}}" alt="{{this.title}}">{{/if}}
              <p class="holonet-rendered-text">{{{this.renderedBodyPreview}}}</p>
              <div class="bulletin-record-footer">
                <span>{{this.createdAt}}</span>
                <div class="bulletin-record-actions">
                  <button type="button" class="swse-ui-button" data-action="bulletin-edit" data-section="events" data-record-id="{{this.id}}">Edit</button>
                  {{#unless (eq this.state "published")}}<button type="button" class="swse-ui-button" data-action="bulletin-publish" data-record-id="{{this.id}}">Publish</button>{{/unless}}
                  {{#if this.isPinned}}<button type="button" class="swse-ui-button" data-action="bulletin-unpin-last-session" data-record-id="{{this.id}}">Unpin</button>{{else}}<button type="button" class="swse-ui-button" data-action="bulletin-pin-last-session" data-record-id="{{this.id}}">Pin Last Session</button>{{/if}}
                  {{#unless (eq this.state "archived")}}<button type="button" class="swse-ui-button" data-action="bulletin-archive" data-record-id="{{this.id}}">Archive</button>{{/unless}}
                  <button type="button" class="swse-ui-button" data-action="bulletin-delete" data-record-id="{{this.id}}">Delete</button>
                </div>
              </div>
            </article>
            {{else}}
            <p class="placeholder">No bulletin events yet.</p>
            {{/each}}
          </div>

          {{else if (eq bulletinSection "holonews")}}
          <div class="bulletin-panel-header holonews-panel-header">
            <div>
              <h3>HoloNews Desk</h3>
              <p>Publish ordinary galactic background noise, or author a red Breaking News alert when the party truly changes the public story.</p>
            </div>
            <div class="holonews-wire-count"><strong>{{holonewsSeedCount}}</strong><span>ambient wire stories</span></div>
          </div>

          <form class="bulletin-composer holonews-composer" data-bulletin-form="holonews">
            <input type="hidden" name="recordId" value="{{holonewsEditorRecord.id}}">
            <input type="hidden" name="submitMode" value="draft">
            <input type="hidden" name="category" value="holonews">
            <div class="bulletin-form-grid">
              <label>
                <span>HoloNews Headline</span>
                <input type="text" name="title" value="{{holonewsEditorRecord.title}}" placeholder="Local Port Authority Updates Docking Procedures">
              </label>
              <label>
                <span>News Source</span>
                <input type="text" name="authorName" value="{{holonewsEditorRecord.newsSource}}" placeholder="Galaxy News Net">
              </label>
              <label>
                <span>Dateline</span>
                <input type="text" name="dateline" value="{{holonewsEditorRecord.dateline}}" placeholder="Coruscant">
              </label>
              <label>
                <span>Sector / Region</span>
                <input type="text" name="sector" value="{{holonewsEditorRecord.sector}}" placeholder="Core Worlds">
              </label>
              <label>
                <span>News Topic</span>
                <select name="newsCategory">
                  <option value="general" {{#if (or (not holonewsEditorRecord.newsCategory) (eq holonewsEditorRecord.newsCategory "general"))}}selected{{/if}}>General</option>
                  {{#each holonewsCategories}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsEditorRecord.newsCategory this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Priority</span>
                <select name="priority">
                  <option value="low" {{#if (eq holonewsEditorRecord.priority "low")}}selected{{/if}}>Low</option>
                  <option value="normal" {{#if (or (not holonewsEditorRecord.priority) (eq holonewsEditorRecord.priority "normal"))}}selected{{/if}}>Normal</option>
                  <option value="high" {{#if (eq holonewsEditorRecord.priority "high")}}selected{{/if}}>High</option>
                  <option value="critical" {{#if (eq holonewsEditorRecord.priority "critical")}}selected{{/if}}>Critical</option>
                </select>
              </label>
              <label class="bulletin-image-field">
                <span>News Holostill / Feed Image</span>
                <span class="bulletin-image-row">
                  <input type="text" name="imageUrl" value="{{holonewsEditorRecord.imageUrl}}" placeholder="systems/foundryvtt-swse/assets/.../news.webp" data-bulletin-image-input>
                  <button type="button" class="swse-ui-button" data-action="bulletin-pick-image">Browse</button>
                </span>
              </label>
            </div>

            <div class="bulletin-form-grid bulletin-form-grid-audience">
              <label>
                <span>Audience</span>
                <select name="audienceType">
                  {{#each audienceOptions}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsEditorRecord.audienceType this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <div class="bulletin-recipient-picker">
                <span>Recipients</span>
                <div class="bulletin-recipient-list">
                  {{#each bulletinPlayers}}
                  <label class="bulletin-recipient-chip">
                    <input type="checkbox" name="playerIds" value="{{this.userId}}" {{#if (contains ../holonewsEditorRecord.audiencePlayerIds this.userId)}}checked{{/if}}>
                    <span>{{this.actorName}}</span>
                  </label>
                  {{/each}}
                </div>
              </div>
            </div>

            <div class="bulletin-console-controls holonews-console-controls">
              <label class="bulletin-toggle-chip holonews-breaking-toggle">
                <input type="checkbox" name="breakingNews" {{#if holonewsEditorRecord.isBreakingNews}}checked{{/if}}>
                <span>Breaking News red alert</span>
              </label>
              <label class="bulletin-toggle-chip">
                <input type="checkbox" name="pinAsLastSession" {{#if holonewsEditorRecord.isPinned}}checked{{/if}}>
                <span>Pin as Last Session</span>
              </label>
              <label class="bulletin-slot-select">
                <span>Home Placement</span>
                <select name="homeSlot">
                  <option value="feed" {{#if (or (not holonewsEditorRecord.homeSlot) (eq holonewsEditorRecord.homeSlot "feed"))}}selected{{/if}}>Comm Feed</option>
                  <option value="last-session" {{#if (eq holonewsEditorRecord.homeSlot "last-session")}}selected{{/if}}>Last Session</option>
                </select>
              </label>
            </div>

            <label class="bulletin-body-field">
              <span>News Deck / One-line Summary</span>
              <input type="text" name="deck" value="{{holonewsEditorRecord.newsDeck}}" placeholder="A short summary shown to the GM while writing.">
            </label>

            <label class="bulletin-body-field">
              <span>Story Body</span>
              <textarea name="body" rows="6" placeholder="Galaxy News Net reports that local port officials have revised docking procedures after routine inspections." data-holonet-editor="holonews-event">{{holonewsEditorRecord.body}}</textarea>
            </label>

            <div class="bulletin-form-actions">
              <button type="submit" class="swse-ui-button" data-submit-mode="draft">Save HoloNews Draft</button>
              <button type="submit" class="swse-ui-button bulletin-primary-action" data-submit-mode="publish">Publish HoloNews</button>
            </div>
          </form>

          <section class="holonews-wire-panel">
            <div class="holonews-wire-header">
              <div>
                <h4>Ambient Wire</h4>
                <p>Search the atomized, deliberately boring background wire. It combines planet, system, source, lead, and detail atoms into ordinary filler news, not galaxy-shaking events.</p>
              </div>
              <div class="holonews-wire-stats">
                <span><strong>{{holonewsWireFilteredCount}}</strong> matching</span>
                <span><strong>{{holonewsUsedSeedCount}}</strong> already used</span>
              </div>
              <div class="holonews-atom-stats" aria-label="HoloNews atom pool summary">
                {{#each holonewsAtomStats}}
                <span><strong>{{this.value}}</strong> {{this.label}}</span>
                {{/each}}
              </div>
            </div>

            <form class="holonews-wire-filters" data-holonews-wire-filter-form>
              <label class="holonews-wire-search">
                <span>Search Wire</span>
                <input type="search" name="query" value="{{holonewsWireFilters.query}}" placeholder="port, weather, planet atom, system, agriculture...">
              </label>
              <label>
                <span>Topic</span>
                <select name="category">
                  <option value="" {{#unless holonewsWireFilters.category}}selected{{/unless}}>All topics</option>
                  {{#each holonewsCategories}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsWireFilters.category this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Sector</span>
                <select name="sector">
                  <option value="" {{#unless holonewsWireFilters.sector}}selected{{/unless}}>All sectors</option>
                  {{#each holonewsSectors}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsWireFilters.sector this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Priority</span>
                <select name="priority">
                  <option value="" {{#unless holonewsWireFilters.priority}}selected{{/unless}}>Any priority</option>
                  {{#each holonewsPriorities}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsWireFilters.priority this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label class="bulletin-toggle-chip holonews-hide-used">
                <input type="checkbox" name="hideUsedSeeds" {{#if holonewsHideUsedSeeds}}checked{{/if}}>
                <span>Hide used wire stories</span>
              </label>
              <div class="holonews-wire-filter-actions">
                <button type="submit" class="swse-ui-button">Apply Filters</button>
                <button type="button" class="swse-ui-button" data-action="holonews-reset-wire-filters">Reset</button>
              </div>
            </form>

            <div class="holonews-wire-pager">
              <button type="button" class="swse-ui-button" data-action="holonews-wire-prev">Previous 12</button>
              <button type="button" class="swse-ui-button" data-action="holonews-shuffle-wire" data-filtered-count="{{holonewsWireFilteredCount}}">Random Page</button>
              <button type="button" class="swse-ui-button" data-action="holonews-wire-next">Next 12</button>
            </div>

            <div class="holonews-seed-grid">
              {{#each holonewsSeeds}}
              <article class="holonews-seed-card {{#if this.alreadyUsed}}already-used{{/if}}">
                <div class="holonews-seed-meta">
                  <span>{{this.source}}</span>
                  <span>{{this.dateline}}</span>
                  <span>{{this.sector}}</span>
                  <span>{{this.category}}</span>
                  <span>{{this.priority}}</span>
                  {{#if this.alreadyUsed}}<span class="used">USED</span>{{/if}}
                </div>
                <h5>{{this.headline}}</h5>
                <p>{{this.deck}}</p>
                <details class="holonews-seed-details">
                  <summary>Read wire copy</summary>
                  <div class="holonews-seed-body">{{{this.bodyPreview}}}</div>
                </details>
                <div class="holonews-seed-actions">
                  <button type="button" class="swse-ui-button" data-action="holonews-use-draft" data-seed-id="{{this.id}}">Use as Draft</button>
                  <button type="button" class="swse-ui-button" data-action="holonews-publish-ambient" data-seed-id="{{this.id}}">Publish Ambient</button>
                </div>
              </article>
              {{else}}
              <p class="placeholder">No ambient wire stories match those filters.</p>
              {{/each}}
            </div>
          </section>

          <section class="holonews-archive-panel">
            <div class="holonews-wire-header">
              <div>
                <h4>HoloNews Archive</h4>
                <p>Review authored, ambient, breaking, draft, live, and archived stories without mixing them into the ambient seed pool.</p>
              </div>
              <div class="holonews-wire-stats">
                <span><strong>{{holonewsArchiveFilteredCount}}</strong> shown</span>
                <span><strong>{{holonewsArchiveTotalCount}}</strong> total</span>
              </div>
            </div>

            <div class="holonews-archive-stats">
              {{#each holonewsArchiveStats}}
              <div class="holonews-archive-stat {{this.tone}}">
                <strong>{{this.value}}</strong>
                <span>{{this.label}}</span>
              </div>
              {{/each}}
            </div>

            <form class="holonews-archive-filters" data-holonews-archive-filter-form>
              <label class="holonews-archive-search">
                <span>Search Archive</span>
                <input type="search" name="query" value="{{holonewsArchiveFilters.query}}" placeholder="headline, source, sector, seed id...">
              </label>
              <label>
                <span>State</span>
                <select name="state">
                  {{#each holonewsArchiveStateOptions}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsArchiveFilters.state this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Type</span>
                <select name="type">
                  {{#each holonewsArchiveTypeOptions}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsArchiveFilters.type this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Priority</span>
                <select name="priority">
                  <option value="" {{#unless holonewsArchiveFilters.priority}}selected{{/unless}}>Any priority</option>
                  {{#each holonewsPriorities}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsArchiveFilters.priority this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Sector</span>
                <select name="sector">
                  <option value="" {{#unless holonewsArchiveFilters.sector}}selected{{/unless}}>All sectors</option>
                  {{#each holonewsSectors}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsArchiveFilters.sector this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Topic</span>
                <select name="category">
                  <option value="" {{#unless holonewsArchiveFilters.category}}selected{{/unless}}>All topics</option>
                  {{#each holonewsCategories}}
                  <option value="{{this.value}}" {{#if (eq ../holonewsArchiveFilters.category this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <div class="holonews-wire-filter-actions holonews-archive-filter-actions">
                <button type="submit" class="swse-ui-button">Apply Archive Filters</button>
                <button type="button" class="swse-ui-button" data-action="holonews-reset-archive-filters">Reset</button>
              </div>
            </form>
          </section>

          <div class="bulletin-record-grid holonews-record-grid">
            {{#each holonewsRecords}}
            <article class="bulletin-record-card holonews {{this.state}} {{this.recordTone}}">
              <div class="bulletin-record-meta">
                <span class="bulletin-chip state">{{this.stateLabel}}</span>
                <span class="bulletin-chip category">HoloNews</span>
                <span class="bulletin-chip type">{{this.holonewsTypeLabel}}</span>
                {{#if this.newsCategory}}<span class="bulletin-chip category">{{this.newsCategory}}</span>{{/if}}
                <span class="bulletin-chip priority">{{this.priority}}</span>
                <span class="bulletin-chip audience">{{this.audienceLabel}}</span>
                {{#if this.isBreakingNews}}<span class="bulletin-chip breaking">BREAKING</span>{{/if}}
                {{#if this.isPinned}}<span class="bulletin-chip pinned">PINNED</span>{{/if}}
              </div>
              <h4>{{this.title}}</h4>
              <div class="bulletin-record-sender">{{this.newsSource}}{{#if this.dateline}} · {{this.dateline}}{{/if}}{{#if this.sector}} · {{this.sector}}{{/if}}</div>
              {{#if this.imageUrl}}<img class="bulletin-record-image" src="{{this.imageUrl}}" alt="{{this.title}}">{{/if}}
              <p class="holonet-rendered-text">{{{this.renderedBodyPreview}}}</p>
              <div class="holonews-record-details">
                {{#if this.holonewsSeedId}}<span>Seed: {{this.holonewsSeedId}}</span>{{/if}}
                {{#if this.publishedAt}}<span>Published: {{this.publishedAt}}</span>{{/if}}
                {{#if this.archivedAt}}<span>Archived: {{this.archivedAt}}</span>{{/if}}
              </div>
              <div class="bulletin-record-footer">
                <span>{{this.createdAt}}</span>
                <div class="bulletin-record-actions">
                  <button type="button" class="swse-ui-button" data-action="bulletin-edit" data-section="holonews" data-record-id="{{this.id}}">Edit</button>
                  <button type="button" class="swse-ui-button" data-action="holonews-duplicate-draft" data-record-id="{{this.id}}">Duplicate Draft</button>
                  {{#if this.isBreakingNews}}
                    <button type="button" class="swse-ui-button" data-action="holonews-toggle-breaking" data-enabled="false" data-record-id="{{this.id}}">Remove Breaking</button>
                  {{else}}
                    <button type="button" class="swse-ui-button" data-action="holonews-toggle-breaking" data-enabled="true" data-record-id="{{this.id}}">Make Breaking</button>
                  {{/if}}
                  {{#unless (eq this.state "published")}}<button type="button" class="swse-ui-button" data-action="bulletin-publish" data-record-id="{{this.id}}">Publish</button>{{/unless}}
                  {{#if this.isPinned}}<button type="button" class="swse-ui-button" data-action="bulletin-unpin-last-session" data-record-id="{{this.id}}">Unpin</button>{{else}}<button type="button" class="swse-ui-button" data-action="bulletin-pin-last-session" data-record-id="{{this.id}}">Pin Last Session</button>{{/if}}
                  {{#if (eq this.state "archived")}}<button type="button" class="swse-ui-button" data-action="holonews-restore-draft" data-record-id="{{this.id}}">Restore Draft</button>{{else}}<button type="button" class="swse-ui-button" data-action="bulletin-archive" data-record-id="{{this.id}}">Archive</button>{{/if}}
                  <button type="button" class="swse-ui-button" data-action="bulletin-delete" data-record-id="{{this.id}}">Delete</button>
                </div>
              </div>
            </article>
            {{else}}
            <p class="placeholder">No HoloNews entries match those archive filters.</p>
            {{/each}}
          </div>

          {{else if (eq bulletinSection "messages")}}
          <div class="bulletin-panel-header">
            <div>
              <h3>Manage Notices</h3>
              <p>Author one-way GM-to-player notices. Use Messenger for conversations and replies.</p>
            </div>
          </div>

          <form class="bulletin-composer" data-bulletin-form="messages">
            <input type="hidden" name="recordId" value="{{messageEditorRecord.id}}">
            <input type="hidden" name="submitMode" value="draft">
            <div class="bulletin-form-grid">
              <label>
                <span>Subject</span>
                <input type="text" name="title" value="{{messageEditorRecord.title}}" placeholder="@Master Tholos has posted new instructions">
              </label>
              <label>
                <span>Category</span>
                <input type="text" name="category" value="{{messageEditorRecord.category}}" placeholder="mentor / npc / reward / warning">
              </label>
              <label>
                <span>Sender Label</span>
                <input type="text" name="authorName" value="{{messageEditorRecord.senderName}}" placeholder="Rendarr / Master Tholos / GM">
              </label>
              <label>
                <span>Priority</span>
                <select name="priority">
                  <option value="low" {{#if (eq messageEditorRecord.priority "low")}}selected{{/if}}>Low</option>
                  <option value="normal" {{#if (or (not messageEditorRecord.priority) (eq messageEditorRecord.priority "normal"))}}selected{{/if}}>Normal</option>
                  <option value="high" {{#if (eq messageEditorRecord.priority "high")}}selected{{/if}}>High</option>
                  <option value="critical" {{#if (eq messageEditorRecord.priority "critical")}}selected{{/if}}>Critical</option>
                </select>
              </label>
              <label class="bulletin-image-field">
                <span>Notice Image / Sender Portrait</span>
                <span class="bulletin-image-row">
                  <input type="text" name="imageUrl" value="{{messageEditorRecord.imageUrl}}" placeholder="icons/svg/mystery-man.svg" data-bulletin-image-input>
                  <button type="button" class="swse-ui-button" data-action="bulletin-pick-image">Browse</button>
                </span>
              </label>
            </div>

            <div class="bulletin-form-grid bulletin-form-grid-audience">
              <label>
                <span>Recipients</span>
                <select name="audienceType">
                  {{#each audienceOptions}}
                  <option value="{{this.value}}" {{#if (eq ../messageEditorRecord.audienceType this.value)}}selected{{/if}}>{{this.label}}</option>
                  {{/each}}
                </select>
              </label>
              <div class="bulletin-recipient-picker">
                <span>Recipient Players</span>
                <div class="bulletin-recipient-list">
                  {{#each bulletinPlayers}}
                  <label class="bulletin-recipient-chip">
                    <input type="checkbox" name="playerIds" value="{{this.userId}}" {{#if (contains ../messageEditorRecord.audiencePlayerIds this.userId)}}checked{{/if}}>
                    <span>{{this.actorName}}</span>
                  </label>
                  {{/each}}
                </div>
              </div>
            </div>

            <div class="bulletin-console-controls">
              <label class="bulletin-toggle-chip">
                <input type="checkbox" name="urgent" {{#if messageEditorRecord.isUrgent}}checked{{/if}}>
                <span>Urgent home alert</span>
              </label>
              <label class="bulletin-toggle-chip">
                <input type="checkbox" name="pinAsLastSession" {{#if messageEditorRecord.isPinned}}checked{{/if}}>
                <span>Pin as Last Session</span>
              </label>
              <label class="bulletin-slot-select">
                <span>Home Placement</span>
                <select name="homeSlot">
                  <option value="feed" {{#if (or (not messageEditorRecord.homeSlot) (eq messageEditorRecord.homeSlot "feed"))}}selected{{/if}}>Comm Feed</option>
                  <option value="last-session" {{#if (eq messageEditorRecord.homeSlot "last-session")}}selected{{/if}}>Last Session</option>
                </select>
              </label>
            </div>

            <label class="bulletin-body-field">
              <span>Body</span>
              <textarea name="body" rows="6" placeholder="@Kael Vorren, your stipend has arrived. Report to @Rendarr for the next #shipment." data-holonet-editor="bulletin-notice">{{messageEditorRecord.body}}</textarea>
            </label>

            <div class="bulletin-syntax-guide">
              {{#each syntaxGuide}}<span>{{this}}</span>{{/each}}
            </div>

            <div class="bulletin-form-actions">
              <button type="submit" class="swse-ui-button" data-submit-mode="draft">Save Draft</button>
              <button type="submit" class="swse-ui-button bulletin-primary-action" data-submit-mode="publish">Publish Notice</button>
            </div>
          </form>

          <div class="bulletin-record-grid">
            {{#each messageRecords}}
            <article class="bulletin-record-card message {{this.state}} {{this.recordTone}}">
              <div class="bulletin-record-meta">
                <span class="bulletin-chip state">{{this.stateLabel}}</span>
                <span class="bulletin-chip category">{{this.category}}</span>
                <span class="bulletin-chip priority">{{this.priority}}</span>
                <span class="bulletin-chip audience">{{this.audienceLabel}}</span>
                <span class="bulletin-chip home-slot">{{this.homeSlotLabel}}</span>
                {{#if this.isBreakingNews}}<span class="bulletin-chip breaking">BREAKING</span>{{else if this.isUrgent}}<span class="bulletin-chip urgent">ALERT</span>{{/if}}
                {{#if this.isPinned}}<span class="bulletin-chip pinned">PINNED</span>{{/if}}
              </div>
              <h4>{{this.title}}</h4>
              <div class="bulletin-record-sender">From {{this.senderName}}</div>
              {{#if this.imageUrl}}<img class="bulletin-record-image" src="{{this.imageUrl}}" alt="{{this.title}}">{{/if}}
              <p class="holonet-rendered-text">{{{this.renderedBodyPreview}}}</p>
              <div class="bulletin-record-footer">
                <span>{{this.createdAt}}</span>
                <div class="bulletin-record-actions">
                  <button type="button" class="swse-ui-button" data-action="bulletin-edit" data-section="messages" data-record-id="{{this.id}}">Edit</button>
                  {{#unless (eq this.state "published")}}<button type="button" class="swse-ui-button" data-action="bulletin-publish" data-record-id="{{this.id}}">Publish</button>{{/unless}}
                  {{#if this.isPinned}}<button type="button" class="swse-ui-button" data-action="bulletin-unpin-last-session" data-record-id="{{this.id}}">Unpin</button>{{else}}<button type="button" class="swse-ui-button" data-action="bulletin-pin-last-session" data-record-id="{{this.id}}">Pin Last Session</button>{{/if}}
                  {{#unless (eq this.state "archived")}}<button type="button" class="swse-ui-button" data-action="bulletin-archive" data-record-id="{{this.id}}">Archive</button>{{/unless}}
                  <button type="button" class="swse-ui-button" data-action="bulletin-delete" data-record-id="{{this.id}}">Delete</button>
                </div>
              </div>
            </article>
            {{else}}
            <p class="placeholder">No bulletin notices yet.</p>
            {{/each}}
          </div>

          {{else if (eq bulletinSection "players")}}
          <div class="bulletin-panel-header">
            <div>
              <h3>Manage Players</h3>
              <p>Set current location, objective, and situation for individual player datapads.</p>
            </div>
          </div>
          <div class="bulletin-state-layout">
            <aside class="bulletin-player-list">
              {{#each bulletinPlayers}}
              <button class="bulletin-player-card {{#if (eq ../selectedPlayerId this.actorId)}}is-active{{/if}}" type="button" data-select-player-state="{{this.actorId}}">
                <strong>{{this.actorName}}</strong>
                <span>{{this.userName}}</span>
              </button>
              {{/each}}
            </aside>
            <form class="bulletin-state-editor" data-player-state-form>
              <input type="hidden" name="actorId" value="{{selectedPlayerId}}">
              <label>
                <span>Current Location</span>
                <input type="text" name="location" value="{{selectedPlayerState.location}}" placeholder="Wayfarer-class freighter">
              </label>
              <label>
                <span>Current Objective</span>
                <input type="text" name="objective" value="{{selectedPlayerState.objective}}" placeholder="Meet @Rendarr and confirm the shipment route">
              </label>
              <label>
                <span>Current Situation</span>
                <textarea name="situation" rows="6" placeholder="Currently onboard Wayfarer-class freighter. Last contact: Mid-Rim." data-holonet-editor="player-state">{{selectedPlayerState.situation}}</textarea>
              </label>
              <div class="bulletin-form-actions">
                <button type="submit" class="swse-ui-button bulletin-primary-action">Save Player State</button>
              </div>
            </form>
          </div>

          {{else if (eq bulletinSection "party")}}
          <div class="bulletin-panel-header">
            <div>
              <h3>Manage Party</h3>
              <p>Set party-wide opening state for the player Home experience.</p>
            </div>
          </div>
          <form class="bulletin-state-editor" data-party-state-form>
            <label>
              <span>Party Location</span>
              <input type="text" name="location" value="{{partyState.location}}" placeholder="Docking Ring Aurek">
            </label>
            <label>
              <span>Party Objective</span>
              <input type="text" name="objective" value="{{partyState.objective}}" placeholder="Secure the spice shipment and avoid Imperial customs">
            </label>
            <label>
              <span>Party Situation</span>
              <textarea name="situation" rows="6" placeholder="The party is starting aboard the freighter with Imperial patrols nearby." data-holonet-editor="party-state">{{partyState.situation}}</textarea>
            </label>
            <div class="bulletin-form-actions">
              <button type="submit" class="swse-ui-button bulletin-primary-action">Save Party State</button>
            </div>
          </form>
          {{/if}}
        </section>

        <aside class="bulletin-home-preview swse-ui-panel" aria-label="Player home preview" data-bulletin-live-preview>
          <div class="bulletin-preview-header">
            <span class="bulletin-preview-kicker">Player Home Preview</span>
            <strong>Datapad Feed Projection</strong>
          </div>

          <div class="bulletin-preview-card bulletin-preview-card--state">
            <span class="bulletin-preview-label">Current State</span>
            <strong data-preview-state-location>{{homePreview.state.location}}</strong>
            <p data-preview-state-objective>{{homePreview.state.objective}}</p>
            <div class="bulletin-preview-status" data-preview-state-situation>{{homePreview.state.situation}}</div>
          </div>

          <div class="bulletin-preview-card bulletin-preview-card--feed">
            <span class="bulletin-preview-label">Comm Feed</span>
            {{#if homePreview.feed}}
            <div class="bulletin-preview-meta">
              <span data-preview-feed-category>{{homePreview.feed.category}}</span>
              <span data-preview-feed-priority>{{homePreview.feed.priority}}</span>
              <span class="urgent {{#if homePreview.feed.isBreakingNews}}breaking{{/if}} {{#unless homePreview.feed.isUrgent}}is-hidden{{/unless}}" data-preview-feed-urgent>{{#if homePreview.feed.isBreakingNews}}BREAKING NEWS{{else}}Alert{{/if}}</span>
            </div>
            {{#if homePreview.feed.imageUrl}}<img class="bulletin-preview-image" src="{{homePreview.feed.imageUrl}}" alt="{{homePreview.feed.title}}" data-preview-feed-image>{{else}}<img class="bulletin-preview-image is-hidden" alt="" data-preview-feed-image>{{/if}}
            <strong data-preview-feed-title>{{homePreview.feed.title}}</strong>
            <em data-preview-feed-sender>{{homePreview.feed.sender}} · {{homePreview.feed.audience}}</em>
            <p class="holonet-rendered-text" data-preview-feed-body>{{{homePreview.feed.renderedPreview}}}</p>
            {{else}}
            <p class="placeholder">No bulletin selected. Save or publish a bulletin to preview the feed card.</p>
            {{/if}}
          </div>

          <div class="bulletin-preview-card bulletin-preview-card--session">
            <span class="bulletin-preview-label">Last Session / Featured</span>
            {{#if homePreview.lastSession}}
            {{#if homePreview.lastSession.imageUrl}}<img class="bulletin-preview-image" src="{{homePreview.lastSession.imageUrl}}" alt="{{homePreview.lastSession.title}}">{{/if}}
            <strong>{{homePreview.lastSession.title}}</strong>
            <em>{{homePreview.lastSession.sender}}</em>
            <p class="holonet-rendered-text">{{{homePreview.lastSession.renderedPreview}}}</p>
            {{else}}
            <p class="placeholder">Pin a bulletin as Last Session to control the player home recap card.</p>
            {{/if}}
          </div>
        </aside>
      </div>
    </div>

    {{!-- House Rules Page --}}
    {{else if (eq currentPage "house-rules")}}
    <div class="gm-datapad-page gm-datapad-house-rules swse-house-rules-datapad">
      <div class="page-header">
        <button class="back-button swse-ui-button" data-nav-to="home">← Back</button>
        <h2>{{pageTitle}}</h2>
        <p class="page-subtitle">{{pageDescription}}</p>
      </div>

      <div class="datapad-body">

        {{!-- CHARACTER CREATION --}}
        {{#if rules.characterCreation}}
        <div class="rule-category">
          <div class="rule-category-header">
            <span class="category-icon">⚙</span>
            Character Creation
          </div>

          <div class="rule-list">
            {{#each rules.characterCreation}}
              <div class="rule-entry">
                <div class="rule-info">
                  <div class="rule-name">{{this.name}}</div>
                  <div class="rule-description">{{this.description}}</div>
                </div>

                <div class="rule-toggle">
                  <label class="cyber-switch">
                    <input type="checkbox"
                           data-rule-key="{{this.key}}"
                           data-rule-type="{{this.type}}"
                           {{#if this.enabled}}checked{{/if}}>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{!-- COMBAT --}}
        {{#if rules.combat}}
        <div class="rule-category">
          <div class="rule-category-header">
            <span class="category-icon">⚔</span>
            Combat
          </div>

          <div class="rule-list">
            {{#each rules.combat}}
              <div class="rule-entry">
                <div class="rule-info">
                  <div class="rule-name">{{this.name}}</div>
                  <div class="rule-description">{{this.description}}</div>
                </div>

                <div class="rule-toggle">
                  <label class="cyber-switch">
                    <input type="checkbox"
                           data-rule-key="{{this.key}}"
                           data-rule-type="{{this.type}}"
                           {{#if this.enabled}}checked{{/if}}>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{!-- FORCE --}}
        {{#if rules.force}}
        <div class="rule-category">
          <div class="rule-category-header">
            <span class="category-icon">✦</span>
            Force
          </div>

          <div class="rule-list">
            {{#each rules.force}}
              <div class="rule-entry">
                <div class="rule-info">
                  <div class="rule-name">{{this.name}}</div>
                  <div class="rule-description">{{this.description}}</div>
                </div>

                <div class="rule-toggle">
                  <label class="cyber-switch">
                    <input type="checkbox"
                           data-rule-key="{{this.key}}"
                           data-rule-type="{{this.type}}"
                           {{#if this.enabled}}checked{{/if}}>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{!-- RECOVERY & CONDITIONS --}}
        {{#if rules.recovery}}
        <div class="rule-category">
          <div class="rule-category-header">
            <span class="category-icon">❤</span>
            Recovery & Conditions
          </div>

          <div class="rule-list">
            {{#each rules.recovery}}
              <div class="rule-entry">
                <div class="rule-info">
                  <div class="rule-name">{{this.name}}</div>
                  <div class="rule-description">{{this.description}}</div>
                </div>

                <div class="rule-toggle">
                  <label class="cyber-switch">
                    <input type="checkbox"
                           data-rule-key="{{this.key}}"
                           data-rule-type="{{this.type}}"
                           {{#if this.enabled}}checked{{/if}}>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{!-- SKILLS & TALENTS --}}
        {{#if rules.skills}}
        <div class="rule-category">
          <div class="rule-category-header">
            <span class="category-icon">📚</span>
            Skills & Talents
          </div>

          <div class="rule-list">
            {{#each rules.skills}}
              <div class="rule-entry">
                <div class="rule-info">
                  <div class="rule-name">{{this.name}}</div>
                  <div class="rule-description">{{this.description}}</div>
                </div>

                <div class="rule-toggle">
                  <label class="cyber-switch">
                    <input type="checkbox"
                           data-rule-key="{{this.key}}"
                           data-rule-type="{{this.type}}"
                           {{#if this.enabled}}checked{{/if}}>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
        {{/if}}

        {{!-- VEHICLES & SPACE --}}
        {{#if rules.vehicles}}
        <div class="rule-category">
          <div class="rule-category-header">
            <span class="category-icon">🚀</span>
            Vehicles & Space Combat
          </div>

          <div class="rule-list">
            {{#each rules.vehicles}}
              <div class="rule-entry">
                <div class="rule-info">
                  <div class="rule-name">{{this.name}}</div>
                  <div class="rule-description">{{this.description}}</div>
                </div>

                <div class="rule-toggle">
                  <label class="cyber-switch">
                    <input type="checkbox"
                           data-rule-key="{{this.key}}"
                           data-rule-type="{{this.type}}"
                           {{#if this.enabled}}checked{{/if}}>
                    <span class="slider"></span>
                  </label>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
        {{/if}}

      </div>

      {{!-- FOOTER STATUS --}}
      <div class="datapad-footer">
        <div class="status-line">
          <span class="status-label">SYSTEM INTEGRITY:</span>
          <span class="status-value">100%</span>
        </div>
        <div class="status-line">
          <span class="status-label">ACTIVE OVERRIDES:</span>
          <span class="status-value">{{activeRuleCount}}</span>
        </div>
      </div>
    </div>

    {{!-- Store Page --}}
    {{else if (eq currentPage "store")}}
    <div class="gm-datapad-page gm-datapad-store gm-store-control-console swse-store-ui swse-ui-shell swse-store-shell flexcol">
      <div class="page-header gm-app-header gm-store-header">
        <button class="back-button swse-ui-button" data-nav-to="home">← Back</button>
        <div class="gm-app-header-copy">
          <span class="gm-command-eyebrow">COMMERCE COMMAND</span>
          <h2>{{pageTitle}}</h2>
          <p class="page-subtitle">{{pageDescription}}</p>
        </div>
        <div class="gm-store-status-strip" aria-label="Store command status">
          <span class="{{#if storeOpen}}online{{else}}offline{{/if}}"><strong>{{#if storeOpen}}OPEN{{else}}CLOSED{{/if}}</strong>Store</span>
          <span><strong>{{transactions.length}}</strong>Transactions</span>
          <span><strong>{{storeApprovalCounts.total}}</strong>Approvals</span>
          <span><strong>{{inventoryStats.total}}</strong>Inventory</span>
        </div>
      </div>

      <nav class="gm-store-tabs swse-ui-tabs swse-ui-frame" aria-label="Store control tabs">
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'options')}}active{{/if}}" data-store-tab="options" aria-selected="{{#if (eq currentTab 'options')}}true{{else}}false{{/if}}">Store Options</button>
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'transactions')}}active{{/if}}" data-store-tab="transactions" aria-selected="{{#if (eq currentTab 'transactions')}}true{{else}}false{{/if}}">Transactions</button>
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'approvals')}}active{{/if}}" data-store-tab="approvals" aria-selected="{{#if (eq currentTab 'approvals')}}true{{else}}false{{/if}}">Approvals</button>
        <button type="button" class="tab-button swse-ui-tab {{#if (eq currentTab 'inventory')}}active{{/if}}" data-store-tab="inventory" aria-selected="{{#if (eq currentTab 'inventory')}}true{{else}}false{{/if}}">Inventory</button>
      </nav>

      <div class="gm-store-tab-content swse-ui-panel">

        {{!-- TAB 1: STORE OPTIONS --}}
        <section class="gm-store-tab-panel {{#if (eq currentTab 'options')}}active{{/if}}" data-store-tab-panel="options" {{#unless (eq currentTab 'options')}}hidden{{/unless}}>
          <div class="gm-store-section-heading">
            <div>
              <span class="gm-command-eyebrow">STORE OPTIONS</span>
              <h3>Market Policy</h3>
              <p>Set the current shop posture, price environment, availability gates, and sale rules.</p>
            </div>
          </div>

          <div class="gm-store-options-grid">
            <article class="gm-command-card gm-store-option-card">
              <header>
                <i class="fa-solid fa-power-off"></i>
                <div>
                  <h4>Store Status</h4>
                  <p>Controls whether players can buy from the store.</p>
                </div>
              </header>
              <label class="gm-store-toggle-row">
                <input type="checkbox" name="storeOpen" {{#if storeOpen}}checked{{/if}}>
                <span>Store Open</span>
              </label>
              {{#unless storeOpen}}
                <p class="gm-store-warning">Purchases are closed. GM controls remain available.</p>
              {{/unless}}
            </article>

            <article class="gm-command-card gm-store-option-card">
              <header>
                <i class="fa-solid fa-tags"></i>
                <div>
                  <h4>Pricing</h4>
                  <p>Markup and discount feed the v2 pricing engine.</p>
                </div>
              </header>
              <label class="gm-store-slider-row">
                <span>Markup</span>
                <input type="range" name="storeMarkup" min="0" max="200" step="5" value="{{storeMarkup}}">
                <strong data-store-markup-value>{{storeMarkup}}%</strong>
              </label>
              <label class="gm-store-slider-row">
                <span>Discount</span>
                <input type="range" name="storeDiscount" min="0" max="90" step="5" value="{{storeDiscount}}">
                <strong data-store-discount-value>{{storeDiscount}}%</strong>
              </label>
              <p class="gm-store-note">Legacy buy modifier is mirrored from markup for older store surfaces.</p>
            </article>

            <article class="gm-command-card gm-store-option-card">
              <header>
                <i class="fa-solid fa-key"></i>
                <div>
                  <h4>Availability Gates</h4>
                  <p>Global visibility by normalized store availability.</p>
                </div>
              </header>
              <div class="gm-store-check-grid">
                <label><input type="checkbox" name="availability-standard" {{#if visibleRarities.standard}}checked{{/if}}> Standard</label>
                <label><input type="checkbox" name="availability-licensed" {{#if visibleRarities.licensed}}checked{{/if}}> Licensed</label>
                <label><input type="checkbox" name="availability-rare" {{#if visibleRarities.rare}}checked{{/if}}> Rare</label>
                <label><input type="checkbox" name="availability-restricted" {{#if visibleRarities.restricted}}checked{{/if}}> Restricted</label>
                <label><input type="checkbox" name="availability-military" {{#if visibleRarities.military}}checked{{/if}}> Military</label>
                <label><input type="checkbox" name="availability-illegal" {{#if visibleRarities.illegal}}checked{{/if}}> Illegal</label>
              </div>
            </article>

            <article class="gm-command-card gm-store-option-card">
              <header>
                <i class="fa-solid fa-boxes-stacked"></i>
                <div>
                  <h4>Category Access</h4>
                  <p>Show or hide major inventory departments globally.</p>
                </div>
              </header>
              <div class="gm-store-check-grid">
                <label><input type="checkbox" name="type-weapons" {{#if visibleTypes.weapons}}checked{{/if}}> Weapons</label>
                <label><input type="checkbox" name="type-armor" {{#if visibleTypes.armor}}checked{{/if}}> Armor</label>
                <label><input type="checkbox" name="type-gear" {{#if visibleTypes.gear}}checked{{/if}}> Gear</label>
                <label><input type="checkbox" name="type-droids" {{#if visibleTypes.droids}}checked{{/if}}> Droids</label>
                <label><input type="checkbox" name="type-vehicles" {{#if visibleTypes.vehicles}}checked{{/if}}> Vehicles</label>
              </div>
            </article>

            <article class="gm-command-card gm-store-option-card gm-store-option-card--wide">
              <header>
                <i class="fa-solid fa-hand-holding-credit-card"></i>
                <div>
                  <h4>Selling Rules</h4>
                  <p>Controls player sale requests and automatic resale valuation.</p>
                </div>
              </header>
              <div class="gm-store-selling-grid">
                <label class="gm-store-toggle-row">
                  <input type="checkbox" name="autoAcceptSelling" {{#if autoAcceptSelling}}checked{{/if}}>
                  <span>Automatically accept item sales</span>
                </label>
                <label class="gm-store-slider-row {{#unless autoAcceptSelling}}disabled{{/unless}}">
                  <span>Automatic Sale Value</span>
                  <input type="range" name="autoSalePercent" min="10" max="100" step="5" value="{{autoSalePercent}}" {{#unless autoAcceptSelling}}disabled{{/unless}}>
                  <strong data-auto-sale-value>{{autoSalePercent}}%</strong>
                </label>
                <label class="gm-store-toggle-row">
                  <input type="checkbox" name="disallowAutoSellNoPrice" {{#if disallowAutoSellNoPrice}}checked{{/if}}>
                  <span>Disallow auto-selling items with no base price</span>
                </label>
              </div>
            </article>
          </div>
        </section>

        {{!-- TAB 2: TRANSACTIONS LEDGER --}}
        <section class="gm-store-tab-panel {{#if (eq currentTab 'transactions')}}active{{/if}}" data-store-tab-panel="transactions" {{#unless (eq currentTab 'transactions')}}hidden{{/unless}}>
          <div class="gm-store-section-heading">
            <div>
              <span class="gm-command-eyebrow">TRANSACTIONS</span>
              <h3>Sales History</h3>
              <p>TransactionEngine ledger view: audit who bought what, credit impact, status, rollback state, and GM corrections.</p>
            </div>
            <div class="gm-store-toolbar">
              <select class="swse-ui-input" data-store-transaction-filter="actor">
                <option value="">All actors</option>
                {{#each actors}}
                  <option value="{{this.id}}">{{this.name}}</option>
                {{/each}}
              </select>
              <select class="swse-ui-input" data-store-transaction-filter="status">
                <option value="">All statuses</option>
                <option value="Success">Success</option>
                <option value="Failed">Failed</option>
                <option value="Rolled Back">Rolled Back</option>
                <option value="Pending">Pending</option>
              </select>
            </div>
          </div>

          {{#if transactions.length}}
            <div class="gm-store-table-wrap">
              <table class="gm-store-table transactions-table">
                <thead>
                  <tr>
                    <th>Time</th>
                    <th>Actor</th>
                    <th>Type</th>
                    <th>Item</th>
                    <th>Qty</th>
                    <th>Credit Impact</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th>Reason</th>
                    <th>Source</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each transactions}}
                    <tr data-index="{{@index}}" data-actor-id="{{this.actorId}}" data-status="{{this.status}}">
                      <td>{{#formatDate this.timestamp}}{{/formatDate}}</td>
                      <td>{{this.actor}}</td>
                      <td><span class="type-badge {{lowercase this.type}}">{{this.type}}</span></td>
                      <td>{{this.item}}</td>
                      <td>{{this.quantity}}</td>
                      <td class="amount {{#if (gt this.amount 0)}}positive{{else}}negative{{/if}}">{{#if (gt this.amount 0)}}+{{/if}}{{this.amount}} cr</td>
                      <td class="gm-store-balance-cell">{{this.balanceDisplay}}</td>
                      <td><span class="gm-store-status-chip">{{this.status}}</span></td>
                      <td>{{#if this.reason}}{{this.reason}}{{else}}—{{/if}}</td>
                      <td><span class="source-badge">{{this.source}}</span></td>
                      <td>
                        {{#if this.canRollback}}
                          <button class="action-btn swse-ui-button" data-action="rollback-transaction" data-index="{{@index}}" title="Rollback through TransactionEngine, remove safe owned items, and restore tracked stock.">Rollback</button>
                        {{else}}
                          {{#if this.rolledBackByTransactionId}}
                            <span class="gm-store-muted-action">Rolled back</span>
                          {{else}}
                            <span class="gm-store-muted-action">Ledger only</span>
                          {{/if}}
                        {{/if}}
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{else}}
            <p class="empty-state">No store transactions have been recorded.</p>
          {{/if}}
        </section>

        {{!-- TAB 3: COMMERCE APPROVALS --}}
        <section class="gm-store-tab-panel {{#if (eq currentTab 'approvals')}}active{{/if}}" data-store-tab-panel="approvals" {{#unless (eq currentTab 'approvals')}}hidden{{/unless}}>
          <div class="gm-store-section-heading">
            <div>
              <span class="gm-command-eyebrow">APPROVALS</span>
              <h3>Commerce Requests</h3>
              <p>Sale, haggle, restricted purchase, and custom acquisition requests that touch the store economy.</p>
            </div>
            <div class="gm-store-status-strip gm-store-status-strip--compact">
              <span><strong>{{storeApprovalCounts.pendingSales}}</strong>Sales</span>
              <span><strong>{{storeApprovalCounts.customPurchases}}</strong>Custom Assets</span>
            </div>
          </div>

          <div class="gm-store-approval-grid">
            <article class="gm-command-card">
              <header class="gm-store-card-header">
                <i class="fa-solid fa-scale-balanced"></i>
                <div>
                  <h4>Pending Sales / Haggles</h4>
                  <p>Player sell and negotiation requests belong here.</p>
                </div>
              </header>
              {{#if pendingSales.length}}
                <div class="gm-store-approval-list gm-store-sale-request-list">
                  {{#each pendingSales}}
                    <div class="gm-store-approval-card gm-store-sale-request-card" data-sale-request-id="{{this.id}}">
                      <div class="gm-store-sale-request-main">
                        <div>
                          <span class="gm-command-eyebrow">{{this.type}} REQUEST</span>
                          <strong>{{this.item}}</strong>
                          <span>{{this.actor}} · {{this.submittedDisplay}}</span>
                        </div>
                        <span class="gm-store-status-chip {{#if this.warning}}warn{{/if}}">{{#if this.warning}}Needs Review{{else}}Pending{{/if}}</span>
                      </div>

                      <div class="gm-store-sale-request-grid">
                        <div>
                          <span>Base Price</span>
                          <strong>{{this.basePriceDisplay}}</strong>
                        </div>
                        <div>
                          <span>Suggested Offer</span>
                          <strong>{{this.suggestedPriceDisplay}}</strong>
                        </div>
                        <div>
                          <span>Requested / Default</span>
                          <strong>{{this.requestedPriceDisplay}}</strong>
                        </div>
                      </div>

                      {{#if this.warning}}
                        <p class="gm-store-warning gm-store-sale-warning">{{this.warning}}</p>
                      {{/if}}

                      <div class="gm-store-sale-controls">
                        <label>
                          <span>GM Amount</span>
                          <input type="number" min="0" step="1" class="swse-ui-input" data-sale-custom-amount value="{{#if this.defaultAmount}}{{this.defaultAmount}}{{/if}}" placeholder="Set offer">
                        </label>
                        <label>
                          <span>GM Note / Denial Reason</span>
                          <textarea class="swse-ui-input" data-sale-reason rows="2" placeholder="Optional note for approval; denial reason if denied."></textarea>
                        </label>
                      </div>

                      <div class="gm-store-sale-actions">
                        {{#if this.canApprove}}
                          <button type="button" class="swse-ui-button" data-action="approve-sale-request" data-request-id="{{this.id}}" data-default-amount="{{this.defaultAmount}}">Approve Suggested</button>
                        {{else}}
                          <button type="button" class="swse-ui-button" data-action="approve-sale-request" data-request-id="{{this.id}}">Approve Amount</button>
                        {{/if}}
                        <button type="button" class="swse-ui-button secondary" data-action="counteroffer-sale-request" data-request-id="{{this.id}}">Approve Custom Amount</button>
                        <button type="button" class="swse-ui-button danger" data-action="deny-sale-request" data-request-id="{{this.id}}">Deny</button>
                      </div>
                    </div>
                  {{/each}}
                </div>
              {{else}}
                <p class="gm-store-empty-note">No sale or haggle requests are currently queued.</p>
              {{/if}}
            </article>

            <article class="gm-command-card">
              <header class="gm-store-card-header">
                <i class="fa-solid fa-robot"></i>
                <div>
                  <h4>Custom Droid / Ship Requests</h4>
                  <p>Full review is handled by the GM Approvals app.</p>
                </div>
              </header>
              {{#if pendingApprovals.length}}
                <div class="gm-store-approval-list">
                  {{#each pendingApprovals}}
                    <div class="gm-store-approval-card">
                      <strong>{{this.draftData.name}}</strong>
                      <span>{{this.ownerActorName}} · {{capitalize this.type}}</span>
                      <em>{{this.costCredits}} cr</em>
                    </div>
                  {{/each}}
                </div>
                <button type="button" class="swse-ui-button" data-nav-to="approvals">Open Full Approval Review</button>
              {{else}}
                <p class="gm-store-empty-note">No custom droid or vehicle purchases are queued.</p>
              {{/if}}
            </article>
          </div>
        </section>

        {{!-- TAB 4: INVENTORY --}}
        <section class="gm-store-tab-panel {{#if (eq currentTab 'inventory')}}active{{/if}}" data-store-tab-panel="inventory" {{#unless (eq currentTab 'inventory')}}hidden{{/unless}}>
          <div class="gm-store-section-heading">
            <div>
              <span class="gm-command-eyebrow">INVENTORY</span>
              <h3>Store Inventory Policy</h3>
              <p>Soft-ban, show, hide, quantity-limit, require approval, or override player-facing price per item.</p>
            </div>
            <div class="gm-store-status-strip gm-store-status-strip--compact">
              <span><strong>{{inventoryStats.visible}}</strong>Visible</span>
              <span><strong>{{inventoryStats.available}}</strong>Available</span>
              <span><strong>{{inventoryStats.requiresApproval}}</strong>Approval</span>
              <span><strong>{{inventoryStats.overrides}}</strong>Price Overrides</span>
            </div>
          </div>

          {{#if inventoryLoadError}}
            <p class="gm-store-warning">Inventory index could not be loaded: {{inventoryLoadError}}</p>
          {{else}}
            <div class="gm-store-toolbar gm-store-inventory-toolbar">
              <input type="search" class="swse-ui-input" data-store-inventory-filter="search" placeholder="Search inventory...">
              <select class="swse-ui-input" data-store-inventory-filter="type">
                <option value="">All types</option>
                {{#each typeFilters}}
                  <option value="{{this.id}}">{{this.label}}</option>
                {{/each}}
              </select>
              <select class="swse-ui-input" data-store-inventory-filter="availability">
                <option value="">All availability</option>
                {{#each availabilityFilters}}
                  <option value="{{this.id}}">{{this.label}}</option>
                {{/each}}
              </select>
              <select class="swse-ui-input" data-store-inventory-filter="visibility">
                <option value="">All policies</option>
                <option value="visible">Visible</option>
                <option value="hidden">Hidden</option>
                <option value="available">Available</option>
                <option value="unavailable">Unavailable</option>
                <option value="overridden">Price override</option>
              </select>
            </div>

            <div class="gm-store-table-wrap gm-store-inventory-table-wrap">
              <table class="gm-store-table gm-store-inventory-table">
                <thead>
                  <tr>
                    <th>Show</th>
                    <th>Buy</th>
                    <th>Qty</th>
                    <th>Approval</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Availability</th>
                    <th>Base Cost</th>
                    <th>Final Cost</th>
                    <th>GM Price Override</th>
                    <th>Source</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each inventoryRows}}
                    <tr data-store-inventory-row data-item-id="{{this.id}}" data-search="{{this.searchText}}" data-type="{{this.type}}" data-availability="{{this.availabilityKey}}" data-visible="{{this.visible}}" data-available="{{this.available}}">
                      <td><input type="checkbox" data-store-policy-field="visible" data-item-id="{{this.id}}" {{#if this.visible}}checked{{/if}} title="Show this item to players."></td>
                      <td><input type="checkbox" data-store-policy-field="available" data-item-id="{{this.id}}" {{#if this.available}}checked{{/if}} title="Allow this item to be bought."></td>
                      <td class="gm-store-quantity-cell">
                        <label><input type="checkbox" data-store-policy-field="trackQuantity" data-item-id="{{this.id}}" {{#if this.trackQuantity}}checked{{/if}} title="Track finite stock."> Track</label>
                        <input type="number" min="0" step="1" data-store-policy-field="quantity" data-item-id="{{this.id}}" value="{{this.quantity}}" placeholder="∞" title="Finite quantity available. Empty means unlimited.">
                      </td>
                      <td><input type="checkbox" data-store-policy-field="requiresApproval" data-item-id="{{this.id}}" {{#if this.requiresApproval}}checked{{/if}} title="Require GM approval before purchase."></td>
                      <td><strong>{{this.name}}</strong></td>
                      <td>{{this.typeLabel}}</td>
                      <td>{{this.category}} / {{this.subcategory}}</td>
                      <td><span class="gm-store-status-chip">{{this.availabilityLabel}}</span></td>
                      <td>{{this.baseCostDisplay}}</td>
                      <td>{{this.finalCostDisplay}}</td>
                      <td><input type="number" min="0" step="1" class="gm-store-price-override" data-store-policy-field="overridePrice" data-item-id="{{this.id}}" value="{{this.overridePriceDisplay}}" placeholder="Default" title="Arbitrary GM sale price override. Saved now; player-store enforcement comes in the policy enforcement phase."></td>
                      <td>{{this.source}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{/if}}
        </section>


      </div>
    </div>

    {{!-- Approvals Page --}}
    {{else if (eq currentPage "approvals")}}
    <div class="gm-datapad-page gm-datapad-approvals flexcol">
      <div class="page-header gm-app-header gm-approval-header">
        <button class="back-button swse-ui-button" data-nav-to="home">← Back</button>
        <div class="gm-app-header-copy">
          <span class="gm-command-eyebrow">COMMAND QUEUE</span>
          <h2>{{pageTitle}}</h2>
          <p class="page-subtitle">{{pageDescription}}</p>
        </div>
        <div class="gm-approval-count-strip" aria-label="Approval queue counts">
          <span><strong>{{approvalQueueCounts.total}}</strong>Total</span>
          <span><strong>{{approvalQueueCounts.droids}}</strong>Droids</span>
          <span><strong>{{approvalQueueCounts.ships}}</strong>Ships</span>
        </div>
      </div>

      {{#if hasApprovalRequests}}
      <div class="gm-approval-console">
        <aside class="gm-approval-queue swse-ui-panel" aria-label="Approval request queue">
          <div class="gm-approval-queue-header">
            <div>
              <span class="gm-command-eyebrow">REQUESTS</span>
              <h3>Pending Review</h3>
            </div>
          </div>

          <div class="gm-approval-queue-list">
            {{#each approvalRequests}}
            <button type="button" class="gm-approval-queue-card {{this.tone}} {{#if (eq this.key ../selectedApproval.key)}}is-active{{/if}}" data-action="select-approval" data-approval-key="{{this.key}}">
              <span class="gm-approval-queue-icon"><i class="{{this.icon}}"></i></span>
              <span class="gm-approval-queue-copy">
                <strong>{{this.title}}</strong>
                <em>{{this.subtitle}}</em>
                <small>{{this.typeLabel}}</small>
              </span>
              {{#if this.warnings.length}}<span class="gm-approval-warning-pip">!</span>{{/if}}
            </button>
            {{/each}}
          </div>
        </aside>

        <form class="gm-approval-review-form" data-approval-review-form data-approval-key="{{selectedApproval.key}}">
          <section class="gm-approval-summary-packet swse-ui-panel">
            <div class="gm-approval-packet-header">
              <div>
                <span class="gm-command-eyebrow">{{selectedApproval.typeLabel}}</span>
                <h3>{{selectedApproval.title}}</h3>
                <p>{{selectedApproval.ownerLabel}} · {{selectedApproval.costLabel}} · submitted {{selectedApproval.submittedLabel}}</p>
              </div>
              <span class="gm-approval-mode-chip {{#if approvalEditMode}}edit{{else}}review{{/if}}">
                {{#if approvalEditMode}}Inline Edit Mode{{else}}Read-Only Review{{/if}}
              </span>
            </div>

            <div class="gm-approval-summary-grid">
              {{#each selectedApproval.categories}}
              <article class="gm-approval-summary-card" data-approval-category="{{this.id}}">
                <header>
                  <span class="gm-approval-category-icon"><i class="{{this.icon}}"></i></span>
                  <h4>{{this.label}}</h4>
                </header>

                <div class="gm-approval-field-grid">
                  {{#each this.rows}}
                  <label class="gm-approval-field {{#if this.wide}}is-wide{{/if}} {{#if this.editable}}is-editable{{/if}}" {{#if this.fieldId}}for="{{this.fieldId}}"{{/if}}>
                    <span class="gm-approval-field-label">{{this.label}}</span>
                    {{#if this.editable}}
                      {{#if @root.approvalEditMode}}
                        {{#if (eq this.inputType "textarea")}}
                          <textarea id="{{this.fieldId}}" name="{{this.inputName}}" rows="4" data-approval-edit-field data-label="{{this.label}}" data-original="{{this.originalValue}}" placeholder="{{this.placeholder}}">{{this.value}}</textarea>
                        {{else}}
                          <span class="gm-approval-input-wrap">
                            <input id="{{this.fieldId}}" type="{{this.inputType}}" name="{{this.inputName}}" value="{{this.value}}" data-approval-edit-field data-label="{{this.label}}" data-original="{{this.originalValue}}" placeholder="{{this.placeholder}}">
                            {{#if this.suffix}}<span>{{this.suffix}}</span>{{/if}}
                          </span>
                        {{/if}}
                      {{else}}
                        <strong>{{this.displayValue}}</strong>
                      {{/if}}
                    {{else}}
                      <strong>{{this.value}}</strong>
                    {{/if}}
                  </label>
                  {{/each}}
                </div>
              </article>
              {{/each}}
            </div>
          </section>

          <aside class="gm-approval-detail-rail swse-ui-panel">
            <div class="gm-approval-rail-section gm-approval-rail-identity">
              <span class="gm-approval-large-icon"><i class="{{selectedApproval.icon}}"></i></span>
              <div>
                <span class="gm-command-eyebrow">SELECTED REQUEST</span>
                <h3>{{selectedApproval.title}}</h3>
                <p>{{selectedApproval.typeLabel}}</p>
              </div>
            </div>

            <div class="gm-approval-rail-section gm-approval-ledger-preview">
              <div><span>Requested For</span><strong>{{selectedApproval.ownerLabel}}</strong></div>
              <div><span>Approved Cost</span><strong>{{selectedApproval.costLabel}}</strong></div>
              <div><span>Submitted</span><strong>{{selectedApproval.submittedLabel}}</strong></div>
            </div>

            <div class="gm-approval-rail-section">
              <span class="gm-command-eyebrow">VALIDATION WARNINGS</span>
              {{#if selectedApproval.warnings.length}}
              <div class="gm-approval-warning-stack">
                {{#each selectedApproval.warnings}}
                <div class="gm-approval-warning-row"><span>!</span><p>{{this}}</p></div>
                {{/each}}
              </div>
              {{else}}
              <p class="gm-approval-empty-note">No blocking warnings detected. GM may still override as needed.</p>
              {{/if}}
            </div>

            {{#if approvalEditMode}}
            <div class="gm-approval-rail-section gm-approval-change-panel">
              <span class="gm-command-eyebrow">PENDING GM EDITS</span>
              <div class="gm-approval-change-list" data-approval-change-list>
                <p class="gm-approval-empty-note" data-approval-change-empty>No edits yet. Change fields in the summary packet to build the adjustment list.</p>
              </div>
            </div>
            {{/if}}

            {{#if approvalDenyMode}}
            <div class="gm-approval-rail-section gm-approval-denial-panel">
              <label>
                <span class="gm-command-eyebrow">DENIAL REASON</span>
                <textarea name="denialReason" rows="5" placeholder="Tell the player why this request was denied."></textarea>
              </label>
              <div class="gm-approval-action-stack">
                <button type="button" class="swse-ui-button deny" data-action="approval-confirm-deny" data-approval-key="{{selectedApproval.key}}">Confirm Denial</button>
                <button type="button" class="swse-ui-button secondary" data-action="approval-cancel-deny" data-approval-key="{{selectedApproval.key}}">Cancel Denial</button>
              </div>
            </div>
            {{else}}
            <div class="gm-approval-rail-section gm-approval-decision-panel">
              {{#if approvalEditMode}}
              <div class="gm-approval-action-stack">
                <button type="button" class="swse-ui-button approve" data-action="approval-finalize-edits" data-approval-key="{{selectedApproval.key}}">
                  <i class="fa-solid fa-check"></i> Finalize Approval
                </button>
                <button type="button" class="swse-ui-button secondary" data-action="approval-cancel-edit" data-approval-key="{{selectedApproval.key}}">
                  Cancel Edits
                </button>
                <button type="button" class="swse-ui-button deny" data-action="approval-deny" data-approval-key="{{selectedApproval.key}}">
                  Deny Instead
                </button>
              </div>
              {{else}}
              <div class="gm-approval-action-stack">
                <button type="button" class="swse-ui-button approve" data-action="approval-approve" data-approval-key="{{selectedApproval.key}}">
                  <i class="fa-solid fa-check"></i> Approve
                </button>
                <button type="button" class="swse-ui-button" data-action="approval-enter-edit" data-approval-key="{{selectedApproval.key}}">
                  <i class="fa-solid fa-pen-to-square"></i> Approve with Edits
                </button>
                <button type="button" class="swse-ui-button deny" data-action="approval-deny" data-approval-key="{{selectedApproval.key}}">
                  <i class="fa-solid fa-xmark"></i> Deny
                </button>
              </div>
              {{/if}}
            </div>
            {{/if}}
          </aside>
        </form>
      </div>
      {{else}}
      <div class="gm-approval-empty-state swse-ui-panel">
        <i class="fa-solid fa-check-double"></i>
        <h3>No pending ship or droid approvals</h3>
        <p>The acquisition queue is clear. New custom droid, ship, or vehicle requests will appear here as summary packets.</p>
      </div>
      {{/if}}
    </div>

    {{!-- Settings Page --}}
    {{else if (eq currentPage "settings")}}
    <div class="gm-datapad-page gm-datapad-settings swse-shell-surface-host" data-shell-surface="settings">
      {{> "systems/foundryvtt-swse/templates/shell/partials/surface-settings.hbs" vm=settingsVm}}
    </div>

    {{!-- Healing Page --}}
    {{else if (eq currentPage "healing")}}
    <div class="gm-datapad-page gm-datapad-healing">
      <div class="page-header">
        <button class="back-button swse-ui-button" data-nav-to="home">← Back</button>
        <h2>{{pageTitle}}</h2>
        <p class="page-subtitle">{{pageDescription}}</p>
      </div>

      <div class="healing-content">
        <div class="healing-summary swse-ui-panel">
          <h3>Party Recovery Status</h3>
          <div class="healing-stats">
            <div class="stat-box">
              <span class="stat-label">Eligible for Healing</span>
              <span class="stat-value eligible">{{eligible}}</span>
            </div>
            <div class="stat-box">
              <span class="stat-label">Ineligible / Vehicles / Droids</span>
              <span class="stat-value ineligible">{{ineligible}}</span>
            </div>
          </div>

          <div class="healing-action">
            <button class="swse-ui-button swse-ui-button-primary" data-action="trigger-healing">
              <i class="fa-solid fa-heart-pulse"></i> Trigger Natural Healing
            </button>
            <p class="action-hint">Triggers recovery for all eligible party members. Fires restCompleted hook for Holonet notifications.</p>
          </div>
        </div>

        {{#if eligibleActors.length}}
        <div class="healing-eligible swse-ui-panel">
          <h3>Eligible Actors</h3>
          <ul class="actor-list">
            {{#each eligibleActors}}
            <li class="actor-item">
              <span class="actor-name">{{this.name}}</span>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/if}}

        {{#if ineligibleActors.length}}
        <div class="healing-ineligible swse-ui-panel">
          <h3>Ineligible Actors</h3>
          <ul class="actor-list">
            {{#each ineligibleActors}}
            <li class="actor-item">
              <span class="actor-name">{{this.name}}</span>
            </li>
            {{/each}}
          </ul>
          <p class="hint-text">These actors are not eligible: not a character type, is a droid, is a vehicle, or is dead (HP ≤ 0).</p>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Workspace Page --}}
    {{else if (eq currentPage "workspace")}}
    <div class="gm-datapad-page gm-datapad-workspace">
      <div class="page-header">
        <button class="back-button swse-ui-button" data-nav-to="home">← Back</button>
        <h2>{{pageTitle}}</h2>
        <p class="page-subtitle">{{pageDescription}}</p>
      </div>

      <div class="workspace-content">
        {{#if gmActors.length}}
        <div class="actors-grid">
          {{#each gmActors}}
          <div class="actor-card swse-ui-panel">
            <div class="actor-img">
              <img src="{{this.img}}" alt="{{this.name}}">
            </div>
            <div class="actor-info">
              <h4>{{this.name}}</h4>
              <p class="actor-type">{{this.type}}</p>
              <button class="swse-ui-button" data-open-actor="{{this.id}}">
                Open Sheet
              </button>
            </div>
          </div>
          {{/each}}
        </div>
        {{else}}
        <p class="placeholder">No GM-owned actors</p>
        {{/if}}
      </div>
    </div>

    {{else}}
    <div class="gm-datapad-page gm-datapad-error">
      <div class="page-header">
        <button class="back-button swse-ui-button" data-nav-to="home">← Back</button>
        <h2>Unknown Page</h2>
      </div>
      <p class="error-message">Page "{{currentPage}}" not found</p>
    </div>
    {{/if}}

        </div>
      </div>

      <div class="swse-tablet-vent swse-tablet-vent--bottom" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>

      <button type="button" class="swse-tablet-bottom-home" data-nav-to="home" title="Return to GM holopad home" aria-label="Return to GM holopad home">
        <span class="swse-tablet-bottom-home__glyph" aria-hidden="true">⌂</span>
        <span class="swse-tablet-bottom-home__label">HOME</span>
      </button>

      <div class="swse-tablet-bottom-engraving" aria-hidden="true">GM COMMAND HOLOPAD · OPS ACCESS · SHARED SHELL</div>
    </div>
  </div>
</div>
