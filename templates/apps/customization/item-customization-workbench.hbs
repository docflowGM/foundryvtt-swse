<div class="swse-customization-stage swse-datapad swse-ui-shell swse-sheet-ui" data-theme="{{themeKey}}" data-motion-style="{{motionStyle}}" style="{{{themeStyleInline}}}; {{{motionStyleInline}}};">
  <div class="swse-customization-tablet">
    <div class="swse-customization-screen" data-application-content>
      <header class="swse-customization-hud">
        <div class="hud-side left">
          <span>WORKBENCH-LINK</span>
          <span>{{#if mentorName}}{{mentorName}}{{else}}WORKSHOP{{/if}}</span>
        </div>
        <div class="hud-title">ARMORY // CUSTOMIZATION</div>
        <div class="hud-side right">
          <span>{{actor.name}}</span>
          <span>{{footer.credits}} CR</span>{{#if isStoreStageMode}}<span>STORE-STAGE</span>{{/if}}
        </div>
      </header>

      <section class="swse-customization-mentor {{#if (eq mentorKey 'miraj')}}mentor-miraj{{else}}mentor-delta{{/if}}">
        <div class="mentor-avatar">
          {{#if mentorPortrait}}<img src="{{mentorPortrait}}" alt="{{mentorName}}" class="mentor-avatar-img">{{else}}⌬{{/if}}
        </div>
        <div class="mentor-copy">
          <div class="mentor-head">{{mentorHead}}</div>
          <div class="mentor-text" data-workbench-mentor-text data-mentor="{{mentorKey}}" data-raw-text="{{mentorText}}">{{mentorText}}</div>
        </div>
      </section>

      {{#if lightsaberConstruction.available}}
      <section class="swse-lightsaber-construction-callout panel">
        <div>
          <span class="callout-eyebrow">Milestone Ready</span>
          <strong>Lightsaber construction is available.</strong>
          <p>Open the Saber Forge wizard path without needing an existing lightsaber in inventory.</p>
        </div>
        <button type="button" class="primary-action saber-ready-action" data-action="start-lightsaber-construction" data-entry-point="workbench-callout">Construct Lightsaber</button>
      </section>
      {{/if}}

      {{#if hasItems}}
      <nav class="swse-customization-tabs">
        {{#each categories}}
        <button type="button" class="workbench-tab {{#if active}}active{{/if}} {{#if special}}special{{/if}}" data-action="select-category" data-category="{{key}}">
          <span class="icon">{{icon}}</span>
          <span>{{label}}</span>
          <span class="count">{{count}}</span>
        </button>
        {{/each}}
      </nav>

      <section class="swse-customization-workarea">
        <aside class="workbench-inventory panel">
          <div class="panel-head">
            <span>Inventory</span>
            <span class="hint">{{currentItem.category}}</span>
          </div>
          {{#if isStoreStageMode}}
          <div class="store-stage-banner">Staging mode: no credits are charged here. This customized listing is added to cart and paid at checkout.</div>
          {{/if}}
          <div class="search-row">
            <input type="text" class="search-input" data-action="search-items" placeholder="Search items" value="{{search}}">
            {{#if hasSearch}}<button type="button" class="filter-reset" data-action="reset-filter">Reset</button>{{/if}}
          </div>
          <div class="inventory-list">
            {{#unless hasInventoryResults}}
            <div class="inventory-empty">{{#if isLightsaber}}No existing lightsabers found. Use Construct Lightsaber to begin the self-built forge path.{{else}}No items match this filter.{{/if}}</div>
            {{/unless}}
            {{#each inventoryItems}}
            <button type="button" class="inventory-item {{#if active}}active{{/if}}" data-action="select-item" data-item-id="{{id}}">
              <img class="inventory-icon" src="{{img}}" alt="{{name}}">
              <span class="inventory-copy">
                <span class="inventory-name">{{name}}</span>
                <span class="inventory-subtitle">{{subtitle}}</span>
              </span>
              <span class="inventory-meta">{{modCount}} MOD{{#if templateCount}} · {{templateCount}} TMP{{/if}}</span>
            </button>
            {{/each}}
          </div>
        </aside>

        <section class="workbench-detail">
          <div class="item-hero panel">
            <div class="panel-head">
              <span>{{currentItem.name}}</span>
              <span class="hint">{{currentItem.subtitle}}</span>
            </div>
            <div class="hero-grid">
              <div class="hero-art">
                <img src="{{currentItem.img}}" alt="{{currentItem.name}}">
              </div>
              <div class="hero-copy">
                <div class="hero-breadcrumb">{{currentItem.category}} · {{currentItem.subtitle}}</div>
                <div class="hero-description">{{currentItem.description}}</div>
                <div class="hero-stats">
                  {{#each currentItem.stats}}
                  <div class="hero-stat">
                    <span class="key">{{key}}</span>
                    <span class="value">{{value}}</span>
                  </div>
                  {{/each}}
                </div>
              </div>
            </div>
          </div>

          {{#if techSpecialist.canUse}}
          <section class="detail-panel panel tech-specialist-panel">
            <div class="panel-head compact"><span>Tech Specialist</span><span class="hint">{{techSpecialist.subjectType}}</span></div>
            <p class="panel-note">{{techSpecialist.hint}}</p>
            {{#if techSpecialist.installedTraits.length}}
            <div class="tech-trait-list">
              {{#each techSpecialist.installedTraits}}
              <button type="button" class="tech-trait-chip {{#if active}}active{{/if}}" data-action="toggle-tech-signature-trait" data-trait-id="{{id}}">
                <strong>{{name}}</strong><span>{{tier}}</span>
              </button>
              {{/each}}
            </div>
            {{/if}}
            <div class="tech-actions">
              <button type="button" class="action primary" data-action="open-tech-specialist" {{#unless techSpecialist.canInstall}}disabled{{/unless}}>Install Tech Trait</button>
              {{#if techSpecialist.canDesignateSignature}}<button type="button" class="action ghost" data-action="designate-signature-device">Make Signature Device</button>{{/if}}
            </div>
          </section>
          {{/if}}

          {{#if isLightsaber}}
          <div class="lightsaber-workspace lightsaber-workspace--tabs lightsaber-construction-wizard {{#if lightsaber.constructionMode}}lightsaber-workspace--construction{{/if}}" data-lightsaber-route-mode="{{lightsaber.route.mode}}" data-lightsaber-route-intent="{{lightsaber.route.routeIntent}}" data-lightsaber-wizard-stage="{{lightsaber.activeTab}}" style="--blade-color: {{lightsaber.bladeHex}};">
            <section class="detail-panel panel ls-tab-stage ls-wizard-main">
              <div class="panel-head ls-wizard-head">
                <span>{{#if lightsaber.constructionMode}}Lightsaber Construction Wizard{{else}}Lightsaber Tuning{{/if}}</span>
                <span class="hint">{{lightsaber.mode}}</span>
              </div>

              {{#if lightsaber.ineligibleNotice}}
              <div class="ls-eligibility-banner ineligible">
                <strong>Construction Locked</strong>
                <span>{{lightsaber.eligibilityReasonLabel}}</span>
                <small>Mode: {{lightsaber.constructionModeSetting}} · Requires {{lightsaber.constructionRequirements}}</small>
              </div>
              {{/if}}

              {{#if lightsaber.alreadyBuiltNotice}}
              <div class="ls-eligibility-banner built">
                <strong>Lightsaber Already Constructed</strong>
                <span>This actor already has a self-built lightsaber. Construction mode is hidden; tune the crystal and hilt here, and use the item edit sheet for blade color.</span>
              </div>
              {{/if}}

              <nav class="ls-step-rail" aria-label="Lightsaber construction steps">
                {{#each lightsaber.tabs}}
                <button type="button" class="ls-step {{#if active}}active{{/if}} {{#if done}}done{{/if}}" data-action="set-lightsaber-tab" data-tab="{{key}}">
                  <span class="ls-step-index">{{number}}</span>
                  <span>{{label}}</span>
                </button>
                {{/each}}
              </nav>

              {{#if lightsaber.tabChassis}}
              <section class="ls-tab-panel" data-lightsaber-tab-panel="chassis">
                <div class="panel-head compact"><span>Chassis</span><span class="hint">{{lightsaber.chassis.length}} frames</span></div>
                <div class="ls-tab-card-grid">
                  {{#each lightsaber.chassis}}
                  <button type="button" class="config-card ls-option-card {{#if selected}}selected{{/if}}" data-action="select-lightsaber-chassis" data-key="{{id}}" data-lightsaber-inspect-type="chassis" data-lightsaber-inspect-key="{{id}}" data-component-type="chassis" title="{{description}}">
                    <span class="card-top"><span class="card-name">{{name}}</span><span class="card-cost">{{cost}} cr</span></span>
                    <span class="card-desc">{{description}}</span>
                    <span class="card-tags"><span class="tag">DC {{system.baseBuildDc}}</span><span class="tag">{{system.chassisId}}</span></span>
                  </button>
                  {{/each}}
                </div>
              </section>
              {{/if}}

              {{#if lightsaber.tabCrystal}}
              <section class="ls-tab-panel" data-lightsaber-tab-panel="crystal">
                <div class="panel-head compact"><span>Kyber Crystal</span><span class="hint">{{lightsaber.crystals.length}} crystals</span></div>
                <div class="ls-tab-card-grid">
                  {{#each lightsaber.crystals}}
                  <button type="button" class="config-card ls-option-card {{#if selected}}selected{{/if}} {{#if incompatible}}disabled{{/if}}" data-action="select-lightsaber-crystal" data-key="{{id}}" data-lightsaber-inspect-type="crystal" data-lightsaber-inspect-key="{{id}}" data-component-type="crystal" {{#if incompatible}}disabled{{/if}} title="{{description}}">
                    <span class="card-top"><span class="card-name">{{name}}</span><span class="card-cost">{{cost}} cr</span></span>
                    <span class="card-desc">{{description}}</span>
                    <span class="card-tags"><span class="tag">{{rarity}}</span><span class="tag ls-color-text-tag">{{#each bladeColorParts}}<span class="{{className}}" {{#if style}}style="{{style}}"{{/if}}>{{label}}</span>{{/each}}</span><span class="tag">DC {{buildDcModifier}}</span>{{#if incompatible}}<span class="tag state">Incompatible</span>{{/if}}</span>
                  </button>
                  {{/each}}
                </div>
              </section>
              {{/if}}

              {{#if lightsaber.tabHilt}}
              <section class="ls-tab-panel" data-lightsaber-tab-panel="hilt">
                <div class="panel-head compact"><span>Hilt Accessories</span><span class="hint">{{lightsaber.slotState.usedSlots}}/{{lightsaber.slotState.totalAvailable}} slots</span></div>
                {{#if lightsaber.slotState.techSpecialistBonus}}<p class="panel-note">Tech Specialist grants one additional hilt modification slot during construction.</p>{{/if}}
                <div class="ls-tab-card-grid">
                  {{#each lightsaber.accessories}}
                  <button type="button" class="config-card ls-option-card {{#if selected}}selected{{/if}} {{#if incompatible}}disabled{{/if}}" data-action="toggle-lightsaber-accessory" data-key="{{id}}" data-lightsaber-inspect-type="accessory" data-lightsaber-inspect-key="{{id}}" data-component-type="accessory" {{#if incompatible}}disabled{{/if}} title="{{description}}">
                    <span class="card-top"><span class="card-name">{{name}}</span><span class="card-cost">{{cost}} cr</span></span>
                    <span class="card-desc">{{description}}</span>
                    <span class="card-tags"><span class="tag">{{slotCost}} slot</span><span class="tag">DC {{buildDcModifier}}</span>{{#if incompatible}}<span class="tag state">Incompatible</span>{{/if}}</span>
                  </button>
                  {{/each}}
                </div>
              </section>
              {{/if}}

              {{#if lightsaber.tabReview}}
              <section class="ls-tab-panel ls-tab-panel--review" data-lightsaber-tab-panel="review">
                <div class="panel-head compact"><span>Review / Construct</span><span class="hint">engine-authorized</span></div>
                <div class="ls-review-grid ls-review-grid--full">
                  <article><span>Chassis</span><strong>{{lightsaber.review.chassisName}}</strong></article>
                  <article><span>Crystal</span><strong>{{lightsaber.review.crystalName}}</strong></article>
                  <article><span>Hilt</span><strong>{{lightsaber.review.accessoryNames}}</strong></article>
                  <article><span>Blade Color</span><strong class="ls-color-name-strip">{{#each lightsaber.review.bladeColorParts}}<span class="{{className}}" {{#if style}}style="{{style}}"{{/if}}>{{label}}</span>{{/each}}</strong></article>
                  <article><span>Damage</span><strong>{{lightsaber.review.damage}}</strong></article>
                  <article><span>Critical</span><strong>{{lightsaber.review.critical}}</strong></article>
                  <article><span>Damage Type</span><strong>{{lightsaber.review.damageType}}</strong></article>
                  <article><span>Range</span><strong>{{lightsaber.review.range}}</strong></article>
                  <article><span>Build DC</span><strong>{{lightsaber.review.buildDc}}</strong></article>
                  <article><span>Use the Force</span><strong>{{lightsaber.review.useTheForce}}</strong></article>
                  <article><span>Take 10</span><strong>{{lightsaber.review.take10}}</strong></article>
                  <article><span>Total Cost</span><strong>{{lightsaber.review.totalCost}} cr</strong></article>
                </div>

                <div class="ls-review-checks">
                  <div class="ls-check-mode">
                    <button type="button" class="{{#if lightsaber.rollSelected}}active{{/if}}" data-action="set-lightsaber-check-mode" data-key="roll">Roll Use the Force</button>
                    <button type="button" class="{{#if lightsaber.take10Selected}}active{{/if}}" data-action="set-lightsaber-check-mode" data-key="take10">Take 10</button>
                  </div>
                  <div class="ls-affordability {{#if lightsaber.review.affordable}}ok{{else}}bad{{/if}}">
                    <span>Credits</span>
                    <strong>{{footer.credits}} cr → {{lightsaber.review.after}} cr</strong>
                    <small>{{#if lightsaber.review.affordable}}Affordable{{else}}Insufficient credits{{/if}}</small>
                  </div>
                </div>

                {{#if lightsaber.result}}
                <div class="ls-roll-result {{#if lightsaber.result.success}}success{{else}}failure{{/if}}">
                  <span class="ls-roll-label">{{lightsaber.result.title}}</span>
                  <strong>{{lightsaber.result.rollTotal}}</strong>
                  <p>{{lightsaber.result.message}}</p>
                  {{#if lightsaber.result.rollRaw}}<small>d20 {{lightsaber.result.rollRaw}} + UtF {{lightsaber.result.modifier}} vs DC {{lightsaber.result.finalDc}}</small>{{/if}}
                </div>
                {{/if}}

                <div class="ls-review-actions">
                  <button type="button" class="action ghost" data-action="attempt-lightsaber-construction" data-mode="take10" {{#unless lightsaber.canTake10Build}}disabled{{/unless}}>Construct via Take 10</button>
                  <button type="button" class="action primary" data-action="attempt-lightsaber-construction" data-mode="roll" {{#unless lightsaber.canRoll}}disabled{{/unless}}>Roll Use the Force</button>
                </div>
              </section>
              {{/if}}

              <div class="ls-wizard-nav">
                {{#if lightsaber.navigation.previous}}<button type="button" class="action ghost" data-action="lightsaber-step-prev" data-tab="{{lightsaber.navigation.previous}}">← Back</button>{{/if}}
                <span class="ls-wizard-rules"><span>24 hr uninterrupted</span><span>No Take 20</span><span>Use the Force</span></span>
                {{#if lightsaber.navigation.next}}<button type="button" class="action primary" data-action="lightsaber-step-next" data-tab="{{lightsaber.navigation.next}}">{{#if (eq lightsaber.navigation.next "review")}}Review →{{else}}Next →{{/if}}</button>{{/if}}
              </div>
            </section>

            <aside class="ls-forge-rail">
              <section class="detail-panel panel ls-forge-stage">
                <div class="panel-head">
                  <span>✦ Forge Preview</span>
                  <span class="hint">{{lightsaber.mode}}</span>
                </div>
                <div class="ls-blade-render {{lightsaber.hiltKind}}" style="--blade-color: {{lightsaber.bladeHex}};">
                  <span class="ls-blade ls-left"></span>
                  <span class="ls-hilt"></span>
                  <span class="ls-blade ls-right"></span>
                  <span class="ls-crossguard ls-crossguard-a"></span>
                  <span class="ls-crossguard ls-crossguard-b"></span>
                </div>
                <div class="ls-color-cta ls-color-cta--readonly" style="--blade-color: {{lightsaber.bladeHex}};">
                  <span class="ls-color-current"><span class="ls-color-dot"></span><span class="ls-color-name-strip">{{#each lightsaber.review.bladeColorParts}}<span class="{{className}}" {{#if style}}style="{{style}}"{{/if}}>{{label}}</span>{{/each}}</span> blade</span>
                  <small>Color selection now lives on the item edit sheet.</small>
                </div>
                {{#unless lightsaber.showChassis}}
                <div class="ls-locked-chassis-card ls-rail-lock-note">
                  <div class="card-top"><span class="card-name">{{lightsaber.selectedChassisName}}</span><span class="card-cost">Fixed</span></div>
                  <span class="card-desc">{{lightsaber.chassisLockReason}}</span>
                </div>
                {{/unless}}
              </section>

              <section class="detail-panel panel ls-component-intel">
                <div class="panel-head"><span>Selected Component Intel</span><span class="hint">{{lightsaber.componentIntel.kind}}</span></div>
                <article class="rail-detail-card {{#if lightsaber.componentIntel.selected}}selected{{/if}}" {{#if lightsaber.componentIntel.colorHex}}style="--weapon-color: {{lightsaber.componentIntel.colorHex}}"{{/if}}>
                  <div class="rail-detail-top"><span>{{lightsaber.componentIntel.name}}</span><span>{{lightsaber.componentIntel.kind}}</span></div>
                  {{#if lightsaber.componentIntel.colorHex}}<div class="ls-intel-color-chip"><span></span>{{lightsaber.componentIntel.name}}</div>{{/if}}
                  {{#if lightsaber.componentIntel.bladeColorParts}}<div class="ls-color-name-strip ls-color-name-strip--intel">{{#each lightsaber.componentIntel.bladeColorParts}}<span class="{{className}}" {{#if style}}style="{{style}}"{{/if}}>{{label}}</span>{{/each}}</div>{{/if}}
                  <dl class="rail-detail-fields">
                    <div><dt>Detail</dt><dd>{{lightsaber.componentIntel.description}}</dd></div>
                    {{#each lightsaber.componentIntel.fields}}
                    <div><dt>{{key}}</dt><dd>{{value}}</dd></div>
                    {{/each}}
                  </dl>
                </article>
              </section>

              <section class="detail-panel panel ls-build-summary">
                <div class="panel-head"><span>Build Summary</span><span class="hint">DC {{lightsaber.buildSummary.finalDc}}</span></div>
                <div class="ls-dc-row">
                  <span>DC {{lightsaber.buildSummary.baseDc}}</span>
                  <span>{{lightsaber.buildSummary.crystalDcText}}</span>
                  <span>{{lightsaber.buildSummary.accessoryDcText}}</span>
                  <strong>{{lightsaber.buildSummary.finalDc}}</strong>
                </div>
                <div class="ls-summary-line {{#if lightsaber.buildSummary.canTake10}}ok{{else}}bad{{/if}}">{{lightsaber.buildSummary.take10Text}}</div>
                <div class="ls-summary-line {{#if lightsaber.buildSummary.affordable}}ok{{else}}bad{{/if}}">{{lightsaber.buildSummary.totalCost}} cr total · {{lightsaber.buildSummary.credits}} cr available</div>
              </section>
            </aside>

            {{#if lightsaber.showSuccessOverlay}}
            <div class="ls-success-overlay">
              <div class="ls-success-beam" style="--blade-color: {{lightsaber.bladeHex}};"></div>
              <h3>Lightsaber Forged</h3>
              <p>{{lightsaber.createdWeaponName}} resonates with the Force. The construction engine stored builtBy, builtAt, bladeColor, and lightsaberConfig, then cleared the construction milestone flags.</p>
              <div class="ls-success-actions">
                <button type="button" class="action primary" data-action="begin-lightsaber-attunement">Attune Now — Summon Miraj</button>
                <button type="button" class="action ghost" data-action="dismiss-lightsaber-success">Attune Later</button>
              </div>
            </div>
            {{/if}}
          </div>
          {{else}}
          {{#if isEnergyShield}}
          <section class="energy-shield-rules panel">
            <div class="panel-head"><span>Energy Shield Operating Profile</span><span class="hint">SR {{energyShield.sr}} · {{energyShield.typeLabel}}</span></div>
            <div class="energy-shield-grid">
              <div class="energy-shield-emitter">
                <span class="shield-ring shield-ring-a"></span>
                <span class="shield-ring shield-ring-b"></span>
                <span class="shield-core">SR {{energyShield.sr}}</span>
              </div>
              <div class="energy-shield-rule-copy">
                <p><strong>Inactive:</strong> Worn but inert. No Reflex override, no Max Dex cap, no armor check penalty, and no Shield Rating.</p>
                <p><strong>Activated:</strong> Swift Action, consumes 1 charge, lasts until encounter end, and grants SR {{energyShield.sr}} against Energy damage only.</p>
                <p><strong>Penalty:</strong> While active, applies Max Dex {{#if energyShield.maxDex}}+{{energyShield.maxDex}}{{else}}—{{/if}} and ACP {{energyShield.armorCheckPenalty}}. Without Armor Proficiency ({{energyShield.proficiency}}), apply -5 Reflex and deny Dex bonus, but do not remove heroic level bonus.</p>
              </div>
            </div>
          </section>
          {{/if}}
          <div class="detail-grid {{#if isEnergyShield}}energy-shield-detail-grid{{/if}}">
            {{#if isEnergyShield}}
            <section class="detail-panel panel energy-shield-maintenance-panel">
              <div class="panel-head">
                <span>Shield Structural / Maintenance</span>
                <span class="hint">generator-safe only</span>
              </div>
              <div class="card-list structural-list">
                <article class="config-card installed">
                  <span class="card-top"><span class="card-name">Power Cell Housing</span><span class="card-cost">Charges</span></span>
                  <span class="card-desc">Energy shields are tuned through generator maintenance and compatible templates, not normal armor plating mods.</span>
                  <span class="card-tags"><span class="tag">5 charges</span><span class="tag">Swift activate</span></span>
                </article>
                <article class="config-card disabled">
                  <span class="card-top"><span class="card-name">Armor Modification Surface</span><span class="card-cost">Illegal</span></span>
                  <span class="card-desc">Normal armor modifications cannot be taken on an energy shield unless a rule/template explicitly says it works on energy shields.</span>
                  <span class="card-tags"><span class="tag state">No armor mods</span></span>
                </article>
                {{#each structuralActions.strips}}
                <button type="button" class="config-card {{#if selected}}selected{{/if}} {{#if installed}}installed{{/if}} {{#if disabled}}disabled{{/if}}" data-action="toggle-strip" data-key="{{key}}">
                  <span class="card-top"><span class="card-name">{{label}}</span>{{#if effect}}<span class="card-cost">{{effect}}</span>{{/if}}</span>
                  {{#if description}}<span class="card-desc">{{description}}</span>{{/if}}
                </button>
                {{/each}}
              </div>
            </section>
            {{else}}
            <section class="detail-panel panel">
              <div class="panel-head">
                <span>Modifications</span>
                <span class="hint">{{upgrades.length}} available</span>
              </div>
              <div class="card-list">
                {{#if upgrades.length}}
                  {{#each upgrades}}
                  <button type="button" class="config-card {{#if selected}}selected{{/if}} {{#if installed}}installed{{/if}} {{#if disabled}}disabled{{/if}}" data-action="toggle-upgrade" data-key="{{key}}" {{#if disabled}}title="No slots available"{{/if}}>
                    <span class="card-top">
                      <span class="card-name">{{name}}</span>
                      <span class="card-cost">{{costCredits}} cr</span>
                    </span>
                    <span class="card-desc">{{description}}</span>
                    <span class="card-tags">
                      {{#if effect}}<span class="tag">{{effect}}</span>{{/if}}
                      <span class="tag">{{slotCost}} slot</span>
                      {{#if installed}}<span class="tag state">Installed</span>{{/if}}
                      {{#if selected}}{{#unless installed}}<span class="tag state">Staged</span>{{/unless}}{{/if}}
                    </span>
                  </button>
                  {{/each}}
                {{else}}
                  <div class="empty-state">No structured modifications available for this item.</div>
                {{/if}}
              </div>
            </section>
            {{/if}}

            <section class="detail-panel panel">
              <div class="panel-head">
                <span>Templates</span>
                <span class="hint">Max {{footer.maxTemplatesPerItem}}</span>
              </div>
              <div class="card-list">
                {{#if templates.length}}
                  {{#each templates}}
                  <button type="button" class="config-card template {{#if selected}}selected{{/if}} {{#if installed}}installed{{/if}} {{#if disabled}}disabled{{/if}}" data-action="toggle-template" data-key="{{key}}" {{#if disabledReason}}title="{{disabledReason}}"{{/if}}>
                    <span class="card-top">
                      <span class="card-name">{{name}}</span>
                      <span class="card-cost">{{costPreview}} cr</span>
                    </span>
                    <span class="card-desc">{{description}}</span>
                    {{#if rulesText}}<span class="card-rules">{{rulesText}}</span>{{/if}}
                    <span class="card-tags">
                      <span class="tag">{{restriction}}</span>
                      {{#if rarity}}<span class="tag rare">Rare</span>{{/if}}
                      {{#if installed}}<span class="tag state">Applied</span>{{/if}}
                      {{#if selected}}{{#unless installed}}<span class="tag state">Staged</span>{{/unless}}{{/if}}
                    </span>
                  </button>
                  {{/each}}
                {{else}}
                  <div class="empty-state">No templates are available for this item.</div>
                {{/if}}
              </div>
            </section>

            {{#unless isEnergyShield}}
            <section class="detail-panel panel">
              <div class="panel-head">
                <span>Structural Changes</span>
                <span class="hint">Slots + bulk</span>
              </div>
              <div class="card-list structural-list">
                <button type="button" class="config-card {{#if structuralActions.sizeIncrease.selected}}selected{{/if}} {{#if structuralActions.sizeIncrease.disabled}}disabled{{/if}}" data-action="toggle-size-increase">
                  <span class="card-top">
                    <span class="card-name">{{structuralActions.sizeIncrease.label}}</span>
                  </span>
                  <span class="card-desc">{{structuralActions.sizeIncrease.description}}</span>
                </button>
                {{#each structuralActions.strips}}
                <button type="button" class="config-card {{#if selected}}selected{{/if}} {{#if installed}}installed{{/if}} {{#if disabled}}disabled{{/if}}" data-action="toggle-strip" data-key="{{key}}">
                  <span class="card-top"><span class="card-name">{{label}}</span>{{#if effect}}<span class="card-cost">{{effect}}</span>{{/if}}</span>
                  {{#if description}}<span class="card-desc">{{description}}</span>{{/if}}
                </button>
                {{/each}}
              </div>
            </section>
            {{/unless}}

            <aside class="detail-rail panel">
              <div class="panel-head">
                <span>Modification Intel</span>
                <span class="hint">{{detailRail.slotSummary}}</span>
              </div>
              <div class="detail-rail-scroll">
                {{#if detailRail.stagedRows.length}}
                <section class="rail-section rail-section-staged">
                  <div class="rail-section-title">Staged Work</div>
                  {{#each detailRail.stagedRows}}
                  <article class="rail-detail-card selected">
                    <div class="rail-detail-top"><span>{{name}}</span><span>{{kind}}</span></div>
                    <dl class="rail-detail-fields">
                      <div><dt>Detail</dt><dd>{{description}}</dd></div>
                      {{#if effect}}<div><dt>Benefit</dt><dd class="rail-benefit">{{effect}}</dd></div>{{/if}}
                      <div><dt>Slots</dt><dd>{{#if slotCost}}{{slotCost}}{{else}}0{{/if}}</dd></div>
                      <div><dt>Cost</dt><dd>{{#if cost}}{{cost}} cr{{else}}+0 cr{{/if}}</dd></div>
                    </dl>
                    {{#if selectable}}<button type="button" class="rail-select-btn" data-action="{{action}}" {{#if key}}data-key="{{key}}"{{/if}}>{{buttonLabel}}</button>{{/if}}
                  </article>
                  {{/each}}
                </section>
                {{/if}}

                <section class="rail-section">
                  <div class="rail-section-title">Available Modifications</div>
                  {{#if detailRail.upgradeRows.length}}
                    {{#each detailRail.upgradeRows}}
                    <article class="rail-detail-card {{#if selected}}selected{{/if}} {{#if installed}}installed{{/if}} {{#if disabled}}disabled{{/if}}">
                      <div class="rail-detail-top"><span>{{name}}</span><span>{{kind}}</span></div>
                      <dl class="rail-detail-fields">
                        <div><dt>Detail</dt><dd>{{description}}</dd></div>
                        {{#if effect}}<div><dt>Benefit</dt><dd class="rail-benefit">{{effect}}</dd></div>{{/if}}
                        <div><dt>Slots</dt><dd>{{slotCost}}</dd></div>
                        <div><dt>Cost</dt><dd>{{cost}} cr</dd></div>
                      </dl>
                      <div class="rail-tags">{{#if installed}}<span>Installed</span>{{/if}}{{#if selected}}{{#unless installed}}<span>Staged</span>{{/unless}}{{/if}}</div>
                      {{#if selectable}}<button type="button" class="rail-select-btn" data-action="{{action}}" data-key="{{key}}">{{buttonLabel}}</button>{{/if}}
                    </article>
                    {{/each}}
                  {{else}}
                    <div class="rail-empty">No structured modifications are available for this item.</div>
                  {{/if}}
                </section>

                {{#if detailRail.templateRows.length}}
                <section class="rail-section">
                  <div class="rail-section-title">Templates</div>
                  {{#each detailRail.templateRows}}
                  <article class="rail-detail-card {{#if selected}}selected{{/if}} {{#if installed}}installed{{/if}} {{#if disabled}}disabled{{/if}}">
                    <div class="rail-detail-top"><span>{{name}}</span><span>{{kind}}</span></div>
                    <dl class="rail-detail-fields">
                      <div><dt>Detail</dt><dd>{{description}}</dd></div>
                      {{#if effect}}<div><dt>Benefit</dt><dd class="rail-benefit">{{effect}}</dd></div>{{/if}}
                      <div><dt>Slots</dt><dd>0</dd></div>
                      <div><dt>Cost</dt><dd>{{cost}} cr</dd></div>
                    </dl>
                    <div class="rail-tags">{{#if installed}}<span>Applied</span>{{/if}}{{#if selected}}{{#unless installed}}<span>Staged</span>{{/unless}}{{/if}}</div>
                    {{#if selectable}}<button type="button" class="rail-select-btn rail-select-btn--template" data-action="{{action}}" data-key="{{key}}">{{buttonLabel}}</button>{{/if}}
                  </article>
                  {{/each}}
                </section>
                {{/if}}

                {{#if detailRail.structuralRows.length}}
                <section class="rail-section">
                  <div class="rail-section-title">Structural Changes</div>
                  {{#each detailRail.structuralRows}}
                  <article class="rail-detail-card {{#if selected}}selected{{/if}} {{#if installed}}installed{{/if}} {{#if disabled}}disabled{{/if}}">
                    <div class="rail-detail-top"><span>{{name}}</span><span>{{kind}}</span></div>
                    <dl class="rail-detail-fields">
                      <div><dt>Detail</dt><dd>{{description}}</dd></div>
                      {{#if effect}}<div><dt>Benefit</dt><dd class="rail-benefit">{{effect}}</dd></div>{{/if}}
                      <div><dt>Slots</dt><dd>+1</dd></div>
                      <div><dt>Cost</dt><dd>{{#if cost}}{{cost}} cr{{else}}+0 cr{{/if}}</dd></div>
                    </dl>
                    <div class="rail-tags">{{#if installed}}<span>Installed</span>{{/if}}{{#if selected}}{{#unless installed}}<span>Staged</span>{{/unless}}{{/if}}</div>
                    {{#if selectable}}<button type="button" class="rail-select-btn" data-action="{{action}}" {{#if key}}data-key="{{key}}"{{/if}}>{{buttonLabel}}</button>{{/if}}
                  </article>
                  {{/each}}
                </section>
                {{/if}}
              </div>
            </aside>

            <section class="detail-panel panel appearance-panel">
              <div class="panel-head">
                <span>Appearance / Configuration</span>
                <span class="hint">Visual pass</span>
              </div>
              <div class="appearance-blocks">
                {{#each currentItem.appearance}}
                <div class="appearance-block">
                  <div class="appearance-label">{{key}}</div>
                  {{#if options}}
                    {{#if selectedHex}}
                    <div class="blaster-bolt-preview" style="--weapon-color: {{selectedHex}}" aria-label="Selected bolt color {{selectedLabel}}">
                      <span class="blaster-bolt-preview__muzzle" aria-hidden="true"></span>
                      <span class="blaster-bolt-preview__beam" aria-hidden="true"></span>
                      <span class="blaster-bolt-preview__label">{{selectedLabel}} bolt package</span>
                    </div>
                    <div class="weapon-color-picker bolt-color-grid" aria-label="{{key}}">
                      {{#each options}}
                      <button type="button" class="weapon-color-cell blaster-color-cell {{#if selected}}selected{{/if}}" style="--weapon-color: {{hex}}" data-action="{{../action}}" data-key="{{key}}" title="{{label}}" aria-label="Bolt color {{label}}">
                        <span class="weapon-color-preview bolt-preview" aria-hidden="true"><span class="weapon-color-beam"></span></span>
                        <span class="weapon-color-label">{{label}}</span>
                      </button>
                      {{/each}}
                    </div>
                    {{else}}
                    <div class="swatch-grid">
                      {{#each options}}
                      <button type="button" class="swatch {{#if selected}}selected{{/if}}" style="--swatch: {{hex}}" data-action="{{../action}}" data-key="{{key}}" title="{{label}}"></button>
                      {{/each}}
                    </div>
                    {{/if}}
                  {{/if}}
                  {{#if variantOptions}}
                  <div class="variant-list">
                    {{#each variantOptions}}
                    <button type="button" class="variant-row {{#if selected}}selected{{/if}}" data-action="{{../action}}" data-key="{{key}}">
                      <span class="variant-name">{{name}}</span>
                      <span class="variant-desc">{{description}}</span>
                    </button>
                    {{/each}}
                  </div>
                  {{/if}}
                </div>
                {{/each}}
              </div>
            </section>
          </div>
          {{/if}}
        </section>
      </section>

      <footer class="swse-customization-footer">
        <div class="footer-credits">
          <div class="credit-box">
            <span class="label">Credits</span>
            <span class="value">{{footer.credits}}</span>
          </div>
          <div class="credit-box cost">
            <span class="label">Cost</span>
            <span class="value">-{{footer.cost}}</span>
          </div>
          <div class="credit-box {{#if footer.canApply}}after{{else}}short{{/if}}">
            <span class="label">After</span>
            <span class="value">{{footer.after}}</span>
          </div>
        </div>
        <div class="slot-meter">
          <div class="meter-head">Slot Usage <span>{{footer.slots.usedSlots}} / {{footer.slots.totalAvailable}}</span></div>
          <div class="meter-bar {{#if footer.slots.isOverflowing}}overflow{{/if}}">
            <span class="meter-fill" style="width: {{footer.slotPercent}}%"></span>
          </div>
        </div>
        <div class="footer-actions">
          <button type="button" class="action ghost" data-action="reset-item">Reset</button>
          <button type="button" class="action ghost" data-action="close-workbench">Close</button>
          {{#if footer.blockedReason}}<span class="footer-blocker">{{footer.blockedReason}}</span>{{/if}}
          <button type="button" class="action primary" data-action="apply-item" {{#unless footer.canApply}}disabled{{/unless}}>{{footer.applyLabel}}</button>
        </div>
      </footer>
      {{else}}
      <section class="swse-customization-empty">No supported items found for the first-wave customization workbench.</section>
      {{/if}}
    </div>
  </div>
</div>
