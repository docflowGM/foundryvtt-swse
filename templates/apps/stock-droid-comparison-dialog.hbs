<div class="stock-droid-comparison-dialog">
  <div class="comparison-header">
    <h2><i class="fas fa-code-branch"></i> Compare: {{actor.name}}</h2>
    <p class="subtitle">{{#if isConverted}}Converted{{else}}Imported{{/if}} from {{sourceName}}</p>
  </div>

  <div class="comparison-intro">
    {{#if isConverted}}
    <div class="info-box converted">
      <i class="fas fa-wand-magic-sparkles"></i>
      <p><strong>Converted Droid:</strong> This droid was converted from a stock statblock to a custom system-native droid. Current values may differ from the original stock statblock due to builder edits and inferred selections.</p>
    </div>
    {{else}}
    <div class="info-box">
      <i class="fas fa-info-circle"></i>
      <p><strong>Stock Droid:</strong> This droid was imported as a stock statblock. Comparison shows published values vs. any subsequent customizations.</p>
    </div>
    {{/if}}
  </div>

  {{#if summary}}
  <div class="comparison-summary">
    <h3>Summary</h3>
    <div class="summary-stats">
      <div class="stat-item">
        <span class="label">Total Fields</span>
        <span class="value">{{summary.totalFields}}</span>
      </div>
      <div class="stat-item">
        <span class="label">Same</span>
        <span class="value">{{summary.sameCount}}</span>
      </div>
      <div class="stat-item">
        <span class="label">Changed</span>
        <span class="value">{{summary.changedCount}}</span>
      </div>
      <div class="stat-item">
        <span class="label">Reference</span>
        <span class="value">{{summary.referenceOnlyCount}}</span>
      </div>
      <div class="stat-item">
        <span class="label">Unknown</span>
        <span class="value">{{summary.unknownCount}}</span>
      </div>
    </div>
  </div>
  {{/if}}

  <div class="comparison-categories">
    {{#each categoriesForTemplate}}
    <section class="comparison-category">
      <h3 class="category-header">
        <i class="fas {{this.icon}}"></i>
        {{this.name}}
      </h3>

      {{#if this.fields}}
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Field</th>
            <th>Published Stock</th>
            <th>Current</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.fields}}
          <tr class="field-row status-{{this.status}}">
            <td class="field-name">{{this.name}}</td>
            <td class="field-published">{{#if this.published}}{{this.published}}{{else}}<em>—</em>{{/if}}</td>
            <td class="field-current">{{#if this.current}}{{this.current}}{{else}}<em>—</em>{{/if}}</td>
            <td class="field-status">
              <span class="status-badge {{this.status}}">{{this.statusLabel}}</span>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{else if this.summary}}
      <div class="summary-details">
        {{#each this.summary}}
        <div class="summary-item">
          <span class="label">{{this.@key}}:</span>
          <span class="value">{{this}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </section>
    {{/each}}
  </div>

  <div class="comparison-footer">
    <button class="btn btn-secondary" data-action="close">
      <i class="fas fa-times"></i> Close
    </button>
  </div>
</div>

<style>
