<div class="npc-import-wizard">
  <div class="wizard-header">
    <h2>Customize NPC Import</h2>
    <p class="subtitle">Make quick adjustments before finalizing the NPC. Leave blank to use template defaults.</p>
  </div>

  <div class="wizard-content">
    <!-- Portrait Section -->
    <div class="form-group portrait-group">
      <label for="portrait">Portrait</label>
      <div class="portrait-container">
        <div class="portrait-preview">
          <img src="{{portraitPreview}}" alt="{{template.name}}" />
        </div>
        <div class="portrait-controls">
          <div class="portrait-path">
            <input
              type="text"
              id="portrait"
              name="portrait"
              class="form-control"
              value="{{customData.portrait}}"
              placeholder="Paste image path or use picker..."
            />
          </div>
          <button type="button" class="portrait-picker-btn" title="Browse for image">
            <i class="fas fa-folder-open"></i> Browse
          </button>
        </div>
      </div>
      <p class="form-hint">Supported: webp, png, jpg. Portrait updates dynamically.</p>
    </div>

    <!-- Name Section -->
    <div class="form-group">
      <label for="name">NPC Name</label>
      <input
        type="text"
        id="name"
        name="name"
        class="form-control"
        value="{{customData.name}}"
        placeholder="Enter NPC name..."
        required
      />
      <p class="form-hint">Required. Used for actor display name and token.</p>
    </div>

    <!-- Notes Section -->
    <div class="form-group">
      <label for="notes">Quick Notes</label>
      <textarea
        id="notes"
        name="notes"
        class="form-control"
        rows="3"
        placeholder="Add quick notes about this NPC (optional)..."
      >{{customData.notes}}</textarea>
      <p class="form-hint">Appears in actor biography. Use for quick reminders or roleplay notes.</p>
    </div>

    <!-- Biography Section -->
    <div class="form-group">
      <label for="biography">Biography</label>
      <textarea
        id="biography"
        name="biography"
        class="form-control"
        rows="3"
        placeholder="Enter full biography (optional)..."
      >{{customData.biography}}</textarea>
      <p class="form-hint">Full background and lore. Can be expanded after import.</p>
    </div>

    <!-- Template Info -->
    <div class="template-info-section">
      <h3>Template Information</h3>
      <div class="template-info">
        <div class="info-row">
          <span class="label">Source Template:</span>
          <span class="value">{{template.name}}</span>
        </div>
        {{#if template.metadata.species}}
        <div class="info-row">
          <span class="label">Species:</span>
          <span class="value">{{template.metadata.species}}</span>
        </div>
        {{/if}}
        {{#if template.metadata.classLevels}}
        <div class="info-row">
          <span class="label">Classes:</span>
          <span class="value">
            {{#each template.metadata.classLevels}}
            <span class="class-badge">{{@key}} {{this}}</span>
            {{/each}}
          </span>
        </div>
        {{/if}}
        <p class="info-note">
          <i class="fas fa-info-circle"></i>
          You can adjust more details after the actor is created using the full character sheet.
        </p>
      </div>
    </div>
  </div>

  <!-- Footer Actions -->
  <div class="wizard-footer">
    <button class="cancel-btn" type="button">
      <i class="fas fa-times"></i> Cancel
    </button>
    <button class="confirm-btn" type="button">
      <i class="fas fa-check"></i> Finalize & Import
    </button>
  </div>
</div>

<style>
