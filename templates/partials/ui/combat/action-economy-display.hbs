{{!-- Action Economy Display Partial
     Shows visual representation of turn action economy

     Context expected:
     - actionState: { standard, move, swift, full }
       Each can be: "available", "degraded", "used"
     - breakdown: Array of descriptive strings
--}}

<div class="swse-action-economy" {{#if breakdown}}title="{{join breakdown ' '}}{{/if}}">
  {{!-- STANDARD ACTION --}}
  <span class="badge-standard badge-{{actionState.standard}}"
        title="Standard Action: {{actionState.standard}}">
  </span>

  {{!-- MOVE ACTION --}}
  <span class="badge-move badge-{{actionState.move}}"
        title="Move Action: {{actionState.move}}">
  </span>

  {{!-- SWIFT ACTION --}}
  <span class="badge-swift badge-{{actionState.swift}}"
        title="Swift Actions: {{actionState.swift}}">
  </span>

  {{!-- FULL-ROUND (indicator only) --}}
  {{#if fullRoundUsed}}
    <span class="badge-full-round badge-used"
          title="Full-round action used">
    </span>
  {{/if}}
</div>
