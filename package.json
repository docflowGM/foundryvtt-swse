{
  "name": "foundryvtt-swse-tools",
  "private": true,
  "type": "module",
  "scripts": {
    "validate:partials": "node tools/validate-partials.mjs --strict",
    "report:partials": "node tools/validate-partials.mjs --report partials-report.json",
    "fix:partials": "node tools/validate-partials.mjs --strict --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:governance": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=phase-5-governance",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
