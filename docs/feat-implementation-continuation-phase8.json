{
  "phase": "phase8-feat-implementation-continuation",
  "purpose": "Continue implementing feats from the refreshed descriptions after phases 1-7, prioritizing mechanics that can be safely handled by existing resource, derived, combat option, and roll-context engines.",
  "sourceInputs": [
    "packs/feats.db after phases 1-7",
    "/mnt/data/swse_feats.json",
    "/mnt/data/swse_feat_index.json",
    "/mnt/data/swse_feats_foundry_seed.json"
  ],
  "designPrinciples": [
    "Do not add conditional bonuses to static sheet totals.",
    "Use existing engines rather than parallel feat systems.",
    "Convert false scaffold attack modifiers into explicit resource rules or attack options.",
    "Only automate high-confidence mechanics; leave complex prompt/UI flows as partial metadata when the engine cannot fully apply them yet."
  ],
  "implementedGroups": {
    "hitPointAndDamageThresholdRules": [
      {
        "feat": "Toughness",
        "implementation": "resourceRules.hitPoints MAX_BONUS_PER_LEVEL",
        "consumer": "ActorEngine.recomputeHP via MetaResourceFeatResolver.getHitPointMaxBonus",
        "notes": "Old flat hp.max +5 modifier disabled because Toughness is +1 HP per character level."
      },
      {
        "feat": "Improved Damage Threshold",
        "implementation": "resourceRules.damageThreshold FLAT_BONUS +5",
        "consumer": "DerivedCalculator via MetaResourceFeatResolver.getDamageThresholdRules",
        "notes": "Old defense.damageThreshold modifier disabled to avoid double counting."
      },
      {
        "feat": "Fight Through Pain",
        "implementation": "resourceRules.damageThreshold USE_WILL_AS_BASE",
        "consumer": "DerivedCalculator via MetaResourceFeatResolver.getDamageThresholdRules",
        "notes": "Old fake attack modifier disabled. Damage Threshold now uses the better of Fortitude or Will when this feat is present."
      }
    ],
    "secondWindRules": [
      {
        "feat": "Resurgence",
        "implementation": "GRANT_MOVE_ACTION_ON_USE",
