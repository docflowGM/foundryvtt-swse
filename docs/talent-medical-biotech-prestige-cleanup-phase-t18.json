  "notes": [
    "This pass removes unsafe generic migrated modifiers from medical, biotech, and implant talents rather than letting them apply as always-on attack/defense bonuses.",
    "Implant talents are surfaced as manual standard-action cards because their bonuses are granted to adjacent willing living recipients for encounter duration, not passively to the owning actor.",
    "Bugbite uses the existing weapon-rule modifier path to add +1 weapon die only for Razor Bug and Thud Bug contexts.",
    "Curved Throw uses a swift action card plus an optional attack flag that suppresses cover only for the next Thud Bug/Razor Bug attack when selected.",
    "Biotech surgery, mending, crafting, and skill-reroll talents are left as cleaned future-runtime contexts until their owning subsystem exists."
  ],
  "nextRecommendedBatch": {
    "suggestedTheme": "Remaining Force/biotech/social edge cases or any talent tree still carrying migrated generic modifiers/effects after T18.",
    "suggestedAuditQuery": "Scan remaining talents.db for abilityMeta.modifiers and embedded effects outside already-cleaned phase tags."
  }
}
