    {
      "area": "Force Sensitivity legacy hook",
      "files": [
        "scripts/engine/force/ForceRules.js",
        "scripts/utils/force-power-manager.js"
      ],
      "change": "Added ForceRules.forceSensitivityGrantsForcePower() and made ForcePowerManager.handleForceSensitivity respect it.",
      "result": "RAW/default behavior no longer opens a Force Power picker when Force Sensitivity is added outside V2 progression. The old +1 Force Power behavior still works only when the default-off house rule is enabled."
    },
    {
      "area": "Force Training ability modifier",
      "files": [
        "scripts/engine/force/ForceTrainingEngine.js",
        "scripts/apps/progression-framework/steps/force-power-step.js"
      ],
      "change": "Centralized actor-only Force Training slot math on FeatGrantEntitlementResolver and made ForceTrainingEngine read abilities/attributes/stats safely.",
      "result": "Fallback Force Power selection now uses the configured Force Training ability instead of accidentally preferring Charisma whenever a CHA mod exists."
    },
    {
      "area": "Pending ability modifier math",
      "files": [
        "scripts/apps/progression-framework/steps/feat-step.js"
      ],
      "change": "Rewrote pending ability modifier lookup to distinguish already-computed modifiers from ability scores.",
      "result": "Language and other feat entitlements no longer risk converting a pending modifier like +3 into floor((3 - 10) / 2)."
    },
    {
      "area": "Blank prerequisite normalization",
      "files": [
        "packs/feats.db"
      ],
      "change": "Converted blank system.prerequisite strings to None for obvious no-prerequisite feats.",
      "result": "Prerequisite display/parsing is consistent: blank no-prerequisite feats now say None."
    },
    {
      "area": "Metadata category lookup",
      "files": [
        "scripts/apps/chargen/chargen-main.js",
        "scripts/apps/levelup/levelup-feats.js"
      ],
      "change": "Added normalized feat metadata lookup fallback for case/punctuation/apostrophe differences.",
      "result": "Armor Proficiency lowercase variants and Harm's Way curly apostrophe now resolve existing metadata instead of falling into misc/uncategorized in legacy chargen/level-up surfaces."
    }
